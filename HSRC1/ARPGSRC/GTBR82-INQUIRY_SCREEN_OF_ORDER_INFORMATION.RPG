     H            Y.
     F** GDGR82 ************************************
     F*   INQUIRY SCREEN OF ORDER INFORMATION      *
     F*   GDGR81 ----> GDGR82                      *
     F*       MSK.KUNIEDA         2000.11.09       *
     F*  CHANGE   %001   N.HAYAKAWA  2004.01.15    *
     F************************************ GDGR82 **
     FGDGPW82 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL1
     FGDGPL25 IF  E           K        DISK
     FGDIPL25 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
      *
     E                    MSG     1   2 60
      *
     I            DS
     I                                        1   60TIME
     I                                        1   20TIMHH
     I                                        3   40TIMMM
      *
     I            DS
     I                                        1   80HYMD8
     I                                        3   80HYMD6
     I                                        1   40HYY
     I                                        5   60HMM
     I                                        7   80HDD
     I            DS
     I                                        1   6 WKORDR
     I                                        1   2 WKORD1
     I                                        3   4 WKORD2
     I                                        5   6 WKORD3
     I            DS
     I                                        1  15 @HIN
     I                                        1   5 @HIN1
     I                                        6   6 WKF3
     I                                        7  11 @HIN2
     I                                       12  12 WKF4
     I                                       13  14 @HIN3
     I            DS
     I                                        1  15 WKSP
     I                                        1   8 WKKATA
     I                                        1   2 WKKAT1
     I                                        3   6 WKKAT2
     I                                        7   7 WKKAT3
     I                                        8   8 WKKAT4
     I                                        1   5 WKHIN1
     I                                        6  10 WKHIN2
     I                                       11  12 WKHIN3
      *
     I            DS
     I                                        1  11 @KATA
     I                                        1   2 @KAT1
     I                                        3   3 WKFA
     I                                        4   7 @KAT2
     I                                        8   8 WKFB
     I                                        9   9 @KAT3
     I                                       10  10 WKFC
     I                                       11  11 @KAT4
      *
     I            DS
     I                                        1   8 @ODER
     I                                        1   2 @ORD1
     I                                        3   3 WKF1
     I                                        4   5 @ORD2
     I                                        6   6 WKF2
     I                                        7   8 @ORD3
      *
     I            DS
     I                                        1   6 WKDATE
     I                                        1   20@MM
     I                                        3   40@DD
     I                                        5   60@YY
      *
     I            DS
     I                                        1   7 @DINVO
     I                                        1   2 IEINV1
     I                                        3   3 WKF7
     I                                        4   70IEINV2
      *
     I            DS
     I                                        1   8 WODER
     I                                        1   20PORD1
     I                                        3   3 WKF1P
     I                                        4   50PORD2
     I                                        6   6 WKF2P
     I                                        7   80PORD3
      *
     I            DS
     I                                        1   60ODERX
     I                                        1   20XORD1
     I                                        3   40XORD2
     I                                        5   60XORD3
      *
      *----------------------------------------------------*
      *  PARAMETER TRANCFER                                *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PSNO    6
     C                     PARM           PENO    6
     C                     PARM           PNO     1
     C                     PARM           PPART  15
     C                     PARM           PRENCD  1
     C                     PARM           PODER   8
     C                     PARM           PITEM   50
     C                     PARM           PARTN  22
     C                     PARM           POQTY   90
     C                     PARM           PCQTY   60
     C                     PARM           PMBOX   40
     C                     PARM           P@HANY  1
     C                     PARM           P@DLVR  80
      *
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     C           KEYSRH    KLIST
     C                     KFLD           #KODER  60
     C                     KFLD           #KITEM  50
      *
     C           KEYIES    KLIST
     C                     KFLD           #KODER  60
     C                     KFLD           #KITEM  50
     C                     KFLD           #KIKBN  20
 %001C                     KFLD           #KPARE  4
     C                     KFLD           #KINVO  6
      *
     C           KEYIKS    KLIST
     C                     KFLD           #KODER  60
     C                     KFLD           #KITEM  50
     C                     KFLD           #KIKBN  20
 %001C                     KFLD           #KPARE  4
     C                     KFLD           #KBXNO  40
     C                     KFLD           #KINVO  6
      *
     C           KEYF81    KLIST
     C                     KFLD           #KHY    40
     C                     KFLD           #KHM    20
     C                     KFLD           #KHD    20
      *----------------------------------------------------*
      *  MAIN                                            *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           *IN03     DOWEQ'0'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      *    INI. PROCESS                                    *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     TIME           TIME
     C                     Z-ADD*DATE     HYMD8
     C                     MOVE *BLANK    DSPSW1  1
     C                     MOVE *BLANK    DSPSW2  1
     C                     MOVE *BLANK    DSPSW3  1
     C                     Z-ADD0         X       10
      *
     C                     MOVE PODER     WODER
     C                     MOVE PNO       X
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVELMSG,X     @TYPE
     C                     MOVE PSNO      WKORDR
     C                     MOVE WKORD1    @ORD1
     C                     MOVE WKORD2    @ORD2
     C                     MOVE WKORD3    @ORD3
     C                     MOVE @ODER     @ODER1
     C                     MOVE PENO      WKORDR
     C                     MOVE WKORD1    @ORD1
     C                     MOVE WKORD2    @ORD2
     C                     MOVE WKORD3    @ORD3
     C                     MOVE @ODER     @ODER2
     C                     MOVE *BLANK    @ODER
      *
     C                     MOVE PODER     @HODR
     C                     MOVE PITEM     @HITEM
     C                     MOVELPARTN     @HPART
     C                     MOVE PCQTY     @HSYS
     C                     MOVE PMBOX     @HBOX
     C                     MOVE POQTY     @HQTY
     C                     MOVE P@HANY    @HANYK
     C                     Z-ADDP@DLVR    @DLVR
     C                     Z-ADD0         ODERX
     C                     Z-ADDPORD1     XORD1
     C                     Z-ADDPORD2     XORD2
     C                     Z-ADDPORD3     XORD3
     C                     MOVE ODERX     #KODER
     C                     MOVE PITEM     #KITEM
      *
     C                     SETOF                     10
     C           PPART     IFNE *BLANK
     C                     SETON                     10
     C                     MOVE PPART     WKSP
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVE '-'       WKF3
     C                     MOVE '-'       WKF4
     C                     MOVE '-'       WKF7
     C                     MOVE '-'       WKFA
     C                     MOVE '-'       WKFB
     C                     MOVE '-'       WKFC
     C           PNO       IFEQ '1'
      *
     C                     MOVE WKHIN1    @HIN1
     C                     MOVE WKHIN2    @HIN2
     C                     MOVE WKHIN3    @HIN3
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WKF4
     C                     END
     C                     MOVE @HIN      @HPART
      *
     C                     END
      *
     C           PNO       IFEQ '2'
     C                     MOVE WKKAT4    @KAT4
     C                     MOVE WKKAT3    @KAT3
     C                     MOVE WKKAT2    @KAT2
     C                     MOVE WKKAT1    @KAT1
     C           @KAT4     IFEQ *BLANK
     C                     MOVE *BLANK    WKFB
     C                     MOVE *BLANK    WKFC
     C                     END
     C                     MOVEL@KATA     @HPART
     C                     END
     C                     END
      *SFL1 CLEAR
     C                     SETON                     71
     C                     WRITESREC1
     C                     SETOF                     71
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         WKPAGE  20
     C                     Z-ADD1         @SFRC1
      *
     C                     MOVE '1'       DSPSW1
     C                     MOVE '0'       DSPSW2
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   MAIN PROCESS                                   *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
     C           *IN03     DOWEQ'0'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR $SB210
     C                     END
      *
     C           *IN03     DOWEQ'0'
     C           DSPSW2    ANDEQ'1'
     C                     EXSR $SB220
     C                     END
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   DATA READ                                      *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
      *--------------------*
      * PART & WASHER      *
      *--------------------*
     C           PNO       IFEQ '1'
     C           KEYSRH    SETLLGDGPL251
     C                     SETOF                     8166
     C                     DO   *HIVAL
     C           KEYSRH    READEGDGPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IESKJY    ANDEQ'D'
     C           IESKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     EXSR $SB400
     C                     END
     C  N81N66             END
     C           CTRX      IFEQ 0
     C                     SETON                     9903
     C                     MOVE 'E'       PRENCD
     C                     GOTO $S210E
     C                     END
      *
     C                     EXSR $SB900
     C                     END
      *
      *--------------------*
      * TOOL               *
      *--------------------*
     C           PNO       IFEQ '2'
     C           KEYSRH    SETLLGDIPL251
     C                     SETOF                     8166
     C                     DO   *HIVAL
     C           KEYSRH    READEGDIPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IKSKJY    ANDEQ'D'
     C           IKSKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     EXSR $SB401
     C                     END
     C  N81N66             END
     C           CTRX      IFEQ 0
     C                     SETON                     9903
     C                     MOVE 'E'       PRENCD
     C                     GOTO $S210E
     C                     END
      *
     C                     EXSR $SB901
     C                     END
      *
     C                     MOVE '1'       DSPSW2
     C                     MOVE '0'       DSPSW1
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   1ST SCREEN    (SFL.GDGPW828,GDGPW829)            *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
     C                     SETON                     70
     C                     WRITEGDGPW828
     C                     WRITEGDGPW829
     C                     EXFMTSREC1
     C                     SETOF                     70
      * CMD-3
     C           *IN03     IFEQ '1'
     C                     MOVE *BLANK    PRENCD
     C                     EXSR $SB410
     C                     GOTO $S220E
     C                     END
      * ROLLDOWN
     C           *IN52     IFEQ '1'
     C                     ADD  1         CTRX
      *
     C           WKPAGE    IFEQ 1
     C                     GOTO $S220E
     C                     END
      *
     C           *IN81     IFEQ '1'
     C                     SETOF                       81
     C           PNO       IFEQ '1'
     C           KEYSRH    SETGTGDGPL251
     C                     END
      *
     C           PNO       IFEQ '2'
     C           KEYSRH    SETGTGDIPL251
     C                     END
     C                     END
      *
     C                     ADD  5         CTRX
     C                     SETOF                     66
      *
     C           PNO       IFEQ '1'
     C                     DO   *HIVAL
     C           KEYSRH    REDPEGDGPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IESKJY    ANDEQ'D'
     C           IESKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     SUB  1         CTRX         6666
     C                     END
     C  N81N66             END
     C                     END
      *
     C           PNO       IFEQ '2'
     C                     DO   *HIVAL
     C           KEYSRH    REDPEGDIPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IKSKJY    ANDEQ'D'
     C           IKSKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     SUB  1         CTRX         6666
     C                     END
     C  N81N66             END
     C                     END
      *
      *カウンタクリア
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C                     SETOF                       81
     C           PNO       IFEQ '1'
     C           KEYSRH    SETLLGDGPL251
     C                     END
     C           PNO       IFEQ '2'
     C           KEYSRH    SETLLGDIPL251
     C                     END
     C                     END
      *サブファイルクリアー
     C                     SETON                     71
     C                     WRITESREC1
     C                     SETOF                     71
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      * PART & WASHER
     C           PNO       IFEQ '1'
     C                     SETOF                         66
     C                     DO   *HIVAL
     C           KEYSRH    READEGDGPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IESKJY    ANDEQ'D'
     C           IESKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     EXSR $SB400
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB900
     C                     SUB  1         WKPAGE
     C                     END
      * TOOL
     C           PNO       IFEQ '2'
     C                     SETOF                         66
     C                     DO   *HIVAL
     C           KEYSRH    READEGDIPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IKSKJY    ANDEQ'D'
     C           IKSKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     EXSR $SB401
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB901
     C                     SUB  1         WKPAGE
     C                     END
     C                     END
      * ROLL-UP
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
     C                     SETON                       71
     C                     WRITESREC1
     C                     SETOF                       7166
      * PART & WASHER
     C           PNO       IFEQ '1'
     C                     SETOF                         66
     C                     DO   *HIVAL
     C           KEYSRH    READEGDGPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IESKJY    ANDEQ'D'
     C           IESKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     EXSR $SB400
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB900
     C                     ADD  1         WKPAGE
     C                     END
      * TOOL
     C           PNO       IFEQ '2'
     C                     SETOF                         66
     C                     DO   *HIVAL
     C           KEYSRH    READEGDIPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IKSKJY    ANDEQ'D'
     C           IKSKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     EXSR $SB401
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB901
     C                     ADD  1         WKPAGE
     C                     END
     C                     END
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   INQUIRY SCREEN ITEM SET (PART & WASHER)        *
      *----------------------------------------------------*
     CSR         $SB400    BEGSR
      *
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
      *
     C                     MOVE '-'       WKF7
     C                     MOVELIEINVO    IEINV1  2
     C                     MOVE IEINVO    IEINV2  40
     C           IEINV1    IFEQ *BLANK
     C           IEINV2    ANDEQ0
     C                     MOVE *BLANK    @DINVO
     C                     END
     C                     MOVE IEPARE    @DPALN
     C                     MOVE IESKOY    @YY
     C                     MOVE IESKOM    @MM
     C                     MOVE IESKOD    @DD
     C                     MOVE WKDATE    @DSHPD
     C                     Z-ADDIESURY    @DSHPQ
     C                     Z-ADDIESYOS    @DSYS
     C                     Z-ADDIESBOX    @DBOX
     C                     MOVE IESKOY    #KHY
     C                     MOVE IESKOM    #KHM
     C                     MOVE IESKOD    #KHD
     C                     MOVE *BLANK    @HANY
     C                     SETOF                         20
     C           KEYF81    SETLLAGDPL121
     C           IEHANY    IFEQ 'S'
     C                     MOVE 'SHIP'    @HANY
     C                     Z-ADD22        A       20
     C                     ELSE
     C                     MOVE ' AIR'    @HANY
     C                     Z-ADD4         A       20
     C                     END
      * IAF ARRIVAL DATE GET
%0001C           IEHANY    IFEQ 'S'
  |  C                     Z-ADDIETOYY    @YY
  |  C                     Z-ADDIETOYM    @MM
  |  C                     Z-ADDIETOYD    @DD
%0001C                     ELSE
     C                     DO   A
     C                     READ AGDPL12                  20
     C                     ENDDO
     C                     Z-ADDF8KAYY    @YY
     C                     Z-ADDF8KAMM    @MM
     C                     Z-ADDF8KADD    @DD
%0001C                     END
     C                     MOVE WKDATE    @DDATE
     C                     MOVE IENYUY    @YY
     C                     MOVE IENYUM    @MM
     C                     MOVE IENYUD    @DD
     C                     MOVE WKDATE    @DRDAT
      *
     C                     WRITESFL1
      *
     C           CTRX      IFEQ 05
     C                     SETON                       66
     C                     END
      *
     CSR         $S400E    ENDSR
      *----------------------------------------------------*
      *   INQUIRY SCREEN ITEM SET (TOOL)                 *
      *----------------------------------------------------*
     CSR         $SB401    BEGSR
      *
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
      *
     C                     MOVE '-'       WKF7
     C                     MOVELIKINVO    IEINV1  2
     C                     MOVE IKINVO    IEINV2  40
     C           IEINV1    IFEQ *BLANK
     C           IEINV2    ANDEQ0
     C                     MOVE *BLANK    @DINVO
     C                     END
     C                     MOVE IKPARE    @DPALN
     C                     MOVE IKBXNO    @DBOXN
     C                     MOVE IKSKOY    @YY
     C                     MOVE IKSKOM    @MM
     C                     MOVE IKSKOD    @DD
     C                     MOVE WKDATE    @DSHPD
     C                     Z-ADDIKSURY    @DSHPQ
     C                     Z-ADDIKSYOS    @DSYS
     C                     Z-ADDIKSBOX    @DBOX
     C                     MOVE IKSKOY    #KHY
     C                     MOVE IKSKOM    #KHM
     C                     MOVE IKSKOD    #KHD
     C                     MOVE *BLANK    @HANY
     C                     SETOF                         20
     C           KEYF81    SETLLAGDPL121
     C           IKHANY    IFEQ 'S'
     C                     MOVE 'SHIP'    @HANY
     C                     Z-ADD22        A       20
     C                     ELSE
     C                     MOVE ' AIR'    @HANY
     C                     Z-ADD4         A       20
     C                     END
      * IAF ARRIVAL DATE GET
%0001C           IEHANY    IFEQ 'S'
  |  C                     Z-ADDIKTOYY    @YY
  |  C                     Z-ADDIKTOYM    @MM
  |  C                     Z-ADDIKTOYD    @DD
%0001C                     ELSE
     C                     DO   A
     C                     READ AGDPL12                  20
     C                     ENDDO
     C                     Z-ADDF8KAYY    @YY
     C                     Z-ADDF8KAMM    @MM
     C                     Z-ADDF8KADD    @DD
%0001C                     END
     C                     MOVE WKDATE    @DDATE
     C                     MOVE IKNYUY    @YY
     C                     MOVE IKNYUM    @MM
     C                     MOVE IKNYUD    @DD
     C                     MOVE WKDATE    @DRDAT
      *
     C                     WRITESFL1
      *
     C           CTRX      IFEQ 05
     C                     SETON                       66
     C                     END
      *
      *
     CSR         $S401E    ENDSR
      *----------------------------------------------------*
      *   表示項目クリアー                               *
      *----------------------------------------------------*
     CSR         $SB410    BEGSR
     C                     MOVE '0'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     MOVE '0'       DSPSW3
     C                     SETON                     71
     C                     WRITESREC1
     C                     SETOF                     71
     C                     Z-ADD0         RRN
     CSR         $S410E    ENDSR
      *----------------------------------------------------*
      *    NEXT POINTER SETR (PART & WASHER)               *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
      *
     C                     SETOF                         68
     C                     DO   *HIVAL
     C           KEYSRH    READEGDGPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IESKJY    ANDEQ'D'
     C           IESKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     MOVE IEODER    #KODER
     C                     MOVE IEITEM    #KITEM
     C                     MOVE IEIKBN    #KIKBN
     C                     MOVE IEPARE    #KPARE
     C                     MOVE IEINVO    #KINVO
     C                     SETON                         68
     C                     END
     C  N81N68             END
      *
     C           KEYIES    SETLLGDGPL251
      *
     CSR         $S900E    ENDSR
      *----------------------------------------------------*
      *    NEXT POINTER SETR (TOOL)                        *
      *----------------------------------------------------*
     CSR         $SB901    BEGSR
      *
     C                     SETOF                         68
     C                     DO   *HIVAL
     C           KEYSRH    READEGDIPL251                 81
     C                     SETOF                       67
     C           *IN81     IFEQ '0'
     C           IKSKJY    ANDEQ'D'
     C           IKSKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     MOVE IKODER    #KODER
     C                     MOVE IKITEM    #KITEM
     C                     MOVE IKIKBN    #KIKBN
     C                     MOVE IKPARE    #KPARE
     C                     MOVE IKBXNO    #KBXNO
     C                     MOVE IKINVO    #KINVO
     C                     SETON                         68
     C                     END
     C  N81N68             END
      *
     C           KEYIKS    SETLLGDIPL251
      *
     CSR         $S901E    ENDSR
**
PART & WASHER
TOOL
