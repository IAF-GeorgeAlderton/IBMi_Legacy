     FAL#PL77 UF  E           K        DISK
     FAL#PP21 IF  E           K        DISK
     FAL#PR7J O   E             55     PRINTER
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   60STIME
     I                                        7  140SDATE
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           P1STS   1
      *
     C                     TIME           WTIME
     C                     MOVEL'0'       P1STS
      *
     C****                 EXSR #SB100
     C                     SETON                     55
     C                     Z-ADD0         KKNKHZ  80
     C                     MOVEL*BLANK    SVNAMC  5
     C                     MOVEL*BLANK    SVDOCK  2
     C                     MOVEL*BLANK    SVMHN  12
     C           KKNKHZ    SETLLAL#PL771
     C           KKNKHZ    READEAL#PL771                 80
     C           *IN80     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     EXSR #SB100
     C                     ENDIF
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLESDATE
     C                     ELSE
     C                     MOVEL'1'       P1STS
     C           L7NAMC    IFEQ SVNAMC
     C           L7DOCK    ANDEQSVDOCK
     C           L7MHN     ANDEQSVMHN
     C                     ELSE
     C                     EXSR #SB400
     C                     MOVELL7NAMC    SVNAMC  5
     C                     MOVELL7DOCK    SVDOCK  2
     C                     MOVELL7MHN     SVMHN  12
     C                     ENDIF
     C                     Z-ADDSDATE     L7NKHZ
     C                     Z-ADDSTIME     L7NKTI
     C                     UPDATAL#PL771
     C                     ENDIF
     C           KKNKHZ    READEAL#PL771                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVELWTIYY     P1DAYY
     C                     MOVELWTIMM     P1DAMM
     C                     MOVELWTIDD     P1DADD
     C                     MOVELTIMHH     P1TIHH
     C                     MOVELTIMMM     P1TIMM
     C                     MOVELTIMSS     P1TISS
     C                     MOVEL*ALL'-'   P1LIN
     C                     WRITEAL#PR7J1
     C                     SETOF                     55
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL*BLANK    P2LOC
     C           P2LOC     CAT  L7LOC1:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  L7LOC2:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  L7LOC3:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  L7LOC4:0  P2LOC
      *
     C                     MOVEL*BLANK    P2TOKU
     C                     MOVEL*BLANK    P2NONY
     C                     MOVEL*BLANK    P2NKOJ
     C           L7NAMC    CHAINAL#PP211             26
     C           *IN26     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
     C           *IN26     IFEQ '0'
     C                     MOVELC2TOKU    P2TOKU
     C                     MOVELC2NONY    P2NONY
     C                     MOVELC2NKOJ    P2NKOJ
     C                     ENDIF
     C                     MOVELL7DOCK    P2DOCK
      *
     C                     MOVELL7KNB#    P2KNB#
     C           5         SUBSTL7MHN:1   WKMHN1  5
     C           5         SUBSTL7MHN:6   WKMHN2  5
     C           2         SUBSTL7MHN:11  WKMHN3  2
     C                     MOVEL*BLANK    P2MHN
     C           P2MHN     CAT  WKMHN1:0  P2MHN
     C           P2MHN     CAT  '-':0     P2MHN
     C           P2MHN     CAT  WKMHN2:0  P2MHN
     C           WKMHN3    IFNE *BLANK
     C           P2MHN     CAT  '-':0     P2MHN
     C           P2MHN     CAT  WKMHN3:0  P2MHN
