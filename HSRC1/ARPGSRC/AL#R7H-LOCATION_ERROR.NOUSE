     H            Y.
     F** AL#R7H *********************************************
     F* LOCATION ERROR
     F*              ITS.        2015.05.13                 *
     F*******************************************************
     FAL#WP77 IF  E           K        DISK
     FAL#PP21 IF  E           K        DISK
     FAL#PR7H O   E             55     PRINTER
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140SDATE
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
      *
     C                     EXSR #SB100
     C                     READ AL#WP771                 80
     C           *IN80     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     EXSR #SB100
     C                     ENDIF
     C                     EXSR #SB400
     C                     READ AL#WP771                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVELWTIYY     P1DAYY
     C                     MOVELWTIMM     P1DAMM
     C                     MOVELWTIDD     P1DADD
     C                     MOVELTIMHH     P1TIHH
     C                     MOVELTIMMM     P1TIMM
     C                     MOVELTIMSS     P1TISS
     C                     MOVEL*ALL'-'   P1LIN
     C                     WRITEAL#PR7H1
     C                     SETOF                     55
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL*BLANK    P2LOC
     C           P2LOC     CAT  W7LOC1:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  W7LOC2:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  W7LOC3:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  W7LOC4:0  P2LOC
      *
     C                     MOVEL*BLANK    P2TOKU
     C                     MOVEL*BLANK    P2NONY
     C                     MOVEL*BLANK    P2NKOJ
     C           W7NAMC    CHAINAL#PP211             26
     C           *IN26     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
     C           *IN26     IFEQ '0'
     C                     MOVELC2TOKU    P2TOKU
     C                     MOVELC2NONY    P2NONY
     C                     MOVELC2NKOJ    P2NKOJ
     C                     ENDIF
     C                     MOVELW7DOCK    P2DOCK
      *
     C                     MOVELW7KNB#    P2KNB#
     C           5         SUBSTW7MHN:1   WKMHN1  5
     C           5         SUBSTW7MHN:6   WKMHN2  5
     C           2         SUBSTW7MHN:11  WKMHN3  2
     C                     MOVEL*BLANK    P2MHN
     C           P2MHN     CAT  WKMHN1:0  P2MHN
     C           P2MHN     CAT  '-':0     P2MHN
     C           P2MHN     CAT  WKMHN2:0  P2MHN
     C           WKMHN3    IFNE *BLANK
     C           P2MHN     CAT  '-':0     P2MHN
     C           P2MHN     CAT  WKMHN3:0  P2MHN
     C                     ENDIF
     C                     MOVEL*BLANK    P2SHN
     C           P2SHN     CAT  W7SHN1:0  P2SHN
     C           P2SHN     CAT  '-':0     P2SHN
     C           P2SHN     CAT  W7SHN2:0  P2SHN
     C           W7SHN3    IFNE *BLANK
     C           P2SHN     CAT  '-':0     P2SHN
     C           P2SHN     CAT  W7SHN3:0  P2SHN
     C                     ENDIF
     C                     MOVEL*BLANK    P2TKR
     C           P2TKR     CAT  W7TKR1:0  P2TKR
     C           P2TKR     CAT  '-':0     P2TKR
     C           P2TKR     CAT  W7TKR2:0  P2TKR
     C           P2TKR     CAT  '-':0     P2TKR
     C           P2TKR     CAT  W7TKR3:0  P2TKR
     C           P2TKR     CAT  '-':0     P2TKR
     C           P2TKR     CAT  W7TKR4:0  P2TKR
      *
     C                     MOVEL*ALL'-'   P2LIN
     C                     WRITEAL#PR7H2
      *
     CSR         ESB400    ENDSR
