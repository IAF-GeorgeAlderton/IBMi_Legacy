     I                                        5   60WWSIMM
     I                                        7   80WWSIDD
     I*
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C*
     C                     Z-ADD*DATE     WWDATE
     C                     Z-ADDWWDAYY    OODAYY
     C                     Z-ADDWWDAMM    OODAMM
     C                     Z-ADDWWDADD    OODADD
     C                     MOVEL*ALL'-'   LIN60  60
     C                     Z-ADD0         D1MMYY
     C                     MOVE *OFF      *IN11
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           @LOP      TAG
     C*
     C                     WRITEDSP02
     C                     EXFMTDSP01
     C                     MOVE *OFF      *IN11
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C   KA                GOTO @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABNE*OFF      @LOP
     C*
B01  C           *INKE     IFEQ *ON
     C*
     C                     MOVE *BLANK    WWVEND  4
     C                     MOVE *BLANK    WWINVO  6
     C                     Z-ADD0         WWKIN  110
     C                     Z-ADD0         WWDOLL  72
     C                     Z-ADD0         WWSIHZ  80
     C                     MOVE *OFF      *IN20
     C                     Z-ADDD1YY      W1YY
     C                     Z-ADDD1MM      W1MM
     C                     EXSR #CLR
     C           *LOVAL    SETLLGDKPL081
     C*
B02  C                     DO   *HIVAL
     C                     READ GDKPL081                 30
     C   30                LEAVE
     C           ITUKYM    COMP W1YYMM               3131
     C   31                ITER
     C*
B03  C           *IN20     IFEQ *OFF
     C                     MOVELITINVO    WWINVO
     C                     Z-ADDITSIHZ    WWSIHZ
E03  C                     ENDIF
     C*
B03  C           ITVEND    IFNE WWVEND
B04  C           *INOF     IFEQ *ON
     C                     EXCPTHED
     C                     MOVE *OFF      *INOF
E04  C                     ENDIF
B04  C           OOKIN     IFNE 0
 04  C           OORATE    ORNE 0
 04  C           OODOLL    ORNE 0
     C                     EXCPTDTL
E04  C                     ENDIF
     C                     ADD  OOKIN     WWKIN
     C                     ADD  OODOLL    WWDOLL
     C                     EXSR #CLR
     C   20                EXCPTTTL1
     C                     MOVELITVEND    WWVEND
     C                     MOVEL*BLANK    OOVNAM 20
     C                     MOVELWWVEND    B2CODE
     C           B2CODE    CHAINFGBPL011             31
     C  N31                MOVELB2SMEI    OOVNAM
     C                     EXCPTHED
     C                     MOVE *OFF      *INOF
     C                     MOVELITINVO    WWINVO
     C                     Z-ADDITRATE    OORATE
     C                     Z-ADD0         WWKIN
     C                     Z-ADD0         WWDOLL
     C                     Z-ADDITSIHZ    WWSIHZ
     C                     MOVE *ON       *IN20
E03  C                     ENDIF
     C*
B03  C           ITINVO    IFNE WWINVO
B04  C           *INOF     IFEQ *ON
     C                     EXCPTHED
     C                     MOVE *OFF      *INOF
E04  C                     ENDIF
B04  C           OOKIN     IFNE 0
 04  C           OORATE    ORNE 0
 04  C           OODOLL    ORNE 0
     C                     EXCPTDTL
E04  C                     ENDIF
     C                     ADD  OOKIN     WWKIN
     C                     ADD  OODOLL    WWDOLL
     C                     EXSR #CLR
     C                     ADD  ITKIN     OOKIN
     C                     Z-ADDITRATE    OORATE
     C                     ADD  ITDOLL    OODOLL
X03  C                     ELSE
     C                     ADD  ITKIN     OOKIN
     C                     ADD  ITDOLL    OODOLL
E03  C                     ENDIF
     C*
     C                     MOVELITVEND    WWVEND
     C                     MOVELITINVO    WWINVO
     C*
E02  C                     ENDDO
     C*
B02  C           *IN20     IFEQ *ON
     C           OOKIN     IFNE 0
     C           OORATE    ORNE 0
     C           OODOLL    ORNE 0
     C                     EXCPTDTL
     C                     ENDIF
     C                     ADD  OOKIN     WWKIN
     C                     ADD  OODOLL    WWDOLL
     C                     EXCPTTTL1
E02  C                     ENDIF
     C*
     C                     GOTO @END
     C*
E01  C                     ENDIF
     C*
     C                     GOTO @LOP
     C*
     C           @END      TAG
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*
     C****************************************************************
     C*          #CHK01    INPUT-DATA CHECK
     C****************************************************************
     C           #CHK01    BEGSR
     C*
B01  C           D1YY      IFEQ 0
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     9911
E01  C                     END
B01  C           D1MM      IFLT 1
 01  C           D1MM      ORGT 12
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     9911
E01  C                     END
     C*
     C                     ENDSR
     C****************************************************************
     C*          #CLR      FIELD CLEAR
     C****************************************************************
     C           #CLR      BEGSR
     C*
     C                     MOVEA'00'      *IN,22
     C*
     C                     Z-ADD0         OOKIN  110
     C                     Z-ADD0         OORATE  82
     C                     Z-ADD0         OODOLL  72
     C*
     C                     ENDSR
     C****************************************************************
     O****************************************************************
     OQPRINT  E   01           HED
     O                                    7 'GDKR12'
     O                                   34 'PAYMENT'
     O                                   41 'AMOUNT'
     O                                   51 'BREAKDOWN'
     O                                   57 'TABLE'
     O                         OODATE    88 '  .  .    '
     O                                   94 'PAGE'
     O                         PAGE  Z   98
     O        E   02           HED
     O                                   92 'INDIANA AUTOMOTIVE'
     O        E   03           HED
     O                         D1MMYY    44 '  /    '
     O                                   89 'FASTENERS,INC'
     O        E   04           HED
     O                                    8 'VENDOR'
     O        E   05           HED
     O                         ITVEND     7
     O                         OOVNAM  +  2
     O        E   08           HED
     O                                   26 'INVOICE NO.'
     O                                   44 'AMOUNT(YEN)'
     O                                   56 'RATE'
     O                                   75 'AMOUNT(DOLLAR)'
     O        E   0910         HED
     O                         LIN60     75
     C**
     O        E  1             DTL
     O                         WWINVO    24
     O                         OOKIN 1   44
     O                         OORATE    56 '   , 0 .  '
     O                         OODOLL    75 '  , 0 .  '
     O        E 1              TTL1
     O                                   28 'VENDOR TOTAL'
