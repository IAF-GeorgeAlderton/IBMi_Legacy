     H            Y.
     F***CHKR38*****************************************************************
     F*  PROGRAM    : CHECK DUPLICATE ORDERS (AB#PP2A)                         *
     F*             : READ AB#PL2R                                             *
     F*  WRITTEN    : 12/7/2018                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2R UF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *IN98     DOWEQ*OFF
     C                     READ AB#PL2R                  98
     C           *IN98     IFEQ *OFF
     C           ACUPID    ANDEQ' '
     C           ACQNTY    ANDNE0
      * CHAIN
     C           ACPLSH    IFEQ SVPLSH
     C           ACNONY    ANDEQSVNONY
     C           ACNKOJ    ANDEQSVNKOJ
     C           ACNUKE    ANDEQSVNUKE
     C           ACBIN     ANDEQSVBIN
     C           ACODRN    ANDEQSVODRN
     C           ACMHIN    ANDEQSVMHIN
     C           ACPLSH    ANDGTTODAY
     C                     EXSR #PRINT
      * DELETE DUPLICATE ORDER
     C           $UPD      IFEQ 'Y'
     C                     MOVE 'D'       ACUPID
     C                     MOVEL#PGM      ACAUTH    P
     C                     UPDATAB#PP2A1
     C                     ENDIF
      *
     C                     ELSE
     C                     Z-ADDACPLSH    SVPLSH
     C                     Z-ADDACTOKU    SVTOKU
     C                     Z-ADDACNONY    SVNONY
     C                     MOVELACNKOJ    SVNKOJ
     C                     MOVELACNUKE    SVNUKE
     C                     Z-ADDACBIN     SVBIN
     C                     MOVELACODRN    SVODRN
     C                     MOVELACMHIN    SVMHIN
     C                     Z-ADDACCRDT    SVCRDT
     C                     Z-ADDACKTIM    SVKTIM
     C                     Z-ADDACQNTY    SVQNTY
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         SVPLSH  80
     C                     Z-ADD0         SVTOKU  40
     C                     Z-ADD0         SVNONY  40
     C                     MOVE *BLANK    SVNKOJ  1
     C                     MOVE *BLANK    SVNUKE  4
     C                     Z-ADD0         SVBIN   20
     C                     MOVE *BLANK    SVODRN 20
     C                     Z-ADD0         SVQNTY  70
     C                     MOVE *BLANK    SVMHIN 20
     C                     Z-ADD0         SVCRDT  80
     C                     Z-ADD0         SVKTIM  60
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   19 'UPD_FLG='
     O                         $UPD      21
     O                                   45 '** DUPLICATE ORDER R'
     O                                   65 'EPORT (AB#PP2A) **  '
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   31 'SHP_DATE'
     O                                   36 'BN'
     O                                   46 'USER_PART'
     O                                   64 'ORDER#'
     O                                   88 'QTY'
     O                                   97 'CRT_DATE'
     O                                  108 'CRT_TIME'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         SVTOKU  +001
     O                         SVNONY  +001
     O                         SVNKOJ  +001
     O                         SVNUKE  +001
     O                         SVPLSH  +001 '    /  /  '
     O                         SVBIN   +001
     O                         SVMHIN  +001
     O                         SVODRN  +001
     O                         SVQNTY1 +001
     O                         SVCRDT  +001 '    /  /  '
     O                         SVKTIM  +001 '0 :  :  '
