     H            Y.                                    1
      ** GDLR1C ********************************************
      *  MATERIAL ORDER DATA CREATE FOR O&K(4511)          *
      *                                 NSCI(4530)         *
      *    GET # OF JULIAN WEEK                            *
      *                                                    *
      *  TCHK1  04/08/06 CREATE                            *
      ******************************************** GDLR1C **
     FAGDPL12 IF  E           K        DISK
     E*
     E                    DS         60  8 0
     E                    DE         60  8 0
     I*
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  140W@TODY
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
     I            DS
     I                                        1   80W8KADT
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@WCNT  20
     C                     PARM           P@WYMD  8
     C                     Z-ADD*ZERO     P@WCNT
     C*
     C           P@WYMD    IFEQ *BLANK
     C                     TIME           W@TIME
     C                     ELSE
     C                     MOVELP@WYMD    W@TODY
     C                     END
     C                     CLEARDS
     C                     CLEARDE
     C*
     C           KEY1      KLIST
     C                     KFLD           K@YYYY  40
     C                     KFLD           K@MMMM  20
     C                     KFLD           K@DDDD  20
     C                     Z-ADDW@DY      K@YYYY
     C                     Z-ADD01        K@MMMM
     C                     Z-ADD01        K@DDDD
     C*
     C                     Z-ADD*ZERO     X       30
     C                     DO
     C*
     C           KEY1      CHAINAGDPL12              99
     C   99                LEAVE
     C*
     C                     ADD  1         X
     C           F8YOBI    IFEQ 6
     C                     Z-ADDW8KADT    DS,X
     C                     Z-ADDW8KADT    DE,X
     C                     ELSE
     C                     DO   *HIVAL
     C           W@DY      READEAGDPL12                  99
     C   99                LEAVE
     C           F8YOBI    IFEQ 6
     C                     Z-ADDW8KADT    DE,X
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C   99                LEAVE
     C*
     C                     DO   *HIVAL
     C           W@DY      READEAGDPL12                  98
     C   98                LEAVE
     C           F8YOBI    IFEQ 7
     C                     ADD  1         X
     C                     Z-ADDW8KADT    DS,X
     C                     DO   *HIVAL
     C           W@DY      READEAGDPL12                  97
     C           *IN97     IFEQ *ON
     C                     Z-ADDW@DY      F8KAYY
     C                     Z-ADD12        F8KAMM
     C                     Z-ADD31        F8KADD
     C                     Z-ADDW8KADT    DE,X
     C                     LEAVE
     C                     END
     C           F8YOBI    IFEQ 6
     C                     Z-ADDW8KADT    DE,X
     C                     LEAVE
     C                     END
     C                     ENDDO
     C   97                LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     Z-ADD*ZERO     X
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 60
     C                     LEAVE
     C                     END
     C           W@TODY    IFGE DS,X
     C           W@TODY    ANDLEDE,X
     C                     Z-ADDX         P@WCNT
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
