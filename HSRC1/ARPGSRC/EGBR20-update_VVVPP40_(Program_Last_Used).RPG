     H            Y.
     F** EGBR20 ********************************************
     F*  UPDATE VVVPP40 (PROGRAM/LAST USED)                *
     F*  J.WATALIB    2020.04.09                           *
     F******************************************************
     FEGBPL13 IF  E           K        DISK
     FVVVPP40 UF  E           K        DISK
      ******************************************************
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   6 ODCDAT
     I                                        1   2 CMM
     I                                        3   4 CDD
     I                                        5   6 CYY
     I            DS
     I                                        1   6 ODUDAT
     I                                        1   2 LMM
     I                                        3   4 LDD
     I                                        5   6 LYY
     I            DS
     I                                        1   6 WKUDAT
     I                                        1   2 WYY
     I                                        3   4 WMM
     I                                        5   6 WDD
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      * MAIN ROUTINE
      ******************************************************
     C                     EXSR #INIT
     C*
     C                     DO   *HIVAL
     C                     READ EGBPL13                  98
     C   98                LEAVE
      *
     C           MLSKJY    IFEQ 'D'
     C           MLPGMN    OREQ *BLANK
     C                     ITER
     C                     ENDIF
      * FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVELMLPGMN    SVPGMN  6
     C                     MOVE 'N'       FIRST
     C                     ENDIF
      * BREAK ?
     C           MLPGMN    IFNE SVPGMN
     C                     EXSR #BREAK
     C                     ENDIF
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BREAK
     C                     ENDIF
      * ADJUST LAST USED DATE
     C                     EXSR #ADJ
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* BREAK
     C*===============================================================
     C           #BREAK    BEGSR
     C*
     C                     MOVELSVPGMN    LTR10  10
     C           LTR10     CHAINVVVPP40              99
     C           *IN99     IFEQ *OFF
     C                     MOVE 'Y'       V1FLG
     C**                   Z-ADDTODAY     V1CRHZ
     C**                   Z-ADDNOW       V1CRTM
     C**                   MOVEL#USER     V1CRUS
      *
     C**         ODUDAT    IFEQ *BLANK
     C**                   Z-ADD0         V1LSHZ
     C**                   ELSE
     C**                   MOVELLYY       WYY
     C**                   MOVELLMM       WMM
     C**                   MOVELLDD       WDD
     C**                   Z-ADD20000000  V1LSHZ
     C**                   MOVE WKUDAT    V1LSHZ
     C**                   ENDIF
      *
     C                     UPDATVVVPP401
     C                     ENDIF
      * RESET
     C                     MOVELMLPGMN    SVPGMN
      *
     C                     ENDSR
     C*===============================================================
     C* ADJUST
     C*===============================================================
     C           #ADJ      BEGSR
      *
     C           *LOVAL    SETLLVVVPP40
     C                     DO   *HIVAL
     C                     READ VVVPP40                  97
     C   97                LEAVE
      *
     C**         ODUDAT    IFEQ *BLANK
     C**         V1LSHZ    ORNE 0
     C**                   ITER
     C**                   ENDIF
      * LAST USED
     C           ODUDAT    IFEQ *BLANK
     C                     Z-ADD0         V1LSHZ
     C                     ELSE
     C                     MOVELLYY       WYY
     C                     MOVELLMM       WMM
     C                     MOVELLDD       WDD
     C           WYY       IFGE '50'
     C                     Z-ADD19000000  V1LSHZ
     C                     ELSE
     C                     Z-ADD20000000  V1LSHZ
     C                     ENDIF
     C                     MOVE WKUDAT    V1LSHZ
     C                     ENDIF
      * CREATE DATE
     C           ODCDAT    IFEQ *BLANK
     C                     Z-ADD0         V1CRHZ
     C                     Z-ADD0         V1CRTM
     C                     ELSE
     C                     MOVELCYY       WYY
     C                     MOVELCMM       WMM
     C                     MOVELCDD       WDD
     C           WYY       IFGE '50'
     C                     Z-ADD19000000  V1CRHZ
     C                     ELSE
     C                     Z-ADD20000000  V1CRHZ
     C                     ENDIF
     C                     MOVE WKUDAT    V1CRHZ
     C                     MOVE ODCTIM    V1CRTM
     C                     ENDIF
      *
     C                     UPDATVVVPP401
     C                     ENDDO
      *
     C                     ENDSR
     C*===============================================================
     C* INITIAL SETTING
     C*===============================================================
     C           #INIT     BEGSR
     C*
     C                     TIME           @SDATE
     C                     MOVE 'Y'       FIRST   1
     C*
     C                     ENDSR
