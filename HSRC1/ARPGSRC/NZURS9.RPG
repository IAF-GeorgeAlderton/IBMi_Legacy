     H            Y.
     FNZUPP01 IP  E                    DISK
     C                     CALL 'BARR83'
     C                     PARM           N2KANR  1
     C                     PARM           N2SZET  4
     C                     PARM           N2STHI  3
     C                     PARM           N2SPAG  2
     C                     PARM           N2NIJI  1
     C                     PARM           N2TAIS  1
     C                     PARM           N2SYKO  1
     C                     PARM           N2HKSY  1
     C                     PARM           N2CHKD  1
     C                     PARM           P@BARC 20
      *
     C                     CALL 'BARR84'
     C                     PARM           N2KANR  1
     C                     PARM           N2SZET  4
     C                     PARM           N2STHI  3
     C                     PARM           N2SPAG  2
     C                     PARM           N2NIJI  1
     C                     PARM           N2TAIS  1
     C                     PARM           N2SYKO  1
     C                     PARM           N2HKSY  1
     C                     PARM 'Z'       N2CHKD  1
     C                     PARM           P#BARC 20
      *
     C           P@BARC    IFNE P#BARC
     C                     ADD  1         @ERR    90
     C                     END
      *
     C                     MOVELP@BARC    P@APCS
     C                     CALL 'BARR82'
     C                     PARM           P@APCS 15
     C                     PARM           P@OKNG  2
     C           P@OKNG    IFNE 'OK'
     C                     ADD  1         @CNT    90
     C                     END
     C                     ADD  1         @REC    90
      *
     C           @REC      IFGE 88888
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
