     H            Y.
     F** MRAR91 *********************************************
     F* UNTRANSMIT LIST                                     *
     F*     TRANCOM ITS.           2012.09.18               *
     F*******************************************************
     FMRAPP01 IF  E                    DISK
     FAGDPL12 IF  E           K        DISK
     FMRAWP91 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
      *
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     C           KEYF81    KLIST
     C                     KFLD           #KYY    40
     C                     KFLD           #KMM    20
     C                     KFLD           #KDD    20
     C                     Z-ADD*YEAR     #KYY
     C                     Z-ADDUMONTH    #KMM
     C                     Z-ADDUDAY      #KDD
     C                     Z-ADD1         X       20
     C                     Z-ADD*DATE     WKKAHZ  80
     C           KEYF81    SETLLAGDPL121
     C                     READPAGDPL121                 80
     C           *IN80     DOWEQ'0'
     C           X         ANDLE10
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KAHZ    WKKAHZ
     C                     ADD  1         X
     C                     ENDIF
     C                     READPAGDPL121                 80
     C                     ENDDO
      * NEW PRODUCTION FILE
     C                     READ MRAPP011                 80
     C           *IN80     DOWEQ'0'
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C           P1GET     IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     READ MRAPP011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVELWKKAHZ    P1KAHZ
     C                     CALL 'MRAR92'
     C                     PARM           M1KENO
     C                     PARM           M1KENA
     C                     PARM           M1KEED
     C                     PARM           P1KAHZ  8
     C                     PARM           P1STAT  2
     C                     PARM           P1GET   1
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
