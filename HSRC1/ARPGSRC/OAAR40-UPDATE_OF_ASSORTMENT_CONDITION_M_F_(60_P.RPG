     C           *INKE     IFEQ '0'
     C                     GOTO @DISP3
     C                     END
     C*************************************
     C** WRITE&UPDAT                     **
     C*************************************
     C                     Z-ADD0         H       20
     C                     Z-ADD1         YUI     30
     C                     Z-ADD@PKN11    WP1
     C                     Z-ADD@PKN12    WP2
     C                     Z-ADD@PKN13    WP3
     C                     Z-ADD@PKN21    WP4
     C                     Z-ADD@PKN22    WP5
     C                     Z-ADD@PKN23    WP6
     C                     MOVEL@SIYO     WS1
     C                     MOVEL@SIY2     WS2
     C           KEY       KLIST
     C                     KFLD           @RGCD
     C                     KFLD           YUI
     C           1         DO   60
     C                     ADD  1         H
     C           KEY       CHAINOAAPL401             95
     C                     MOVE *BLANK    R3SKJY
     C                     Z-ADD0         R3SKHZ
     C                     Z-ADD*DATE     R3KOHZ
     C                     TIME           WTIME
     C*                    MOVELUS        R3KOME
     C                     MOVE @RGCD     R3RGCD
     C                     Z-ADDWPKN,H    R3PKET
     C                     MOVEAWSIY,H    R3SKBN
     C           @KOSN     IFEQ '0'
     C                     MOVEL'D'       R3SKJY
     C                     Z-ADD*DATE     R3SKHZ
     C                     END
     C           *IN,95    IFEQ '0'
     C                     UPDATOAAPL401
     C                     ELSE
     C                     WRITEOAAPL401
     C                     END
     C                     ADD  1         YUI
     C                     END
     C                     EXSR MADOKA
     C                     GOTO @DISP1
     C*************************************
     C** MOVE                            **
     C*************************************
     C           MADOKA    BEGSR
     C                     MOVE @KOSN     KOSN
     C                     MOVE '-'       BOU
     C                     MOVE @RGCD     MRGCD
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @RGCD
     C                     SETOF                     99
     C                     ENDSR
     C*************************************
     C** MOVE2                           **
     C*************************************
     C           RANMA     BEGSR
     C                     MOVE *BLANK    MKOSN
     C                     MOVE *BLANK    MRGCD
     C                     ENDSR
     C*
**
ER-1  I INPUT  OTHER THAN 0.1.2
ER-2  RG CODE ISN'T INPUT
ER-3  ADD WAS APPOINTED, BUT M/F EXIST
ER-4  A CHANGE WAS APPOINTED, BUT M/F DOESN'T EXIST
ER-5  A CHANGE WAS APPOINTED, BUT M/F IS CANCELLED ALREADY
ER-6  A CANCELLATION WAS APPOINTED, BUT M/F DOESN'T EXIST
ER-7  A CANCELLATION WAS APPOINTED, BUT M/F IS CANCELLED
ER-8  M/F DOESN'T COME WITH READ
ER-9  INPUT ALL GATE NUMBERS
ER-10 IT IS REGISTERED ALREADY 01.99 REPETITION IS FAIR
ER-11 RG(BIN) CODE NAME M/F DOESN'T INCLUDE IT
