     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *   第一画面表示                                   *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAGJPW421
     C                     MOVEL*BLANK    @ERR
     C                     SETOF                     99
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      * F12 CSV
     C           *IN12     IFEQ '1'
     C                     CALL 'AGJC43'
     C                     PARM           P1DATA  1
     C                     GOTO ESB210
     C                     ENDIF
      * F7左
     C           *IN07     IFEQ '1'
     C           WKH       IFEQ 1
     C                     MOVELER,1      @ERR
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
     C                     EXSR #LEFT
     C                     ENDIF
      * F8右
     C           *IN08     IFEQ '1'
     C           *IN86     IFEQ '1'
     C                     MOVELER,1      @ERR
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
     C                     EXSR #RIGHT
     C                     ENDIF
      *前
     C           *IN52     IFEQ '1'
     C           WKV       IFEQ 1
     C                     MOVELER,1      @ERR
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
     C                     EXSR #PRV
     C                     ENDIF
      *次
     C           *IN51     IFEQ '1'
     C           *IN87     IFEQ '1'
     C                     MOVELER,1      @ERR
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
     C                     EXSR #NEXT
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * LEFT                                               *
      *----------------------------------------------------*
     CSR         #LEFT     BEGSR
      *
     C                     MOVEL$SQ,1     #KSEQN
     C                     MOVEL$DT,1     #KGROP
     C           KEYW11    SETLLAGJWP401
     C                     DO   8
     C                     READPAGJWP401                 86
     C                     ENDDO
     C           *IN86     IFEQ '1'
     C           *LOVAL    SETLLAGJWP401
     C                     ENDIF
     C                     SUB  1         WKH
     C           WKH       IFEQ 1
     C                     MOVEL*BLANK    @LMOR
     C                     ENDIF
     C                     EXSR #SB111
     C                     EXSR #SB131
      *
     CSR         ELEFT     ENDSR
      *----------------------------------------------------*
      * RIGHT                                              *
      *----------------------------------------------------*
     CSR         #RIGHT    BEGSR
      *
     C                     MOVEL$SQ,7     #KSEQN
     C                     MOVEL$DT,7     #KGROP
     C           KEYW11    SETGTAGJWP401
     C                     ADD  1         WKH
     C                     MOVEL'<<--'    @LMOR
     C                     EXSR #SB111
     C                     EXSR #SB131
      *
     CSR         ERIGHT    ENDSR
      *----------------------------------------------------*
      * PRV PAGE                                           *
      *----------------------------------------------------*
     CSR         #PRV      BEGSR
      *
     C                     Z-ADD$SD,1     W@AP
     C                     Z-ADDW@APHZ    #KAPHZ
     C                     Z-ADDW@APBN    #KAPBN
     C           KEYW21    SETLLAGJWP411
     C                     DO   15
     C                     READPAGJWP411                 87
     C                     ENDDO
     C           *IN87     IFEQ '1'
     C           *LOVAL    SETLLAGJWP411
     C                     ENDIF
     C                     SUB  1         WKV
     C                     EXSR #SB121
     C                     EXSR #SB131
      *
     CSR         EPRV      ENDSR
      *----------------------------------------------------*
      * NEXT PAGE                                          *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     Z-ADD$SD,14    W@AP
     C                     Z-ADDW@APHZ    #KAPHZ
     C                     Z-ADDW@APBN    #KAPBN
     C           KEYW21    SETGTAGJWP411
     C                     ADD  1         WKV
     C                     EXSR #SB121
     C                     EXSR #SB131
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      * GROUP(RIGHT)                                       *
      *----------------------------------------------------*
     CSR         #SB611    BEGSR
      *
     C                     MOVELW0GROP    @DT,A
     C           W0GROP    IFEQ '999'
     C                     MOVEL'OTHER'   @DT,A
     C                     ENDIF
     C                     MOVELW0GROP    $DT,A
     C                     MOVELW0SEQN    $SQ,A
     C                     ADD  1         A
      *
     CSR         ESB611    ENDSR
      *----------------------------------------------------*
      * SET ISSUE DATE                                     *
      *----------------------------------------------------*
     CSR         #SB621    BEGSR
      *
     C                     Z-ADDW1AP      @SD,B
     C                     Z-ADDW1AP      $SD,B
     C                     ADD  1         B
      *
     CSR         ESB621    ENDSR
      *----------------------------------------------------*
      * SET #OF ISSUE                                      *
      *----------------------------------------------------*
     CSR         #SB631    BEGSR
      *
     C                     Z-ADD1         X       20
     C           W2AP      LOKUP$SD,X                    29
     C           *IN29     IFEQ '1'
     C                     MOVE W2MAIS    P1MOJI
     C                     MOVEL'09'      P1KETA
     C                     MOVEL'00'      P1PONT
     C                     MOVEL'Y'       P1ZERO
     C                     MOVEL'Y'       P1SPCS
     C                     MOVEL*BLANK    P9MOJI
     C                     MOVEL*BLANK    P9STS
     C                     EXSR #AS800
     C                     SELEC
     C           C         WHEQ 1
     C                     MOVE P9MOJI    @QT1,X
     C           C         WHEQ 2
     C                     MOVE P9MOJI    @QT2,X
     C           C         WHEQ 3
     C                     MOVE P9MOJI    @QT3,X
     C           C         WHEQ 4
     C                     MOVE P9MOJI    @QT4,X
     C           C         WHEQ 5
     C                     MOVE P9MOJI    @QT5,X
     C           C         WHEQ 6
     C                     MOVE P9MOJI    @QT6,X
     C           C         WHEQ 7
     C                     MOVE P9MOJI    @QT7,X
     C                     ENDSL
     C                     ENDIF
      *
     CSR         ESB631    ENDSR
      *----------------------------------------------------*
      *数字編集                                          *
      *----------------------------------------------------*
     CSR         #AS800    BEGSR
      *
     C                     CALL 'AGJR48'
     C                     PARM           P1MOJI 15
     C                     PARM           P1KETA  20
     C                     PARM           P1PONT  20
     C                     PARM           P1ZERO  1
     C                     PARM           P1SPCS  1
