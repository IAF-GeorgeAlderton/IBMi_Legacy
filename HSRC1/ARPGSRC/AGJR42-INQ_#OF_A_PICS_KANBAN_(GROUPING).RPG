      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR #SB100
      * GROUP
     C                     Z-ADD1         WKH     30
     C                     MOVEL*BLANK    @LMOR
     C           *LOVAL    SETLLAGJWP401
     C                     EXSR #SB111
      * ISSUE DATE
     C                     Z-ADD1         WKV     30
     C           *LOVAL    SETLLAGJWP411
     C                     EXSR #SB121
      * #OF ISSUE
     C                     EXSR #SB131
      *
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      *   INI                                              *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
     C                     MOVELP1CR1     C1CR1
     C                     MOVE P1CB1     C1CR1
     C                     MOVELP1CR2     C1CR2
     C                     MOVE P1CB2     C1CR2
     C                     MOVEL*BLANK    D1TITL
     C                     SELEC
     C           P1DATA    WHEQ '3'
     C           P1DATA    OREQ '4'
     C                     MOVELTX,1      D1TITL
     C           P1DATA    WHEQ '5'
     C           P1DATA    OREQ '6'
     C                     MOVELTX,2      D1TITL
     C                     ENDSL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * SET GROPU                                          *
      *----------------------------------------------------*
     CSR         #SB111    BEGSR
      *
     C                     CLEAR@DT
     C                     CLEAR$DT
     C                     CLEAR$SQ
     C                     Z-ADD1         A       20
     C                     READ AGJWP401                 86
     C           *IN86     DOWEQ'0'
     C           A         ANDLE7
     C                     EXSR #SB611
     C                     READ AGJWP401                 86
     C                     ENDDO
     C                     MOVEL*BLANK    @RMOR
     C           *IN86     IFEQ '0'
     C                     MOVEL'-->>'    @RMOR
     C                     ENDIF
      *
     CSR         ESB111    ENDSR
      *----------------------------------------------------*
      * SET ISSUE DATE                                     *
      *----------------------------------------------------*
     CSR         #SB121    BEGSR
      *
     C                     CLEAR@SD
     C                     CLEAR$SD
     C                     Z-ADD1         B       20
     C                     READ AGJWP411                 87
     C           *IN87     DOWEQ'0'
     C           B         ANDLE14
     C                     EXSR #SB621
     C                     READ AGJWP411                 87
     C                     ENDDO
      *
     C           *IN87     IFEQ '0'
     C                     MOVELWKMORE    @MORE
     C                     ELSE
     C                     MOVELWKEND     @MORE
     C                     ENDIF
      *
     CSR         ESB121    ENDSR
      *----------------------------------------------------*
      * SET #OF ISSUE                                      *
      *----------------------------------------------------*
     CSR         #SB131    BEGSR
      *
     C                     CLEAR@QT1
     C                     CLEAR@QT2
     C                     CLEAR@QT3
     C                     CLEAR@QT4
     C                     CLEAR@QT5
     C                     CLEAR@QT6
     C                     CLEAR@QT7
      *
     C                     Z-ADD1         C       20
     C           C         DOWLE7
      *
     C                     MOVEL$DT,C     #KGROP
     C           #KGROP    IFEQ *BLANK
     C                     SELEC
     C           C         WHEQ 1
     C                     CLEAR@QT1
     C           C         WHEQ 2
     C                     CLEAR@QT2
     C           C         WHEQ 3
     C                     CLEAR@QT3
     C           C         WHEQ 4
     C                     CLEAR@QT4
     C           C         WHEQ 5
     C                     CLEAR@QT5
     C           C         WHEQ 6
     C                     CLEAR@QT6
     C           C         WHEQ 7
     C                     CLEAR@QT7
     C                     ENDSL
     C                     ELSE
     C           KEYW31    SETLLAGJWP421
     C           KEYW31    READEAGJWP421                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB631
     C           KEYW31    READEAGJWP421                 81
     C                     ENDDO
     C                     ENDIF
      *
     C                     ADD  1         C
     C                     ENDDO
      *
     CSR         ESB131    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
