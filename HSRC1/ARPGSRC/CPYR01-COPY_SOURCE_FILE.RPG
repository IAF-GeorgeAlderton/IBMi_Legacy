     H            Y/                                    1
     H** CPYR01 *******************************************************
     H*  COPY SOURCE FILE                                             *
     H*  JW   2026.01.15                                              *
     F*****************************************************************
     FVVVPP50DIF  E           K        DISK
      *================================================================
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
     I              'ARPGLESRC '          C         @C1
      *===============================================================
      *  MAIN
      *===============================================================
     C                     DO   *HIVAL
     C                     READ VVVPP50D                 98
     C   98                LEAVE
      *
     C                     MOVELV5FILE    PFROM
      *
     C                     SELEC
     C           V5SEU     WHEQ 'CLP  '
     C                     MOVEL'ACLSRC  'PTO       P
     C           V5SEU     WHEQ 'CMD  '
     C                     MOVEL'ACMDSRC 'PTO       P
     C           V5SEU     WHEQ 'DDS  '
     C                     MOVEL'ADDSSRC 'PTO       P
     C           V5SEU     WHEQ 'DSPF  '
     C                     MOVEL'ADSPSRC 'PTO       P
     C           V5SEU     WHEQ 'PRTF  '
     C                     MOVEL'APRTSRC 'PTO       P
     C           V5SEU     WHEQ 'RPG   '
     C                     MOVEL'ARPGSRC 'PTO       P
     C           V5SEU     WHEQ 'RPGL  '
     C                     MOVEL@C1       PTO       P
     C                     ENDSL
      * COPY
     C                     CALL 'CPYSRC2'
     C                     PARM           PFROM  10
     C                     PARM           PTO    10
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
