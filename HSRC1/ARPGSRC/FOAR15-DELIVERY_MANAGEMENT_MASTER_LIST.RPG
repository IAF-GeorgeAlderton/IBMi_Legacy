      *検索用KEY定義
     C           KEYOA1    KLIST
     C                     KFLD           #KKAT1  2
     C                     KFLD           #KKAT2  4
     C                     KFLD           #KKAT3  1
     C           KEYOA2    KLIST
     C                     KFLD           #KKAT1  2
     C           KEYQ41    KLIST
     C                     KFLD           #KKAT1  2
     C                     KFLD           #KKAT2  4
     C           KEYGC1    KLIST
     C                     KFLD           #KKAT1  2
     C                     KFLD           #KKAT2  4
     C                     KFLD           #KKAT3  1
     C           KEYOM1    KLIST
     C                     KFLD           #KTYPE  1
