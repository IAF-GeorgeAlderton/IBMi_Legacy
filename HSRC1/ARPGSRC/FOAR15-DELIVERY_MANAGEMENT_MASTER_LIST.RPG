      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           *IN01     DOWEQ'0'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     MOVE *BLANK    DSPSW1  1
      *
     C                     Z-ADD0         @DATE
     C                     MOVE UYEAR     @YY
     C                     MOVE UMONTH    @MM
     C                     MOVE UDAY      @YY
      *
     C                     SETOF                     77
      *マッチングリストデータ格納
     C                     MOVE '2'       #KTYPE  1
     C                     SETOF                       21
     C           KEYOM1    CHAINFOAPP021             21
     C           *IN21     IFEQ '0'
     C           OMSKJY    ANDEQ'D'
     C           OMSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C   21                MOVE *ALL' '   KAT
      *型メーカ行き
     C                     SETOF                       21
     C           KEYOM1    CHAINFOAPP031             21
     C           *IN21     IFEQ '0'
     C           OKSKJY    ANDEQ'D'
     C           OKSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C   21                MOVE *ALL' '   KTT
      *
     C                     MOVE '1'       DSPSW1
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           *IN01     DOWEQ'0'
     C           *IN05     ANDEQ'0'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR $SB210
     C                     END
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *  第一画面(FOAPW015)                              *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTFOAPW151
     C                     SETOF                       99
     C                     SETOF                     3132
     C                     MOVE *BLANK    @ERR
      * CMD-1
     C           *IN01     IFEQ '1'
     C                     GOTO $S210E
     C                     END
      *
      *
     C           @1KAT1    IFEQ *BLANK
     C                     SETOF                       05
     C                     SETON                       3199
     C                     MOVELER,1      @ERR
     C                     GOTO $S210E
     C                     END
      *
     C                     MOVE @1KAT1    @SKEY1
     C           @1KAT2    IFNE '0000'
     C                     MOVE @1KAT2    @SKEY2
     C                     ELSE
     C                     MOVE *BLANK    @SKEY2
     C                     END
     C                     MOVE @1KAT3    @SKEY3
      *
     C                     MOVE @2KAT1    @EKEY1
     C           @2KAT2    IFNE '0000'
     C                     MOVE @2KAT2    @EKEY2
     C                     ELSE
     C                     MOVE *BLANK    @EKEY2
     C                     END
     C                     MOVE @2KAT3    @EKEY3
      *
     C           @EKEY     IFNE *BLANK
     C           @SKEY     IFGT @EKEY
     C                     SETON                       3132
     C                     SETON                       99
     C                     SETOF                       05
     C                     MOVELER,2      @ERR
     C                     GOTO $S210E
     C                     END
     C                     END
      *-------------------*
      * LIST              *
      *-------------------*
     C                     SETOF                       88
     C           *IN05     IFEQ '1'
     C                     MOVE @1KAT1    #KKAT1
     C                     MOVE @1KAT2    #KKAT2
     C                     MOVE @1KAT3    #KKAT3  1
     C                     EXSR $SB400
     C           *IN88     IFEQ '0'
     C                     SETOF                       05
     C                     SETON                     313299
     C                     MOVELER,3      @ERR
     C                     GOTO $S210E
     C                     END
     C                     END
      *
     C   05                SETON                       01
     C   05                MOVE '0'       DSPSW1
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         $SB400    BEGSR
     C                     SETOF                       21
     C           KEYOA1    SETLLFOAPP011
     C                     DO   *HIVAL
     C                     READ FOAPP011                 21
     C   21                LEAVE
     C                     MOVE '0'       GETFLG  1
     C           OASKJY    IFEQ 'D'
     C           OASKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           @EKEY     IFEQ *BLANK
     C                     MOVE '1'       GETFLG
     C                     ELSE
     C           OAKATA    IFGE @SKEY
     C           OAKATA    ANDLE@EKEY
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
      *
     C           GETFLG    IFEQ '1'
     C                     MOVE OAG1SH    W@G1SH  1
     C                     MOVE OAG2SH    W@G2SH  1
      *------------------------------*
      *マッチングリストデータ検索  *
      *------------------------------*
     C                     MOVE *BLANK    MACFLG  1
     C                     Z-ADD1         @Y      20
     C           OAKAT1    IFNE *BLANK
     C           OAKAT1    LOKUPKAT,@Y                   21
     C   21                MOVE '1'       MACFLG  1
     C                     END
      *
     C           MACFLG    IFEQ *BLANK
      *
     C                     Z-ADD1         @Y      20
     C           OAKAT1    IFNE *BLANK
     C           OAKAT1    LOKUPKTT,@Y                   21
     C   21                MOVE '1'       MACFLG  1
     C                     END
     C           MACFLG    IFEQ '1'
     C                     MOVE '2'       W@G1SH
     C                     MOVE '2'       W@G2SH
     C                     ELSE
     C                     MOVE ' '       W@G1SH
     C                     MOVE ' '       W@G2SH
     C                     END
      *
     C                     END
      *
     C                     EXCPTFILE
     C                     SETON                       88
     C                     END
      *
     C                     ENDDO
     CSR         $S400E    ENDSR
      *
     OFOAWP15 E                FILE
     O                         OAKAT1     2
     O                         OAKAT2     6
     O                         OAKAT3     7
     O                         W@G1SH     8
     O                         W@G2SH B   9
     O                         OAZAKB B  10
