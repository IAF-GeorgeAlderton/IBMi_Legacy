      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C           *IN88     IFEQ *ON
     C                     MOVELMSG,1     D@MSG
     C                     ELSE
     C                     MOVELMSG,2     D@MSG
     C                     ENDIF
     C                     ELSE
     C                     MOVE '02'      @@ID
