     C           PUNONY    LOKUPSRV                      10
     C   10                ITER
      *
     C                     MOVE *ON       *IN88
     C                     MOVE *BLANK    @@NG    2
     C           PUSERL    CHAINAB#PP7W              90
     C           *IN90     IFEQ *OFF
     C           PWRST1    IFEQ '0'
