     C           PUODRN    IFNE *BLANK
     C           BAODRN    ANDNEPUODRN
     C                     ITER
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL01
      *
     C           @@NG      IFNE *BLANK
     C                     MOVE *OFF      *IN55
     C           K#14      SETLLAB#PL14
     C           *IN90     DOUEQ*ON
     C           K#14      READEAB#PL14                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PUODRN    IFNE *BLANK
     C           BAODRN    ANDNEPUODRN
