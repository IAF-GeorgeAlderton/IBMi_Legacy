      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     MOVE *BLANK    CFLG    1
      *
     C           STEP0     TAG
     C                     EXFMTAANPW101
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C           *INKE     IFEQ '0'
     C                     GOTO STEP0
     C                     END
      *
     C           1         SETLLAANPP01
     C                     SETOF                     10
     C                     DO   *HIVAL
     C                     READ AANPP01                  10
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE *DATE
     C                     GOTO END
     C                     END
     C                     END
      *
     C           L7DTKO    IFEQ '2'
     C           L7DTKO    OREQ 'D'
     C                     GOTO END
     C                     END
      *
     C           L7SYOS    IFEQ 0
     C                     GOTO END
     C                     END
      *
     C           L7KOUT    IFNE 'Y'
     C                     GOTO END
     C                     END
      *
     C           L7KMIN    IFEQ L7KMAX
     C                     GOTO END
     C                     END
      *
     C           L7STHZ    IFNE 99999999
     C                     GOTO END
     C                     END
      *
     C                     MOVE *BLANK    @HKBN   1        ｴｹ
     C                     Z-ADD0         @DFLT   30       ｴNOｸｽ
     C                     Z-ADD0         @MAIS   50       ｴﾕｳｴ
     C                     Z-ADD0         @INZI   30       ｳﾕｳｴ
      *
     C           @ENTRY    PLIST
     C                     PARM           @PARM1  5        ｷ ALL
     C                     PARM           @PARM2  5              MIN
     C                     PARM           @PARM3  5              MAX
     C                     PARM           @PARM4  5              
     C                     PARM           @PARM5  1        ｴｹ
     C                     PARM           @PARM6  5        ｴNOｸｽ
     C                     PARM           @PARM7  5        ｴﾕｳｴ
     C                     PARM           @PARM8  5        ｳﾕｳｴ
      *
     C                     MOVE L7KALL    @PARM1
     C                     MOVE L7KMIN    @PARM2
     C                     MOVE L7KMAX    @PARM3
     C                     MOVE L7SRMS    @PARM4
     C                     MOVE *BLANK    @PARM5
     C                     MOVE *BLANK    @PARM6
     C                     MOVE *BLANK    @PARM7
     C                     MOVE *BLANK    @PARM8
     C                     CALL 'AAOR04'  @ENTRY           ｴﾕｳｴｻｳ
     C                     MOVE @PARM5    @HKBN
     C                     MOVE @PARM6    @DFLT
     C                     MOVE @PARM7    @MAIS
     C                     MOVE @PARM8    @INZI
      *
     C                     MOVE '*'       CFLG
      *
     C                     MOVE *BLANK    L7KOUT
     C                     MOVE 'Y'       L7DOUT
     C                     MOVE '*'       L7DTHE
     C                     EXSR #SB100
     C                     Z-ADD0         WPNO    30
     C                     Z-ADD@DFLT     WPNO
      *
     C*                    Z-ADD0         WHAKO   50
     C*                    Z-ADD0         AMRI    50
     C*          L7KCD2    IFEQ 'D'
     C*          L7HKSU    IFEQ 0
     C*                    Z-ADD1         L7HKSU
     C*                    END
     C*          @MAIS     DIV  L7HKSU    WHAKO
     C*                    MVR            AMRI
     C*          AMRI      IFGT 0
     C*                    ADD  1         WHAKO
     C*                    END
     C*                    ELSE
     C*                    Z-ADD@MAIS     WHAKO
     C*                    END
     C                     DO   @MAIS
     C*****                DO   WHAKO
     C                     Z-ADDL7KALL    #7KALL
     C                     Z-ADDL7MAIS    #7MAIS
     C                     Z-ADDL7KMIN    #7KMIN
     C                     Z-ADDL7KMAX    #7KMAX
     C                     Z-ADDL7SRMS    #7SRMS
     C                     Z-ADDL7ALHK    #7ALHK
     C                     Z-ADDL7MXHK    #7MXHK
     C                     Z-ADDL7JDMS    #7JDMS
     C                     EXCPTDT
TCHK2C                     WRITEAANWP111
     C                     ADD  1         WPNO
     C                     ENDDO
     C                     UPDATAANPP011
      *
     C           END       TAG
     C  N10                ENDDO
      *
     C           CFLG      IFEQ *BLANK
     C                     SETON                     99
     C                     GOTO STEP0
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------------------*
     C           #SB100    BEGSR
     C                     MOVE *BLANK    HHIN1   5
     C                     MOVE *BLANK    HHIN2   5
     C                     MOVE *BLANK    HHIN3   2
     C           KEY1      KLIST
     C                     KFLD           L7SHN1
     C                     KFLD           L7SHN2
     C                     KFLD           L7SHN3
     C                     SETOF                     11
TCHK3C*          KEY1      CHAINFCEPL41              11
TCHK3C           KEY1      SETLLFCEPL41
TCHK3C                     DO   *HIVAL
TCHK3C           KEY1      READEFCEPL41                  11
TCHK3C   11                LEAVE
TCHK3C           F4GSKD    IFNE *BLANK
TCHK3C                     ITER
TCHK3C                     END
TCHK3C*          *IN11     IFEQ '0'
     C                     MOVE F4PRT1    HHIN1
     C                     MOVE F4PRT2    HHIN2
     C                     MOVE F4PRT3    HHIN3
TCHK3C*                    END
TCHK3C                     LEAVE
TCHK3C                     ENDDO
      *
     C                     MOVE *BLANK    WHIRO   6
     C                     Z-ADD1         @Z      20
     C                     SETOF                     11
     C           L7HAK2    LOKUPCMT1,@Z                  11
     C           *IN11     IFEQ '1'
     C                     MOVE CMT2,@Z   WHIRO
     C                     END
      *
     C           KEY2      KLIST
     C                     KFLD           L7BMON
     C                     KFLD           L7TAIP
     C                     MOVE *BLANK    WKNAME 14
     C                     SETOF                     11
     C           KEY2      CHAINGCKPL211             11
     C           *IN11     IFEQ '0'
     C           T2SKJY    IFEQ 'D'
     C           T2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELT2NAMN    WKNAME
     C                     END
     C                     END
     C           ESB100    ENDSR
