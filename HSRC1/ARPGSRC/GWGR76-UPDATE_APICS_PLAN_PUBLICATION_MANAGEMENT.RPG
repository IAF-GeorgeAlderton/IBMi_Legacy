      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     READ GWCALP1                  81
     C           *IN80     DOUEQ*ON
     C                     READ GWSCDP1                  80
     C           *IN80     IFEQ *OFF
      *
     C           1         DO   30        X       30
     C           ORA,X     IFNE *ZERO
     C           DT1,X     ANDNE99999999
     C           DT1,X     ANDNE0
     C                     EXSR #PLS
     C                     ENDIF
     C                     ENDDO
      *
     C           1         DO   25        X       30
     C           ORS,X     IFNE *ZERO
     C           DT2,X     ANDNE99999999
     C           DT2,X     ANDNE0
     C                     EXSR #MNS
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#BTA     KLIST
     C                     KFLD           PRT1
     C                     KFLD           PRT2
     C                     KFLD           PRT3
     C                     KFLD           K@YM    60
      *
     C                     MOVE *ALL'-'   @LINE  60
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #PLS      BEGSR
      * PLUS
      *
     C                     MOVELDT1,X     K@YM
     C                     Z-ADDDT1,X     Z       20
     C           K#BTA     CHAINBTAPL04              90
     C           *IN90     IFEQ *OFF
     C           BTSKJY    IFNE *BLANK
     C                     Z-ADD*ZERO     #PH
     C                     Z-ADD*ZERO     #MH
     C                     ENDIF
     C                     ADD  ORA,X     #PH,Z
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD*YEAR     BTKOYY
     C                     Z-ADD*MONTH    BTKOMM
     C                     Z-ADD*DAY      BTKODD
     C                     TIME           @@TIME
     C                     Z-ADD@@HH      BTKOHH
     C                     Z-ADD@@MN      BTKOSS
     C                     MOVE #USER     BTKOME
     C                     UPDATBTAPL041
     C                     ELSE
     C                     CLEARBTAPL041
      *
     C                     ADD  ORA,X     #PH,Z
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD*YEAR     BTKOYY
     C                     Z-ADD*MONTH    BTKOMM
     C                     Z-ADD*DAY      BTKODD
     C                     TIME           @@TIME
     C                     Z-ADD@@HH      BTKOHH
     C                     Z-ADD@@MN      BTKOSS
     C                     MOVE #USER     BTKOME
     C                     Z-ADDK@YM      BTKEYM
     C                     MOVELPRT1      BTSHN1
     C                     MOVELPRT2      BTSHN2
     C                     MOVELPRT3      BTSHN3
     C                     WRITEBTAPL041
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #MNS      BEGSR
      * MINUS
     C                     MOVELDT2,X     K@YM
     C                     Z-ADDDT2,X     Z       20
     C           K#BTA     CHAINBTAPL04              90
     C           *IN90     IFEQ *OFF
     C           BTSKJY    IFNE *BLANK
     C                     Z-ADD*ZERO     #MH
     C                     Z-ADD*ZERO     #PH
     C                     ENDIF
     C                     ADD  ORS,X     #MH,Z
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD*YEAR     BTKOYY
     C                     Z-ADD*MONTH    BTKOMM
     C                     Z-ADD*DAY      BTKODD
     C                     TIME           @@TIME
     C                     Z-ADD@@HH      BTKOHH
     C                     Z-ADD@@MN      BTKOSS
     C                     MOVE #USER     BTKOME
     C                     UPDATBTAPL041
     C                     ELSE
     C                     CLEARBTAPL041
      *
     C                     ADD  ORS,X     #MH,Z
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD*YEAR     BTKOYY
     C                     Z-ADD*MONTH    BTKOMM
     C                     Z-ADD*DAY      BTKODD
     C                     TIME           @@TIME
     C                     Z-ADD@@HH      BTKOHH
     C                     Z-ADD@@MN      BTKOSS
     C                     MOVE #USER     BTKOME
     C                     Z-ADDK@YM      BTKEYM
     C                     MOVELPRT1      BTSHN1
     C                     MOVELPRT2      BTSHN2
     C                     MOVELPRT3      BTSHN3
     C                     WRITEBTAPL041
     C                     ENDIF
      *
     C                     ENDSR
