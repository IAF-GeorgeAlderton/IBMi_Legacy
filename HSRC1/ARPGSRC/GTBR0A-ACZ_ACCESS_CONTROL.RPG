      **** GTBR0A ******************************************************
      *                                                                *
      *  CHECK FILE LOCK                                               *
      *     P@ID = '1' -> CHECK AND LOCK THE FILE                      *
      *     P@ID = '2' -> UNLOCK THE FILE                              *
      *                                                                *
      *     P@OK = OK  -> ABLE TO USE                                  *
      *     P@OK = NO  -> UNABLE TO USE                                *
      *                                                                *
      *     P@FILE = FILE NAME TO BE LOCKED                            *
      *
      * TCHK  01/21/13 CREATE(COPY FROM GDGR00)
      ******************************************************************
     H            Y/                                    1
     FGTBPP90 UF  E           K        DISK                      A
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C****************************************************************
     C*MAIN
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@FILE 10
     C                     PARM           P@OK    2
     C                     PARM           P@ID    1
     C****************************************************************
     C                     MOVELP@FILE    KEY    10
     C           KEY       CHAINGTBPP90              90
     C           *IN90     IFEQ *ON
     C                     Z-ADD*DATE     G90UPD
     C                     TIME           G90TIM
     C                     MOVEL#PGM      G90PGM
     C                     MOVEL#WSID     G90WSD
     C                     MOVELP@FILE    G90KEY
     C                     MOVE *BLANK    G90USE
     C                     WRITEGTBPP901
     C                     MOVE 'OK'      P@OK
     C                     ELSE
      *
     C                     Z-ADD*DATE     G90UPD
     C                     TIME           G90TIM
     C                     MOVEL#PGM      G90PGM
     C                     MOVEL#WSID     G90WSD
      *
     C                     SELEC
     C           P@ID      WHEQ '1'
     C           G90USE    IFEQ *BLANK
     C                     MOVE 'OK'      P@OK
     C                     MOVE '1'       G90USE
     C                     UPDATGTBPP901
     C                     ELSE
     C                     MOVE 'NO'      P@OK
     C                     ENDIF
      *
     C                     OTHER
     C                     MOVE *BLANK    G90USE
     C                     UPDATGTBPP901
     C                     ENDSL
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*
