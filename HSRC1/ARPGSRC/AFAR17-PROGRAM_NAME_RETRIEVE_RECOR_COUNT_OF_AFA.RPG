     I*収容数切替日
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     C           KEY       KLIST
     C                     KFLD           CFHIN1
     C                     KFLD           CFHIN2
     C                     KFLD           CFHIN3
      *
     C           *ENTRY    PLIST
     C                     PARM           CNT     20
      *
     C                     SETOF                     11
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AFAWP15                  10
     C           *IN10     IFEQ '0'
      *
     C           *IN11     IFEQ '0'
     C                     SETON                     11
     C                     Z-ADD1         CNT
     C                     END
      *
     C                     SETOF                     12
     C                     MOVE *BLANK    WTKRO   6
     C           KEY       CHAINFCEPL011             12
     C           *IN12     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD0         WYMD    80
     C           1         DO   3         A
     C                     SETOF                     13
     C           4         SUB  A         B       20
     C           HIZ,B     IFNE 0
     C                     SETON                     13
     C                     Z-ADDHIZ,B     WYMD
     C                     END
     C  N13                END
      *
     C           WYMD      IFEQ 999999
     C           WYMD      OREQ 0
     C                     Z-ADD*DATE     WYMD
     C                     END
      *
     C           A2TRHZ    IFGT WYMD
     C                     MOVE A2KTKR    WTKRO
     C                     ELSE
     C                     MOVE A2STKR    WTKRO
     C                     END
     C                     END
      *
     C                     EXSR #HAKO
      *
     C           TURUBE    IFNE '1'
     C*   つるべ以外
     C                     EXCPTUP
     C                     ELSE
     C*   つるべ更新
     C                     MOVE ISPAGE    W1PAGE  20
     C                     Z-ADDW1PAGE    $$PAGE  30
     C                     EXCPTUPTURU
     C                     ENDIF
      *
     C                     END
     C  N10                END
      *
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *
      *================================================================
     C           #HAKO     BEGSR
     C                     Z-ADD0         HAKO    41       日当数量
     C*収容数切替日
S1   C           A2SYHZ    IFLE *DATE
     C                     Z-ADDA2SSYS    W$SYSU  50       新収容数
X1   C                     ELSE
     C                     Z-ADDA2KSYS    W$SYSU           旧収容数
E1   C                     ENDIF
     C*日当箱数
S1   C           W$SYSU    IFNE 0
     C           A2GEKN    DIV  20        W$HIS   90       日当数量
     C           W$HIS     DIV  W$SYSU    HAKO      H      日当数量
E1   C                     ENDIF
     C*
     C                     ENDSR
      *================================================================
      *
     OAFAWP15 E                UP
     O                         WTKRO    209
     O*   日当数量
     O                         HAKO     228
     O*   開始ページ
     O                                  232 '001'
     OAFAWP15 E                UPTURU
     O                         $$PAGE   232
