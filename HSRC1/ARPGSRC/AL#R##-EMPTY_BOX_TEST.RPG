     H            Y.
     F** AL#R## *********************************************
     F* EMPTY BOX TEST
     F*             ITS.           2015.06.15               *
     F*******************************************************
     FAL#PW## CF  E                    WORKSTN
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD0         D1C
     C                     Z-ADD0         D1D
     C                     Z-ADD0         D1EMPT
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAL#PW##1
     C                     SETOF                     303132
     C                     SETOF                     333435
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      *
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     Z-ADDD1C       WKCNTC  30
     C           D1D       MULT 2         WKCNTD  30
     C                     Z-ADD0         P9EMPT  30
     C                     EXSR #SB410
     C                     Z-ADDP9EMPT    D1EMPT
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     CSR         #SB410    BEGSR
      *
     C                     Z-ADD0         WKCNT   40
     C           WKCNTC    ADD  WKCNTD    WKCNT
     C           WKCNTD    IFEQ 0
     C                     EXSR #SB411
     C                     ELSE
     C                     EXSR #SB412
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *-----------------------------------------------------
      *Ｄ箱がない場合
      *-----------------------------------------------------
     CSR         #SB411    BEGSR
      *
     C                     Z-ADD0         P9EMPT
     C                     Z-ADD0         SYO     30
     C                     Z-ADD0         AMR     30
     C           WKCNT     DIV  12        SYO
     C                     MVR            AMR
     C           AMR       IFNE 0
     C           12        SUB  AMR       P9EMPT
     C                     ENDIF
      *
     CSR         ESB411    ENDSR
      *-----------------------------------------------------
      *Ｄ箱がある場合
      *-----------------------------------------------------
     CSR         #SB412    BEGSR
      *
     C                     Z-ADD0         P9EMPT
     C                     Z-ADD0         SYO     30
     C                     Z-ADD0         AMR     30
     C           WKCNT     DIV  12        SYO
     C                     MVR            AMR
     C           AMR       IFNE 0
     C           12        SUB  AMR       P9EMPT
     C                     ENDIF
      *
     C                     Z-ADD0         TOTAL   40
     C           P9EMPT    ADD  WKCNT     TOTAL
     C           TOTAL     IFLT 24
     C                     ADD  12        P9EMPT
     C                     ENDIF
      *
     CSR         ESB412    ENDSR
