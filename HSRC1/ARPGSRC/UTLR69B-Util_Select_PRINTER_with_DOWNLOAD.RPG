     H            Y.
      ** UTLR69B *********************************************
      *  UTILITY- SELECT PRINTER OPTION WITH DOWNLOAD        *
      *  JW       2024.01.04                                 *
      *---------------------------------
      *  CALLING SEQ.
      *                    CALL 'UTLR69B'
      *                    PARM           $PRT   10
      *                    PARM           $RTN    1
      *  OUT $PRT  : 10A PRINTER NAME
      *      $RTN  :  1A RETURN CODE (BLANK: NOMAL PRINTER)
      *                              (* : ABNORMAL PRINTER)
      *                              (X : DOWNLOAD TO CSV )
      ********************************************************
     FUTLPW69BCF  E                    WORKSTN
      *
     E                    ERR     1   4 60
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------*
      *     M  A  I  N   R O U T I N E                            *
      *-----------------------------------------------------------*
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      @DSP1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      *  DISPLAY 1
      *************************************************************
     C           @DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
      * F1: CANCEL
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      W@ID
     C                     MOVE '*'       $RTN
     C                     GOTO @END1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     SELEC
     C           XOPT      WHEQ '1'
     C                     MOVEL'QPRINTC '$PRT
     C           XOPT      WHEQ '2'
     C                     MOVEL'LANPRT02'$PRT
     C           XOPT      WHEQ '3'
     C                     MOVEL'LANPRT07'$PRT
     C           XOPT      WHEQ '4'
     C                     MOVEL'LANPRT03'$PRT
     C           XOPT      WHEQ '5'
     C                     MOVEL'LANPRT04'$PRT
     C           XOPT      WHEQ '6'
     C                     MOVEL'LANPRT06'$PRT
     C           XOPT      WHEQ '7'
     C                     MOVEL'QPRINT  '$PRT
     C           XOPT      WHEQ '9'
     C                     MOVEL'EPRINT1 '$PRT
     C           XOPT      WHEQ 'X'
     C                     MOVE 'X'       $RTN
     C                     MOVEL'CSV     '$PRT
     C                     ENDSL
      * F5: RUN
     C           *INKE     IFEQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO @END1
     C                     ENDIF
      *
     C                     MOVEL'01'      W@ID
     C                     MOVELERR,2     XMSG
     C                     GOTO @END1
     C                     ENDIF
      *
     C           @END1     ENDSR
      *************************************************************
      *  CHECK OPTION
      *************************************************************
     C           #CHK1     BEGSR
      *
     C           XOPT      IFNE '1'
     C           XOPT      ANDNE'2'
     C           XOPT      ANDNE'3'
     C           XOPT      ANDNE'4'
     C           XOPT      ANDNE'5'
     C           XOPT      ANDNE'6'
     C           XOPT      ANDNE'7'
     C           XOPT      ANDNE'9'
     C           XOPT      ANDNE'X'
     C                     MOVELERR,1     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVEL#USER     U1      1
     C           XOPT      IFEQ 'X'
     C           U1        ANDNE'I'
     C                     MOVELERR,3     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *************************************************************
      * INITIAL SET
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $PRT   10
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     MOVEL'01'      W@ID    2
     C                     MOVE '*'       XOPT
      *
     C                     ENDSR
** (ERR) --------------------------------------------------> (60)
PRINTER OPTION IS INVALID !
PRESS F5 TO RUN...
DOWNLOAD DOES NOT APPLY TO THIS USER ID !

