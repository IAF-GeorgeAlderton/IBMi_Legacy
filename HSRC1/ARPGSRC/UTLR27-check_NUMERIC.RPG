     H            Y.
     F** UTLR27 ***********************************************************
     F*  CHECK NUMERIC                                                    *
     F*-------------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR27'
     F*                    PARM           $IN    20
     F*                    PARM           $NUM    2
     F*                    PARM           $RTN    1
     F*   IN  $IN   : 20A    TARGET
     F*       $NUM  :  2A    TARGET COLUMN
     F*   OUT $RTN  :  1A    *=NOT NUMERIC, BLANK=NUMERIC
     F*********************************************************************
     E                    IN         20  1
     F******************************************************************
     C           *ENTRY    PLIST
     C                     PARM           $IN    20
     C                     PARM           $NUM    2
     C                     PARM           $RTN    1
      *
     C                     MOVEA$IN       IN
     C                     MOVEL$NUM      @NUM    20
     C                     MOVE *BLANK    $RTN
      *
     C           @NUM      IFLE 0
     C           @NUM      ORGT 20
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
     C* CHECK NUMERIC
     C           1         DO   @NUM      IX      20
     C           IN,IX     IFLT '0'
     C           IN,IX     ORGT '9'
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
