      ************************************
      * LAST LAINE (CHECK MENUED PROGRAM)
      ************************************
     C           #LAST     BEGSR
     C                     EXSR #F0
      *
     C                     MOVELXPGM      K@PGM
     C           K@PGM     CHAINEGBPL13              99
     C           *IN99     IFEQ *OFF
     C                     MOVELXPGM      @PGM
     C                     MOVE '*'       @PGM
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDSR
      *******************
      * PRINT           *
      *******************
     C           #PRINT    BEGSR
     C           LIN#      IFGT 60
     C                     Z-ADD0         LIN#
     C                     EXCPT@HDR
     C                     ENDIF
      *
     C                     ADD  1         LIN#
     C                     EXCPT@DTL
      *
     C                     ENDSR
      **************************************
     OQPRINT  E   01           @HDR
     O                                    7 'VJBR51'
     O                                   50 '** PGM-PGM (PARENT) '
     O                                   60 'REPORT ** '
     O                                   99 'DATE'
     O                         @DATE    102 '    .  .  '
     O                         @TIME    112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   02           @HDR
     O                                    9 'PROGRAM'
     O                                   18 'PARENT1'
     O                                   28 'PARENT2'
     O                                   38 'PARENT3'
     O                                   48 'PARENT4'
     O                                   58 'PARENT5'
     O                                   68 'PARENT6'
     O                                   78 'PARENT7'
     O                                   88 'PARENT8'
     O                                   98 'PARENT9'
      *
     O        E 1              @DTL
     O                         @PGM      10
     O                         @LINK1    20
     O                         @LINK2    30
     O                         @LINK3    40
     O                         @LINK4    50
     O                         @LINK5    60
     O                         @LINK6    70
     O                         @LINK7    80
     O                         @LINK8    90
     O                         @LINK9   100
      *
     O        E 1              @FOT
     O                         XPGM      12
     O                                   34 ': THERE IS NO PARENT'
     O                                   54 ' PROPGRAM! OR NOT UP'
     O                                   74 'DATED VVVPPB0!      '
