     H            Y.                                    1
     F** VJBR51 ****************************
     F*   PRINT PGM-PGM (PARENT) REPORT    *
     F*   JW    4/6/2016                   *
     F**************************************
     FVVVPLB0 IF  E           K        DISK
     FVVVPLB2 IF  E           K        DISK
     FVVVPLB3 IF  E           K        DISK
     FVVVPLB4 IF  E           K        DISK
     FVVVPLB5 IF  E           K        DISK
     FVVVPLB6 IF  E           K        DISK
     FVVVPLB7 IF  E           K        DISK
     FVVVPLB8 IF  E           K        DISK
     FVVVPLB9 IF  E           K        DISK
     FEGBPL13 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  10 VWPNAM
     I                                        4   4 SRID
      ****************************************************
     C           *ENTRY    PLIST
     C                     PARM           XPGM    8
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     Z-ADD99        LIN#    30
     C                     EXSR #F0
      *
     C                     MOVELXPGM      K@VV1  11
     C           K@VV1     SETLLVVVPLB0
      *
     C           *IN80     DOWEQ*OFF
     C           K@VV1     READEVVVPLB0                  80
     C           *IN80     IFEQ *OFF
     C           SRID      ANDEQ'C'
     C           *IN80     OREQ *OFF
     C           SRID      ANDEQ'R'
     C           *IN80     OREQ *OFF
     C           SRID      ANDEQ'E'
     C           *IN80     OREQ *OFF
     C           SRID      ANDEQ' '
     C                     MOVELVWFNAM    @PGM    8
     C                     MOVELVWPNAM    @LINK1    P
     C                     MOVEL@LINK1    K@VV2  11
     C                     EXSR #F2
     C                     ENDIF
     C                     ENDDO
      * PRINT LAST LINE
     C                     EXSR #LAST
      * PRINT FOOTER
     C           LIN#      IFEQ 99
     C**                   MOVE 'X'       XPGM
     C                     EXCPT@HDR
     C                     EXCPT@FOT
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *******************
      * F0: INITIALIZE  *
      *******************
     C           #F0       BEGSR
     C                     MOVE *BLANK    @LINK1  9
     C                     MOVE *BLANK    @LINK2  9
     C                     MOVE *BLANK    @LINK3  9
     C                     MOVE *BLANK    @LINK4  9
     C                     MOVE *BLANK    @LINK5  9
     C                     MOVE *BLANK    @LINK6  9
     C                     MOVE *BLANK    @LINK7  9
     C                     MOVE *BLANK    @LINK8  9
     C                     MOVE *BLANK    @LINK9  9
     C                     ENDSR
      *******************
      * F2              *
      *******************
     C           #F2       BEGSR
     C                     MOVE 'Y'       @C2     1
     C                     MOVE *OFF      *IN82
     C           K@VV2     SETLLVVVPLB2
     C           *IN82     DOWEQ*OFF
     C           K@VV2     READEVVVPLB2                  82
     C**                   MOVELVWPNAM    TEMP
     C**                   MOVE TEMP      SRID
     C           *IN82     IFEQ *OFF
     C           SRID      ANDEQ'C'
     C           *IN82     OREQ *OFF
     C           SRID      ANDEQ'R'
     C           *IN82     OREQ *OFF
     C           SRID      ANDEQ'E'
     C           *IN82     OREQ *OFF
     C           SRID      ANDEQ' '
     C                     MOVELVWPNAM    @LINK2    P
     C                     MOVEL@LINK2    K@VV3  11
     C                     EXSR #F3
     C                     MOVE ' '       @C2
     C                     MOVE *BLANK    @LINK2
     C                     ELSE
     C           @C2       IFEQ 'Y'
     C                     MOVEL@LINK1    K@PGM   6
     C           K@PGM     CHAINEGBPL13              99
     C           *IN99     IFEQ *OFF
     C           SRID      OREQ ' '
     C                     MOVE '*'       @LINK1
     C                     ENDIF
     C                     EXSR #PRINT
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDSR
      *******************
      * F3              *
      *******************
