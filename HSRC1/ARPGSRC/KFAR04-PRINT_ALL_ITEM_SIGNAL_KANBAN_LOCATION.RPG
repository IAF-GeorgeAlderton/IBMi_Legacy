     FKFAWP04 IP  F      36            DISK
     FKFAPR04 O   E             77     PRINTER                        UC
     E                    TAB3    1   6  1   TAB4    6   箱色　名
     IKFAWP04 NS  01
     I                                        1   40KZBMONL1
     I                                        5   5 KZBAN1
     I                                        6   7 KZBAN2
     I                                        8   9 KZBAN3
     I                                       10  10 KZBAN4
     I                                       11  11 KZHICR
     I                                       12  16 KZHIN1
     I                                       17  21 KZHIN2
     I                                       22  23 KZHIN3
     I                                       24  26 KZKIB1
     I                                       27  29 KZKIB2
     I                                       30  32 KZKIB3
     I                                       33  33 KZYOTP
     I                                       34  350KZHIMS
     I                                       36  36 KZHIRO
     I            DS
     I                                        1  14 KZHINB
     I                                        1   5 KZHIN1
     I                                        6   6 KZH1
     I                                        7  11 KZHIN2
     I                                       12  12 KZH2
     I                                       13  14 KZHIN3
     I            DS
     I                                        1   6 KZBAN
     I                                        1   1 KZBAN1
     I                                        2   3 KZBAN2
     I                                        4   5 KZBAN3
     I                                        6   6 KZBAN4
     I                                        2   2 KZBAN5
     I                                        4   4 KZBAN6
     I            DS
     I                                        1   4 NAME
     I                                        1   2 NAME01
     I                                        3   4 NAME02
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
     C  N01                GOTO @END
      *
     C           *IN,90    IFEQ '0'
     C                     Z-ADD0         CNT     10
     C                     MOVE *BLANK    PSW     1
     C                     MOVEL'1'       *IN77
     C                     MOVEA'1'       *IN,90
     C                     END
      *
     C           PSW       IFEQ *BLANK
     C                     OPEN KFAPR04
     C                     MOVEL'*'       PSW
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     MOVE *BLANK    NAME
     C                     MOVEL'XXXX'    NAME
     C                     ADD  1         CNT
      *
     C           CNT       IFEQ 1
     C                     WRITEKFAPR041
     C                     END
      *
     C           CNT       IFEQ 2
     C                     WRITEKFAPR042
     C                     END
      *
     C           CNT       IFEQ 3
     C                     WRITEKFAPR043
     C                     Z-ADD0         CNT
     C                     END
      *
     C                     END
      *
     C                     MOVE '-'       KZH1
     C                     MOVE '-'       KZH2
      *
     C*  ﾌﾃbﾜ ﾈｮn
     C*
     C                     MOVE *BLANK    COL     6
     C           KZHIRO    LOKUPTAB3      TAB4           10
     C   10                MOVELTAB4      COL
      *
     C*          KZBAN5    IFEQ '0'
     C*                    MOVE *BLANK    KZBAN5
     C*                    END
     C*          KZBAN6    IFEQ '0'
     C*                    MOVE *BLANK    KZBAN6
     C*                    END
     C*          KZBAN4    IFEQ '0'
     C*                    MOVE '-'       KZBAN4
     C*                    END
      *
     C                     DO   KZHIMS
     C                     ADD  1         CNT
     C           CNT       IFEQ 1
     C                     WRITEKFAPR044
     C                     END
      *
     C           CNT       IFEQ 2
     C                     WRITEKFAPR045
     C                     END
      *
     C           CNT       IFEQ 3
     C                     WRITEKFAPR046
     C                     Z-ADD0         CNT
     C                     END
      *
     C                     END
      *
     C           @END      TAG
      *
