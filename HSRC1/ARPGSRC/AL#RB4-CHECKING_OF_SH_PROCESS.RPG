     H            Y.
     F** AL#RB4 *********************************************
     F* CHECKING OF SH PROCESS
     F*              ITS.        2015.05.13                 *
     F*******************************************************
     FAL#WPB1 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAL#PRB4 O   E             55     PRINTER
     FAL#PPB1 O   E                    DISK                      A
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OKO        15  3               工程
     E                    OSY        15  1               か種
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I            DS
     I                                        1   6 WKTKR
     I                                        1   1 WKTKR1
     I                                        2   3 WKTKR2
     I                                        4   5 WKTKR3
     I                                        6   6 WKTKR4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P9IAFB  3
     C                     PARM           P9IAFP  3
      *
     C                     MOVEL'1'       OPNCLS
     C                     TIME           WTIME
     C                     MOVEL'0'       WRTFLG  1
      *
     C           KKWRK     KLIST
     C                     KFLD           KKTYPE  1
     C                     KFLD           P9IAFB
      *
     C                     MOVEL'5'       KKTYPE  1
     C           KKWRK     SETLLAL#WPB11
     C           KKWRK     READEAL#WPB11                 80
     C                     MOVEL*BLANK    SVIAFB  3
     C                     MOVEL*BLANK    SVIAFP  3
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB399
     C           GET       IFEQ '1'
     C           *IN55     IFEQ '1'
     C           W1IAFB    ORNE SVIAFB
     C           W1IAFP    ORNE SVIAFP
     C                     EXSR #SB100
     C                     MOVELW1IAFB    SVIAFB  3
     C                     MOVELW1IAFP    SVIAFP  3
     C                     ENDIF
     C                     EXSR #SB400
     C                     ENDIF
     C           KKWRK     READEAL#WPB11                 80
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL*BLANK    W6SMEI 15
     C           W1NONY    CHAINFGBPL011             24
     C           *IN24     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     24
     C                     ENDIF
     C           *IN24     IFEQ '0'
     C                     MOVELB2SMEI    W6SMEI
     C                     ENDIF
      *
     C                     MOVELW1IAFB    P1IAFB
     C                     MOVELW1IAFP    P1IAFP
     C                     MOVEL*BLANK    P1CUST
     C           P1CUST    CAT  W1SURT:0  P1CUST
     C           P1CUST    CAT  W1ORD#:2  P1CUST
     C           P1CUST    CAT  W6SMEI:2  P1CUST
     C           P1CUST    CAT  W1DOCK:2  P1CUST
     C           P1CUST    CAT  W1PALT:2  P1CUST
     C                     MOVELWTIYY     P1DAYY
     C                     MOVELWTIMM     P1DAMM
     C                     MOVELWTIDD     P1DADD
     C                     MOVELTIMHH     P1TIHH
     C                     MOVELTIMMM     P1TIMM
     C                     MOVELTIMSS     P1TISS
     C                     MOVEL*ALL'-'   P1LIN
     C                     WRITEAL#PRB41
     C                     SETOF                     55
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB399    BEGSR
      *
     C                     MOVEL'0'       GET     1
     C           P9IAFP    IFEQ *BLANK
     C                     MOVEL'1'       GET
     C                     ELSE
     C           P9IAFP    IFEQ W1IAFP
     C                     MOVEL'1'       GET
     C                     ENDIF
     C                     ENDIF
      *
     C           GET       IFEQ '1'
     C           W1BOX     IFEQ W1SUMI
     C                     MOVEL'0'       GET
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB399    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL*BLANK    P2LOC
     C           P2LOC     CAT  W1TKR2:0  P2LOC
     C           P2LOC     CAT  '-':0     P2LOC
     C           P2LOC     CAT  W1TKR3:0  P2LOC
     C                     MOVELW1KNB#    P2KNB#
     C           5         SUBSTW1MHN:1   WKMHN1  5
     C           5         SUBSTW1MHN:6   WKMHN2  5
     C           2         SUBSTW1MHN:11  WKMHN3  2
     C                     MOVEL*BLANK    P2MHN
     C           P2MHN     CAT  WKMHN1:0  P2MHN
     C           P2MHN     CAT  '-':0     P2MHN
     C           P2MHN     CAT  WKMHN2:0  P2MHN
     C           WKMHN3    IFNE *BLANK
     C           P2MHN     CAT  '-':0     P2MHN
     C           P2MHN     CAT  WKMHN3:0  P2MHN
     C                     ENDIF
     C                     Z-ADDW1SUMI    P2SUMI
     C                     Z-ADDW1BOX     P2TOTL
      *
     C                     EXSR #SB490
      *
     C                     MOVEL*ALL'-'   P2LIN
     C                     WRITEAL#PRB42
      *
     C           WRTFLG    IFEQ '0'
     C                     EXSR #SB550
     C                     MOVEL'1'       WRTFLG
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB490    BEGSR
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OKO
     C                     MOVEA*BLANK    OSY
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           W1SHN1  5
     C                     PARM           W1SHN2  5
     C                     PARM           W1SHN3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPKOT      OKO
     C                     MOVEAPSHR      OSY
      *最終番地
     C                     MOVEL*BLANK    WKBMON  40
     C                     MOVEL*BLANK    WKKOT   3
     C                     MOVEL*BLANK    WKKBN   3
     C                     MOVEL*BLANK    WKSY    1
     C                     MOVEL'0'       GET     1
     C                     Z-ADD15        XX      20
     C           XX        DOWGE1
     C           GET       ANDEQ'0'
     C           OTK,XX    IFNE *BLANK
     C                     MOVELOBM,XX    WKBMON
     C                     MOVELOKO,XX    WKKOT
     C                     MOVELOKB,XX    WKKBN
     C                     MOVELOSY,XX    WKSY
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     SUB  1         XX
     C                     ENDDO
      *前番地
     C                     MOVEL*BLANK    WKTKR   6
     C                     MOVEL'0'       GET     1
     C           XX        DOWGE1
     C           GET       ANDEQ'0'
     C           OTK,XX    IFNE *BLANK
     C           OTK,XX    ANDNE'------'
     C                     MOVEAOTK,XX    WKTKR   6
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     SUB  1         XX
     C                     ENDDO
      *
     C                     MOVEL*BLANK    P2SHN
     C           P2SHN     CAT  W1SHN1:0  P2SHN
     C           P2SHN     CAT  '-':0     P2SHN
     C           P2SHN     CAT  W1SHN2:0  P2SHN
     C           W1SHN3    IFNE *BLANK
     C           P2SHN     CAT  '-':0     P2SHN
     C           P2SHN     CAT  W1SHN3:0  P2SHN
     C                     ENDIF
      *
     C                     MOVELWKKOT     P2KOT
      *
     C                     MOVEL*BLANK    P2KBN
     C           WKBMON    IFEQ 0111
     C                     MOVELWKKBN     P2KBN
     C                     ELSE
     C           WKBMON    CHAINFGBPL011             41
     C           *IN41     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     41
     C                     ENDIF
     C           *IN41     IFEQ '0'
     C                     MOVELB2SMEI    P2KBN
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL*BLANK    P2LOCP
     C           WKTKR     IFNE *BLANK
     C           P2LOCP    CAT  WKTKR2:0  P2LOCP
     C           P2LOCP    CAT  '-':0     P2LOCP
     C           P2LOCP    CAT  WKTKR3:0  P2LOCP
     C                     ENDIF
      *
     C                     MOVEL*BLANK    P2SRT
     C                     MOVEL*BLANK    T@SRTN
     C                     MOVEL*BLANK    T@SRT#
      *
     C                     CALL 'AAFRS7'
     C                     PARM           W1SHN1
     C                     PARM           W1SHN2
     C                     PARM           W1SHN3
     C                     PARM           W1TKR1  1
     C                     PARM           W1TKR2  2
     C                     PARM           W1TKR3  2
     C                     PARM           W1TKR4  1
     C                     PARM           T@SRTN 20
     C                     PARM           T@SRT# 20
      *
     C                     MOVELT@SRTN    U@CHR1128
     C                     MOVELT@SRT#    U@CHR2128
     C                     MOVEL*BLANK    U@CHR3128
      *
     C                     CALL 'APLC11'
     C                     PARM           U@CHR1
     C                     PARM           U@CHR2
     C                     PARM           U@CHR3
     C                     MOVELU@CHR3    P2SRT
      *
     CSR         ESB490    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB550    BEGSR
      *
     C                     CLEARAL#PPB11
     C                     Z-ADDSDATE     CBKOHZ
     C                     Z-ADDSTIME     CBKOTI
     C                     MOVELW#USER    CBKOME
     C                     MOVELW1SHME    CBSHME
     C                     Z-ADDSDATE     CBHKHZ
     C                     Z-ADDSTIME     CBHKTI
     C                     WRITEAL#PPB11
      *
     CSR         ESB550    ENDSR
