     H            Y.
     F** UEXR41E ***********************************************
     F*  CHECK ACTIVE PART/DOCK BY FORD CUM MASTER             *
     F*  WRITTEN: JW (SRA) 2022.04.29                          *
     F*--------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR41E'
     F*                    PARM           $PLNT   5
     F*                    PARM           $MHIN  12
     F*                    PARM           $DOCK   4
     F*                    PARM           $YN     1
     F*  IN: $PLNT   5A  PLANT CODE
     F*      $MHIN  12A  USER PART
     F*      $DOCK   4A  DOCK CODE
     F*  OUT $YN     1A  Y=ACTIVE, N=NOT ACTIVE
     F******************************************************
     FABFAL01 IF  E           K        DISK
      *
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C                     MOVE *BLANK    SVPOR#  6
     C                     MOVE *BLANK    SVDOC2  4
      *
     C           K#01      SETLLABFAL01
     C                     DO   *HIVAL
     C           K#01      READEABFAL01                  98
     C   98                LEAVE
      * IGNORE
     C           CFDLCD    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           CFPOR#    IFGT SVPOR#
     C                     MOVELCFPOR#    SVPOR#
     C                     MOVELCFDOC2    SVDOC2
     C                     ENDIF
     C                     ENDDO
      *
     C           SVDOC2    IFEQ $DOCK
     C                     MOVE 'Y'       $YN
     C                     ELSE
     C                     MOVE 'N'       $YN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *===================================================
      * INITIAL SETTING
      *===================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $PLNT   5
     C                     PARM           $MHIN  12
     C                     PARM           $DOCK   4
     C                     PARM           $YN     1
      *
     C           K#01      KLIST
     C                     KFLD           K#DOCK  5
     C                     KFLD           K#PART 12
      *
     C                     MOVE *BLANK    $YN
     C                     MOVEL$PLNT     K#DOCK
     C                     MOVEL$MHIN     K#PART
      *
     C                     ENDSR
