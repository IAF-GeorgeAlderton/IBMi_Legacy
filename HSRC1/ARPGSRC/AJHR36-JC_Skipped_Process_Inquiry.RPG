DATE FROM IS INVALID                                                   01
FROM DATE > TO DATE                                                    02
NO DATA FOUND                                                          03
ENTER X FOR SELECTION                                                  04
PART NOT FOUND IN MASTER                                               05
DATE TO IS INVALID                                                     06
TIME TO ID INVALID                                                     07
ENTER OK, NG OR BLANK                                                  08
TIME FROM ID INVALID                                                   09
