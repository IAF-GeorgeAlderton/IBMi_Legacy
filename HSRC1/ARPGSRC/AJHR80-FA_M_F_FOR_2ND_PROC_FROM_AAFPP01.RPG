     C*
     C           *IN04     IFEQ *OFF
     C                     TIME           WTIME
     C                     SETON                     04
     C                     ENDIF
     C*
     C           A3SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
     C*有効日・失効日のチェック*
     C           A3UKHZ    IFLE *DATE
     C           A3STHZ    ANDGT*DATE
     C                     ELSE
     C                     GOTO @END
     C                     END
      *
     C           A3ATOK    IFEQ 'JC '
     C                     ELSE
     C                     GOTO @END
     C                     END
      *指定の荷姿があるか
     C                     SETOF                     77
     C           1         DO   2         CT      20
      *
     C           JKT,CT    IFNE *BLANK
     C           JKT,CT    LOKUPTB1                      77
     C                     ENDIF
     C  N77                ENDDO
      *
     C           *IN77     IFEQ '0'
     C                     GOTO @END
     C                     END
      *
     C                     EXSR #MOVE
