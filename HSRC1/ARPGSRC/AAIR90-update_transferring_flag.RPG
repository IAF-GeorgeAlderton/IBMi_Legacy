      *-----------------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *  INITIALIZE
      *-----------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVE '01'      @@ID    2
     C                     Z-ADD0111      K@DPT   40
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  1ST SCREEN
      *-----------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  CHECK
      *-----------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@APCS    IFEQ *BLANK
     C           D@MST1    ANDEQ*BLANK
     C           D@MST2    ANDEQ*BLANK
     C           D@INTR    ANDEQ*BLANK
     C           D@QUEN    ANDEQ*BLANK
     C           D@PLAT    ANDEQ*BLANK
     C                     MOVE *ON       *IN99
     C                     MOVEA'1111111' *IN,61
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
      *
     C           D@APCS    IFNE *BLANK
     C           D@BIN     IFLT 0
     C           D@BIN     ORGT 12
     C                     MOVE *ON       *IN62
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,2     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C           D@BIN     IFNE *ZERO
     C           D@APCS    ANDEQ*BLANK
     C  N99                MOVE ERR,3     D@MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@APCS    IFNE *BLANK
     C           *IN99     ANDEQ*OFF
     C           K@DPT     CHAINAAIPL11             N90
     C           *IN90     IFEQ *OFF
     C                     Z-ADD1         Y       20
     C           D@BIN     LOKUPBA,Y                     10
     C           *IN10     IFEQ *OFF
     C  N99                MOVE ERR,2     D@MSG
     C                     MOVE *ON       *IN62
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           JA,Y      IFNE '*'
     C  N99                MOVE ERR,4     D@MSG
     C                     MOVE *ON       *IN62
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  CLEAR
      *-----------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  WRITE
      *-----------------------------------------------------------
     C           #WRT      BEGSR
      * APICS
     C           D@APCS    IFNE *BLANK
     C           K@DPT     CHAINAAIPL11              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADD1         Y       20
     C           D@BIN     LOKUPBA,Y                     10
     C           *IN10     IFEQ *ON
     C           JA,Y      ANDEQ'*'
     C           FA,Y      ANDEQ*BLANK
     C                     MOVE '*'       FA,Y
     C                     UPDATAAIPP111
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * MASTER
     C           D@MST1    IFNE *BLANK
     C           K@DPT     CHAINAALPL11              90
      *
     C                     ENDSR
      *-----------------------------------------------------------
**   ERR
E-01 SELECT AT LEAST ONE.
E-02 TYPE THE CORRECT BIN#.
E-03 SELECT APICS?
E-04 TODAY'S DATA HAS NOT BEEN CREATED YET.
