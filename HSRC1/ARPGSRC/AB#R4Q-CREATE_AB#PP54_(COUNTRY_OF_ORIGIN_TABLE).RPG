     H            Y.
     F** AB#R4Q ***********************************************
     F*  CREATE AB#PP54 (COUNTRY OF ORIGIN TABLE)             *
     F*  J.W    2024.05.07                                    *
     F*********************************************************
     FFBCWP01 IF  E           K        DISK
     FFAAPL04 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PP54 IF  E           K        DISK                      A
      *========================================================
     I            DS
     I                                        1  12 SHIN1
     I                                        1   5 FBSHN1
     I                                        6  10 FBSHN2
     I                                       11  12 FBSHN3
     I            DS
     I                                        1  12 SHIN2
     I                                        1   5 B7SHN1
     I                                        6  10 B7SHN2
     I                                       11  12 B7SHN3
     I            DS
     I                                        1  12 SHIN3
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
     I            DS
     I                                        1  15 A4MHIN
     I                                        1   5 A4MHN1
     I                                        6  10 A4MHN2
     I                                       11  15 A4MHN3
     I            DS
     I                                        1  15 @@MHIN
     I                                        1   5 @@MHN1
     I                                        6  10 @@MHN2
     I                                       11  15 @@MHN3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      * MAIN ROUTINE
      ******************************************************
     C                     EXSR #INIT
      *
     C                     EXSR #FBCP
      *
     C                     EXSR #FAAP
      *
     C                     EXSR #FCEP
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      * CREATE FROM FBCPP01 (PRICE MASTER)
      ******************************************************
     C           #FBCP     BEGSR
      *
     C           *LOVAL    SETLLFBCWP01
     C                     DO   *HIVAL
     C                     READ FBCWP01                  98
     C   98                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * GET C.O.ORIGIN
     C                     MOVELSHIN1     $PART
     C                     MOVE '0000'    $NONY
     C                     MOVE 'I'       $PTYP
     C                     CALL 'UTLR06A'
     C                     PARM           $PART  20
     C                     PARM           $NONY   4
     C                     PARM           $PTYP   1
     C                     PARM           $CO     3
      *
     C           $CO       IFEQ 'JP '
     C                     MOVELFBSHN1    K4SHN1
     C                     MOVELFBSHN2    K4SHN2
     C                     MOVELFBSHN3    K4SHN3
     C                     MOVELFBMHN1    @@MHN1
     C                     MOVELFBMHN2    @@MHN2
     C                     MOVELFBMHN3    @@MHN3
     C                     EXSR #CHK54
     C           EFLG      IFEQ 'N'
     C                     CLEARAB#PP541
     C                     MOVELFBSHN1    A4SHN1
     C                     MOVELFBSHN2    A4SHN2
     C                     MOVELFBSHN3    A4SHN3
     C                     MOVEL$CO       A4EDIC
     C                     Z-ADDTODAY     A4CRHZ
     C                     Z-ADDNOW       A4CRTM
     C                     MOVEL#USER     A4CRME
     C                     MOVEL#PGM      A4CRPG
     C                     MOVEL'FBCPP01' A4CRSF
     C                     MOVELFBGRP     A4GRP
      *
     C                     Z-ADDFBTOKU    A4TOKU
     C                     Z-ADDFBNONY    A4NONY
     C                     MOVELFBMHN1    A4MHN1
     C                     MOVELFBMHN2    A4MHN2
     C                     MOVELFBMHN3    A4MHN3
     C                     MOVELFBMHN4    A4MHN4
      *
     C                     WRITEAB#PP541
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * CREATE FROM FAAPP02 (COMMON PART)
      ******************************************************
     C           #FAAP     BEGSR
      *
     C           *LOVAL    SETLLFAAPL04
     C                     DO   *HIVAL
     C                     READ FAAPL04                  98
     C   98                LEAVE
      *
     C           B7SKBN    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * GET C.O.ORIGIN
     C                     MOVELSHIN2     $PART
     C                     MOVE '0000'    $NONY
     C                     MOVE 'I'       $PTYP
     C                     CALL 'UTLR06A'
     C                     PARM           $PART  20
     C                     PARM           $NONY   4
     C                     PARM           $PTYP   1
     C                     PARM           $CO     3
      *
     C           $CO       IFEQ 'JP '
     C                     MOVELB7SHN1    K4SHN1
     C                     MOVELB7SHN2    K4SHN2
     C                     MOVELB7SHN3    K4SHN3
     C                     MOVELB7MHN1    @@MHN1
     C                     MOVELB7MHN2    @@MHN2
     C                     MOVELB7MHN3    @@MHN3
     C                     EXSR #CHK54
     C           EFLG      IFEQ 'N'
     C                     CLEARAB#PP541
     C                     MOVELB7SHN1    A4SHN1
     C                     MOVELB7SHN2    A4SHN2
     C                     MOVELB7SHN3    A4SHN3
     C                     MOVEL$CO       A4EDIC
     C                     Z-ADDTODAY     A4CRHZ
     C                     Z-ADDNOW       A4CRTM
     C                     MOVEL#USER     A4CRME
     C                     MOVEL#PGM      A4CRPG
     C                     MOVEL'FAAPP02' A4CRSF
      *
     C                     Z-ADDB7TOKU    A4TOKU
     C                     Z-ADDB7NONY    A4NONY
     C                     MOVELB7MHN1    A4MHN1
     C                     MOVELB7MHN2    A4MHN2
     C                     MOVELB7MHN3    A4MHN3
     C                     MOVELB7MHN4    A4MHN4
      *
     C                     SELEC
     C           A4TOKU    WHEQ 3411
     C                     MOVE 'TYT'     A4GRP
     C           A4TOKU    WHEQ 5149
     C                     MOVE 'FRD'     A4GRP
     C           A4TOKU    WHEQ 0294
     C           A4TOKU    OREQ 0295
     C           A4TOKU    OREQ 0296
     C           A4TOKU    OREQ 0390
     C           A4TOKU    OREQ 0391
     C           A4TOKU    OREQ 0400
     C           A4TOKU    OREQ 1602
     C           A4TOKU    OREQ 3135
     C                     MOVE 'HND'     A4GRP
     C                     ENDSL
      *
     C                     WRITEAB#PP541
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * CHECK PART EXISTS IN PP54?
      ******************************************************
     C           #CHK54    BEGSR
      *
     C                     MOVE 'N'       EFLG    1
     C           KEY54     SETLLAB#PP54
     C                     DO   *HIVAL
     C           KEY54     READEAB#PP54                  98
     C   98                LEAVE
      *
     C           A4MHIN    IFEQ @@MHIN
     C                     MOVE 'Y'       EFLG
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * CREATE FROM FCEPP01 (IAF PART)
      ******************************************************
     C           #FCEP     BEGSR
      *
     C           *LOVAL    SETLLFCEPL01
     C                     DO   *HIVAL
     C                     READ FCEPL01                  98
     C   98                LEAVE
      *
     C           A2GSKD    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELSHIN3     $PART
     C                     MOVE '0000'    $NONY
     C                     MOVE 'I'       $PTYP
     C                     CALL 'UTLR06A'
     C                     PARM           $PART  20
     C                     PARM           $NONY   4
     C                     PARM           $PTYP   1
     C                     PARM           $CO     3
      *
     C           $CO       IFEQ 'JP '
     C                     MOVELA2BHB1    K4SHN1
     C                     MOVELA2BHB2    K4SHN2
     C                     MOVELA2BHB3    K4SHN3
     C                     MOVELA2BHB1    @@MHN1
     C                     MOVELA2BHB2    @@MHN2
     C                     MOVELA2BHB3    @@MHN3    P
     C                     EXSR #CHK54
     C           EFLG      IFEQ 'N'
     C                     CLEARAB#PP541
     C                     MOVELA2BHB1    A4SHN1
     C                     MOVELA2BHB2    A4SHN2
     C                     MOVELA2BHB3    A4SHN3
     C                     MOVEL$CO       A4EDIC
     C                     Z-ADD0         A4TOKU
     C                     MOVELA2BHB1    A4MHN1
     C                     MOVELA2BHB2    A4MHN2
     C                     Z-ADDTODAY     A4CRHZ
     C                     Z-ADDNOW       A4CRTM
     C                     MOVEL#USER     A4CRME
     C                     MOVEL#PGM      A4CRPG
     C                     MOVEL'FCEPP01' A4CRSF
     C                     WRITEAB#PP541
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * INITIAL SETTING
      ******************************************************
     C           #INIT     BEGSR
      *
     C           KEY54     KLIST
     C                     KFLD           K4SHN1  5
     C                     KFLD           K4SHN2  5
     C                     KFLD           K4SHN3  2
      *
     C                     TIME           SDATE
      *
     C                     ENDSR
