     FABTPW03 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     F                                              KNUM        1
     F                                              KINFDS INFDS
     FABTWP02 IF  E           K        DISK
     F**AB#PPM1 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I            DS
     I                                        1   5 S1NOTM
     I                                        1   2 S1NTIH
     I                                        3   3 S1NTTT
     I                                        4   5 S1NTIM
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     IINFDS       DS
     I                                    B 370 3710#CUR
     I                                    B 378 3790#POS
     I                                      401 402 MJCODE
     I                                      401 404 MJCOD4
     I                                     *STATUS  @STTS
      *
     I              'INSPECTION'          C         KBN1
     I              'BZ        '          C         KBN2
     I              'SB        '          C         KBN3
     I              'H.T.      '          C         KBN4
     I              'DS        '          C         KBN5
     I              'JC        '          C         KBN6
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KBN   1
     C                     PARM           P1PG    50
     C                     PARM           P1DATE  8
     C                     PARM           P1TIME  6
     C                     PARM           P1REC  100
     C                     PARM           P1CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
     C                     MOVEL*BLANK    C1DEPT
     C                     SELEC
     C           P1KBN     WHEQ '1'
     C                     MOVELKBN1      C1DEPT
     C           P1KBN     WHEQ '2'
     C                     MOVELKBN2      C1DEPT
     C           P1KBN     WHEQ '3'
     C                     MOVELKBN3      C1DEPT
     C           P1KBN     WHEQ '4'
     C                     MOVELKBN4      C1DEPT
     C           P1KBN     WHEQ '5'
     C                     MOVELKBN5      C1DEPT
     C           P1KBN     WHEQ '6'
     C                     MOVELKBN6      C1DEPT
     C                     ENDSL
      *
     C                     MOVE P1DATE    C1DATE
     C                     MOVE P1TIME    C1TIME
      *
     C                     MOVEL*BLANK    P1CMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
     C                     Z-ADD0         WKPAG@  30
     C           P1REC     DIV  7         SS      30
     C                     MVR            RR      30
     C           RR        IFNE 0
     C                     ADD  1         SS
     C                     ENDIF
     C           P1PG      IFGT SS
     C                     Z-ADD1         P1PG
     C                     ENDIF
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLABTWP021
     C                     READ ABTWP021                 81
      *
     C           WKPAG@    DOWLTP1PG
     C                     EXSR #CLR
      *
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ABTWP021                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAG@
     C                     ADD  1         WKPAGE
     C                     ENDDO
      *
     C                     Z-ADDP1PG      WKPAGE  30
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C*******              EXFMTSFLCTL
     C           CTRX      IFEQ 0
     C                     WRITEABTPW039               92
     C                     ELSE
     C                     WRITESFLCTL                 92
     C                     ENDIF
     C                     READ ABTPW03                9898
      *
     C                     SETOF                     7273
     C                     SETOF                     3199
     C           *IN,98    IFEQ '1'
     C           @STTS     ANDEQ1331
     C           *IN81     IFEQ '1'
     C                     Z-ADD1         P1PG
     C                     ELSE
     C                     ADD  1         P1PG
     C                     ENDIF
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      P1CMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F5
     C           *IN05     IFEQ '1'
     C                     MOVEL'05'      P1CMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTABTWP021
     C                     READPABTWP021                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  07        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPABTWP021                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLABTWP021
     C                     READ ABTWP021                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C                     SUB  1         WKPAGE
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ABTWP021                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     ADD  1         WKPAGE
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ABTWP021                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     EXSR #EDIT
     C                     WRITESFL
      *
     C           CTRX      IFEQ 07
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT DATA                                        *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR ITEM                                         *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT ITEM                                          *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     Z-ADD0         #1NO   110
     C           WKPAGE    MULT 07        #1NO
     C                     SUB  07        #1NO
     C                     ADD  CTRX      #1NO
     C                     Z-ADD#1NO      S1NO
     C                     Z-ADDW2CNT     S1CNT
      *
     C                     MOVEL*BLANK    S1LOCA
     C           W2LOC2    IFNE *BLANK
     C           W2LOC2    CAT  '-':0     S1LOCA
     C           S1LOCA    CAT  W2LOC3:0  S1LOCA
     C                     ENDIF
      *
     C                     MOVEL*BLANK    S1SHN
     C                     MOVELW2LPR1    S1SHN
     C           W2LPR2    IFNE *BLANK
     C           S1SHN     CAT  '-':0     S1SHN
     C           S1SHN     CAT  W2LPR2:0  S1SHN
     C                     ENDIF
     C           W2LPR3    IFNE *BLANK
     C           S1SHN     CAT  '-':0     S1SHN
     C           S1SHN     CAT  W2LPR3:0  S1SHN
     C                     ENDIF
      *
     C                     Z-ADDW2SRTD    S1SRTD
     C                     SELEC
     C           P1KBN     WHEQ '1'
     C                     Z-ADDW2STKD    S1ULD
     C                     ADD  W2SBKD    S1ULD
     C                     ADD  W2HTKD    S1ULD
     C                     Z-ADDW2STID    S1IN
     C                     ADD  W2SBID    S1IN
     C                     ADD  W2HTID    S1IN
     C                     Z-ADDW2STPD    S1PLD
     C                     ADD  W2SBPD    S1PLD
     C                     ADD  W2HTPD    S1PLD
     C           P1KBN     WHEQ '2'
     C                     Z-ADDW2STKD    S1ULD
     C                     Z-ADDW2STID    S1IN
     C                     Z-ADDW2STPD    S1PLD
     C           P1KBN     WHEQ '3'
     C                     Z-ADDW2SBKD    S1ULD
     C                     Z-ADDW2SBID    S1IN
     C                     Z-ADDW2SBPD    S1PLD
     C           P1KBN     WHEQ '4'
     C                     Z-ADDW2HTKD    S1ULD
     C                     Z-ADDW2HTID    S1IN
     C                     Z-ADDW2HTPD    S1PLD
     C                     ENDSL
     C                     Z-ADDW2PRE     S1PRE
     C                     Z-ADDW2CVS     S1CVS
     C                     MOVEL'SRT'     S1PROC
     C                     MOVELW2MSN#    S1MSN#
      *
     C                     Z-ADDW2NODT    S1NODT
     C                     MOVELW2NOBN    S1NOBN
     C                     MOVEL*BLANK    S1NOTM
     C           KEYM1     KLIST
     C                     KFLD           K@NONY  4
     C                     KFLD           K@BIN   2
     C                     MOVELW2NONY    K@NONY
     C                     MOVE W2NOBN    K@BIN
     C***        KEYM1     CHAINAB#PPM1              47
     C***        *IN47     IFEQ '0'
     C***        M@SKJY    IFEQ 'D'
     C***        M@SKDT    ANDLE*DATE
     C***                  ELSE
     C***                  MOVELM@NTIM    S1NTIH
     C***                  MOVEL':'       S1NTTT
     C***                  MOVE M@NTIM    S1NTIM
     C***        M@CHGD    IFGT *DATE
     C***                  MOVELM@OTIM    S1NTIH
     C***                  MOVEL':'       S1NTTT
     C***                  MOVE M@OTIM    S1NTIM
     C***                  ENDIF
     C***                  ENDIF
     C***                  ENDIF
     C***        W2NOTM    IFEQ 0
     C***                  MOVEL*BLANK    S1NOTM
     C***                  ELSE
     C                     MOVELW2NOTM    S1NTIH
     C                     MOVEL':'       S1NTTT
     C                     MOVE W2NOTM    S1NTIM
     C***                  ENDIF
     C*
     C                     MOVELW2TOKU    S1TOKU
     C                     MOVELW2NONY    S1NONY
     C                     MOVELW2NKOJ    S1NKOJ
     C                     MOVELW2NUKE    S1NUKE
     C                     MOVEL*BLANK    S1TONM
     C           KEYGAD    KLIST
     C                     KFLD           W2TOKU
     C                     KFLD           W2NONY
     C                     KFLD           W2NKOJ
     C                     KFLD           W2NUKE
     C           KEYGAD    CHAINGADPL11              47
     C           *IN47     IFEQ '0'
     C                     MOVELB5KMEI    S1TONM
     C                     ENDIF
     C                     MOVEL*ALL'-'   S1FFFF
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * NEXT DATA                                          *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
