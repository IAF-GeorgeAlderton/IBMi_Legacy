     H            Y.
     F** EDSR70 ***********************************************
     F*  PROGRAM: UTILITY - SAVE AB#EP70/71 TO AB#EP70S/71S
     F*  WRITTEN: JW (SRA)
     F*           07/29/2016
     F*--------------------------------------------------------
     FAB#EP70 UF  E                    DISK
     FAB#EP71 UF  E                    DISK
     FAB#EP70SO   E                    DISK
     FAB#EP71SO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * INITIAL SETTING
     C                     TIME           D#TIME
      * SAVE AB#EP70 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ AB#EP70                  99
     C           *IN99     IFEQ *OFF
     C           E7FLG0    ANDEQ*BLANK
     C                     Z-ADDTODAY     E7CRDT
     C                     Z-ADDNOW       E7CRTM
     C                     MOVEL#USER     E7CRUS
     C                     MOVEL#WSID     E7CRWS
     C                     MOVEL#PGM      E7CRPG
     C                     WRITEAB#E70S1
      *
     C                     MOVE '*'       E7FLG0
     C                     UPDATAB#EP701
     C                     ENDIF
     C                     ENDDO
      * SAVE AB#EP71 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ AB#EP71                  99
     C           *IN99     IFEQ *OFF
     C           E7FLG1    ANDEQ*BLANK
     C                     Z-ADDTODAY     E7CRDT
     C                     Z-ADDNOW       E7CRTM
     C                     WRITEAB#E71S1
      *
     C                     MOVE '*'       E7FLG1
     C                     UPDATAB#EP711
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
