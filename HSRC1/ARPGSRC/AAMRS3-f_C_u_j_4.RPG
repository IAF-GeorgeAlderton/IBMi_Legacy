      *================================================================
      *   PARAMETER TRANCEFER                              *
      *================================================================
     C           *ENTRY    PLIST
      *  IN
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@TKR   6
     C                     PARM           P@AKT1  3
     C                     PARM           P@AKT2  3
     C                     PARM           P@AKT3  3
     C                     PARM           P@AKT4  3
     C                     PARM           P@OPCL  1
      *  OUT
     C                     PARM           P@MHIN 12
     C                     PARM           P@MZET  4
     C                     PARM           P@KBY1  6        機番予備１
     C                     PARM           P@KBY2  6        機番予備２
     C                     PARM           P@KBY3  6        機番予備３
     C                     PARM           P@FLG   1
      *================================================================
      *   メインルーチン                                 *
      *================================================================
     C           P@OPCL    IFEQ '1'
     C                     OPEN AAMPL11
     C                     OPEN ABHPL03
     C                     OPEN ADHPL03
     C                     OPEN AAFPL03
     C                     OPEN AAHPL03
     C                     OPEN FGBPL01
     C                     ENDIF
      *強制終了
     C           P@OPCL    IFEQ '9'
     C                     CLOSEAAMPL11
     C                     CLOSEABHPL03
     C                     CLOSEADHPL03
     C                     CLOSEAAFPL03
     C                     CLOSEAAHPL03
     C                     CLOSEFGBPL01
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C                     MOVE *BLANK    NKOT             工程
     C                     Z-ADD0         NBMN             部門
     C                     MOVE *BLANK    NTKR             所番地
     C                     MOVE *BLANK    NTKR             所番地
     C                     MOVE *BLANK    NSHR             かんばん種類
     C                     MOVE *BLANK    NHBN             品番
     C                     MOVE *BLANK    OKOT             工程
     C                     Z-ADD0         OBMN             部門
     C                     MOVE *BLANK    OTKR             所番地
     C                     MOVE *BLANK    OSHR             かんばん種類
     C                     MOVE *BLANK    OHBN             品番
     C                     MOVE *ZERO     KHZ
     C                     MOVE *BLANK    SKOT             工程
     C                     Z-ADD0         SBMN             部門
     C                     MOVE *BLANK    STKR             所番地
     C                     MOVE *BLANK    SSHR             かんばん種類
     C                     MOVE *BLANK    SHBN             品番
      *
     C                     MOVE *BLANK    P@MHIN 12
     C                     MOVE *BLANK    P@MZET  4
     C                     MOVE *BLANK    P@KBY1  6        機番予備１
     C                     MOVE *BLANK    P@KBY2  6        機番予備２
     C                     MOVE *BLANK    P@KBY3  6        機番予備３
     C                     MOVE *BLANK    P@FLG   1
      *
     C           KEYCK1    KLIST
     C                     KFLD           P@HIN1  5
     C                     KFLD           P@HIN2  5
     C                     KFLD           P@HIN3  2
      *
     C           KEYCK1    CHAINAAMPL11              90
     C           *IN90     IFEQ *OFF
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     ENDIF
     C*
     C           *IN90     IFEQ *ON
     C                     MOVE '9'       P@FLG
     C                     ELSE
     C                     EXSR ###
     C                     ENDIF
     C*
     C                     RETRN
      *================================================================
      *
      *================================================================
     C           ###       BEGSR
      *
S1   C           1         DO   15        X       20
 S2  C           KHZ,X     IFNE *ZERO
     C                     MOVELKHZ,X     CHKDAT  80
     C                     MOVE OKOT,X    SKOT,X           工程
     C                     Z-ADDOBMN,X    SBMN,X           部門
     C                     MOVE OTKR,X    STKR,X           所番地
     C                     MOVE OSHR,X    SSHR,X           かんばん種
     C                     MOVE OHBN,X    SHBN,X           品番
  S3 C           *DATE     IFGE CHKDAT
     C                     MOVE NKOT,X    SKOT,X           工程
     C                     Z-ADDNBMN,X    SBMN,X           部門
     C                     MOVE NTKR,X    STKR,X           所番地
     C                     MOVE NSHR,X    SSHR,X           かんばん種
     C                     MOVE NHBN,X    SHBN,X           品番
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDDO
      *
     C                     Z-ADD1         Z       20
     C           P@TKR     LOKUPSTKR,Z                   50:EQ
      *-------------------------
S1   C           *IN50     IFEQ *ON
 S2  C                     DO   *HIVAL
     C                     SUB  1         Z
  S3 C           Z         IFLE 0
     C                     LEAVE
  E3 C                     ENDIF
  S3 C           STKR,Z    IFNE '------'                   所番地
     C                     MOVE STKR,Z    $TKR    6        所番地
     C                     MOVE SSHR,Z    $SHR    1        かんばん種
     C                     MOVE SHBN,Z    P@MHIN           品番
     C                     MOVE '1'       P@FLG
     C                     LEAVE
  E3 C                     ENDIF
 E2  C                     ENDDO
E1   C                     ENDIF
      *-------------------------
S1   C           P@FLG     IFEQ '1'
     C                     SELEC
     C           $SHR      WHEQ 'A'                        かんばん種
     C                     EXSR #ABH
     C           $SHR      WHEQ 'B'                        かんばん種
     C                     EXSR #ADH
     C           $SHR      WHEQ 'C'                        かんばん種
     C                     EXSR #AAF
     C           $SHR      WHEQ 'E'                        かんばん種
     C                     EXSR #AAH
     C                     ENDSL
E1   C                     ENDIF
      *-------------------------
      *機番予備
      *-------------------------
     C                     Z-ADD0         Z
     C           P@AKT1    IFNE *BLANK
     C                     MOVE P@AKT1    $$AKT   3
     C                     EXSR #AKT
     C                     ENDIF
     C           P@AKT2    IFNE *BLANK
     C                     MOVE P@AKT2    $$AKT
     C                     EXSR #AKT
     C                     ENDIF
     C           P@AKT3    IFNE *BLANK
     C                     MOVE P@AKT3    $$AKT
     C                     EXSR #AKT
     C                     ENDIF
     C           P@AKT4    IFNE *BLANK
     C                     MOVE P@AKT4    $$AKT
     C                     EXSR #AKT
     C                     ENDIF
      *
     C                     ENDSR
      *================================================================
     C           #AKT      BEGSR
      *
     C                     Z-ADD1         X
     C           $$AKT     LOKUPSKOT,X                   50:EQ
      *
S1   C           *IN50     IFEQ *ON
     C           SBMN,X    ANDNE0111
     C           SBMN,X    CHAINFGBPL011             91
 S2  C           *IN91     IFEQ *OFF
     C           B2SKJY    ANDNE'D'
     C                     ADD  1         Z
  S3 C                     SELEC
     C           Z         WHEQ 1
     C                     MOVELB2SMEI    P@KBY1           機番予備１
     C           Z         WHEQ 2
     C                     MOVELB2SMEI    P@KBY2           機番予備２
     C           Z         WHEQ 3
     C                     MOVELB2SMEI    P@KBY3           機番予備３
  E3 C                     ENDSL
 E2  C                     ENDIF
E1   C                     ENDIF
      *
     C                     ENDSR
      *================================================================
      * INTRA-PROCESS KANBAN M/F
      *================================================================
     C           #ABH      BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           $TKR1
     C                     KFLD           $TKR2
     C                     KFLD           $TKR3
     C                     KFLD           $TKR4
      *
     C           KEY01     SETGTABHPL03
     C                     DO   *HIVAL
     C           KEY01     REDPEABHPL03                  91
     C   91                LEAVE
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           M6UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C                     MOVE M6ZETI    P@MZET
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================
      * QUENCHING KANBAN M/F *
      *================================================================
     C           #ADH      BEGSR
      *
     C           KEY01     SETGTADHPL03
     C                     DO   *HIVAL
     C           KEY01     REDPEADHPL03                  91
     C   91                LEAVE
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           J6UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C                     MOVE J6ZETI    P@MZET
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================
      * PLATING KANBAN M/F ...           *
      *================================================================
     C           #AAF      BEGSR
      *
     C           KEY01     SETGTAAFPL03
     C                     DO   *HIVAL
     C           KEY01     REDPEAAFPL03                  91
     C   91                LEAVE
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           A3UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C                     MOVE A3ZETI    P@MZET
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================
      * PART WITHDRAWAL KANBAN M/F.        *
      *================================================================
     C           #AAH      BEGSR
      *
     C           KEY01     SETGTAAHPL03
     C                     DO   *HIVAL
     C           KEY01     REDPEAAHPL03                  91
     C   91                LEAVE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L6UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C                     MOVE L6ZETI    P@MZET
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================
