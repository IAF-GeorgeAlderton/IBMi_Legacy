     H            Y.
     F** FBCR45 ****************************************************************
     F*  PROGRAM    : PRINT FORD PRICE LIST (TO BE STOPPED)                    *
     F*  WRITTEN    : 6/18/2018                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FFBCPL16 IF  E           K        DISK
     FAB#PL05 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80EFDATE
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1   80EXDATE
     I                                        1   40FBTSYY
     I                                        5   60FBTSMM
     I                                        7   80FBTSDD
     I            DS
     I                                        1   80UPDATE
     I                                        1   40FBKOYY
     I                                        5   60FBKOMM
     I                                        7   80FBKODD
     I            DS
     I                                        1   40UPTIME
     I                                        1   20FBKOHH
     I                                        3   40FBKOSS
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR @INIT
      *
     C           *IN98     DOWEQ*OFF
     C                     READ FBCPL16                  98
      * END?
     C           *IN98     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      * IGNORE DELETED
     C           FBSKJY    IFNE ' '
     C                     ITER
     C                     ENDIF
      * IGNORE OTHER THAN FORD
     C           FBTOKU    IFNE 5149
     C                     ITER
     C                     ENDIF
      * IGNORE 5288, 8888
     C**         FBNONY    IFEQ 5288
     C**         FBNONY    OREQ 8888
     C**                   ITER
     C**                   ENDIF
      * IGNORE EXP_DATE<>9999
     C           FBTSYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      * IGNORE INDIVUDIAL FLAN=Y
     C           FBIND     IFEQ 'Y'
     C                     ITER
     C                     ENDIF
      * IGNORE SHIPPING LOG EXISTS
     C           K#PL05    CHAINAB#PL05              99
     C           *IN99     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      * PRINT
     C                     EXSR @PRINT
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           @PRINT    BEGSR
      *
     C           LIN#      IFGE 63
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           K#PL05    KLIST
     C                     KFLD           FBTOKU
     C                     KFLD           FBNONY
     C                     KFLD           FBMHN1
     C                     KFLD           FBMHN2
     C                     KFLD           FBMHN3
     C                     KFLD           FBMHN4
      *
     C                     TIME           WSDT
     C                     Z-ADD0         SEQ#    60
     C                     Z-ADD90        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** FORD PRICE LIST ('
     O                                   60 'TO BE STOPPED)      '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  116 'P.'
     O                         PAGE  Z  120
     O        E   03           @HDR
     O                                    7 'SEQ#'
     O                                    9 'I'
     O                                   14 'CUST'
     O                                   19 'DELV'
     O                                   35 'USER PART______'
     O                                   44 'F  DOCK'
     O                                   55 'U/P'
     O                                   67 'EFFECTIVE'
     O                                   77 'EXP_DATE'
     O                                   88 'UPDATE  '
     O                                   95 'TIME'
     O                                  101 'USER'
      *
     O        E 1              @DTL1
     O                         SEQ#  Z +001
     O                         FBIND   +001
     O                         FBTOKU  +001
     O                         FBNONY  +001
     O                         FBMHN1  +001
     O                         FBMHN2  +001
     O                         FBMHN3  +001
     O                         FBNKOJ  +001
     O                         FBNUKE  +001
     O                         FBNTAN1 +001
     O                         EFDATEY +001
     O                         EXDATEY +001
     O                         UPDATEY +001
     O                         UPTIME  +001 '0 :  '
     O                         FBKOME  +001
      *
