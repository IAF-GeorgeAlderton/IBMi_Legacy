     H            Y/
     F***************************************************
     F* Reset accumulated quantity from january 1st     *
     F*                                                 *
     F*     FORD all plant                              *
     F*                                                 *
     F* TCHK1 12/20/07 CRATE(copied from AB#RFY2)       *
     F* TCHK2 02/17/13 CHG CFDOCK LENGTH(4 --> 5)       *
JW1  F* JW1   11/25/20 ADD LOG FILE                     *
     F***************************************************
     FABFAP01 UF  E           K        DISK
JW1  FABFAP02 O   E           K        DISK
      *------------------------------------------------------------
     I            DS
TCHK1I                                        1   5 CFDOCK
     I                                        1   2 @@DOCK
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@H
     I                                        3   40W@M
     I                                        5   60W@S
     I                                        7  140W@YMD
JW1  I                                        1   60NOW
 .   I                                        7  140TODAY
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@OPT   1
     C*
     C                     EXSR @INT
     C*
     C           *LOVAL    SETLLABFAP01R
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABFAP01R                 99
     C   99                LEAVE
JW1   * LOG
 .   C                     MOVEL'BEFORE'  C2UPST
 .   C                     EXSR #LOGU
     C* CUM.FROM AUG/01
     C                     Z-ADD*ZERO     CFCAMN
     C* LAST DAY CUM. QTY.
     C           P@OPT     IFEQ '1'
     C                     Z-ADD*ZERO     CFCAMT
     C                     ENDIF
     C                     Z-ADD*YEAR     CFUPDY
     C                     Z-ADD*MONTH    CFUPDM
     C                     Z-ADD*DAY      CFUPDD
     C                     Z-ADDW@H       CFUPTH
     C                     Z-ADDW@M       CFUPTM
     C                     Z-ADD0         CFUPNM
     C*
     C                     UPDATABFAP01R
JW1   * LOG
 .   C                     MOVEL'AFTER '  C2UPST
 .   C                     EXSR #LOGU
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
JW1  C***********************************************************
 .   C* LOG FILE
 .   C***********************************************************
 .   C           #LOGU     BEGSR
      *
     C                     MOVE *BLANK    C2DLCD
     C                     Z-ADD0         C2DLHZ
     C                     Z-ADD0         C2DLTM
     C                     MOVE *BLANK    C2DLUS
     C                     Z-ADDTODAY     C2UPHZ
     C                     Z-ADDNOW       C2UPTM
     C                     MOVEL#USER     C2UPUS
     C                     Z-ADD0         C2CRHZ
     C                     Z-ADD0         C2CRTM
     C                     MOVEL#PGM      C2CRUS
 .   C                     WRITEABFAP02R
 .    *
JW1  C                     ENDSR
     C******************************************************
     C* @INT : Initial                                     *
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           W@TIME
     C*
     C                     ENDSR
