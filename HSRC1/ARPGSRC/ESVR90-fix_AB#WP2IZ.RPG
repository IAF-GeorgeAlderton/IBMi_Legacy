     H            Y.
     F** ESVR90 ********************************************
     F*  PROGRAM: FIX AB#WP2IZ                             *
     F*  WRITTEN: JW (SRA) 2024.10.09                      *
     F*----------------------------------------------------*
     FAB#WL2IZUF  E           K        DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * MAIN ROUTINE
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
      * READ AB#WP2IZ -------------------------------------
     C           @FROM     SETLLAB#WL2IZ
     C                     DO   *HIVAL
     C                     READ AB#WL2IZ                 98
     C   98                LEAVE
      *
     C           I2CRWS    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELI2CRDT    $CRHZ
     C                     MOVELI2CRPF    $FILE
     C                     MOVELI2CRUS    $USER
     C                     MOVELI2DELY    $NONY
     C                     MOVELI2SHDT    $NOHZ
      *
     C                     SELEC
     C           I2DELY    WHEQ '0567'
     C                     MOVELI2RELS    LTR13  13
     C                     MOVE LTR13     $ODRN
     C                     OTHER
     C                     MOVELI2ORDR    $ODRN
     C                     ENDSL
      *
     C                     CALL 'UTLR51B'
     C                     PARM           $CRHZ   8
     C                     PARM           $FILE  10
     C                     PARM           $USER  10
     C                     PARM           $NONY   4
     C                     PARM           $NOHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
      *
     C                     MOVEL$PICK#    I2CRWS
      *
     C           I2CRWS    IFNE *BLANK
     C                     UPDATAB#WP2ZR
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      * INITIAL SETTING
      *--------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $FROM   8
      *
     C                     TIME           SDATE
      *
     C           $FROM     IFEQ ' '
     C                     Z-ADDTODAY     @FROM   80
     C                     ELSE
     C                     MOVEL$FROM     @FROM
     C                     ENDIF
      *
     C                     ENDSR
