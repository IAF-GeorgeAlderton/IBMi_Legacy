     H            Y.
     F** ALRR20 *******************************************************
     F* SORTING SCAN
     F*   KIRI                                               2019.12.04
JW1  F*   JW    2020.09.28 CHK MULTIPLE SCAN
JW2  F*   JW    2020.12.18 CHG LF ALRPL21 TO ALRPL21A
.    F*                    CHG LF ALRPL22 TO ALRPL22A
     F*****************************************************************
     FALRPW20 CF  E                    WORKSTN
      *
     FFCETL11 IF  E           K        DISK
JW1  F**ALRPL21 IF  E           K        DISK
"    F**ALRPL22 IF  E           K        DISK
JW2  FALRPL21AIF  E           K        DISK
"    FALRPL22AIF  E           K        DISK
      *
     FALRPP20 O   E                    DISK
      *================================================================
     E                    ER      1  25 60
     E                    DUP      9999256
      *================================================================
      *
      *---------------------------------------------
      *
     I$$BAR       DS
     I                                        1   1 BCTYPE
     I                                        1   3 QRTYPE
     I                                        5   5 QRKDAI
JW1  I                                        7  10 QRZETI
      *MEKI
     I                                        2   5 A@ZETI
     I                                        6   8 A@LOT#
      *PTKANBAN
     I                                       12  12 P@KCD1
      *INTER
     I                                        2   5 #2ZETI
     I                                        6   7 #2BMNA
     I                                        8   8 #2KDAI
     I                                        9  11 #2KOTI
     I                                       12  14 #2HKNO
      *
JW1  I                                        1 200 $$BARK
     I                                        1 256 $$BAR1
     I                                      257 512 $$BAR2
      *
     I                                        1  20 D1SBAR
      *  A-PICS
     I                                        2   5 D1SZET
     I                                        6   8 D1STEH
     I                                        9  10 D1SPAG
      *  INTRA PROC
     I                                        1   1 D1KSNK
     I                                        6   7 D1ATOH
     I                                        8   8 D1ATYP
     I                                        9  11 D1KOTE
     I                                       12  14 D1BPAG
     I                                       15  15 D1CD
      *
      *---------------------------------------------
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
      *
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
      *
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
      *
     I            DS
     I                                        1  12 W1SHN
     I                                        1   5 W1SHN1
     I                                        6  10 W1SHN2
     I                                       11  12 W1SHN3
     I            DS
     I                                        1  12 W2SHN
     I                                        1   5 W2SHN1
     I                                        6  10 W2SHN2
     I                                       11  12 W2SHN3
     I*
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIME6
     I                                        7  140WDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           POPR    6
     C                     PARM           PITANT 20
     C                     PARM           PISECT  1
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
     C                     TIME           WTIME
     C                     Z-ADD0         D1CTR
     C                     Z-ADD0         Z       40
     C                     MOVE *BLANK    DUP
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *================================================================
      * FIRST SCREEN - Display Screen for 1ST KANBAN Entry   *
      *================================================================
     CSR         #SB100    BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
      *
      * if any Function Key was hit other than F1, just display
      * screen 1 again.
     C                     SELEC
     C           *IN01     WHEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB100
     C           *IN02     WHEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     GOTO ESB100
     C                     OTHER
     C                     ENDSL
      *
     C           D1BAR     IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVELD1BAR     $$BAR
JW1   * CHECK QR
 .   C           QRTYPE    IFNE 'B01'
 .   C           QRTYPE    ANDNE'C01'
 .   C                     SETON                     99
 .   C                     MOVELER,1      D9ERR
 .   C                     EXSR #SB290
 .   C                     MOVEL*BLANK    D1BAR
 .   C                     GOTO ESB100
JW1  C                     ENDIF
      *
      * CHECK DIGIT - if check digit is not correct, display
      * error screen.
     C                     EXSR ##BAR
      *
     C** 99                MOVEL'NG'      W$OKNG  2
     C** 99                EXSR #SB500
     C   99                MOVEL*BLANK    D1BAR
     C   99                GOTO ESB100
      *
     C                     ADD  1         D1CTR
     C                     ADD  1         Z
     C                     MOVELW$BAR     DUP,Z
      *
     C                     MOVEL'OK'      W$OKNG  2
     C                     MOVE *BLANKS   ERRCOD  2
     C                     EXSR #SB500
     C                     MOVEL*BLANK    D1BAR
     C                     SETON                     61
     C                     MOVEL'01'      DSPSW
      *
     CSR         ESB100    ENDSR
      *================================================================
      *
      *================================================================
     C           ##BAR     BEGSR
     C                     MOVEL*BLANK    W$AHN1  5
     C                     MOVEL*BLANK    W$AHN2  5
     C                     MOVEL*BLANK    W$AHN3  2
     C                     MOVEL*BLANK    W$AZET  4
     C                     MOVEL*BLANK    W$TEHA  3
     C                     MOVEL*BLANK    W$PAGE  2
     C                     Z-ADD0         W$HAHZ  80
     C                     Z-ADD0         W$HABB  20
      **
     C                     MOVEL*BLANK    W$BAR 256
     C                     MOVEL*BLANK    W$QR    2
     C                     MOVEL*BLANK    W$ERCD  2
      **
     C                     MOVEL*BLANK    W$KCD   1
      **
      *////////////////////////////////////////////////////
S1   C           QRTYPE    IFNE 'B01'                      :NE QRCODE
 1   C           QRTYPE    ANDNE'C01'                      :NE QRCODE
     C                     MOVEL$$BAR     W$BAR
      *                   *
      * CHECK DIGIT - call program to get check digit and compare
      *  to make sure it's correct.
      *
      *  if kanban barcode starts with an "I" then it's a Pass Thru
      *   kanban, so it will be 16 chars instead of 14 like the apics kanban
      *
     C           1         SUBST$$BAR:1   BCID    1
 S2  C           BCID      IFEQ 'I'
     C                     MOVEL$$BAR     PMAREA
     C                     MOVEL'016'     PMBYTE
     C           1         SUBST$$BAR:17  WKCHK   1
     C                     EXSR #SB600
 X2  C                     ELSE
     C                     MOVEL$$BAR     PMAREA
     C                     MOVEL'014'     PMBYTE
     C           1         SUBST$$BAR:15  WKCHK   1
     C                     EXSR #SB600
 E2  C                     ENDIF
      *
      * if check digits don't match, display error, go back to screen2.
 S2  C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     MOVEL'02'      W$ERCD  2
     C                     EXSR #SB290
     C                     GOTO E##BAR
 E2  C                     ENDIF
     C*
E1   C                     ENDIF
      *                   *
      *////////////////////////////////////////////////////
      *
      *
      * get part information from PART INFORMATION M/F
      *
S1   C           QRTYPE    IFEQ 'B01'
     C           QRTYPE    OREQ 'C01'
     C           4         SUBST$$BAR:7   W$AZET           QR
X1   C                     ELSE
     C           4         SUBST$$BAR:2   W$AZET
E1   C                     ENDIF
      *
     C                     MOVEL'0'       PRTCHK  1
      *
     C           W$AZET    CHAINFCETL111             21
      *
S1   C           *IN21     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLEWDATE
     C                     SETON                     21
E1   C                     ENDIF
      *
      * part number found and not marked for delete.
S1   C           *IN21     IFEQ '0'
     C                     MOVEL'1'       PRTCHK
     C                     MOVELA2BHB1    W$AHN1
     C                     MOVELA2BHB2    W$AHN2
     C                     MOVELA2BHB3    W$AHN3
E1   C                     ENDIF
      *
      * QR
S1   C           QRTYPE    IFEQ 'B01'                      := QR
     C           QRTYPE    OREQ 'C01'                      := QR
     C                     GOTO @@QR
E1   C                     ENDIF
      *///////////////////////////////////
      * CODE 39
      *///////////////////////////////////
      * INTRA PROC
S1   C           BCTYPE    IFGE '0'
     C           BCTYPE    ANDLE'9'
     C                     MOVEL*BLANK    W$TEHI
     C                     MOVELD1BPAG    W$PAGE
     C                     MOVELD1KOTE    W$KOTE  3
     C                     MOVEL#2KDAI    W$KCD
X1   C                     ELSE
      * A-PICS
     C           3         SUBST$$BAR:6   W$TEHA
     C           2         SUBST$$BAR:9   W$PAGE
E1   C                     ENDIF
      * IMPORT
S1   C           BCTYPE    IFEQ 'I'
     C                     MOVELP@KCD1    W$KCD
     C           4         SUBST$$BAR:13  W$TEHI  4
     C                     MOVEL*BLANK    W$PAGE
E1   C                     ENDIF
      *
     C                     GOTO @@GETC
      *///////////////////////////////////
     C           @@QR      TAG
      *///////////////////////////////////
     C**
     C                     MOVEL'QR'      W$QR    2
     C                     MOVEL$$BAR1    @@BARA
     C                     MOVEL$$BAR2    @@BARB
     C                     MOVEL*BLANK    P9BAR  20
     C* CREATE CODE39
     C                     CALL 'UEXR13'
     C                     PARM           @@BARA256
     C                     PARM           @@BARB256
     C                     PARM           P9BAR
     C                     MOVELP9BAR     W$BAR
     C**
     C                     SELEC
      * A-PICS
     C           QRTYPE    WHEQ 'C01'                      := QR
     C                     MOVELQRKDAI    W$KCD
     C           3         SUBST$$BAR:53  W$TEHA           QR
     C**         2         SUBST$$BAR:14  W$PAGE           QR
JW1  C           2         SUBST$$BAR:59  W$PAGE           QR
     C           8         SUBST$$BAR:140 $$HAHZ  8        QR
     C                     MOVE $$HAHZ    W$HAHZ  80
     C           2         SUBST$$BAR:165 $$HABB  2        QR
     C                     MOVEL$$HABB    W$HABB  20
      * INTRA-PROC
     C           QRKDAI    WHEQ 'A'
     C                     MOVELQRKDAI    W$KCD
     C           2         SUBST$$BAR:95  W$PAGE           QR
      * HEAT TREATMENT
     C           QRKDAI    WHEQ 'B'
     C                     MOVELQRKDAI    W$KCD
     C           2         SUBST$$BAR:94  W$PAGE           QR
      * PLATING
     C           QRKDAI    WHEQ 'C'
     C                     MOVEL'@'       W$KCD
     C           3         SUBST$$BAR:53  W$TEHA           QR
     C           2         SUBST$$BAR:59  W$PAGE           QR
     C                     ENDSL
     C*
     C                     MOVE '1'       PRTCHK
      *
      *///////////////////////////////////
     C           @@GETC    TAG
JW1   **  CHECK CHARTER STEEL
 |   C           QRTYPE    IFEQ 'B01'
 |   C           QRTYPE    OREQ 'C01'
 |   C                     MOVELQRZETI    $ZETI   4
 |   C                     ELSE
 |   C                     MOVELA@ZETI    $ZETI
 |   C                     ENDIF
 |   C                     CALL 'UTLR21C'
 |   C                     PARM           $ZETI   4
 |   C                     PARM           $SHIN  12
 |   C                     PARM           $SUPP   4
 |   C                     PARM           $RTN    1
 |   C           $SUPP     IFNE '4540'
 |   C                     SETON                     99
 |   C                     MOVELER,11     D9ERR
 |   C                     MOVEL'11'      W$ERCD
 |   C                     EXSR #SB290
 |   C                     GOTO E##BAR
JW1  C                     ENDIF
      **  DUPLICATE KANBAN.
     C           W$BAR     LOKUPDUP                      50:EQ
     C           *IN50     IFEQ *ON
     C                     SETON                     99
     C                     MOVELER,7      D9ERR
     C                     MOVEL'07'      W$ERCD
     C                     EXSR #SB290
     C                     GOTO E##BAR
     C                     ENDIF
JW1   **  MUILTIPLE SCAN?
 |   C                     EXSR #MSCAN
 |   C           MSFLG     IFEQ 'Y'
 |   C                     SETON                     99
 |   C                     MOVELER,4      D9ERR
 |   C                     MOVEL'04'      W$ERCD
 |   C                     EXSR #SB290
 |   C                     GOTO E##BAR
JW1  C                     ENDIF
      ** NO PART MASTER
S1   C           PRTCHK    IFEQ '0'
     C                     SETON                     99
     C                     MOVELER,10     D9ERR
     C                     MOVEL'10'      W$ERCD  2
     C                     EXSR #SB290
     C                     GOTO E##BAR
E1   C                     ENDIF
      *
     C           E##BAR    ENDSR
JW1   *----------------------------------------------------*
 .    * CHECK MULTIPLE SCAN                                *
 .    *----------------------------------------------------*
 .   C           #MSCAN    BEGSR
      *
     C                     MOVE 'N'       MSFLG   1
      *
     C           QRTYPE    IFNE 'B01'
     C           QRTYPE    ANDNE'C01'
     C                     MOVELD1BAR     LTR20  20
      *JW2       LTR20     SETLLALRPL21
JW2  C           LTR20     SETLLALRPL21A
     C                     ELSE
      *JW2       $$BAR1    SETLLALRPL22
JW2  C           $$BAR1    SETLLALRPL22A
     C                     ENDIF
      *
     C                     DO   *HIVAL
     C           QRTYPE    IFNE 'B01'
     C           QRTYPE    ANDNE'C01'
      *JW2       LTR20     READEALRPL21                  98
JW2  C           LTR20     READEALRPL21A                 98
     C                     ELSE
      *JW2       $$BAR1    READEALRPL22                  98
JW2  C           $$BAR1    READEALRPL22A                 98
     C                     ENDIF
     C   98                LEAVE
      *
     C           L2SKJY    IFEQ ' '
     C           L2OKNG    ANDEQ'OK'
     C           L2IDAT    ANDEQ0
     C           L2ODAT    ANDEQ0
     C                     EXSR #CHKDT
     C           #DAYS     IFLE 180
     C                     MOVE 'Y'       MSFLG
     C                     LEAVE
 .   C                     ENDIF
 .   C                     ENDIF
 .   C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
JW1   * CHECK SCAN DATE IS NEW ENOUGH
 .    *----------------------------------------------------*
 .   C           #CHKDT    BEGSR
 .    *
     C                     Z-ADD0         #DAYS   40
     C                     MOVELL2CODT    $DT81
     C                     MOVELWDATE     $DT82
     C                     MOVEL'N'       $IAF
     C                     MOVEL'N'       $INC
     C                     CALL 'UTLR24'
     C                     PARM           $DT81   8
     C                     PARM           $DT82   8
     C                     PARM           $IAF    1
     C                     PARM           $INC    1
     C                     PARM           $DAYS   4
     C                     PARM           $RTNX   1
      *
     C           $RTNX     IFEQ *BLANK
 .   C                     MOVEL$DAYS     #DAYS
 .   C                     ENDIF
 .    *
JW1  C                     ENDSR
      *================================================================
      *----------------------------------------------------*
      * ALRPP20 - SORTING SCAN RESULT FILE                 *
      *----------------------------------------------------*
      *================================================================
     C           #SB500    BEGSR
     C                     TIME           WTIME
      *
     C                     CLEARALRPP201
     C                     Z-ADDWDATE     L2UPDT
     C                     Z-ADDWTIME6    L2UPTM
     C                     MOVELW#WSID    L2WSID           UPDATE WSID
     C                     MOVELW#USER    L2USER
     C                     MOVELW#PGM     L2UPPG
      *
     C                     MOVELPOPR      L2WKCD           WORKER CODE
     C                     MOVELPITANT    L2WKNM           WORKER NAME
     C                     Z-ADDWDATE     L2CODT           SCAN DATE
     C                     Z-ADDWTIME6    L2COTM           SCAN TIME
     C**
     C                     MOVELW$AHN1    L2AHN1           PART NO1
     C                     MOVELW$AHN2    L2AHN2           PART NO2
     C                     MOVELW$AHN3    L2AHN3           PART NO3
     C                     MOVELW$AZET    L2AZET           PART ID NO.
     C                     MOVELW$TEHA    L2TEHA           LOT NO.
     C                     MOVELW$PAGE    L2PAGE           PAGE NO.
     C                     Z-ADDW$HAHZ    L2HAHZ           ISSUE DATE
     C                     Z-ADDW$HABB    L2HABB           ISSUE BIN
     C*
     C                     MOVELW$OKNG    L2OKNG           OK/NG
     C                     MOVELW$ERCD    L2ERCD           ERROR CODE
     C*
     C           W$QR      IFEQ 'QR'
     C                     MOVELW$BAR     L2ABAR           APICS BARCODE
     C                     MOVELD1BAR     L2AQR            APICS QR
     C                     ELSE
     C                     MOVELW$BAR     L2ABAR           APICS BARCODE
     C                     ENDIF
      *
     C           L2ERCD    IFEQ '07'                       ERROR CODE
     C                     MOVELD1BAR     L2AQR            APICS QR
     C                     ENDIF
      *
     C                     WRITEALRPP201
      *
     C                     ENDSR
      *================================================================
      * Call Program to Get Check Digit                    *
      *================================================================
     C           #SB600    BEGSR
      *
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        INPUT DATA
     C                     PARM           PMBYTE  3        LENGTH
     C                     PARM           PMCHK   1        CHECKS DIGITS
     C                     PARM           PMRTCD  1        RETRN CODE
      *
     C                     ENDSR
      *
      *================================================================
      * ERROR SCREEN - Display Error on Screen             *
      *================================================================
     C           #SB290    BEGSR
      *
     C           D9ERR     IFEQ ER,5
      *
     C*  PASSWORD LOCK
     C                     MOVE PISECT    P1PGM
     C                     MOVELD9ERR     P1ERR
     C                     MOVELW#PGM     P1PID
     C                     MOVELPOPR      P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
     C                     MOVEL*ON       W@ERCK  1
      *
     C                     ELSE
      *
     C                     WRITEDSP08
     C                     EXFMTDSP09
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *----------------------------------------------------*
      *----------------------------------------------------*
      *----------------------------------------------------*
** ER(60A) ........2.........3.........4.........5.........6
SCAN QR CODE!                                                01
CHECK DIGIT ERROR!                                           02
PARTS MASTER ERROR!                                          03
KANBAN ALREADY SCANNED!                                      04 JW1
NONMATCH ERROR                                               05
FNC KEY ERROR!                                               06
DUPLICATE KANBAN!                                            07
APICS STOP ALERT!                                            08
PT STOP ALERT                                                09
NO KANBAN M/F!                                               10
SCAN CHARTER STEEL ONLY!                                     11 JW1
