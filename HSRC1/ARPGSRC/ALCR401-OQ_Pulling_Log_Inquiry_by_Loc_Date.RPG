     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     SETON                     313233
     C                     SETON                     89
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,5     MSG
