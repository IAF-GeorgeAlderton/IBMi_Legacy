     C                     MOVELA8EM02    S2EMG2
     C           S2EMG1    IFEQ *BLANK
     C                     MOVEL'ERROR'   S2EMG1
     C                     MOVEL'ERROR'   S2EMG2
     C                     END
     C                     MOVEL*ON       *IN72
     C                     ELSE
     C                     MOVEL*OFF      *IN72
     C                     END
     C*
     C                     MOVEL*BLANK    W@PART
     C                     MOVELA8PR11    W@PRT1
     C           A8PR12    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C                     MOVELA8PR12    W@PRT2
     C           A8PR13    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELA8PR13    W@PRT3
     C                     MOVELW@PART    S2HIN1
     C*
     C                     MOVEL*BLANK    W@PART
     C                     MOVELA8PR21    W@PRT1
     C           A8PR22    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C                     MOVELA8PR22    W@PRT2
     C           A8PR23    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELA8PR23    W@PRT3
     C                     MOVELW@PART    S2HIN2
     C*
     C                     MOVEL*BLANK    W@PART
     C                     MOVELA8PR31    W@PRT1
     C           A8PR32    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C                     MOVELA8PR32    W@PRT2
     C           A8PR33    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELA8PR33    W@PRT3
     C                     MOVELW@PART    S2HIN3
     C*
     C                     MOVELA8BRC1    S2BAR1
     C* ----------------------------------------------------
