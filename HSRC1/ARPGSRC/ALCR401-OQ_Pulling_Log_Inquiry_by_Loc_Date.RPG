     C                     MOVELLON,Y     F1SLOC
     C                     ELSE
     C                     MOVEL*BLANK    W@SLC
     C                     MOVEL*BLANK    F1SLOC
     C                     END
     C*
     C                     DO
     C*
     C           K#AGDP    KLIST
     C                     KFLD           W1SCFY
     C                     KFLD           W1SCFM
     C                     KFLD           W1SCFD
     C           K#AGDP    SETLLAGDPL12
     C                     READPAGDPL12                  98
     C   98                LEAVE
     C*
     C                     Z-ADD230000    K@TIME
     C           W@SLSW    IFEQ *ON
     C           K#L05X    KLIST
     C                     KFLD           W@SLC1
     C                     KFLD           W@SLC2
     C                     KFLD           W@SLC3
     C                     KFLD           W@SLC4
     C                     KFLD           F8KAHZ
     C                     KFLD           K@TIME  60
     C           K#L05X    SETLLALCPL05
     C                     ELSE
     C           K#L05A    KLIST
     C                     KFLD           K@LOC1  1
     C                     KFLD           F1LOC2
     C                     KFLD           F1LOC3
     C                     KFLD           K@LOC4  1
     C                     KFLD           F8KAHZ
     C                     KFLD           K@TIME  60
     C                     MOVEL'1'       K@LOC1
     C                     MOVEL'0'       K@LOC4
     C           K#L05A    SETLLALCPL05
     C                     END
     C*
     C                     DO   *HIVAL
     C*
     C           W@SLSW    IFEQ *ON
     C           K#L05Y    KLIST
     C                     KFLD           W@SLC1
     C                     KFLD           W@SLC2
     C                     KFLD           W@SLC3
     C                     KFLD           W@SLC4
     C           K#L05Y    READEALCPL05                  97
     C                     ELSE
     C           K#L05B    KLIST
     C                     KFLD           K@LOC1
     C                     KFLD           F1LOC2
     C                     KFLD           F1LOC3
     C                     KFLD           K@LOC4
     C           K#L05B    READEALCPL05                  97
     C                     END
     C   97                LEAVE
     C           A8DATE    IFEQ W1SCTH
     C           A8TIME    ANDGE230000
     C                     LEAVE
     C                     END
     C           A8DATE    IFGT W1SCTH
     C                     LEAVE
     C                     END
TCHK6C           A8EM03    IFNE *BLANK
TCHK6C                     ITER
TCHK6C                     END
      *
     C           A8USER    IFNE 'O'
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL020
     C*
     C                     Z-ADDA8DTMD    S2DATE
