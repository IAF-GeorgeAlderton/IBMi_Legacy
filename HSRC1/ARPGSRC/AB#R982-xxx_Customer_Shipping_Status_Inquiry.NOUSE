     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR @INT
     C*
     C                     EXSR @F1RTN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WWTIME
     C*
     C                     Z-ADD@@YY      F1SHFY
     C                     Z-ADD@@MM      F1SHFM
     C                     Z-ADD@@DD      F1SHFD
     C                     Z-ADD*ZERO     F1SHTY
     C                     Z-ADD*ZERO     F1SHTM
     C                     Z-ADD*ZERO     F1SHTD
     C                     MOVEL*BLANK    F1NONY
     C                     MOVEL*BLANK    F1NUKE
     C                     Z-ADD*ZERO     F1BINN
TANE C*                    MOVEL'Y'       F1STS
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     Z-ADD*ZERO     W1SHFY  40
     C                     Z-ADD*ZERO     W1SHFM  20
     C                     Z-ADD*ZERO     W1SHFD  20
     C                     Z-ADD*ZERO     W1SHTY  40
     C                     Z-ADD*ZERO     W1SHTM  20
     C                     Z-ADD*ZERO     W1SHTD  20
     C                     Z-ADD*ZERO     W1CUST  40
     C                     Z-ADD*ZERO     W1NONY  40
     C                     MOVEL*BLANK    W1NUKE  4
     C                     Z-ADD*ZERO     W1BINN  20
     C                     MOVEL*BLANK    W1STS   1
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT010
     C******************************************************
     C           @F1RTN    BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*OFF      *IN48
     C                     MOVEL*OFF      *IN47
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C   KA                LEAVE
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     EXSR @SHCHK
     C           *IN49     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C                     EXSR @F2RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SHIP DATE CHECK
     C******************************************************
     C           @SHCHK    BEGSR
     C*
     C           F1SHFY    IFEQ *ZERO
     C           F1SHFM    ANDEQ*ZERO
     C           F1SHFD    ANDEQ*ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C*
     C           F1SHFY    IFEQ *ZERO
     C           F1SHFM    OREQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C*
     C           F1SHTY    IFNE *ZERO
     C           F1SHTM    IFEQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C                     END
     C           F1SHTM    IFNE *ZERO
     C           F1SHTY    IFEQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C                     END
     C*
     C           F1SHTY    IFNE *ZERO
     C           F1SHTM    ORNE *ZERO
     C                     Z-ADDF1SHFY    W1SHFY
     C                     Z-ADDF1SHFM    W1SHFM
     C                     Z-ADDF1SHTY    W1SHTY
     C                     Z-ADDF1SHTM    W1SHTM
     C           W1SFDT    IFGT W1STDT
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  @F2RTN
     C******************************************************
     C           @F2RTN    BEGSR
     C*
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP2  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN48
     C                     MOVEL*ON       *IN47
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C   KA
     COR KL                LEAVE
     C*
     C  NKJ                MOVELN#MODE    *IN43
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C           *INKF     IFEQ *ON
     C           F1SHFY    ORNE W1SHFY
     C           F1SHFM    ORNE W1SHFM
     C           F1SHFD    ORNE W1SHFD
     C           F1SHTY    ORNE W1SHTY
     C           F1SHTM    ORNE W1SHTM
     C           F1SHTD    ORNE W1SHTD
     C           F1CUST    ORNE W1CUST
     C           F1NONY    ORNE W1NONY
     C           F1NUKE    ORNE W1NUKE
     C           F1BINN    ORNE W1BINN
TANE C*          F1STS     ORNE W1STS
     C                     EXSR @SHCHK
     C   49                ITER
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP2
     C                     ITER
     C                     END
     C*
     C                     EXSR @F3RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 SET
     C******************************************************
     C           @F2SET    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     MOVEL*ON       *IN43
     C                     MOVEL*ON       N#MODE
     C*
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WP98
     C*
     C* SET SHP-TO DATE CONDITION
     C           F1SHTY    IFNE *ZERO
     C                     Z-ADDF1SHTY    W@SHTY
     C                     ELSE
     C                     Z-ADDF1SHFY    W@SHTY
     C                     END
     C           F1SHTM    IFNE *ZERO
     C                     Z-ADDF1SHTM    W@SHTM
     C                     ELSE
     C                     Z-ADDF1SHFM    W@SHTM
     C                     END
     C           F1SHTD    IFNE *ZERO
     C                     Z-ADDF1SHTD    W@SHTD
     C                     ELSE
     C                     Z-ADDF1SHFD    W@SHTD
     C           F1SHFD    IFEQ *ZERO
     C                     Z-ADD99        W@SHTD
     C                     END
     C                     END
     C*
     C           K#L1NA    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     KFLD           K@SHDD
     C           K#L1NB    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     Z-ADDF1SHFY    K@SHYY
     C                     Z-ADDF1SHFM    K@SHMM
     C                     Z-ADDF1SHFD    K@SHDD
     C           F1SHFD    IFEQ *ZERO
     C           K#L1NB    SETLLAB#PL1N
     C                     ELSE
     C           K#L1NA    SETLLAB#PL1N
     C                     END
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#PL1N                  98
     C   98                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C           BANODT    IFGT W@TODT
     C                     LEAVE
     C                     END
     C*
     C* CUST
     C           F1CUST    IFNE *ZERO
     C           F1CUST    IFNE BATOKU
     C                     ITER
     C                     END
     C                     END
     C* DELI
     C           F1NONY    IFNE *ZERO
     C           F1NONY    IFNE BANONY
     C                     ITER
     C                     END
     C                     END
     C* DOCK
     C           F1NUKE    IFNE *BLANK
     C           F1NUKE    IFNE BANUKE
     C                     ITER
     C                     END
     C                     END
     C* BIN#
     C           F1BINN    IFNE *ZERO
     C           F1BINN    IFNE BANOBN
     C                     ITER
     C                     END
     C                     END
     C*
     C           K#L78A    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BANOBN
     C           K#L78A    SETLLAB#PL78
     C                     MOVEL*OFF      W@BFND  1        O# BLANK FND
     C                     MOVEL*OFF      W@OFND  1        O# FOUND
     C                     DO   *HIVAL
     C           K#L78A    READEAB#PL78                  96
     C   96                LEAVE
     C           P8SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           P8ODRN    IFEQ *BLANK
     C                     MOVEL*ON       W@BFND
     C                     END
     C           P8ODRN    IFEQ BAODRN
     C                     MOVEL*ON       W@OFND
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     MOVEL*OFF      *IN95
     C           W@BFND    IFEQ *ON
     C           W@OFND    ANDEQ*OFF
     C                     MOVEL*OFF      *IN96
     C           K#L78A    SETLLAB#PL78
     C                     DO   *HIVAL
     C           K#L78A    READEAB#PL78                  95
     C   95                LEAVE
     C           P8SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           P8ODRN    IFEQ *BLANK
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C* CREATE SUB-FILE
     C                     CLEARSFL020
     C*
     C                     MOVELBATOKU    S2CUST
     C                     MOVELBANONY    S2NONY
     C                     MOVELBANUKE    S2NUKE
     C                     Z-ADDBANOBN    S2BINN
     C                     Z-ADDBANODT    S2SHDT
     C                     MOVELBANKOJ    H2NKOJ
     C*
     C           K#GADP    KLIST
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C           K#GADP    CHAINGADPL11              94
     C  N94                MOVELB5KMEI    S2SHNM
     C*
     C           K#PP98    KLIST
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C           K#PP98    CHAINAB#PP98              97
     C*
     C           *IN96     IFEQ *ON
     C           *IN95     OREQ *ON
     C*
     C           *IN97     IFEQ *ON
     C           P9SKJY    ORNE *BLANK
     C                     MOVEL*ALL'*'   S2ASDT
     C                     END
     C*
     C                     ELSE
     C*
     C                     MOVELP8ODRN    S2ODRN
     C                     MOVELP8SERL    S2SERL
      *
     C                     Z-ADDP8PLDT    S2PLDT
     C           P8PLTM    IFNE *ZERO
     C                     Z-ADDP8PLTM    W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2PLTM
     C                     END
      *
     C           P8LPDT    IFNE *ZERO
     C                     Z-ADDP8LPDT    W2DT@
     C                     MOVELW2DT@Y    W2DTYY
     C                     MOVEL'/'       W2DTS1
     C                     MOVELW2DT@M    W2DTMM
     C                     MOVEL'/'       W2DTS2
     C                     MOVELW2DT@D    W2DTDD
     C                     MOVELW2DT      S2LPDT
     C                     ELSE
     C           BATOKU    IFEQ 3411
     C           BATOKU    OREQ 0541
     C           BATOKU    OREQ 3423
     C           BANONY    IFNE 0323
     C                     MOVEL*ALL'*'   S2LPDT
     C                     END
     C                     END
     C                     END
     C           P8LPTM    IFNE *ZERO
     C                     Z-ADDP8LPTM    W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2LPTM
     C                     END
     C*
     C           *IN97     IFEQ *ON
     C           P9SKJY    ORNE *BLANK
     C                     MOVEL*ALL'*'   S2ASDT
     C                     ELSE
     C           P8ASDT    IFNE *ZERO
     C                     Z-ADDP8ASDT    W2DT@
     C                     MOVELW2DT@Y    W2DTYY
     C                     MOVEL'/'       W2DTS1
     C                     MOVELW2DT@M    W2DTMM
     C                     MOVEL'/'       W2DTS2
     C                     MOVELW2DT@D    W2DTDD
     C                     MOVELW2DT      S2ASDT
     C                     Z-ADDP8ASTM    W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2ASTM
     C                     END
     C                     END
     C*
     C                     Z-ADDP8SPDT    S2SPDT
     C           P8SPTM    IFNE *ZERO
     C                     Z-ADDP8SPTM    W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2SPTM
     C                     END
     C*
     C                     END
     C*
     C                     MOVEL*ALL'-'   S2DUM1
     C                     MOVEL*ALL'-'   S2DUM2
     C*
     C           K#WP98    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BANOBN
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           S2SERL
     C                     KFLD           S2ODRN
     C           K#WP98    CHAINAB#WP98              93
     C           *IN93     IFEQ *ON
     C                     CLEARAB#WP981
     C                     Z-ADDBANOYY    W8NOYY
     C                     Z-ADDBANOMM    W8NOMM
     C                     Z-ADDBANODD    W8NODD
     C                     Z-ADDBANOBN    W8BINN
     C                     Z-ADDBATOKU    W8CUST
     C                     Z-ADDBANONY    W8NONY
     C                     MOVELBANKOJ    W8NKOJ
     C                     MOVELBANUKE    W8NUKE
     C                     MOVELS2SERL    W8SERL
     C                     MOVELS2ODRN    W8ODRN
     C                     WRITEAB#WP981
     C                     ADD  1         RRN2
     C                     MOVEL*ON       *IN52
     C                     WRITESFL020
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C           K#L1NC    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BANOBN
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAODRN
     C           K#L1NC    SETGTAB#PL1N
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     CLEARSFL020
     C                     Z-ADD1         RRN2
     C                     MOVEL*ON       *IN51
     C                     MOVEL*OFF      *IN52
     C                     WRITESFL020
     C                     MOVEL*OFF      *IN51
     C                     MOVEL*ON       *IN49
