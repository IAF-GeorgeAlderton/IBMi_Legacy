      ** AB#R98 ********************************************
      * CUSTOMER ORDER SHIPPING STATUS INQUIRY             *
      *                                                    *
      * TCHK1 : 02/02/07 CREATE                            *
      ******************************************************
     FAB#PW98 CF  E                    WORKSTN
     F                                        RRN2  KSFILE SFL020
     F                                        RRN3  KSFILE SFL030
     F                                              KINFDS @INFDS
     FAB#PL1N IF  E           K        DISK
     FAB#PL78 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAB#PP98 IF  E           K        DISK
     FAB#WP98 IF  E           K        DISK                      A    UC
      *---------------------------------------------------
     E                    ERR     1  10 78
     E                    CMD     1   1 70
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
      * SHIP DATE(KEY)
     I            DS
     I                                        1   80K@SHDT
     I                                        1   40K@SHYY
     I                                        5   60K@SHMM
     I                                        7   80K@SHDD
      * SHIP DATE(AB#PL78)
     I            DS
     I                                        1   80P8NODT
     I                                        1   40P8NOYY
     I                                        5   60P8NOMM
     I                                        7   80P8NODD
      * SHIP DATE(AB#PL1N)
     I            DS
     I                                        1   80BANODT
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      *
     I            DS
     I                                        1   80W@TODT
     I                                        1   40W@SHTY
     I                                        5   60W@SHTM
     I                                        7   80W@SHTD
      *
     I            DS
     I                                        1   60W1SFDT
     I                                        1   40W1SHFY
     I                                        5   60W1SHFM
     I            DS
     I                                        1   60W1STDT
     I                                        1   40W1SHTY
     I                                        5   60W1SHTM
      *
     I            DS
     I                                        1   80W2DT@
     I                                        1   40W2DT@Y
     I                                        5   60W2DT@M
     I                                        7   80W2DT@D
     I            DS
     I                                        1  10 W2DT
     I                                        1   4 W2DTYY
     I                                        5   5 W2DTS1
     I                                        6   7 W2DTMM
     I                                        8   8 W2DTS2
     I                                        9  10 W2DTDD
     I            DS
     I                                        1   60W2TM@
     I                                        1   20W2TM@H
     I                                        3   40W2TM@M
     I                                        5   60W2TM@S
     I            DS
     I                                        1   8 W2TM
     I                                        1   2 W2TMHH
     I                                        3   3 W2TMD1
     I                                        4   5 W2TMMM
     I                                        6   6 W2TMD2
     I                                        7   8 W2TMSS
      *
     I            DS
     I                                        1  15 W3MHIN
     I                                        1   5 W3MHI1
     I                                        6  10 W3MHI2
     I                                       11  15 W3MHI3
     I            DS
     I                                        1  12 W3SHIN
     I                                        1   5 W3SHI1
     I                                        6  10 W3SHI2
     I                                       11  12 W3SHI3
