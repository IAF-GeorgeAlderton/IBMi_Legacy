     H            Y.
     F** ABMR60 *********************************************
     F* CREATE FORECAST USER PART NO.
     F*    HOTTA.               2018.06.05                  *
     F*******************************************************
     FABBPL06 IF  E           K        DISK
     FABMPP01 IF  E           K        DISK
     FABMWP60 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  12 Q5SHN
     I                                        1   5 Q5SHN1
     I                                        6  10 Q5SHN2
     I                                       11  12 Q5SHN3
      *
     I            DS
     I                                        1  12 W@SHN
     I                                        1   5 W@SHN1
     I                                        6  10 W@SHN2
     I                                       11  12 W@SHN3
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   60W@DTYM
     I                                        1   40W@DTYY
     I                                        5   60W@DTMM
     I                                        7   80W@DTDD
      *
     I            DS
     I                                        1   60W@M1YM
     I                                        1   40W@M1YY
     I                                        5   60W@M1MM
      *
     I            DS
     I                                        1   60W@M2YM
     I                                        1   40W@M2YY
     I                                        5   60W@M2MM
      *
     I            DS
     I                                        1   60W@M3YM
     I                                        1   40W@M3YY
     I                                        5   60W@M3MM
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
     C                     Z-ADD*DATE     W@DATE
     C                     Z-ADDW@DTYM    W@NTYM  60
      * N-1
     C           W@DTMM    IFEQ 1
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     ELSE
     C                     SUB  1         W@DTMM
     C                     ENDIF
     C                     Z-ADDW@DTYM    W@M1YM
      * N-2
     C                     Z-ADDW@M1YM    W@M2YM
     C           W@M1MM    IFEQ 1
     C                     SUB  1         W@M2YY
     C                     Z-ADD12        W@M2MM
     C                     ELSE
     C                     SUB  1         W@M2MM
     C                     ENDIF
      * N-3
     C                     Z-ADDW@M2YM    W@M3YM
     C           W@M2MM    IFEQ 1
     C                     SUB  1         W@M3YY
     C                     Z-ADD12        W@M3MM
     C                     ELSE
     C                     SUB  1         W@M3MM
     C                     ENDIF
      *
     C           KEYQ5     KLIST
     C                     KFLD           K@DTYM  60
     C                     Z-ADDP@DTYM    K@DTYM
      *
     C           KEYQ5     SETLLABBPL061
     C           KEYQ5     READEABBPL061                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB810
     C           W@NKBN    IFEQ '1'
     C                     EXSR #SB500
     C                     ELSE
     C                     EXSR #SB510
     C                     ENDIF
     C           KEYQ5     READEABBPL061                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      * USEING FORECAST                             *
      *---------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARABMWP601
     C                     MOVELQ5TOKU    Q6TOKU
     C                     MOVELQ5NONY    Q6NONY
     C                     MOVELQ5NKOJ    Q6NKOJ
     C                     MOVELQ5NUKE    Q6NUKE
     C                     MOVELQ5SHN1    Q6SHN1
     C                     MOVELQ5SHN2    Q6SHN2
     C                     MOVELQ5SHN3    Q6SHN3
     C                     MOVELQ5MHN1    Q6MHN1
     C                     MOVELQ5MHN2    Q6MHN2
     C                     MOVELQ5MHN3    Q6MHN3
     C                     MOVELQ5MHN4    Q6MHN4
     C                     Z-ADDQ5NNNM    Q6NNNM
     C                     Z-ADDQ51NNM    Q61NNM
     C                     Z-ADDQ52NNM    Q62NNM
     C                     EXSR #SB511
     C                     Z-ADDW@USM1    Q6USM1
     C                     Z-ADDW@USM2    Q6USM2
     C                     Z-ADDW@USM3    Q6USM3
     C                     Z-ADDQ5NTYM    Q6NTYM
     C                     MOVELW@NKBN    Q6PP01
     C                     Z-ADD1         Q6DCNT
     C                     WRITEABMWP601
      *
     CSR         ESB500    ENDSR
      *---------------------------------------------*
      * USEING SALES                                *
      *---------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C           KEYW      KLIST
     C                     KFLD           Q5NTYM
     C                     KFLD           Q5SHN1
     C                     KFLD           Q5SHN2
     C                     KFLD           Q5SHN3
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
     C           KEYW      CHAINABMWP601             27
     C           *IN27     IFEQ '1'
     C                     CLEARABMWP601
     C                     MOVELQ5TOKU    Q6TOKU
     C                     MOVELQ5NONY    Q6NONY
     C                     MOVEL*BLANK    Q6NKOJ
     C                     MOVEL*BLANK    Q6NUKE
     C                     MOVELQ5SHN1    Q6SHN1
     C                     MOVELQ5SHN2    Q6SHN2
     C                     MOVELQ5SHN3    Q6SHN3
     C                     MOVEL*BLANK    Q6MHN1
     C                     MOVEL*BLANK    Q6MHN2
     C                     MOVEL*BLANK    Q6MHN3
     C                     MOVEL*BLANK    Q6MHN4
     C                     Z-ADDQ5NNNM    Q6NNNM
     C                     Z-ADDQ51NNM    Q61NNM
     C                     Z-ADDQ52NNM    Q62NNM
     C                     EXSR #SB511
     C                     Z-ADDW@USM1    Q6USM1
     C                     Z-ADDW@USM2    Q6USM2
     C                     Z-ADDW@USM3    Q6USM3
     C                     Z-ADDQ5NTYM    Q6NTYM
     C                     MOVELW@NKBN    Q6PP01
     C                     Z-ADD1         Q6DCNT
     C                     WRITEABMWP601
     C                     ELSE
     C                     ADD  Q5NNNM    Q6NNNM
     C                     ADD  Q51NNM    Q61NNM
     C                     ADD  Q52NNM    Q62NNM
     C***                  EXSR #SB511
     C***                  ADD  W@USM1    Q6USM1
     C***                  ADD  W@USM2    Q6USM2
     C***                  ADD  W@USM3    Q6USM3
     C                     ADD  1         Q6DCNT
     C                     UPDATABMWP601
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *---------------------------------------------*
      * SALES DATA                                  *
      *---------------------------------------------*
     CSR         #SB511    BEGSR
      * N-1
     C                     Z-ADDW@M1YY    @5DTYY
     C                     Z-ADDW@M1MM    @5DTMM
     C                     CALL 'ABMR45'
     C                     PARM           Q5TOKU
     C                     PARM           Q5NONY
     C                     PARM           Q5SHN1
     C                     PARM           Q5SHN2
     C                     PARM           Q5SHN3
     C                     PARM           @5DTYY  40
     C                     PARM           @5DTMM  20
     C                     PARM           P9USRY  90
     C                     Z-ADDP9USRY    W@USM1  90
      * N-2
     C                     Z-ADDW@M2YY    @5DTYY
     C                     Z-ADDW@M2MM    @5DTMM
     C                     CALL 'ABMR45'
     C                     PARM           Q5TOKU
     C                     PARM           Q5NONY
     C                     PARM           Q5SHN1
     C                     PARM           Q5SHN2
     C                     PARM           Q5SHN3
     C                     PARM           @5DTYY  40
     C                     PARM           @5DTMM  20
     C                     PARM           P9USRY  90
     C                     Z-ADDP9USRY    W@USM2  90
      * N-3
     C                     Z-ADDW@M3YY    @5DTYY
     C                     Z-ADDW@M3MM    @5DTMM
     C                     CALL 'ABMR45'
     C                     PARM           Q5TOKU
     C                     PARM           Q5NONY
     C                     PARM           Q5SHN1
     C                     PARM           Q5SHN2
     C                     PARM           Q5SHN3
     C                     PARM           @5DTYY  40
     C                     PARM           @5DTMM  20
     C                     PARM           P9USRY  90
     C                     Z-ADDP9USRY    W@USM3  90
      *
     CSR         ESB511    ENDSR
      *---------------------------------------------*
      * FORECAST  USER M/F                          *
      *---------------------------------------------*
     CSR         #SB810    BEGSR
      *
     C           KEYS2     KLIST
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
     C                     KFLD           K5NKOJ  1
     C                     KFLD           K5NUKE  4
     C                     MOVELQ5NKOJ    K5NKOJ
     C                     MOVELQ5NUKE    K5NUKE
     C                     MOVEL'0'       W@NKBN  1
     C           KEYS2     CHAINABMPP011             23
     C           *IN23     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
      *
     C           *IN23     IFEQ '1'
     C                     MOVEL*BLANK    K5NUKE
     C           KEYS2     CHAINABMPP011             23
     C           *IN23     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN23     IFEQ '1'
     C                     MOVEL*BLANK    K5NKOJ
     C           KEYS2     CHAINABMPP011             23
     C           *IN23     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN23     IFEQ '0'
     C                     MOVEL'1'       W@NKBN
     C                     ENDIF
      *
     CSR         ESB810    ENDSR
