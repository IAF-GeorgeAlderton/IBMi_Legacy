      * WORK DAYS OF THE LAST MONTH
     C                     Z-ADD0         @DYS    31
     C                     Z-ADD*YEAR     K@YY
     C           *MONTH    SUB  1         K@MM
 B0  C           K@MM      IFEQ 0
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
 E0  C                     ENDIF
      *
     C           K#AGDX    SETLLAGDPL121
 B0  C           *IN90     DOUEQ*ON
     C           K#AGDX    READEAGDPL121                 90
 B1  C           *IN90     IFEQ *OFF
      *
 B2  C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
 E2  C                     ENDIF
      *
 B2  C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @DYS
     C                     ELSE
     C                     ADD  0.5       @DYS
 E2  C                     ENDIF
      *
 E1  C                     ENDIF
 E0  C                     ENDDO
      *
     C                     Z-ADDD@YMD     K@YMD
