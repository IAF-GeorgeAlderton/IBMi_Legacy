     F******************************************** AJSR90 **
     FAJSPP10 IP  E                    DISK
     FAJSWP60 O   E                    DISK
     FAJSWP61 O   E                    DISK
     I            DS
     I                                        1   80J1WIHZ
     I                                        1   40J1WINY
     I                                        5   60J1WINM
     I                                        7   80J1WIND
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
     C                     PARM           PRECD   7
     C                     PARM           PKENS   7
     C                     MOVE PHIZK     WHIZK   80
      *
     C                     ADD  1         WRECD   70
      *
     C           J1WIHZ    IFGT WHIZK
     C                     ADD  1         WKENS   70
     C                     WRITEAJSWP601
     C                     ELSE
     C                     WRITEAJSWP611
     C                     END
      *
     CLR                   MOVE WRECD     PRECD
     CLR                   MOVE WKENS     PKENS
