     H            Y.
     F***CHKR75*****************************************************************
     F*  PROGRAM    : PRINT SUBARU DOUBLE G REPORT                             *
     F*  WRITTEN    : 7/24/2019                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLAJ IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     I            DS
     I                                        1  10 BAODRN
     I                                        1   1 ORD1
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     EXSR #MAIN
      *
     C           SEQ#      IFGE 1
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVE ' '       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  MAIN RUOTINE                                      *
      *----------------------------------------------------*
     C           #MAIN     BEGSR
      *
     C                     Z-ADD0         GCNT    20
     C                     Z-ADD20190101  K#NOHZ
     C           K#PLAJ    SETLLAB#PLAJ
     C                     DO   *HIVAL
     C                     READ AB#PLAJ                  98
     C   98                LEAVE
      *
     C           BANONY    IFNE 3611
     C                     LEAVE
     C                     ENDIF
      *
     C**         BANOHZ    IFNE TODAY
     C**                   LEAVE
     C**                   ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           ORD1      IFEQ 'G'
     C           BANOHZ    IFEQ SVNOHZ
     C                     ADD  1         GCNT
     C                     ELSE
     C                     Z-ADD1         GCNT
     C                     Z-ADDBATOKU    SVTOKU
     C                     Z-ADDBANONY    SVNONY
     C                     Z-ADDBANOHZ    SVNOHZ
     C                     Z-ADDBANOBN    SVNOBN
     C                     MOVELBAMHN1    SVMHN1
     C                     MOVELBAMHN2    SVMHN2
     C                     MOVELBAMHN3    SVMHN3
     C                     MOVELBAODRN    SVODRN
     C                     Z-ADDBASRYO    SVSRYO
     C                     MOVELBAEDIK    SVEDIK
     C                     Z-ADDBACRHZ    SVCRHZ
     C                     Z-ADDBACRTM    SVCRTM
     C                     ENDIF
     C                     ENDIF
      * PRINT
     C           ORD1      IFEQ 'G'
     C           GCNT      ANDGE2
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * PRINT HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT BREAK
     C           GCNT      IFEQ 2
     C           SEQ#      ANDNE0
     C                     EXCPT@BRK
     C                     ADD  1         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C           GCNT      IFEQ 2
     C                     ADD  1         SEQ#
     C                     EXCPT@DTLS
     C                     ADD  1         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#PLAJ    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#NOHZ  80
      *
     C                     TIME           @SDATE
     C                     Z-ADD3611      K#NONY
     C                     MOVEL'0'       K#NKOJ
     C                     MOVEL'00  '    K#NUKE
     C                     Z-ADDTODAY     K#NOHZ
      *
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      * DEFINE SAVE FIELD
     C           *LIKE     DEFN BATOKU    SVTOKU
     C           *LIKE     DEFN BANONY    SVNONY
     C           *LIKE     DEFN BANOHZ    SVNOHZ
     C           *LIKE     DEFN BANOBN    SVNOBN
     C           *LIKE     DEFN BAMHN1    SVMHN1
     C           *LIKE     DEFN BAMHN2    SVMHN2
     C           *LIKE     DEFN BAMHN3    SVMHN3
     C           *LIKE     DEFN BAODRN    SVODRN
     C           *LIKE     DEFN BASRYO    SVSRYO
     C           *LIKE     DEFN BAEDIK    SVEDIK
     C           *LIKE     DEFN BACRHZ    SVCRHZ
     C           *LIKE     DEFN BACRTM    SVCRTM
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SUBARU DOUBLE "G"'
     O                                   60 ' ORDER REPORT **    '
     O                                   99 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                         PAGE  Z  109
     O                                  106 'P.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   27 'SHP_DATE'
     O                                   33 'BIN'
     O                                   44 'USER_PART'
     O                                   58 'ORDER#'
     O                                   76 'QTY'
     O                                   81 'TYPE'
     O                                   90 'CRT_DATE'
     O                                   98 'TIME'
     O        E   04           @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         BATOKU  +002
     O                         BANONY  +002
     O                         BANOHZ  +002 '    /  /  '
     O                         BANOBN  +002
     O                         BAMHN1  +002
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         BAODRN  +000
     O                         BASRYO1 +001
     O                         BAEDIK  +003
     O                         BACRHZ  +002 '    /  /  '
     O                         BACRTM  +002 '0 :  :  '
     O        E 1              @DTLS
     O                         SEQ#  Z +001
     O                         SVTOKU  +002
     O                         SVNONY  +002
     O                         SVNOHZ  +002 '    /  /  '
     O                         SVNOBN  +002
     O                         SVMHN1  +002
     O                         SVMHN2  +001
     O                         SVMHN3  +001
     O                         SVODRN  +000
     O                         SVSRYO1 +001
     O                         SVEDIK  +003
     O                         SVCRHZ  +002 '    /  /  '
     O                         SVCRTM  +002 '0 :  :  '
     O        E 1              @BRK
     O                                    1 '.'
