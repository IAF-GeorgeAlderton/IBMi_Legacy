     C           AWSRYO    IFEQ *ZERO
     C                     GOTO @@JUMP
     C                     END
     C           W@AWYM    IFEQ YM,1
     C           W@AWYM    OREQ YM,2
     C           W@AWYM    OREQ YM,3
     C                     ELSE
     C                     GOTO @@JUMP
     C                     END
     C*
     C           K#FCEP    KLIST
     C                     KFLD           AWSHN1
     C                     KFLD           AWSHN2
     C                     KFLD           AWSHN3
     C           K#FCEP    CHAINFCEPL01              91
     C           *IN91     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     GOTO @@JUMP
     C                     END
     C*
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    W@SYS   50
     C                     ELSE
     C                     Z-ADDA2SSYS    W@SYS
     C                     END
     C*
TCHK1C                     Z-ADDA2GEKN    W@GEKN  90
TCHK1C           K#FCEP    CHAINFCEPL11              94
TCHK1C           *IN94     IFEQ *OFF
TCHK1C           FCCD01    ANDNE*ZERO
TCHK1C           FCGK01    DIV  FCCD01    @@QTY   90
TCHK1C           @@QTY     MULT 20        W@GEKN
TCHK1C                     END
TCHK1C*
TCHK1C*          A2GEKN    DIV  20        W@W#01  92
TCHK1C           W@GEKN    DIV  20        W@W#01  92
     C           W@W#01    DIV  W@SYS     W@W#02  92
     C           W@W#02    MULT 1.2       W@W#03  92H
     C           W@W#02    MULT 0.5       W@W#04  92H
     C*
TCHK1C*          AWSRYO    DIV  5         W@W#11  92
TCHK1C                     Z-ADD*ZERO     W@SRYO  90
TCHK1C           K#PL02    KLIST
TCHK1C                     KFLD           AWSHN1
TCHK1C                     KFLD           AWSHN2
TCHK1C                     KFLD           AWSHN3
TCHK1C           K#PL02    SETLLABBPL02
TCHK1C                     DO   *HIVAL
TCHK1C           K#PL02    READEABBPL02                  93
TCHK1C   93                LEAVE
TCHK1C                     SELEC
TCHK1C           W@AWYM    WHEQ YM,1
TCHK1C                     ADD  Q5NNNM    W@SRYO
TCHK1C           W@AWYM    WHEQ YM,2
TCHK1C                     ADD  Q51NNM    W@SRYO
TCHK1C           W@AWYM    WHEQ YM,3
TCHK1C                     ADD  Q52NNM    W@SRYO
TCHK1C                     ENDSL
TCHK1C                     ENDDO
TCHK1C           W@SRYO    DIV  20        W@W#11  92
     C           W@W#11    DIV  W@SYS     W@W#12  92H
     C*
     C           W@NONY    IFEQ *ZERO
     C                     Z-ADDAWNONY    W@NONY
     C                     END
     C*
     C           W@W#12    IFGT W@W#03
     C           W@W#12    ORLT W@W#04
     C           *INOC     IFEQ *ON
     C           *IN97     OREQ *OFF
     C           AWNONY    ORNE W@NONY
     C           AWNONY    CHAINGADPL13              92
     C   92                MOVEL*BLANK    W@FNM  15
     C  N92                MOVELB5KMEI    W@FNM
     C                     EXCPT@HEDA
     C  N97                MOVEL*ON       *IN97
     C                     Z-ADDAWNONY    W@NONY
     C                     MOVEL*BLANK    W@SHIN
     C                     END
TCHK1C*                    Z-ADDA2GEKN    W@GEKN  90
     C                     Z-ADDW@W#02    W@CNT1  52
     C                     Z-ADDW@W#03    W@CNT2  52
     C                     Z-ADDW@W#12    W@CNT3  52
     C                     Z-ADDW@W#04    W@CNT4  52
      *
     C                     MOVEL*BLANK    W@HYP1  1
     C                     MOVEL*BLANK    W@HYP2  1
     C                     MOVEL*BLANK    W@HYP3  1
     C           AWMHN2    IFNE *BLANK
     C                     MOVEL'-'       W@HYP1
     C                     END
     C           AWMHN3    IFNE *BLANK
     C                     MOVEL'-'       W@HYP2
     C                     END
     C           AWMHN4    IFNE *BLANK
     C                     MOVEL'-'       W@HYP3
     C                     END
     C                     MOVEL*BLANK    W@HYPA  1
     C                     MOVEL*BLANK    W@HYPB  1
     C           AWSHN2    IFNE *BLANK
     C                     MOVEL'-'       W@HYPA
     C                     END
     C           AWSHN3    IFNE *BLANK
     C                     MOVEL'-'       W@HYPB
     C                     END
      *
     C           W@SHIN    IFEQ *BLANK
     C                     MOVELPSHIN     W@SHIN
     C                     END
     C           PSHIN     IFNE W@SHIN
     C                     EXCPT@DTLB
     C                     MOVELPSHIN     W@SHIN
     C                     END
      *
     C                     MOVELAWSBAN    W@SBAN  4
      *
     C                     EXCPT@DTLA
     C                     END
      *
     C           @@JUMP    TAG
     C*
      *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     TIME           W@TIME
     C                     TIME           WTIME   60
     C                     MOVEA'000'     *IN,96
      *
     C                     MOVEL*BLANK    W@SHIN 12
     C                     Z-ADD*ZERO     W@NONY  40
      *
     C                     CLEARYM
     C                     Z-ADDW@DY      @YY
     C                     Z-ADDW@DM      @MM
