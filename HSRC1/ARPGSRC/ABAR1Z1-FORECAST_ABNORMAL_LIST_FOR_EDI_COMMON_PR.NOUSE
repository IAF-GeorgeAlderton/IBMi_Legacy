     C                     ADD  1         @MM
     C           @MM       IFGT 12
     C                     Z-ADD1         @MM
     C                     ADD  1         @YY
     C                     END
     C                     END
     C                     Z-ADD@YYMM     YM,1
     C                     ADD  1         @MM
     C           @MM       IFGT 12
     C                     Z-ADD1         @MM
     C                     ADD  1         @YY
     C                     END
     C                     Z-ADD@YYMM     YM,2
     C                     ADD  1         @MM
     C           @MM       IFGT 12
     C                     Z-ADD1         @MM
     C                     ADD  1         @YY
     C                     END
     C                     Z-ADD@YYMM     YM,3
      *
     C                     ENDSR
