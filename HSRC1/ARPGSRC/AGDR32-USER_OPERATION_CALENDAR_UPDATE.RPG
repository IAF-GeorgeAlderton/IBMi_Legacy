     H            Y.
     F************************************
     F* USER OPERATION CALENDAR UPDATE *
     F* C:Y.AOYAMA 1991.09.10 *
     F************************************
     FAGDPW32 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FAGDPL31 UF  E           K        DISK                      A
     E                    ER      1  14 60               ERRMSG
     E                    YB      1   7  1 0 DAY     8
     I            DS
     I                                        1   80@HIZK
     I                                        1   40HIYY
     I                                        5   60HIMM
     I                                        7   80HIDD
     C*---------------
     C*  KEY
     C*---------------
     C           KEY       KLIST
     C                     KFLD           @TOKU
     C                     KFLD           @NOKJ
     C                     KFLD           HIYY
     C                     KFLD           HIMM
     C                     KFLD           HIDD
     C*---------------
     C*  fﾞx] ﾉ ﾆｭgf
     C*---------------
     C           LAB1      TAG
     C                     Z-ADD0         @TOKU
     C                     MOVE *BLANK    @NOKJ
     C                     Z-ADD0         @HIZK
     C                     MOVE *BLANK    @KOSI
     C           LAB2      TAG
     C*---------------
     C*  AGDPW321 ﾍｭcﾆﾞ
     C*---------------
     C                     EXFMTAGDPW321
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070899
     C*---------------
     C*  CMD-1 kｩｮh
     C*---------------
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*---------------
     C*  CMD-2 kｩｮh
     C*---------------
     C           *INKB     IFEQ '1'
     C                     SETON                     U1LR
     C                     RETRN
     C                     END
     C*---------------
     C*  nhbﾅg ﾉ kｩｮh
     C*---------------
     C           @TOKU     IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,1      @ERR
     C                     GOTO LAB2
     C                     END
     C*-     -*
     C* CHAIN *
     C*-     -*
     C           @TOKU     CHAINFGBPL01              90
     C           *IN90     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      @ERR
     C                     GOTO LAB2
     C                     ELSE
     C                     MOVE B2CODE    TCODE
     C                     MOVELB2SMEI    TKMEI
     C                     END
     C*---------------
     C*  DATE ﾉ kｩｮh
     C*---------------
     C           @HIZK     IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,3      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           HIYY      IFGE 1990
     C           HIMM      ANDGE01
     C           HIMM      ANDLE12
     C           HIDD      ANDGE01
     C           HIDD      ANDLE31
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,4      @ERR
     C                     GOTO LAB2
     C                     END
     C*---------------
     C*  ﾃcﾆ]hﾎﾞ] kｩｮh
     C*---------------
     C           @KOSI     IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,5      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           @KOSI     IFEQ '0'
     C           @KOSI     OREQ '1'
     C           @KOSI     OREQ '2'
     C                     ELSE
     C                     SETON                     0499
     C                     MOVE ER,6      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           @KOSI     IFEQ '0'
     C                     MOVE 'CANCEL'  SYORI
     C                     END
     C           @KOSI     IFEQ '1'
     C                     MOVE 'CHANGE'  SYORI
     C                     END
     C           @KOSI     IFEQ '2'
     C                     MOVE 'ADD   '  SYORI
     C                     END
     C*---------------
     C*  ﾛﾃｰnﾞ CHAIN
     C*---------------
     C                     SETOF                     20
     C           KEY       CHAINAGDPL311             20
     C*--         --*
     C*  nﾒiﾆ kｩｮh  *
     C*--         --*
     C           @KOSI     IFEQ '0'
     C           *IN20     ANDEQ'1'
     C                     SETON                     010203
     C                     SETON                     0499
     C                     MOVE ER,7      @ERR
     C                     GOTO LAB2
     C                     END
     C*--         --*
     C*  s]ﾃc kｩｮh  *
     C*--         --*
     C           @KOSI     IFEQ '1'
     C           *IN20     ANDEQ'1'
     C                     SETON                     010203
     C                     SETON                     0499
     C                     MOVE ER,8      @ERR
     C                     GOTO LAB2
     C                     END
     C*--         --*
     C*  lbf  kｩｮh  *
     C*--         --*
     C           @KOSI     IFEQ '2'
     C           *IN20     ANDEQ'0'
     C                     SETON                     010203
     C                     SETON                     0499
     C                     MOVE ER,9      @ERR
     C                     GOTO LAB2
     C                     END
     C*---------------
     C*  ﾑcﾍﾞ ﾉ i]ﾅh
     C*---------------
     C                     Z-ADD1         A       10
     C           F8YOBI    LOKUPYB,A                     30
     C           *IN30     IFEQ '1'
     C                     MOVE DAY,A     YOUBI
     C                     END
     C*---------------
     C*  fﾞx] ﾉ ﾆｭgf
     C*---------------
     C           @KOSI     IFNE '2'
     C                     MOVE F8HIRU    @HIKB
     C                     MOVE F8YORU    @YAKB
     C                     MOVE F8MAEY    @JOKB
     C                     MOVE F8YOBI    @YOBI
     C                     MOVE F8RIKB    @RINS
     C                     ELSE
     C                     MOVE *BLANK    @HIKB
     C                     MOVE *BLANK    @YAKB
     C                     MOVE *BLANK    @JOKB
     C                     Z-ADD0         @YOBI
     C                     MOVE *BLANK    YOUBI
     C                     MOVE *BLANK    @RINS
     C                     END
     C*---------------
     C*  AGDPW322ﾍｭcﾆﾞ
     C*---------------
     C           LAB4      TAG
     C                     EXFMTAGDPW322
     C                     SETOF                     050607
     C                     SETOF                     080999
     C*---------------
     C*  CMD-3 kｩｮh
     C*---------------
     C           *INKC     IFEQ '1'
     C                     GOTO LAB1
     C                     END
     C*---------------
     C*  ﾍﾓg] kｩｮh
     C*---------------
     C           @HIKB     IFEQ *BLANK
     C           @HIKB     OREQ '*'
     C                     ELSE
     C                     SETON                     0599
     C                     MOVE ER,10     @ERR
     C                     GOTO LAB4
     C                     END
     C*---------------
     C*  zg] kｩｮh
     C*---------------
     C           @YAKB     IFEQ *BLANK
     C           @YAKB     OREQ '*'
     C                     ELSE
     C                     SETON                     0699
     C                     MOVE ER,10     @ERR
     C                     GOTO LAB4
     C                     END
     C*---------------
     C*  udzg] kｩｮh
     C*---------------
     C           @JOKB     IFEQ *BLANK
     C           @JOKB     OREQ 'S'
     C           @JOKB     OREQ 'M'
     C           @JOKB     OREQ 'E'
     C                     ELSE
     C                     SETON                     0799
     C                     MOVE ER,11     @ERR
     C                     GOTO LAB4
     C                     END
     C*---------------
     C*  ﾑcﾍﾞﾃｰnﾞ kｩｮh
     C*---------------
     C           @YOBI     IFEQ 0
     C                     SETON                     0899
     C                     MOVE ER,12     @ERR
     C                     GOTO LAB4
     C                     END
     C*--    --*
     C*  i]ﾅh  *
     C*--    --*
     C                     Z-ADD1         A       10
     C           @YOBI     LOKUPYB,A                     30
     C           *IN30     IFEQ '1'
     C                     MOVE DAY,A     YOUBI
     C                     ELSE
     C                     SETON                     0899
     C                     MOVE ER,13     @ERR
     C                     GOTO LAB4
     C                     END
     C*---------------
     C*  ﾒ]ﾆｬl kｩｮh
     C*---------------
     C           @RINS     IFEQ *BLANK
     C           @RINS     OREQ 'R'
     C                     ELSE
     C                     SETON                     0999
     C                     MOVE ER,14     @ERR
     C                     GOTO LAB4
     C                     END
     C*---------------
     C*  CMD-5 kｩｮh
     C*---------------
     C           *INKE     IFEQ '0'
     C                     GOTO LAB4
     C                     END
     C*---------------
     C*  ﾛﾃｰnﾞ ﾅhﾆﾞｭ
     C*---------------
     C           @KOSI     IFEQ '0'
     C  N20                DELETAGDPL311
     C                     END
     C*---------------
     C*  lbf kｩｮh
     C*---------------
     C           @KOSI     IFEQ '2'
     C                     MOVE HIYY      F8KAYY
     C                     MOVE HIMM      F8KAMM
     C                     MOVE HIDD      F8KADD
     C                     END
     C*---------------
     C*  ﾎｧｰﾓnﾞ ﾆｭﾒ
     C*---------------
     C                     MOVE YB,A      F8YOBI
     C                     MOVE TCODE     F8TOKU
     C                     MOVE @NOKJ     F8KOJO
     C                     MOVE @HIKB     F8HIRU
     C                     MOVE @YAKB     F8YORU
     C                     MOVE @JOKB     F8MAEY
     C                     MOVE @RINS     F8RIKB
     C*---------------
     C*  ﾛﾃｰnﾞ s]ﾃc&lbf
     C*---------------
     C           @KOSI     IFNE '0'
     C           *IN20     IFEQ '0'
     C                     UPDATAGDPL311
     C                     ELSE
     C                     WRITEAGDPL311
     C                     END
     C                     END
     C*---------------
     C*  LAB1 s nﾎﾞ
     C*---------------
     C                     GOTO LAB1
** ER
E-01 INPUT CUSTOMER
E-02 THERE ISN'T THIS CODE IN DETAILS M/F
E-03 INPUT DATE
E-04 INPUT DATE JUSTLY
E-05 INPUT UPDATE INSTRUCTION
E-06 INPUT <0,1,2>.
E-07 SELECTED CANCEL BUT DATA DOESN'T EXIST.
E-08 SELECTED CHANGE BUT DATA DOESN'T EXIST.
E-09 SELECTED ADD BUT DATA EXISTS ALREADY.
E-10 INPUT <*> OR A BLANK.
E-11 INPUT <S,M,E> OR A BLANK.
E-12 INPUT DAY IN A WEEK CODE
E-13 DAY IN A WEEK CODE IS NOT RIGHT
E-14 INPUT <R> OR  A BLANK.
** YB/DAY
1MONDAY
2TUESDAY
3WEDNSDAY
4THURSDAY
5FRIDAY
6SATURDAY
7SUNDAY
