     F** AB#R2I *******************************
     F*  TAKATA      FORECAST PROCESSING   *
     F*                                       *
     F*           MAR/12/04                   *
TCH73F* TCH  07/20/05 FOR TAKATA  COPIED FROM AB#R5E
TCHK F* TCH  09/12/05 FOR TAKATA  MULITI NONY and BUG FIX
TCHK1F* TCH1 02/02/06 FOR TAKATA  FORMAT CHANGE
TCHK2F* TCH2 08/03/10 FOR TAKATA  3713
     F******************************* AB#R2E **
     FTAKATAF IP  F     600            DISK
     FABAWTKF O   E                    DISK
     FAGDPL12 IF  E           K        DISK
     F*AAPL02 IF  E           K        DISK
     F*CEPL01 IF  E           K        DISK
      *--------------------------------------------------------
     E                    AY        500  1
     E                    DT1        13  8 0
     E                    DAT        13  8 0
     E                    A21         2  1
     E                    A22         2  1
     E                    A9          9  1
     E                    A9X         9  1
      *
     E                    AMM        30  2
     E                    ADD        30  2
     E                    AYY        30  4
     E                    ZYY         4  1
     E                    ADT        30  8
     E                    APT        14  1
     E                    AQT        09  1
     E                    XQT        13  9
     E                    SQT         9  1
     E                    APX        14  1
      *--------------------------------------------------------
     ITAKATAF AA  01
     I                                        1 256 DAT1
     I                                      257 500 DAT2
     I            DS
     I                                        1   80YMD
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   80DAY
     I            DS
     I                                        1   8 YMD6
     I                                        1   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1  15 #PART
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
      *
     I            DS
     I                                        1   8 WADT
     I                                        1   4 WAYY
     I                                        5   6 WAMM
     I                                        7   8 WADD
      *
     I            DS
     I                                        1   80AWENDD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80AWSTRD
     I                                        1   40NAYY
     I                                        5   60NAMM
     I                                        7   80NADD
     I            DS
     I                                        1   40NAXX
     I                                        1   10NAY1
     I                                        2   20NAY2
     I                                        3   30NAY3
     I                                        4   40NAY4
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
TCHK C                     PARM           PM#RUN  1
      *
     C           KEY3      KLIST
     C                     KFLD           NAYY    40
     C                     KFLD           NAMM    20
     C                     KFLD           NADD    20
      *
      * CONSTANT
     C                     Z-ADD3656      AWTOKU
TCHK C*                    Z-ADD3712      AWNONY
TCHK C                     SELEC
TCHK C           PM#RUN    WHEQ '1'
TCHK C                     Z-ADD3682      AWNONY
TCHK C           PM#RUN    WHEQ '2'
TCHK C                     Z-ADD3712      AWNONY
TCHK C                     OTHER
TCHK C                     Z-ADD3842      AWNONY
TCHK C                     ENDSL
TCHK C*
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
      *
     C                     MOVEADAT1      AY,1
     C                     MOVEADAT2      AY,257
     C* ======
     C* HEADER
     C* ======
TCHK C*          *IN99     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'TAKATA'  SCAN DAT1      X              10
     C  N10      'Takata'  SCAN DAT1      X              10
     C  N10                GOTO @END
      *
     C                     MOVE *BLANK    A21
     C                     MOVE *BLANK    A22
     C                     MOVE *BLANK    AMM
     C                     MOVE *BLANK    ADD
     C                     MOVE *BLANK    AYY
     C                     Z-ADD0         Y       30
     C                     Z-ADD1         Z       30
     C                     Z-ADD0         G       30
      *++++++
TCHK C*                    MOVE *ON       *IN99
      *++++++
      *
TCHK C*                    ENDIF
     C*=======
      * DETAIL
     C*=======
     C                     Z-ADD1         X
      * -------------
      *   PART NUMBER
      * -------------
     C                     MOVE *BLANKS   APT
     C           ','       LOKUPAY,X                     10
B0   C           *IN10     IFEQ '1'
     C           X         ADD  1         G
B1   C           1         DO   14        H       30
B2   C           AY,G      IFEQ ','
     C                     LEAVE
     C                     ELSE
     C                     MOVELAY,G      APT,H
     C                     ADD  1         G
E2   C                     ENDIF
E1   C                     ENDDO
E0   C                     ENDIF
      *
     C                     MOVE *BLANKS   APX
     C                     Z-ADD1         G
B0   C           1         DO   14        H       30
B1   C           APT,H     IFNE '-'
B1   C           APT,H     ANDNE' '
     C                     MOVELAPT,H     APX,G
     C                     ADD  1         G
     C                     ELSE
E1   C                     ENDIF
E0   C                     ENDDO
     C                     MOVEAAPX       #PART
TCHK2C*
TCHK2C           AWNONY    IFEQ 3712
TCHK2C           AWMHN1    IFEQ 'H2028'
TCHK2C           AWMHN2    ANDEQ'215AA'
TCHK2C                     Z-ADD3713      AWNONY
TCHK2C                     END
TCHK2C           AWMHN1    IFEQ '20289'
TCHK2C           AWMHN2    ANDEQ'74AB '
TCHK2C                     Z-ADD3713      AWNONY
TCHK2C                     END
TCHK2C           AWMHN1    IFEQ '20307'
TCHK2C           AWMHN2    ANDEQ'97AA '
TCHK2C                     Z-ADD3713      AWNONY
TCHK2C                     END
TCHK2C                     END
      * ---
      * QTY/# BOX
      * ---
     C*                    MOVE AWNKOJ    XXNKOJ  1
     C*                    MOVE AWNUKE    XXNUKE  4
      *
      * ---
      * DATE
      * ---
     C                     Z-ADD*ZERO     AWSTRD
     C           '/'       LOKUPAY,X                     10
     C  N10                GOTO @END
      *MM
     C           X         SUB  3         F       20
     C           X         SUB  2         F1      20
     C           X         SUB  1         F2      20
     C           AY,F      IFEQ ','
     C                     MOVELAY,F1     NAMM
     C                     MOVE AY,F2     NAMM
     C                     ELSE
     C                     MOVEL'0'       NAMM
     C                     MOVE AY,F2     NAMM
     C                     ENDIF
      *DD  YYYY
     C           X         ADD  3         F       20
     C           X         ADD  2         F1      20
     C           X         ADD  1         F2      20
     C           X         ADD  4         F3      20
     C           X         ADD  5         F4      20
     C           X         ADD  6         F5      20
     C           X         ADD  7         F6      20
     C           AY,F      IFEQ '/'
     C                     MOVELAY,F2     NADD
     C                     MOVE AY,F1     NADD
     C                     MOVELAY,F3     NAY1
     C                     MOVELAY,F4     NAY2
     C                     MOVELAY,F5     NAY3
     C                     MOVELAY,F6     NAY4
     C                     Z-ADDNAXX      NAYY
     C                     ELSE
     C                     MOVEL'0'       NADD
TCHK C*                    MOVE AY,F1     NADD
TCHK C*                    MOVELAY,F3     NAY1
TCHK C*                    MOVELAY,F4     NAY2
TCHK C*                    MOVELAY,F5     NAY3
TCHK C*                    MOVELAY,F6     NAY4
TCHK C                     MOVE AY,F2     NADD
TCHK C                     MOVELAY,F      NAY1
TCHK C                     MOVELAY,F3     NAY2
TCHK C                     MOVELAY,F4     NAY3
TCHK C                     MOVELAY,F5     NAY4
     C                     Z-ADDNAXX      NAYY
     C                     ENDIF
      * FOR END   DATE WEEK1
     C                     MOVE '0'       *IN44
     C           KEY3      SETLLAGDPL121
     C           *IN44     DOWEQ'0'
