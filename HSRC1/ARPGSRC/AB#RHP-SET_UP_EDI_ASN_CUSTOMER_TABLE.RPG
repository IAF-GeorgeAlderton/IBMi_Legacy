     H            Y.
     F**AB#RHP **********************************************
     F* SET UP ASN CUSTOMER TABLE                           *
     F* JW     2022.10.17                                   *
     F*----------------------------------------------       *
JW1  F* JW     2024.03.04 CHG AB#PLA1 TO AB#PL10E           *
     F*******************************************************
     F***AB#PLA1 IF  E           K        DISK
JW1  FAB#PL10EIF  E           K        DISK
     FAB#HP22 IF  E           K        DISK                      A
      *
JW1  I            DS
 .   I                                        1   80BANOHZ
 .   I                                        1   40BANOYY
 .   I                                        5   60BANOMM
JW1  I                                        7   80BANODD
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C***        @CRHZ     SETLLAB#PLA1
JW1  C           @CRHZ     SETLLAB#PL10E
     C                     DO   *HIVAL
     C***                  READ AB#PLA1                  98
JW1  C                     READ AB#PL10E                 98
     C   98                LEAVE
      * IGNORE
     C           BASKJY    IFEQ 'D'
     C           BAEDIK    ORNE 'E'
     C                     ITER
     C                     ENDIF
      *
     C           BANONY    CHAINAB#HP22              99
     C           *IN99     IFEQ *ON
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * SET TO AB#HP22                                     *
      *----------------------------------------------------*
     C           #SET      BEGSR
      *
     C                     CLEARAB#HP221
     C                     Z-ADDBANONY    S2NONY
     C                     Z-ADDBANOHZ    S2STHZ
     C                     Z-ADDTODAY     S2CRHZ
     C                     Z-ADDNOW       S2CRTM
     C                     MOVEL#USER     S2CRUS
     C                     MOVEL#WSID     S2CRWS
     C                     WRITEAB#HP221
      *
     C                     ENDSR
      *----------------------------------------------------*
      * INITIAL SETTING                                    *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $CRHZ   8
      *
     C                     TIME           SDATE
      *
     C           $CRHZ     IFEQ *BLANK
     C                     Z-ADDTODAY     @CRHZ   80
     C                     ELSE
     C                     MOVEL$CRHZ     @CRHZ
     C                     ENDIF
      * PREVIOUS DAY
     C                     MOVEL@CRHZ     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVEL'0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @CRHZ
      *
     C                     ENDSR
