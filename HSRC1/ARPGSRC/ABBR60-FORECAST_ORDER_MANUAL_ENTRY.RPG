     C                     Z-ADD0         WGEKN2  90
      *
     C                     Z-ADD1         A
     C           1         DO   5         A
      *
     C                     Z-ADD0         WRECD
      *
     C                     Z-ADD0         ZYMD1
     C           ZDT1,A    IFNE 0
     C                     MOVE ZDT1,A    ZYMD1
     C                     MOVELWNYM      ZYMD1
     C                     END
      *
     C                     Z-ADD0         ZYMD2
     C           ZDT2,A    IFNE 0
     C                     MOVE ZDT2,A    ZYMD2
     C                     MOVELWNYM      ZYMD2   80
     C                     END
      *
     C           ZYMD1     IFNE 0
     C                     Z-ADD0         @HZ1
     C                     Z-ADD0         @HZ2
     C                     Z-ADD0         B
     C                     Z-ADD0         C
      *
     C                     SETOF                     71
     C           ZYMD2     IFEQ 0
     C           ZKEY1     SETLLAGDPL121
      *
     C                     DO   7
     C                     SETOF                     70
     C                     READ AGDPL121                 70
     C           *IN70     IFEQ '0'
      *
     C           F8YOBI    IFEQ 7
     C                     SETON                     70
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         WRECD
      *
     C           F8KAYM    IFEQ WNYM
     C                     ADD  1         B
     C                     Z-ADDF8KAHZ    @HZ1,B
     C                     ELSE
     C                     SETON                     71
     C                     ADD  1         C
     C                     Z-ADDF8KAHZ    @HZ2,C
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N70                END
     C                     ELSE
      *
     C           ZKEY1     SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     70
     C                     READ AGDPL121                 70
     C           *IN70     IFEQ '0'
      *
     C           F8KAHZ    IFGT ZYMD2
     C                     SETON                     70
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         WRECD
      *
     C           F8KAYM    IFEQ WNYM
     C                     ADD  1         B
     C                     Z-ADDF8KAHZ    @HZ1,B
     C                     ELSE
     C                     SETON                     71
     C                     ADD  1         C
     C                     Z-ADDF8KAHZ    @HZ2,C
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N70                END
     C                     END
      *
     C           WRECD     IFEQ 0
     C                     Z-ADDZYMD1     ZYMD
     C                     ADD  ZNS,A     ZSU1,Z
     C                     ADD  ZNS,A     ZGEKN1
     C                     ELSE
      *
     C           ZNS,A     DIV  WRECD     WNISU   90H
      *
     C                     Z-ADD1         B
     C           1         DO   31        B
     C           @HZ1,B    IFNE 0
     C                     Z-ADD@HZ1,B    ZYMD
     C                     ADD  WNISU     ZSU1,Z
     C           *IN71     IFEQ '1'
     C                     ADD  ZSU1,Z    WGEKN1
     C                     END
     C                     END
     C                     END
      *
     C           *IN71     IFEQ '1'
      *
     C                     Z-ADD1         B
     C           1         DO   31        B
     C           @HZ2,B    IFNE 0
     C                     Z-ADD@HZ2,B    ZYMD
     C                     ADD  WNISU     ZSU2,Z
     C                     ADD  ZSU2,Z    WGEKN2
     C                     END
     C                     END
      *
     C                     END
      *
     C           *IN71     IFEQ '0'
     C                     ADD  ZNS,A     ZGEKN1
     C                     ELSE
     C                     MOVE '*'       ZWK,A
     C                     ADD  WGEKN1    ZGEKN1
     C                     ADD  WGEKN2    ZGEKN2
     C                     END
      *
     C                     END
     C                     END
     C                     END
      *
     C                     ENDSR
      *
      *
     C*-----------------*
     C*  ..BEGSR        *
     C*  ..    1    ..  *
     C*-----------------*
     C           SBCR1     BEGSR
      *
     C                     MOVE *BLANK    ITOKU
     C                     MOVE *BLANK    INONY
     C                     MOVE *BLANK    INKOJ
     C                     MOVE *BLANK    INUKE
     C                     Z-ADD0         IDATE
     C                     MOVE *BLANK    IKUBN
      *
     C                     ENDSR
      *
      *
     C*-----------------*
     C*  ..BEGSR        *
     C*  ..    2    ..  *
     C*-----------------*
     C           SBCR2     BEGSR
      *
     C                     MOVE *BLANK    IMHIN
     C                     MOVE *BLANK    IKOSN
      *
     C                     ENDSR
      *----------------------------------------*
      *数量チェック　ＷＥＥＫ
      *----------------------------------------*
     CSR         #SB800    BEGSR
      *
     C                     MOVEL'0'       WKWARN  1
     C                     Z-ADD0         P#HIHK  70
     C                     CLEARP#FR
     C                     CLEARP#TO
     C                     Z-ADD0         S       30
      *Ｎ月
     C                     Z-ADD1         @       20
     C           @         DOWLE5
     C           IDT11,@   IFNE 0
     C                     MOVELINYM01    P@FRDT
     C                     MOVE IDT11,@   P@FRDT
     C                     MOVELINYM01    P@TODT
     C                     MOVE IDT12,@   P@TODT
     C                     Z-ADDINS1,@    P@SU    90
     C                     EXSR #SB801
     C                     ENDIF
     C                     ADD  1         @
     C                     ENDDO
      *Ｎ＋１月
     C                     Z-ADD1         @       20
     C           @         DOWLE5
     C           IDT21,@   IFNE 0
     C                     MOVELINYM02    P@FRDT
     C                     MOVE IDT21,@   P@FRDT
     C                     MOVELINYM02    P@TODT
     C                     MOVE IDT22,@   P@TODT
     C                     Z-ADDINS2,@    P@SU    90
     C                     EXSR #SB801
     C                     ENDIF
     C                     ADD  1         @
     C                     ENDDO
      *Ｎ＋２月
     C                     Z-ADD1         @       20
     C           @         DOWLE5
     C           IDT31,@   IFNE 0
     C                     MOVELINYM03    P@FRDT
     C                     MOVE IDT31,@   P@FRDT
     C                     MOVELINYM03    P@TODT
     C                     MOVE IDT32,@   P@TODT
     C                     Z-ADDINS3,@    P@SU    90
     C                     EXSR #SB801
     C                     ENDIF
     C                     ADD  1         @
     C                     ENDDO
      *
     C           WKWARN    IFEQ '1'
     C                     WRITEW1
     C           DSP01A    TAG
     C                     EXFMTABBPW60A
     C                     SELEC
     C           *IN03     WHEQ '1'
     C                     MOVEL'1'       WKBACK
     C                     GOTO ESB800
     C           *IN05     WHEQ '1'
     C                     GOTO ESB800
     C                     OTHER
     C                     GOTO DSP01A
     C                     ENDSL
     C                     ENDIF
      *
     CSR         ESB800    ENDSR
      *----------------------------------------*
      *期間の稼働日数
      *----------------------------------------*
     CSR         #SB801    BEGSR
      *
     C                     CALL 'ABMR9Y'
     C                     PARM           P@FRDT  80
     C                     PARM           P@TODT  80
     C                     PARM           P9KADO  31
     C                     Z-ADD0         P@HIKN  90
     C                     Z-ADD0         P@HIHK  71
     C           P9KADO    IFNE 0
     C           P@SU      DIV  P9KADO    P@HIKN
     C                     ENDIF
     C           DASSYS    IFNE 0
     C           P@HIKN    DIV  DASSYS    P@HIHK    H
     C                     ENDIF
      *
     C           P@HIHK    SUB  DAHIHK    P@SA    71
     C                     Z-ADD0         P@RITU  93
     C           DAHIHK    IFNE 0
     C           P@HIHK    DIV  DAHIHK    P@RITU    H
     C                     ENDIF
     C                     MOVEL'0'       AAB     1
     C           P@RITU    IFGE 1.25
     C******     P@RITU    ORLE 0.75
     C                     MOVEL'1'       AAB
     C                     ENDIF
      *
     C           AAB       IFEQ '1'
     C           P@SA      IFGE 4
     C           P@SA      ORLE -4
     C                     MOVEL'1'       WKWARN
     C                     Z-ADDP@HIHK    P#HIHK
     C                     ADD  1         S
     C                     MOVE P@FRDT    P#FR,S
     C                     MOVE P@TODT    P#TO,S
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB801    ENDSR
      *----------------------------------------*
      *数量チェック　ＭＯＮＴＨＬＹ
      *----------------------------------------*
     CSR         #SB850    BEGSR
      *
     C                     MOVEL'0'       WKWARN  1
     C                     Z-ADD0         P#HIHK  70
     C                     CLEARP#NT
     C                     Z-ADD0         S       30
      *Ｎ月
     C                     MOVELINYM01    P@NTYM
     C                     Z-ADDIGEK01    P@SU    90
     C                     EXSR #SB851
      *Ｎ＋１月
     C                     MOVELINYM02    P@NTYM
     C                     Z-ADDIGEK02    P@SU    90
     C                     EXSR #SB851
      *Ｎ＋２月
     C                     MOVELINYM03    P@NTYM
     C                     Z-ADDIGEK03    P@SU    90
     C                     EXSR #SB851
      *
     C           WKWARN    IFEQ '1'
     C                     WRITEW2
     C           DSP01B    TAG
     C                     EXFMTABBPW60B
     C                     SELEC
     C           *IN03     WHEQ '1'
     C                     MOVEL'1'       WKBACK
     C                     GOTO ESB850
     C           *IN05     WHEQ '1'
     C                     GOTO ESB850
     C                     OTHER
     C                     GOTO DSP01B
     C                     ENDSL
     C                     ENDIF
      *
     CSR         ESB850    ENDSR
      *----------------------------------------*
      *指定年月の稼働日数
      *----------------------------------------*
     CSR         #SB851    BEGSR
      *
     C                     CALL 'ABMR9Z'
     C                     PARM           P@NTYM  60
     C                     PARM           P9KADO  31
     C                     Z-ADD0         P@HIKN  90
     C                     Z-ADD0         P@HIHK  71
     C           P9KADO    IFNE 0
     C           P@SU      DIV  P9KADO    P@HIKN
     C                     ENDIF
     C           DASSYS    IFNE 0
     C           P@HIKN    DIV  DASSYS    P@HIHK    H
     C                     ENDIF
      *
     C           P@HIHK    SUB  DAHIHK    P@SA    71
     C                     Z-ADD0         P@RITU  93
     C           DAHIHK    IFNE 0
     C           P@HIHK    DIV  DAHIHK    P@RITU    H
     C                     ENDIF
     C                     MOVEL'0'       AAB     1
     C           P@RITU    IFGE 1.25
     C******     P@RITU    ORLE 0.75
     C                     MOVEL'1'       AAB
     C                     ENDIF
      *
     C           AAB       IFEQ '1'
     C           P@SA      IFGE 4
     C           P@SA      ORLE -4
     C                     MOVEL'1'       WKWARN
     C                     Z-ADDP@HIHK    P#HIHK
     C                     ADD  1         S
     C                     Z-ADDP@NTYM    P#NT,S
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB851    ENDSR
      *
** ER(60A) ........2.........3.........4.........5.........6
