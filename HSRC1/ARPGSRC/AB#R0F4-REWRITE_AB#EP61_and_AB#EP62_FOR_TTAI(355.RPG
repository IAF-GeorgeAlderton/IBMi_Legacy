     H            Y.
     F** AB#R0F4 ************************************************************
     F*  RE-CREATE AB#EP61 AND AB#EP62 FOR TTAI(3556)                       *
     F*  JW   2020.11.01                                                    *
     F*--------------------------------------------
     F*  JW   2021.01.19 CRT AB#EP62 BY AB#EP77
     F*                  USE AB#WP62
JW1  F*  JW   2021.10.06 CHG BOX 4 DIGITS
     F***********************************************************************
     FAB#EP61 UF  E           K        DISK                      A
     FAB#EP62 UF  E           K        DISK                      A
JW   FAB#EL77 IF  E           K        DISK
JW   FAB#WP61 IF  E           K        DISK                      A
JW   FAB#WP62 IF  E           K        DISK                      A
     E*****************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************************
      *                    MAIN ROUTINE                                     *
      ***********************************************************************
     C                     EXSR #INIT
      *
     C           RCNT61    IFNE 0
      * ADJ AB#EP61
     C                     EXSR #EP61
      * ADJ AB#EP62
     C                     EXSR #EP62
      *
     C                     ENDIF
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* ADJUST AB#EP61
     C***********************************************************
     C           #EP61     BEGSR
      * DELETE EP61
     C                     EXSR #DLT61
      * RE-CREATE EP61
     C                     EXSR #CRT61
      *
     C                     ENDSR
     C***********************************************************
     C* DELETE AB#EP61
     C***********************************************************
     C           #DLT61    BEGSR
      *
     C           *LOVAL    SETLLAB#EP61
     C                     DO   *HIVAL
     C                     READ AB#EP61                  97
     C   97                LEAVE
      *
     C           E2PRTN    IFEQ '3556'
     C                     WRITEAB#WP611
     C                     DELETAB#EP611
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* RE-CREATE AB#EP61
     C***********************************************************
     C           #CRT61    BEGSR
      *
     C                     MOVE *BLANK    SHID61 10
     C           *LOVAL    SETLLAB#WP61
     C                     DO   *HIVAL
     C                     READ AB#WP61                  95
     C   95                LEAVE
      *
     C           E2SHID    IFNE SHID61
     C                     EXSR #WRT61
     C                     MOVELE2SHID    SHID61
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* RE-CREATE AB#EP61
     C***********************************************************
     C           #WRT61    BEGSR
      *
     C                     Z-ADD0         BOX#    40
     C                     Z-ADD0         PAL#    30
     C                     Z-ADD0         MAX#    30
     C                     Z-ADD0         REM#    30
     C* GET PALLET#
     C                     MOVELE2SHID    $PL#
     C                     CALL 'UEXR07D'
     C                     PARM           $PL#    9
     C                     PARM           $QTY    8
     C                     PARM           $BOX    4
     C                     PARM           $MST#   3
     C                     PARM           $MAX    3
     C                     PARM           $RTN    1
     C                     MOVEL$BOX      BOX#
     C                     MOVEL$MST#     PAL#
     C                     MOVEL$MAX      MAX#
     C           PAL#      SUB  1         WPAL    30
     C           MAX#      MULT WPAL      WBOX    40
     C           BOX#      SUB  WBOX      REM#
      *
     C           1         DO   PAL#      IX      20
     C           E2SHID    CHAINAB#WP61              99
     C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         E2#LOD
     C                     Z-ADDMAX#      E2#UNT
     C                     MOVEL'BOX'     E2PKCD    P
      *
     C                     MOVELE2ORDN    LTR10  10
     C                     MOVE IX        LTR10
     C                     MOVELLTR10     E2SERL    P
     C                     MOVELLTR10     E2ORDN    P
      * FIRST RECORD
     C           IX        IFEQ 1
     C                     MOVELLTR10     MST01
     C                     ENDIF
      * LAST RECORD
     C           IX        IFEQ PAL#
     C                     Z-ADDREM#      E2#UNT
     C                     ENDIF
      *
     C                     WRITEAB#EP611
      *
     C           IX        IFEQ 99
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* ADJUST AB#EP62
     C***********************************************************
     C           #EP62     BEGSR
      * COPY/DELETE TTAI EP62
     C           *LOVAL    SETLLAB#EP62
     C                     DO   *HIVAL
     C                     READ AB#EP62                  96
     C   96                LEAVE
     C           E3PRTN    IFEQ '3556'
     C                     WRITEAB#WP621
     C                     DELETAB#EP621
     C                     ENDIF
     C                     ENDDO
      * RE-CREATE AB#EP62
     C                     MOVE *BLANK    XPRTN  10
     C                     MOVEL'3556'    XPRTN
     C                     MOVE 'Y'       FIRST1  1
     C                     Z-ADD0         SCNT    80       TOTAL ORDER QTY
     C                     Z-ADD0         BCNT    40       TOTAL BOX
     C                     Z-ADD0         PCNT    40       TOTAL BOX FOR PALLET
      *
     C           XPRTN     SETLLAB#EL77
     C                     DO   *HIVAL
     C           XPRTN     READEAB#EL77                  96
     C   96                LEAVE
     C           E7PRTN    IFNE '3556'
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST1    IFEQ 'Y'
     C                     MOVE 'N'       FIRST1
     C                     MOVELE7PRTN    SVPRTN
     C                     MOVELE7SHID    SVSHID
     C                     MOVELE7ORDN    SVORDN
     C                     MOVELE7MAN#    SVMAN#
     C                     MOVELE7MHIN    SVMHIN 20
     C                     ENDIF
      * BREAK BY 60?
     C                     ADD  1         PCNT
     C           PCNT      IFGT 60
     C                     EXSR #BRK1
     C                     ENDIF
      * BRAEK BY RECORD
     C           E7PRTN    IFNE SVPRTN
     C           E7SHID    ORNE SVSHID
     C           E7ORDN    ORNE SVORDN
     C           E7MAN#    ORNE SVMAN#
     C           E7MHIN    ORNE SVMHIN
     C                     EXSR #BRK2
     C                     ENDIF
      * DETAIL
     C                     ADD  1         BCNT
     C                     ADD  E7SYOS    SCNT
      *
     C                     ENDDO
      * LAST BREAK ?
     C           FIRST1    IFEQ 'N'
     C                     EXSR #BRK2
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
     C* BREAK BY 60 (PALLET)
     C***********************************************************
     C           #BRK1     BEGSR
      *
     C           K#WP62    CHAINAB#WP62              99
     C           *IN99     IFEQ *OFF
     C                     MOVELSVORDN    E3ORDN
     C                     Z-ADDSCNT      E3SRYO
     C                     Z-ADDBCNT      ETBOX
     C                     WRITEAB#EP621
     C                     ENDIF
      * RESET
     C                     Z-ADD0         PCNT
     C                     Z-ADD0         SCNT
     C                     Z-ADD0         BCNT
      *
     C                     ENDSR
     C***********************************************************
     C* BREAK BY RECORD (CONTAINER)
     C***********************************************************
     C           #BRK2     BEGSR
      *
     C           K#WP62    KLIST
     C                     KFLD           SVPRTN
     C                     KFLD           SVSHID
     C                     KFLD           SVMAN#
     C                     KFLD           SVMHIN
      *
     C           SCNT      IFNE 0
     C           K#WP62    CHAINAB#WP62              99
     C           *IN99     IFEQ *OFF
     C                     MOVELSVORDN    E3ORDN
     C                     Z-ADDSCNT      E3SRYO
     C                     Z-ADDBCNT      ETBOX
     C                     WRITEAB#EP621
     C                     ENDIF
     C                     ENDIF
      * RESET
     C                     MOVELE7PRTN    SVPRTN
     C                     MOVELE7SHID    SVSHID
     C                     MOVELE7ORDN    SVORDN
     C                     MOVELE7MAN#    SVMAN#
     C                     MOVELE7MHIN    SVMHIN
     C                     Z-ADD0         SCNT
     C                     Z-ADD0         BCNT
      *
     C                     ENDSR
     C***********************************************************
     C* INITIAL SET
     C***********************************************************
     C           #INIT     BEGSR
     C*
     C           *LIKE     DEFN E2SHID    SVSHID
     C           *LIKE     DEFN E2PRTN    SVPRTN
     C           *LIKE     DEFN E2MAN#    SVMAN#
     C           *LIKE     DEFN E2BLN#    SVBLN#
     C           *LIKE     DEFN E2INVN    SVINVN
     C           *LIKE     DEFN E2ORDN    SVORDN
     C           *LIKE     DEFN E2SUPL    SVSUPL
     C           *LIKE     DEFN E2DEHZ    SVDEHZ
     C           *LIKE     DEFN E2#LOD    SV#LOD
     C           *LIKE     DEFN E2#UNT    SV#UNT
     C           *LIKE     DEFN E2PKCD    SVPKCD
     C           *LIKE     DEFN E2SERL    SVSERL
      *
     C                     MOVE *BLANK    MST01  10
      * CHECK 3556
     C                     Z-ADD0         RCNT61  40
     C           *LOVAL    SETLLAB#EP61
     C                     DO   *HIVAL
     C                     READ AB#EP61                  98
     C   98                LEAVE
     C           E2PRTN    IFEQ '3556'
     C                     ADD  1         RCNT61
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
