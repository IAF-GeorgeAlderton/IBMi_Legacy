     C           M6DKTO    CABEQ'Y'       STP82
     C           M6KSHK    CABEQ*BLANK    STP82
     C                     ENDIF
     C           M6DKTO    IFNE *BLANK
     C                     MOVE 'H'       M6KSHK
     C                     Z-ADDWKALL     M6ALHK
     C                     Z-ADDWMAX      M6MXHK
     C                     ENDIF
     C           STP82     TAG
     C           M6DTKO    IFNE '2'
     C           M6DTKO    ANDNE'D'
     C           KSKBN     IFEQ M6KSNK
     C           M6KMIN    IFEQ M6KMAX
     C                     GOTO STP83
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*************        MOVE *BLANK    M6DKTO
     C*************        MOVE 'Y'       M6KPUT
     C           STP83     TAG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      **ファイルの更新**
     C                     MOVEL'ZIDOU'   M6KMEI    P
     C                     Z-ADD*DATE     M6KOHZ
     C                     TIME           WTIME
     C                     ENDIF
      **
     C           M6DTKO    IFEQ '0'
