     H            Y/                                    1
     FMBEPP02 IP  E           K        DISK
     FMBEPL05 UF  E           K        DISK                      A
      *
     C           I6DNEN    IFEQ 6005
     C                     MOVELI6SHN1    @6SHN1  5
     C                     MOVELI6SHN2    @6SHN2  5
     C                     MOVELI6SHN3    @6SHN3  2
     C                     Z-ADDI6DNEN    @6DNEN  40
     C                     Z-ADDI6TOK7    @6TOK7  30
     C                     Z-ADDI6UKE7    @6UKE7  30
     C                     Z-ADDI6RCD7    @6RCD7  50
     C                     Z-ADDI6SRO7    @6SRO7  90
     C                     Z-ADDI6KGK7    @6KGK7  90
     C                     EXSR SUB
     C                     END
      *
     CSR         SUB       BEGSR
     C           KEY       KLIST
     C                     KFLD           @6DNEN  40
     C                     KFLD           @6SHN1
     C                     KFLD           @6SHN2
     C                     KFLD           @6SHN3
     C                     Z-ADD2005      @6DNEN
     C           KEY       CHAINMBEPL051             25
     C           *IN25     IFEQ '0'
     C                     Z-ADD@6TOK7    I6TOK7
     C                     Z-ADD@6UKE7    I6UKE7
     C                     Z-ADD@6RCD7    I6RCD7
     C                     Z-ADD@6SRO7    I6SRO7
     C                     Z-ADD@6KGK7    I6KGK7
     C                     UPDATMBEPL051
     C                     ELSE
     C                     CLEARMBEPL051
     C                     MOVEL@6SHN1    I6SHN1
     C                     MOVEL@6SHN2    I6SHN2
     C                     MOVEL@6SHN3    I6SHN3
     C                     Z-ADD2005      I6DNEN
     C                     Z-ADD@6TOK7    I6TOK7
     C                     Z-ADD@6UKE7    I6UKE7
     C                     Z-ADD@6RCD7    I6RCD7
     C                     Z-ADD@6SRO7    I6SRO7
     C                     Z-ADD@6KGK7    I6KGK7
     C                     WRITEMBEPL051
     C                     ENDIF
     CSR         SUBE      ENDSR
      *
