     C                     SETOF                     03
     C           TOKUM     CHAINFGBPL011             03
     C   03                GOTO @END
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    IFLE *DATE
     C                     GOTO @END
     C                     END
     C                     END
      *
     C           NBANM     IFEQ *BLANK
      *
     C           TOKUM     IFEQ 2011
     C           TKOJM     ANDEQ'2'
     C                     GOTO STEP1
     C                     END
      *
     C           TOKUM     IFEQ 6688
     C           TKOJM     ANDEQ'6'
     C                     GOTO STEP1
     C                     END
      *
     C                     SETOF                     04
     C           KEY1      CHAINKAAPP101             04
      *
