     C           #DSP3E    ENDSR
     C*****************************************************
     C*  #PGDW   PAGE-DOWN (ROLL-UP)                      *
     C*****************************************************
     C           #PGDW     BEGSR
     C*
     C                     Z-ADDS@MAXJ    J
     C                     MOVEL@DIE,J    W@DIE@
     C                     MOVELW@DIK1    K@KAT1            DIE NO.1
     C                     MOVELW@DIK2    K@KAT2            DIE NO.2
     C                     MOVELW@DIK3    K@KAT3            DIE NO.3
     C                     MOVELW@DIK4    K@KAT4            DIE NO.4
     C                     MOVEL'R'       F@PP90
     C*                    ____________
     C           K@PP90    SETGTECSPP90
     C                     EXSR #PP90
     C*                    ~~~~~~~~~~~~
I----C           *IN92     IFEQ '1'
|    C                     MOVEL@ER,8     D#SMSG
|    C                     SETON                     99
|    C                     MOVEL'DSP3'    S@PROC
|    C                     GOTO #PGDWE
E----C                     ENDIF
     C*
     C*==< SUB FILE WRITE >==*
I----C           S@MAXJ    IFLT 68
|    C                     MOVEL@DIE,1    W@DIE@
|    C                     MOVELW@DIK1    K@KAT1            DIE NO.1
|    C                     MOVELW@DIK2    K@KAT2            DIE NO.2
|    C                     MOVELW@DIK3    K@KAT3            DIE NO.3
|    C                     MOVELW@DIK4    K@KAT4            DIE NO.4
|    C                     MOVEL'R'       F@PP90
|    C*                    ____________
|    C           K@PP90    SETLLECSPP90
|    C                     EXSR #PP90
|    C*                    ~~~~~~~~~~~~
E----C                     ENDIF
     C*
     C                     EXSR #SFLE
     C*
     C*==< NEXT PROCESSING >==*
     C                     MOVEL'DSP3'    S@PROC
     C*
     C           #PGDWE    ENDSR
     C*****************************************************
     C*  #PGUP   PAGE-UP (ROLL-DOWN)                      *
     C*****************************************************
     C           #PGUP     BEGSR
     C*
     C                     MOVEL@DIE,1    W@DIE@
     C                     MOVELW@DIK1    K@KAT1            DIE NO.1
     C                     MOVELW@DIK2    K@KAT2            DIE NO.2
     C                     MOVELW@DIK3    K@KAT3            DIE NO.3
     C                     MOVELW@DIK4    K@KAT4            DIE NO.4
     C                     MOVEL'P'       F@PP90
     C*                    ____________
     C           K@PP90    SETLLECSPP90
     C                     EXSR #PP90
     C*                    ~~~~~~~~~~~~
I----C           *IN92     IFEQ '1'
|    C                     MOVEL@ER,7     D#SMSG
|    C                     SETON                     99
|    C                     MOVEL'DSP3'    S@PROC
|    C                     GOTO #PGUPE
E----C                     ENDIF
     C*
     C                     Z-ADD68        J
D----C           *IN92     DOWEQ'0'
|    C           J         ANDGT*ZERO
|    C                     MOVELE9KAT1    W@DIK1
|    C                     MOVELE9KAT2    W@DIK2
|    C                     MOVELE9KAT3    W@DIK3
|    C                     MOVELE9KAT4    W@DIK4
|    C*                    __________
|    C                     EXSR #PP90
|    C*                    ~~~~~~~~~~
|    C                     SUB  1         J
E----C                     ENDDO
     C*
     C*==< SUB FILE WRITE >==*
     C                     MOVELW@DIK1    K@KAT1            DIE NO.1
     C                     MOVELW@DIK2    K@KAT2            DIE NO.2
     C                     MOVELW@DIK3    K@KAT3            DIE NO.3
     C                     MOVELW@DIK4    K@KAT4            DIE NO.4
     C                     MOVEL'R'       F@PP90
     C*                    ____________
     C           K@PP90    SETLLECSPP90
     C                     EXSR #PP90
     C*                    ~~~~~~~~~~~~
     C                     EXSR #SFLE
     C*
     C*==< NEXT PROCESSING >==*
     C                     MOVEL'DSP3'    S@PROC
     C*
     C           #PGUPE    ENDSR
     C*
----+-*--1----+----2----+----3----+----4----+----5----+----6
** @ER
E-01 INPUT IS NEEDED.
E-02 THE ENTERED CONTENT IS INCORRECT
E-03 DIE NUMBER IS INPUT MISSING.
E-04 THIS DIE IS NOT REGISTERED.
E-05 NOT REGISTERED
E-06 IT IS REGISTERED
E-07 FIRST PAGE OF REPORT.
E-08 LAST PAGE OF REPORT.


