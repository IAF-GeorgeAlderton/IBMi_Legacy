     H            Y.
     F** ECSR90 *******************************************
     F*  RESTRICTION QUANTITY ON TAKING OUT DIE           *
     F*          2017.09.11  ITS.  T.MITSUI               *
     F*****************************************************
     F*          FILE DEFINITION                          *
     F*****************************************************
     F*==< SCREEN >==*
     FECSPW90 CF  E                    WORKSTN
     F                                        #RRN1 KSFILE ECSPW90S
     F                                              KINFDS INFDS
     F*
     F*==< DIE KANBAN M/F >==*
     FGCQPL14 IF  E           K        DISK
     F*
     F*==< RESTRICTION QUANTITY ON TAKING OUT DIE >==*
     FECSPP90 UF  E           K        DISK                      A
     F*
     F*
     E*****************************************************
     F*          ARRAY DEFINITION                         *
     E*****************************************************
     E                    @ER     1  10 60
     E*
     E                    @DIE       68 11
     E                    @RQT       68  3 0
     E*
     I*****************************************************
     I*          DATA STRUCTURE                           *
     I*****************************************************
     I*==< SYSTEM INFORMATION >==*
     I           SDS
     I                                     *PROGRAM @@PGID
     I                                      244 253 @@WSID
     I                                      254 263 @@USID
     I                                      264 269 @@JBNO
     I*==< WROKSTATION INFORMATION >==*
     IINFDS       DS
     I                                      273 282 $$WSNM
     I                                    B 370 3710$$CUR
     I                                    B 378 3790$$RRN
     I*==< SYSTEM DATE/TIME >==*
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        7  140S@YMD
     I                                        7  100S@YYYY
     I                                       11  120S@MM
     I                                       13  140S@DD
     I*==< SCREEN ITEM >==*
     I*         ( DIE NUMBER )
     I            DS
     I                                        1   8 D#KAT@
     I                                        1   2 D#KAT1
     I                                        3   6 D#KAT2
     I                                        7   7 D#KAT3
     I                                        8   8 D#KAT4
     I*==< WORK >==*
     I*         ( DIE NUMBER )
     I            DS
     I                                        1  11 W@DIE@
     I                                        1   2 W@DIK1
     I                                        3   3 W@DIH2
     I                                        4   7 W@DIK2
     I                                        8   8 W@DIH3
     I                                        9   9 W@DIK3
     I                                       10  10 W@DIH4
     I                                       11  11 W@DIK4
     I*
     C*****************************************************
     C*          PARAMETERS LIST                          *
     C*****************************************************
     C*
     C*
     C*****************************************************
     C*          KEY LIST                                 *
     C*****************************************************
     C*==< ECSPP90 : RESTRICTION QUANTITY ON TAKING OUT DIE >==*
     C           K@PP90    KLIST
     C                     KFLD           K@KAT1  2         DIE NO.1
     C                     KFLD           K@KAT2  4         DIE NO.2
     C                     KFLD           K@KAT3  1         DIE NO.3
     C                     KFLD           K@KAT4  1         DIE NO.4
     C*
     C*****************************************************
     C*          INTERNAL WORKING ITEM                    *
     C*****************************************************
     C                     MOVEL'EDT1'    S@PROC  4
     C                     MOVEL*BLANK    F@PP90  1
     C                     Z-ADD*ZERO     J       30
     C                     Z-ADD*ZERO     K       30
     C                     Z-ADD*ZERO     S@MAXJ  30
     C                     Z-ADD*ZERO     S@RRN1  50
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C*
     C*==< MAIN PROCESSING >==*
D----C           S@PROC    DOWNE'EXIT'
|    C*
|S---C                     SELEC
|+---C           S@PROC    WHEQ 'EDT1'
||   C                     EXSR #EDT1
||   C*
|+---C           S@PROC    WHEQ 'DSP1'
||   C                     EXSR #DSP1
||   C*
|+---C           S@PROC    WHEQ 'CHK1'
||   C                     EXSR #CHK1
||   C*
|+---C           S@PROC    WHEQ 'EDT2'
||   C                     EXSR #EDT2
||   C*
|+---C           S@PROC    WHEQ 'DSP2'
||   C                     EXSR #DSP2
||   C*
|+---C           S@PROC    WHEQ 'CHK2'
||   C                     EXSR #CHK2
||   C*
|+---C           S@PROC    WHEQ 'DATA'
||   C                     EXSR #DATA
||   C*
|+---C           S@PROC    WHEQ 'EDT3'
||   C                     EXSR #EDT3
||   C*
|+---C           S@PROC    WHEQ 'DSP3'
||   C                     EXSR #DSP3
||   C*
|+---C           S@PROC    WHEQ 'PGUP'
||   C                     EXSR #PGUP
||   C*
|+---C           S@PROC    WHEQ 'PGDW'
||   C                     EXSR #PGDW
||   C*
|E---C                     ENDSL
|    C*
E----C                     ENDDO
     C*
     C*==< FINAL PROCESSING >==*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  #EDT1   EDIT SCREEN-1                            *
     C*****************************************************
     C           #EDT1     BEGSR
     C*
     C*==< INITIALIZE ITEMS >==*
     C                     MOVEL*BLANK    D#UPKB
     C                     MOVEL*BLANK    D#KAT1
     C                     MOVEL*BLANK    D#KAT2
     C                     MOVEL*BLANK    D#KAT3
     C                     MOVEL*BLANK    D#KAT4
     C                     MOVEL*BLANK    D#EMSG
     C                     MOVEA'00000'   *IN,31             31-35
     C                     SETOF                     99
     C*
     C*==< NEXT PROCESSING >==*
     C                     MOVEL'DSP1'    S@PROC
     C*
     C           #EDT1E    ENDSR
     C*****************************************************
     C*  #DSP1   DISPLAY SCREEN-1                         *
     C*****************************************************
     C           #DSP1     BEGSR
     C*
     C*==< DISPLAY >==*    _____________
     C                     EXFMTECSPW901
     C*                    ~~~~~~~~~~~~~
     C                     TIME           S@TIME
     C*
     C*==< NEXT PROCESSING >==*
S----C                     SELEC
+----C           *IN01     WHEQ '1'                        < F1 >
|    C                     MOVEL'EXIT'    S@PROC
|    C*
+----C           *IN12     WHEQ '1'                        < F12 >
|    C                     MOVEL'CHK1'    S@PROC
|    C*
+----C                     OTHER                           < ENTER >
|    C                     MOVEL'CHK1'    S@PROC
E----C                     ENDSL
     C*
     C           #DSP1E    ENDSR
     C*****************************************************
     C*  #CHK1   CHECK SCRREN-1                           *
     C*****************************************************
     C           #CHK1     BEGSR
     C*
     C*==< INITIALIZE ITEMS >==*
     C                     MOVEL*BLANK    D#EMSG
     C                     MOVEA'00000'   *IN,31             31-35
     C                     SETOF                     99
     C*
     C*==< UPDATE >==*
I----C           *IN12     IFEQ '0'
|S---C                     SELEC
|+---C           D#UPKB    WHEQ *BLANK
||   C                     MOVEL@ER,1     D#EMSG
||   C                     SETON                     3199
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
||   C*
|+---C           D#UPKB    WHEQ '0'
||   C           D#UPKB    OREQ '1'
||   C           D#UPKB    OREQ '2'
||   C*
|+---C                     OTHER
||   C                     MOVEL@ER,2     D#EMSG
||   C                     SETON                     3199
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
||   C*
|E---C                     ENDSL
E----C                     ENDIF
     C*
     C*==< DIE NUMBER >==*
I----C           *IN12     IFEQ '0'
|I---C           D#KAT@    IFEQ *BLANK
||   C                     MOVEL@ER,1     D#EMSG
||   C                     MOVEA'1111'    *IN,32
||   C                     SETON                     99
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
|E---C                     ENDIF
E----C                     ENDIF
     C*
I----C           D#KAT4    IFNE *BLANK
|I---C           D#KAT1    IFEQ *BLANK
||   C  N99                MOVEL@ER,3     D#EMSG
||   C                     SETON                     3299
|E---C                     ENDIF
|    C*
|I---C           D#KAT2    IFEQ *BLANK
||   C  N99                MOVEL@ER,3     D#EMSG
||   C                     SETON                     3399
|E---C                     ENDIF
|    C*
|I---C           D#KAT3    IFEQ *BLANK
||   C  N99                MOVEL@ER,3     D#EMSG
||   C                     SETON                     3499
|E---C                     ENDIF
|    C*
|I---C           *IN99     IFEQ '1'
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
|E---C                     ENDIF
E----C                     ENDIF
     C*
I----C           D#KAT3    IFNE *BLANK
|I---C           D#KAT1    IFEQ *BLANK
||   C  N99                MOVEL@ER,3     D#EMSG
||   C                     SETON                     3299
|E---C                     ENDIF
|    C*
|I---C           D#KAT2    IFEQ *BLANK
||   C  N99                MOVEL@ER,3     D#EMSG
||   C                     SETON                     3399
|E---C                     ENDIF
|    C*
|I---C           *IN99     IFEQ '1'
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
|E---C                     ENDIF
E----C                     ENDIF
     C*
I----C           D#KAT2    IFNE *BLANK
|I---C           D#KAT1    IFEQ *BLANK
||   C  N99                MOVEL@ER,3     D#EMSG
||   C                     SETON                     3299
|E---C                     ENDIF
|    C*
|I---C           *IN99     IFEQ '1'
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
|E---C                     ENDIF
E----C                     ENDIF
     C*
I----C           *IN12     IFEQ '0'
|    C*                    ____________
|    C           D#KAT1    SETLLGCQPL14
|    C                     EXSR #GCQP
|    C*                    ~~~~~~~~~~~~
|I---C           *IN91     IFEQ '1'
||   C                     MOVEL@ER,4     D#EMSG
||   C                     SETON                     323334
||   C                     SETON                     99
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO #CHK1E
|E---C                     ENDIF
E----C                     ENDIF
     C*
     C*==< ECSPP90 REGISTED >==*
I----C           *IN12     IFEQ '0'
|    C                     MOVELD#KAT1    K@KAT1            DIE NO.1
|    C                     MOVELD#KAT2    K@KAT2            DIE NO.2
|    C                     MOVELD#KAT3    K@KAT3            DIE NO.3
|    C                     MOVELD#KAT4    K@KAT4            DIE NO.4
|    C*                    ____________
|    C           K@PP90    CHAINECSPP90              92
|    C*                    ~~~~~~~~~~~~
|I---C           *IN92     IFEQ '1'
||   C           *IN92     OREQ '0'
||   C           E9SKJY    ANDEQ'D'
||   C           E9SKHZ    ANDLES@YMD
||I--C           D#UPKB    IFEQ '0'
|||  C           D#UPKB    OREQ '1'
|||  C                     MOVEL@ER,5     D#EMSG
|||  C                     MOVEA'1111'    *IN,32
|||  C                     SETON                     99
|||  C                     MOVEL'DSP1'    S@PROC
|||  C                     GOTO #CHK1E
||E--C                     ENDIF
||   C*
|+---C                     ELSE
||I--C           D#UPKB    IFEQ '2'
|||  C                     MOVEL@ER,6     D#EMSG
|||  C                     MOVEA'1111'    *IN,32
|||  C                     SETON                     99
|||  C                     MOVEL'DSP1'    S@PROC
|||  C                     GOTO #CHK1E
||E--C                     ENDIF
|E---C                     ENDIF
E----C                     ENDIF
     C*
     C*==< NEXT PROCESSING >==*
I----C           *IN12     IFEQ '0'
|    C                     MOVEL'EDT2'    S@PROC
+----C                     ELSE
|    C                     MOVEL'EDT3'    S@PROC
E----C                     ENDIF
     C*
     C           #CHK1E    ENDSR
     C*===================================================*
     C*  #GCQP   GCQPL14 READE                            *
     C*===================================================*
     C           #GCQP     BEGSR
     C*
     C           #GCQP1    TAG
     C*                    ____________
     C           D#KAT1    READEGCQPL14                  91
     C*                    ~~~~~~~~~~~~
     C           *IN91     CABEQ'1'       #GCQPE
     C*
     C*==< SKIP >==*
I----C           T6SKJY    IFEQ 'D'
|    C           T6SKHZ    ANDLES@YMD
|    C                     GOTO #GCQP1
E----C                     ENDIF
     C*
I----C           D#KAT2    IFNE *BLANK
|    C           D#KAT2    ANDNET6KAT2
|    C                     GOTO #GCQP1
E----C                     ENDIF
     C*
I----C           D#KAT3    IFNE *BLANK
|    C           D#KAT3    ANDNET6KAT3
|    C                     GOTO #GCQP1
E----C                     ENDIF
     C*
I----C           T6KIHZ    IFGT S@YMD
|    C                     GOTO #GCQP1
E----C                     ENDIF
     C*
     C           #GCQPE    ENDSR
     C*****************************************************
     C*  #EDT2   EDIT SCREEN-2                            *
     C*****************************************************
     C           #EDT2     BEGSR
     C*
     C*==< INITIALIZE ITEMS >==*
S----C                     SELEC
+----C           D#UPKB    WHEQ '0'
|    C                     MOVEL'CANCEL'  D#UPNM
|    C                     Z-ADDE9REQT    D#REQT
|    C                     SETON                     51
+----C           D#UPKB    WHEQ '1'
|    C                     MOVEL'CHANGE'  D#UPNM
|    C                     Z-ADDE9REQT    D#REQT
|    C                     SETOF                     51
+----C           D#UPKB    WHEQ '2'
|    C                     MOVEL'ADD   '  D#UPNM
|    C                     Z-ADD*ZERO     D#REQT
|    C                     SETOF                     51
E----C                     ENDSL
     C                     MOVEL*BLANK    D#EMSG
     C                     SETOF                     3699
