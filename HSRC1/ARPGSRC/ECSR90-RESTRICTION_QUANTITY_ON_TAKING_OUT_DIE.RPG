     C*****************************************************
     C*  #CHK2   CHECK SCRREN-2                           *
     C*****************************************************
     C           #CHK2     BEGSR
     C*
     C*==< INITIALIZE ITEMS >==*
     C                     MOVEL*BLANK    D#EMSG
     C                     SETOF                     3699
     C*
     C*==< RESTRICTION QUANTITY >==*
I----C           D#REQT    IFEQ *ZERO
|    C                     MOVEL@ER,1     D#EMSG
|    C                     SETON                     3699
|    C                     MOVEL'DSP2'    S@PROC
|    C                     GOTO #CHK2E
E----C                     ENDIF
     C*
     C*==< NEXT PROCESSING >==*
I----C           *IN05     IFEQ '1'
|    C                     MOVEL'DATA'    S@PROC
+----C                     ELSE
|    C                     MOVEL'DSP2'    S@PROC
E----C                     ENDIF
     C*
     C           #CHK2E    ENDSR
     C*****************************************************
     C*  #DATA   ECSPP90 RECORD UPDATE                    *
     C*****************************************************
     C           #DATA     BEGSR
     C*
     C*==< ECSPP90 EDIT & UPDATE >==*
S----C                     SELEC
+----C           D#UPKB    WHEQ '0'
|    C                     MOVEL'D'       E9SKJY
|    C                     Z-ADDS@YMD     E9SKHZ
|    C                     MOVEL@@USID    E9KOME
|    C*                    _____________
|    C                     UPDATECSPP901
|    C*                    ~~~~~~~~~~~~~
+----C           D#UPKB    WHEQ '1'
|I---C           D#REQT    IFNE E9REQT
||   C                     Z-ADDS@YMD     E9KOHZ
||   C                     Z-ADDS@HMS     E9KOJK
||   C                     MOVEL@@USID    E9KOME
||   C                     Z-ADDD#REQT    E9REQT
||   C*                    _____________
||   C                     UPDATECSPP901
||   C*                    ~~~~~~~~~~~~~
|E---C                     ENDIF
|    C*
+----C           D#UPKB    WHEQ '2'
|    C                     CLEARECSPP901
|    C                     Z-ADDS@YMD     E9KOHZ
|    C                     Z-ADDS@HMS     E9KOJK
|    C                     MOVEL@@USID    E9KOME
|    C                     MOVELD#KAT1    E9KAT1
|    C                     MOVELD#KAT2    E9KAT2
|    C                     MOVELD#KAT3    E9KAT3
|    C                     MOVELD#KAT4    E9KAT4
|    C                     Z-ADDD#REQT    E9REQT
|    C*                    _____________
|    C  N92                UPDATECSPP901
|    C   92                WRITEECSPP901
|    C*                    ~~~~~~~~~~~~~
E----C                     ENDSL
