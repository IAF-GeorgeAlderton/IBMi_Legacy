     H            Y.                                    1
     H** AFDR72 *******************************************************
     H*  OUT SOURCE ORDER RECIEVING(FAS)
     H*
     H* TCHK1 10/11/12 CREATE
%1   H* KIRI  2017/02/22 INTRA KANBAN(KCLAS ='A')
     H**************************************************************************
     FAFDPW72 CF  E                    WORKSTN
     FAFDPL21 UF  E           K        DISK
     FAFDPL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
%1   FABHTL02 IF  E           K        DISK
     FAFDPL40 UF  E           K        DISK                      A
      *--------------------------------------------------------------
     E                    ER      1  10 15
     E                    TAB1    1   5  4   TAB2   15
     E                    BCD2       14  1
     E                    BCDB       14  1
     I**************************************************************************
     I* BARCODE
     I* APICS(INTRA) KANBAN
     I*(KANRI CODE+ZETAI NO+TEHAI NO+PAGE NO+NIJI KAKO KUBUN+TAISYO KUBN+
     I            DS
     I                                        1  15 BARCD1
     I                                        1   1 BCOCD
     I                                        2   5 BZETI
     I                                        6   80BTEHI
     I                                        6   8 WTEHI
     I                                        8   8 KCLAS
     I                                        9  10 BPAGE
     I                                       11  11 BNIJI
     I                                       12  12 BTICD
     I                                       13  13 BYUKO
     I                                       14  14 BHASY
     I                                       15  15 BCKDT
     I            DS
     I                                        1  14 BARCD2
     I            DS
     I                                        1  12 B@SHIN
     I                                        1   5 B@SHN1
     I                                        6  10 B@SHN2
     I                                       12  12 B@SHN3
     I            DS
     I                                        1  11 BARCD3
     I                                        1  11 B@SERL
     I**************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C           @@ID      CASEQ'02'      #DSP02
     C           @@ID      CASEQ'03'      #DSP03
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PWKCD   6
     C                     PARM           SUPLY   4
     C                     PARM           PID     1
      *
     C           K#AFD     KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@BIN   3
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C* AFDPL11
     C           K#11      KLIST
     C                     KFLD           BCOCD            CONTROL CD
     C                     KFLD           BZETI            ABSOLUTE #
     C                     KFLD           WTEHI            TEHAI
     C                     KFLD           BPAGE            PAGE
     C                     KFLD           BNIJI            2ND.TREATEMENT
     C                     KFLD           BTICD            TARGET TYPE
     C                     KFLD           BYUKO            SHIP EFFECTIVE
     C                     KFLD           BHASY            CONTAINER TYPE
     C                     KFLD           BCKDT            CHECK DIGIT
%1   C* AFDPL40
     C           K#40      KLIST
     C                     KFLD           BCOCD
     C                     KFLD           BZETI
     C                     KFLD           WTEHI
     C                     KFLD           BPAGE
     C                     KFLD           BNIJI
     C                     KFLD           BTICD
     C                     KFLD           BYUKO
     C                     KFLD           BHASY
     C                     KFLD           BCKDT
     C                     KFLD           W@BIN
     C                     KFLD           W@ODNO
     C                     KFLD           SUPLY
      *
%1   C           KEY1      KLIST
     C                     KFLD           ADPAR1
     C                     KFLD           ADPAR2
     C                     KFLD           ADPAR3
      *
      * FOR KANBAN CHECK DEGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C                     MOVE SUPLY     @SUPP   40
     C                     MOVELPID       @@3     1
     C                     Z-ADD*ZERO     K@YY
     C                     Z-ADD*ZERO     K@MM
     C                     Z-ADD*ZERO     K@DD
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C           SUPLY     LOKUPTAB1      TAB2           10
     C                     MOVELTAB2      TITL
      *
     C                     SETOF                     60
     C                     MOVE *BLANK    MAE
     C                     Z-ADD*ZERO     KENS
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN (APICS KANBAN)
     C**************************************************************************
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR @CHK1
     C           *IN30     IFEQ '0'
     C                     MOVEL'02'      @@ID
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           @CHK1     BEGSR
     C*
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C                     SETOF                     3061
     C*
     C                     DO
     C* CHECK DEGIT
     C                     MOVELBARCD1    PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     3061
     C                     MOVE ER,10     MSG
     C                     LEAVE
     C                     ENDIF
     C           PMCHK     IFNE BCKDT
     C                     SETON                     3061
     C                     MOVE ER,10     MSG
     C                     LEAVE
     C                     ENDIF
     C*
     C           K#11      SETGTAFDPL11
     C           *IN90     DOUEQ*ON
     C           K#11      REDPEAFDPL11                  90
     C           *IN90     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
     C           ADSUPP    ANDEQSUPLY
     C                     MOVELADBINN    K@BIN
     C                     MOVELADODNO    W@ODNO  60
     C                     MOVELADBINN    W@BIN   3
      * %1
     C                     Z-ADD*ZERO     @@LOT   50
     C           KCLAS     IFEQ 'A'
     C                     EXSR #LOT
     C                     ELSE
     C                     Z-ADD1         @@LOT
     C                     ENDIF
      *
     C                     LEAVE
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     SETON                     3061
     C                     MOVE ER,1      MSG
     C                     LEAVE
     C                     END
      *
     C           K#AFD     SETLLAFDPL21
     C           *IN90     DOUEQ*ON
     C           K#AFD     READEAFDPL21                  90
     C           *IN90     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
     C           AFAKI1    ANDEQ@@3
     C           AFAKI2    ANDNE*BLANK
     C  N30                MOVE ER,3      MSG
     C                     SETON                     3061
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C           *IN30     IFEQ *ON
     C                     LEAVE
     C                     END
      *
     C           K#AFD     SETLLAFDPL21
     C           *IN90     DOUEQ*ON
     C           K#AFD     READEAFDPL21                  90
     C           *IN90     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
     C           AFAKI1    ANDEQ@@3
     C           AFODNO    ANDEQW@ODNO
     C           AFZETI    ANDEQBZETI
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C           *IN90     IFEQ *ON
     C                     SETON                     3061
     C                     MOVE ER,1      MSG
     C                     LEAVE
     C                     ENDIF
     C*
     C           K#40      SETLLAFDPL40
     C           *IN90     DOUEQ*ON
     C           K#40      READEAFDPL40                  90
     C           *IN90     IFEQ *OFF
     C           A4SKJY    ANDEQ*BLANK
     C  N30                MOVE ER,6      MSG
     C  N30                MOVEL'ORDER#:' MSG2
     C  N30                MOVE W@ODNO    MSG2
     C                     SETON                     3061
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*    2ND SCREEN (PART#)
     C**************************************************************************
     C           #DSP02    BEGSR
      *
     C                     EXFMTDSP02
      *
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
      *
     C                     OTHER
     C                     EXSR @CHK2
     C           *IN30     IFEQ *OFF
%1   C           BCOCD     IFEQ 'A'                        A=APICS
     C                     MOVE '03'      @@ID
%1   C                     ELSE                            ::OTHER
     C                     EXSR @UPD
     C                     MOVE '01'      @@ID
%1   C                     ENDIF
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK2
     C**************************************************************************
     C           @CHK2     BEGSR
     C*
     C                     DO
     C*
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C                     SETOF                     3064
     C*
     C                     MOVEABARCD2    BCD2
     C                     MOVEL*BLANK    BCDB
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 14
     C                     LEAVE
     C                     END
     C           BCD2,X    IFNE *BLANK
     C           BCD2,X    ANDNE'-'
     C                     ADD  1         Y
     C                     MOVELBCD2,X    BCDB,Y
     C                     END
     C                     ENDDO
     C                     MOVEABCDB      W@014  14
     C                     MOVELW@014     B@SHIN
     C*
     C           B@SHN1    IFEQ *BLANK
     C                     MOVE ER,5      MSG
     C                     SETON                     3064
     C                     LEAVE
     C                     END
      *
     C                     MOVELB@SHN1    K@SHN1
     C                     MOVELB@SHN2    K@SHN2
     C                     MOVELB@SHN3    K@SHN3
      *
     C           K#FCE     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     MOVEL*BLANK    K@SHN3
     C           K#FCE     CHAINFCEPL01              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     MOVELER,7      MSG
     C                     SETON                     3064
     C                     LEAVE
     C                     END
     C*
     C           A2ZETI    IFNE BZETI
     C                     MOVELER,7      MSG
     C                     SETON                     3064
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*    3RD SCREEN (SERIAL#)
     C**************************************************************************
     C           #DSP03    BEGSR
      *
     C                     EXFMTDSP03
      *
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR @CHK3
     C           *IN30     IFEQ *OFF
     C                     EXSR @UPD
     C                     MOVE '01'      @@ID
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK3
     C**************************************************************************
     C           @CHK3     BEGSR
     C*
     C                     DO
     C*
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    MSG2
     C                     SETOF                     3065
     C*
     C           BARCD3    IFEQ *BLANK
     C                     MOVE ER,5      MSG
     C                     SETON                     3065
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*        UPDATE
     C**************************************************************************
     C           @UPD      BEGSR
     C*
     C                     TIME           WSDT
     C*
     C           K#AFD     SETLLAFDPL21
     C           *IN90     DOUEQ*ON
     C           K#AFD     READEAFDPL21                  90
     C           *IN90     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
     C           AFAKI1    ANDEQ@@3
     C           AFODNO    ANDEQW@ODNO
     C           AFPAR1    ANDEQB@SHN1
     C           AFPAR2    ANDEQB@SHN2
     C           AFPAR3    ANDEQB@SHN3
     C                     Z-ADDWSSDAT    AFKODT
     C                     Z-ADDWSSTM6    AFKHMS
     C                     MOVELPWKCD     AFKOME
     C                     MOVEL#PGM      AFKOPG
 %1  C***                  ADD  1         AFNOSU
     C                     ADD  @@LOT     AFNOSU
     C           AFHAKO    IFEQ AFNOSU
     C                     Z-ADDWSSYYY    AFNOYY
     C                     Z-ADDWSSMMM    AFNOMM
     C                     Z-ADDWSSDDD    AFNODD
     C                     END
     C                     UPDATAFDPP201
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C                     CLEARAFDPP401
     C                     Z-ADDWSSDAT    A4KODT
     C                     Z-ADDWSSTM6    A4KOTM
     C                     MOVEL#USER     A4KOME                  USER
     C                     MOVEL#PGM      A4KOPG                  PGM-ID
     C                     MOVELPWKCD     A4WORK                  WORKER CD
     C                     MOVELADKANR    A4KANR           CONTROL CODE
     C                     MOVELADZETI    A4ZETI           ABSOLUTE
     C                     MOVELADTEHI    A4TEHI           TEHAI #
     C                     MOVELADPAGE    A4PAGE           PAGE #
     C                     MOVELADNIJI    A4NIJI           2ND TREATMENT
     C                     MOVELADTAIS    A4TAIS           TARGET TYPE
     C                     MOVELADSYUK    A4SYUK           SHIP EFECTIVE
     C                     MOVELADHKOS    A4HKOS           CONTAINER TYPE
     C                     MOVELADCHKD    A4CHKD           CHECK DIGIT
     C                     MOVELADSUPP    A4SUPP
     C                     MOVELADFILR    A4FILR
     C                     Z-ADDA4KODT    A4SCDT
     C                     Z-ADDA4KOTM    A4SCTM
     C                     Z-ADDADODYY    A4ODYY
     C                     Z-ADDADODMM    A4ODMM
     C                     Z-ADDADODDD    A4ODDD
     C                     Z-ADDADODNO    A4ODNO
     C                     MOVELB@SERL    A4SERL
     C                     WRITEAFDPP401
     C*
     C                     MOVELBARCD1    MAE
     C                     ADD  1         KENS
     C                     SETON                     60
     C*
     C                     MOVEL*BLANK    BARCD1
     C                     MOVEL*BLANK    BARCD2
     C                     MOVEL*BLANK    BARCD3
     C*
     C                     ENDSR
      *---------------------------------------------------------
      *  LOT COUNT
      *---------------------------------------------------------
     C           #LOT      BEGSR
      *
 |   C           KEY1      SETLLABHTL02
 |   C                     DO   *HIVAL
 |   C           KEY1      READEABHTL02                  91
 |   C   91                LEAVE
 |   C           M6SKJY    IFEQ 'D'
 |   C           M6SKHZ    ANDLEWSSDAT
 |   C                     ITER
 |   C                     ENDIF
 |   C           M6STYY    IFEQ 9999
 |   C           M6BMON    ANDEQ@SUPP
 |   C                     ELSE
 |   C                     ITER
 |   C                     ENDIF
 |   C                     Z-ADDM6LOTK    @@LOT
 |   C                     LEAVE
 |   C                     ENDDO
      *
     C           @@LOT     IFEQ *ZERO
     C                     ADD  1         @@LOT
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------
** ERROR MESSAGE
NO DATA
BIN ERROR.
ALREADY RCVED.
BIN # NOT MATCH.
BLANK.
DUPLICATE.
PART# ERROR.
BARCODE ERROR.
SERIAL# NOT SCAN
CHECK DIGIT ERR
** TAB1 / TAB2
5555** FROM FAS  **



