     H            Y.
     F** ADKR60 ********************************************
     F* CREATE APICS MAXIMUM ISSUE NUMBER MGMT F PER BIN   *
     F*    IWATA.       2020.03.05                         *
     F******************************************************
     FAGAPL31 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAAIPL11 IF  E           K        DISK
     FADKPL60 UF  E           K        DISK                      A
     FADKPP40 IF  E           K        DISK
     FADKPP45 IF  E           K        DISK
     E                    CBTR       24  2 0             m]c ﾍﾞ]
      *
     I            DS
     I                                        1  480CBTR
     I                                        1   20CBTR01
     I                                        3   40CBTR02
     I                                        5   60CBTR03
     I                                        7   80CBTR04
     I                                        9  100CBTR05
     I                                       11  120CBTR06
     I                                       13  140CBTR07
     I                                       15  160CBTR08
     I                                       17  180CBTR09
     I                                       19  200CBTR10
     I                                       21  220CBTR11
     I                                       23  240CBTR12
     I                                       25  260CBTR13
     I                                       27  280CBTR14
     I                                       29  300CBTR15
     I                                       31  320CBTR16
     I                                       33  340CBTR17
     I                                       35  360CBTR18
     I                                       37  380CBTR19
     I                                       39  400CBTR20
     I                                       41  420CBTR21
     I                                       43  440CBTR22
     I                                       45  460CBTR23
     I                                       47  480CBTR24
      *
     I            DS
     I                                        1  100WKAP
     I                                        1   80WKAPHZ
     I                                        9  100WKAPBN
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WDATE
     C           *ENTRY    PLIST
     C                     PARM           PHM     4
     C                     CALL 'ADKR90'
     C                     PARM           PHM     4
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     Z-ADDP1APHZ    WKAPHZ  80
     C                     Z-ADDP1APBN    WKAPBN  20
      *
     C                     EXSR #SB780
     C                     EXSR #SB790
      *
     C                     Z-ADD0         WKTOTL 122
     C                     READ AGAPL311                 22
     C           *IN22     DOWEQ'0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ AGAPL311                 22
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *                                   *
      *-----------------------------------*
     CSR         #SB400    BEGSR
      *部品Ｍ
     C           KEYSHN    KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C           KEYSHN    CHAINFCEPL011             22
     C           *IN22     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '1'
     C                     GOTO ESB400
     C                     ENDIF
      *便数
     C                     Z-ADD0         WKBINS  20
      *指定便
     C                     Z-ADD1         A       50
     C           A         DOWLE24
     C           CBTR,A    IFNE 0
     C                     ADD  1         WKBINS
     C                     ENDIF
     C                     ADD  1         A
     C                     ENDDO
      *指定便がない
     C           WKBINS    IFEQ 0
     C                     Z-ADDWKCIBI    WKBINS  20
     C                     ENDIF
      *設定数
     C                     Z-ADD0         WKGEKN 120
     C                     Z-ADD0         P9GEKN 120
     C                     CALL 'ADKR96'
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           P9GEKN 120
     C                     Z-ADDP9GEKN    WKGEKN
      *係数
      *品番別があればそちらを使う
     C           KEYSHN    CHAINADKPP451             22
     C           *IN22     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     MULT CNKSU     WKGEKN
     C                     ELSE
     C                     MULT WKKSU     WKGEKN
     C                     ENDIF
      *日当り箱数
     C                     Z-ADD0         WKSETD 122
     C           CBSYUY    IFNE 0
     C           WKGEKN    DIV  CBSYUY    WKSETD    H
     C           WKSETD    DIV  20        WKSETD    H
     C                     ENDIF
      *
     C           WKSETD    IFLE 0
     C                     Z-ADD1         WKSETD
     C                     ENDIF
      *
     C                     Z-ADD1         A       50
     C           A         DOWLEWKBINS
     C                     EXSR #SB410
     C                     ADD  1         A
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C           KEY60     KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C                     KFLD           KKAPBN  20
     C                     Z-ADDA         KKAPBN
     C           KEY60     CHAINADKPL601             25
      *
     C                     CLEARADKPL601
     C                     Z-ADD*DATE     D6KOHZ
     C                     TIME           D6KOTI
     C                     MOVELW#USER    D6KOME
     C                     MOVELCBSHN1    D6SHN1
     C                     MOVELCBSHN2    D6SHN2
     C                     MOVELCBSHN3    D6SHN3
     C                     Z-ADDWKAPHZ    D6APHZ
      *
     C                     Z-ADDWKSETD    D6SETD
     C                     Z-ADDWKBINS    D6CIBI
     C                     Z-ADDA         D6APBN
     C                     Z-ADDCBBARL    D6BARL
     C                     Z-ADD0         D6LIMT
     C                     Z-ADD0         WK1    102
     C                     Z-ADD0         WK2    100
     C           D6CIBI    IFNE 0
     C           D6SETD    DIV  D6CIBI    WK1
     C                     ENDIF
     C           WK1       MULT D6APBN    WK1
     C           D6BARL    IFNE 0
     C           WK1       DIV  D6BARL    WK1
     C                     ENDIF
     C           WK1       ADD  0.99      WK2
     C           WK2       IFLT 1
     C                     Z-ADD1         WK2
     C                     ENDIF
     C           WK2       MULT D6BARL    D6LIMT
      *
     C           *IN25     IFEQ '0'
     C                     UPDATADKPL601
     C                     ELSE
     C                     WRITEADKPL601
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *----------------------------------------------------*
      *品番上限係数                                      *
      *----------------------------------------------------*
     CSR         #SB780    BEGSR
      *
     C                     MOVEL'PART#'   KKKEY  10
     C                     Z-ADD1.00      WKKSU   52
     C           KKKEY     CHAINADKPP401             20
     C           *IN49     IFEQ '0'
     C                     Z-ADDD@KSU     WKKSU
     C                     ENDIF
      *
     CSR         ESB780    ENDSR
      *----------------------------------------------------*
      *便数                                              *
      *----------------------------------------------------*
     CSR         #SB790    BEGSR
      *
     C                     Z-ADD0         WKCIBI  20
     C           0111      CHAINAAIPL111             49
     C           *IN49     IFEQ '0'
     C                     Z-ADDCDCIBI    WKCIBI
     C                     ENDIF
      *
     CSR         ESB790    ENDSR
