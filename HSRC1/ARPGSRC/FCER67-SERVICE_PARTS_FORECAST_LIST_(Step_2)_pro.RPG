     H            Y.
     F** FCER66 ****************************************************************
     F*  PROGRAM    : SERVICE PARTS FORECAST LIST                              *
     F*  WRITTEN    : 2019.01.10                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FFCEPL30 IF  E           K        DISK
     FABAWP11 IF  E           K        DISK
     F**FCEPL01 IF  E           K        DISK
     FFCEWP66 O   E           K        DISK
      *---------------------------------------------------
     E                    @YM         7  6 0
     E                    @QT         7  7 0
     E                    FWQ         7  7 0
      *---------------------------------------------------
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120TGTYM
     I                                        7  100TGTYY
     I                                       11  120TGTMM
     I            DS
     I                                        1   60#YM
     I                                        1   40#YY
     I                                        5   60#MM
     I            DS
     I                                        1  12 K#SHN
     I                                        1   5 K#SHN1
     I                                        6  10 K#SHN2
     I                                       11  12 K#SHN3
     I            DS
     I                                        1  15 F3BHB
     I                                        1   5 F3BHB1
     I                                        6  10 F3BHB2
     I                                       11  12 F3BHB3
     I                                       13  15 F3BHBX
     I            DS
     I                                        1  15 A1MHN
     I                                        1   5 A1MHN1
     I                                        6  10 A1MHN2
     I                                       11  15 A1MHN3
     I            DS
     I                                        1  12 A1SHN
     I                                        1   5 A1SHN1
     I                                        6  10 A1SHN2
     I                                       11  12 A1SHN3
     I            DS
     I                                        1  12 FWSHN
     I                                        1   5 FWSHN1
     I                                        6  10 FWSHN2
     I                                       11  12 FWSHN3
     I            DS
     I                                        1  15 FWMHN
     I                                        1   5 FWMHN1
     I                                        6  10 FWMHN2
     I                                       11  15 FWMHN3
     I            DS
     I                                        1  490FWQ
     I                                        1   70FWQTY1
     I                                        8  140FWQTY2
     I                                       15  210FWQTY3
     I                                       22  280FWQTY4
     I                                       29  350FWQTY5
     I                                       36  420FWQTY6
     I                                       43  490FWQTY7
     I            DS
     I                                        1   6 Z7LOC
     I                                        1   1 Z7LOC1
     I                                        2   3 Z7LOC2
     I                                        4   5 Z7LOC3
     I                                        6   6 Z7LOC4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ FCEPL30                  98
     C   98                LEAVE
      * SELECT DATA
     C           F3GSKD    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SELECT LOCATION
     C           F3TYMD    IFGT TODAY
     C                     MOVELF3KTRT    LOC2    2
     C                     MOVELF3KTRR    LOC3    2
     C                     ELSE
     C                     MOVELF3STRT    LOC2
     C                     MOVELF3STRR    LOC3
     C                     ENDIF
      * SELECT LOCATION
     C           LOC2      IFLT 'C1'
     C           LOC2      ORGT 'C8'
     C                     ITER
     C                     ENDIF
      * SUMMARIZE FC W/ IAF PART
     C                     MOVELF3BHB     K#SHN
     C                     EXSR #FC1
      *
      * SUMMARIZE FC W/ USER PART
     C**         FCNT      IFEQ 0
     C**                   ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  SUMMARIZE FC WITH IAF PART                        *
      *----------------------------------------------------*
     C           #FC1      BEGSR
      *
     C                     Z-ADD0         FCNT    40
     C                     Z-ADD0         @QT
      *
     C           K#WL14    SETLLABAWP11
     C                     DO   *HIVAL
     C           K#WL14    READEABAWP11                  98
     C   98                LEAVE
      * FILL FC QTY
     C                     ADD  1         FCNT
     C                     Z-ADD1         IX
     C           A1DATE    LOKUP@YM,IX                   95
     C           *IN95     IFEQ *ON
     C                     Z-ADDA1NNSU    @QT,IX
     C                     ITER
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     CLEARFCEWP661
      *
      * GET MONTHLY SETTING QTY
     C**         K#WL14    CHAINFCEPL01              99
     C**         *IN99     IFEQ *OFF
     C**         A2GSKD    ANDNE'D'
     C**                   Z-ADDA2GEKN    FWGEKN
     C**                   ELSE
     C**                   Z-ADD0         FWGEKN
     C**                   ENDIF
      * GET Q/C
     C           F3SYMD    IFLE TODAY
     C                     Z-ADDF3SSYS    FWGEKN
     C                     ELSE
     C                     Z-ADDF3KSYS    FWGEKN
     C                     ENDIF
      * WRITE
     C**         FCNT      IFGT 0
     C                     MOVELF3BHB     FWSHN
     C                     MOVELA1MHN     FWMHN
     C                     MOVELLOC2      FWLOC2
     C                     MOVELLOC3      FWLOC3
     C                     Z-ADDTGTYM     FWNOYM
     C                     Z-ADD@QT       FWQ
     C                     WRITEFCEWP661
     C**                   ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           K#WL14    KLIST
     C                     KFLD           K#SHN1
     C                     KFLD           K#SHN2
     C                     KFLD           K#SHN3
      *
     C                     TIME           @SDATE
     C                     Z-ADDTGTYY     #YY
     C           TGTMM     SUB  1         #MM
      * SET TABLE
     C           1         DO   7         IX      20
     C           #MM       IFLE 6
     C                     ADD  1         #MM
     C                     ELSE
     C                     ADD  1         #YY
     C                     Z-ADD1         #MM
     C                     ENDIF
     C                     Z-ADD#YM       @YM,IX
     C                     ENDDO
      *
     C                     ENDSR
