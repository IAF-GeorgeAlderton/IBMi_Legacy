     H            Y
     F*AFAR65************************************************
     F* COMBINED PARTIAL CONTAINERS (PRINT BY PROCESS DATE) *
     F*                                                     *
     F*       I.HACHISUKA               2000.07.21          *
     F* TCHK1 10/08/09 BUG FIXED                            *
     F************************************************AFAR65*
     F*  *INKC = 1(CF03)
     F*  *INKE = 1(CF05)
     F*  *INKI = 1(CF09)
     F*  *INKL = 1(CF12)
     F*  *IN30 = 0(FIRST DISPLAY)     1(NOT FIRST)
     F*  *IN31 = 0(PART NUMBER INPUT) 1(NO PART NUMBER INPUT)
     F*  *IN32 = 0(ABS NUM INPUT)     1(NO ABS NUM INPUT)
     F*  *IN33 = 0(START/END DATE INPUT)  1(NO START/END DATE INPUT)
     F*  *IN90 = 1(NOT READ AFAPP60)
     F*  *IN91 = 1(NOT READ FCETL13)
     F*  *IN92 = 1(NOT READ FCEPL01)
     F**********************************************************
     FAFAPW65 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
     FFCETL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAFAPL62 IF  E           K        DISK
     F**********************************************************
TCHK1E*                   ERR     1   3 60
TCHK1E                    ERR     1   4 60
     E**********************************************************
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I* START DATE
     I            DS
     I                                        1   80DSSTRD
     I                                        1   40#STRY
     I                                        5   60#STRM
     I                                        7   80#STRD
     I* END DATE
     I            DS
     I                                        1   80DSENDD
     I                                        1   40#ENDY
     I                                        5   60#ENDM
     I                                        7   80#ENDD
     I* PART NUMBER
     I            DS
     I                                        1  12 DSPART
     I                                        1   5 #PAR1
     I                                        6  10 #PAR2
     I                                       11  12 #PAR3
     I****************************************************************
     C                     TIME           WTIME
     C* DEFINE KEY1 FIELD
     C           KEY2      KLIST
     C                     KFLD           DSZETI
     C*
     C           KEY3      KLIST
     C                     KFLD           #PAR1
     C                     KFLD           #PAR2
     C                     KFLD           #PAR3
     C*
     C           KEY4      KLIST
     C                     KFLD           DSZETI
     C                     KFLD           DSSTRD
     C* DEFINE USER PARAMETER
     C           *ENTRY    PLIST
     C                     PARM           RUSRP  10
     C* DEFINE P1 PARAMETER
     C           P1        PLIST
     C                     PARM           P10     1
     C                     PARM           DSZETI
     C                     PARM           WANLOT  30
     C                     PARM           RUSRP
     C                     PARM           P14     60
     C                     PARM           P15     60
     C*
     C                     MOVE 00000000  DSSTRD
     C                     MOVE 99999999  DSENDD
     C                     MOVE *BLANK    DSPART
TCHK1C*                    SETON                     72
TCHK1C*                    WRITESFLCTL
TCHK1C*                    SETOF                     72
     C*
     C           *INKC     DOWEQ'0'
     C           *IN30     IFEQ '0'
     C                     WRITEAFAPW651
     C                     EXFMTAFAPW652
     C                     SETOF                     99
     C                     MOVE *BLANK    @MSG
     C                     ELSE
     C* SECOND SCREEN
     C                     Z-ADD1         RRN
     C                     WRITEAFAPW699
     C                     WRITEAFAPW652
     C                     SETON                         70
     C                     EXFMTSFLCTL
     C                     SETOF                         70
     C                     END
     C           *INKE     IFEQ '1'
     C                     MOVE '1'       P10
     C                     Z-ADDDSSTRD    P14
     C                     Z-ADDDSENDD    P15
     C                     CALL 'AFAR63'  P1
     C                     ELSE
     C           *INKL     IFEQ '1'
     C                     MOVE *BLANK    DSPART
     C                     MOVE *BLANK    DSZETI
     C                     MOVE 00000000  DSSTRD
     C                     MOVE 99999999  DSENDD
TCHK1C*                    SETON                         72
TCHK1C*                    WRITESFLCTL
TCHK1C*                    SETOF                       3072
TCHK1C                     SETOF                       30
TCHK1C                     SETOF                     99
TCHK1C                     MOVE *BLANK    @MSG
     C                     ELSE
     C           *INKI     IFEQ '1'
     C*                    CALL 'AKAR37'
     C                     ELSE
     C           *INKC     IFEQ '1'
     C                     ELSE
     C                     EXSR @CHK1
     C  N99                EXSR @SFL
     C*
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
     C*
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*************************************************************
     C*    @CHK1
     C*************************************************************
     C           @CHK1     BEGSR
     C           DSPART    IFEQ *BLANK
     C           DSZETI    IFEQ *BLANK
     C                     SETON                     323199
     C                     MOVEAERR,2     @MSG
     C                     ELSE
     C           KEY2      CHAINFCETL11              91
     C           *IN91     IFEQ '1'
     C                     SETON                     3299
     C                     MOVEAERR,1     @MSG
     C                     END
     C                     END
     C                     ELSE
     C           KEY3      CHAINFCEPL01              92
     C           *IN92     IFEQ '1'
     C                     SETON                     3199
     C                     MOVEAERR,2     @MSG
     C                     ELSE
     C                     MOVE A2ZETI    DSZETI
     C                     END
     C                     END
     C*
     C*
     C           *IN99     IFEQ '1'
     C                     GOTO #CHK1
     C                     END
     C*
     C*
     C           DSSTRD    IFEQ *ZERO
     C                     ELSE
     C           #STRM     IFGE 1
     C           #STRM     ANDLE12
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C           #STRD     IFGE 1
     C           #STRD     ANDLE31
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C                     END
     C           DSENDD    IFEQ 99999999
     C                     ELSE
     C           #ENDM     IFGE 1
     C           #ENDM     ANDLE12
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C           #ENDD     IFGE 1
     C           #ENDD     ANDLE31
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C                     END
     C*
     C           #CHK1     ENDSR
     C*
     C**************************************************************
     C*  @SFL
     C**************************************************************
     C           @SFL      BEGSR
TCHK1C*
TCHK1C                     MOVEL*ON       *IN71
TCHK1C                     WRITESFLCTL
TCHK1C                     MOVEL*OFF      *IN71
     C                     MOVE *ZERO     RRN
     C           KEY4      SETLLAFAPL62
TCHK1C*
TCHK1C*          KEY2      READEAFAPL62                  90
TCHK1C*          AADATE    IFLE DSENDD
TCHK1C*          *IN90     DOUEQ'1'
TCHK1C*          AADATE    ORGT DSENDD
TCHK1C*                    ADD  1         RRN     40
TCHK1C*          RRN       CHAINSFL01                90
TCHK1C*
TCHK1C                     DO   *HIVAL
TCHK1C*
TCHK1C           KEY2      READEAFAPL62                  90
TCHK1C   90                LEAVE
TCHK1C           AASKJY    IFNE *BLANK
TCHK1C                     ITER
TCHK1C                     END
TCHK1C           AADATE    IFGT DSENDD
TCHK1C                     LEAVE
TCHK1C                     END
TCHK1C*
     C                     CLEARSFL01
     C                     MOVE AANLOT    @NLOT
     C                     MOVE AADATE    @UPDAY
     C                     MOVELAAKOME    @MEMB
     C                     MOVE AAKAN1    @KAN1
     C                     MOVE AAKAN2    @KAN2
     C                     MOVE AAKAN3    @KAN3
     C                     MOVE AALOT1    @LOT1
     C                     MOVE AALOT2    @LOT2
     C                     MOVE AALOT3    @LOT3
     C                     MOVE AAKAN4    @KAN4
     C                     MOVE AAKAN5    @KAN5
     C                     MOVE AAKAN6    @KAN6
     C                     MOVE AALOT4    @KAN4
     C                     MOVE AALOT5    @KAN5
     C                     MOVE AALOT6    @KAN6
     C                     Z-ADDAACOPY    @COPY
     C           AAUPFG    IFEQ '1'
     C                     MOVE 'S'       @SRPL
     C                     ELSE
     C                     MOVE *BLANK    @SRPL
     C                     ENDIF
      *
TCHK1C* N90                UPDATSFL01
TCHK1C*  90                WRITESFL01
TCHK1C*
TCHK1C*          KEY2      READEAFAPL62                  90
TCHK1C*
TCHK1C*                    END
TCHK1C*                    END
TCHK1C*
TCHK1C                     ADD  1         RRN
TCHK1C                     WRITESFL01
TCHK1C*
TCHK1C                     ENDDO
     C*
     C           RRN       IFNE *ZERO
     C                     SETON                     30
TCHK1C                     ELSE
TCHK1C                     MOVELERR,4     @MSG
TCHK1C                     MOVEL*ON       *IN99
     C                     END
     C*
     C                     ENDSR
     C*
     C**************************************************************
** ERROR MESSAGE
PART NUMBER IS NOT FOUND IN M/F.
ENTER ABSOLUTE NUMBER OR PART NUMBER
WRONG DATE ENTERED
NO FOUND TARGET DATA. CHECK INPUT DATA THEN TRY AGAIN.
