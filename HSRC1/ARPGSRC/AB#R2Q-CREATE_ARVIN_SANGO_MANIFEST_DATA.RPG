     H            Y.
      ** AB#R2Q***********************************************
      *  CREATE ARVIN SANGO MANIFEST DATA                    *
      *  K.KASHIWAGI     2001.03.13                          *
      *
      *  N.HYOTO         2001.06.26
      *  H.AMANO         2001.10.30
      *  H.AMANO         2001.11.07
      *       ORDER NUMBER 6 -> 10
      *  H.AMANO         2002.05.31
      *                     CLOSE PGM AFTER WRITE RECORDS
      *
      * TCHK1 12/13/07 BIG FIX
      ********************************* AB#R2Q ***************
     FAB#PW2Q CF  E                    WORKSTN
     FAB#PL08 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGADPL13 IF  E           K        DISK
     FAB#PP41 IF  E           K        DISK
     FEDIPL40 IF  E           K        DISK
     FAB#WP2S O   E                    DISK
     FAB#WP2R O   E                    DISK
      *
     E                    MSGTBL  1   9 60
     I           SDS
     I                                        1   8 @PGMID
     I            DS
     I                                        1   80DATE
     I                                        1   20W@CT
     I                                        3   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   8 DATEC
     I                                        1   2 MM
     I                                        3   3 SLS1
     I                                        4   5 DD
     I                                        6   6 SLS2
     I                                        7   8 YY
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     I            DS
     I                                        1  15 MHIN
     I                                        1   5 MHIN1
     I                                        6  10 MHIN2
     I                                       11  15 MHIN3
     I            DS
     I                                        1   80KSPDT
     I                                        1   40KSPYY
     I                                        5   60KSPMM
     I                                        7   80KSPDD
     I* ARVIN SANGO RECEIVED DATE
     I            DS
     I                                        1   80AVRVDT
     I                                        1   40AVRVYY
     I                                        5   60AVRVMM
     I                                        7   80AVRVDD
     I            DS
     I                                        1   80NYMD
     I                                        1   40NOYY
     I                                        5   60NOMM
     I                                        7   80NODD
     I            DS
     I                                        1   2 AVTRUC
     I                                        1   1 TRUC1
     I                                        2   2 TRUC2
     C*------------------------------------------------------
     C* KEY LIST
     C*------------------------------------------------------
     C           KEY1      KLIST
     C                     KFLD           KNONY   40
     C                     KFLD           KNKOJ   1
     C                     KFLD           KNUKE   4
     C                     KFLD           KNOYY   40
     C                     KFLD           KNOMM   20
     C                     KFLD           KNODD   20
     C                     KFLD           KNOBN   20
     C*
     C           KEY2      KLIST
     C                     KFLD           F8KAYY  40
     C                     KFLD           F8KAMM  20
     C                     KFLD           F8KADD  20
     C*
     C           KEY3      KLIST
     C                     KFLD           B5NONY  40
     C*
     C           KEY4      KLIST
     C                     KFLD           KSHN1   5
     C                     KFLD           KSHN2   5
     C                     KFLD           KSHN3   2
     C                     KFLD           KNONY   40
     C                     KFLD           KSPDT   80
     C*------------------------------------------------------
     C* PLIST
     C*------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PTEAM  10
      *--------------*
      * MAIN ROUTINE *
      *--------------*
     C                     EXSR @INTR
     C           W@ID      DOWNE'90'
     C           W@ID      CASEQ'01'      @DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *---------------*
      * INITIALIZATION
      *---------------*
     C           @INTR     BEGSR
     C                     MOVEL*BLANKS   @MSG1
     C                     MOVEL'01'      W@ID    2
     C                     TIME           #TIME
     C                     MOVE *DATE     DATE
     C                     Z-ADD2000      W@YY4   40
     C                     ADD  W@YY      W@YY4
     C                     Z-ADD0         NYMD
     C                     ENDSR
      *--------------*
      * FIRST SCREEN *
      *--------------*
     C           @DSP1     BEGSR
     C                     EXFMTAB#PW21
     C                     MOVEL*BLANKS   @MSG1
     C                     SETOF                     993031
     C                     SETOF                     323334
     C                     SETOF                     98
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'90'      W@ID
     C           *INKE     WHEQ '1'
     C                     EXSR @CHK1
     C           *IN99     IFEQ '0'
     C                     EXSR @PRT
     C                     EXFMTWIN01
     C                     MOVEL'90'      W@ID
     C                     ENDIF
     C                     OTHER
     C                     EXSR @CHK1
     C                     ENDSL
     C                     ENDSR
      *--------------*
      * CHECK1*
      *--------------*
     C           @CHK1     BEGSR
     C* DELIVERY CODE TEST
     C           NONY      IFLE 0
     C                     MOVEL'1'       *IN99
     C                     MOVEL'1'       *IN30
     C                     MOVELMSGTBL,1  @MSG1
     C                     ELSE
     C                     MOVE NONY      B5NONY
     C                     SETOF                     70
     C           KEY3      CHAINGADPL13              70
     C           *IN70     IFEQ '1'
     C                     MOVEL'1'       *IN99
     C                     MOVEL'1'       *IN30
     C                     MOVELMSGTBL,1  @MSG1
     C                     ENDIF
     C                     ENDIF
     C* FACTORY CODE TEST
     C           NKOJ      IFEQ *BLANK
     C                     MOVEL'1'       *IN31
     C           *IN99     IFEQ '0'
     C                     MOVEL'1'       *IN99
     C                     MOVELMSGTBL,2  @MSG1
     C                     ENDIF
     C                     ENDIF
     C* DOCK CODE TEST
     C           NUKE      IFLE *BLANK
     C                     MOVEL'1'       *IN32
     C           *IN99     IFEQ '0'
     C                     MOVEL'1'       *IN99
     C                     MOVELMSGTBL,3  @MSG1
     C                     ENDIF
     C                     ENDIF
     C* SHIPPING DATE TEST
     C                     Z-ADDNOYY      F8KAYY
     C                     Z-ADDNOMM      F8KAMM
     C                     Z-ADDNODD      F8KADD
     C                     SETOF                     60
     C           KEY2      CHAINAGDPL12              60
     C           *IN60     IFEQ '1'
     C                     MOVEL'1'       *IN33
     C           *IN99     IFEQ '0'
     C                     MOVEL'1'       *IN99
     C                     MOVELMSGTBL,4  @MSG1
     C                     ENDIF
     C                     ENDIF
     C* BIN TEST
     C           NOBN      IFLE 0
     C                     MOVEL'1'       *IN34
     C           *IN99     IFEQ '0'
     C                     MOVEL'1'       *IN99
     C                     MOVELMSGTBL,5  @MSG1
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
     C*--------------*
     C* PRINT PROCESS
     C*--------------*
     C           @PRT      BEGSR
     C                     Z-ADDNONY      KNONY
     C                     MOVELNKOJ      KNKOJ
     C                     MOVELNUKE      KNUKE
     C                     Z-ADDNOYY      KNOYY
     C                     Z-ADDNOMM      KNOMM
     C                     Z-ADDNODD      KNODD
     C                     Z-ADDNOBN      KNOBN
     C* READ FILE AB#PL08
     C           KEY1      SETLLAB#PP101
     C           KEY1      READEAB#PP101                 95
     C           *IN95     IFEQ '0'
     C                     MOVELBAINVN    MNMANI
     C                     Z-ADDBANOYY    MNNOYY
     C                     Z-ADDBANOMM    MNNOMM
     C                     Z-ADDBANODD    MNNODD
     C                     MOVE W@YY      YY
     C                     MOVE W@MM      MM
     C                     MOVE W@DD      DD
     C                     MOVEL'/'       SLS1
     C                     MOVEL'/'       SLS2
     C                     MOVE DATEC     MNDATE
     C*
     C** TRUCK NUMBER FROM AB#PP41
     C                     MOVELBASHN1    KSHN1
     C                     MOVELBASHN2    KSHN2
     C                     MOVELBASHN3    KSHN3
     C                     MOVELBANONY    KNONY
     C                     MOVELBANOYY    KSPYY
     C                     MOVELBANOMM    KSPMM
     C                     MOVELBANODD    KSPDD
     C           KEY4      SETLLAB#PP411
     C           *IN94     DOUEQ*ON
     C           KEY4      READEAB#PP411                 94
     C           *IN94     IFEQ *OFF
     C                     MOVELAVMAN#    @@16   16 P
     C           @@16      IFEQ BAINVN
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C*******    KEY4      CHAINAB#PP411             94
     C           *IN94     IFEQ '1'
     C                     SETON                     99
     C                     MOVELMSGTBL,8  @MSG1
     C                     ELSE
     C           TRUC2     IFEQ *BLANKS
     C                     MOVE TRUC1     MNTRUC
     C                     ELSE
     C                     MOVELAVTRUC    MNTRUC
     C                     ENDIF
     C*
     C                     MOVELBACARD    MNCARD
     C                     MOVELBASIRE    MNSIRE
     C                     MOVELBANUKE    MNNUKE
     C                     Z-ADDAVRVYY    MNRCYY
     C                     Z-ADDAVRVMM    MNRCMM
     C                     Z-ADDAVRVDD    MNRCDD
      *
     C                     MOVE NONY      @@NONY  4
     C           @@NONY    CHAINEDIPL40              91
     C           *IN91     IFEQ *OFF
     C                     MOVELE4ADD1    MNADR1
     C                     MOVELE4ADD2    MNADR2
     C                     MOVELE4ADD3    MNADR3
     C                     ENDIF
     C* WRITE HEADER RECORD
     C                     WRITEAB#WP2S1
     C           *IN95     DOWEQ'0'
     C           *IN95     IFEQ '1'
     C                     LEAVE
     C                     ENDIF
     C           BAINVN    IFNE MNMANI
     C                     MOVELBAINVN    MNMANI
     C                     WRITEAB#WP2S1
     C                     ENDIF
     C*
     C                     MOVELBAINVN    MDMANI
     C                     MOVELBAODRN    MDORDN
     C                     MOVELBASBAN    MDSBAN
     C                     MOVELBAMHN1    MHIN1
     C                     MOVELBAMHN2    MHIN2
     C                     MOVELBAMHN3    MHIN3
     C                     MOVELMHIN      MDPART
     C                     Z-ADDBASYOS    MDSYOS
     C                     Z-ADD0         REM     50       REMAINDER
TCHK1C*          BASRYO    DIV  BASYOS    MDNOKB
TCHK1C*                    MVR            REM     50
TCHK1C           BAUSYS    IFEQ *ZERO
TCHK1C           BASYOS    IFEQ *ZERO
TCHK1C                     Z-ADD1         MDNOKB
TCHK1C                     ELSE
TCHK1C           BASRYO    DIV  BASYOS    MDNOKB
TCHK1C                     MVR            REM     50
TCHK1C                     END
TCHK1C                     ELSE
TCHK1C           BASRYO    DIV  BAUSYS    MDNOKB
TCHK1C                     MVR            REM     50
TCHK1C                     END
      *
     C           REM       IFGT 0
     C                     ADD  1         MDNOKB
     C                     ENDIF
     C                     Z-ADDBASRYO    MDSRYO
     C                     Z-ADD0         MDMQTY
     C* DETAIL RECORD
     C                     WRITEAB#WP2R1
     C           KEY1      READEAB#PL08                  95
     C                     ENDDO
     C           *IN95     IFEQ '1'
     C                     CLEARAB#PW21
     C                     MOVELMSGTBL,9  @MSG1
     C                     SETON                         98
     C                     ENDIF
     C                     ENDIF
     C                     ELSE
     C                     MOVELMSGTBL,7  @MSG1
     C                     SETON                         98
     C                     ENDIF
     C*
     C                     ENDSR
** (MSGTBL)
E-01 INVALID DELIVERY CODE.
E-02 INVALID FACTORY CODE.
E-03 INVALID DOCK CODE.
E-04 INVALID SHIPPING DATE
E-05 INVALID BIN.
E-06 INVALID DOCK .
E-07 NO DATA.
E-08 TRUCK NUMBER CANNOT BE FOUND IN AB#PP41.
E-09 THE PROCESS IS FINISHED.
