     C***********************************************************
     C* #SFL:CREATE SUB FILE
     C***********************************************************
     C           #SFL      BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1
     C                     MOVE PNONY     WNONY
     C                     MOVE *OFF      *IN31
     C*
     C           KEY1      SETLLAB#PL131
     C           KEY1      READEAB#PL131                 93
     C           *IN93     DOWEQ'0'
     C                     MOVE *OFF      *IN61
     C*
     C* DELETED  ?
     C           BASKJY    IFNE ' '
     C                     GOTO #READ
     C                     END
     C*
     C* SAME BIN ?
     C           BIN       IFNE 0
     C           BIN       ANDNEBANOBN
     C                     GOTO #READ
     C                     END
      *
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     GOTO #READ
     C                     ENDIF
     C*
     C* IF SELECTED ORDER#, SAME ORDER# ?
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     GOTO #READ
     C                     END
     C*
     C* SET DATA TO SUB FILE
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                94
     C                     MOVE *BLANK    @FLAG
     C                     Z-ADD*ZERO     @#LAB
     C*
     C           BAMHN4    IFEQ *BLANK
     C                     MOVE *BLANK    @P3
     C                     MOVE *BLANK    WAMHN4
     C                     ELSE
     C                     MOVE BAMHN4    WAMHN4
     C                     MOVE '-'       @P3
     C                     END
     C*
     C           BAMHN3    IFEQ *BLANK
     C                     MOVE *BLANK    @P2
     C                     MOVE *BLANK    WAMHN3
     C                     ELSE
     C                     MOVE BAMHN3    WAMHN3
     C                     MOVE '-'       @P2
     C                     END
     C*
     C           BAMHN2    IFEQ *BLANK
     C                     MOVE *BLANK    @P1
     C                     MOVE *BLANK    WAMHN2
     C                     ELSE
     C                     MOVE BAMHN2    WAMHN2
     C                     MOVE '-'       @P1
     C                     END
     C*
     C                     MOVE BAMHN1    WAMHN1
     C*
     C                     MOVE BASBAN    @SBAN
     C                     MOVE BAODRN    @ODER
     C                     Z-ADDBASRYO    @RQTY
     C                     Z-ADDBASYOS    @SYOS
     C                     Z-ADDBAUSYS    @USYS
     C           BASYOS    IFNE BAUSYS
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN31
     C                     MOVELER,16     XMSG
     C                     ENDIF
     C   94                WRITESFL01
     C  N94                UPDATSFL01
     C*
     C           #READ     TAG
     C           KEY1      READEAB#PL131                 93
     C                     END
     C*
     C           RRN1      IFEQ *ZERO
     C                     SETON                     30
     C                     MOVELER,12     XMSG
     C                     MOVE '04'      XMSG
     C*
     C                     ELSE
     C                     MOVE '2'       WKDSP
     C                     Z-ADDRRN1      W1RRN
     C                     Z-ADD1         RRN1
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* WRITE LABEL DATA(SELECTED PART NUMBER)
     C***********************************************************
     C           #WRT2     BEGSR
     C*
     C                     SETON                     8887
     C* GET THE NUMBER OF LABEL
     C           PNONY     CHAINAB#PL90              96
     C           *IN96     IFEQ '0'
     C                     Z-ADDYA#LAB    W#LAB
     C                     Z-ADDYAMXPL    W@MXPL
     C                     ELSE
     C                     Z-ADD1         W#LAB
     C                     END
     C*
     C                     Z-ADD1         RRN1
     C                     DO   W1RRN
     C           RRN1      CHAINSFL01                94
     C           *IN94     IFEQ '0'
     C           @FLAG     IFNE *BLANK
     C           @#LAB     ORNE 0
     C*
     C                     MOVE PNONY     WNONY   40
     C                     MOVEL@ODER     WORDN  10
     C*
     C                     EXSR #8450
     C*
     C                     END
     C                     END
     C*
     C           XWRT2     TAG
     C                     ADD  1         RRN1
     C*
     C                     ENDDO
     C*
     C                     SETOF                     88
     C*
     C                     ENDSR
