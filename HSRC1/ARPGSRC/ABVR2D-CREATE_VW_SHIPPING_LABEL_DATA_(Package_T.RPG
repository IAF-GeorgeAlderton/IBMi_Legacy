     C***********************************************************
     C                     EXSR #INIT
     C*
     C                     EXSR #MAIN
      *
     C                     SETON                     LR
     C                     RETRN
     C***********************************************************
     C* #MAIN:CONTROL DISPLAY
     C***********************************************************
     C           #MAIN     BEGSR
     C* F3
     C           *INKC     DOWEQ'0'
     C*
     C                     SELEC
     C           WKDSP     WHEQ '0'
     C                     EXFMTABVPW2D0
      *
     C           WKDSP     WHEQ '1'
     C                     EXFMTABVPW2D2
     C*
     C                     OTHER
     C                     WRITEABVPW2D1
     C                     SETON                     70
     C                     EXFMTCTL01
     C                     SETOF                     70
     C                     ENDSL
     C* CLEAR MSG
     C                     MOVEAWKBLAK    *IN,30
     C                     SETOF                     87
     C* F3: END
     C           *INKC     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C*
     C                     SELEC
      * BARCODE
     C           WKDSP     WHEQ '0'
     C           *INKI     IFEQ *ON                        F9
     C                     CLEARABVPW2D2
     C                     MOVE '1'       WKDSP
     C                     ELSE
      *
     C                     EXSR #CHK0
     C           *IN30     IFEQ *OFF
     C           RRN2      ANDNE*ZERO
      *
     C                     DO   *HIVAL
     C                     MOVE CFK,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
     C           *INKC     WHEQ *ON                        F3
     C                     MOVE *ON       *INLR
     C                     RETRN
     C           *INKK     WHEQ *ON                        F11
     C                     LEAVE
     C                     ENDSL
     C                     ENDDO
     C                     ENDIF
      *
      * CHECK F5
     C           *IN30     IFEQ *OFF
     C           *INKE     ANDEQ*OFF
     C                     MOVE *ON       *IN30
     C                     MOVELER,11     XMSG
     C                     ITER
     C                     ENDIF
      *
     C           *IN30     IFEQ *OFF
     C                     EXSR #WRT1
     C           @@CNT     IFEQ *ZERO
     C                     MOVELER,12     XMSG
     C                     MOVE '01'      XMSG
     C                     MOVE *ON       *IN30
     C                     MOVE *OFF      *IN87
     C                     ELSE
     C                     EXSR #CLR0
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MANUAL ENTRY
     C           WKDSP     WHEQ '1'
      * F12
     C           *INKL     IFEQ *ON                        F12
     C                     MOVE '0'       WKDSP
     C                     MOVE *BLANK    XMSG
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CHK1
     C           *IN30     IFEQ *OFF
     C           *INKG     ANDEQ*OFF                       F7
     C           RRN2      ANDNE*ZERO
     C                     DO   *HIVAL
     C                     MOVE CFK,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVE *ON       *INLR
     C                     RETRN
      * F11
     C           *INKK     WHEQ *ON
     C                     LEAVE
     C                     ENDSL
     C                     ENDDO
     C                     ENDIF
      *
     C                     SELEC
     C           *INKE     WHEQ '1'                        F5
     C           *INKK     OREQ '1'                        F11
     C* CHECK OK?
     C           *IN30     IFEQ '0'
     C                     EXSR #WRT1
     C           @@CNT     IFEQ *ZERO
     C                     MOVELER,12     XMSG
     C                     MOVE '02'      XMSG
     C                     MOVE *ON       *IN30
     C                     MOVE *OFF      *IN87
     C                     ENDIF
     C                     END
      * F7
     C           *INKG     WHEQ '1'
     C           *IN30     IFEQ '0'
     C                     EXSR #SFL
     C                     END
     C* F12
     C           *INKL     WHEQ '1'
     C                     MOVE '0'       WKDSP
      *
     C                     ENDSL
     C*
     C* 2ND. SCREEN
     C                     OTHER
      *
     C                     SELEC
     C           *INKE     WHEQ '1'                        F5
     C           *INKG     OREQ '1'                        F7
     C                     EXSR #CHK2
     C* CHECK OK?
     C           *IN30     IFEQ '0'
     C                     EXSR #WRT2
     C                     EXSR #CLRS
     C                     END
      * F12
     C           *INKL     WHEQ '1'                        F12
     C                     EXSR #CLRS
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
     C*
     C                     ENDSL
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* #CHK0:CHECK BARCODE
     C***********************************************************
     C           #CHK0     BEGSR
     C*
     C**                   DO
     C**
     C**         D@PCKC    IFEQ '1'
     C**         D@PCKC    OREQ '2'
     C**                   ELSE
     C**                   SETON                     3032
     C**                   MOVELER,18     XMSG
     C**                   LEAVE
     C**                   END
     C* RESET SVBARC
     C           D@BARC    IFNE SVBARC
     C                     MOVE *BLANK    SVBARC
     C                     ENDIF
      *
     C           D@BARC    IFEQ *BLANK
     C                     SETON                     3031
     C                     MOVELER,7      XMSG
     C                     GOTO XCHK0
     C                     ENDIF
      *
     C           D@BARC    CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     SETON                     3031
     C                     MOVELER,15     XMSG
     C                     GOTO XCHK0
     C                     END
      *
     C           PUNONY    IFNE 8450
     C                     SETON                     3031
     C                     MOVELER,17     XMSG
     C                     GOTO XCHK0
     C                     END
      * ALREADY PRINTED
     C           PULPDT    IFNE 0
     C           PUSERL    ANDNESVBARC
      *
JW1  C                     DO   *HIVAL
 |   C                     MOVEL*OFF      *INKJ
 |   C                     MOVEL*OFF      *INKL
 |   C                     Z-ADDPULPDT    WINDT
 |   C                     EXFMTWIN01
 |   C           *INKL     IFEQ *ON                        F12 CANCEL
 |   C                     SETON                     3031
 |   C                     MOVELER,19     XMSG
 |   C                     MOVE PULPDT    XMSG
 |   C                     LEAVE
 |   C                     ENDIF
 |   C           *INKJ     IFEQ *ON                        F10 CONTINUE
     C                     MOVELD@BARC    SVBARC
 |   C                     Z-ADD0         PULPDT
 |   C                     LEAVE
 |   C                     ENDIF
JW1  C                     ENDDO
     C                     ENDIF
      * GET ORDERED BOX
     C                     EXSR #GETBX
     C                     Z-ADD#BOX      D@OBOX
     C           #BOX      IFEQ 0
     C                     SETON                     3031
     C                     MOVELER,12     XMSG
     C                     MOVE '03'      XMSG
     C                     GOTO XCHK0
     C                     ENDIF
      *
     C           D@RBOX    IFEQ 0
     C           D@EBOX    ANDEQ0
     C                     SETON                     3041
     C                     MOVELER,9      XMSG
     C                     GOTO XCHK0
     C                     ENDIF
      *
     C           D@RBOX    ADD  D@EBOX    D@TBOX
     C           D@TBOX    IFNE D@OBOX
     C                     SETON                     3041
     C                     MOVELER,10     XMSG
     C                     MOVE '01'      XMSG
     C                     GOTO XCHK0
     C                     ENDIF
      * IF NO ERROR...
JW6  C                     Z-ADD0         @ECNT   40
JW6  C                     Z-ADD0         @7CNT   40
     C                     MOVELPUNONY    PNONY
     C                     MOVELPUNKOJ    PNKOJ
     C                     MOVELPUNUKE    PNUKE
     C                     Z-ADDPUBINN    BIN
     C                     Z-ADDPUDAT     PNOHZ
     C                     MOVELPUODRN    PORD#
     C                     MOVE PNONY     WNONY   40
     C                     EXSR #SYSCH
      *
     C           XCHK0     ENDSR
     C***********************************************************
     C* GET QTY TO BE SHIPPED
     C***********************************************************
     C           #GETBX    BEGSR
      *
     C                     Z-ADD0         #BOX    40
     C           K#PL1A    KLIST
     C                     KFLD           KKNOHZ  80
     C                     KFLD           KKNOBN  20
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKODRN 10
     C*
     C                     MOVELPUDAT     KKNOHZ
     C                     MOVELPUBINN    KKNOBN
     C                     MOVELPUNONY    KKNONY
     C                     MOVELPUNKOJ    KKNKOJ
     C                     MOVELPUNUKE    KKNUKE
     C                     MOVELPUODRN    KKODRN
     C           K#PL1A    SETLLAB#PL1A
     C                     DO   *HIVAL
     C           K#PL1A    READEAB#PL1A                  97
     C   97                LEAVE
      *
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           BASRYO    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C           BASYOS    IFNE 0
     C                     Z-ADDBASYOS    @QPC    60
     C                     ELSE
     C           BAUSYS    IFNE 0
     C                     Z-ADDBAUSYS    @QPC
     C                     ELSE
     C                     Z-ADDBASRYO    @QPC
     C                     ENDIF
     C                     ENDIF
      *
     C           BASRYO    DIV  @QPC      SHO     60
     C                     MVR            RMT     60
     C           RMT       IFNE 0
     C                     ADD  1         SHO
     C                     ENDIF
      *
     C                     ADD  SHO       #BOX
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* QTY/BOX CHECK
     C***********************************************************
     C           #SYSCH    BEGSR
      *
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
      *
     C                     Z-ADD*ZERO     @ITM    30
     C                     MOVE *OFF      *IN93
      *
     C           KEY1      SETLLAB#PL13
     C           *IN93     DOUEQ*ON
     C           KEY1      READEAB#PL131                 93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C           BIN       IFNE *ZERO
     C           BANOBN    ANDNEBIN
     C                     ITER
     C                     ENDIF
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         @ITM
      *
     C           BASYOS    IFEQ *ZERO
     C                     MOVE BATOKU    PTOKU
     C                     MOVE BANONY    PNONY
     C                     MOVE *BLANK    @SHIN
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           BANKOJ
     C                     PARM           BANUKE  4
     C                     PARM           WMHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG    1
     C                     MOVE @SHN1     BASHN1
     C                     MOVE @SHN2     BASHN2
     C                     MOVE @SHN3     BASHN3
     C           KEY2      CHAINFCEPL011             91
     C           *IN91     IFEQ *OFF
     C                     Z-ADDA2SSYS    BASYOS
     C                     ENDIF
     C                     ENDIF
      *
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@BOX   50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVE INF,2     S@MSG
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDIF
      *
     C           BAUSYS    IFNE BASYOS
     C           BAUSYS    ANDNE*ZERO
     C           BASYOS    ANDNE*ZERO
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVE INF,1     S@MSG
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* #CLR :CLR SCREEN
     C***********************************************************
     C           #CLR0     BEGSR
     C*
     C                     MOVEL*BLANK    D@BARC
     C**                   MOVEL*BLANK    D@PCKC
      *
     C                     ENDSR
     C***********************************************************
     C* CHECK ITEMS ON 1ST. SCREEN
     C***********************************************************
     C           #CHK1     BEGSR
     C*
     C* DELIVERY CODE BLANK ?
     C           PNONY     IFEQ *BLANK
     C                     SETON                     3031
     C                     MOVELER,1      XMSG
     C                     GOTO XCHK1
     C                     END
     C           PNONY     IFNE '8450'
     C                     SETON                     3031
     C                     MOVELER,17     XMSG
     C                     GOTO XCHK1
     C                     END
     C*
     C* FACTORY CODE BLANK ?
     C           PNKOJ     IFEQ *BLANK
     C                     SETON                     3032
     C                     MOVELER,2      XMSG
     C                     GOTO XCHK1
     C                     END
     C*
     C* DOCK CODE BLANK ?
     C           PNUKE     IFEQ *BLANK
     C                     SETON                     3033
     C                     MOVELER,3      XMSG
     C                     GOTO XCHK1
     C                     END
     C*
     C* SHIPPING DATE
     C           PNOHZ     IFEQ 0
     C                     SETON                     3034
     C                     MOVELER,4      XMSG
     C                     GOTO XCHK1
     C                     END
JW6   * VALIDATE DATE
     C                     MOVELPNOHZ     $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTNX   1
     C           $RTNX     IFNE *BLANK
     C                     SETON                     3034
     C                     MOVELER,5      XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C**
     C**
     C**         PPCKC     IFEQ '1'
     C**         PPCKC     OREQ '2'
     C**                   ELSE
     C**                   SETON                     3037
     C**                   MOVELER,18     XMSG
     C**                   GOTO XCHK1
     C**                   END
     C*
     C* BIN       *
     C           BIN       IFEQ 0
     C                     SETON                     3035
     C                     MOVELER,6      XMSG
     C                     GOTO XCHK1
     C                     END
     C* ORDER#    *
     C           PORD#     IFEQ *BLANK
     C                     SETON                     3036
     C                     MOVELER,14     XMSG
     C                     GOTO XCHK1
     C                     END
      *
     C                     MOVE PNONY     WNONY   40
     C                     EXSR #SYSCH
     C           RRN2      IFNE 0
     C                     SETON                     30
     C                     GOTO XCHK1
     C                     END
      *
     C                     Z-ADD@@BOX     D@OBOX
     C           D@RBOX    ADD  D@EBOX    D@TBOX
      * CHECK TOTAL BOX
     C           D@OBOX    IFNE D@TBOX
     C                     SETON                     3037
     C                     MOVELER,10     XMSG
     C                     MOVE '02'      XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * IF NO ERROR...
     C                     MOVELER,11     XMSG
      *
     C           XCHK1     ENDSR
     C***********************************************************
     C* #CHK2:CHECK SFL
     C***********************************************************
     C           #CHK2     BEGSR
     C*
     C                     SETOF                     89
     C                     SETOF                     31
     C                     Z-ADD1         RRN1
     C                     DO   W1RRN
     C           RRN1      CHAINSFL01                94
     C*
     C           *IN94     IFEQ '0'
     C           @FLAG     IFNE *BLANK
     C           @#LAB     ORNE *ZERO
     C                     SETON                     89
     C                     END
     C           @USYS     IFNE @SYOS
     C                     MOVE *ON       *IN61
     C                     MOVELER,16     XMSG
     C                     MOVE *ON       *IN31
     C                     ELSE
     C                     MOVE *OFF      *IN61
     C                     ENDIF
     C                     UPDATSFL01
     C                     END
     C*
     C* NOT USE # OF LABELS
     C                     ADD  1         RRN1
     C                     ENDDO
     C*
     C           *IN89     IFEQ '0'
