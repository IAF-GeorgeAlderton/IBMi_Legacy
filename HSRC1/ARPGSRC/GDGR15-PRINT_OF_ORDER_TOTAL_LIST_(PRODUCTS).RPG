     C                     SETON                     10
     C                     TIME           @@TIME
TCHK2C                     TIME           WSDT
     C                     EXCPTHD
E0   C                     END
     C*
B0   C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     GOTO @END
E0   C                     END
     C*
     C                     MOVE *BLANK    @LOC1   1
     C                     MOVE *BLANK    @LOC2   2
     C                     MOVE *BLANK    @LOC3   2
     C                     MOVE *BLANK    @LOC4   1
     C                     Z-ADD*ZERO     @BOX5
     C                     Z-ADD*ZERO     @ABOX5  72
     C                     Z-ADD*ZERO     @SHQY  110
     C*
B0   C                     SELEC
     C           IBSEIH    WHEQ '0'
     C           K#KEY     SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAAPTL01                  90
     C           *IN90     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STHZ    ANDEQ*ALL'9'
     C                     MOVE L5TKR1    @LOC1   1
     C                     MOVE L5TKR2    @LOC2   2
     C                     MOVE L5TKR3    @LOC3   2
     C                     MOVE L5TKR4    @LOC4   1
TCHK1C*
TCHK1C                     EXSR #SETT
TCHK1C           W@SYS     IFNE *ZERO
TCHK1C           W@W#01    MULT 5         @@BOX  110
TCHK1C           @@BOX     DIV  W@SYS     @BOX5   72
TCHK1C           W@W#01    DIV  W@SYS     @DBOX   50H
TCHK1C                     ELSE
TCHK1C           L5SYOS    IFNE *ZERO
TCHK1C           L5KTSU    MULT 5         @@BOX
TCHK1C           @@BOX     DIV  L5SYOS    @BOX5
TCHK1C           L5KSSU    DIV  L5SYOS    @DBOX   50H
TCHK1C                     ENDIF
TCHK1C                     END
