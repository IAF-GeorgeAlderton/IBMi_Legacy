     C                     MOVE G9KN11    @PRT1
     C                     MOVE G9KN12    @PRT2
     C                     MOVE G9KN13    @PRT3
     C           @PRT2     IFNE *BLANK
     C                     MOVE '-'       @H1
     C                     ENDIF
     C           @PRT3     IFNE *BLANK
     C                     MOVE '-'       @H2
     C                     ENDIF
      *
     C                     MOVEL@PART     COMPT1
     C                     Z-ADDG9TNK1    COMPR1
      *
     C                     MOVE *BLANK    @H1
     C                     MOVE *BLANK    @H2
     C                     MOVE G9KN21    @PRT1
     C                     MOVE G9KN22    @PRT2
     C                     MOVE G9KN23    @PRT3
     C           @PRT2     IFNE *BLANK
     C                     MOVE '-'       @H1
     C                     ENDIF
     C           @PRT3     IFNE *BLANK
     C                     MOVE '-'       @H2
     C                     ENDIF
      *
     C                     MOVEL@PART     COMPT2
     C                     Z-ADDG9TNK2    COMPR2
