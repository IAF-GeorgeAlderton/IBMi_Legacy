     C           G9RKB1    IFNE *BLANK
     C           G9RRI1    IFNE 0
     C           G9RRI1    DIV  100       WW      43
     C           1         SUB  WW        WI      43
     C           G9STAN    DIV  WI        WR      74H
     C           WR        SUB  G9STAN    G9RKN1
     C                     ELSE
     C                     Z-ADDG9RKI1    G9RKN1
