     H            Y.
     F** MFARS1 ********************************************
     F*  FACILITY MANAGEMENT M/F INQ                     *
     F*  T.SAKASHITA                        2014.08.05     *
     F* -------------------------------------------------- *
     F*  JW1   2025.12.02 ADD F7: DOWNLOAD                 *
     F******************************************** BTMRC1 **
     FMFAPWS1 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FMFAPL25 IF  E           K        DISK
      ******************************************************
     E                    MSG     1  20 60
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     C*===============================================================
      * MAIN ROUTINE
     C*===============================================================
     C                     EXSR #INIT
      *
     C           @STEP     IFEQ '#DSP1'
     C                     EXSR #DSP1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
      * FIRST SCREEN
     C*===============================================================
     C           #DSP1     BEGSR
      *
     C                     DO   *HIVAL
      *
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *
      * F3: BACK
     C           *INKC     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE *BLANK    P@SYS1
     C                     MOVE *BLANK    P@SYS2
     C                     LEAVE
     C                     ENDIF
JW1   * F7: DOWNLOAD
 .   C           *INKG     IFEQ *ON
 .   C                     CALL 'MFACS2'
     C                     PARM           P@KBN1
     C                     PARM           P@KGUN
     C                     PARM           P@COS1
     C                     PARM           P@COS2
     C                     PARM           P@COS3
     C                     PARM           P@SYS1
     C                     PARM           P@SYS2
 .   C                     LEAVE
JW1  C                     ENDIF
      *
      * CHECK SELECTION
     C                     Z-ADD0         @X      40
     C                     Z-ADD0         @CNT    40
     C                     DO   *HIVAL
     C                     ADD  1         @X
     C           @X        CHAINSFREC1               77
     C   77                LEAVE
      *
     C           S1SELC    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE M@SYS1    P@SYS1
     C                     MOVE M@SYS2    P@SYS2
     C                     ADD  1         @CNT
     C                     ENDDO
      *
     C           @CNT      IFGE 2
     C                     MOVE *BLANK    P@SYS1
     C                     MOVE *BLANK    P@SYS2
     C                     SETON                     99
     C                     MOVELMSG,01    @ERR
     C                     ITER
     C                     END
      *
     C           @CNT      IFEQ 1
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*===============================================================
     C* INITIAL SETTINGS
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@KBN1  3
     C                     PARM           P@KGUN  3
     C                     PARM           P@COS1  2
     C                     PARM           P@COS2  2
     C                     PARM           P@COS3  2
     C                     PARM           P@SYS1  4
     C                     PARM           P@SYS2  4
     C*
     C                     MOVEA*ALL'0'   *IN
     C* CLEAR SUB FILE
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
      *
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
      *
     C                     DO   *HIVAL
     C                     READ MFAPL25                  88
     C   88                LEAVE
      *
     C           P@KBN1    IFNE *BLANK
     C           P@KBN1    ANDNEM@KBN1
     C                     ITER
     C                     END
      *
     C           P@KGUN    IFNE *BLANK
     C           P@KGUN    ANDNEM@KGUN
     C                     ITER
     C                     END
      *
     C           P@COS1    IFNE *BLANK
     C           P@COS1    ANDNEM@COS1
     C                     ITER
     C                     END
      *
     C           P@COS2    IFNE *BLANK
     C           P@COS2    ANDNEM@COS2
     C                     ITER
     C                     END
      *
     C           P@COS3    IFNE *BLANK
     C           P@COS3    ANDNEM@COS3
     C                     ITER
     C                     END
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C*
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP   8
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
      *
     C                     ENDSR
**  MSG (60A) .....2.........3.........4.........5.........6
SELECT 1 LINE !
