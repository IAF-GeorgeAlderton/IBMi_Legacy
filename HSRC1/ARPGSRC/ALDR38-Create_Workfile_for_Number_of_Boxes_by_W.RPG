     H            Y.
      ** ALDR38 ********************************************************
      *  THE NUMBER OF PROCESSED BOXES BY WORKER INQUIRY WORKFILE      *
      *      FOR INTO LOCATION SCAN.                                   *
      *  LEC          2019/09/27                                       *
      ********************************************  ALDR19 *************
     FALDPL35CIF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FALDWP38 O   E                    DISK
     I******************************************************************
     I            DS
     I                                        1  120A9DATM
     I                                        1   80A9KODT
     I                                        9  140A9KOTM
     I            DS
     I                                        1   80D5DATE
     I                                        1   40D5YYYY
     I                                        5   60D5MMMM
     I                                        7   80D5DDDD
     I            DS
     I                                        1   80WWDATE
     I                                        1   40WWYY
     I                                        5   60WWMM
     I                                        7   80WWDD
     I            DS
     I                                        1   80KKDATE
     I                                        1   40KYYYY
     I                                        5   60KMMMM
     I                                        7   80KDDDD
      *
     I            DS
     I                                        1  120X1DATI
     I                                        1   40X1KSYY
     I                                        5   60X1KSMM
     I                                        7   80X1KSDD
     I                                        9  120X1TIM
      *
     I            DS
     I                                        1  120X2DATI
     I                                        1   80X2DAT
     I                                        1   40X2KSYY
     I                                        5   60X2KSMM
     I                                        7   80X2KSDD
     I                                        9  120X2TIM
      *
     C           *ENTRY    PLIST
     C                     PARM           PYYYY   40
     C                     PARM           PMMMM   20
     C                     PARM           PDDDD   20
     C                     PARM           P1TIM1  40
     C                     PARM           P1YY2   40
     C                     PARM           P1MM2   20
     C                     PARM           P1DD2   20
     C                     PARM           P1TIM2  40
      *
      **************************************************************************
      *     M A I N L I N E
      *
     C                     EXSR @INT
     C                     EXSR @MAIN
      *
     C                     SETON                     LR
     C                     RETRN
      **************************************************************************
      * Initialization
      *
     C           @INT      BEGSR
      *
      * ALDPP35
     C           K1        KLIST
     C                     KFLD           KKDATE
      *
     C           K2        KLIST
     C                     KFLD           K21     60
      *
     C                     Z-ADDPYYYY     WWYY
     C                     Z-ADDPMMMM     WWMM
     C                     Z-ADDPDDDD     WWDD
      *
     C                     Z-ADDPYYYY     KYYYY
     C                     Z-ADDPMMMM     KMMMM
     C                     Z-ADDPDDDD     KDDDD
      *
     C                     Z-ADD0         X1DATI
     C                     Z-ADD0         X2DATI
     C                     Z-ADDPYYYY     X1KSYY
     C                     Z-ADDPMMMM     X1KSMM
     C                     Z-ADDPDDDD     X1KSDD
     C                     Z-ADDP1TIM1    X1TIM
     C                     Z-ADDP1YY2     X2KSYY
     C                     Z-ADDP1MM2     X2KSMM
     C                     Z-ADDP1DD2     X2KSDD
     C                     Z-ADDP1TIM2    X2TIM
      *
     C           X2DAT     IFEQ *ZERO
     C                     Z-ADD99999999  X2DAT
     C                     ENDIF
      *
     C           X2TIM     IFEQ *ZERO
     C                     Z-ADD2359      X2TIM
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *  Main Subroutine
      *
     C           @MAIN     BEGSR
      *
     C                     SETON                     80
      *
     C           K1        SETLLALDPL35C
     C                     READ ALDPL35C                 90
      *
     C           *IN90     DOWEQ*OFF
      *
     C           A9DATM    IFGT X2DATI
     C                     GOTO @SKP1
     C                     ENDIF
      *
     C           A9DATM    IFLT X1DATI
     C                     GOTO @SKP1
     C                     ENDIF
      *
      * FIRST RECORD
     C           *IN80     IFEQ *ON
     C                     SETOF                     80
     C                     MOVELA9WOKR    D5OPER
     C                     MOVELA9WOKR    K21
      *
     C           K2        CHAINALBPL30              93
     C           *IN93     IFEQ *OFF
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
     C                     ENDIF
      *
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
      *
     C                     ELSE
     C           A9WOKR    IFNE D5OPER
     C                     WRITEALDWP381
     C                     CLEARALDWP381
     C                     MOVELA9WOKR    D5OPER
     C                     MOVELA9WOKR    K21
     C           K2        CHAINALBPL30              93
     C           *IN93     IFEQ *OFF
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
     C                     ENDIF
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
     C                     ADD  1         D5BOX
     C                     ENDIF
     C                     ENDIF
      *
     C           @SKP1     TAG
     C                     READ ALDPL35C                 90
     C                     ENDDO
      *
     C  N80                WRITEALDWP381
     C  N80                CLEARALDWP381
      *
     C                     ENDSR
      **************************************************************************
