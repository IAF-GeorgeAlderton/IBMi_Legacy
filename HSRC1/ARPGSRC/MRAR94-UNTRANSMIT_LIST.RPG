     H            Y.
     F** MRAR94 *********************************************
     F* UNTRANSMIT LIST                                     *
     F*      TRANCOM-ITS.        2012.09.18                 *
     F*******************************************************
     FMRAWP91 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FMRAPL11 UF  E           K        DISK
      *
     I            DS
     I                                        1   80MASKHZ
     I                                        1   40MASKYY
     I                                        5   60MASKMM
     I                                        7   80MASKDD
      *
     I            DS
     I                                        1   80MASAHZ
     I                                        1   40MASAYY
     I                                        5   60MASAMM
     I                                        7   80MASADD
      *
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     C           KEYF81    KLIST
     C                     KFLD           #KYY    40
     C                     KFLD           #KMM    20
     C                     KFLD           #KDD    20
     C                     Z-ADD*YEAR     #KYY
     C                     Z-ADDUMONTH    #KMM
     C                     Z-ADDUDAY      #KDD
     C                     Z-ADD1         X       20
     C                     Z-ADD*DATE     WKKAHZ  80
     C           KEYF81    SETLLAGDPL121
     C                     READPAGDPL121                 80
     C           *IN80     DOWEQ'0'
     C           X         ANDLE10
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KAHZ    WKKAHZ
     C                     ADD  1         X
     C                     ENDIF
     C                     READPAGDPL121                 80
     C                     ENDDO
      *
     C                     READ MRAWP911                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB40A
     C                     READ MRAWP911                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB40A    BEGSR
      *
     C           KEYMA1    KLIST
     C                     KFLD           W1KENO
     C                     KFLD           W1KENA
     C           KEYMA1    SETGTMRAPL111
     C           KEYMA1    REDPEMRAPL111                 80
     C           *IN80     DOWEQ'0'
     C           MASKJY    IFEQ 'D'
     C           MASKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C           KEYMA1    REDPEMRAPL111                 80
     C                     ENDDO
      *
     CSR         ESB40A    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SELEC
     C           MASTAT    WHEQ '01'
     C                     EXSR #SB401
     C           MASTAT    WHEQ '03'
     C                     EXSR #SB403
     C                     OTHER
     C                     ENDSL
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB401    BEGSR
      *
     C           MALIDT    IFNE 0
     C                     GOTO ESB401
     C                     ENDIF
      *
     C           MASAHZ    IFGT WKKAHZ
     C                     GOTO ESB401
     C                     ENDIF
      *
     C                     Z-ADD*DATE     MALIDT
     C                     TIME           MALITI
     C                     UPDATMRAPL111
      *
     CSR         ESB401    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB403    BEGSR
      *
     C           MALIDT    IFNE 0
     C                     GOTO ESB403
     C                     ENDIF
      *
     C           MASBDT    IFGT WKKAHZ
     C                     GOTO ESB403
     C                     ENDIF
      *
     C                     Z-ADD*DATE     MALIDT
     C                     TIME           MALITI
     C                     UPDATMRAPL111
      *
     CSR         ESB403    ENDSR
