     F********************************** EADR22 **
     FEADWP22 IP  F     100            DISK
     FEADWP23 O   F     100            DISK
     IEADWP22 NS  01
     I                                        1   5 @HIN1 L1
     I                                        6  10 @HIN2 L1
     I                                       11  12 @HIN3 L1
     I                                       13  160@SRY
     I                                       17  240@STHZ
     I                                       25  320@ENHZ
     C******************************************************
     C*  START PROGRAM  <EADR22>                           *
     C******************************************************
     C  N01                GOTO @END
     C*
     C           *IN,90    IFEQ '0'
     C                     Z-ADD0         WSRY    40
     C                     MOVEA'1'       *IN,90
     C                     END
     C*
     C                     ADD  @SRY      WSRY
     C*
     C           @END      TAG
     C*
     CL1                   EXSR #WRT
     C******************************************************
     C           #WRT      BEGSR                           *
     C******************************************************
     C                     MOVE *BLANK    #HIN1   5
     C                     MOVE *BLANK    #HIN2   5
     C                     MOVE *BLANK    #HIN3   2
     C                     Z-ADD0         #SRY    40
     C                     Z-ADD0         #STHZ   80
     C                     Z-ADD0         #ENHZ   80
     C*
     C                     MOVEL@HIN1     #HIN1
     C                     MOVEL@HIN2     #HIN2
     C                     MOVEL@HIN3     #HIN3
     C                     ADD  WSRY      #SRY
     C                     Z-ADD@STHZ     #STHZ
     C                     Z-ADD@ENHZ     #ENHZ
     C                     SETON                     U2
     C                     EXCPTF01
     C*
     C                     Z-ADD0         WSRY
     C                     ENDSR
     C*
     C*
     C*
     OEADWP23 E                F01
     O                         #HIN1      5
     O                         #HIN2     10
     O                         #HIN3     12
     O                         #SRY      16
     O                         #STHZ     24
     O                         #ENHZ     32
