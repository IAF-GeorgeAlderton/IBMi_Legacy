     H            Y.                                    1
     F** AAMR801 *************************************
     F*  CREATE KANBAN RECICLE DAY DATA (ENGLISH)    *
     F*  JW     2025.02.10                           *
     F************************************************
     FAAMPW801CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     E                    ER      1  19 65
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I              '0123456789'          C         WKCKSU
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C           DSPSW     DOUEQ'99'
     C                     EXSR #MAIN
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  DISPLAY 1ST SCREEN
      *----------------------------------------------------*
     C           #MAIN     BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     3799
     C                     MOVEL*BLANK    @ERR
      * F1: END
     C           *IN01     IFEQ '1'
     C                     MOVE '01'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO XMAIN
     C                     ENDIF
      *
     C           D1BMON    IFNE *BLANK
     C           WKCKSU    CHECKD1BMON                   90
     C           *IN90     IFEQ '1'
     C                     MOVELER,4      @ERR
     C                     SETON                     3199
     C                     GOTO XMAIN
     C                     ENDIF
      *
     C                     MOVE D1BMON    CODE    40
     C           CODE      CHAINFGBPL011             21
     C           *IN21     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C                     MOVELER,5      @ERR
     C                     SETON                     3199
     C                     GOTO XMAIN
     C                     ENDIF
     C                     ENDIF
      *
     C           D1OUT     IFEQ '1'
     C           D1OUT     OREQ '2'
     C           D1OUT     OREQ '3'
     C                     ELSE
     C                     MOVELER,3      @ERR
     C                     SETON                     3799
     C                     GOTO XMAIN
     C                     ENDIF
      * IF NO ERROR...
     C           *IN05     IFEQ '0'
     C                     MOVELER,1      @ERR
     C                     SETON                       99
     C                     GOTO XMAIN
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     MOVELD1BMON    PBMON
     C                     MOVEL*BLANK    PKOTE
     C                     MOVEL*BLANK    PK1F
     C                     MOVEL*BLANK    PK1T
     C                     MOVEL*BLANK    PT1F
     C                     MOVEL*BLANK    PT1T
     C                     MOVELD1OUT     POUT
     C                     MOVEL'05'      PCMD
     C                     ENDIF
      *
     C           XMAIN     ENDSR
      *----------------------------------------------------*
      *   INITIAL SETTING
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
     C                     MOVEL*BLANK    PBMON
     C                     MOVEL*BLANK    PKOTE
     C                     MOVEL*BLANK    PK1F
     C                     MOVEL*BLANK    PK1T
     C                     MOVEL*BLANK    PT1F
     C                     MOVEL*BLANK    PT1T
     C                     MOVEL*BLANK    POUT
     C                     MOVEL*BLANK    PCMD
     C                     MOVEL*BLANK    D1BMON
      *
     C                     ENDSR
** ER(65)..........2.........3.........4.........5.........6....>
ER-01 PRESS F5 TO CREATE DATA...
ER-02
ER-03 SELECT 1, 2 OR 3 !
ER-04 ENTER 4 NUMBERS !
ER-05 DEPT NOT FOUND IN THE MASTER !
ER-06
ER-07
