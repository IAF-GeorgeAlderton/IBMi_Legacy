     C                     ADD  BIN,13    GKIO    30
      ************************************************************
      * 制御                                           MAIN    *
      ************************************************************
     CL1                   EXSR SUB1
     CL1                   EXCPTME1
     CL2                   EXCPTME2
      *----------------------------------------------------------*
      * 出荷箱数                                       SUB-1   *
      *----------------------------------------------------------*
     C           SUB1      BEGSR
     C                     Z-ADD0         MAIS    60
     C                     SETOF                     30
     C           KEY1      SETLLAH#NP121
      *
     C                     DO   *HIVAL
     C           KEY1      READEAH#NP121                 30
     C           *IN30     IFEQ '0'
     C                     ADD  AHHAKO    GKIP    60
     C                     ADD  AHHAKO    GKI16   60
     C                     END
     C  N30                END
      *
     C                     ENDSR
