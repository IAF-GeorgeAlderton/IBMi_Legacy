      * PARM *
     C           *ENTRY    PLIST
     C                     PARM           US     10
      * KEY *
     C           KEY1      KLIST
     C                     KFLD           CFBMON
     C                     KFLD           MNYY
     C                     KFLD           MNMM
     C                     KFLD           MNDD
      ************************************************************
      * 初期設定                                       MAIN    *
      ************************************************************
     C           *IN01     IFEQ '0'
     C                     TIME           WTIME   60
     C                     SETOF                     30
     C           US        CHAINRGAPL111             30
     C           *IN30     IFEQ '0'
     C                     MOVELJ8NAME    USR     9
     C                     ELSE
     C                     MOVE *BLANK    USR
     C                     END
     C                     SETON                     01
     C                     END
      ************************************************************
      * 部門コード                                     MAIN    *
      ************************************************************
     C           *INL2     IFEQ '1'
     C                     Z-ADD0         PAGE
     C           CFBMON    CHAINFGBPL011             55
     C           *IN55     IFEQ '0'
     C                     MOVELB2SMEI    KABMON 16
     C                     ELSE
     C                     MOVE *BLANK    KABMON
     C                     END
     C                     EXCPTHD
     C                     END
      ************************************************************
      * 計算                                           MAIN    *
      ************************************************************
     C                     ADD  HINGOK    GKI1    50
     C                     ADD  HAKGOK    GKI2    60
     C                     ADD  BIN,1     GKI3    50
     C                     ADD  BIN,2     GKI4    50
