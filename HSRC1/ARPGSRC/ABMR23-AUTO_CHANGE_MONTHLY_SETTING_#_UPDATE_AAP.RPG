     C                     Z-ADD@3DUPH    L5DUPH
     C                     Z-ADD0         L5AMXH
     C                     ADD  L5KAIH    L5AMXH
     C                     ADD  L5SINH    L5AMXH
     C                     ADD  L5DUPH    L5AMXH
     C                     ADD  L5HRH1    L5AMXH
     C                     ADD  L5HRH2    L5AMXH
