     C                     ADD  L5JTEI    L5AMXH
     C                     ADD  L5SKJI    L5AMXH
     C                     ADD  L5PADJ    L5AMXH
     C                     ADD  L5AUAJ    L5AMXH
     C                     Z-ADDL5AMXH    L5UZAR
     C                     ENDIF
      *
     CSR         ESB700    ENDSR
