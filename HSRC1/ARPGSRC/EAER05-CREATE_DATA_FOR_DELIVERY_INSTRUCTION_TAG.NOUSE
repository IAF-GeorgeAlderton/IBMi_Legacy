     C           KEY1      KLIST
     C                     KFLD           TOKUM
     C                     KFLD           NONYM
     C                     KFLD           NKOJM
     C                     KFLD           NUKEM
      *
     C           KEY2      KLIST
     C                     KFLD           HBA1
     C                     KFLD           HBA2
     C                     KFLD           HBA3
      *
     C           KEY3      KLIST
     C                     KFLD           TOKUM
     C                     KFLD           NONYM
     C                     KFLD           MHN1
     C                     KFLD           MHN2
     C                     KFLD           MHN3
      *-------------------------------------*
      *        ﾅbyhuﾇj-  ﾑﾒ  ﾉcpｬcﾅgxb      *
      *-------------------------------------*
     C                     MOVE *BLANK    WZETI
     C                     SETOF                     02
     C                     MOVE *BLANK    WNONM  16
     C           NONYM     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     02
     C                     END
     C                     END
     C   02                GOTO @END
     C                     MOVELB2SMEI    WNONM
      *
      *-------------------------------------*
      *       ﾆﾏlfuﾇj- ﾑﾒ ﾃcﾆﾞﾑcxb          *
      *                   j]ncﾆｫﾃｰnﾞ        *
      *                   joﾌﾞ]             *
      *-------------------------------------*
     C                     MOVE *BLANK    WNKNM  15
     C                     Z-ADD0         WTANT   40
     C                     MOVE *BLANK    WTNA    3
     C                     SETOF                     03
     C           KEY1      CHAINGADPL111             03
     C           *IN03     IFEQ '0'
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
     C                     END
     C   03                GOTO STEP2
     C                     MOVELB5KMEI    WNKNM
     C                     Z-ADD0         WTANT
     C                     MOVE *BLANK    WTNA
     C           STEP2     TAG
      *-------------------------------------*
      *     j]ncxbuﾇj- f[ j]ncﾆzxb          *
      *-------------------------------------*
     C                     MOVE *BLANK    WTMEI   9
     C           WTANT     IFNE 0
     C                     SETOF                     04
     C           WTANT     CHAINFAEPL011             04
     C  N04                MOVELG1TMEI    WTMEI
     C                     END
      *--------------暫定処理----------93.09.27------*
      *日本電装３６４６、受入の１桁目がＳ．Ｄのものは*
      *  工場名を『ニシオポンプ４０８』に変更する。  *
      *------------------------------------------------*
     C           TOKUM     IFEQ 3646
     C           NONYM     IFEQ 3646
     C           NKOJM     IFEQ '2'
     C           TKKI1     IFEQ 'S'
     C           TKKI1     OREQ 'D'
     C                     MOVE *BLANK    WNKNM
     C                     MOVEL'NISHIO  'KJMEI1 12
     C                     MOVE '408'     KJMEI1
     C                     MOVELKJMEI1    WNKNM
     C                     END
     C                     END
     C                     END
     C                     END
      *----------------------------------93.10.20-----*
      * 日本電装３６４６　工場名印字変更マスターに  *
      * 有る時は引いた内容を優先してエフに印字する。*
      *-----------------------------------------------*
     C           KEY4      KLIST
     C                     KFLD           TOKUM
     C                     KFLD           NONYM
     C                     KFLD           NKOJM
     C                     KFLD           NUKEM
     C                     KFLD           MHN1
     C                     KFLD           MHN2
     C                     KFLD           MHN3
     C*
     C                     SETOF                     06
     C           KEY4      CHAINEAEPL801             06
     C           *IN06     IFEQ '0'
     C           ECSKJY    IFEQ 'D'
     C                     SETON                     06
     C                     END
     C                     END
     C*無い時、何もしない
     C*有る時、工場名印字変更マスターより入力
     C           *IN06     IFEQ '0'
     C                     MOVELECINJI    WNKNM
     C                     END
      *--------------------------------------*
      *指示エフ発行条件荷姿マスターより引く*
      *＊引けた場合は部品マスターから引けた*
      *  と同じ様に計算する。              *
      *--------------------------------------*
     C*
     C                     MOVE *BLANK    WTKRO
     C                     Z-ADD0         WSYUY
     C*
     C                     SETOF                     06
     C           KEY4      CHAINEAEPL601             06
     C           *IN06     IFEQ '0'
     C           EBSKJY    IFEQ 'D'
     C           EBSKHZ    ANDLE*DATE
     C                     SETON                     06
     C                     END
     C                     END
     C*無い時、通常の部品マスターより入力
     C           *IN06     IFEQ '1'
     C                     GOTO EXIT1
     C                     END
     C*有る時、荷姿条件マスターより入力
     C                     Z-ADDEBKSYU    WSYUY
     C                     MOVE EBTBAN    XTKRO
     C                     MOVELEBNISG    STEIM
     C                     GOTO STEP3
     C           EXIT1     TAG
      *-------------------------------------*
      *     ﾎﾞﾍ]uﾇj-  f[  ﾆﾏcﾑcﾇc           *
      *                   ﾌﾞ]k              *
      *-------------------------------------*
     C                     MOVE *BLANK    WTKRO
     C                     Z-ADD0         WSYUY
     C                     SETOF                     05
     C           KEY2      CHAINFCEPL011             05
     C           *IN05     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     05
     C                     END
     C                     END
     C           *IN05     IFEQ '0'
     C           A2SYHZ    IFGT SHIZM
     C                     Z-ADDA2KSYS    WSYUY   50
     C                     ELSE
     C                     Z-ADDA2SSYS    WSYUY
     C                     END
     C           A2TRHZ    IFGT SHIZM
     C                     MOVE A2KTKR    WTKRO   6
     C                     ELSE
     C                     MOVE A2STKR    WTKRO
     C                     END
     C                     MOVE A2ZETI    WZETI   4        95.11. S.OHTAKE
     C                     END
     C           FTKRO     IFEQ *BLANK
     C                     MOVE WTKRO     XTKRO
     C                     ELSE
     C                     MOVE FTKRO     XTKRO
     C                     END
     C           XTKR2     IFEQ '0'
     C                     MOVE *BLANK    XTKR2
     C                     END
     C           XTKR3     IFEQ '0'
     C                     MOVE *BLANK    XTKR3
     C                     END
     C           XTKR4     IFEQ '0'
     C                     MOVE *BLANK    XTKR4
     C                     END
     C           STEP3     TAG
      *
      *-------------------------------------*
      *     ﾃcﾝﾆﾑcﾆﾞ 2208 ﾉng ﾃ]tﾟcﾆﾏcﾑcﾇc  *
      *-------------------------------------*
     C                     SETOF                     14
     C           TOKUM     IFEQ 2208
     C           KEY3      CHAINFACPL011             14
     C           *IN14     IFEQ '0'
     C                     Z-ADDA7SYUY    WSYUY
     C                     END
     C                     END
      *-------------------------------------*
      *     ﾌﾃﾇc  ﾌﾇc  ･  ibﾅ]  mﾞ  ynxﾓ    *
      *-------------------------------------*
     C                     Z-ADD0         WHASU   70
     C                     Z-ADD0         WHAK2   10
      *
     C           WSYUY     IFEQ 0
     C                     Z-ADDSRYOM     WHASU
     C                     Z-ADD1         WHAK2
     C                     GOTO STEP4
     C                     END
      *
     C                     Z-ADDSRYOM     XSRYOM  70
     C           XSRYOM    IFLT WSYUY
     C                     Z-ADDSRYOM     WHASU
     C                     Z-ADD1         WHAK2
     C                     Z-ADD0         WSYUY
     C                     ELSE
     C           XSRYOM    DIV  WSYUY     WHAK1   30
     C           WSYUY     MULT WHAK1     WKOTE   70
     C           XSRYOM    SUB  WKOTE     WHASU
     C           WHASU     IFNE 0
     C                     Z-ADD1         WHAK2
     C                     END
     C                     END
     C           STEP4     TAG
      *
     C           TOKUM     IFEQ 3182
     C           KAR       IFEQ '1'
     C                     MOVE '2'       KKBNM
     C                     END
     C                     END
      *
     C           TOKUM     IFEQ 3646
     C           TOKUM     OREQ 8400
     C           SGATM     IFEQ 'C1'
     C                     MOVE '2'       KKBNM
     C                     END
      *
     C           SGATM     IFEQ 'C2'
     C                     MOVE '3'       KKBNM
     C                     END
      *
     C           SGATM     IFEQ 'C3'
     C                     MOVE '4'       KKBNM
     C                     END
     C                     END
      *
     C                     Z-ADDTANKM     WTANK
     C                     MOVE *BLANK    YTAN2   2
     C           WTANK     IFNE 0
     C                     MOVE WTAN2     YTAN2
     C                     END
      *
     C           WPAGE     ADD  1         WPAGE   40
      *
     C                     Z-ADD0         WRCDN   50
     C                     Z-ADDRCDNM     WRCDN
      *
     C                     Z-ADD0         WSRYO   70
     C                     Z-ADDSRYOM     WSRYO
      *
     C                     EXCPT@@@
      *
     C           @END      TAG
