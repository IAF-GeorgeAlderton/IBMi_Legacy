     H            Y.                                    1
      ** GDAR11 *****************************
      *  MATERIAL ORDER DATA UPDATE SYSTEM  *
      *      AFTER SUMMARIZATION            *
      *
      *
      * TCHK1 01/07/08 CHG 0002 TO 8990
      *
      *
      ***************************** GDAR11 **
     FGDAPW11 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FGDAPL10 UF  E           K        DISK                      A
     FFGBPL01 IF  E           K        DISK
     FIZAPL01 IF  E           K        DISK
     FIZBPL01 IF  E           K        DISK
      *-------------------------------------------------------
     E                    ER      1  15 78
     E                    CMD     1   3 78
     E                    UP1     1   3  1   UP2    10
      *-------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80ZCSKHZ
     I                                        1   40ZCSKYY
     I                                        5   60ZCSKMM
     I                                        7   80ZCSKDD
     I            DS
     I                                        1   80ZDSKHZ
     I                                        1   40ZDSKYY
     I                                        5   60ZDSKMM
     I                                        7   80ZDSKDD
     I            DS
     I                                        1   80ZCUKHZ
     I                                        1   40ZCUKYY
     I                                        5   60ZCUKMM
     I                                        7   80ZCUKDD
     I            DS
     I                                        1   80ZCSTHZ
     I                                        1   40ZCSTYY
     I                                        5   60ZCSTMM
     I                                        7   80ZCSTDD
     I            DS
     I                                        1   80ZDUKHZ
     I                                        1   40ZDUKYY
     I                                        5   60ZDUKMM
     I                                        7   80ZDUKDD
     I            DS
     I                                        1   80ZDSTHZ
     I                                        1   40ZDSTYY
     I                                        5   60ZDSTMM
     I                                        7   80ZDSTDD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------------
      *   MAIN ROUTINE
      *----------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------------
      *   INITIALIZE
      *----------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           ISIRE   40
     C                     KFLD           XZAIS  15
     C                     KFLD           XZAIK   52
      *
     C           KEY2      KLIST
     C                     KFLD           ISIRE   40
     C                     KFLD           ZZAIS  15
     C                     KFLD           ZZAIK   52
      *
     C           KEY3      KLIST
     C                     KFLD           IZAIS  15
     C                     KFLD           IZAIK   52
     C                     KFLD           IKOJE   40
     C                     KFLD           ISIRE   40
      *
     C           KEY4      KLIST
     C                     KFLD           ISIRE   40
     C                     KFLD           IZAIS  15
     C                     KFLD           IZAIK   52
      *
     C                     Z-ADD*DATE     K@YMD
TCHK1C*                    MOVE '0002'    PSIRE
TCHK1C                     MOVE '8990'    PSIRE
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *--------------------------------------------------------
      * SCREEN 1 *
      *--------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     MOVELER,13     D@MSG
     C                     ELSE
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
      * CLEAR
      *---------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,01
      *
     C                     ENDSR
      *---------------------------------------------------
      * CHECK 1ST SCREEN
      *---------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           PSIRE     IFEQ *BLANK
     C                     MOVELER,9      D@MSG
     C                     SETON                     99
     C                     ELSE
      *
     C                     MOVEL'0111'    IKOJE   40
     C                     MOVELPSIRE     ISIRE   40
      *
     C           ISIRE     CHAINFGBPL011             05
      *
     C           *IN05     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     15
     C                     END
     C                     END
      *
     C           *IN05     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,9      D@MSG
     C                     END
      *
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     @@RNO   40
      *
     C                     ENDSR
      *---------------------------------------------------
      * SET DATA FOR 2ND SCREEN
      *---------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN83
     C                     WRITECTL01
     C                     MOVE *OFF      *IN83
     C                     Z-ADD0         RRN1    40
      *
     C           ISIRE     SETLLGDAPL10
     C           *IN10     DOUEQ*ON
     C           ISIRE     READEGDAPL10             N    10
     C           *IN10     IFEQ *OFF
     C           IBSKJY    ANDEQ*BLANK
     C                     MOVELIBZAIS    ZS01
     C                     Z-ADDIBZAIK    ZK01
     C                     Z-ADDIBMAIS    MS01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C           @@RNO     IFEQ *ZERO
     C           @@RNO     ORGT RRN1
     C                     Z-ADD1         #RCNO
     C                     ELSE
     C                     Z-ADD@@RNO     #RCNO
     C                     ENDIF
      *
     C                     MOVE *BLANK    IUPDT
     C                     MOVE *BLANK    IZAIS
     C                     Z-ADD0         IZAIK
     C                     MOVE 'W'       IPTCD
     C                     Z-ADD0         IMAIS
      *
     C                     ENDSR
      *--------------------------------------------------------
      * SCREEN 2 *
      *--------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVEA'11'      *IN,81
     C                     WRITECTL01
     C                     Z-ADD@@REC     #RCNO
     C                     Z-ADD@@REC     @@RNO
      *
     C                     MOVEA'00'      *IN,81
     C                     EXFMTDSP98
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKC     WHEQ *ON
     C                     MOVE '01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     MOVE '03'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
      * CHECK 2ND SCREEN
      *---------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
      *------------*
      * RENEW CODE *
      *------------*
     C                     Z-ADD1         X       20
     C           IUPDT     LOKUPUP1,X                    25
     C           *IN25     IFEQ '0'
     C                     SETON                     0199
     C                     MOVELER,5      D@MSG
     C                     ELSE
     C   25                MOVELUP2,X     D@MODE
     C                     ENDIF
      *
     C           IUPDT     IFEQ '0'
     C                     SETON                     70
     C                     END
      *----------------------*
      * WIRE / WIRE DIAMETER *
      *----------------------*
     C           IZAIS     IFEQ *BLANK
     C  N99                MOVELER,10     D@MSG
     C                     SETON                     0299
     C                     END
      *
     C           IZAIK     IFEQ 0
     C  N99                MOVELER,11     D@MSG
     C                     SETON                     0399
     C                     END
      *
     C           IPTCD     IFNE 'W'
     C           IPTCD     ANDNE'R'
     C  N99                MOVELER,12     D@MSG
     C                     SETON                     0499
     C                     END
     C                     MOVE *BLANK    ZETI    4
      *-------------*
      * WIRE KANBAN *
      *-------------*
     C                     SELEC
     C           IPTCD     WHEQ 'W'
     C           KEY3      SETGTIZAPL01
     C           *IN10     DOUEQ*ON
     C           KEY3      REDPEIZAPL011                 10
      *
     C           *IN10     IFEQ '0'
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCUKHZ    ANDLE*DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     MOVELZCKNO3    ZETI
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN10     IFEQ *ON
     C  N99                MOVELER,3      D@MSG
     C                     SETON                     010203
     C                     SETON                     0499
     C                     ENDIF
      *------------*
      * ROD KANBAN *
      *------------*
     C           IPTCD     WHEQ 'R'
     C           KEY3      SETGTIZBPL01
     C           *IN10     DOUEQ*ON
     C           KEY3      REDPEIZBPL011                 10
      *
     C           *IN10     IFEQ '0'
     C           ZDSKJY    ANDEQ*BLANK
     C           ZDUKHZ    ANDLE*DATE
     C           ZDSTHZ    ANDGT*DATE
     C                     MOVELZDKNO3    ZETI
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN10     IFEQ *ON
     C  N99                MOVELER,4      D@MSG
     C                     SETON                     010203
     C                     SETON                     0499
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           KEY4      CHAINGDAPL10             N30
      *
     C           *IN30     IFEQ '1'
     C           IUPDT     IFEQ '0'
     C           IUPDT     OREQ '1'
     C  N99                MOVELER,6      D@MSG
     C                     SETON                     020399
     C                     END
     C                     END
      *
     C           *IN30     IFEQ '0'
     C           IBSKJY    ANDEQ'D'
     C           IUPDT     ANDEQ'0'
     C  N99                MOVELER,7      D@MSG
     C                     SETON                     020399
     C                     ENDIF
      *
     C           IUPDT     IFNE '2'
     C                     Z-ADDIBMAIS    IMAIS
     C                     END
      *
     C           *IN30     IFEQ *OFF
     C           IUPDT     ANDEQ'2'
     C  N99                MOVELER,8      D@MSG
     C                     SETON                     020399
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      * SCREEN 3 *
      *--------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE CMD,3     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP03
      * CMD-3 *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '02'      W@ID
     C                     Z-ADD@@RNO     #RCNO
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     EXSR #SET1
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
      * CHECK SCREEN 3 *
      *--------------------------------------------------------
     C           #CHK3     BEGSR
      *
     C                     EXSR #CLR
      *
     C           IMAIS     IFEQ 0
     C                     SETON                     0199
     C                     MOVELER,14     D@MSG
     C                     END
      *
     C                     ENDSR
      *--------------------------------------------------------
      * UPDATE
      *--------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           KEY4      CHAINGDAPL10              30
     C                     TIME           IBKOTM
     C                     Z-ADD*DATE     IBKODT
     C                     MOVEL#USER     IBKOME
     C           IUPDT     IFEQ '0'
     C                     MOVE 'D'       IBSKJY
     C                     Z-ADD*DATE     IBSKDT
     C                     END
      *
     C           IUPDT     IFEQ '1'
     C           IUPDT     OREQ '2'
      *
     C                     MOVE *BLANK    IBSKJY
     C                     Z-ADD0         IBSKDT
     C                     MOVELISIRE     IBSIRE
     C                     MOVEL'0111'    IBUKEI
     C                     MOVEL*BLANK    IBUKOJ
     C                     MOVEL*BLANK    IBUUKE
     C                     MOVELIZAIS     IBZAIS
     C                     Z-ADDIZAIK     IBZAIK
     C                     MOVELIPTCD     IBPTCD
     C                     MOVELZETI      IBZETI
     C                     Z-ADDIMAIS     IBMAIS
     C                     END
      *
     C           *IN30     IFEQ '1'
     C                     WRITEGDAPP101
     C                     ELSE
     C                     UPDATGDAPP101
     C                     END
      *
     C                     ENDSR
** MSG
E-01 THIS PAGE IS DISPLAYED THE DATA OF TOP PAGE.
E-02 THIS PAGE IS DISPLAYED THR DATA OF BOTTOM PAGE.
E-03 THIS DATA IS NOT IN WIRE KANBAN MASTER FILE.
E-04 THIS DATA IS NOT IN ROD KANBAN MASTER FILE.
E-05 INPUT CODE IS DIFFERENT.
E-06 THIS DATA IS NOT IN ORDER TEMPORARY FILE.
E-07 THIS DATA ALREADY HAS BEEN DELETED.
E-08 THIS DATA ALREADY HAS BEEN INPUT.
E-09 SUPPLIER CODE ERROR.
E-10 INPUT WIRE DATA.
E-11 INPUT WIRE DIAMETER DATA.
E-12 INPUT PARTS CODE IS DIFFERENT.
E-13 NO DATA.
E-14 INPUT NUMBER OF KANBAN.
** CMD
F1:END
F1:END    F3:GO BACK
F1:END    F3:GO BACK      F5:UPDATE
** UP1/UP2
0 0-DELETE
1 1-CHANGE
2  2-ADD
