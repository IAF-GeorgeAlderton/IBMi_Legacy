     H            Y.
     F** ABMR36 *********************************************
     F*間口数変更リスト
     F*    HOTTA.               2018.09.14                  *
     F*******************************************************
     FABMPL33 IF  E           K        DISK
     FABMPRI6 O   E             55     PRINTER
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     SETON                     55
     C                     Z-ADDP@DTYM    K@DTYM  60
     C           K@DTYM    SETLLABMPL331
     C           K@DTYM    READEABMPL331                 87
     C           *IN87     DOWEQ'0'
     C           S5BRYO    IFNE S5MAGS
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRI61
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #SB001
     C                     ENDIF
     C           K@DTYM    READEABMPL331                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     MOVELS5KCD1    P2KCD1
     C                     MOVELS5ATK1    P2ATK1
     C                     MOVELS5ATK2    P2ATK2
     C                     MOVELS5ATK3    P2ATK3
     C                     MOVELS5ATK4    P2ATK4
     C                     MOVELS5SDAI    P2SDAI
     C                     MOVELS5SSYO    P2SSYO
     C                     MOVEL*BLANK    P2SHIN
     C           S5SHN1    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  S5SHN2:0  P2SHIN
     C           P2SHIN    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  S5SHN3:0  P2SHIN
     C                     Z-ADDS5SSYS    P2SSYS
     C                     MOVELS5ATOB    P2ATOB
     C                     MOVELS5ATOK    P2ATOK
     C                     Z-ADDS5BRYO    P2BRYO
     C                     Z-ADDS5MAGS    P2MAGS
     C                     Z-ADDS5KMAX    P2KMAX
     C                     Z-ADDS5KMAA    P2KMAA
     C                     Z-ADDS5BOXD    P2BOXD
     C                     WRITEABMPRI62
      *
     CSR         ESB001    ENDSR
