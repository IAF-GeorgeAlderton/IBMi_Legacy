     C           OASKHZ    ANDLE@YMD
     C                     ELSE
      *
     C           OAUKHZ    IFLE @YMD
     C           OASTHZ    ANDGT@YMD
     C                     SETON                     10
     C                     MOVE '*'       $ARS
     C                     END
     C                     END
     C                     END
     C  N10                END
      *
     C*--------------------------*
     C*  ..ＡＲＲＳマスター..  *
     C*--------------------------*
     C           $ARS      IFEQ '*'
     C                     SETOF                     10
     C           KEY1      CHAINOABPL011             10
     C           *IN10     IFEQ '0'
     C           OBSKJY    ANDEQ'D'
     C           OBSKHZ    ANDLE@YMD
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE '0'       WTSKB            jbﾆｭchﾎﾞ]
     C                     Z-ADD@YMD      $KYMD
     C           OBAPHB    IFGT $KBHB
     C                     MOVE OBKKBN    WSKKB            ﾆｬｮfﾏcﾃchﾎﾞ]
     C                     ELSE
     C                     MOVE OBSKBN    WSKKB            ﾆｬｮfﾏcﾃchﾎﾞ]
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C                     SETOF                     0312
     C                     MOVE *BLANK    WKDAI   1
     C           KEY1      CHAINAGAPL411             12
     C           *IN12     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     12
     C                     END
     C           *IN12     IFEQ '0'
     C                     SETON                     03
     C                     MOVE CBKDAI    WKDAI
     C                     END
      *
     C*--------------------------------*
     C*  ..メッキかんばんマスター..  *
     C*--------------------------------*
     C                     MOVE *BLANK    WKCD2   1        f]ﾌﾞ]ﾆｬﾓb ﾆｭc
     C                     MOVE *BLANK    WNJKB   1        2ﾆﾞfﾃchﾎﾞ]
TCHK3C                     MOVE *BLANK    WATOK   3
TCHK3C                     MOVE *BLANK    WATOB   4
      *
S1   C           WKDAI     IFEQ 'C'
     C           KEY2      SETGTAAFPL031
      *
     C                     DO   *HIVAL
     C                     SETOF                     12
     C           KEY2      REDPEAAFPL031                 12
     C           *IN12     IFEQ '0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE@YMD
     C                     ELSE
      *
     C           A3UKHB    IFLE @YMDB
     C           A3STHB    ANDGT@YMDB
     C                     SETON                     12
      *
     C           *IN03     IFEQ '0'
     C                     MOVE 'A'       WNJKB
     C                     ELSE
     C           WKDAI     IFEQ A3KCD1
     C                     MOVE '0'       WNJKB
     C                     ELSE
     C                     MOVE 'A'       WNJKB
     C                     END
     C                     END
      *
     C                     MOVE A3MTKR    WMTKR            udﾃcmb nﾃﾜﾌﾞ]k
     C                     MOVE A3KCD2    WKCD2            f]ﾌﾞ]ﾆｬﾓb ﾆｭc
      *
     C                     END
     C                     END
     C                     END
     C  N12                END
     C                     ENDIF
      *
     C*--------------------------------*
     C*  ..平準化確定発注ファイル..  *
     C*--------------------------------*
     C                     SETOF                     12
     C           KEY1      CHAINAGAPL411             12
     C           *IN12     IFEQ '0'
     C*                    MOVE CBLOTN    @@LOTN  30
     C                     MOVE CBLOTN    @@LOTN  3
     C           CBBARL    IFEQ 0
     C                     Z-ADD1         @@BARL  20
     C                     ELSE
     C                     Z-ADDCBBARL    @@BARL
     C                     END
     C                     END
      *
     C                     EXSR SUBCHK
      *
     C           WERNM     IFEQ *BLANK
     C                     SETOF                       25
     C           KEY1      CHAINAHDPP601             25
     C           *IN25     IFEQ '0'
     C           AHSKJY    ANDEQ'D'
     C           AHSKHZ    ANDLE*DATE
     C                     SETON                     25
     C                     END
      *
      *かんばん発行での有効日チェック
      *
     C           *IN25     IFEQ '0'
     C           D3APHZ    IFGE AHYUHZ
     C           D3APHZ    ANDLEAHSTHZ
     C                     ELSE
     C                     SETON                     25
     C                     END
     C                     END
      *
     C           WMAIS     DIV  @@BARL    @@KAIS  30
      *箱数：ゼロ以下又は｣バレルと等しい時ロット単位の
      *バラシは、実行しない
      *
     C           WMAIS     IFLE 0
     C           WMAIS     ORLE @@BARL
     C                     SETON                     25
     C                     END
      *
     C           *IN25     IFEQ '0'
      *
     C                     DO   @@KAIS
     C*                    ADD  1         @@LOTN
     C*          @@LOTN    IFLT 990
     C*                    Z-ADD990       @@LOTN
     C*                    ENDIF
      *
     C                     EXSR #LOTN
      *
TCHK1C                     MOVE @@LOTN    CBLOTN
     C                     Z-ADDCBBARL    WMAIS
     C                     EXCPTDT
     C                     ENDDO
TCHK1C*                    MOVE @@LOTN    CBLOTN
     C                     ELSE
      *
     C*                    ADD  1         @@LOTN
     C*          @@LOTN    IFLT 990
     C*                    Z-ADD990       @@LOTN
     C*                    ENDIF
      *
     C                     EXSR #LOTN
      *
TCHK1C                     MOVE @@LOTN    CBLOTN
     C                     EXCPTDT
TCHK1C*                    MOVE @@LOTN    CBLOTN
     C                     END
      *
     C                     END
      *
     C  N12                UPDATAGAPL411
      *
     C                     ENDSR
