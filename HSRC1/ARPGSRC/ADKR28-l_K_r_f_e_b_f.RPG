     C*------------------------------------------*
     C*  ..Ａ－ＰＩＣＳ　転送先判断マスター..  *
     C*------------------------------------------*
     C                     Z-ADD0         WBMON   40
     C                     MOVE *BLANK    WKCD1   1
     C                     MOVE *BLANK    WSW1    1
      *
     C           D3BRUI    IFEQ '0'
     C                     Z-ADD0111      WBMON
     C                     ELSE
      *
     C           KEY3      SETLLACAPL111
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY3      READEACAPL111                 10
     C           *IN10     IFEQ '0'
     C           I1SKJY    IFEQ 'D'
     C           I1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     10
     C                     MOVE '*'       WSW1
     C                     Z-ADDI1BMON    WBMON
     C                     MOVE I1KCD1    WKCD1
      *
     C                     ENDIF
     C                     ENDIF
     C  N10                ENDDO
      *
     C           WSW1      IFEQ *BLANK
     C                     Z-ADD0111      WBMON
     C                     ELSE
      *
     C                     SETOF                     11
     C           KEY4      CHAINACAPL111             11
     C           *IN11     IFEQ '0'
     C           I1SKJY    ANDEQ'D'
     C           I1SKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     ENDIF
     C           *IN11     IFEQ '0'
     C                     Z-ADDI1BMON    WBMON
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETOF                     10
     C                     Z-ADD1         A       20
     C           WBMON     LOKUPBUM,A                    10
     C           *IN10     IFEQ '1'
     C           D3APBN    IFLE BIN,A
     C                     SETON                     02
     C                     Z-ADDBIN,A     @BB
     C                     Z-ADDBIN,A     $KBBI
     C                     ADD  D3MAIS    WMAIS
     C                     MOVE '*'       D3MAK2
     C                     MOVE '*'       D3MAK1
     C                     MOVE '*'       D3EFLG
     C                     Z-ADD@YMDB     D3DTHB
     C                     UPDATADKPL351
