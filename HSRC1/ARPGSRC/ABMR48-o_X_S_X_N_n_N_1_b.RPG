     H            Y.
     F** ABMR48 *********************************************
     F*構成品の確定設定数　ＮとＮ＋１の多い方（日当りで返す）
     F*    HOTTA.               2018.10.24                  *
     F*******************************************************
     FMCENP13 IF  E           K        DISK
     FABMPL21 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@KHN1  5
     C                     PARM           P@KHN2  5
     C                     PARM           P@KHN3  2
     C                     PARM           P@KSSU  90
     C                     PARM           P@KTSU  90
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     Z-ADDP@DTYM    K@NTYM
     C                     Z-ADD0         P@KSSU
     C                     Z-ADD0         P@KTSU
      *
     C           KEYMCE    KLIST
     C                     KFLD           K@KHN1  5
     C                     KFLD           K@KHN2  5
     C                     KFLD           K@KHN3  2
     C                     MOVELP@KHN1    K@KHN1
     C                     MOVELP@KHN2    K@KHN2
     C                     MOVELP@KHN3    K@KHN3
      *
     C           KEYMCE    SETLLMCENP131
     C           KEYMCE    READEMCENP131                 75
     C           *IN75     DOWEQ'0'
     C                     EXSR #SB100
     C           KEYMCE    READEMCENP131                 75
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      *内示
      *---------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C           KEYFCE    KLIST
     C                     KFLD           MCSHN1
     C                     KFLD           MCSHN2
     C                     KFLD           MCSHN3
     C           KEYFCE    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C           A2GEKN    DIV  20        Q@KSSU  90
     C           A2GEKN    DIV  20        Q@KTSU  90
     C                     ENDIF
      *
     C           KEYFC1    KLIST
     C                     KFLD           K@NTYM  60
     C                     KFLD           MCSHN1
     C                     KFLD           MCSHN2
     C                     KFLD           MCSHN3
     C           KEYFC1    CHAINABMPL211             25
     C           *IN25     IFEQ '0'
     C           S4SKJY    ANDEQ'D'
     C           S4SKHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C           S4OMIT    IFEQ '0'
     C                     Z-ADD0         Q@KSSU
     C                     Z-ADD0         Q@KTSU
     C                     ADD  S4NSRD    Q@KSSU
     C           S4NSRD    IFGT S4FSD1
     C                     ADD  S4NSRD    Q@KTSU
     C                     ELSE
     C                     ADD  S4FSD1    Q@KTSU
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  Q@KSSU    P@KSSU
     C                     ADD  Q@KTSU    P@KTSU
      *
     CSR         ESB100    ENDSR
