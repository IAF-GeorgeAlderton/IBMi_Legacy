     H            Y/
     F******************************************************
     F*  MATERIAL CHANGE INQUIRY BY DATE                   *
     F*                                                    *
     F* TCHK  04/19/12 CREATE                              *
     F******************************************************
     FFCEPW86 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FABHTL06 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    MSG     1   1 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        7  120WSSYM
     I*
     I            DS
     I                                        1  14 W@SHIN
     I                                        1   5 W@SHN1
     I                                        6   6 W@SHNA
     I                                        7  11 W@SHN2
     I                                       12  12 W@SHNB
     I                                       13  14 W@SHN3
     I            DS
     I                                        1   60M6UKYM
     I                                        1   40M6UKYY
     I                                        5   60M6UKMM
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C*
     C                     TIME           WSDT
     C                     Z-ADDWSSYM     D@YYMM
     C*
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@YYMM    IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
     C*
     C                     DO
     C*
     C           *LOVAL    SETLLABHTL06
     C                     DO   *HIVAL
     C                     READ ABHTL06                  98
     C   98                LEAVE
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C   98                LEAVE
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVELM6HIN1    K@HIN1  5
     C                     MOVELM6HIN2    K@HIN2  5
     C                     MOVELM6HIN3    K@HIN3  2
     C           K#T06A    KLIST
     C                     KFLD           K@HIN1
     C                     KFLD           K@HIN2
     C                     KFLD           K@HIN3
     C           K#T06A    SETGTABHTL06
     C*
     C                     MOVEL*BLANK    W@ZAI1 15
     C                     Z-ADD*ZERO     W@ZAI2  52
     C*
     C                     DO   *HIVAL
     C*
     C           K#T06A    REDPEABHTL06                  97
     C   97                LEAVE
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           M6UKYM    IFNE D@YYMM
     C                     ITER
     C                     END
     C*
     C                     MOVELM6ZAI1    W@ZAI1
     C                     Z-ADDM6ZAI2    W@ZAI2
     C*
     C                     DO   *HIVAL
     C           K#T06A    REDPEABHTL06                  96
     C   96                LEAVE
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C   96                LEAVE
     C*
     C           M6ZAI1    IFEQ W@ZAI1
     C           M6ZAI2    ANDEQW@ZAI2
     C                     LEAVE
     C                     END
     C*
     C                     CLEARSFL01
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELM6HIN1    W@SHN1
     C                     MOVELM6HIN2    W@SHN2
     C                     MOVELM6HIN3    W@SHN3
     C           M6HIN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C           M6HIN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELW@SHIN    S1PART
     C*
     C                     MOVELW@ZAI1    S1ZA1N
     C                     Z-ADDW@ZAI2    S1ZA2N
     C                     MOVELM6ZAI1    S1ZA1O
     C                     Z-ADDM6ZAI2    S1ZA2O
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C           K#T06A    SETGTABHTL06
     C                     READ ABHTL06                  95
     C   95                LEAVE
     C*
     C                     ENDDO
     C*
     C                     Z-ADD1         #RCNO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1:EXIT   ENTER:NEXT
F1:EXIT   F12:GO BACK
**  MSG
