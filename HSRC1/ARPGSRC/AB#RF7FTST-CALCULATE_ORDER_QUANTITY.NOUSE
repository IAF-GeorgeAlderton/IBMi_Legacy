     C*
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C                     EXSR @END
     C***********************************************************
     C* INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     TIME           WTMDT
     C*
     C                     Z-ADD*ZERO     WQTY2  100
     C                     Z-ADD*ZERO     WQTY3  100
     C                     Z-ADD*ZERO     WSUMQ  100
     C                     Z-ADD*ZERO     WODRQ  100
     C                     SETON                     OF
     C*
     C                     Z-ADDPRYYYY    WRYYYY
     C                     Z-ADDPRMMMM    WRMMMM
     C                     Z-ADDPRDDDD    WRDDDD
     C                     Z-ADDPSYYYY    WSYYYY
     C                     Z-ADDPSMMMM    WSMMMM
     C                     Z-ADDPSDDDD    WSDDDD
     C*
     C* NOT WORKING DAY?
     C           WRDATE    IFNE WSDATE
     C                     SETON                     89
     C                     END
     C*
     C* GET THE DATE OF 2WEEKS AGO
     C                     Z-ADD*ZERO     @CNT    20
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL11
     C           *IN97     DOUEQ*ON
     C                     READPAGDPL11                  97
     C           *IN97     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @CNT
     C           @CNT      IFEQ 7
     C                     Z-ADDF8DATE    @@STDT  80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           KEY8      SETLLAGDPL111
     C                     DO   14
     C                     READPAGDPL111                 97
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C* NIRVANA PLANT EXISTS IN ROUTE MASTER
     C* READ AND PROCESS ALL ROUTE MASTER RECORD
     C           *LOVAL    SETLLABFDL01R
B0   C           *IN90     DOUEQ*ON
     C                     READ ABFDL01R                 90
TCHK4C   90                LEAVE
      *
TCHK4C           @@NONY    IFEQ *ZERO
TCHK4C*
TCHKHC           PGRP      IFEQ '3'
TCHK4C           QANONY    IFEQ 5120
TCHK4C           QANONY    OREQ 5100
TCHK4C           QANONY    OREQ 5111
TCHK4C           QANONY    OREQ 5115
TCHK4C           QANONY    OREQ 5130
TCHK4C           QANONY    OREQ 5118
TCHK4C           QANONY    OREQ 5140
TCHK4C           QANONY    OREQ 5135
TCHK4C           QANONY    OREQ 5102
TCHK5C           QANONY    OREQ 5141
TCHK9C           QANONY    OREQ 5119
TCHKEC           QANONY    OREQ 5116
TCHKFC           QANONY    OREQ 5114
TCHKIC           QANONY    OREQ 5121
TCHKJC           QANONY    OREQ 5138
TCHKKC           QANONY    OREQ 5113
TCHKLC           QANONY    OREQ 5112
TCHKMC           QANONY    OREQ 5166
TCHKNC           QANONY    OREQ 5129
TCHKHC                     ELSE
TCHK4C                     ITER
TCHK4C                     END
TCHKHC                     END
TCHK4C*
TCHK4C                     MOVELQANONY    W@A004  4
TCHK4C           W@A004    LOKUPGRP2                     87
TCHK4C           PGRP      IFEQ '1'
TCHK4C           *IN87     ANDEQ*ON
TCHK4C                     ITER
TCHK4C                     END
TCHK4C           PGRP      IFEQ '2'
TCHK4C           *IN87     ANDEQ*OFF
TCHK4C                     ITER
TCHK4C                     END
TCHK4C*
TCHK4C                     ELSE
TCHK4C*
TCHK4C           @@NONY    IFNE QANONY
TCHK4C                     ITER
TCHK4C                     END
TCHK4C*
TCHK4C                     END
      *
     C                     Z-ADDQANONY    K@NONY
     C                     MOVE QADOCK    K@DOCK
      *
     C           K#ADF     SETGTABFDL01R
B2   C           *IN88     DOUEQ*ON
     C           K#ADF     REDPEABFDL01R                 88
B3   C           *IN88     IFEQ *ON
     C           K#ADF     SETGTABFDL01R
     C                     LEAVE
     C                     ELSE
B4   C           QASKJY    IFEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     ITER
E4   C                     ENDIF
B4   C           QAEFHZ    IFGT *DATE
     C                     ITER
E4   C                     ENDIF
     C*
     C* SET ROUTE CODE TO INVOICE#
     C                     MOVE WROUT     WINV1
     C*
     C* READ ADDRESS MASTER
     C           QAPLAN    CHAINABF9P01              93
B4   C           *IN93     IFEQ '1'
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL1
%0002C                     SETON                     U2
E4   C                     END
     C*
     C* READ EDI KEY FILE
     C                     MOVELQADOCK    K12     4
     C           KEY1      SETLLABFAP01R
     C           KEY1      READEABFAP01R                 91
B4   C           *IN91     DOWEQ'0'
     C*
B5   C           CFDLCD    IFEQ *BLANK
     C           CFSIDT    ANDGE@@STDT
     C* READ FORD EDI FILE
     C                     CLEARK21
     C                     MOVELCFPART    K21    20
TCH11C                     Z-ADD1         WW      10
TCH11C           CFPART    LOKUPP1,WW                    10
TCH11C   10                MOVELP2,WW     K21
      *
     C                     Z-ADDWRDAT     K22     80
     C           KEY2      CHAINABF2P011             92
      *
B6   C           *IN92     IFEQ *ON
     C           KEY2      SETLLABF2P011
     C           KEY21     REDPEABF2P011                 92
E6   C                     ENDIF
      *
B6   C           *IN92     IFEQ '0'
     C*
     C* SET AB#WP451(INPUT FILE FOR AB#R45)
     C                     MOVE 'AVRT'    WSIRE   4        SUPPLIER CODE
     C                     MOVE 'A'       WSIRK   1        FACTORY  CODE
     C                     MOVE '5149'    WTOKU   4        CUSTOMER CODE
     C                     MOVE 5149      @TOKU   40       CUSTOMER CODE
     C                     MOVE QANONY    WNONY   4        DELIVERY CODE
     C                     MOVE '0'       WNKOJ   1        FACTORY  CODE
     C                     MOVELQADOCK    WNUKE   4        RECEIVING   E
     C                     MOVE *BLANK    WSBAN   4        NUMBER      E
     C                     MOVE *BLANK    WMHIN
     C                     MOVELAFIPAR    WMHIN            PART NUMBER E
     C                     Z-ADDWSDAT     WNYMD   80       DELIVERY DATE
     C                     MOVEL'11111'   WODRN  10        ORDER #     E
TCHK8C           PBIN#     IFNE *ZERO
TCHK8C                     MOVELPBIN#     WBIN
TCHK8C                     ELSE
     C           QAROUT    CHAINABFBP10              95
B7   C           *IN95     IFEQ *OFF
     C                     MOVE B1BINN    WBIN    2
     C                     ELSE
     C                     MOVE '06'      WBIN
E7   C                     ENDIF
TCHK8C                     END
      *
     C                     Z-ADD99        K62     20       BIN
     C*
     C                     EXSR @SUM
     C*
     C* NOT WORKING DAY,RE-CULUCULATE
B7   C           *IN89     IFEQ '1'
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  WODRQ     WQTY2
     C                     MOVE WQTY2     WSURY   7
     C*
     C                     ELSE
     C*
     C* REQUESTED CUM - SHIPPED CUM
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  WODRQ     WQTY2
     C                     MOVE WQTY2     WSURY   7
E7   C                     END
     C*
B7   C           WQTY2     IFGT *ZERO
     C*
     C***** GET UNIT QUANTITY
     C                     MOVELWTOKU     PTOKU   4
     C                     MOVELWNONY     PNONY   4
     C                     MOVELWNKOJ     PNKOJ   1
     C                     MOVELWNUKE     PNUKE   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVELWMHIN     WMHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
     C*
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           @MHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG
     C*
     C* GET QTY./CONT. FROM PART MASTER
     C                     Z-ADD*ZERO     WSYOS            FOR ERROR
     C           KEY4      SETLLFCEPL011
     C           #READ1    TAG
     C           KEY4      READEFCEPL011                 94
B8   C           *IN94     IFEQ '0'
B9   C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     GOTO #READ1
     C*
     C                     ELSE
     C*
B10  C           A2SSHZ    IFLE *DATE
     C                     Z-ADDA2SSYS    WSYOS   60
     C                     ELSE
     C                     Z-ADDA2KSYS    WSYOS
E10  C                     END
     C*
E9   C                     END
     C*
     C                     ELSE
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL2
%0002C                     SETON                     U2
E8   C                     END
     C*
     C* CHECK FRACTION OR NOT
B8   C           WSYOS     IFNE *ZERO
     C           WQTY2     DIV  WSYOS     WQTY2
     C                     MVR            WREST   40
B9   C           WREST     IFNE *ZERO
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL3
%0002C                     SETON                     U2
E9   C                     END
     C*
E8   C                     END
     C*
     C                     Z-ADD*ZERO     WNOTM   40       INVOICE TIME
     C                     Z-ADD*ZERO     WUSYS   60       USER QTY/CONT.
     C                     MOVELAFALFL    WALFL   4        FEED LINE
     C*
     C* GET INVOICE NUMBER(ROUTE + JULIAN DATE)
     C           KEY3      CHAINABFEP01              95
B8   C           *IN95     IFEQ '0'
     C           QB#DAY    ADD  WSDDDD    WINV2
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     WINV2
E8   C                     END
     C*
     C                     MOVELAFRALF    WRLOC   4
+TCHKC                     Z-ADD20        W@DAT2
+TCHKC                     Z-ADDAFDATE    W@DAT3
+TCHKC                     MOVELW@DAT1    WCRTDT
+TCHKC                     WRITEABWP451R
     C                     SETON                     U1
      *
E7   C                     END
     C*
X6   C                     ELSE
B7   C           F8DATE    IFLE CFSIDT
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL4
%0002C                     SETON                     U2
E7   C                     END
E6   C                     END
      *
E5   C                     ENDIF
     C           KEY1      READEABFAP01R                 91
E4   C                     END
     C*
     C           K#ADF     SETGTABFDL01R
     C                     LEAVE
E3   C                     ENDIF
E2   C                     ENDDO
      *
E0   C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* SUM (SUMMARY ALREADY ORDERED DATA)
     C***********************************************************
     C           @SUM      BEGSR
     C*
     C                     Z-ADD5149      K61     40
     C                     Z-ADD*ZERO     WODRQ
     C                     Z-ADD2000      K63
TCHK3C           AFLSDT    IFEQ *ZERO
TCHK3C                     ADD  WDAYY     K63
TCHK3C                     ELSE
     C                     ADD  WFLSDT    K63
TCHK3C                     END
     C                     MOVELQADOCK    @NUKE   4        RECEIVING   E
