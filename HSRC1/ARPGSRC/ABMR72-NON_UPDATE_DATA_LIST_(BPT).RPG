     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C                     TIME           WTIME
      *
     C                     EXCPTHD
     C           *HIVAL    SETGTABMWP701
     C                     READPABMWP701                 87
     C           *IN87     DOWEQ'0'
     C                     EXSR #SB001
     C                     READPABMWP701                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           KEYFC1    KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
     C                     MOVEL*BLANK    W1STRK  1
     C                     MOVEL*BLANK    W1STRT  2
     C                     MOVEL*BLANK    W1STRR  2
     C                     MOVEL*BLANK    W1STRD  1
     C                     Z-ADD0         W1GEHZ  80
     C           KEYFC1    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELA2STRK    W1STRK
     C                     MOVELA2STRT    W1STRT
     C                     MOVELA2STRR    W1STRR
     C                     MOVELA2STRD    W1STRD
     C                     Z-ADDA2GEHZ    W1GEHZ
     C                     ENDIF
     C                     MOVEL*BLANK    C1STRK  1
     C                     MOVEL*BLANK    C1STRT  2
     C                     MOVEL*BLANK    C1STRR  2
     C                     MOVEL*BLANK    C1STRD  1
     C           KEYFC1    CHAINAAMPL111             25
     C           *IN25     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELCKSTRK    C1STRK
     C                     MOVELCKSTRT    C1STRT
     C                     MOVELCKSTRR    C1STRR
     C                     MOVELCKSTRD    C1STRD
     C                     ENDIF
      *
     C                     Z-ADD0         CNT     30
     C           KEYFC1    SETLLFCEPP401
     C           KEYFC1    READEFCEPP401                 25
     C           *IN25     DOWEQ'0'
     C           F4GSKD    IFEQ 'D'
     C           F4GSDT    ANDLE*DATE
     C                     ELSE
     C                     MOVEL*BLANK    @4PRT1  5
     C                     MOVEL*BLANK    @4PRT2  5
     C                     MOVEL*BLANK    @4PRT3  2
     C                     MOVELF4PRT1    @4PRT1
     C                     MOVELF4PRT2    @4PRT2
     C                     MOVELF4PRT3    @4PRT3
     C                     ADD  1         CNT     30
     C                     EXSR #SB002
     C                     ENDIF
     C           KEYFC1    READEFCEPP401                 25
     C                     ENDDO
      *
     C*          CNT       IFEQ 0
     C*                    MOVEL*BLANK    @4PRT1  5
     C*                    MOVEL*BLANK    @4PRT2  5
     C*                    MOVEL*BLANK    @4PRT3  2
     C*                    MOVEL*BLANK    WWSTRK  1
     C*                    MOVEL*BLANK    WWSTRT  2
     C*                    MOVEL*BLANK    WWSTRR  2
     C*                    MOVEL*BLANK    WWSTRD  1
     C*                    Z-ADD0         WWGEHZ  80
     C*                    Z-ADD0         @4GEKN  90
     C*                    Z-ADD0         @4NSRY  90
     C*                    Z-ADD0         @4BOXD  61
     C*                    Z-ADD0         @4NBXD  61
     C*                    Z-ADD0         @4BOXP  62
     C*                    Z-ADD0         @4BOXS  61
     C*                    EXCPTDT
     C*                    ENDIF
      *
     CSR         ESB001    ENDSR
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB002    BEGSR
      *
     C           KEYFCE    KLIST
     C                     KFLD           @4PRT1
     C                     KFLD           @4PRT2
     C                     KFLD           @4PRT3
     C                     MOVEL*BLANK    WWSTRK  1
     C                     MOVEL*BLANK    WWSTRT  2
     C                     MOVEL*BLANK    WWSTRR  2
     C                     MOVEL*BLANK    WWSTRD  1
     C                     Z-ADD0         WWGEHZ  80
     C           *IN25     IFEQ '0'
     C           KEYFCE    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELA2STRK    WWSTRK
     C                     MOVELA2STRT    WWSTRT
     C                     MOVELA2STRR    WWSTRR
     C                     MOVELA2STRD    WWSTRD
     C                     Z-ADDA2GEHZ    WWGEHZ
     C                     ENDIF
     C                     ENDIF
      *
     C           CNT       IFGE 2
     C                     MOVEL*BLANK    W1STRK
     C                     MOVEL*BLANK    W1STRT
     C                     MOVEL*BLANK    W1STRR
     C                     MOVEL*BLANK    W1STRD
     C                     Z-ADD0         W1GEHZ
     C                     MOVEL*BLANK    W0SHN1
     C                     MOVEL*BLANK    W0SHN2
     C                     MOVEL*BLANK    W0SHN3
     C                     Z-ADD0         W0SSYS
     C                     Z-ADD0         W0GEKN
     C                     Z-ADD0         W0NSRY
     C                     Z-ADD0         W0BOXD
     C                     Z-ADD0         W0NBXD
     C                     Z-ADD0         W0BOXP
     C                     Z-ADD0         W0BOXS
     C                     ENDIF
      *
     C           KEY21     KLIST
     C                     KFLD           W0NTYM
     C                     KFLD           @4PRT1
     C                     KFLD           @4PRT2
     C                     KFLD           @4PRT3
     C                     Z-ADD0         @4GEKN  90
     C                     Z-ADD0         @4NSRY  90
     C                     Z-ADD0         @4BOXD  61
     C                     Z-ADD0         @4NBXD  61
     C                     Z-ADD0         @4BOXP  62
     C                     Z-ADD0         @4BOXS  61
     C           KEY21     CHAINABMPL211             46
     C           *IN46     IFEQ '0'
     C                     Z-ADDS4GEKN    @4GEKN
     C                     Z-ADDS4NSRY    @4NSRY
     C                     Z-ADDS4BOXD    @4BOXD
     C                     Z-ADDS4NBXD    @4NBXD
     C                     Z-ADDS4BOXP    @4BOXP
     C           S4NBXD    SUB  S4BOXD    @4BOXS
     C                     ENDIF
      *
     C                     EXCPTDT
      *
     CSR         ESB002    ENDSR
