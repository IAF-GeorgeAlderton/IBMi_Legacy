     F** ABBR80 ********************************************
     F*   .. PRIORITY KANBAN LIST ..                       *
     F* CODING:K.OKACHI    2002/06/06                      *
     F******************************************** ABBR80 **
     FINPUT1  IP  F     512            DISK
     FOUTPUT1 O   F     512            DISK
      *
     IINPUT1  AA
     I                                        1 512 IDATA
     I                                       45  50 ITKRO L1
     I                                       66  70 IPRT1 L2
     I                                       71  75 IPRT2 L2
     I                                       76  77 IPRT3 L2
     I                                       82  890IISDT
     I                                      115 115 IAPKB
      *
     C           *INL1     IFEQ '1'
     C                     ADD  1         CNT
     C                     END
     C           IAPKB     IFEQ *BLANK
     C                     MOVE *BLANK    WAPKB
     C                     END
     C           IISDT     IFNE 0
     C           IISDT     ANDLTWISDT
     C                     Z-ADDIISDT     WISDT
     C                     END
     CL2                   EXSR #SB100
      *-----------------------------------------------------*
     C           *INZSR    BEGSR
     C                     Z-ADD99999999  WISDT   80
     C                     MOVE '9'       WAPKB   1
     C                     Z-ADD0         CNT     30
     C                     ENDSR
      *-----------------------------------------------------*
     C           #SB100    BEGSR
     C           WISDT     IFEQ 99999999
     C                     Z-ADD0         WISDT
     C                     END
     C           CNT       IFGE 2
     C                     EXCPTDTA
     C                     END
     C                     Z-ADD0         CNT
     C                     Z-ADD99999999  WISDT
     C                     MOVE '9'       WAPKB
     C           ESB100    ENDSR
     OOUTPUT1 E                DTA
     O                         IDATA    512
     O                         WISDT     89
     O                         WAPKB    115
