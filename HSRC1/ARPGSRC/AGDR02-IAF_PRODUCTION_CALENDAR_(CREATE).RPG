      *******
     C           KEY1      KLIST
     C                     KFLD           NEN
     C                     KFLD           TSUKI
      *--------------------------------------*
      *             ﾎﾟﾜhﾞ[w ﾇj-n             *
      *--------------------------------------*
     C                     TIME           SDATE
JW2  C                     MOVELOVPF      XFILE
      *
JW2  C                     SELEC
 .   C           OV2       WHEQ 'A@'
 .   C                     MOVELTITL@     XTITL
 .   C           OV2       WHEQ 'A$'
 .   C                     MOVELTITL$     XTITL
 .   C           OV2       WHEQ 'A#'
 .   C                     MOVELTITL#     XTITL
 .   C                     OTHER
 .   C                     MOVELTITL      XTITL
JW2  C                     ENDSL
      *
     C                     Z-ADDYYMM      @NENG
     C           STP1      TAG
      *
     C           @KAISI    IFEQ 0
JW1  C                     Z-ADD1         @KAISI
     C                     ENDIF
      *
     C           @OWARI    IFEQ 0
     C                     SELEC
     C           TSUKI     WHEQ 01
     C           TSUKI     OREQ 03
     C           TSUKI     OREQ 05
     C           TSUKI     OREQ 07
     C           TSUKI     OREQ 08
     C           TSUKI     OREQ 10
     C           TSUKI     OREQ 12
     C                     Z-ADD31        @OWARI
      *
     C           TSUKI     WHEQ 04
     C           TSUKI     OREQ 06
     C           TSUKI     OREQ 09
     C           TSUKI     OREQ 11
     C                     Z-ADD30        @OWARI
      *
     C           TSUKI     WHEQ 02
     C                     Z-ADD28        @OWARI
     C                     ENDSL
     C                     ENDIF
      * GET DAY
     C           @YOBI     IFEQ 0
JW   C                     MOVEL@NENG     $DATE
     C                     MOVE @KAISI    $DATE
     C                     CALL 'UTLR02D'
     C                     PARM           $DATE   8
     C                     PARM           $DAY    1
 .   C                     PARM           $WEEK#  1
 .   C                     PARM           $RTN    1
 .   C                     MOVEL$DAY      @YOBI
JW   C                     ENDIF
      *
     C           STEP1     TAG
     C           NO1       IFEQ '1'
     C                     SETON                     08
     C                     END
     C           NO1       IFEQ '2'
     C                     SETOF                     08
     C                     END
      *--------------------------------------*
      *            １画面表示              *
