     O                                   37 'ITEM #'
     O                                   48 'ORDER DATE'
     O                                   53 'QTY.'
     O                                   67 'QTY./BOX'
     O                                   72 'BOX'
     O                                   78 'CRT'
     O                                   87 'DELIVERY'
     O                                   95 'QTY.'
