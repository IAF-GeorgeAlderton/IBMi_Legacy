     H            Y.                                    1
      ** GDGR37 *******************
      *  PRINT NON-DELIVERY LIST  *
      *  K.YASUDA    2000.10.30   *
      *  N.HYOTO     2001.03.09   *
      *  K.KASHIWAGI 2001.03.15   *
      ******************* GDGR37 **
     FGDGWP36 IP  F     128            DISK
     FGDGPL25 IF  E           K        DISK
     FQPRINT  O   F     158     OF     PRINTER
      *
     IGDGWP36 AA  01
     I                                        1   5 IHIN1 L2
     I                                        6  10 IHIN2 L2
     I                                       11  12 IHIN3 L2
     I                                       13  180IODER L1
     I                                       13  14 IODR1
     I                                       15  16 IODR2
     I                                       17  18 IODR3
     I                                       19  230IITEM L1
     I                                       24  310IODHZ
     I                                       32  380ISYOS
     I                                       39  430IMAIS
     I                                       44  500ISURY
      *
     I                                       51  51 IHANY
     I                                       52  590IDLHZ
      *
      *
     I            DS
     I                                        1   80IESKHZ
     I                                        1   40IESKYY
     I                                        5   60IESKMM
     I                                        7   80IESKDD
     I            DS
     I                                        1   80IESOHZ
     I                                        1   40IESKOY
     I                                        5   60IESKOM
     I                                        7   80IESKOD
     I            DS
     I                                        1   80IENYHZ
     I                                        1   40IENYUY
     I                                        5   60IENYUM
     I                                        7   80IENYUD
     I            DS
     I                                        1   6 IEINVO
     I                                        1   2 IIVO1
     I                                        3   6 IIVO2
     I           SDS
     I                                        1   8 @PGMID
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C                     MOVE *BLANK    WUSER   9
     C                     MOVE *BLANK    WUSME  15
     C                     CALL 'APLR00'
     C                     PARM           US
     C                     PARM           WUSME
     C                     MOVELWUSME     WUSER
      *-----*
      * KEY *
      *-----*
     C           KEY       KLIST
     C                     KFLD           IODER
     C                     KFLD           IITEM
      *-----*
      * INZ *
      *-----*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     Z-ADD0         GSKSU   70
     C                     Z-ADD0         GSKHK   30
     C                     Z-ADD0         GRESU   70
     C                     Z-ADD0         GREHK   30
     C                     Z-ADD0         GMISU   70
     C                     Z-ADD0         GMIHK   30
     C                     TIME           WTIME   60
     C                     MOVE *BLANK    MINO    1
     C                     MOVE *BLANK    GHANY   1
     C                     EXCPTHD
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
      *
     C           *INL2     IFEQ '1'
     C           *IN50     ANDEQ'1'
     C                     EXCPTDT1
     C                     END
     C                     SETON                     50
      *----------------------*
      * SHIPPING INFORMATION *
      *----------------------*
     C           KEY       SETLLGDGPL25
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY       READEGDGPL251                 10
     C           *IN10     IFEQ '0'
     C           IESKJY    IFEQ 'D'
     C           IESKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE IEHANY    GHANY
      *
     C           IENYUK    IFEQ *BLANK
     C                     ADD  IESURY    GSKSU
     C                     ELSE
     C                     ADD  IESURY    GSKSU
     C                     ADD  IESURY    GRESU
     C                     END
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
      *
     C                     ADD  ISURY     SSURY   80
     C                     ADD  GSKSU     SSKSU   80
     C                     ADD  GRESU     SRESU   80
      *
     C                     ADD  ISURY     TSURY   80
     C                     ADD  GSKSU     TSKSU   80
     C                     ADD  GRESU     TRESU   80
      *
     CL1         ISURY     SUB  GSKSU     GMISU
     CL1         GMISU     IFGT 0
     CL1                   MOVEL'*'       MINO
     CL1                   END
     CL1         IESYOS    IFNE 0
     CL1         GSKSU     DIV  IESYOS    GSKHK
     CL1         GRESU     DIV  IESYOS    GREHK
     CL1         GMISU     DIV  IESYOS    GMIHK
     CL1                   END
     CL1                   EXCPTDT2
     CL1                   MOVE *BLANK    MINO
     CL1                   Z-ADD0         GSKSU
     CL1                   Z-ADD0         GSKHK
     CL1                   Z-ADD0         GRESU
     CL1                   Z-ADD0         GREHK
     CL1                   Z-ADD0         GMISU
     CL1                   Z-ADD0         GMIHK
     CL2                   EXCPTSTOT
     CL2                   Z-ADD*ZERO     SSURY
     CL2                   Z-ADD*ZERO     SSKSU
     CL2                   Z-ADD*ZERO     SRESU
     CLR                   EXCPTTTOT
     OQPRINT  E  103           HD
     O                                  151 '.....................'
      *
     O        E  1             HD
     O                                  151 '.         .         .'
      *
     O        E  1             HD
     O                         @PGMID    11
     O                                  109 'TIME'
     O                         WTIME    118
     O                                  131 '.'
     O                                  141 '.'
     O                         WUSER    150
     O                                  151 '.'
      *
     O        E  1             HD
     O                                   64 '** ORDER HISTORY LIST **'
     O                                  109 'DATE'
     O                         UDATE    118 '  .  .  '
     O                                  124 'PAGE'
     O                         PAGE  Z  128
     O                                  151 '.....................'
      *
     O        E  1             HD
     O                                   20 'ORDER INFORMATION'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   75 '---------------'
     O                                   88 '-------------'
     O                                  107 'SIHP INFO-------'
     O                                  126 'RECEIVE INFO----'
     O                                  148 'NON-DELI INFO------'
