TCHK2C           F8YOBI    ANDEQ7
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
     C                     READ AGDPL121                 44
TCHK2C           W@NXTD    IFEQ 99999999
TCHK2C           W@YOBI    IFEQ 1
TCHK2C           F8YOBI    ANDEQ3
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           W@YOBI    IFEQ 4
TCHK2C           F8YOBI    ANDEQ7
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
     C                     READ AGDPL121                 44
TCHK2C           W@NXTD    IFEQ 99999999
TCHK2C           W@YOBI    IFEQ 1
TCHK2C           F8YOBI    ANDEQ3
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           W@YOBI    IFEQ 4
TCHK2C           F8YOBI    ANDEQ7
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
     C                     READ AGDPL121                 44
TCHK2C           W@NXTD    IFEQ 99999999
TCHK2C           W@YOBI    IFEQ 1
TCHK2C           F8YOBI    ANDEQ3
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           W@YOBI    IFEQ 4
TCHK2C           F8YOBI    ANDEQ7
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
     C                     READ AGDPL121                 44
TCHK2C           W@NXTD    IFEQ 99999999
TCHK2C           W@YOBI    IFEQ 1
TCHK2C           F8YOBI    ANDEQ3
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           W@YOBI    IFEQ 4
TCHK2C           F8YOBI    ANDEQ7
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
TCHK2C                     ENDDO
     C*
     C                     WRITEABAWTAF1
     C                     MOVE '1'       PID
     C*
     C                     ENDDO
