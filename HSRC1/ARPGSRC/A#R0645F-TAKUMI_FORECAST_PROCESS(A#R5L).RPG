     H            Y.
     F** AB#R5L ********************************************
     F*  TAKUMI FORECAST PROCESSING                        *
     F*                                                    *
     F* TCHK1 05/08/06 CREATE                              *
     F* TCHK2 05/27/09 CHG FORMATTE                        *
     F* TCHK3 08/14/13 CHG FORMATTE                        *
     F* T.SAKAKI 09/03/2015 CHG FORMAT FROM 3DAYS TO 5DAYS %0001 *
     F******************************************************
     FTAKUMI  IP  F    3000            DISK
     FABAWTAF O   E                    DISK
     FAGDPL12 IF  E           K        DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    DAT       100  8 0
     E                    QTY       100  9 0
     E                    A2          2  1
     E                    A6          6  1
     E                    A6X         6  1
     E                    A8          8  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    A15        15  1
      *--------------------------------------------------------
     ITAKUMI  AA  01
     I                                        1   4 SEQN
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 780 DAT3
     I            DS
     I                                        1   80YMD
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   8 DAY
     I            DS
     I                                        1  15 AWMHIN
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
     I            DS
     I                                        1   80WWENDD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     C                     Z-ADD1         X
     C                     MOVEADAT1      AY,X
     C                     ADD  256       X       50
     C                     MOVEADAT2      AY,X
     C                     ADD  256       X       50
     C                     MOVEADAT3      AY,X
      *
      * HEADER
     C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X
     C           '/'       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADD*ZERO     X
TCHK3C*                    DO   3
TCHK3C***                  DO   7
%0001C                     DO   9
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ENDDO
      *
     C                     Z-ADDX         Z       50
     C                     Z-ADD*ZERO     Y       50
     C                     Z-ADD*ZERO     I       50
     C                     Z-ADD*ZERO     DAT
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
      *
     C                     MOVEL*ZERO     YMD
     C                     Z-ADDX         Z
     C* MM
     C                     ADD  1         Z
     C           '/'       LOKUPAY,Z                     10
     C  N10                LEAVE
     C           Z         SUB  2         Y
     C                     MOVEAAY,Y      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      MONTH
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      MONTH
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      MONTH
     C                     END
     C                     END
     C* DD
     C                     ADD  1         Z
     C           '/'       LOKUPAY,Z                     10
     C  N10                LEAVE
     C           Z         SUB  2         Y
     C                     MOVEAAY,Y      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      DAY
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      DAY
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      DAY
     C                     END
     C                     END
     C* YY
     C           Z         ADD  1         Y
     C                     MOVEAAY,Y      W@A4    4
     C                     MOVELW@A4      YEAR
      *
     C                     ADD  1         I
     C                     Z-ADDYMD       DAT,I
     C  N99                MOVE *ON       *IN99
      *
     C                     ENDDO
      *
     C                     GOTO @END
      *
     C                     END
     C*
     C* DETAIL
     C                     Z-ADD*ZERO     W       50
     C*
     C* PART NUMBER
     C                     Z-ADD1         X
     C           '-'       LOKUPAY,X                     10
     C  N10                GOTO @END
     C*
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     Z-ADDX         Z
      *
     C                     MOVE *BLANK    A15
     C                     Z-ADD*ZERO     Y
     C                     DO   Z         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     ENDIF
     C           AY,X      IFEQ '-'
     C                     ITER
     C                     ENDIF
     C                     ADD  1         Y
     C                     MOVE AY,X      A15,Y
     C                     ENDDO
      *
     C                     MOVEAA15       AWMHIN    P
      *
      * KANBAN#
     C                     MOVEL*BLANK    AWSBAN
      * QTY/BOX
     C                     Z-ADD*ZERO     AWSYOS
     C*
     C* QTY
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     W
     C                     MOVE *BLANK    A9
     C                     Z-ADD*ZERO     QTY
      *
TCHK3C                     Z-ADD*ZERO     X
TCHK3C****                 DO   7
%0001C                     DO   9
TCHK3C                     ADD  1         X
TCHK3C           ','       LOKUPAY,X                     10
TCHK3C  N10                GOTO @END
TCHK3C                     ENDDO
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C*
     C                     Z-ADDX         Z
     C                     Z-ADD*ZERO     W
     C                     MOVEL*BLANK    A9
      *
     C                     DO   *HIVAL
     C                     ADD  1         Z
     C           AY,Z      IFEQ ','
     C           AY,Z      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         W
     C                     MOVELAY,Z      A9,W
     C                     ENDDO
      *
     C                     MOVE '0'       A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V       30
     C                     DO   9
     C           A9,W      IFNE *BLANK
     C                     MOVE A9,W      A9X,V
     C                     SUB  1         V
     C                     END
     C                     SUB  1         W
     C           W         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C*
     C                     ADD  1         I
     C                     Z-ADD@9        QTY,I
     C*
     C                     ENDDO
     C*
     C                     XFOOTQTY       W@QTY   90
     C           W@QTY     IFNE *ZERO
     C                     Z-ADD0645      AWTOKU
     C                     Z-ADD0645      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
     C                     MOVEL'0503'    AWORDN    P
      *
     C                     DO   100       I
     C           DAT,I     IFEQ *ZERO
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADDQTY,I     AWSRYO
     C                     Z-ADDDAT,I     AWSTRD
     C                     Z-ADDDAT,I     YMD
      * FOR END   DATE
     C                     MOVE '0'       *IN44
     C                     MOVELYEAR      NAYY
     C                     MOVELMONTH     NAMM
     C                     MOVELDAY       NADD
TCHK2C           I         ADD  1         K       50
TCHK2C           K         IFGT 100
TCHK2C                     Z-ADD99999999  W@NXTD  80
TCHK2C                     ELSE
TCHK2C                     Z-ADDDAT,K     W@NXTD
TCHK2C           W@NXTD    IFEQ *ZERO
TCHK2C                     Z-ADD99999999  W@NXTD
TCHK2C                     END
TCHK2C                     END
     C           KEY3      KLIST
     C                     KFLD           NAYY    40
     C                     KFLD           NAMM    20
     C                     KFLD           NADD    20
     C           KEY3      SETLLAGDPL121
     C                     READ AGDPL121                 44
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
TCHK2C                     Z-ADDF8YOBI    W@YOBI  10
TCHK2C                     DO
     C                     READ AGDPL121                 44
TCHK2C           W@NXTD    IFEQ 99999999
TCHK2C           W@YOBI    IFEQ 1
TCHK2C           F8YOBI    ANDEQ3
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           W@YOBI    IFEQ 4
TCHK2C           F8YOBI    ANDEQ7
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C           WWENDD    IFLT W@NXTD
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     END
     C                     READ AGDPL121                 44
TCHK2C           W@NXTD    IFEQ 99999999
TCHK2C           W@YOBI    IFEQ 1
TCHK2C           F8YOBI    ANDEQ3
TCHK2C                     Z-ADDWWENDD    AWENDD
TCHK2C                     LEAVE
TCHK2C                     END
