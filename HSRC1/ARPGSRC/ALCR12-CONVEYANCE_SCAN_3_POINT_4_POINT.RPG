      *
      *-------------------------*
      * AAMPL11
      *-------------------------*
     C           K#KEY     CHAINAAMPL11              90
S1   C           *IN90     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     $$ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVE '07'      $$ERR
     C                     MOVE '07'      F99ER1
     **** M/F NOT FOUND                    #04
     C                     MOVELERR,4     F99ER2
     C                     GOTO $KAN99
E1   C                     ENDIF
      *
      *
      * check to see if it's a washer, if so set on w-rack flag...
     C                     MOVE *OFF      WRACKF  1
     C           2         SUBST$$SHN1:1  SHN12   2
     C           SHN12     IFEQ 'AA'
     C                     MOVE *ON       WRACKF
     C           WWZETI    CHAINFCETL11              81
     C           *IN81     IFEQ *OFF
     C                     MOVELA21HB5    W@SHN1  5
     C                     MOVELA22HB5    W@SHN2  5
     C                     MOVELA23HB2    W@SHN3  2
     C                     ENDIF
     C                     ENDIF
      *
      *
      *-------------------------*
     C           $KAN99    ENDSR
      *
      *----------------------------------------------------*
      * ABHPP01
      *----------------------------------------------------*
     CSR         #ABH01    BEGSR
      *
     C           KEYM6     KLIST
     C                     KFLD           #KKSNK  10
     C                     KFLD           #KZETI  4
     C                     KFLD           #KATOH  20
     C                     KFLD           #KATYP  1
      *
     C           KEYM6     SETGTABHPL071
     C           KEYM6     REDPEABHPL071                 87
1    C           *IN87     DOWEQ'0'
|2   C           M6SKJY    IFEQ 'D'
||   C           M6SKHZ    ANDLEW@DATE
|2   C                     ELSE
||   C***        M6UKHZ    IFLE W@DATE
||   C***        M6STHZ    ANDGTW@DATE
||3  C           M6AKT1    IFEQ W$BA9B
|||  C           M6AKT2    OREQ W$BA9B
|||  C           M6AKT3    OREQ W$BA9B
|||  C           M6AKT4    OREQ W$BA9B
|||  C                     MOVELM6JBN1    W$JBN1  1
|||  C                     MOVELM6JBN2    W$JBN2  2
|||  C                     MOVELM6JBN3    W$JBN3  2
|||  C                     MOVELM6JBN4    W$JBN4  1
|||  C                     MOVELWJBN      OLO,1
|||  C                     MOVELWJBNT     OLOT,1
|||  C                     MOVE M6BMON    W$DEPT  4
|||  C                     MOVELM6MTK1    W$MTK1  1
|||  C                     MOVELM6MTK2    W$MTK2  2
|||  C                     MOVELM6MTK3    W$MTK3  2
|||  C                     MOVELM6MTK4    W$MTK4  1
|||  C                     MOVELWMTK      PLO,1
|||  C                     MOVELWMTKT     PLOT,1
|||  C                     MOVE '000'     W@HKSU
|||  C                     MOVE M6LOTK    W@HKSU
|||  C                     LEAVE
||3  C                     ENDIF
||   C***                  ENDIF
|2   C                     ENDIF
|    C           KEYM6     REDPEABHPL071                 87
1    C                     ENDDO
      *
      *
     CSR         EABH01    ENDSR
      *----------------------------------------------------*
      * ADHPP01
      *----------------------------------------------------*
     CSR         #ADH01    BEGSR
      *
     C           K#KEY     SETGTADHTL051
     C           K#KEY     REDPEADHTL051                 87
1    C           *IN87     DOWEQ'0'
|2   C           J6SKJY    IFEQ 'D'
||   C           J6SKHZ    ANDLEW@DATE
|2   C                     ELSE
||   C***        J6UKHZ    IFLE W@DATE
||   C***        J6STHZ    ANDGTW@DATE
||   C**
||   C           Z         IFGT 3
||   C                     LEAVE
||   C                     ENDIF
||   C**
||   C                     MOVELJ6ATK1    W$JBN1  1
||   C                     MOVELJ6ATK2    W$JBN2  2
||   C                     MOVELJ6ATK3    W$JBN3  2
||   C                     MOVELJ6ATK4    W$JBN4  1
||   C                     MOVELWJBN      OLO,Z
||   C                     MOVELWJBNT     OLOT,Z
||   C                     MOVE J6ATOB    W$DEPT  4
||   C                     MOVELJ6MTK1    W$MTK1  1
||   C                     MOVELJ6MTK2    W$MTK2  2
||   C                     MOVELJ6MTK3    W$MTK3  2
||   C                     MOVELJ6MTK4    W$MTK4  1
||   C                     MOVELWMTK      PLO,Z
||   C                     MOVELWMTKT     PLOT,Z
||   C                     MOVE '000'     W@HKSU
||   C                     MOVE J6LOTO    W@HKSU
||   C                     ADD  1         Z
||   C***                  LEAVE
||   C***                  ENDIF
|2   C                     ENDIF
|    C**
|    C           K#KEY     REDPEADHTL051                 87
1    C                     ENDDO
      *
     CSR         EADH01    ENDSR
      *----------------------------------------------------*
      * AAFPP01 & AAHPP01
      *----------------------------------------------------*
     CSR         #AFH01    BEGSR
      *
     C                     MOVEL'0'       GETKAN  1
      *
     C                     SETOF                         83
     C           K#KEY     SETGTAAFTL061
     C           K#KEY     REDPEAAFTL061                 83
     C           *IN83     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLEW@DATE
     C                     ELSE
     C           A3UKHZ    IFLE W@DATE
     C           A3STHZ    ANDGTW@DATE
     C           FCHK      IFEQ 'P'
     C           A3ATK1    ANDEQ'1'
     C                     MOVEL'1'       GETKAN
     C                     MOVEL'P'       W@KID   1        PLASTIC
     C                     MOVELA3ATK1    W$JBN1  1
     C                     MOVELA3ATK2    W$JBN2  2
     C                     MOVELA3ATK3    W$JBN3  2
     C                     MOVELA3ATK4    W$JBN4  1
     C                     MOVELWJBN      OLO,Z
     C                     MOVELWJBNT     OLOT,Z
     C                     MOVE A3ATOB    W$DEPT  4
     C                     MOVELA3MTK1    W$MTK1  1
     C                     MOVELA3MTK2    W$MTK2  2
     C                     MOVELA3MTK3    W$MTK3  2
     C                     MOVELA3MTK4    W$MTK4  1
     C                     MOVELWMTK      PLO,Z
     C                     MOVELWMTKT     PLOT,Z
     C                     ADD  1         Z
     C                     ENDIF
     C           FCHK      IFNE 'P'
     C           A3ATK1    ANDEQ'0'
     C                     MOVEL'1'       GETKAN
     C                     MOVELA3ATK1    W$TBN1  1
     C                     MOVELA3ATK2    W$TBN2  2
     C                     MOVELA3ATK3    W$TBN3  2
     C                     MOVELA3ATK4    W$TBN4  1
     C                     MOVELWJBN      OLO,Z
     C                     MOVELWJBNT     OLOT,Z
     C                     MOVE A3ATOB    W$DEPT  4
     C                     MOVELA3MTK1    W$MTK1  1
     C                     MOVELA3MTK2    W$MTK2  2
     C                     MOVELA3MTK3    W$MTK3  2
     C                     MOVELA3MTK4    W$MTK4  1
     C                     MOVELWMTK      PLO,Z
     C                     MOVELWMTKT     PLOT,Z
     C                     ADD  1         Z
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           K#KEY     REDPEAAFTL061                 83
     C                     ENDDO
      *
      *
     C           GETKAN    IFNE '1'
     C                     SETOF                         83
     C           K#KEY     SETGTAAHTL061
     C           K#KEY     REDPEAAHTL061                 83
     C           *IN83     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLEW@DATE
     C                     ELSE
     C           L6UKHZ    IFLE W@DATE
     C           L6STHZ    ANDGTW@DATE
     C                     MOVEL'1'       GETKAN
     C                     MOVELL6ATK1    W$TBN1  1
     C                     MOVELL6ATK2    W$TBN2  2
     C                     MOVELL6ATK3    W$TBN3  2
     C                     MOVELL6ATK4    W$TBN4  1
     C                     MOVELWJBN      OLO,1
     C                     MOVELWJBNT     OLOT,1
     C                     MOVE L6ATOB    W$DEPT  4
     C                     MOVELL6MTK1    W$MTK1  1
     C                     MOVELL6MTK2    W$MTK2  2
     C                     MOVELL6MTK3    W$MTK3  2
     C                     MOVELL6MTK4    W$MTK4  1
     C                     MOVELWMTK      PLO,1
     C                     MOVELWMTKT     PLOT,1
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C           K#KEY     REDPEAAHTL061                 83
     C                     ENDDO
     C                     ENDIF
      *
     CSR         EAFH01    ENDSR
      *----------------------------------------------------*
      *  CHECK PARTIAL COMBINE KANBAN ISSUE LOG
      *----------------------------------------------------*
     CSR         #COMBI    BEGSR
      *
     C           AJKEY     KLIST
     C                     KFLD           W$BA25
     C                     KFLD           W$BA68
     C                     KFLD           W$BA9A
      *
     C                     MOVEL*BLANK    FCHK    1
      *
     C           W$BACC    IFNE '5'
      *
     C                     SETOF                         83
     C           AJKEY     SETGTAJZPL331
     C           AJKEY     REDPEAJZPL331                 83
     C           *IN83     DOWEQ'0'
     C*
     C* PLASTIC
     C           J1APPL    IFEQ 'P'                        COMBINED
     C           J1APPL    OREQ '2'                        EXTRA
     C                     MOVEL'P'       FCHK
     C                     LEAVE
     C                     ENDIF
     C* A-PICS
     C           J1APPL    IFEQ 'A'                        COMBINED
     C           J1APPL    OREQ '1'                        EXTRA
     C                     MOVEL'A'       FCHK
     C                     LEAVE
     C                     ENDIF
     C*
     C           J1BAN1    IFEQ '1'                        LOC1
     C                     MOVEL'P'       FCHK
     C                     LEAVE
     C                     ENDIF
     C           J1BAN1    IFEQ '0'                        LOC1
     C                     MOVEL'A'       FCHK
     C                     LEAVE
     C                     ENDIF
     C*
     C           AJKEY     REDPEAJZPL331                 83
     C                     ENDDO
      *
     C                     ENDIF
      *
      * NOT FOUND THEN JUDGE BY PAGE NO.
     C           FCHK      IFEQ *BLANK
     C           W$BA67    IFEQ '99'
     C                     MOVEL'P'       FCHK
     C                     ELSE
     C                     MOVEL'A'       FCHK
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ECOMBI    ENDSR
      *----------------------------------------------------*
%0001 *  CHECK P/T RETRIEVAL SCAN FILE
      *----------------------------------------------------*
     CSR         #CHKAR    BEGSR
      *
     C                     TIME           WSDT
      * CHECK DUPLICATED SCAN TO RETRIEVAL KANBAN
      *  GET DATE & TIME 3 HOURS AGO
     C                     MOVE WSSDAT    PIYMD   8
     C                     MOVE WSSTM6    PIJFB   6
     C                     MOVEL*BLANK    POYMD   8
     C                     MOVEL*BLANK    POJFB   6
     C                     MOVEL'-'       PFUGO   1
     C                     MOVEL'00180'   PFUN    5
     C                     CALL 'DATR45'
     C                     PARM           PIYMD
     C                     PARM           PIJFB
     C                     PARM           POYMD
     C                     PARM           POJFB
     C                     PARM           PFUGO
     C                     PARM           PFUN
      *
     C                     MOVE POYMD     K1DATE
     C                     MOVE POJFB     K1TIME
     C                     MOVELF4BAR     K1BAR
      *
     C           K#KEY1    KLIST
     C                     KFLD           K1BAR  20
     C                     KFLD           K1DATE  80
     C                     KFLD           K1TIME  60
      *
     C           K#KEY1    SETLLALRPL0A1
     C                     DO   *HIVAL
     C           K1BAR     READEALRPL0A1                 84
     C   84                LEAVE
      *
     C           PTSKJY    IFNE *BLANK
     C           PTOKNG    OREQ 'NG'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'E'       ARCHK
     C                     LEAVE
     C                     ENDDO
      *
     CSR         ECHKAR    ENDSR
      *================================================================********
%0001 *   WRITE ALRPP05  P.T. RETRIEVAL SCAN RESULT
      *================================================================********
     C           #WRTAR    BEGSR
     C*
     C                     TIME           WSDT
     C                     CLEARALRPP051
     C                     Z-ADDWSSDAT    PTKODT
     C                     Z-ADDWSSTM6    PTKOTM
     C                     MOVEL#WSID     PTWSID
     C                     MOVEL#USER     PTUSER
     C                     MOVEL#JBNO     PTJOBN
     C                     MOVEL#PGM      PTKOPG
     C                     MOVELF1USRC    PTWKCD
     C                     Z-ADDWSSDAT    PTCODT
     C                     Z-ADDWSSTM6    PTCOTM
      * apics
     C                     MOVELA8BRC1    PTABAR
     C                     MOVELW2SHN1    PTAHN1
     C                     MOVELW2SHN2    PTAHN2
     C                     MOVELW2SHN3    PTAHN3
     C           4         SUBSTPTABAR:2  PTAZET
     C           3         SUBSTPTABAR:6  PTTEHA
     C           2         SUBSTPTABAR:9  PTPAGE
     C           1         SUBSTC1T,1:1   PTABN1
     C           2         SUBSTC1T,1:2   PTABN2
     C           2         SUBSTC1T,1:4   PTABN3
     C           1         SUBSTC1T,1:6   PTABN4
      *
      * location
     C                     MOVELA8BRC2    PTLBAR
     C                     MOVELW2SHN1    PTLHN1
     C                     MOVELW2SHN2    PTLHN2
     C                     MOVELW2SHN3    PTLHN3
     C           4         SUBSTPTLBAR:1  PTLZET
     C           1         SUBSTPTLBAR:5  PTTBN1
     C           2         SUBSTPTLBAR:6  PTTBN2
     C           2         SUBSTPTLBAR:8  PTTBN3
     C           1         SUBSTPTLBAR:10 PTTBN4
      *
      * passthru
     C                     MOVELA8BRC3    PTPBAR
     C           4         SUBSTPTPBAR:2  PTPZET
     C                     MOVELW4SHN1    PTPHN1
     C                     MOVELW4SHN2    PTPHN2
     C                     MOVELW4SHN3    PTPHN3
     C                     MOVELPTTBN1    PTPBN1
     C                     MOVELPTTBN2    PTPBN2
     C                     MOVELPTTBN3    PTPBN3
     C                     MOVELPTTBN4    PTPBN4
      *
     C           6         SUBSTPTPBAR:6  PTODER
     C           1         SUBSTPTPBAR:12 PTPRCD
     C           4         SUBSTPTPBAR:13 PTLOTN
      *
     C                     MOVEL'OK'      PTOKNG
     C                     MOVEL*BLANK    PTERCD
     C                     WRITEALRPP051
     C*
     C           EWRTAR    ENDSR
      *================================================================*********
