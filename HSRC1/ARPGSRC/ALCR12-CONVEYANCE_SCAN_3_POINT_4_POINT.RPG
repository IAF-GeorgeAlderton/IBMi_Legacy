     I              '3 POINT SCAN'        C         $3P
     I              '4 POINT SCAN'        C         $4P
     I              '* READ KANBAN    *'  C         $1ST
     I              '* READ PRECEDING *'  C         $2ND1
     I              '* PROCESS KANBAN *'  C         $2ND2
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 20
     C                     PARM           WUSECT  1
      *
      *================================================================
      *                    MAIN ROUTINE
      *================================================================
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #FMT30
     C           @@ID      CASEQ'40'      #FMT40
     C           @@ID      CASEQ'50'      #FMT50
     C           @@ID      CASEQ'55'      #FMT55
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *================================================================
      *         INITIALIZE
      *================================================================
     C           *INZSR    BEGSR
      *
      * FOR KANBAN CHECK DEGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C           K#KEY     KLIST
     C                     KFLD           $$SHN1
     C                     KFLD           $$SHN2
     C                     KFLD           $$SHN3
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    W@DATE  80
     C                     Z-ADDWSSTM6    @@TIM   60
     C*
     C           K#AGDP    KLIST
     C                     KFLD           WSSYYY
     C                     KFLD           WSSMMM
     C                     KFLD           WSSDDD
     C                     Z-ADDWSSDAT    W@3BF
     C                     Z-ADDWSSDAT    W@3AF
     C*
     C           K#AGDP    CHAINAGDPL12              98
     C*
S1   C           *IN98     IFEQ *OFF
     C                     Z-ADD*ZERO     W@CNT   20
 S2  C                     DO   *HIVAL
     C                     READPAGDPL12                  97
     C   97                LEAVE
  S3 C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ITER
  E3 C                     END
     C                     Z-ADDF8KAYY    W@3BFY
     C                     Z-ADDF8KAMM    W@3BFM
     C                     Z-ADDF8KADD    W@3BFD
     C                     ADD  1         W@CNT
  S3 C           W@CNT     IFGE 3
     C                     LEAVE
  E3 C                     END
 E2  C                     ENDDO
E1   C                     ENDIF
     C*
     C           K#AGDP    CHAINAGDPL12              97
     C                     Z-ADD*ZERO     W@CNT   20
S1   C           *IN97     IFEQ *OFF
 S2  C                     DO   *HIVAL
     C                     READ AGDPL12                  97
     C   97                LEAVE
  S3 C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ITER
  E3 C                     END
     C                     Z-ADDF8KAYY    W@3AFY
     C                     Z-ADDF8KAMM    W@3AFM
     C                     Z-ADDF8KADD    W@3AFD
     C                     ADD  1         W@CNT
  S3 C           W@CNT     IFGE 3
     C                     LEAVE
  E3 C                     END
 E2  C                     ENDDO
E1   C                     ENDIF
     C*
     C                     CLEARFMT100
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
     C                     CLEARFMT550
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVEL*BLANK    W@ERR   1
     C*
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL'A'       @@K     1
     C                     MOVEL*OFF      W@CONV  1
     C* DUMMY READ
     C                     READ ALCPP01                  98
     C*
     C                     ENDSR
      *================================================================
      *     1ST SCREEN(TM-CODE ENTRY)   <<F1USRC>>
      *================================================================
     C           #FMT10    BEGSR
      *
      * if worker code was passed in, then use that code
      * if not, then display format to enter worker code.
     C           WORKER    IFEQ *BLANKS
     C                     EXFMTFMT100
     C                     ELSE
     C                     MOVELWORKER    F1USRC
     C                     ENDIF
      *
     C                     MOVEL*BLANK    F1ERR
      *
S1   C                     SELEC
-1   C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
-1   C                     OTHER
     C                     EXSR #CHK10
 S2  C           *IN99     IFEQ *OFF
     C                     MOVE '20'      @@ID
     C                     MOVELF1USRC    W@TMCD  6
     C           W@TMCD    LOKUPTM                       98:EQ
  S3 C           *IN98     IFEQ *OFF
     C                     MOVEL*ON       W@CONV
  X3 C                     ELSE
     C                     MOVEL*OFF      W@CONV
  E3 C                     END
 E2  C                     END
E1   C                     ENDSL
      *
     C                     ENDSR
      *================================================================
      *     1ST SCREEN CHECK
      *================================================================
     C           #CHK10    BEGSR
     C*
     C                     SETOF                     6199
     C* TM-CODE CHECK
     C           F1USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     6199
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,7     F1ERR
     C                     MOVE *BLANKS   WORKER
     C                     END
     C                     END
      *
     C                     ENDSR
      *================================================================
      *     2RD SCREEN(APICS/PLASTIC KANBAN)  <<F2BAR>>
      *================================================================
     C           #FMT20    BEGSR
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2SERR 16
     C                     MOVEL*BLANK    F2ERR
      *
S1   C                     SELEC
-1   C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
-1   C           *INKG     WHEQ *ON
     C*** NO MOVE
-1   C                     OTHER
     C                     EXSR #CHK20
     C**
 S2  C           *IN99     IFEQ *OFF
     C                     MOVEL*BLANK    F4MID1
     C                     MOVEL*BLANK    F4MID2
     C** 4 POINT SCAN
  S3 C           W@QR      IFEQ *ON
     C           W@AP      OREQ *ON
     C           W@INT     OREQ *ON
     C                     MOVE '30'      @@ID             :LOCATION
     C                     MOVE *BLANK    F3LOC
     C                     MOVEL$4P       F3MID
     C                     MOVEL$2ND1     F4MID1
     C                     MOVEL$2ND2     F4MID2
     C** 3 POINT SCAN
  X3 C                     ELSE
     C                     MOVE '40'      @@ID             :KANBAN QR
     C                     MOVE *BLANK    F4BAR
     C                     MOVEL$3P       F3MID
     C                     MOVEL$1ST      F4MID2
     C                     MOVEL*BLANK    F4LOC
     C           W@OQPL    IFEQ *ON
     C           3         SUBSTF2BAR:4   F4LOC
     C                     ELSE
     C                     MOVELF2BAR     F4LOC
     C                     ENDIF
  E3 C                     ENDIF
 X2  C                     ELSE
     C                     EXSR #WRTER
 E2  C                     ENDIF
     C**
E1   C                     ENDSL
      *
      *
     C           EFMT20    ENDSR
      *================================================================*********
      *     2RD SCREEN CHECK  -1
      *================================================================*********
     C           #CHK20    BEGSR
     C*
     C                     MOVE *OFF      ##TAP   1
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVELF2BAR     W$BAR
     C                     SETOF                     9961
      *-------------------------
S1   C                     DO
     C*
 S2  C           F2BAR     IFEQ *BLANK
     C                     SETON                     9961
