      *================================================================********
      *     5TH SCREEN(LOT ID TAG)
      *================================================================********
     C           #FMT50    BEGSR
     C*
     C                     EXFMTFMT500
     C                     MOVEL*BLANK    F5ERR
     C**
S1   C                     SELEC
-1   C           *INKC     WHEQ *ON
     C***********          MOVE '99'      @@ID
     C                     MOVE '40'      @@ID
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVEL*BLANK    F4BAR
     C**
-1   C           *INKG     WHEQ *ON
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
     C                     CLEARFMT550
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVE '20'      @@ID
     C**
-1   C           *INKE     WHEQ *ON
 S2  C           *IN66     IFEQ *ON
     C                     TIME           WSDT
     C                     EXSR #WRTOK
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
     C                     CLEARFMT550
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W3LOC
     C                     MOVEL*BLANK    W4SHIN
     C                     CLEARFMT200
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVE '20'      @@ID
     C                     EXFMTFMT900
 E2  C                     ENDIF
     C**
-1   C                     OTHER
     C*
     C                     EXSR #CHK50
     C*
 S2  C           *IN99     IFEQ *OFF
     C                     TIME           WSDT
     C                     EXSR #WRTOK
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W3LOC
     C                     MOVEL*BLANK    F4ERR
     C                     MOVEL*BLANK    F4BAR
     C                     MOVEL*BLANK    F5ERR
     C                     MOVEL*BLANK    F5LOT#
     C                     MOVEL*BLANK    W4SHIN
     C* 4 POINT
  S3 C           W@QR      IFEQ *ON
     C           W@AP      OREQ *ON
     C           W@INT     OREQ *ON
     C                     CLEARFMT200
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVE '20'      @@ID
     C                     EXFMTFMT900
     C* 3 POINT
  X3 C                     ELSE
     C                     MOVE '40'      @@ID
  E3 C                     ENDIF
 X2  C                     ELSE
     C                     EXSR #WRTER
 E2  C                     ENDIF
E1   C                     ENDSL
     C*
     C                     ENDSR
      *================================================================********
      *     5TH SCREEN CHECK
      *================================================================********
     C           #CHK50    BEGSR
     C*
     C                     SETOF                     9961
     C                     MOVEL*OFF      W@UNME  1
     C*
S1   C                     DO
     C*
 S2  C           F5LOT#    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,20    F5ERR
     C                     MOVELERR,20    F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
 E2  C                     ENDIF
     C*
     C                     MOVELF5LOT#    PMAREA    P
      *
     C           WRACKF    IFEQ *OFF
     C                     MOVE '007'     PMBYTE
     C           1         SUBSTF5LOT#:8  WKCHK   1
     C                     ELSE
     C                     MOVE '010'     PMBYTE
     C           1         SUBSTF5LOT#:11 WKCHK   1
     C                     ENDIF
      *
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
 S2  C           PMCHK     IFNE WKCHK
     C                     SETON                     9961
     C                     MOVELERR,20    F5ERR
     C                     MOVELERR,20    F99ER1
     **** CHECK DIGIT ERR                  #15
     C                     MOVELERR,15    F99ER2
     C                     LEAVE
 E2  C                     ENDIF
     C*
E1   C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
     C*
     C                     ENDSR
      *================================================================*********
      *     5TH SCREEN - 4 LOT IDS
      *================================================================********
     C           #FMT55    BEGSR
      *
     C                     MOVE *BLANKS   LOTIDS
     C                     MOVEALOTIDS    LOTS
      *
     C           *INKC     DOUEQ*ON
      *
     C                     EXFMTFMT550
     C                     MOVEL*BLANK    F5ERR
     C                     MOVE *OFF      *IN99
     C                     MOVE *OFF      *IN61
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVEL*BLANK    F4BAR
     C                     MOVE *BLANKS   LOTIDS
     C                     MOVEALOTIDS    LOTS
     C                     MOVE *BLANKS   F5LTID
     C                     MOVE *BLANKS   F5ERR
     C                     MOVEL'40'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK55
      *
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
      *
     C                     TIME           WSDT
     C                     MOVEALOTIDS    LOTS
      *
      * write out records with lot ids
     C                     DO   4         N       40
      *
     C           LOTS,N    IFNE *BLANK
     C                     MOVELLOTS,N    F5LOT#
     C                     EXSR #WRTOK
     C                     ENDIF
      *
     C                     ENDDO
      *
      * 4 POINT
     C           W@QR      IFEQ *ON
     C           W@AP      OREQ *ON
     C           W@INT     OREQ *ON
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
     C                     CLEARFMT550
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W3LOC
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVE *BLANKS   LOTIDS
     C                     MOVEALOTIDS    LOTS
     C                     MOVE '20'      @@ID
     C                     EXFMTFMT900
     C                     LEAVE
      * 3 POINT
     C                     ELSE
     C                     MOVE '40'      @@ID
     C                     MOVE *BLANK    F4BAR
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================********
      *     5TH SCREEN - CHECK 4 LOT IDS
      *================================================================********
     C           #CHK55    BEGSR
      *
     C                     MOVELF5LTID    W4LOT1  8
     C                     MOVE F5LTID    W4CHKD  1
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           F5LTID    IFEQ *BLANK
     C           F5LOT1    ANDEQ*BLANK
     C           F5LOT2    ANDEQ*BLANK
     C           F5LOT3    ANDEQ*BLANK
     C           F5LOT4    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELERR,20    F5ERR
     C                     LEAVE
     C                     ENDIF
      *
      * check digit...
     C           W4LOT1    IFGT *BLANKS
     C                     MOVELW4LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,15    F5ERR
     C                     ENDIF
      *
     C           PMCHK     IFNE W4CHKD
     C                     SETON                     9961
     C                     MOVELERR,15    F5ERR
     C                     ENDIF
      *
     C   99                LEAVE
      *
     C           F5LTID    IFEQ F5LOT1
     C           F5LTID    OREQ F5LOT2
     C           F5LTID    OREQ F5LOT3
     C           F5LTID    OREQ F5LOT4
     C                     SETON                     9961
     C           F5ERR     IFEQ *BLANK
     C                     MOVELERR,25    F5ERR
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           F5LOT1    WHEQ *BLANK
     C                     MOVELF5LTID    F5LOT1
     C                     MOVEL*BLANK    F5LTID
     C           F5LOT2    WHEQ *BLANK
     C                     MOVELF5LTID    F5LOT2
     C                     MOVEL*BLANK    F5LTID
     C           F5LOT3    WHEQ *BLANK
     C                     MOVELF5LTID    F5LOT3
     C                     MOVEL*BLANK    F5LTID
     C           F5LOT4    WHEQ *BLANK
     C                     MOVELF5LTID    F5LOT4
     C                     MOVEL*BLANK    F5LTID
     C                     ENDSL
     C                     ENDIF
      *
     C           F5LOT4    IFNE *BLANK
     C                     MOVE *ON       *INKE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================*********
      *       WRITE A ERROR RECORD
      *================================================================*********
     C           #WRTER    BEGSR
     C*
     C                     MOVEL'E'       W@ERR
     C*
     C                     TIME           WSDT
     C                     EXSR #WRTOK
     C*
     C                     MOVEL*BLANK    W@ERR
     C                     Z-ADD*ZERO     F998ID
     C*
     C                     ENDSR
      *================================================================********
      *       WRITE A OK RECORD
      *================================================================********
     C           #WRTOK    BEGSR
     C*
     C                     CLEARALCPP011
     C*
     C                     Z-ADDWSSDAT    A8DATE
     C                     Z-ADDWSSTM6    A8TIME
     C                     MOVEL#USER     A8USER
     C                     MOVEL#WSID     A8WSID
     C                     MOVEL#PGM      A8PGID
     C*
     C                     MOVELF1USRC    A8TMCD
     C                     MOVELWUSRID    A8TMNM    P
     C*
     C                     MOVELW@ERR     A8ERR
     C*
     C                     MOVELF3LOC     A8BRC2
     C                     MOVELW3SHN1    A8PR21
     C                     MOVELW3SHN2    A8PR22
     C                     MOVELW3SHN3    A8PR23
     C           W3LOC1    IFGE '0'
     C           W3LOC1    ANDLE'9'
     C           WRACKF    OREQ *ON
     C                     MOVELW3ZETI    A8B2LZ
     C                     MOVELW3LC#1    A8B2L1
     C                     MOVELW3LC#2    A8B2L2
     C                     MOVELW3LC#3    A8B2L3
     C                     MOVELW3LC#4    A8B2L4
     C                     ENDIF
     C*
     C* 4 POINT SCAN
S1   C           W@QR      IFEQ *ON
     C           W@AP      OREQ *ON
     C           W@INT     OREQ *ON
     C**
 S2  C           F2BAR3    IFEQ 'B01'
     C           F2BAR3    OREQ 'C01'
     C           F2BAR3    OREQ 'C03'
     C                     MOVELF2BAR     A8QR1
     C                     CLEAR@@BAR
     C                     MOVELF2BARA    @@BARA
     C                     MOVELF2BARB    @@BARB
     C                     MOVEL*BLANK    P9BAR  20
     C* CREATE CODE39
     C                     CALL 'UEXR13'
     C                     PARM           @@BARA
     C                     PARM           @@BARB
     C                     PARM           P9BAR
     C                     MOVELP9BAR     A8BRC1
     C**
 S2  C                     ELSE
     C                     MOVELF2BAR     A8BRC1
 S2  C                     ENDIF
     C**
     C                     MOVELW2SHN1    A8PR11
     C                     MOVELW2SHN2    A8PR12
     C                     MOVELW2SHN3    A8PR13
     C**
 S2  C           F4BAR3    IFEQ 'B01'
     C           F4BAR3    OREQ 'C01'
     C           F4BAR3    OREQ 'C03'
     C                     MOVELF4BAR     A8QR3
     C                     CLEAR@@BAR
     C                     MOVELF4BARA    @@BARA
     C                     MOVELF4BARB    @@BARB
     C                     MOVEL*BLANK    P9BAR
     C* CREATE CODE39
     C                     CALL 'UEXR13'
     C                     PARM           @@BARA
     C                     PARM           @@BARB
     C                     PARM           P9BAR
     C                     MOVELP9BAR     A8BRC3
     C**
 S2  C                     ELSE
     C                     MOVELF4BAR     A8BRC3
 S2  C                     ENDIF
     C**
     C                     MOVELW4SHN1    A8PR31
     C                     MOVELW4SHN2    A8PR32
     C                     MOVELW4SHN3    A8PR33
     C                     MOVELC1KID     A8KIND
     C* 3 POINT SCAN
X1   C                     ELSE
     C                     MOVELW@KID     A8KIND
     C                     MOVELF2BAR     W3LOC#
     C                     MOVELW3LC#1    A8B2L1
     C                     MOVELW3LC#2    A8B2L2
     C                     MOVELW3LC#3    A8B2L3
     C                     MOVELW3LC#4    A8B2L4
     C                     MOVELF2BAR     A8BRC2           BARCODE2
     C*
 S2  C           F4BAR3    IFEQ 'B01'
     C           F4BAR3    OREQ 'C01'
     C           F4BAR3    OREQ 'C03'
     C                     MOVELF4BAR     A8QR1
     C                     CLEAR@@BAR
     C                     MOVELF4BARA    @@BARA
     C                     MOVELF4BARB    @@BARB
     C                     MOVEL*BLANK    P9BAR
     C* CREATE CODE39
     C                     CALL 'UEXR13'
     C                     PARM           @@BARA
     C                     PARM           @@BARB
     C                     PARM           P9BAR
     C                     MOVELP9BAR     A8BRC1
 S2  C                     ELSE
     C                     MOVELF4BAR     A8BRC1
 S2  C                     ENDIF
     C*
     C*
     C                     MOVELW4SHN1    A8PR11
     C                     MOVELW4SHN2    A8PR12
     C                     MOVELW4SHN3    A8PR13
E1   C                     ENDIF
     C*
     C*
     C                     MOVELF5LOT#    A8BRC4
     C                     MOVELF5LOT#    A8LOT#
     C*
     C           W@ERR     IFNE *BLANK
     C                     MOVELF99ER1    A8EM01
     C                     MOVELF99ER2    A8EM02
     C                     END
     C*
     C           F998ID    IFNE *ZERO
     C                     MOVELF998ID    A8EM03
     C                     END
     C*
     C                     MOVELWUSECT    A8SECT
     C                     WRITEALCPP011
     C*
     C*  SUBTRACT LOCATION STOCK      CALL 'STAR00'
     C*** 4 POINT SCAN ONLY
     C           W@ERR     IFEQ *BLANK
S1   C           W@QR      IFEQ *ON
     C           W@AP      OREQ *ON
     C           W@INT     OREQ *ON
     C                     EXSR #SBSTA
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *================================================================
      * INTRA STOCK UPDATE SUB ROUTINE               *
      *================================================================
     C           #SBSTA    BEGSR
      *
     C                     MOVELC2DEPT    P#BMON  4
     C                     Z-ADD0         P#HKSU  50
     C                     MOVE C1HKSU    P#HKSU
      *
     C                     MOVELA8BRC1    P#BAR1    P
      *
     C                     MOVEL*BLANK    P#QR11
     C                     MOVEL*BLANK    P#QR12
      *
-1   C           A8QR1     IFNE *BLANK                                 C WASH
     C           256       SUBSTA8QR1:1   P#QR11256
     C           256       SUBSTA8QR1:257 P#QR12256
     C                     ENDIF                                       C WASH
      *
     C                     MOVELA8BRC3    P#BAR2    P
      *
     C                     MOVEL*BLANK    P#QR21
     C                     MOVEL*BLANK    P#QR22
      *
-1   C           A8QR3     IFNE *BLANK                                 C WASH
     C           256       SUBSTA8QR3:1   P#QR21256
     C           256       SUBSTA8QR3:257 P#QR22256
     C                     ENDIF                                       C WASH
      *
     C                     CALL 'STAR00'
     C                     PARM A8DATE    P#TIHZ  80
     C                     PARM A8TIME    P#TITI  60
     C                     PARM           P#BMON  4
     C                     PARM W3SHN1    P#SHN1  5
     C                     PARM W3SHN2    P#SHN2  5
     C                     PARM W3SHN3    P#SHN3  2
     C                     PARM W3LC#1    P#ATK1  1
     C                     PARM W3LC#2    P#ATK2  2
     C                     PARM W3LC#3    P#ATK3  2
     C                     PARM W3LC#4    P#ATK4  1
     C                     PARM '2'       P#SYOR  1
     C                     PARM '2'       P#ZAIK  1
     C                     PARM           P#HKSU  50
     C                     PARM WORKER    P#TMCD 10
     C                     PARM WUSRID    P#TMNM 20
     C                     PARM #PGM      P#PGM  10
     C                     PARM           P#BAR1 20
     C                     PARM           P#QR11256
     C                     PARM           P#QR12256
     C                     PARM           P#BAR2 20
     C                     PARM           P#QR21256
     C                     PARM           P#QR22256
      *
     C                     ENDSR
      *================================================================*********
      *       UNMATCH ERROR PROC
      *================================================================*********
     C           #UNMER    BEGSR
     C*
     C                     Z-ADD*ZERO     F998ID
     C                     MOVEL*BLANK    F998ER
     C                     EXSR #WRTER
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT998
     C*
     C                     EXSR #AM#31
     C           PASFLG    IFEQ '1'
     C                     MOVEL*BLANK    F998ER
     C                     EXSR #PP32
     C                     LEAVE
     C                     END
     C*
     C                     MOVELERR,21    F998ER
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *----------------------------------------------------*
      * PASSWORD                                           *
      *----------------------------------------------------*
     CSR         #AM#31    BEGSR
      *
     C           F998ID    CHAINAM#PP311             49
     C           *IN49     IFEQ '0'
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     SETON                     49
     C                     ENDIF
      *
     C                     MOVEL*BLANK    PASFLG  1
     C           *IN49     IFEQ '0'
     C                     MOVE WUSECT    X       20
     C                     MOVELR3PG,X    PASFLG
     C                     ENDIF
      *
     CSR         EAM#31    ENDSR
      *----------------------------------------------------*
      * LOG ERROR LOCK & UNLOCK INFORMATION                *
      *----------------------------------------------------*
     C           #PP32     BEGSR
      *
      * write to audit log file to record error and who unlocked error msg
     C                     MOVELWSSDAT    R4KOHZ
     C                     MOVELWSSTM6    R4KOTI
     C                     MOVEL#PGM      R4PGM
     C                     Z-ADDF998ID    R4WKCD
     C                     MOVELWORKER    R4KOME
     C                     MOVE '  '      F99ER1
     C           F99ER1    CAT  F99ER2:1  R4ERR
      * get date/time that error was unlocked
     C                     TIME           WSDT
     C                     MOVELWSSDAT    R4KOHU
     C                     MOVELWSSTM6    R4KOTU
      *
     C                     WRITEAM#PP321
      *
     C                     ENDSR
      *================================================================*********
      * Save Screen3 Kanban barcode with the last 32 scanned.                  *
      *================================================================*********
     C           #SVKB4    BEGSR
      *
     C           I3        IFEQ 32
     C                     Z-ADD1         I3      20
     C                     ELSE
     C                     ADD  1         I3
     C                     ENDIF
      *
     C                     MOVELF4BARC    KB4,I3    P
      *
     C                     ENDSR
      *================================================================
      * KANBAN CHECK
      *================================================================
     C           #KANCK    BEGSR
      *-------------------------*
      * INITIALIZATION
      *-------------------------*
     C                     MOVEL*BLANK    W@KID   1        KANBAN KIND
     C                     MOVEL*BLANK    $$SHN1  5        PART  1
     C                     MOVEL*BLANK    $$SHN2  5        PART  2
     C                     MOVEL*BLANK    $$SHN3  2        PART  3
     C                     CLEARPLO                        PREV LOC
     C                     CLEAROLO                        OWN  LOC
     C                     CLEARPLOT                       PREV LOC T
     C                     CLEAROLOT                       OWN  LOC T
     C                     MOVEL*BLANK    W$LINE  1        LINE
     C                     MOVEL*BLANK    W$DEPT  4        OWN DEPARTMENT
      *-------------------------*
      * CODE 39
      *-------------------------*
1    C           W$BAR3    IFNE 'B01'                                  C WASH
|    C           W$BAR3    ANDNE'C01'
|    C           W$BAR3    ANDNE'C03'
|    C*
|    C* NOT PASS THROUGH
|2   C           W$BAR1    IFEQ 'I'                                    C WASH
||   C                     MOVELW$BAR     PMAREA    P
||   C                     MOVE '016'     PMBYTE
||   C           1         SUBSTW$BAR:17  WKCHK   1
||   C                     MOVE *BLANK    PMCHK
||   C                     MOVE *BLANK    PMRTCD
||   C                     CALL 'ALBRCC'  P#BRC
||3  C           PMRTCD    IFNE *BLANK
|||  C                     SETON                     9961
|||4 C           $$ERR     IFEQ *BLANK
|||| C                     MOVELERR,1     $$ERR
|||| C                     MOVELERR,1     F99ER1
|||| C                     MOVE '01'      $$ERR
|||| C                     MOVE '01'      F99ER1
|||| **** CHECK DIGIT ERR                  #15
|||| C                     MOVELERR,15    F99ER2
|||| C                     GOTO $KAN99
|||4 C                     ENDIF
||3  C                     ENDIF
||   C* NOT PASS THROUGH
|2   C                     ELSE                                        C WASH
||   C                     MOVELW$BAR     PMAREA    P
||   C                     MOVE '014'     PMBYTE
||   C           1         SUBSTW$BAR:15  WKCHK   1
||   C                     MOVE *BLANK    PMCHK
||   C                     MOVE *BLANK    PMRTCD
||   C                     CALL 'ALBRCC'  P#BRC
||3  C           PMRTCD    IFNE *BLANK
|||  C                     SETON                     9961
|||4 C           $$ERR     IFEQ *BLANK
|||| C                     MOVELERR,1     $$ERR
|||| C                     MOVELERR,1     F99ER1
|||| C                     MOVE '01'      $$ERR
|||| C                     MOVE '01'      F99ER1
|||| **** CHECK DIGIT ERR                  #15
|||| C                     MOVELERR,15    F99ER2
|||| C                     GOTO $KAN99
|||4 C                     ENDIF
||3  C                     ENDIF
||   C*
|2   C                     ENDIF
|    C*
|2   C           PMCHK     IFNE WKCHK
||   C                     SETON                     9961
||3  C           $$ERR     IFEQ *BLANK
|||  C                     MOVELERR,1     $$ERR
|||  C                     MOVELERR,1     F99ER1
|||  C                     MOVE '06'      $$ERR
|||  C                     MOVE '06'      F99ER1
|||  **** CHECK DIGIT ERR                  #15
|||  C                     MOVELERR,15    F99ER2
|||  C                     GOTO $KAN99
||3  C                     ENDIF
|2   C                     ENDIF
|    C*
1    C                     ENDIF
      *-------------------------*
      * QR
      *-------------------------*
1    C           W$BAR3    IFEQ 'C01'
|    C           W$BAR3    OREQ 'B01'
|    C           W$BAR3    OREQ 'C03'
|    C* QR COMMON (BASED ON A-PICS)
|    C           5         SUBSTW$BAR:30  $$SHN1           PART  1
|    C           5         SUBSTW$BAR:35  $$SHN2           PART  2
|    C           2         SUBSTW$BAR:40  $$SHN3           PART  3
|    C           1         SUBSTW$BAR:42  W$JBN1           OP LOC1
|    C           2         SUBSTW$BAR:43  W$JBN2           OP LOC2
|    C           2         SUBSTW$BAR:45  W$JBN3           OP LOC3
|    C           1         SUBSTW$BAR:47  W$JBN4           OP LOC4
|    C                     MOVELWJBN      OLO,1
|    C                     MOVELWJBNT     OLOT,1
|    C           1         SUBSTW$BAR:65  W$MTK1           PP LOC1
|    C           2         SUBSTW$BAR:66  W$MTK2           PP LOC2
|    C           2         SUBSTW$BAR:68  W$MTK3           PP LOC3
|    C           1         SUBSTW$BAR:70  W$MTK4           PP LOC4
|    C                     MOVELWMTK      PLO,1
|    C                     MOVELWMTKT     PLOT,1
|    C           4         SUBSTW$BAR:75  W$DEPT  4        OWN DEPT
|    C           1         SUBSTW$BAR:86  W$LINE  1        LINE
|    C           2         SUBSTW$BAR:99  W$JOA1  2        PLATING C1
|    C           2         SUBSTW$BAR:101 W$JOA2  2        PLATING C2
