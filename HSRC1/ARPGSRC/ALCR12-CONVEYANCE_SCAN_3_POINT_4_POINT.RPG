     C                     ELSE
     C                     EXSR #CHK40
     C                     ENDIF
     C*
1    C           *IN99     IFEQ *OFF
|    C*  *
|    C* if sorting or shipping scan and no error, write record for apics read
|2   C           W@SRT     IFEQ *ON
||   C           W@SHP     OREQ *ON
||   C                     TIME           WSDT
||   C                     EXSR #WRTOK
||   C                     EXSR #SVKB4
||   C                     MOVEL*BLANKS   F4BAR
||   C                     GOTO EFMT40
|2   C                     ENDIF
|    C*
|    C*  WRITE  P.T. KANBAN SCAN RESULT
|2   C           C2KID     IFEQ 'T'
||   C                     MOVE '001'     C1HKSU
||   C                     TIME           WSDT
||   C                     EXSR #WRTOK                     SCAN RESULT
||   C                     EXSR #WRTAR                     PT RESULT
||   C* CLEAR
||   C                     CLEARFMT200
||   C                     CLEARFMT300
||   C                     CLEARFMT400
||   C                     CLEARFMT500
||   C                     CLEARFMT550
||   C                     MOVEL*BLANK    W2SHIN
||   C                     MOVEL*BLANK    W3SHIN
||   C                     MOVEL*BLANK    W4SHIN
||   C                     MOVE '20'      @@ID
||   C                     EXFMTFMT900
||   C*
||   C*  NEXT SCREEN READS LOT ID TAG EXCEPT P.T. KANBAN
|2   C                     ELSE
||3  C           WUSECT    IFEQ '2'
|||  C           WUSECT    OREQ '4'
|||  C                     MOVE '55'      @@ID             4 LOT IDS
|||  C                     ELSE
|||  C                     MOVE '50'      @@ID             LOT ID TAG
||3  C                     ENDIF
|2   C                     ENDIF
|    C*
|    C* WRITE ERROR RECORDS
1    C                     ELSE
|    C                     EXSR #WRTER
1    C                     ENDIF
     C*
     C                     ENDSL
     C*
     C           EFMT40    ENDSR
      *================================================================
      *     4TH SCREEN CHECK (KANBAN  QR)
      *================================================================
     C           #CHK40    BEGSR
     C*
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVELF4BAR     W$BAR
     C                     SETOF                     996166
     C                     MOVEL*OFF      W@UNME  1
     C                     MOVEL*OFF      W@LOCK  1
      *-------------------------*
1    C                     DO
|    C*
|2   C           F4BAR     IFEQ *BLANK
||   C                     SETON                     9961
||   C                     MOVELERR,1     F4ERR
||   C                     MOVELERR,1     F99ER1
||   C                     MOVE '17'      F4ERR
||   C                     MOVE '17'      F99ER1
||   C                     MOVELERR,3     F99ER2
||   C                     LEAVE
|2   C                     ENDIF
|    C*
|    C                     MOVELF4BAR     W$BAR
|    C                     MOVE *BLANK    $$ERR
|    C*
|    C                     EXSR #KANCK
|    C*
|    C                     MOVEL$$SHN1    W4SHN1
|    C                     MOVEL$$SHN2    W4SHN2
|    C                     MOVEL$$SHN3    W4SHN3
|    C                     MOVEL$$ERR     F4ERR
|    C*
|    C*-------------------------*
|    C   99                LEAVE
|    C*-------------------------*
|    C*
|    C* GET OWN PROCESS LOCATION
|    C                     CLEARC2T
|    C                     CLEARC2TT
|    C                     MOVEAOLO       C2T
|    C                     MOVEAOLOT      C2TT
|    C* GET DEPARTMENT   FOR OUTSOURCE
|    C                     MOVEL*BLANK    C2DEPT  4
|    C                     MOVE W$DEPT    C2DEPT
|    C* GET LINE INFORMATION       FOR  BZ,DS,DSM
|    C                     MOVEL*BLANK    C2LINE  1
|    C                     MOVELW$LINE    C2LINE
|    C* GET PLATING CONDITION 1-2  FOR  JC
|    C                     CLEARQJOA                       PLATING COND1-2
|    C                     MOVELW$JOA1    C2JOA1
|    C                     MOVELW$JOA2    C2JOA2
|    C* GET PICK UP CONDITION 1-3  FOR  JC,SB
|    C                     CLEARQJOK                       PICKUP C1-3
|    C                     MOVELW$JOK1    C2JOK1
|    C                     MOVELW$JOK2    C2JOK2
|    C                     MOVELW$JOK3    C2JOK3
|    C*
|    C* GET ABSOLUTE NO. FOR PASS THROUGH
|    C                     MOVEL*BLANK    C2ZETI  4
|    C                     MOVELWWZETI    C2ZETI
|    C                     MOVEL*BLANK    C2KID   1
|    C                     MOVELW@KID     C2KID
|    C*
|    C*
|    C                     MOVEL*BLANK    F4BARC256
|2   C           F4BAR3    IFEQ 'B01'
||   C           F4BAR3    OREQ 'C01'
||   C           F4BAR3    OREQ 'C03'
||   C                     CLEAR@@BAR
||   C                     MOVELF4BARA    @@BARA
||   C                     MOVELF4BARB    @@BARB
||   C                     MOVEL*BLANK    P9BAR
||   C* CREATE CODE39
||   C                     CALL 'UEXR13'
||   C                     PARM           @@BARA
||   C                     PARM           @@BARB
||   C                     PARM           P9BAR
||   C                     MOVELP9BAR     F4BARC256
|2   C                     ELSE
||   C                     MOVELF4BAR     F4BARC
|2   C                     ENDIF
|    C*
|    C*--------------------------------------------*
|    C*  4 POINT SCAN CHECK                        *
|    C*--------------------------------------------*
|2   C           W@QR      IFEQ *ON
||   C           W@AP      OREQ *ON
||   C           W@INT     OREQ *ON
||   C*-------------------------------
||   C* CHECK FOR P.T. KANBAN
||   C*-------------------------------
||3  C           C2KID     IFEQ 'T'
|||  C*  DUPLICATE SCAN CHECK
|||  C                     MOVEL*BLANK    ARCHK   1
|||  C                     EXSR #CHKAR
|||4 C           ARCHK     IFEQ 'E'
|||| C                     SETON                     9961
|||| C           ERR,22    CAT  ERR,23:1  F4ERR
|||| C                     MOVELERR,22    F99ER1
|||| C                     MOVELERR,23    F99ER2
|||| C                     LEAVE
|||4 C                     ENDIF
|||  C*
|||  C*  COMPARE ABSOLUTE NO.
|||4 C           C1ZETI    IFNE C2ZETI
|||| C                     SETON                     9961
|||| **** UNMATCH                          #10
|||| C                     MOVELERR,10    F4ERR
|||| C                     MOVE '10'      F4ERR
|||| C                     MOVELERR,10    F99ER1
|||| C                     MOVE '10'      F99ER1
|||| **** PART NUMBER                      #18
|||| C                     MOVELERR,18    F99ER2
|||| C                     MOVEL*ON       W@UNME
|||| C                     MOVEL*ON       W@LOCK
|||4 C                     ENDIF
|||  C*----------------------------------------
|||  C* COMPARE LOCATION EXCEPT P.T. KANBAN
|||  C*----------------------------------------
||3  C                     ELSE
|||   * ONLY 1 LOCATION
|||4 C           C2T,1     IFNE *BLANK
|||| C           C2T,2     ANDEQ*BLANK
|||| C           C2T,3     ANDEQ*BLANK
|||| C           C2T,4     ANDEQ*BLANK
||||5C           C2T,1     IFNE C1T,1
|||||C           C2TT,1    ANDNEC1TT,1
|||||C                     SETON                     9961
|||||**** UNMATCH                          #10
|||||C                     MOVELERR,10    F4ERR
|||||C                     MOVELERR,10    F99ER1
|||||C                     MOVE '10'      F4ERR
|||||C                     MOVE '11'      F99ER1
|||||**** LOCATION ERR                     #02
|||||C                     MOVELERR,02    F99ER2
|||||C                     MOVEL*ON       W@UNME
|||||C                     MOVEL*ON       W@LOCK
||||5C                     ENDIF
|||| C* MULTI LOCATION
|||4 C                     ELSE
|||| C           C1T,1     LOKUPC2T                      75
|||| C*  CHECK BY 4 CHARACTERS
