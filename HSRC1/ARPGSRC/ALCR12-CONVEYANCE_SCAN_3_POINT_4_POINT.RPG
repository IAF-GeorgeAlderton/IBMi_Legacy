     C                     MOVELERR,10    F99ER1
     C                     MOVE '10'      F4ERR
     C                     MOVE '10'      F99ER1
     C                     MOVELERR,24    F99ER2
     C                     SETON                     9961
     C                     MOVEL*ON       W@UNME
  E3 C                     END
