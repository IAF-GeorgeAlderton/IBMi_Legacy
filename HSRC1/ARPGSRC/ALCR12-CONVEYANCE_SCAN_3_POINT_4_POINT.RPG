     C                     SETOF                     68
1    C           W@QR      IFEQ *ON
|    C           W@AP      OREQ *ON
|    C           W@INT     OREQ *ON
|    C                     SETON                     68
1    C                     ENDIF
     C*
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
     C*
S1   C                     SELEC
-1   C           *INKC     WHEQ *ON
     C** 4 POINT SCAN
 S2  C           W@QR      IFEQ *ON
  |  C           W@AP      OREQ *ON
  |  C           W@INT     OREQ *ON
  |  C                     MOVE '30'      @@ID
  |  C                     MOVEL*BLANK    W3SHIN
  |  C                     MOVEL*BLANK    F3LOC
  |  C** 3 POINT SCAN
 X2  C                     ELSE
  |  C                     CLEARFMT200
  |  C                     CLEARFMT300
  |  C                     CLEARFMT400
  |  C                     CLEARFMT500
  |  C                     CLEARFMT550
  |  C                     MOVEL*BLANK    W2SHIN
  |  C                     MOVEL*BLANK    W3SHIN
  |  C                     MOVEL*BLANK    W4SHIN
  |  C                     MOVE '20'      @@ID
 E2  C                     ENDIF
-1   C** F7 : 1ST SCREEN  WHEN 4 POINT SCAN
-1   C           *INKG     WHEQ *ON
 S2  C           *IN68     IFEQ *ON
  |3 C           W@QR      IFEQ *ON
  || C           W@AP      OREQ *ON
  || C           W@INT     OREQ *ON
  || C                     CLEARFMT200
  || C                     CLEARFMT300
  || C                     CLEARFMT400
  || C                     CLEARFMT500
  || C                     CLEARFMT550
