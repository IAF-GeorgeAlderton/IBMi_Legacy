      *================================================================*********
     C           #CHK4G    BEGSR
      *
S1   C                     DO
      *
     C           K#KEY     SETGTADHTL05
 S2  C                     DO   *HIVAL
      *
     C           K#KEY     REDPEADHTL05                  97
     C   97                LEAVE
      *
  S3 C           J6SKJY    IFNE *BLANK
     C                     ITER
  E3 C                     ENDIF
  S3 C           J6UKHZ    IFGT WSSDAT
     C                     ITER
  E3 C                     ENDIF
  S3 C           J6STHZ    IFLE WSSDAT
     C                     ITER
  E3 C                     ENDIF
      *
     C                     MOVEL'000'     HOJI    3
     C                     MOVE J6HOJI    HOJI
     C                     MOVELJ6ONDO    ONDO    3
     C                     MOVELJ6CO2P    CO2     3
      *
  S3 C           HOJI      IFNE W2TIME
     C           ONDO      ORNE W2TEMP
     C           CO2       ORNE W2CO2
     C           J6RONO    ORNE W2MCH#
     C                     MOVEL*OFF      W@OQFN  1
     C                     ITER
  X3 C                     ELSE
     C                     MOVEL*ON       W@OQFN
     C                     LEAVE
  E3 C                     ENDIF
      *
 E2  C                     ENDDO
      *
      *** if location is a temporary oq location (SS1 - SS9), it's ok...
     C           W@OQFN    IFEQ *OFF
     C           W2MCH#    ANDGE'SS1'
     C           W2MCH#    ANDLE'SS9'
     C                     MOVEL*ON       W@OQFN
     C                     ENDIF
      *
  S2 C           W@OQFN    IFEQ *ON
     C                     LEAVE
  X2 C                     ELSE
     C                     MOVELERR,10    F4ERR
     C                     MOVELERR,10    F99ER1
     C                     MOVE '01'      F4ERR
     C                     MOVE '01'      F99ER1
     C                     MOVELERR,24    F99ER2
     C                     SETON                     9961
     C                     MOVEL*ON       W@UNME
     C                     LEAVE
  E2 C                     ENDIF
      *
E1   C                     ENDDO
