||   C                     MOVEL'A'       W@KID   1        A-PICS
||   C                     MOVE '004'     W@HKSU  3
|2   C                     ENDIF
|     * INTRA OR PLASTIC QR
|2   C           W$BAR3    IFEQ 'B01'
||   C           4         SUBSTW$BAR:7   WWZETI  4        QR
||   C           5         SUBSTW$BAR:34  $$SHN1           PART  1
||   C           5         SUBSTW$BAR:39  $$SHN2           PART  2
||   C           2         SUBSTW$BAR:44  $$SHN3           PART  3
||   C           4         SUBSTW$BAR:49  W$DEPT           OWN DEPT
||   C           1         SUBSTW$BAR:53  W$JBN1           OP LOC1
||   C           2         SUBSTW$BAR:54  W$JBN2           OP LOC2
||   C           2         SUBSTW$BAR:56  W$JBN3           OP LOC3
||   C           1         SUBSTW$BAR:58  W$JBN4           OP LOC4
||   C                     MOVELWJBN      OLO,1
||   C                     MOVELWJBNT     OLOT,1
||   C           1         SUBSTW$BAR:79  W$MTK1           PP LOC1
||   C           2         SUBSTW$BAR:80  W$MTK2           PP LOC2
||   C           2         SUBSTW$BAR:82  W$MTK3           PP LOC3
||   C           1         SUBSTW$BAR:84  W$MTK4           PP LOC4
||   C                     MOVELWMTK      PLO,1
||   C                     MOVELWMTKT     PLOT,1
||S3 C                     SELEC
||-3 C           W$KDAI    WHEQ 'A'                        PRODUCTION
||   C                     MOVEL'I'       W@KID   1        INTRA
||   C           3         SUBSTW$BAR:85  W@HKSU
||-3 C           W$KDAI    WHEQ 'B'                        HEAT TREAT
||   C                     MOVEL'I'       W@KID   1        INTRA
||   C           3         SUBSTW$BAR:85  W@HKSU
||-3 C           W$KDAI    WHEQ 'C'                        SURFACE TRT
||   C                     MOVEL'P'       W@KID   1        PLASTIC
||   C           5         SUBSTW$BAR:30  $$SHN1           PART  1
||   C           5         SUBSTW$BAR:35  $$SHN2           PART  2
||   C           2         SUBSTW$BAR:40  $$SHN3           PART  3
||   C           1         SUBSTW$BAR:42  W$JBN1           OP LOC1
||   C           2         SUBSTW$BAR:43  W$JBN2           OP LOC2
||   C           2         SUBSTW$BAR:45  W$JBN3           OP LOC3
||   C           1         SUBSTW$BAR:47  W$JBN4           OP LOC4
||   C                     MOVELWJBN      OLO,1
||   C                     MOVELWJBNT     OLOT,1
||   C           4         SUBSTW$BAR:75  W$DEPT           OWN DEPT
||   C           1         SUBSTW$BAR:65  W$MTK1           PP LOC1
||   C           2         SUBSTW$BAR:66  W$MTK2           PP LOC2
||   C           2         SUBSTW$BAR:68  W$MTK3           PP LOC3
||   C           1         SUBSTW$BAR:70  W$MTK4           PP LOC4
||   C                     MOVELWMTK      PLO,1
||   C                     MOVELWMTKT     PLOT,1
||   C                     MOVE '004'     W@HKSU  3
||E3 C                     ENDSL
||    *
||    * %0002 CHECK CURRENT KANBAN
||   C                     CALL 'UEXR14'
||   C                     PARM           W$BARA
||   C                     PARM           W$BARB
||   C                     PARM           P9RDPM  1
||3  C**         P9RDPM    IFEQ 'N'
|||  C**         $$ERR     ANDEQ*BLANK
|||  C**                   SETON                     9961
|||  **** OLD KANBAN NEED                  #05
|||  C**                   MOVELERR,5     $$ERR
|||  C**                   MOVELERR,5     F99ER1
|||  **** TO BE SWITCHED.                  #06
|||  C**                   MOVELERR,6     F99ER2
|||  C**                   GOTO $KAN99
||3  C**                   ENDIF
||    *
|2   C                     ENDIF
|     *
|     *-------------------------*
|     * CODE 39
|     *-------------------------*
1    C                     ELSE
|     * CHECK PART M/F
|    C           4         SUBSTW$BAR:2   WWZETI
|    C           WWZETI    CHAINFCETL11              90
|2   C           *IN90     IFEQ *ON
||   C           A2GSKD    ORNE *BLANK
||   C                     SETON                     9961
||3  C           $$ERR     IFEQ *BLANK
