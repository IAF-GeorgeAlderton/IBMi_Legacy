     C                     CLEARC1TT
     C                     MOVEAPLO       C1T
     C                     MOVEAPLOT      C1TT
     C                     MOVEL*BLANK    C1KID   1
     C                     MOVELW@KID     C1KID
     C                     MOVEL*BLANK    C1HKSU  3
     C                     MOVE W@HKSU    C1HKSU
     C                     MOVEL*BLANK    C1ZETI  4
     C                     MOVELWWZETI    C1ZETI
