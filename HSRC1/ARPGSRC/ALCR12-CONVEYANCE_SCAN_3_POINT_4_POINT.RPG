     C                     MOVEL*BLANK    F3ERR
     C*
S1   C                     SELEC
-1   C           *INKC     WHEQ *ON
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
     C                     CLEARFMT550
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVE '20'      @@ID
-1   C           *INKG     WHEQ *ON
-1   C** NO MOVE
-1   C                     OTHER
     C*
     C                     EXSR #CHK30
     C*
 S2  C           *IN99     IFEQ *OFF
     C                     MOVE *BLANK    F4BAR
     C                     MOVE *BLANK    F4ERR
     C                     MOVE '40'      @@ID
 X2  C                     ELSE
  S3 C           F3LOC     IFNE *BLANK
     C                     EXSR #WRTER
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDSL
     C*
     C                     ENDSR
      *================================================================
      *  4 POINT SCAN -2ND SCREEN CHECK (LOCATION LABEL)
      *================================================================
     C           #CHK30    BEGSR
     C*
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVELF3LOC     W3LOC
     C                     SETOF                     9961
     C*
1    C                     DO
|    C*
|2   C           W3LOC     IFEQ *BLANK
||   C                     SETON                     9961
||   **** LOCATION ERR                     #02
||   C                     MOVELERR,2     F3ERR
||   C                     MOVELERR,2     F99ER1
||   C                     MOVE '02'      F3ERR
||   C                     MOVE '02'      F99ER1
||   **** BLANK                            #03
||   C                     MOVELERR,3     F99ER2
||   C                     LEAVE
|2   C                     ENDIF
|     *
|    C           W3ZETI    CHAINFCETL11              90
|2   C           *IN90     IFEQ *ON
||   C           A2GSKD    ORNE *BLANK
||   C                     SETON                     9961
||   C                     MOVELERR,2     F3ERR
||   C                     MOVELERR,2     F99ER1
||   C                     MOVE '02'      F3ERR
||   C                     MOVE '02'      F99ER1
||   **** M/F NOT FOUND                    #04
||   C                     MOVELERR,4     F99ER2
||   C                     LEAVE
|2   C                     ENDIF
|    C                     MOVELA2BHB1    W3SHN1
|    C                     MOVELA2BHB2    W3SHN2
|    C                     MOVELA2BHB3    W3SHN3
|     *
|     * ONLY 1 LOCATION
|2   C           C1T,1     IFNE *BLANK
||   C           C1T,2     ANDEQ*BLANK
||   C           C1T,3     ANDEQ*BLANK
||   C           C1T,4     ANDEQ*BLANK
||    *
||3  C           W3LOC#    IFNE C1T,1
|||  C           W3LOC4    ANDNEC1TT,1
|||  C                     SETON                     9961
|||4 C           F3ERR     IFEQ *BLANK
|||| **** UNMATCH                          #10
|||| C                     MOVELERR,10    F3ERR
|||| C                     MOVELERR,10    F99ER1
|||| C                     MOVE '01'      F3ERR
|||| C                     MOVE '01'      F99ER1
|||| **** LOCATION ERR                     #02
|||| C                     MOVELERR,02    F99ER2
|||| C                     MOVEL*ON       W@UNME
|||| C                     LEAVE
|||4 C                     ENDIF
||3  C                     ENDIF
||    *
|2   C                     ELSE
||    * MULTI LOCATION  AS 6 CHARACTERS
||   C           W3LOC#    LOKUPC1T                      75
||   C*
||    * IF NOT FOUND, CHECK AGAIN  BY 4 CHARACTERS
||3  C           *IN75     IFEQ *OFF
|||  C           W3LOC4    LOKUPC1TT                     75
||3  C                     ENDIF
||   C*
||3  C           *IN75     IFEQ *ON
|||  C                     CLEARC1T
|||  C                     MOVELW3LOC#    C1T,1
||3  C                     ELSE
|||  C                     SETON                     9961
|||4 C           F3ERR     IFEQ *BLANK
|||| **** UNMATCH                          #10
|||| C                     MOVELERR,10    F3ERR
|||| C                     MOVELERR,10    F99ER1
|||| C                     MOVE '01'      F3ERR
|||| C                     MOVE '01'      F99ER1
|||| **** LOCATION ERR                     #02
|||| C                     MOVELERR,02    F99ER2
|||| C                     MOVEL*ON       W@UNME
|||| C                     LEAVE
|||4 C                     ENDIF
||3  C                     ENDIF
|2   C                     ENDIF
|     *
1    C                     ENDDO
      *
      *--------------------------------------------------
      * COMPARE ABSOLUTE NO. FOR J LOCATION (P.T. PARTS)
      *--------------------------------------------------
1    C           *IN99     IFEQ *ON
|    C           W3LC66    ANDEQ'J'
|2   C           W3ZETI    IFEQ C1ZETI
||   C                     SETOF                     9961
|||  C                     MOVEL*BLANK    F3ERR
|||  C                     MOVEL*BLANK    F99ER1
|||  C                     MOVEL*BLANK    F99ER2
|||  C                     MOVEL*OFF      W@UNME
|||  C**
|2   C                     ELSE
||   C                     SETON                     9961
||3  C           F3ERR     IFEQ *BLANK
|||  **** UNMATCH                          #10
|||  C                     MOVELERR,10    F3ERR
|||  C                     MOVELERR,10    F99ER1
|||  C                     MOVE '10'      F3ERR
|||  C                     MOVE '10'      F99ER1
|||  **** PART NUMBER                      #18
|||  C                     MOVELERR,18    F99ER2
|||  C                     MOVEL*ON       W@UNME
||3  C                     ENDIF
|2   C                     ENDIF
1    C                     ENDIF
      *
      * if w-rack flag is on and location barcode part id starts with
      *    an 'A', it's a washer so check that part & location match...
     C           *IN99     IFEQ *ON
     C           WRACKF    ANDEQ*ON
     C           W3LOC1    ANDEQ'A'
     C                     SETOF                     9961
     C                     EXSR #CHKWA
     C           *IN99     IFEQ *OFF
     C                     MOVEL*BLANK    F3ERR
     C                     MOVEL*BLANK    F99ER1
     C                     MOVEL*BLANK    F99ER2
     C                     MOVEL*OFF      W@UNME
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
