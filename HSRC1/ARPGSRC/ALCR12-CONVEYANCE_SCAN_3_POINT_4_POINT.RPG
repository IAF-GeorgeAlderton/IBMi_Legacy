     C                     MOVEL*OFF      W@OQFN  1
      *
     C           3         SUBSTF4BAR:125 W4MCH#  3
     C           3         SUBSTF4BAR:129 W4TIME  3
     C           3         SUBSTF4BAR:132 W4TEMP  3
     C           3         SUBSTF4BAR:135 W4CO2   3
      *
     C           W2MCH#    IFEQ W4MCH#
     C           W2TIME    ANDEQW4TIME
     C           W2TEMP    ANDEQW4TEMP
     C           W2CO2     ANDEQW4CO2
     C                     MOVEL*ON       W@OQFN
     C                     ENDIF
      *
      *** if location is a temporary oq location (SS1 - SS9), it's ok...
     C           W@OQFN    IFEQ *OFF
     C           W2MCH#    ANDGE'SS1'
     C           W2MCH#    ANDLE'SS9'
     C                     MOVEL*ON       W@OQFN
     C                     ENDIF
