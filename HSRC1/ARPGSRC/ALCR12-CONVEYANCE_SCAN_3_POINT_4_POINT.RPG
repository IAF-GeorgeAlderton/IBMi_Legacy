     C           F2BAR4    OREQ 'DSK '                     DSK
     C           F2BAR4    OREQ 'DSL '                     DSL
     C           F2BAR4    OREQ 'DSN '                     DSN
     C                     MOVEL*ON       W@GMSP
     C**
-1   C           F2BAR4    WHEQ 'BZA '
     C           F2BAR4    OREQ 'BZB '
     C           F2BAR4    OREQ 'BZC '
     C           F2BAR4    OREQ 'BZD '
     C           F2BAR4    OREQ 'BZE '
