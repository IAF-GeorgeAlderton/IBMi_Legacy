      ***************************************
-1   C           F2BAR3    WHEQ 'B01'                                  C WASH
     C           F2BAR3    OREQ 'C01'                                  C WASH
     C           F2BAR3    OREQ 'C03'                                  C WASH
     C                     MOVEL*ON       W@QR
     C                     MOVEL*ON       W@AP
     C                     MOVE *BLANK    $$ERR  16
     C                     EXSR #KANCK
     C                     MOVEL$$SHN1    W2SHN1
     C                     MOVEL$$SHN2    W2SHN2
     C                     MOVEL$$SHN3    W2SHN3
     C                     MOVEL$$ERR     F2ERR
     C                     MOVE PRT       @PRT
     C                     MOVE PRX       @PRX
     C           F2BAR3    IFEQ 'C01'
     C           F2BAR3    OREQ 'C03'
     C                     MOVE *ON       ##TAP
     C                     ENDIF
     C           F2BAR3    IFEQ 'B01'
     C           F2KDAI    ANDEQ'C'
     C                     MOVE *ON       ##TAP
     C                     ENDIF
     C**
-1   C           F2BAR1    WHEQ 'A'                                    C WASH
     C           F2BAR1    OREQ 'R'                                    C WASH
     C                     MOVEL*ON       W@AP
     C                     MOVE *BLANK    $$ERR
     C                     EXSR #KANCK
     C                     MOVEL$$SHN1    W2SHN1
     C                     MOVEL$$SHN2    W2SHN2
     C                     MOVEL$$SHN3    W2SHN3
     C                     MOVEL$$ERR     F2ERR
     C                     MOVE PRT       @PRT
     C                     MOVE PRX       @PRX
      * if APICS/plastic kanban, set flag for type A or B...
     C           F2BAR1    IFEQ 'A'
     C                     MOVE *ON       ##TAP
     C                     ENDIF
     C**
-1   C           F2BAR1    WHGE '0'                                    C WASH
     C           F2BAR1    ANDLE'9'                                    C WASH
     C                     MOVEL*ON       W@INT
     C                     MOVE *BLANK    $$ERR
     C                     EXSR #KANCK
     C                     MOVEL$$SHN1    W2SHN1
     C                     MOVEL$$SHN2    W2SHN2
     C                     MOVEL$$SHN3    W2SHN3
     C                     MOVEL$$ERR     F2ERR
     C                     MOVE PRT       @PRT
     C                     MOVE PRX       @PRX
     C**
     C                     OTHER
     **** LOCATION ERROR                   #02
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVE '02'      F2ERR
     C                     MOVE '02'      F99ER1
E1   C                     ENDSL
     C*
     C* GET PRECEDING PROCESS LOCATION
