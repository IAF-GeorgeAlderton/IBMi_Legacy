     F** ABHRS5 ********************************************
     F*  SRT  PLATING KANBAN M/F  ----> CSV DATA
JW1  F*  JW   2020.07.24 USE SET#/D INSTEAD OF SET#
JW2  F*  JW      2018.02.15 SET TRUN# FROM AAHPPS5
JW3  F*  JW      2020.08.10 USE TURN# TABLE(AAHPPS6) INSTEAD OF AAHPPS5
     F*  T.TODA  2021.02.18 CHANGES(20199)
     F******************************************************
     FABHPL03 IP  E           K        DISK
      *
     FFCEPL01 IF  E           K        DISK
      *
     FMFAPL25 IF  E           K        DISK
      *
     FFCGPP31 IF  E           K        DISK
     FFCGPP41 IF  E           K        DISK
      *
     FFCGPP05 IF  E           K        DISK
      *
     FFGBPL01 IF  E           K        DISK
      *
     F**AAHPPS5 IF  E           K        DISK
JW2  FAAHPPS6 IF  E           K        DISK
      *
     FAAFWPS5 O   F    2048            DISK
      *================================================================
     E                    AK          4  3
     E                    KB          4  3
     E                    T7A         7  1
     E                    T7B         7  1
      *================================================================
     I            DS
     I                                        1  12 AK
     I                                        1   3 M6AKT1
     I                                        4   6 M6AKT2
     I                                        7   9 M6AKT3
     I                                       10  12 M6AKT4
     I            DS
     I                                        1  12 KB
     I                                        1   3 M6KBN1
     I                                        4   6 M6KBN2
     I                                        7   9 M6KBN3
     I                                       10  12 M6KBN4
     I            DS
     I                                        1   80M6STHZ
     I                                        1   40M6STYY
     I                                        5   60M6STMM
     I                                        7   80M6STDD
      *================================================================
     C           M6SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
      *
     C           M6STHZ    IFNE 99999999
     C                     GOTO @END
     C                     END
      *
     C           M6SYUY    IFEQ 0
     C                     GOTO @END
     C                     END
      *
JW1  C           M6KTSU    DIV  20        W@SETD  90
     C           M6KTSU    DIV  20        W@BXPD  91
     C           W@BXPD    DIV  M6SYUY    O@BXPD  61
      *
     C                     MOVELM6HIN1    P@HIN1  5
     C                     MOVELM6HIN2    P@HIN2  5
     C                     MOVELM6HIN3    P@HIN3  2
     C                     MOVELM6JBN1    P@BAN1  1
     C                     MOVELM6JBN2    P@BAN2  2
     C                     MOVELM6JBN3    P@BAN3  2
     C                     MOVELM6JBN4    P@BAN4  1
     C                     MOVE M6BMON    P@BMON  4
      *
     C                     MOVEL*BLANK    P@KOTE  3
     C                     MOVEL*BLANK    P@KIBN  3
     C                     Z-ADD1         X       10
      *
     C           1         DO   4         X
     C           AK,X      IFNE *BLANK
     C                     MOVELAK,X      P@KOTE
     C                     MOVELAK,X      WAKT    2
     C           WAKT      IFEQ 'SL'
     C           WAKT      OREQ 'DT'
     C                     MOVELKB,X      P@KIBN
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           P@KIBN    IFEQ *BLANK
     C                     GOTO @END
     C                     END
      *
     C                     MOVEL*BLANK    O@SRT  20
     C                     MOVELP@KIBN    O@SRT  20
      *
     C                     SELEC
     C           P@KIBN    WHEQ 'DT4'
     C                     MOVEL'DTR4'    O@SRT  20
     C           P@KIBN    WHEQ 'DT5'
     C                     MOVEL'DTR5'    O@SRT  20
     C           P@KIBN    WHEQ 'S37'
     C                     MOVEL'SRT37'   O@SRT  20
     C                     ENDSL
      *
      *
     C                     MOVE P@BMON    W@BMON  40
     C                     MOVE P@KOTE    W@AKT   3
     C                     MOVE P@KIBN    W@KBN   3
     C                     MOVE P@HIN1    O@HIN1  5
     C                     MOVE P@HIN2    O@HIN2  5
     C                     MOVE P@HIN3    O@HIN3  2
     C                     EXSR #OUT
      *****
     C           @END      TAG
      *===============================================================
      *
      *================================================================
     C           #OUT      BEGSR
      *
     C                     EXSR #MFA
      *
     C           FCEKEY    KLIST
     C                     KFLD           O@HIN1
     C                     KFLD           O@HIN2
     C                     KFLD           O@HIN3
      *
     C                     EXSR #FCE
     C   55                GOTO EOUT
      *
JW2   * SET TURN#
 |   C**                   EXSR #GETL
 |   C**         OKFLG     IFEQ 'Y'
 |   C**                   MOVELLIN#      KEY2    20
 |   C**         KEY2      CHAINAAHPPS5              99
 |   C**         *IN99     IFEQ *OFF
 |   C**                   Z-ADDS5TRN#    M@RPMH
 |   C**                   ELSE
 |   C**                   Z-ADD0         M@RPMH
 |   C**                   ENDIF
JW2  C**                   ENDIF
JW3   * SET TURN#
 |   C                     MOVELO@HIN1    PMHIN1
 |   C                     MOVELO@HIN2    PMHIN2
 |   C                     MOVELO@HIN3    PMHIN3
 |   C                     MOVELP@KOTE    PMPRCC
 |   C                     CALL 'UTLR14'
 |   C                     PARM           PMHIN1  5
 |   C                     PARM           PMHIN2  5
 |   C                     PARM           PMHIN3  2
 |   C                     PARM           PMPRCC  3
 |   C                     PARM           PMPRCP  3
 |   C                     PARM           @MCN    3
 |   C                     PARM           PMMCNP  3
 |   C                     PARM           PMMCN1  3
 |   C                     PARM           PMRTN   1
 |   C                     MOVEL@MCN      KEY2    3
 |   C           KEY2      CHAINAAHPPS6              99
 |   C           *IN99     IFEQ *OFF
 |   C                     Z-ADDS6TRN#    M@RPMH
 |   C                     ELSE
 |   C                     Z-ADD0         M@RPMH
JW3  C                     ENDIF
      *
     C                     EXCPTODAT
      *
     C           EOUT      ENDSR
      *================================================================
JW2   *   GET LINE# FROM SORT NAME
 |    *================================================================
 |   C**         #GETL     BEGSR
 |    *
 |   C**                   MOVE *BLANK    LIN#    2
 |   C**                   MOVE 'N'       OKFLG   1
 |   C**                   MOVEAO@SRT     T7A
 |   C**                   MOVEA*BLANK    T7B
 |   C**                   Z-ADD0         IY      10
 |   C**         1         DO   7         IX      10
 |   C**         T7A,IX    IFGE '0'
 |   C**         T7A,IX    ANDLE'9'
 |   C**                   ADD  1         IY
 |   C**                   MOVE T7A,IX    T7B,IY
 |   C**                   ENDIF
 |   C**                   ENDDO
 |    *
 |   C**         IY        IFNE 0
 |   C**         T7B,2     IFEQ *BLANK
 |   C**                   MOVE T7B,1     T7B,2
 |   C**                   MOVE 0         T7B,1
 |   C**                   ENDIF
 |   C**                   MOVE 'Y'       OKFLG
 |   C**                   MOVEAT7B       LIN#
 |   C**                   ENDIF
 |    *
JW2  C**                   ENDSR
      *================================================================
      * .. PART INFORMATION M/F   *.
      *================================================================
     C           #FCE      BEGSR
      *
     C           FCEKEY    CHAINFCEPL01              55
     C           *IN55     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     SETON                     55
     C                     END
     C                     END
      *
      *設定数
     C                     Z-ADD0         O@TANJ  72       単重
      *内示
      * P@TNSU:内示がなかった納入先の実績
     C                     CALL 'ABBRS6'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@N2NM 100
     C                     PARM           P@N1NM 100
     C                     PARM           P@NNNM 100
     C                     PARM           P@1NNM 100
     C                     PARM           P@2NNM 100
     C                     PARM           P@NTYM  60
     C                     PARM           P@TNSU 100
      *内示月度
     C                     MOVELP@NTYM    F@NTYM
     C                     CALL 'AGDRS1'
     C                     PARM           F@NTYM  6
     C                     PARM           F@DAYS  2
     C                     MOVE F@DAYS    F#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@NTYM    F@NTMM  2
     C**         F@NTMM    IFEQ '07'
     C**                   SUB  5         F#DAYS
     C**                   END
JW6   * 2020/04 SPECIAL
 |   C           F#DAYS    IFEQ 0
 |   C           P@NTYM    ANDEQ202004
 |   C                     Z-ADD22        F#DAYS
JW6  C                     ENDIF
      *
     C           P@NNNM    DIV  F#DAYS    F@NNNM 100
      * N/N+1/N+2を求める
     C                     CALL 'ABBRSD'
     C                     PARM           F@NTYM
     C                     PARM           F@N1
     C                     PARM           F@N2
      * N+1の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N1    6
     C                     PARM           F@DAY1  2
     C                     MOVE F@DAY1    F#DAY1  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N1      F@N1MM  2
     C**         F@N1MM    IFEQ '07'
     C**                   SUB  5         F#DAY1
     C**                   END
      *
     C           P@1NNM    DIV  F#DAY1    F@1NNM 100
      * N+2の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N2    6
     C                     PARM           F@DAY2  2
      *
     C                     MOVE F@DAY2    F#DAY2  20
     C                     MOVE F@N2      F@N2MM  2
      *
     C           P@2NNM    DIV  F#DAY2    F@2NNM 100
      *実績- ALL
     C                     CALL 'MBERS1'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GOKE  80
      *
     C                     Z-ADD0         P@GOKG  80
%0002 * LAST MONTH'S SHIPPING RESULT - TOYOTA
     C                     MOVEL'TYT'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      * LAST MONTH'S SHIPPING RESULT - SIA
     C                     MOVEL'SIA'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      * LAST MONTH'S SHIPPING RESULT - AWNC
     C                     MOVEL'AIS'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      * LAST MONTH'S SHIPPING RESULT - FORD
     C                     MOVEL'FRD'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      *実績月度
     C                     CALL 'MCEC00'
     C                     PARM           R@DATE  8
     C                     MOVELR@DATE    R@YYMM  6
      *実績月度の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           R@YYMM  6
     C                     PARM           R@DAYS  2
     C                     MOVE R@DAYS    R#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE R@YYMM    R@MM    2
     C***        R@MM      IFEQ '07'
     C***                  SUB  5         R#DAYS
     C***                  END
      * ALL QTY.
     C           R#DAYS    IFNE *ZERO
     C           P@GOKE    DIV  R#DAYS    R@GOKE  80
     C                     ENDIF
      *
%0002 * SPECIFIC GROUP
     C           R#DAYS    IFNE *ZERO
     C           P@GOKG    DIV  R#DAYS    R@GOKG  80
     C                     ENDIF
      * OTHERS
     C           P@GOKE    SUB  P@GOKG    P@GOKO  80
     C           R#DAYS    IFNE *ZERO
     C           P@GOKO    DIV  R#DAYS    R@GOKO  80
     C                     ENDIF
      *
      *内示なし実績
     C           R#DAYS    IFNE *ZERO
     C           P@TNSU    DIV  R#DAYS    R@TNSU  80
     C                     ENDIF
      * N
     C                     ADD  R@TNSU    F@NNNM
      * N+1
     C                     ADD  R@TNSU    F@1NNM
      * N+2
     C                     ADD  R@TNSU    F@2NNM
      *
     C                     EXSR #FCG
      *
     C                     MOVE A21HB5    K@CMP1
     C                     MOVE A22HB5    K@CMP2
     C                     MOVE A23HB2    K@CMP3
     C                     EXSR #CMP
     C                     Z-ADDEDHDSC    E#HDS1  83
     C                     Z-ADDED2SDS    E#2SD1  83
     C                     MOVE W@ENGN    W@ENG1 15
      *
     C                     MOVE A24HB5    K@CMP1
     C                     MOVE A25HB5    K@CMP2
     C                     MOVE A26HB2    K@CMP3
     C                     EXSR #CMP
     C                     Z-ADDEDHDSC    E#HDS2  83
     C                     Z-ADDED2SDS    E#2SD2  83
     C                     MOVE W@ENGN    W@ENG2 15
      *
     C                     EXSR #NEXT
      *
     C                     EXSR #PRE
      *
     C           EFCE      ENDSR
      *================================================================
      *  FACILITY MANAGEMENT M/F設備管理マスター
      *================================================================
     C           #MFA      BEGSR
      *
     C                     Z-ADD0         W@KADO 100
      *
     C           MFAKEY    KLIST
     C                     KFLD           W@BMON
     C                     KFLD           W@KBN
     C                     KFLD           W@AKT
      *
     C           MFAKEY    SETLLMFAPL25
     C                     DO   *HIVAL
     C           MFAKEY    READEMFAPL25                  44
     C   44                LEAVE
     C           M@SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
      *
     C                     Z-ADD0         T#OUTS 100
     C                     Z-ADD0         T#HOUR 100
     C                     Z-ADD0         T#RPMH  60
      *
     C           *IN44     IFEQ '1'
     C                     MOVE *BLANK    M@KGUN
     C                     MOVE *BLANK    M@KEIS
     C                     Z-ADD0         M@RPMH
     C                     GOTO EMFA
     C                     END
      *実績月度
     C                     CALL 'MCEC00'
     C                     PARM           R@DATE  8
      *
     C                     MOVE R@DATE    T#SDAT
     C                     MOVE '01'      T#SDAT
     C                     MOVE R@DATE    T#EDAT
     C                     MOVELW@KBN     T#KIBN
     C                     CALL 'MTARS1'
     C                     PARM           T#SDAT  80
     C                     PARM           T#EDAT  80
     C                     PARM           T#KIBN  3
     C                     PARM           T#OUTS 100
     C                     PARM           T#HOUR 100
     C                     PARM           T#RPMH  60
      *
     C                     Z-ADDT#RPMH    W@KADO
      *
     C           EMFA      ENDSR
      *================================================================
      *  ..製品図面　情報マスター（海外向け）      *
      *================================================================
     C           #FCG      BEGSR
      *
     C           FCEKEY    CHAINFCGPP31              78
     C           *IN78     IFEQ '0'
     C           E1SKJY    IFEQ 'D'
     C                     SETON                     78
     C                     END
     C                     END
     C           *IN78     IFEQ '1'
     C                     MOVE *BLANK    E1KODO
     C                     MOVE *BLANK    E1SHP1
     C                     MOVE *BLANK    E1SHP2
     C                     MOVE *BLANK    E1SHP3
     C                     MOVE *BLANK    E1SHP4
     C                     MOVE *BLANK    E1SHP5
     C                     MOVE *BLANK    E1SHP6
     C                     END
      *
     C                     MOVE *BLANK    EWSHP1
     C                     MOVE *BLANK    EWSHP2
     C                     MOVE *BLANK    EWSHP3
     C                     MOVE *BLANK    EWSHP4
     C                     MOVE *BLANK    EWSHP5
     C                     MOVE *BLANK    EWSHP6
     C                     MOVELE1SHP1    EWSHP1 15
     C                     MOVELE1SHP2    EWSHP2 15
     C                     MOVELE1SHP3    EWSHP3 15
     C                     MOVELE1SHP4    EWSHP4 15
     C                     MOVELE1SHP5    EWSHP5 15
     C                     MOVELE1SHP6    EWSHP6 15
      *
     C                     EXSR #FCG2
      *
     C           EFCG      ENDSR
      *================================================================
      *  ..製品図面　情報名称マスター（海外向け）  *
      *================================================================
     C           #FCG2     BEGSR
      *
     C           FCGKEY    KLIST
     C                     KFLD           E1SHP1
     C                     KFLD           FCGKY1  1
     C                     KFLD           FCGKY2  1
      *
     C                     MOVE '1'       FCGKY1
     C                     MOVE E1SHP1    FCGKY2
     C           FCGKEY    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    EWSHP1
     C                     END
      *
     C                     MOVE '2'       FCGKY1
     C                     MOVE E1SHP2    FCGKY2
     C           FCGKEY    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    EWSHP2
     C                     END
      *
     C                     MOVE '3'       FCGKY1
     C                     MOVE E1SHP3    FCGKY2
     C           FCGKEY    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    EWSHP3
     C                     END
      *
     C                     MOVE '4'       FCGKY1
     C                     MOVE E1SHP4    FCGKY2
     C           FCGKEY    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    EWSHP4
     C                     END
      *
     C                     MOVE '5'       FCGKY1
     C                     MOVE E1SHP5    FCGKY2
     C           FCGKEY    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    EWSHP5
     C                     END
      *
     C                     MOVE '6'       FCGKY1
     C                     MOVE E1SHP6    FCGKY2
     C           FCGKEY    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    EWSHP6
     C                     END
      *
     C           EFCG2     ENDSR
      *================================================================
      * **
      *================================================================
     C           #NEXT     BEGSR
      *
     C                     MOVE O@HIN1    PIHIN1  5
     C                     MOVE O@HIN2    PIHIN2  5
     C                     MOVE O@HIN3    PIHIN3  2
     C                     MOVE *BLANK    PIBMON  4
     C                     MOVE *BLANK    PIKOTE  3
     C                     MOVE *BLANK    PIKIBN  3
     C                     MOVE M6JBN1    PIBAN1  1
     C                     MOVE M6JBN2    PIBAN2  2
     C                     MOVE M6JBN3    PIBAN3  2
     C                     MOVE M6JBN4    PIBAN4  1
     C                     MOVE *DATE     PIDATE  8
     C                     MOVE '01'      PIBIN   2
      *
     C                     MOVE *BLANK    POBMON  4
     C                     MOVE *BLANK    POKOTE  3
     C                     MOVE *BLANK    POKIBN  3
      *
     C           AAMRS6    PLIST
     C                     PARM           PIHIN1  5
     C                     PARM           PIHIN2  5
     C                     PARM           PIHIN3  2
     C                     PARM           PIBMON  4
     C                     PARM           PIKOTE  3
     C                     PARM           PIKIBN  3
     C                     PARM           PIBAN1  1
     C                     PARM           PIBAN2  2
     C                     PARM           PIBAN3  2
     C                     PARM           PIBAN4  1
     C                     PARM           PIDATE  8
     C                     PARM           PIBIN   2
      *
     C                     PARM           POBMON  4
     C                     PARM           POKOTE  3
     C                     PARM           POKIBN  3
      *
     C                     CALL 'AAMRS6'  AAMRS6
      *
     C                     MOVELPOKOTE    O@KOTE  3
     C                     MOVE *BLANK    O@KIBN 15
     C                     MOVELPOKIBN    O@KIBN
     C           POBMON    IFNE *BLANK
     C           POBMON    ANDNE'0111'
     C                     MOVE POBMON    N@BMON  40
     C           N@BMON    CHAINFGBPL01              65
     C  N65                MOVELB2SMEI    O@KIBN
     C                     END
      *
     C           ENEXT     ENDSR
      *================================================================
      *指定した部門・工程・機番の前の部門・工程・機番を取得
      *================================================================
     C           #PRE      BEGSR
      *
     C                     MOVE O@HIN1    PIHIN1  5
     C                     MOVE O@HIN2    PIHIN2  5
     C                     MOVE O@HIN3    PIHIN3  2
     C                     MOVE W@BMON    PIBMON  4
     C                     MOVE W@AKT     PIKOTE  3
     C                     MOVE W@KBN     PIKIBN  3
     C                     MOVE *BLANK    PIBAN1  1
     C                     MOVE *BLANK    PIBAN2  2
     C                     MOVE *BLANK    PIBAN3  2
     C                     MOVE *BLANK    PIBAN4  1
     C                     MOVE *DATE     PIDATE  8
     C                     MOVE '01'      PIBIN   2
      *
     C                     MOVE *BLANK    POBMON  4
     C                     MOVE *BLANK    POKOTE  3
     C                     MOVE *BLANK    POKIBN  3
      *
     C                     CALL 'AAMRS5'  AAMRS6
      *
     C                     MOVELPOKOTE    @@KOTE  3
     C                     MOVE *BLANK    @@KIBN 15
     C                     MOVELPOKIBN    @@KIBN
     C**         POBMON    IFNE *BLANK
     C**         POBMON    ANDNE'0111'
     C**                   MOVE POBMON    N@BMON  40
     C**         N@BMON    CHAINFGBPL01              65
     C**N65                MOVELB2SMEI    @@KIBN
     C**                   END
      *
     C                     ENDSR
      *================================================================
      *  ..製品図面　情報マスター（最新のみ）
      *================================================================
     C           #CMP      BEGSR
      *
     C                     MOVE *BLANK    W@ENGN 15
      *
     C           CMPKEY    KLIST
     C                     KFLD           K@CMP1  5
     C                     KFLD           K@CMP2  5
     C                     KFLD           K@CMP3  2
     C           CMPKEY    SETGTFCGPP05
     C           CMPKEY    REDPEFCGPP05                  75
     C   75                Z-ADD0         EDHDSC
     C   75                Z-ADD0         ED2SDS
     C   75                GOTO ECMP
      *
     C           FCGKKK    KLIST
     C                     KFLD           EDSHP1
     C                     KFLD           FCGKY1  1
     C                     KFLD           FCGKY2  1
      *
     C                     MOVE '4'       FCGKY1
     C                     MOVE EDSHP4    FCGKY2
