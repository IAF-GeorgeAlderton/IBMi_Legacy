     H            Y.
     F** MRAR22 *********************************************
     F* TRANSMIT TO ASJ                                     *
     F*     TRANCOM ITS.           2012.09.17               *
     F*******************************************************
     FMRAPP31 IF  E                    DISK
     FMRAPL11 UF  E           K        DISK
     FMRAPP41 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80MASKHZ
     I                                        1   40MASKYY
     I                                        5   60MASKMM
     I                                        7   80MASKDD
      *
     C                     READ MRAPP311                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ MRAPP311                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYM12    KLIST
     C                     KFLD           #KKENO  9
     C                     KFLD           #KKENA  1
     C                     MOVELMCKENO    #KKENO
     C                     MOVELMCKENA    #KKENA
     C           KEYM12    SETLLMRAPL111
     C           KEYM12    READEMRAPL111                 20
     C           *IN20     DOWEQ'0'
     C           MASKJY    IFEQ 'D'
     C           MASKHZ    ANDLE*DATE
     C                     ELSE
     C           MASTAT    IFEQ '01'
     C           MASTAT    OREQ '02'
     C           MASTAT    OREQ '03'
     C           MASNDT    IFEQ 0
     C                     Z-ADD*DATE     MASNDT
     C                     TIME           MASNTI
     C                     UPDATMRAPL111
     C                     CLEARMRAPP411
     C                     MOVELMASKJY    MDSKJY
     C                     Z-ADDMASKYY    MDSKYY
     C                     Z-ADDMASKMM    MDSKMM
     C                     Z-ADDMASKDD    MDSKDD
     C                     Z-ADDMAKOYY    MDKOYY
     C                     Z-ADDMAKOMM    MDKOMM
     C                     Z-ADDMAKODD    MDKODD
     C                     Z-ADDMAKOHH    MDKOHH
     C                     Z-ADDMAKOSS    MDKOSS
     C                     MOVELMAKOME    MDKOME
     C                     Z-ADDMASAYY    MDSAYY
     C                     Z-ADDMASAMM    MDSAMM
     C                     Z-ADDMASADD    MDSADD
     C                     Z-ADDMASATH    MDSATH
     C                     Z-ADDMASATM    MDSATM
     C                     Z-ADDMASATS    MDSATS
     C                     MOVELMAKENO    MDKENO
     C                     MOVELMAKENA    MDKENA
     C                     MOVELMAKEED    MDKEED
     C                     MOVELMASTAT    MDSTAT
     C                     Z-ADDMASNDT    MDSNDT
     C                     Z-ADDMASNTI    MDSNTI
     C                     Z-ADDMASBDT    MDSBDT
     C                     Z-ADDMASBTI    MDSBTI
     C                     Z-ADDMALIDT    MDLIDT
     C                     Z-ADDMALITI    MDLITI
     C                     WRITEMRAPP411
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYM12    READEMRAPL111                 20
     C                     ENDDO
      *
     CSR         ESB500    ENDSR
