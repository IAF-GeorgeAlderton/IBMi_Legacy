     H            Y.
      ** EGBR99 ****************
      * MENU PGM CHANGE        *
      * T.SAKASHITA 2005.09.26 *
      **************************
     FEGBPW99 CF  E                    WORKSTN
     FEGBPL14 UF  E           K        DISK
      *
     E                    ER      1   8 60               ERR
      *
     I            DS
     I                                        1   80M1KOHZ
     I                                        1   40M1KOYY
     I                                        5   60M1KOMM
     I                                        7   80M1KODD
     I            DS
     I                                        1   80MAKOHZ
     I                                        1   40MAKOYY
     I                                        5   60MAKOMM
     I                                        7   80MAKODD
      *--------*
      *初期化*
      *--------*
     C           @INIT     TAG
     C                     MOVE *BLANK    I1PGMO
     C                     MOVE *BLANK    I1PGMN
     C                     Z-ADD0         I1CONT
      *--------*
      *画面１*
      *--------*
     C           @DSP1     TAG
     C                     EXFMTEGBPW991
     C                     SETOF                     990102
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     Z-ADD0         I1CONT
      * 未入力エラー
     C           I1PGMO    IFEQ *BLANK
     C                     MOVELER,1      ERR
     C                     SETON                     0199
     C                     GOTO @DSP1
     C                     ENDIF
     C           I1PGMN    IFEQ *BLANK
     C                     MOVELER,2      ERR
     C                     SETON                     0299
     C                     GOTO @DSP1
     C                     ENDIF
     C*プログラム使用件数カウント
     C                     SETOF                     33
     C                     Z-ADD0         I1CONT
     C           I1PGMO    SETLLEGBPL141
     C                     DO   *HIVAL
     C           I1PGMO    READEEGBPL141                 33
     C           *IN33     IFEQ '0'
     C                     ADD  1         I1CONT
     C                     ELSE
     C                     LEAVE
     C                     END
     C                     ENDDO
      *件数ゼロ
     C           I1CONT    IFEQ 0
     C                     MOVELER,3      ERR
     C                     SETON                     0199
     C                     GOTO @DSP1
     C                     END
      *----*
      * F5 *
      *----*
     C           *INKE     IFEQ '0'
     C                     GOTO @DSP1
     C                     ENDIF
      *削除実行
     C                     MOVE I1PGMO    O1PGMO
     C                     MOVE I1PGMN    O1PGMN
     C                     SETOF                     33
     C                     Z-ADD0         O1CONT
     C           I1PGMO    SETLLEGBPL141
     C                     DO   *HIVAL
     C           I1PGMO    READEEGBPL141                 33
     C           *IN33     IFEQ '0'
     C                     MOVE I1PGMN    MPPGMN
     C                     UPDATEGBPL141
     C                     ADD  1         O1CONT
     C                     ELSE
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     GOTO @INIT
**
E-01 INPUT OLD PGM NAME.
E-02 INPUT NEW PGM NAME.
E-03 NODOBY USES THIS PGM.
