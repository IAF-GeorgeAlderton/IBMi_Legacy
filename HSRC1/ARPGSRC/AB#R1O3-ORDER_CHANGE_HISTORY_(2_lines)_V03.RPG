 .   C                     PARM           $NUKE   4
 .   C                     PARM           $MHIN  20
 .   C                     PARM           $NOHZ   8
 .   C                     PARM           $SBAN   6
JW1  C                     MOVEL$SBAN     S@SBAN
      *
     C                     ADD  1         RRN1
     C           RRN1      IFGE 9999
     C                     LEAVE
     C                     ENDIF
