     C                     MOVEL'TOYOTA'  X@OPTN
     C           X@HONF    WHNE *BLANK
     C                     MOVEL'HONDA '  X@OPTN
     C           X@FORF    WHNE *BLANK
     C                     MOVEL'FORD  '  X@OPTN
