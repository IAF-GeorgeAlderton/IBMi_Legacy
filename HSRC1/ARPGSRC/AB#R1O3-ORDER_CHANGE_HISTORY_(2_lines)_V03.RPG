     C                     ENDDO
      * HEADER
     C                     MOVEL'N/A   '  X@OPTN
     C                     SELEC
     C           X@NONY    WHNE 0
     C                     MOVELX@NONY    X@OPTN    P
     C           X@USER    WHNE *BLANK
     C                     MOVELX@USER    X@OPTN    P
