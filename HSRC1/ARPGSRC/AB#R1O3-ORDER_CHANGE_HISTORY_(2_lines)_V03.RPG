      *
     C                     EXSR #INIT
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *================================================================
      * DISPLAY SCREEN 1
      *================================================================
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F3:END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * ENTER KEY
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C                     EXSR #SET1
      *
     C           RRN1      IFGT 0
      *
     C           *INKE     IFEQ *ON
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE '01'      @@ID
     C                     MOVE ERR,6     X@MSG
     C                     ENDIF
      *
     C                     ELSE
     C                     SETON                     6162
     C                     MOVE '01'      @@ID
     C                     MOVE ERR,5     X@MSG
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------------------
      * CLEAR VALUES
      *----------------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    X@MSG
     C                     SETOF                     606162
     C                     SETOF                     636465
     C                     SETOF                     666768
     C                     SETOF                     697071
     C                     MOVE *OFF      *IN85
      *
     C                     ENDSR
      *----------------------------------------------------------------
      * CHECK SCREEN 1 DATA
      *----------------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      * CHECK DATE
     C           X@FROM    IFEQ 0
     C                     MOVELERR,1     X@MSG
     C                     SETON                     61  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELX@FROM    $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFNE ' '
     C                     MOVELERR,2     X@MSG
     C                     SETON                     61  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           X@TO      IFEQ 0
     C                     Z-ADDX@FROM    X@TO
     C                     ENDIF
      *
     C                     MOVELX@TO      $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFNE ' '
     C                     MOVELERR,3     X@MSG
     C                     SETON                     62  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           X@TO      IFLT X@FROM
     C                     MOVE ERR,4     X@MSG
     C                     SETON                     616285
     C                     GOTO XCHK1
     C                     ENDIF
      * DELIVERY
     C**         X@NONY    IFNE 0
     C**         X@USER    IFNE *BLANK
JW1  C**         X@PO      ORNE *BLANK
     C**         X@TOYF    ORNE *BLANK
     C**         X@HONF    ORNE *BLANK
     C**         X@FORF    ORNE *BLANK
     C**                   MOVELERR,7     X@MSG
     C**                   SETON                     63  85
     C**                   GOTO XCHK1
     C**                   ENDIF
     C**                   ENDIF
      ** EXCLUSIVE **
      * USER
     C           X@USER    IFNE *BLANK
     C           X@TOYF    IFNE *BLANK
     C           X@HONF    ORNE *BLANK
     C           X@FORF    ORNE *BLANK
     C                     MOVELERR,7     X@MSG
     C                     SETON                     64  85
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * TOYOTA
     C           X@TOYF    IFNE 'Y'
     C           X@TOYF    ANDNE*BLANK
     C                     MOVELERR,8     X@MSG
     C                     SETON                     65  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           X@TOYF    IFNE *BLANK
     C           X@HONF    IFNE *BLANK
     C           X@FORF    ORNE *BLANK
     C                     MOVELERR,7     X@MSG
     C                     SETON                     65  85
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * HONDA
     C           X@HONF    IFNE 'Y'
     C           X@HONF    ANDNE*BLANK
     C                     MOVELERR,8     X@MSG
     C                     SETON                     66  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           X@HONF    IFNE *BLANK
     C           X@FORF    IFNE *BLANK
     C                     MOVELERR,7     X@MSG
     C                     SETON                     66  85
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * FORD
     C           X@FORF    IFNE 'Y'
     C           X@FORF    ANDNE*BLANK
     C                     MOVELERR,8     X@MSG
     C                     SETON                     67  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *----------------------------------------------------------------
      * SET DATA
      *----------------------------------------------------------------
     C           #SET1     BEGSR
      * CLEAR SUB FILE
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
      * CLEAR AB#WP1H (WORK FILE)
     C           *LOVAL    SETLLAB#WP1H
     C                     DO   *HIVAL
     C                     READ AB#WP1H                  98
     C   98                LEAVE
     C                     DELETAB#WP1H1
     C                     ENDDO
      *
     C                     Z-ADDX@FROM    K@YMD
     C           K#HL      SETLLAB#HL10
     C           *IN80     DOUEQ*ON
     C                     READ AB#HL10                  80
     C           *IN80     IFEQ *OFF
     C           AHYMD     IFGT X@TO
     C                     LEAVE
     C                     ENDIF
      * NONY
     C           X@NONY    IFNE 0
     C           X@NONY    ANDNEAHNONY
     C                     ITER
     C                     ENDIF
      * BIN#
     C           X@NOBN    IFNE 0
     C           X@NOBN    ANDNEAHNOBN
     C                     ITER
     C                     ENDIF
      * DOCK
     C           X@NUKE    IFNE *BLANK
     C           X@NUKE    ANDNEAHNUKE
     C                     ITER
     C                     ENDIF
      * SHN1
     C           X@SHIN    IFNE *BLANK
     C           X@SHIN    ANDNEAHSHIN
     C                     ITER
     C                     ENDIF
      * PO#
     C           X@PO      IFNE *BLANK
     C           X@PO      ANDNEAHODRN
     C                     ITER
     C                     ENDIF
      * USER
     C           X@USER    IFNE *BLANK
     C                     EXSR #USE
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * TOYOTA
     C           X@TOYF    IFNE *BLANK
     C                     EXSR #TOYO
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * HONDA
     C           X@HONF    IFNE *BLANK
     C                     EXSR #HONDA
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * FORD
     C           X@FORF    IFNE *BLANK
     C                     EXSR #FORD
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ENDIF
JW1   * GET INVOICE#
 .   C                     MOVE *BLANK    AHINVN
 .   C                     Z-ADDAHNONY    K#NONY  40
 .   C                     Z-ADDAHNOYY    K#NOYY  40
