     H            Y.
      ** FCER68 ******************************************************
      *  SERVICE PARTS FORECAST LIST (STEP 3) - PRINT                *
      *  J.WATANABE  2019.01.21                                      *
      ********************************************************
     FFCEWP66 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      ********************************************************
     E                    @YM         7  6 0
      *
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120TGTYM
     I                                        7  100TGTYY
     I                                       11  120TGTMM
     I            DS
     I                                        1   60#YM
     I                                        1   40#YY
     I                                        5   60#MM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ FCEWP66                  98
     C   98                LEAVE
      *
     C                     EXSR #PRINT
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * PRINT OPTION
      *************************************************************
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 65
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
      *
     C                     Z-ADD88        LIN#    20
     C                     Z-ADD0         SEQ#    40
     C                     TIME           @SDATE
      *
     C                     Z-ADDTGTYY     #YY
     C           TGTMM     SUB  1         #MM
      * SET TABLE
     C           1         DO   7         IX      20
     C           #MM       IFLE 6
     C                     ADD  1         #MM
     C                     ELSE
     C                     ADD  1         #YY
     C                     Z-ADD1         #MM
     C                     ENDIF
     C                     Z-ADD#YM       @YM,IX
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM       8
     O                         TODAY Y   69
     O                         NOW       79 '  :  :  '
     O                                   83 'P.'
     O                         PAGE  Z   86
     O        E   02           @HDR
     O                                   41 '** SERVICE PART FORE'
     O                                   61 'CAST LIST **        '
     O        E   04           @HDR
     O                                    6 'LOC2/3'
     O                                   18 'IAF PART...'
     O                                   30 'BASE DATE'
     O                         @YM,1     40 '    /  '
     O                         @YM,2     49 '    /  '
     O                         @YM,3     58 '    /  '
     O                         @YM,4     67 '    /  '
     O                         @YM,5     76 '    /  '
     O                         @YM,6     85 '    /  '
     O                                   97 'USR PART...'
      *
     O        E 1              @DTL
     O                         FWLOC2  +  1
     O                         FWLOC3  +  1
     O                         FWSHN1  +  1
     O                         FWSHN2  +  1
     O                         FWSHN3  +  1
     O                         FWNOYM  +  1 '    /  '
     O                         FWQTY11 +  1
     O                         FWQTY21 +  0
     O                         FWQTY31 +  0
     O                         FWQTY41 +  0
     O                         FWQTY51 +  0
     O                         FWQTY61 +  0
     O                         FWMHN1  +  2
     O                         FWMHN2  +  1
     O                         FWMHN3  +  1
