     FAJSPW25 CF  E                    WORKSTN
     FAJSPL01 IF  E           K        DISK
     FAARTL11 IF  E           K        DISK
     FAJSWP25 O   F     256            DISK                      A
     E                    ER      1  14 60               ERROR MESSAGE
     I            DS
     I                                        1  12 SHIN
     I                                        1   5 HIN1
     I                                        6  10 HIN2
     I                                       11  12 HIN3
     C           STEP0     TAG
     C                     MOVE *BLANK    SHIN
     C           STEP1     TAG
     C                     EXFMTAJSPW251
     C                     SETOF                     0199
      * CMD-1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      * ERROR CHECK
     C           HIN1      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     END
     C           HIN2      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     END
     C           HIN3      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           HIN1      IFNE '99999'
     C           HIN2      ANDNE'99999'
     C           HIN3      ANDNE'99'
     C                     EXSR SR1
     C           *IN99     IFEQ '1'
     C                     GOTO STEP1
     C                     END
     C                     ELSE
     C                     EXSR SR2
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      **********************************************************
     C           SR1       BEGSR
     C           KEY1      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C                     SETOF                     10
     C           KEY1      CHAINAJSPL011             10
      *
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO EXIT10
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    ANDLE*DATE
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO EXIT10
     C                     END
     C                     EXSR SR3
     C                     END
      *
     C           EXIT10    TAG
     C                     ENDSR
      **********************************************************
     C           SR2       BEGSR
     C           *LOVAL    SETLLAJSPL011
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AJSPL011                 10
     C           *IN10     IFEQ '0'
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    ANDLE*DATE
     C                     GOTO EXIT20
     C                     ELSE
     C                     EXSR SR3
     C                     END
     C                     END
     C           EXIT20    TAG
     C  N10                ENDDO
     C                     ENDSR
      **********************************************************
     C           SR3       BEGSR
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STEP1
     C                     END
      *
     C                     Z-ADD0         WTOK    40
     C                     Z-ADD0         WKAC    40
     C                     MOVE *BLANK    WSY1    4
     C                     MOVE *BLANK    WSY2    2
     C                     MOVE *BLANK    WSY3    1
     C                     Z-ADD0         WTAN    73
     C                     MOVE *BLANK    WTAI    1
      *
     C                     MOVELJ1SHN1    HIN1
     C                     MOVELJ1SHN2    HIN2
     C                     MOVELJ1SHN3    HIN3
     C                     SETOF                     20
     C           KEY1      CHAINAARTL111             20
     C           *IN20     IFEQ '0'
     C           CSSKJY    IFEQ 'D'
     C           CSSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDCSTOKC    WTOK
     C                     Z-ADDCSKACD    WKAC
     C                     MOVELCSSYR1    WSY1
     C                     MOVELCSSYR2    WSY2
     C                     MOVELCSSYR3    WSY3
     C                     Z-ADDCSTANJ    WTAN
     C                     MOVE CSTANI    WTAI
     C                     END
     C                     END
     C                     EXCPTDAT
     C                     ENDSR
      *
     OAJSWP25 EADD             DAT
     O                         J1SHN1
     O                         J1SHN2
     O                         J1SHN3
     O                         J1TANJ
     O                         J1MEK1
     O                         J1MEK2
     O                         J1MEK3
     O                         J1MSKB
     O                         J1MSKE
     O                         J1MSKJ
     O                         J1MSWS
     O                         J1MSNT
     O                         J1MSCK
     O                         J1MKRI
     O                         J1MKJI
     O                         J1MKSK
     O                         WTOK
     O                         WKAC
     O                         WSY1
     O                         WSY2
     O                         WSY3
     O                         WTAN
     O                         WTAI
**  ER
