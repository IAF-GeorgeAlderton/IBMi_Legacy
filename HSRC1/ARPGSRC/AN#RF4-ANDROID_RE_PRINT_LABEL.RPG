     C                     MOVELBAMHN2    EKMHN2
     C                     MOVELBAMHN3    EKMHN3
     C                     MOVELBAMHN4    EKMHN4
     C                     MOVE BANOBN    EKNOBN
     C                     Z-ADDBADEYY    EKRLYY
     C                     Z-ADDBADEMM    EKRLMM
     C                     Z-ADDBADEDD    EKRLDD
     C                     LEAVE
%0001C                     ENDIF
%0001C                     ENDDO
      *
     C                     MOVE *BLANK    F7LOC
     C           KEY4      CHAINFCEPL011             15
   B1C           *IN15     IFEQ '0'
   B2C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDA2KASI    @@WGHT  72
     C                     MOVELA2SMEI    F7DESC
     C                     MOVE A2ZETI    EKZETI
%0001C                     Z-ADDA2SSYS    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       F7SPQY
      *
   B3C           A2TRHZ    IFLE *DATE
     C                     MOVELA2STKR    F7LOC
     C                     ELSE
     C                     MOVELA2KTKR    F7LOC
   E3C                     END
 | E2C                     END
 TTE1C                     END
      *
     C                     MOVE FCSERL    F7SERL
     C           FCPBCD    IFEQ 'S'
     C           FCSERL    ANDEQ*BLANK
      ** SERIAL NUMBER
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    F7SERL
     C                     MOVE N3NMBR    FCSERL
      *
     C                     EXSR #PP70
     C                     ENDIF
      *
TCHK C                     MOVELFCCPAR    F7PBAR
TCHK C                     MOVELFCCPAR    F7PART
     C***                  MOVEAFCCPAR    PNO
     C***                  MOVE *BLANK    NOB
     C***        1         DO   20        M
     C***        PNO,M     IFEQ *BLANK
     C***        M         ADD  1         P
     C***        PNO,P     IFEQ *BLANK
     C***                  LEAVE
     C***                  ENDIF
     C***                  MOVE '-'       NOB,M
     C***                  ELSE
     C***                  MOVE PNO,M     NOB,M
     C***                  ENDIF
     C***                  ENDDO
      ***
     C***                  MOVEANOB       F7PART
     C*
     C* FIND THE FIRST BLANK BEFORE THE SUFIX PART NUMBER
     C***                  Z-ADD20        M       20
     C***                  MOVEAFCCPAR    PNO
     C***        PNO,M     DOUNE*BLANK
     C***                  SUB  1         M
     C***                  END
     C***
     C***        PNO,M     DOUEQ*BLANK
     C***                  SUB  1         M
     C***                  END
     C***
     C***                  Z-ADD*ZERO     W       20
     C***                  MOVE *BLANK    NOB
     C***        M         SUB  1         P       20
     C***        1         DO   P         W
     C***                  MOVE PNO,W     NOB,W
     C***                  END
     C***                  MOVEANOB       F7BASE
     C***
     C***                  Z-ADD*ZERO     W       20
     C***                  Z-ADD1         T       20
     C***                  MOVE *BLANK    NOA
     C***        M         ADD  1         P       20
     C***        P         DO   20        W
     C***                  MOVE PNO,W     NOA,T
     C***        T         IFEQ 4
     C***        T         ADD  1         TT      20
     C***        PNO,TT    IFNE *BLANK
     C***                  ADD  1         T
     C***                  ENDIF
     C***                  ENDIF
     C***                  ADD  1         T
     C***                  END
     C***                  MOVEANOA       F7SUFX
     C*
%0001C                     Z-ADDFCRQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWRQTY 15
%0001C                     Z-ADDFCUQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWUQTY 15
     C*
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'
%0001C                     MOVELWWRQTY    F7QTY
%0001C                     MOVELLBL,1     F7LABL
   B1C           FCPBCD    WHEQ 'S'
%0001C                     MOVELWWUQTY    F7QTY
%0001C                     MOVEL*BLANK    F7LABL
   E1C                     ENDSL
      *
      *
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'
     C           FCRQTY    MULT @@WGHT    @TWGHT 112
   B1C           FCPBCD    WHEQ 'S'
     C           FCUQTY    MULT @@WGHT    @TWGHT 112
     C                     ENDSL
      *
     C           @TWGHT    DIV  1000      @TWGHT
IH   C           @TWGHT    MULT 2.2046    @@LIB  112H
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'
     C           FCRQTY    DIV  A2SSYS    P
     C           0.7       MULT P         @BOX   112
     C           @@LIB     ADD  @BOX      @@LIB
   B1C           FCPBCD    WHEQ 'S'
     C                     ADD  0.7       @@LIB
     C                     ENDSL
      *
     C           @@LIB     MULT 1         @LWGHT  90H
%0001C                     Z-ADD@LWGHT    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       F7GWEH
      *
     C                     MOVEL'AVRTA'   F7SUPL
      * 2D
     C                     MOVE *BLANK    @DX7
     C           'P'       CAT  F7PBAR:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'Q':0     @DX7      P
     C           @DX7      CAT  F7QTY:0   @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'V':0     @DX7      P
     C           @DX7      CAT  F7SUPL:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'D':0     @DX7      P
     C                     MOVE FCSHDT    @6      6
     C           @DX7      CAT  @6:0      @DX7      P
     C******     @DX7      CAT  F7DATE:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
   B1C           FCPBCD    IFEQ 'M'
