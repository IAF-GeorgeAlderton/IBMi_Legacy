     C*  @SET : SET FIELD OF DISPLAY
     C**************************************************************************
     C           @SET      BEGSR
     C*
     C                     Z-ADD1         J
     C           1         DO   15        J
     C           SEQ,J     IFNE *ZERO
     C                     MOVE SEQ,J     KSEQ
     C           KEY1      CHAINABR6L01             N90
     C           *IN90     IFEQ *OFF
     C                     MOVEAWCDELY    DEL,J            DELIVERY
     C                     MOVEAWCSHDT    SHD,J            SHIPPING DATE
     C                     MOVEAWCIPAR    PAR,J            PART
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @CHK : CHECK INPUT FIELD
     C**************************************************************************
     C           @CHK      BEGSR
     C*
     C           #SEQFR    IFEQ *ZERO
     C           #SEQTO    ANDEQ*ZERO
     C*
     C           #SEQ1     IFEQ *ZERO
     C                     SETON                     3031
     C                     MOVEAMES,1     XMSG
     C                     END
     C*
     C                     ELSE
     C           #SEQFR    IFNE *ZERO
     C           #SEQTO    ANDNE*ZERO
     C*
     C           #SEQFR    IFGT #SEQTO
     C                     SETON                     3031
     C                     MOVEAMES,1     XMSG
     C                     END
     C*
     C                     ELSE
     C                     SETON                     3031
     C                     MOVEAMES,1     XMSG
     C                     END
     C                     END
     C*
     C                     Z-ADD1         L
     C           1         DO   15        L
     C           SEQ,L     IFNE *ZERO
     C                     MOVE SEQ,L     KSEQ
     C           KEY1      CHAINABR6L01             N90
     C*
     C           *IN90     IFEQ '1'
     C                     SETON                     30
     C           L         ADD  31        M
     C                     MOVEA'1'       *IN,M
     C                     MOVEAMES,1     XMSG
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @F5 : RE-CREATE LABEL DATE
     C**************************************************************************
     C           @F5       BEGSR
     C*
     C* FROM - TO
     C           #SEQFR    IFNE *ZERO
     C                     Z-ADD#SEQFR    KSEQ
     C           KEY1      SETLLABR6L01
     C                     READ ABR6L01                  90
     C           *IN90     DOUEQ'1'
     C           FCSEQ#    ORGT #SEQTO
     C*
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C                     EXSR @ADR
     C                     EXSR @MOVE1
     C           FCPRNT    IFEQ *BLANK
     C                     MOVE 'P'       FCPRNT
     C                     ENDIF
      *
     C                     UPDATABR6P011
      *
     C           FCPBCD    IFEQ 'S'
     C                     WRITEABR7P011
     C                     WRITEABR7P011
     C                     ENDIF
     C           FCPBCD    IFEQ 'M'
     C                     MOVE FC#PLT    F7PLT#
     C                     WRITEABR7P021
     C                     END
     C                     END
     C*
     C                     READ ABR6L01                  90
     C                     END
     C                     END
     C*
     C* INDIVISUAL
     C           #SEQFR    IFEQ *ZERO
     C                     Z-ADD1         L
     C           1         DO   15        L
     C*
     C           SEQ,L     IFNE *ZERO
     C                     MOVE SEQ,L     KSEQ
     C           KEY1      SETLLABR6L01
     C           KEY1      READEABR6L01                  90
     C*
     C           *IN90     DOWEQ'0'
     C*
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C                     EXSR @ADR
     C                     EXSR @MOVE1
     C           FCPBCD    IFEQ 'S'
     C                     WRITEABR7P011
     C                     WRITEABR7P011
     C                     ENDIF
     C           FCPBCD    IFEQ 'M'
     C                     MOVE FC#PLT    F7PLT#
     C                     WRITEABR7P021
     C                     END
     C                     END
     C           KEY1      READEABR6L01                  90
     C                     END
     C*
     C                     END
     C*
     C                     END
     C                     END
