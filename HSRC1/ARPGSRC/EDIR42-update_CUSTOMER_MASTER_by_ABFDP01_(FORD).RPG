     H            Y,
      *** EDIR42 ************************************************
      * UPDATE ADDRESS MASTER BY ABFDP01 (ROUTE MASTER)         *
      * J.WATANABE 2017.09.05                                   *
      ***********************************************************
     FABFDL01 IF  E           K        DISK
     FEDIPP42 UF  E           K        DISK                      A
     FQPRINT  O   F     198     OF     PRINTER
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
      *
     C                     MOVE 'Y'       FIRST   1
     C                     TIME           @TIME   60
      *
     C           *IN98     DOWEQ*OFF
     C                     READ ABFDL01                  98
     C           *IN98     IFEQ *OFF
     C           QANONY    ANDNE0
     C           QASKJY    ANDNE'D'
     C           QANONY    ANDNESVNONY
      * CHAIN
     C                     MOVELQANONY    LTR4    4
     C           LTR4      CHAINEDIPP42              99
     C           *IN99     IFEQ *OFF
     C                     MOVE 'N'       UPDFLG  1
      * SET DELEIVERY (NUMERIC)
     C                     MOVELQANONY    NUM4    40
     C           NUM4      IFNE E4NNY2
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4NNY2    S4NNY2  40
     C                     MOVELQANONY    E4NNY2
     C                     ENDIF
      * IF STATE=BLANK,
     C**         E4STCD    IFEQ *BLANK
     C**         ACSTAT    ANDNE*BLANK
     C**                   MOVE 'Y'       UPDFLG
     C                     MOVELE4STCD    S4STCD  2
     C**                   MOVELACSTAT    E4STCD
     C**                   ENDIF
      * IF COUNTRY<>'USA'
     C           E4CNT     IFNE 'USA'
     C           E4STCD    ANDNE' '
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4STCD    S4STCD
     C                     MOVEL'  '      E4STCD
     C                     ENDIF
      * IF COUNTRY=BLANK,
     C**         E4CNT     IFEQ *BLANK
     C**         ACCNTY    ANDNE*BLANK
     C**                   MOVE 'Y'       UPDFLG
     C                     MOVELE4CNT     S4CNT   3
     C**                   MOVELACCNTY    E4CNT
     C**                   ENDIF
      * IF COUTRY='US '
     C           E4CNT     IFEQ 'US '
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4CNT     S4CNT
     C                     MOVEL'USA'     E4CNT
     C                     ENDIF
      * IF COUNTRY<>'MX '
     C           E4CNT     IFEQ 'MX '
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4CNT     S4CNT
     C                     MOVEL'MEX'     E4CNT
     C                     ENDIF
      *
     C           E4GRP     IFNE 'FRD'
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4GRP     S4GRP   3
     C                     MOVEL'FRD'     E4GRP
     C                     ENDIF
      *
     C           UPDFLG    IFEQ 'Y'
     C                     MOVEL'BATCH42' E4KOPG
     C                     UPDATEDIPP421
     C                     EXSR #PRT1
     C                     ENDIF
      *
     C                     MOVELQANONY    SVNONY  40
     C                     ITER
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     CLEAREDIPP421
     C                     MOVELQANONY    E4NONY
     C                     MOVELQANONY    E4NNY2
     C                     MOVE *BLANK    E4STCD
     C                     MOVEL'FRD'     E4GRP
     C                     MOVE *BLANK    E4CNT
     C                     Z-ADD*DATE     E4CRHZ
     C                     TIME           E4CRTM
     C                     MOVEL#USER     E4CRME
     C                     MOVEL'EDIR42  'E4CRPG
     C                     WRITEEDIPP421
     C                     EXSR #PRT2
     C                     MOVELQANONY    SVNONY  40
     C                     ITER
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     C           #PRT1     BEGSR
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXCPT@HDR
     C                     ENDIF
      *
     C                     EXCPT@DTL1
      *
     C                     ENDSR
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     C           #PRT2     BEGSR
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXCPT@HDR
     C                     ENDIF
      *
     C                     EXCPT@DTL2
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** FORD  CUSTOMER M.'
     O                                   60 ' UPDATE RESULT **   '
     O                         UDATE     80 '  .  .  '
     O                         @TIME     90 '  :  :  '
     O                         #USER    102
     O        E   03           @HDR
     O                                    7 'GRP'
     O                                   12 'NONY'
     O                                   17 ' NUM'
     O                                   20 'ST'
     O                                   24 'CNT'
     O        E 1              @DTL1
     O                                    3 'BFR'
     O                         S4GRP   +  1
     O                         E4NONY  +  1
     O                         S4NNY2  +  1
     O                         S4STCD  +  1
     O                         S4CNT   +  1
     O        E 1              @DTL1
     O                                    3 'AFT'
     O                         E4GRP   +  1
     O                         E4NONY  +  1
     O                         E4NNY2  +  1
     O                         E4STCD  +  1
     O                         E4CNT   +  1
     O        E 1              @DTL1
     O                                    1 '*'
     O        E 1              @DTL2
     O                                    3 'ADD'
     O                         E4GRP   +  1
     O                         E4NONY  +  1
     O                         E4NNY2  +  1
     O                         E4STCD  +  1
     O                         E4CNT   +  1
     O        E 1              @DTL2
     O                                    1 '*'
