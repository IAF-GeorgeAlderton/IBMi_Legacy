     H            Y.
      ** AFAR94 **********************************************
      *       .. MATERIAL SUPPLY ORDER LIST ..               *
      *         K.KASHIWAGI     2000.12.01                   *
TCH50 *         TCH             03/12/05                     *
      ********************************* AFAR94 ***************
     FAFAPW94 CF  E                    WORKSTN
     FAFAPL94 IF  E           K        DISK
      *
     E                    MSGTBL  1  12 60
     I            DS
     I                                        1   80DATE
     I                                        1   20W@CT
     I                                        3   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     I            DS
     I                                        1  12 #PT#2
     I                                        1   5 #PT#12
     I                                        6  10 #PT#22
     I                                       11  12 #PT#32
     I            DS
     I                                        1  12 A9PAR
     I                                        1   5 A9PAR1
     I                                        6  10 A9PAR2
     I                                       11  12 A9PAR3
     I            DS
     I                                        1  100#FD2
     I                                        1   40#FDYY2
     I                                        5   60#FDMM2
     I                                        7   80#FDDD2
     I                                        9  100#FDBB2
     I            DS
     I                                        1  100#TD2
     I                                        1   40#TDYY2
     I                                        5   60#TDMM2
     I                                        7   80#TDDD2
     I                                        9  100#TDBB2
     I            DS
     I                                        1  100#FD3
     I                                        1   40#FDYY3
     I                                        5   60#FDMM3
     I                                        7   80#FDDD3
     I                                        9  100#FDBB3
     I            DS
     I                                        1  100#TD3
     I                                        1   40#TDYY3
     I                                        5   60#TDMM3
     I                                        7   80#TDDD3
     I                                        9  100#TDBB3
     I            DS
     I                                        1  100A9OD
     I                                        1   40A9ODYY
     I                                        5   60A9ODMM
     I                                        7   80A9ODDD
     I                                        9  100A9ODBB
     C           *ENTRY    PLIST
     C                     PARM           US     10        USER ID
     C* KEY BY SUPPLIER
     C           KEY2      KLIST
     C                     KFLD           A9SUPP
     C*
     C* KEY BY SUPPLIER, PART#
     C           KEY1      KLIST
     C                     KFLD           A9SUPP
     C                     KFLD           A9PAR1
     C                     KFLD           A9PAR2
     C                     KFLD           A9PAR3
      *--------------*
      * MAIN ROUTINE *
      *--------------*
     C                     EXSR @INTR
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      @DSP1
     C           W@ID      CASEQ'02'      @DSP2
     C           W@ID      CASEQ'03'      @DSP3
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
      *---------------*
      * INITIALIZATION
      *---------------*
     C           @INTR     BEGSR
     C                     MOVEL*BLANK    #MSG1
     C                     MOVEL*BLANK    #MSG2
     C                     MOVEL*BLANK    #MSG3
     C                     MOVEL*BLANK    #OPT1
     C                     MOVEL*BLANK    #PT#3  12
     C                     MOVEL'01'      W@ID    2
     C                     TIME           #TIME
     C                     MOVE *DATE     DATE
     C                     Z-ADD2000      W@YY4   40
     C                     ADD  W@YY      W@YY4
     C                     Z-ADD0         #FD2
     C                     Z-ADD0         #FD3
     C                     Z-ADD0         #TD2
     C                     Z-ADD0         #TD3
     C                     ENDSR
      *--------------*
      * FIRST SCREEN *
      *--------------*
     C           @DSP1     BEGSR
     C                     EXFMTAFAPW941
     C                     MOVEL*BLANKS   #MSG1
     C                     MOVEL'0'       *IN90
     C*
     C                     SELEC
     C           *INKA     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C                     OTHER
     C                     EXSR @CKOPT
     C                     ENDSL
     C                     ENDSR
      *--------------*
      * OPTION CHECK
      *--------------*
     C           @CKOPT    BEGSR
     C           #OPT1     IFNE 'A'
     C           #OPT1     ANDNE'B'
     C                     MOVELMSGTBL,1  #MSG1
     C                     MOVEL'1'       *IN90
     C                     ELSE
     C*
     C                     SELEC
     C           #OPT1     WHEQ 'A'
     C                     MOVEL'02'      W@ID
     C           #OPT1     WHEQ 'B'
     C                     MOVEL'03'      W@ID
     C                     ENDSL
     C                     ENDIF
     C*
     C                     ENDSR
      *---------------------*
      * KEY BY PART# SCREEN *
      *---------------------*
     C           @DSP2     BEGSR
     C                     EXFMTAB#PW942
     C                     MOVEL*BLANKS   #MSG2
     C                     MOVEL*BLANKS   ERRFLG  1
     C                     MOVEL*BLANKS   REC     1
     C                     MOVEL'0'       *IN90
     C                     MOVEL'0'       *IN80
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00000000'*IN,09
     C                     MOVEA'0000'    *IN,17
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL*BLANKS   #OPT1
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ '1'
TCH50C           *INKJ     OREQ '1'
     C                     EXSR @CKPT
     C                     ENDSL
     C*
     C                     ENDSR
      *-------------------*
      * CHECK KEY BY PART#*
      *-------------------*
     C           @CKPT     BEGSR
     C*
     C           #FD2      IFNE 0
     C           #FDYY2    IFLT 2000
     C                     SETON                     0290
     C           *IN02     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN12
     C                     MOVELMSGTBL,3  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #FDMM2    IFLE 0
     C           #FDMM2    ORGT 12
     C                     SETON                     0390
     C           *IN03     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN13
     C                     MOVELMSGTBL,4  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #FDDD2    IFLE 0
     C           #FDDD2    ORGT 31
     C                     SETON                     0490
     C           *IN04     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN14
     C                     MOVELMSGTBL,5  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #FDBB2    IFLT 0
     C           #FDBB2    ORGT 99
     C                     SETON                     0590
     C           *IN05     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN15
     C                     MOVELMSGTBL,6  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TD2      IFNE 0
     C           #TDYY2    IFLT 2000
     C                     SETON                     0690
     C           *IN06     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN16
     C                     MOVELMSGTBL,7  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TDMM2    IFLE 0
     C           #TDMM2    ORGT 12
     C                     SETON                     0790
     C           *IN07     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN17
     C                     MOVELMSGTBL,8  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TDDD2    IFLE 0
     C           #TDDD2    ORGT 31
     C                     SETON                     0890
     C           *IN08     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN18
     C                     MOVELMSGTBL,9  #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TDBB2    IFLT 0
     C           #TDBB2    ORGT 99
     C                     SETON                     0990
     C           *IN09     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN19
     C                     MOVELMSGTBL,10 #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVEL#SPCD2    A9SUPP
     C           KEY2      CHAINAFAPL94              40
     C           *IN40     IFEQ '1'
     C           #SPCD2    IFNE *BLANKS
     C                     SETON                     1090
     C           *IN10     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN20
     C                     MOVELMSGTBL,11 #MSG2
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           ERRFLG    IFEQ *BLANK
     C           #TD2      IFEQ 0
     C                     MOVEL*HIVAL    #TD2
     C                     ENDIF
     C           #SPCD2    IFEQ *BLANK
     C           #PT#2     IFEQ *BLANK
     C                     MOVEL'0'       *IN80
     C           *LOVAL    SETLLAFAPL94
     C           *IN80     DOWEQ'0'
     C                     READ AFAPL94                  80
     C           *IN80     IFEQ '0'
     C           A9OD      IFGE #FD2
     C           A9OD      ANDLE#TD2
     C                     MOVEL'Y'       REC     1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ELSE
     C                     MOVEL'0'       *IN80
     C           *LOVAL    SETLLAFAPL94
     C           *IN80     DOWEQ'0'
     C                     READ AFAPL94                  80
     C           *IN80     IFEQ '0'
     C           A9OD      IFGE #FD2
     C           A9OD      ANDLE#TD2
     C           A9PAR     ANDEQ#PT#2
     C                     MOVEL'Y'       REC     1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     ELSE
     C           #PT#2     IFEQ *BLANK
     C                     MOVEL'0'       *IN80
     C           *LOVAL    SETLLAFAPL94
     C                     MOVEL#SPCD2    A9SUPP
     C           *IN80     DOWEQ'0'
     C           KEY2      READEAFAPL94                  80
     C           *IN80     IFEQ '0'
     C           A9OD      IFGE #FD2
     C           A9OD      ANDLE#TD2
     C                     MOVEL'Y'       REC     1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ELSE
     C                     MOVEL'0'       *IN80
     C           *LOVAL    SETLLAFAPL94
     C                     MOVEL#SPCD2    A9SUPP
     C                     MOVEL#PT#12    A9PAR1
     C                     MOVEL#PT#22    A9PAR2
     C                     MOVEL#PT#32    A9PAR3
     C           *IN80     DOWEQ'0'
     C           KEY1      READEAFAPL94                  80
     C           *IN80     IFEQ '0'
     C           A9OD      IFGE #FD2
     C           A9OD      ANDLE#TD2
     C                     MOVEL'Y'       REC     1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           ERRFLG    IFEQ *BLANKS
     C           #MSG2     ANDEQ*BLANKS
     C           REC       IFEQ 'Y'
     C                     Z-ADD#FD2      #FD    100
     C                     Z-ADD#TD2      #TD    100
     C                     CALL 'AFAR95'
     C                     PARM           #PT#2
     C                     PARM           #FD
     C                     PARM           #TD
     C                     PARM           #SPCD2
     C                     PARM           US
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C                     MOVELMSGTBL,12 #MSG2
     C                     MOVEL'1'       *IN90
     C           #TD2      IFEQ *HIVAL
     C                     Z-ADD0         #TD2
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *---------------*
      * KEY BY ORDER# *
      *---------------*
     C           @DSP3     BEGSR
     C                     EXFMTAB#PW943
     C                     MOVEL*BLANKS   #MSG3
     C                     MOVEL*BLANKS   REC     1
     C                     MOVEL*BLANKS   ERRFLG
     C                     MOVEL'0'       *IN90
     C                     MOVEL'0'       *IN80
     C                     MOVEL'0'       *IN81
     C                     MOVEL'0'       *IN40
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00000000'*IN,09
     C                     MOVEA'0000'    *IN,17
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL*BLANKS   #OPT1
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ '1'
     C                     EXSR @CKOD
     C                     ENDSL
     C                     ENDSR
     C*-------------------*
     C* KEY BY ORDER CHECK*
     C*-------------------*
     C           @CKOD     BEGSR
     C           #FD3      IFNE 0
     C           #FDYY3    IFLT 2000
     C                     SETON                     0290
     C           *IN02     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN12
     C                     MOVELMSGTBL,3  #MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           #FDMM3    IFLE 0
     C           #FDMM3    ORGT 12
     C                     SETON                     0390
     C           *IN03     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN13
     C                     MOVELMSGTBL,4  #MSG3
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #FDDD3    IFLE 0
     C           #FDDD3    ORGT 31
     C                     SETON                     0490
     C           *IN04     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN14
     C                     MOVELMSGTBL,5  #MSG3
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #FDBB3    IFLT 0
     C           #FDBB3    ORGT 99
     C                     SETON                     0590
     C           *IN05     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN15
     C                     MOVELMSGTBL,6  #MSG3
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TD3      IFNE 0
     C           #TDYY3    IFLT 2000
     C                     SETON                     0690
     C           *IN06     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN16
     C                     MOVELMSGTBL,7  #MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TDMM3    IFLE 0
     C           #TDMM3    ORGT 12
     C                     SETON                     0790
     C           *IN07     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN17
     C                     MOVELMSGTBL,8  #MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TDDD3    IFLE 0
     C           #TDDD3    ORGT 31
     C                     SETON                     0890
     C           *IN08     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN18
     C                     MOVELMSGTBL,9  #MSG3
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           #TDBB3    IFLT 0
     C           #TDBB3    ORGT 99
     C                     SETON                     0990
     C           *IN09     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN19
     C                     MOVELMSGTBL,10 #MSG3
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVEL#SPCD3    A9SUPP
     C           KEY2      CHAINAFAPL94              40
     C           *IN40     IFEQ '1'
     C           #SPCD3    IFNE *BLANKS
     C                     SETON                     1090
     C           *IN10     IFEQ '1'
     C           ERRFLG    ANDEQ*BLANKS
     C                     MOVEL'1'       *IN20
     C                     MOVELMSGTBL,11 #MSG3
     C                     MOVEL'Y'       ERRFLG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           ERRFLG    IFEQ *BLANKS
     C           #MSG3     ANDEQ*BLANKS
     C           #TD3      IFEQ 0
     C                     MOVEL*HIVAL    #TD3
     C                     ENDIF
     C           #SPCD3    IFEQ *BLANK
     C                     MOVEL'0'       *IN80
     C           *LOVAL    SETLLAFAPL94
     C           *IN80     DOWEQ'0'
     C                     READ AFAPL94                  80
     C           *IN80     IFEQ '0'
     C           A9OD      IFGE #FD3
     C           A9OD      ANDLE#TD3
     C                     MOVEL'Y'       REC     1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ELSE
     C                     MOVEL'0'       *IN81
     C           *LOVAL    SETLLAFAPL94
     C                     MOVEL#SPCD3    A9SUPP
     C           *IN81     DOWEQ'0'
     C           KEY2      READEAFAPL94                  81
     C           *IN81     IFEQ '0'
     C           A9OD      IFGE #FD3
     C           A9OD      ANDLE#TD3
     C                     MOVEL'Y'       REC     1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
     C*
     C*
     C           ERRFLG    IFEQ *BLANKS
     C           #MSG3     ANDEQ*BLANKS
     C           REC       IFEQ 'Y'
     C                     Z-ADD#FD3      #FD    100
     C                     Z-ADD#TD3      #TD    100
     C                     CALL 'AFAR96'
     C*                    PARM           #PT#3
     C                     PARM           #FD
     C                     PARM           #TD
     C                     PARM           #SPCD3
     C                     PARM           US
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C                     MOVELMSGTBL,12 #MSG3
     C                     MOVEL'1'       *IN90
     C           #TD3      IFEQ *HIVAL
     C                     Z-ADD0         #TD3
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
** (MSGTBL)
E-01 OPTION IS OUT OF RANGE.  CHOOSE OPTION FROM A OR B.
E-02 INVALID PART#.
E-03 INVALID FROM ORDER YEAR.
E-04 INVALID FROM ORDER MONTH.
E-05 INVALID FROM ORDER DAY.
E-06 INVALID FROM ORDER BIN.
E-07 INVALID TO ORDER YEAR.
E-08 INVALID TO ORDER MONTH.
E-09 INVALID TO ORDER DAY.
E-10 INVALID TO ORDER BIN.
E-11 INVALID SUPPLIER CODE.
E-12 RECORD NOT FOUND.
