     C*
     C                     EXSR @OUT
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C******************************************************
     C           *INZSR    BEGSR
     C******************************************************
     C                     TIME           WWTIME
     C*
     C                     ENDSR
     C******************************************************
     C*    OUTPUT                                          *
     C******************************************************
     C           @OUT      BEGSR
     C*
     C           *LOVAL    SETLLAKBPL03
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AKBPL03                  99
     C   99                LEAVE
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1UKHZ    IFGT @@YMD
     C                     ITER
     C                     END
     C           L1STHZ    IFLE @@YMD
     C                     ITER
     C                     ENDIF
     C           L1BMON    IFNE 8990
     C                     ITER
     C                     END
     C*
     C                     CLEARGDMWP201
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELL1SHN1    W@SHN1
     C           L1SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELL1SHN2    W@SHN2
     C           L1SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELL1SHN3    W@SHN3
     C                     MOVELW@SHIN    W2SHIN
     C*
     C                     MOVELL1BMON    W2BMON
     C                     MOVELW@TKRO    W2LOC
     C*
     C           K#KEY     KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           K#KEY     CHAINGDMPL10              98
     C           *IN98     IFEQ *OFF
     C           M1SKJY    ANDEQ*BLANK
     C           M1CHGD    IFLE @@YMD
     C                     Z-ADDM1LOTN    W2LOTS
     C                     ELSE
     C                     Z-ADDM1LOTO    W2LOTS
     C                     END
     C                     END
     C*
     C                     MOVELW@BAR     W2BARC
     C*
     C           W2LOTS    IFNE *ZERO
     C                     WRITEGDMWP201
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*
