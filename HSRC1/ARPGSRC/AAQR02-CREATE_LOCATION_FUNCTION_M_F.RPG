     FAAQPL01 IP  E           K        DISK
     FQPRINT  O   F      80     OF     PRINTER
     C                     SETOF                     0102
     C  N03                TIME           WTIME   60
     C  N03                SETON                     0203
     C           DBSKJY    IFEQ 'D'
     C           DBSKHZ    IFLE *DATE
     C                     GOTO STEP99
     C                     END
     C                     END
     C                     SETON                     01
     C           STEP99    TAG
     OQPRINT  H  102   02
     O       OR        OF
     O                                   80 '+---------+'
     O        H  1     02
     O       OR        OF
     O                                    7 'APICS'
     O                                   58 'TIME'
     O                         WTIME Y   67
     O                                   80 '|         |'
     O        H  1     02
     O       OR        OF
     O                                   12 'AAQR02-1 '
     O                                   58 'DATE'
     O                         UDATE Y   67
     O                                   80 '|         |'
     O        H  2     02
     O       OR        OF
     O                                   38 '** LOCATION FUNCTION'
     O                                   50 'M/F LIST **'
     O                                   63 'PAGE'
     O                         PAGE  Z   67
     O                                   80 '+---------+'
     O        H  2     02
     O       OR        OF
     O                                   14 'FACTORY INST.'
     O                                   28 'PASSAGE INST.'
     O                                   41 '(CHG)FACTORY'
     O                                   54 '(CHG)PASSAGE'
     O                                   66 'SORT INST.'
     O                                   78 'PAPER NBR'
     O        D  1     01
