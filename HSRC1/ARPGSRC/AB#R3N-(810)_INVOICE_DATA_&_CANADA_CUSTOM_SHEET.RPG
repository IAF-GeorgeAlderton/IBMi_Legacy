TCHK3C*          $FLG      IFEQ '*'
TCHK3C*                    MOVE *BLANK    $MHN3
TCHK3C*                    MOVE *BLANK    $MHN4
TCHK3C*                    END
      *
     C                     MOVE BATOKU    @TOKU   4
     C                     MOVE BANONY    @NONY   4
