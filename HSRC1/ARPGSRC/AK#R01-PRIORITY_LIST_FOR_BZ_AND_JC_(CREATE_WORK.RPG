     C                     MOVEL'1'       OPNCLS
     C                     Z-ADD0         WWTOHZ  80
     C                     Z-ADD0         WWZNHZ  80
     C                     Z-ADD0         WWYOHZ  80
     C                     Z-ADD0         WWCIBI  20
     C                     READ AAIPL111                 20
     C           *IN20     IFEQ '0'
     C                     Z-ADDCDTOHZ    WWTOHZ
     C                     Z-ADDCDZNHZ    WWZNHZ
     C                     Z-ADDCDYOHZ    WWYOHZ
     C                     Z-ADDCDCIBI    WWCIBI
     C                     ENDIF
      * GET PAST 10 DAYS
     C           KEYF8     KLIST
     C                     KFLD           K1YY    40
     C                     KFLD           K1MM    20
     C                     KFLD           K1DD    20
     C                     Z-ADDWWTOHZ    K1HZ
     C                     Z-ADD0         WW10DY  80
     C                     Z-ADD1         X       20
     C           KEYF8     SETGTAGDPL121
     C                     READPAGDPL121                 20
     C           *IN20     DOWEQ'0'
     C***        X         ANDLE10
     C           X         ANDLE5
     C           F8HIRU    IFEQ *BLANK
     C                     Z-ADDF8KA      WW10DY
     C                     ADD  1         X
     C                     ENDIF
     C                     READPAGDPL121                 20
     C                     ENDDO
      * PICK UP COMPLETE
     C                     Z-ADD1         X
     C                     Z-ADD0         WWBIN   20
     C           X         DOWLE24
     C           DT,X      IFNE *BLANK
     C                     Z-ADDBI,X      WWBIN
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C                     Z-ADDWWTOHZ    WWCMHZ
     C           WWBIN     SUB  3         WWCMBB
     C           WWCMBB    IFLE 0
     C                     Z-ADDWWZNHZ    WWCMHZ
     C                     ADD  WWCIBI    WWCMBB
     C                     ENDIF
      *
     C                     READ FCEPL011                 20
     C           *IN20     DOWEQ'0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB390
     C                     ENDIF
     C                     READ FCEPL011                 20
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     EXSR #CLOSE
      *
     C                     SETON                     LR
     C                     RETRN
