     C                     PARM           P@PNHZ  8
     C                     PARM           P@RCHZ  8
     C                     PARM           P@OMAI  4
     C                     PARM           P#OPN   1
      *
     C                     MOVE P@OTHZ    W@OTHZ  80
     C           W@OTHZ    IFNE 0
     C                     MOVEL'1'       W1ODAY
     C                     ENDIF
     C*
     C                     ENDSR
      *--------------------------------------------------*
      * AK#WP01                                          *
      *--------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAK#WP011
     C           A2SY      IFLE *DATE
     C                     MOVELA2STR     W1LOC
     C                     ELSE
     C                     MOVELA2KTR     W1LOC
     C                     ENDIF
     C                     MOVELW1LOC     K@BANA
     C                     MOVELW1LOC     K#BANA
     C                     Z-ADDMINASI    W1QTY
     C                     Z-ADDPRE       W1PRE
     C                     Z-ADDMINO      W1MINO
     C                     MOVELA2BHB1    W1SHN1
     C                     MOVELA2BHB2    W1SHN2
     C                     MOVELA2BHB3    W1SHN3
     C                     Z-ADDA2SSYS    W1SSYS
     C                     Z-ADDX2UNS     W1UNS
     C                     Z-ADDCBBARL    W1BARL
     C                     MOVELA2MEK1    W1MEK1
     C                     MOVELA2MEK2    W1MEK2
     C                     MOVELA2MEK3    W1MEK3
     C                     MOVE *BLANK    P@JNAM
     C           W1KOTE    IFEQ 'JC '
     C           W1KOTE    OREQ 'KRO'
     C                     MOVEL*BLANK    P@JNAM
     C                     CALL 'DAHRS7'
     C                     PARM           A2BHB1
     C                     PARM           A2BHB2
     C                     PARM           A2BHB3
     C                     PARM           K#BAN1
     C                     PARM           K#BAN2
     C                     PARM           K#BAN3
     C                     PARM           K#BAN4
     C                     PARM           P@JNAM 20
     C                     PARM           P#OPN   1
     C                     MOVELP@JNAM    W1JNAM
     C                     ENDIF
      * SRT
     C                     MOVE *BLANK    P@SRTN
     C                     MOVE *BLANK    P@SRT#
     C                     CALL 'DAFRS7'
     C                     PARM           A2BHB1
     C                     PARM           A2BHB2
     C                     PARM           A2BHB3
     C                     PARM           K@BAN1
     C                     PARM           K@BAN2
     C                     PARM           K@BAN3
     C                     PARM           K@BAN4
