     C                     PARM           P@SRT# 20
     C                     PARM           P#OPN   1
     C                     MOVELP@SRTN    W1SRTN
     C                     MOVELP@SRT#    W1SRT#
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OKO
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPKOT      OKO
      *最終番地
     C                     MOVEL'0'       GET     1
     C                     Z-ADD15        XX      20
     C           XX        DOWGE1
     C           GET       ANDEQ'0'
     C           OTK,XX    IFNE *BLANK
     C                     MOVELOBM,XX    W1BMON
     C                     MOVELOKO,XX    W1KOTE
     C                     MOVELOKB,XX    W1KIBN
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     SUB  1         XX
     C                     ENDDO
      *前がトンネルの場合工程・機番
     C                     MOVEL'0'       GET     1
     C                     Z-ADD15        XX      20
     C           XX        DOWGE1
     C           GET       ANDEQ'0'
     C           OTK,XX    IFEQ '------'
     C                     MOVELOBM,XX    W1BMON
     C                     MOVELOKO,XX    W1KOTE
     C                     MOVELOKB,XX    W1KIBN
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     SUB  1         XX
     C                     ENDDO
      *
     C                     MOVEL'1'       WRTFLG  1
     C           W1KOTE    IFEQ 'KRO'
     C           W1KIBN    IFEQ 'A22'
     C           W1KIBN    OREQ 'JC4'
     C                     ELSE
     C                     MOVEL'0'       WRTFLG  1
     C                     ENDIF
     C                     ENDIF
     C           W1BMON    IFNE '0111'
     C                     MOVEL'0'       WRTFLG  1
     C                     ENDIF
      *
     C           W1KOTE    IFEQ 'VNL'
%01  C                     MOVEL*BLANK    W1PFLG
     C                     ELSE
%01  C                     MOVELW$PFLG    W1PFLG
     C                     ENDIF
      *
     C           W1KOTE    IFEQ 'BZ '
     C           W1KOTE    OREQ 'DS '
     C           W1KOTE    OREQ 'DSM'
     C           W1KOTE    OREQ 'JC '
     C           W1KOTE    OREQ 'SB '
     C           W1KOTE    OREQ 'KRO'
     C           W1KOTE    OREQ 'VNL'
     C           WRTFLG    IFEQ '1'
     C                     EXSR #SB510
     C                     WRITEAK#WP011
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
