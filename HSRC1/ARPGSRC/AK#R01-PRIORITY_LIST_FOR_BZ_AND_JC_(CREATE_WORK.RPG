     C           ##OUTS    BEGSR
      *
     C                     MOVEL'00000000'P@OTHZ
     C                     MOVEL'00000000'P@PNHZ
     C                     MOVEL'00000000'P@RCHZ
     C                     MOVEL'0000'    P@OMAI
     C                     CALL 'DFARS1'
     C                     PARM           CFCHYU  1
     C                     PARM CFZENO    CFZENO  4
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
