      *--------------------------------------------------*
      * FCEPL01                                          *
      *--------------------------------------------------*
     CSR         #SB390    BEGSR
      *
     C           K#L1EB    CHAINAGAPL311             49
     C           *IN49     IFEQ '0'
     C                     EXSR #SB400
     C                     MOVEL'0'       LIST    1
      *
      *  THEORETICAL STOCK  <  SHIPPING NEEDED BY NEXT WORKING DAY
      *  AND PRELOAD EXIST.
     C           MINASI    IFLT X2UNS
     C           PRE       ANDGT0
     C                     MOVEL'1'       LIST
     C                     ENDIF
      *
     C           LIST      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB390    ENDSR
      *--------------------------------------------------*
      * FCEPL01                                          *
      *--------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     Z-ADD0         X2UNS   61
      *
     C           K#L1EA    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     KFLD           K1YY    40
     C                     KFLD           K1MM    20
     C                     KFLD           K1DD    20
     C                     Z-ADDWWTOHZ    K1HZ
     C           K#L1EB    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
      * GET SHIPPING BOXES NEEDED BY NEXT WORKING DAY
      *
     C           K#L1EA    SETLLAB#PL1E
     C           K#L1EB    READEAB#PL1E                  98
     C           *IN98     DOWEQ'0'
     C           BASKJY    IFEQ 'D'
     C                     ELSE
     C           BANODT    IFGE WWTOHZ
     C           BANODT    ANDLEWWYOHZ
     C           BANONY    IFNE 0323
     C                     Z-ADD0         W@CONT
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    W@CONT  71H
     C                     ELSE
     C                     Z-ADD1         W@CONT
     C                     ENDIF
     C                     ADD  W@CONT    X2UNS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           K#L1EB    READEAB#PL1E                  98
     C                     ENDDO
      *
      * GET UNSCANNED BOXES
      *
     C           K#L1EA    SETLLAB#PL7D
     C           K#L1EB    READEAB#PL7D                  98
     C           *IN98     DOWEQ'0'
     C           EKSKJY    IFEQ 'D'
     C                     ELSE
     C           EKNODT    IFGE WWTOHZ
     C           EKNODT    ANDLEWWYOHZ
     C           EKDEYY    IFNE *ZERO
     C                     SUB  1         X2UNS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           K#L1EB    READEAB#PL7D                  98
     C                     ENDDO
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OKO
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPKOT      OKO
      *
     C                     Z-ADD0         MINO   110
     C                     Z-ADD0         MINASI 110
     C                     Z-ADD0         PRE    110
%01  C                     MOVEL*BLANK    W$PFL1  1
%01  C                     MOVEL*BLANK    W$PFL2  1
     C           KEYCF1    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     KFLD           WW10YY
     C                     KFLD           WW10MM
     C                     KFLD           WW10DD
     C           KEYCF2    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           KEYCF1    SETLLAH#TL191
     C           KEYCF2    READEAH#TL191                 21
     C           *IN21     DOWEQ'0'
     C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     ELSE
      * CHECK SCANNED RESULT
     C                     EXSR #SB410
      *
     C                     ENDIF
     C           KEYCF2    READEAH#TL191                 21
     C                     ENDDO
      *
      * CHECK SCANNED RESULT
%01  C                     MOVEL*BLANK    W$PFLG  1
%01  C           W$PFL1    IFEQ '*'
 |   C           W$PFL2    IFEQ '*'
 |   C                     MOVEL'#'       W$PFLG
 |   C                     ELSE
 |   C                     MOVEL'@'       W$PFLG
 |   C                     ENDIF
%01  C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *--------------------------------------------------*
      * ALDRS1                                           *
      *--------------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C                     MOVE CFCHYU    PHCHYU
     C                     MOVE CFZENO    PHZENO
     C                     MOVE CFTHNO    PHTHNO
     C                     MOVE CFHTHZ    PHHTHZ
     C                     MOVEL'0000'    PHMAIS
     C                     CALL 'DLDRS1'
     C                     PARM           PHCHYU  1
     C                     PARM           PHZENO  4
     C                     PARM           PHTHNO  3
     C                     PARM           PHHTHZ  8
     C                     PARM           PHMAIS  4
     C                     PARM           P#OPN   1
     C                     MOVE PHMAIS    @@MAIS  40
      *
      * CHECK LOAD,UNLOAD RESULT
     C           @@MAIS    IFLT CFMAIS
     C                     EXSR #SB411
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *--------------------------------------------------*
      * LOAD,UNLOAD                                      *
      *--------------------------------------------------*
     CSR         #SB411    BEGSR
      *
     C                     Z-ADD0         P@PKHZ
     C                     MOVEL*BLANK    W1PDAY  1
     C                     EXSR ##PIC
      *
      * LOADING TIME
     C                     Z-ADD0         P@WIHZ
     C                     MOVEL*BLANK    W1WDAY  1        投入日
     C                     EXSR ##WIN
     C           W1WDAY    IFEQ *BLANK
     C                     EXSR ##WIN2
     C                     ENDIF
     C                     SETOF                     79
     C           'SB '     LOKUPOKO                      79
     C           W1WDAY    IFEQ *BLANK
     C           *IN79     IFEQ '1'
     C                     EXSR ##WIN3
     C                     ENDIF
     C                     ENDIF
      * UNLOADING TIME
     C                     Z-ADD0         P@KEHZ
     C                     MOVEL*BLANK    W1KDAY  1        計量日
     C                     EXSR ##KEI
     C           W1KDAY    IFEQ *BLANK
     C                     EXSR ##KEI2
     C                     ENDIF
      * OUTSOURCING TIME
     C                     MOVEL*BLANK    P@OTHZ
     C                     MOVEL*BLANK    W1ODAY  1        計量日
     C                     EXSR ##OUTS
      *
     C                     SELEC
      * SHORTAGE
     C           W1WDAY    WHEQ *BLANK
     C           W1KDAY    ANDEQ*BLANK
     C           W1PDAY    ANDEQ*BLANK
     C           W1ODAY    ANDEQ*BLANK
     C           CFHT      IFLE WWCM
     C                     ADD  CFMAIS    MINO
     C                     ENDIF
      *
      * THEORETICAL STOK
     C           W1WDAY    WHEQ '1'
     C           W1KDAY    OREQ '1'
     C           W1PDAY    OREQ '1'
     C           W1ODAY    OREQ '1'
     C                     EXSR #SB420
     C                     EXSR #SB421
     C           CFMAIS    SUB  XFMAIS    WFMAIS
     C                     SUB  SAITE     WFMAIS
     C           W1WDAY    IFEQ '1'
     C           W1KDAY    OREQ '1'
     C           W1ODAY    OREQ '1'
     C                     ADD  WFMAIS    MINASI
     C                     ENDIF
      * PRELOAD
     C           W1WDAY    IFEQ *BLANK
     C           W1KDAY    ANDEQ*BLANK
     C           W1ODAY    ANDEQ*BLANK
     C           W1PDAY    ANDEQ'1'
%01  C                     EXSR ##CVFG
     C                     ADD  WFMAIS    PRE
     C                     ENDIF
     C                     ENDSL
      *
     CSR         ESB411    ENDSR
      *--------------------------------------------------*
      * MINASI                                           *
      *--------------------------------------------------*
     CSR         #SB420    BEGSR
      *
     C                     Z-ADD0         WFMAIS  30
     C                     Z-ADD0         XFMAIS  30
     C                     Z-ADD0         SAITE   30
     C           K#L30     KLIST
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C           K#L30     SETLLALDPL301
     C           K#L30     READEALDPL301                 16
     C           *IN16     DOWEQ'0'
     C           A3SYDT    IFGE CFHTHZ
     C                     Z-ADD*ZERO     I       30
      *
     C           WKCKSU    CHECKA3PAGE                   25
     C           *IN25     IFEQ '1'
     C                     MOVEL'01'      A3PAGE
     C                     ENDIF
      *
     C                     MOVE A3PAGE    I
     C           I         IFLE CFMAIS
     C                     ADD  1         XFMAIS
     C                     ENDIF
     C                     ENDIF
     C           K#L30     READEALDPL301                 16
     C                     ENDDO
      *
      *
     CSR         ESB420    ENDSR
      *--------------------------------------------------*
      * MINASI                                           *
      *--------------------------------------------------*
     CSR         #SB421    BEGSR
      *
     C           K#AD01    KLIST
     C                     KFLD           K@KSKB  1
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C                     MOVEL'A'       K@KSKB
     C           K#AD01    SETLLADAPL01
     C           K#AD01    READEADAPL01                  91
     C           *IN91     DOWEQ'0'
     C           ADDTKB    IFEQ 'S'
     C           NUM       CHECKADPGNO                   90
     C           *IN90     IFEQ '0'
     C                     MOVELADPGNO    W@A2@2  20
     C           W@A2@2    IFLE CFMAIS
     C           CFHTHZ    ANDLTADKODT
     C                     ADD  1         SAITE
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           K#AD01    READEADAPL01                  91
     C                     ENDDO
      *
     CSR         ESB421    ENDSR
      *===============================================================
      *         　　　・時刻
      *===============================================================
     CSR         ##PIC     BEGSR
      *
     C                     Z-ADD0         P@PKHZ
     C                     Z-ADD0         P@PKTM
     C                     CALL 'DLCRS1'
     C                     PARM           CFCHYU  1
     C                     PARM CFZENO    CFZENO  4
     C                     PARM CFTHNO    CFTHNO  3
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@PKHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@PKTM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@PKHZ    IFNE 0
     C                     MOVEL'1'       W1PDAY
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *   CONVEYED BY CONVEYANCE
      *===============================================================
     CSR         ##CVFG    BEGSR
      *
     C                     MOVEL*BLANK    P@FLG
     C                     CALL 'DLCRS2'
     C                     PARM           CFCHYU  1
     C                     PARM CFZENO    CFZENO  4
     C                     PARM CFTHNO    CFTHNO  3
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@FLG   1
     C                     PARM           P#OPN   1
      *
     C           P@FLG     IFEQ '*'
     C                     MOVEL'*'       W$PFL1
     C                     ELSE
     C                     MOVEL'*'       W$PFL2
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻
      *===============================================================
     CSR         ##WIN     BEGSR
     C                     Z-ADD0         P@WIHZ
     C                     Z-ADD0         P@WITM
