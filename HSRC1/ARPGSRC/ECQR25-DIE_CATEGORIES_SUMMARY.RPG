     H            Y.
     F** ECQR25 **********************************
     F* DIE CATEGORIES SUMMARY
     F*    JAN/24/03   TCH
     F*                                          *
     F*                                          *
     F*
     F********************************** ECQR25 **
     FECQPW25 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FECSPL05 IF  E           K        DISK
     FECSPL10 IF  E           K        DISK
     FFCQPL31 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGDIPL27 IF  E           K        DISK
     FECQPP01 IF  E           K        DISK
     FGCQPL12 IF  E           K        DISK
     F**GKGDDM  IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *-----------------------------------------------------------
     E                    YM          6  6 0
      *-----------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   60D@YYMM
     I                                        1   40D@YY
     I                                        5   60D@MM
     I            DS
     I                                        1   60W@YYMM
     I                                        1   40W@YY
     I                                        5   60W@MM
     I            DS
     I                                        1   60F8YYMM
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I            DS
     I                                        1   80WTO3
     I                                        1   40GKEDYY
     I                                        5   60GKEDMM
     I                                        7   80GKEDDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
      *
     C           K#KEY     KLIST
     C                     KFLD           Q4KAT1
     C                     KFLD           Q4KAT2
     C           K#KEYX    KLIST
     C                     KFLD           Q4KAT1
     C                     KFLD           Q4KAT2
     C                     KFLD           K@KAT3  1
     C                     KFLD           W@YY
     C                     KFLD           W@MM
      *
     C           K#AGD     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
      *
     C                     MOVE '01'      W@ID    2
     C                     TIME           @@TIM   60
     C                     MOVE *ALL'-'   @@LIN  70
     C                     Z-ADD*ZERO     D@YYMM
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKJ     WHEQ *ON
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
     C                     CALL 'ECQR35'
     C                     MOVE *OFF      *IN10
     C                     OTHER
     C                     EXSR #CHK1
     C           *INKE     IFEQ *ON
     C           *IN99     ANDEQ*OFF
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
      *
     C                     EXSR #YM
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     SETOF                     6199
     C           D@YYMM    IFEQ *ZERO
     C                     SETON                     6199
     C                     ELSE
     C                     Z-ADDD@YYMM    W@YYMM
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #YM       BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     YM
     C                     Z-ADDD@YYMM    W@YYMM
     C                     SUB  5         W@MM
     C           W@MM      IFLE *ZERO
     C                     ADD  12        W@MM
     C                     SUB  1         W@YY
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     X       30
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         X
     C                     Z-ADDF8YYMM    YM,X
     C           X         IFEQ 6
     C                     LEAVE
     C                     ENDIF
     C                     Z-ADDF8YYMM    W@YYMM
     C           K#AGD     SETGTAGDPL12
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------------
     C                     MOVE *OFF      *IN98
     C           *LOVAL    SETLLFCQPL31
      *
     C                     MOVE *BLANK    @KAT1   2
     C                     Z-ADD*ZERO     @@CNT   50
     C                     Z-ADD*ZERO     @@QTY   70
     C                     Z-ADD*ZERO     @@CST  130
     C                     Z-ADD*ZERO     @@USE   50
     C                     Z-ADD*ZERO     T@CNT   70
     C                     Z-ADD*ZERO     T@QTY   70
     C                     Z-ADD*ZERO     T@CST  130
     C                     Z-ADD*ZERO     T@USE   90
     C           *IN80     DOWEQ*OFF
     C                     READ FCQPL31                  80
     C           *IN80     IFEQ *OFF
     C           Q4SKJY    ANDEQ*BLANK
      *
     C           K#KEY     SETLLGCQPL12
     C           *IN91     DOUEQ*ON
     C           K#KEY     READEGCQPL12                  91
     C           *IN91     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN91     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C           @KAT1     IFNE *BLANK
     C           Q4KAT1    ANDNE@KAT1
     C                     EXSR #PRT
     C                     Z-ADD*ZERO     @@CNT
     C                     Z-ADD*ZERO     @@QTY   70
     C                     Z-ADD*ZERO     @@CST  130
     C                     Z-ADD*ZERO     @@USE   50
     C                     ENDIF
      * INVENTORY
     C                     ADD  1         @@CNT
     C                     Z-ADD*ZERO     @INQY   70
     C           K#KEY     SETLLECSPL10
     C           *IN81     DOUEQ*ON
     C           K#KEY     READEECSPL10                  81
     C           *IN81     IFEQ *OFF
     C           E1SKJY    ANDEQ*BLANK
     C                     ADD  E1SQTY    @INQY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  @INQY     @@QTY
      *
     C                     MOVE Q4KAT1    @KAT1
     C                     EXSR #PRC
     C           @INQY     MULT W@UPRC    W@CST  110
     C                     ADD  W@CST     @@CST
      *
     C                     EXSR #USG
     C                     ADD  W@USE     @@USE
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@CNT     IFNE *ZERO
     C                     EXSR #PRT
     C                     ENDIF
      *
     C           T@USE     DIV  6         T@AVR   61
     C                     EXCPT@TOT
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #USG      BEGSR
      *-----------------------------------------------------
      * SETTING USAGE
      *  6 MONTHS AVERAGE
     C                     Z-ADD*ZERO     W@USE   50
     C           1         DO   6         X
     C                     Z-ADDYM,X      W@YYMM
     C           K#KEYX    SETLLECSPL05
     C           *IN20     DOUEQ*ON
     C           K#KEYX    READEECSPL05                  20
     C           *IN20     IFEQ *OFF
     C           EQSKJY    ANDEQ*BLANK
     C           EQBMON    ANDEQ0111
      *
     C                     ADD  EQKOSU    W@USE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #PRC      BEGSR
      *-----------------------------------------------------
      * UNIT PRICE
      *
     C                     Z-ADD*ZERO     W@UPRC  90
      *
     C*          K#KEY     SETGTGKGDDM
     C*          *IN20     DOUEQ*ON
     C*          K#KEY     REDPEGKGDDM                   20
     C*          *IN20     IFEQ *OFF
     C*          GKSKJY    ANDEQ*BLANK
     C*          WTO3      ANDGE*DATE
     C*                    Z-ADDGKNHTN    W@UPRC
     C*                    LEAVE
     C*                    ENDIF
     C*                    ENDDO
      *
     C*          *IN20     IFEQ *ON
     C           K#KEY     SETGTECQPP01
     C           *IN20     DOUEQ*ON
     C           K#KEY     REDPEECQPP01                  20
     C           *IN20     IFEQ *OFF
     C           ECVALD    ANDLE*DATE
     C                     Z-ADDECUPRC    W@UPRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C****                 ENDIF
      *
     C           *IN20     IFEQ *ON
     C           K#KEY     SETGTGDIPL27
     C           *IN20     DOUEQ*ON
     C           K#KEY     REDPEGDIPL27                  20
     C           *IN20     IFEQ *OFF
     C           IKSKJY    ANDEQ*BLANK
     C           IKTANK    ANDNE*ZERO
      *
     C**********           Z-ADDIKTANK    W@UPRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #PRT      BEGSR
      *-----------------------------------------------------
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C           @@USE     DIV  6         @@AVR   51H
     C                     EXCPT@DTL
      *
     C                     ADD  @@CNT     T@CNT
     C                     ADD  @@QTY     T@QTY
     C                     ADD  @@CST     T@CST
     C                     ADD  @@USE     T@USE
      *
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                                  110 'P.'
     O                         PAGE  Z  114
     O                         UDATE Y  123
     O                         @@TIM    132 '  :  :  '
     O        E   02           @HED
     O                                   50 'TOOL CATEGORIES SUMMARY'
     O        E   03           @HED
     O                                   64 '6 MONTHS'
     O        E   04           @HED
     O                                   13 'TOOL CATEGORY'
     O                                   25 '# OF TOOLS'
     O                                   36 'TOTAL QTY'
     O                                   52 'INV. VALUE'
     O                                   67 'AVERAGE USAGE'
     O        E   05           @HED
     O                         @@LIN     70
     O        E 1              @DTL
     O                         @KAT1     08
     O                         @@CNT 1   22
     O                         @@QTY 1   35
     O                         @@CST 1   52
     O                         @@AVR 1   65
     O        E 1              @TOT
     O                         @@LIN     70
     O        E 1              @TOT
     O                                   10 'TOTAL'
     O                         T@CNT 1   22
     O                         T@QTY 1   35
     O                         T@CST 1   52
     O                         T@AVR 1   65
