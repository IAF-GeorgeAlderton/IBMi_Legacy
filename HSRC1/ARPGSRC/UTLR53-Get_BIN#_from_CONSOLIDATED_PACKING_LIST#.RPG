     H            Y.
     F** UTLR53 ****************************************************
     F*  UTILITY - RETRIEVE BIN# FROM CONSOLIDATED PACKING LIST#   *
     F*  WRITTEN: JW (SRA)                                         *
     F*           04/03/2017                                       *
     F*------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR53'
     F*                    PARM           $BAR    9
     F*                    PARM           $BIN    2 0
     F*                    PARM           $RTN    1
     F*   IN  $BAR    9   PACKING LIST#
     F*   OUT $BIN    2,0 BIN#
     F*       $RTN    1   RETURN
     F******************************************************
     FAC#PL10 IF  E           K        DISK
     FAB#PL2A IF  E           K        DISK
      *--------------------------------------------------------
     E                    DAT        10  1
      *--------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INZ
     C                     Z-ADD0         K@BIN   20
      * CHAIN AC#PP10
     C           $BAR      CHAINAC#PL10              98
     C           *IN98     IFEQ *OFF
      * READ  AB#PP2A
     C           K#PP2A    SETLLAB#PL2A
     C           *IN96     DOWEQ*OFF
     C           K#PP2A    READEAB#PL2A                  96
     C           *IN96     IFEQ *OFF
     C           ACODRN    ANDEQBCODRN
     C           ACMHIN    ANDEQBCMHIN
     C           ACBIN     ANDNE01
     C                     Z-ADDACBIN     K@BIN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           K@BIN     IFNE 0
     C                     Z-ADDK@BIN     $BIN
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C           #INZ      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $BAR    9
     C                     PARM           $BIN    20
     C                     PARM           $RTN    1
      *
     C           K#PP2A    KLIST
     C                     KFLD           BCTOKU
     C                     KFLD           BCNONY
     C                     KFLD           BCNKOJ
     C                     KFLD           BCNUKE
     C                     KFLD           BCMHN1
     C                     KFLD           BCMHN2
     C                     KFLD           BCMHN3
     C                     KFLD           BCMHN4
     C                     KFLD           BCNODT
      *
     C                     Z-ADD99        $BIN
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
