     I                                       71  770F4TS11
     I                                       78  840F4TS12
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1 600 PRT
     I                                        1  12 $FPR01
     I                                       13  24 $FPR02
     I                                       25  36 $FPR03
     I                                       37  48 $FPR04
     I                                       49  60 $FPR05
