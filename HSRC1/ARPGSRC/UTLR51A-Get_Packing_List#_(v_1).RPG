     H            Y.
     F** UTLR51 *************************************************************
     F*  UTILITY - UTILITY - RETRIEVE PACKING LIST#                         *
     F*  WRITTEN: JW (SRA)   2023.10.13                                     *
     F*---------------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR51A'
     F*                    PARM           $NOHZ   8
     F*                    PARM           $CUST   4
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $BINN   2
     F*                    PARM           $RLHZ   8
     F*                    PARM           $ODRN  10
     F*                    PARM           $PICK#  9
     F*                    PARM           $RTN    1
     F*   IN  $NOHZ   8  SHIP DATE
     F*       $CUST   4  CUSTOMER
     F*       $NONY   4  DELIVERY
     F*       $NKOJ   1  FACTORY
     F*       $NUKE   4  DOCK
     F*       $BINN   2  BIN
     F*       $RLHZ   8  RELEASE DATE
     F*       $ODRN  10  ORDER#
     F*   OUT $PICK#  9  PICK SLIP#
     F*       $RTN    1A RETURN FLAG (BLANK=OK, 1=ERROR)
     F******************************************************
     FAB#PL75 IF  E           K        DISK
      *--------------------------------------------------------
     E                    DAT        10  1
      *--------------------------------------------------------
     I            DS
     I                                        1   80WNOHZ
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80WRLHZ
     I                                        1   40WRLYY
     I                                        5   60WRLMM
     I                                        7   80WRLDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INZ
      *
     C           KEY1      SETLLAB#PL75
      *
     C                     DO   *HIVAL
     C           KEY1      READEAB#PL75                  91
     C   91                LEAVE
      *
     C           PUSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C**         $ODRN     IFNE *BLANK
     C**         $ODRN     ANDNEPUODRN
     C**                   ITER
     C**                   ENDIF
      *
     C           PUSERL    IFGT $PICK#
     C                     MOVELPUSERL    $PICK#
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           $PICK#    IFEQ *BLANK
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C           #INZ      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
      *
     C           KEY1      KLIST
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           K@CUST
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@BINN
     C                     KFLD           K@RLYY
     C                     KFLD           K@RLMM
     C                     KFLD           K@RLDD
     C                     KFLD           K@ODRN
      *
     C           *LIKE     DEFN PUNOYY    K@NOYY
     C           *LIKE     DEFN PUNOMM    K@NOMM
     C           *LIKE     DEFN PUNODD    K@NODD
     C           *LIKE     DEFN PUCUST    K@CUST
     C           *LIKE     DEFN PUNONY    K@NONY
     C           *LIKE     DEFN PUNKOJ    K@NKOJ
     C           *LIKE     DEFN PUNUKE    K@NUKE
     C           *LIKE     DEFN PUBINN    K@BINN
     C           *LIKE     DEFN PURLYY    K@RLYY
     C           *LIKE     DEFN PURLMM    K@RLMM
     C           *LIKE     DEFN PURLDD    K@RLDD
     C           *LIKE     DEFN PUODRN    K@ODRN
      *
     C                     MOVEL$NOHZ     WNOHZ
     C                     MOVEL$RLHZ     WRLHZ
     C                     MOVEL$BINN     @BINN   20
     C                     MOVEL$CUST     @CUST   40
     C                     MOVEL$NONY     @NONY   40
     C                     MOVE *BLANK    $PICK#
     C                     MOVE *BLANK    $RTN
      *
     C                     Z-ADDWNOYY     K@NOYY
     C                     Z-ADDWNOMM     K@NOMM
     C                     Z-ADDWNODD     K@NODD
     C                     Z-ADD@CUST     K@CUST
     C                     Z-ADD@NONY     K@NONY
     C                     MOVEL$NKOJ     K@NKOJ
     C                     MOVEL$NUKE     K@NUKE
     C                     Z-ADD@BINN     K@BINN
     C                     Z-ADDWRLYY     K@RLYY
     C                     Z-ADDWRLMM     K@RLMM
     C                     Z-ADDWRLDD     K@RLDD
     C                     MOVEL$ODRN     K@ODRN
      *
     C                     ENDSR
