     H            Y.
     F***CHKR38E ***************************************************************
     F*  PROGRAM    : CHECK DIFFERENT ORDER QTY                                *
     F*  WRITTEN    : 2021.08.13                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2P IF  E           K        DISK
     FAB#PL10AIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    ERR     1   5 25
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  20 SVMHIN
     I                                        1   5 SVMHN1
     I                                        6  10 SVMHN2
     I                                       11  15 SVMHN3
     I                                       16  20 SVMHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           TODAY     SETLLAB#PL2P
     C                     DO   *HIVAL
     C                     READ AB#PL2P                  98
     C   98                LEAVE
      *
     C           ACEDID    IFNE '850'
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDACPLSH    SVPLSH  80
     C                     Z-ADDACNONY    SVNONY  40
     C                     MOVE ACNKOJ    SVNKOJ  1
     C                     MOVE ACNUKE    SVNUKE  4
     C                     Z-ADDACBIN     SVBIN   20
     C                     MOVE ACODRN    SVODRN 20
     C                     MOVE ACMHN1    SVMHN1  5
     C                     MOVE ACMHN2    SVMHN2  5
     C                     MOVE ACMHN3    SVMHN3  5
     C                     MOVE ACMHN4    SVMHN4  5
     C                     ENDIF
      *
     C           ACPLSH    IFNE SVPLSH
     C           ACNONY    ORNE SVNONY
     C           ACNKOJ    ORNE SVNKOJ
     C           ACNUKE    ORNE SVNUKE
     C           ACBIN     ORNE SVBIN
     C           ACODRN    ORNE SVODRN
     C           ACMHN1    ORNE SVMHN1
     C           ACMHN2    ORNE SVMHN2
     C           ACMHN3    ORNE SVMHN3
     C           ACMHN4    ORNE SVMHN4
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C           RCVD1     IFEQ 0
     C                     Z-ADDACCRDT    RCVD1
     C                     Z-ADDACQNTY    QTY1
     C                     ENDIF
     C           RCVD2     IFEQ 0
     C                     Z-ADDACCRDT    RCVD2
     C                     Z-ADDACQNTY    QTY2
     C                     ENDIF
     C           RCVD1     IFGT ACCRDT
     C                     Z-ADDACCRDT    RCVD1
     C                     Z-ADDACQNTY    QTY1
     C                     ENDIF
     C           RCVD2     IFLT ACCRDT
     C                     Z-ADDACCRDT    RCVD2
     C                     Z-ADDACQNTY    QTY2
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C           QTY1      IFNE QTY2
     C                     EXSR #PP10
     C           OFLG      IFEQ 'Y'
     C           BASRYO    ANDNEQTY2
     C                     Z-ADDBASRYO    QTY1
     C           QTY2      SUB  QTY1      @@BAL   70
     C                     MOVELERR,1     MSG1
     C           SVMHN3    COMP *BLANK                   20
     C           SVMHN4    COMP *BLANK                   21
     C                     EXSR #PRINT
     C                     ENDIF
     C                     ENDIF
      * RESET
     C                     Z-ADDACPLSH    SVPLSH  80
     C                     Z-ADDACNONY    SVNONY  40
     C                     MOVE ACNKOJ    SVNKOJ  1
     C                     MOVE ACNUKE    SVNUKE  4
     C                     Z-ADDACBIN     SVBIN   20
     C                     MOVE ACODRN    SVODRN 20
     C                     MOVE ACMHN1    SVMHN1  5
     C                     MOVE ACMHN2    SVMHN2  5
     C                     MOVE ACMHN3    SVMHN3  5
     C                     MOVE ACMHN4    SVMHN4  5
     C                     Z-ADD0         RCVD1
     C                     Z-ADD0         RCVD2
     C                     Z-ADD0         QTY1
     C                     Z-ADD0         QTY2
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK PP10                                        *
      *----------------------------------------------------*
     C           #PP10     BEGSR
      *
     C                     MOVE 'N'       OFLG    1
     C                     MOVELSVODRN    K#ODRN
     C                     MOVELSVMHIN    K#MHIN
     C                     Z-ADDSVNONY    K#NONY
     C           K#PL10    SETLLAB#PL10A
     C                     DO   *HIVAL
     C           K#PL10    READEAB#PL10A                 96
     C   96                LEAVE
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'Y'       OFLG
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * GET NAME
     C                     MOVELSVNONY    PMNONY
     C                     MOVEL'D'       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           PMRTN   1
     C                     MOVELPMNAME    XNAM7  12
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#PL10    KLIST
     C                     KFLD           K#ODRN 10
     C                     KFLD           K#MHIN 20
     C                     KFLD           K#NONY  40
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    MSG1   25
      *
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SVPLSH  80
     C                     Z-ADD0         SVNONY  40
     C                     MOVE *BLANK    SVNKOJ  1
     C                     MOVE *BLANK    SVNUKE  4
     C                     Z-ADD0         SVBIN   20
     C                     MOVE *BLANK    SVODRN 20
     C                     MOVE *BLANK    SVMHN1  5
     C                     MOVE *BLANK    SVMHN2  5
     C                     MOVE *BLANK    SVMHN3  5
     C                     MOVE *BLANK    SVMHN4  5
     C                     Z-ADD0         RCVD1   80
     C                     Z-ADD0         RCVD2   80
     C                     Z-ADD0         QTY1    80
     C                     Z-ADD0         QTY2    80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** HONDA ORDER QTY/S'
     O                                   60 'HIP DATE CHANGE CHEC'
     O                                   80 'K LIST **           '
     O                         TODAY    109 '    .  .  '
     O                         NOW      119 '  :  :  '
     O                                  123 'P.'
     O                         PAGE  Z  126
     O        E   04           @HDR
     O                                   10 'SHIP DATE'
     O                                   15 'BN'
     O                                   20 'DELV'
     O                                   25 'NAME'
     O                                   47 'USER PART#  '
     O                                   61 'CURRENT QTY'
     O                                   74 'NEW QTY'
     O                                   85 'DIFF.'
     O                                   93 'ORDER#'
     O                                  108 'ERROR MSG'
     O        E 1              @DTL
     O                         SVPLSH    11 '    .  .  '
     O                         SVBIN     15
     O                         SVNONY    20
     O                         XNAM7     33
     O                         SVMHN1    40
     O                                   41 '-'
     O                         SVMHN2    46
     O                N20                47 '-'
     O                         SVMHN3    52
     O**              N21                53 '-'
     O**                       SVMHN4    58
     O                         QTY1  1   61
     O                         QTY2  1   74
     O                                   65 '-->'
     O                         @@BAL J   85
     O                         SVODRN   107
     O                         MSG1     124
** ERR (25A) ......2....>
QTY SHOULD BE CHANGED !                      01
                                             02
                                             03
                                             04
                                             05
