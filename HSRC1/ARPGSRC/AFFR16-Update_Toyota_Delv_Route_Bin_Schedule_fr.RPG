     H            Y.
      ****************************************************************
      *  PROGRAM    : AFFR16                                         *
      *  WRITTEN    : 02/06/2023                                     *
      *  WRITTEN BY : LEC                                            *
      *  FUNCTION   : UPDATE TOYOTA DELV ROUTE/BIN SCHEDULE          *
      *               FROM UPLOAD                                    *
      ****************************************************************
     FAFFWP16 IF  E           K        DISK
     FAB#PP82 O   E           K        DISK
     FAL#PPC1 O   E           K        DISK
      *
     E                    RTE        30 10
     E                    STT        30  4 0
     E                    EDT        30  4 0
      *-----------------------------------------------------------------
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80AFSHDT
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80YYMMDD
     I                                        1   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
      *
     I            DS
     I                                        1   40HHMM
     I                                        1   2 HH
     I                                        3   4 MN
      *
     IA8RT        DS                            300
     I                                        1  10 A8RT01
     I                                       11  20 A8RT02
     I                                       21  30 A8RT03
     I                                       31  40 A8RT04
     I                                       41  50 A8RT05
     I                                       51  60 A8RT06
     I                                       61  70 A8RT07
     I                                       71  80 A8RT08
     I                                       81  90 A8RT09
     I                                       91 100 A8RT10
     I                                      101 110 A8RT11
     I                                      111 120 A8RT12
     I                                      121 130 A8RT13
     I                                      131 140 A8RT14
     I                                      141 150 A8RT15
     I                                      151 160 A8RT16
     I                                      161 170 A8RT17
     I                                      171 180 A8RT18
     I                                      181 190 A8RT19
     I                                      191 200 A8RT20
     I                                      201 210 A8RT21
     I                                      211 220 A8RT22
     I                                      221 230 A8RT23
     I                                      231 240 A8RT24
     I                                      241 250 A8RT25
     I                                      251 260 A8RT26
     I                                      261 270 A8RT27
     I                                      271 280 A8RT28
     I                                      281 290 A8RT29
     I                                      291 300 A8RT30
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C           *ENTRY    PLIST
     C                     PARM           EFFDAT  80
      *
      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
      *
     C                     TIME           WSDT
      *
      *
     C           *IN50     DOWEQ*OFF
     C                     READ AFFWP16                  50
     C   50                LEAVE
      *
     C           SHID      IFEQ *ZERO
     C                     Z-ADDAFSHID    SHID    80
     C                     ENDIF
      *
     C           AFSURT    LOKUPRTE                      51
     C           *IN51     IFEQ *ON
     C           AFSTIM    ANDNESTT,X
     C           AFETIM    ANDNEEDT,X
     C           X         IFLT 30
     C                     ADD  1         X       20
     C                     MOVELAFSURT    RTE,X
     C                     Z-ADDAFSTIM    STT,X
     C                     Z-ADDAFETIM    EDT,X
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN51     IFEQ *OFF
     C           X         IFLT 30
     C                     ADD  1         X       20
     C                     MOVELAFSURT    RTE,X
     C                     Z-ADDAFSTIM    STT,X
     C                     Z-ADDAFETIM    EDT,X
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           X         IFGT *ZERO
     C                     CLEARAB#PP821
     C                     Z-ADDTODAY     A8KODT
     C                     Z-ADDNOW       A8KOTM
     C                     MOVEL#USER     A8KOME
     C                     MOVEL#PGM      A8UPGM
     C                     MOVEL#WSID     A8UPWS
     C                     Z-ADDEFFDAT    A8FRDT
     C                     MOVEARTE       A8RT
     C                     WRITEAB#PP821
      *
     C                     Z-ADDX         TIMES   20
     C                     DO   TIMES     X
     C                     CLEARAL#PPC11
     C                     Z-ADDTODAY     C5KOHZ
     C                     Z-ADDNOW       C5KOTI
     C                     MOVEL#USER     C5KOME
     C                     MOVELX         C5TRKB
     C                     MOVELRTE,X     C5SURT
     C                     Z-ADDSTT,X     C5STTN
     C                     Z-ADDEDT,X     C5EDTN
     C                     Z-ADDEFFDAT    C5KIHZ
     C                     WRITEAL#PPC11
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
