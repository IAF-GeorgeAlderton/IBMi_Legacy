      *** GDKR04 *************************************
      *        MONTHLY AGGREGATION TREATMENT         *
      *  G.B.C                         97/07/25      *
      ************************************************
     H            Y/                                    1
     FGDKPW04 CF  E                    WORKSTN
     FGDKPL06 UF  E           K        DISK
     FGDKPL10 UF  E           K        DISK                      A
     E                    MSG     1   2 60
     E                    AM         12 11 0
     I            DS
     I                                        1   60D1MMYY
     I                                        1   20D1MM
     I                                        3   60D1YY
     I            DS
     I                                        1   5 ITKEY
     I                                        1   4 ITVEND
     I                                        5   5 ITTYPE
     I            DS
     I                                        1   5 XXKEY
     I                                        1   4 XXVEND
     I                                        5   5 XXTYPE
     I            DS
     I                                        1   60TIMEX
     I                                        1   20TIMEHH
     I                                        3   40TIMEMM
     I            DS
     I                                        1 132 AM
     I                                        1  110IUAM01
     I                                       12  220IUAM02
     I                                       23  330IUAM03
     I                                       34  440IUAM04
     I                                       45  550IUAM05
     I                                       56  660IUAM06
     I                                       67  770IUAM07
     I                                       78  880IUAM08
     I                                       89  990IUAM09
     I                                      100 1100IUAM10
     I                                      111 1210IUAM11
     I                                      122 1320IUAM12
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C****************************************************************
     C*           KEY LIST                                           *
     C****************************************************************
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C           @START    TAG
     C                     CLEARDSP01
     C                     MOVE *ON       *IN40            FIRST
     C*** DSP01 ***
     C           @DSP01    TAG
     C                     WRITEDSP02
     C                     EXFMTDSP01
     C*
     C                     MOVEA'00'      *IN,11
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #D1CHK
     C           *IN99     CABEQ'1'       @DSP01
     C*
     C           *INKE     CABEQ'0'       @DSP01
     C**
     C                     EXSR #UPD
     C**
     C           *IN40     IFEQ *ON
     C  N99                MOVELMSG,2     D#MSG
     C                     SETON                     991112
     C                     GOTO @DSP01
     C                     ENDIF
     C***
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*          #D1CHK    DSP01 CHECK                               *
     C****************************************************************
     C           #D1CHK    BEGSR                                     *
     C           D1MM      IFGE 01
     C           D1MM      ANDLE12
     C                     ELSE
     C                     MOVEA'1'       *IN,11
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     D#MSG
     C                     END
     C           D1YY      IFEQ 0
     C                     MOVEA'1'       *IN,11
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     D#MSG
     C                     END
     C                     ENDSR
     C****************************************************************
     C*          #UPD                                                *
     C****************************************************************
     C           #UPD      BEGSR
     C           UPDKEY    KLIST
     C                     KFLD           D1YY
     C                     KFLD           D1MM
     C                     Z-ADDD1MM      X       20
     C                     TIME           TIMEX
     C*
     C           D1RUN     IFEQ 'Y'
     C* GDKPL06 CLR
     C           UPDKEY    SETLLGDKPL061
     C                     DO   *HIVAL
     C           UPDKEY    READEGDKPL061                 90
     C           *IN90     IFEQ '0'
     C                     Z-ADD0         ITMMYY
     C                     Z-ADD0         ITMMMM
     C                     Z-ADD0         ITMMDD
     C                     UPDATGDKPL061
     C                     END
     C  N90                END
     C* GDKPL10 CLR
     C           D1YY      SETLLGDKPL101
     C                     DO   *HIVAL
     C           D1YY      READEGDKPL101                 90
     C           *IN90     IFEQ '0'
     C                     Z-ADD0         AM,X
     C                     UPDATGDKPL101
     C                     END
     C  N90                END
     C*
     C                     END
     C*
     C*
     C                     Z-ADD0         XXYY    40
     C                     Z-ADD0         XXMM    20
     C           INKEY     KLIST
     C                     KFLD           XXYY
     C                     KFLD           XXMM
     C           INKEY     SETLLGDKPL061
     C           INKEY     READEGDKPL061                 90
     C   90                GOTO UPDEND
     C                     SETOF                     40
     C**
     C           UPD1      TAG
     C                     MOVE ITKEY     XXKEY
     C                     Z-ADD0         XXKIN  110
     C           ITKEY     DOWEQXXKEY
     C                     ADD  ITKIN     XXKIN
     C                     Z-ADD*YEAR     ITMMYY
     C                     Z-ADDUMONTH    ITMMMM
     C                     Z-ADDUDAY      ITMMDD
     C                     UPDATGDKPL061
     C           INKEY     READEGDKPL061                 90
     C   90                MOVE *ALL'_'   ITKEY
     C                     END
     C*
     C           GDK10K    KLIST
     C                     KFLD           D1YY
     C                     KFLD           XXVEND
     C                     KFLD           XXTYPE
     C           GDK10K    CHAINGDKPL101             91
     C           *IN91     IFEQ '1'
     C                     MOVE *BLANK    IUSKJY
     C                     Z-ADD0         IUSKYY
     C                     Z-ADD0         IUSKMM
     C                     Z-ADD0         IUSKDD
     C                     Z-ADD*YEAR     IUKOYY
     C                     Z-ADDUMONTH    IUKOMM
     C                     Z-ADDUDAY      IUKODD
     C                     Z-ADDTIMEHH    IUKOHH
     C                     Z-ADDTIMEMM    IUKOSS
     C                     MOVELPPUSER    IUKOME
     C                     MOVE XXVEND    IUVEND
     C                     MOVE XXTYPE    IUTYPE
     C                     Z-ADDD1YY      IUYY
     C                     Z-ADD0         AM
     C                     END
     C                     Z-ADDXXKIN     AM,X
     C                     Z-ADD*YEAR     IUKOYY
     C                     Z-ADDUMONTH    IUKOMM
     C                     Z-ADDUDAY      IUKODD
     C                     Z-ADDTIMEHH    IUKOHH
     C                     Z-ADDTIMEMM    IUKOSS
     C                     MOVELPPUSER    IUKOME
     C   91                WRITEGDKPL101
     C  N91                UPDATGDKPL101
     C*
     C  N90                GOTO UPD1
     C*
     C           UPDEND    ENDSR
**
INCORRECT MONTH.
NO DATA.
