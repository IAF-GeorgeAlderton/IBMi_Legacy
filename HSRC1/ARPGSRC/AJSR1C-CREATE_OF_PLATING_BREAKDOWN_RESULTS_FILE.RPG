     C***                  END
     C*
     C*******>>  *INOD     IFEQ '1'
     C*******>>            SETOF                     OD
     C*******>>            EXCPTHD3
     C*******>>            END
     C**** NOT OMITTO **** GOTO END
     C*******>>            END
     C*******>>            END
