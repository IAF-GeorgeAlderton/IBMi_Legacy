     F********************************** MFBR41 **
     FMFBPW41 CF  E                    WORKSTN
     FMFAPL22 IF  E           K        DISK
     FMFAPL26 IF  E           K        DISK
     FMFEPL40 IF  E           K        DISK
     FMFBPL01 UF  E           K        DISK
     E                    MSG     1  14 60               d[ｰxｮﾈｰﾆﾞ
     E                    TAB3    1   2  1   TAB4    6   ﾃcﾆ]
     I            DS
     I                                        1   60WTIME
     I                                        1   20M1KOHH
     I                                        3   40M1KOSS
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
     I            DS
     I                                        1   80M1KOHZ
     I                                        1   40M1KOYY
     I                                        5   60M1KOMM
     I                                        7   80M1KODD
     I            DS
     I                                        1   80YMD
     I                                        1   40YY
     I                                        5   60MM
     I                                        7   80DD
     I            DS
     I                                        1   80MHSKHZ
     I                                        1   40MHSKYY
     I                                        5   60MHSKMM
     I                                        7   80MHSKDD
     C******************************************************
     C*  START  PROGRAM <MFBR02>                           *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           US     10        ﾏｰﾅﾞｰ xb
     C                     Z-ADD0         M1SKHZ
     C*
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    KOJO
     C                     Z-ADD0         YMD
     C                     MOVE *BLANK    CHUYA
     C                     MOVE *BLANK    KIB1
     C                     MOVE *BLANK    KIB2
     C******************************************************
     C*  EXFMT  <fﾞx] 1>                                   *
     C******************************************************
     C           STP1      TAG
     C                     EXFMTMFBPW411
     C                     MOVEA'000000'  *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
     C*  CMD-1
B001 C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
E001 C                     END
     C*  CMD-12
B001 C           *INKL     IFEQ '1'
     C                     CALL 'MFEC20'
     C                     GOTO STP1
E001 C                     END
     C******************************************************
     C*  <fﾞx] 1 ﾉ kｩｮh>                                   *
     C******************************************************
     C                     MOVE *BLANK    KNAM
     C           KTYPE     LOKUPTAB3      TAB4           22
     C   22                MOVELTAB4      KNAM
     C           *IN,22    IFEQ '0'
     C                     MOVEA'1'       *IN,06
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,13    ERR
     C                     GOTO STP1
E001 C                     END
     C*
     C           KTYPE     COMP '0'                      33
     C*
     C*  ﾃcﾆﾞｭc kｩｮh
     C*
     C                     MOVE *BLANK    KJNM
     C                     MOVELKOJO      #KOJO   40
     C           #KOJO     CHAINMFEPL401             01
B001 C           *IN,01    IFEQ '0'
     C           MHSKJY    ANDEQ'D'
     C           MHSKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,01
     C                     END
     C*
     C           *IN,01    IFEQ '1'
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
E001 C                     END
     C*
     C                     MOVELMHKJNM    KJNM
     C*
     C*  ﾍlﾞi kｩｮh
     C*
B001 C           YMD       IFGT *DATE
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     GOTO STP1
E001 C                     END
     C*
B001 C           YY        IFLT 1987
     C           MM        ORGT 12
     C           MM        ORLT 01
     C           DD        ORGT 31
     C           DD        ORLT 01
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERR
     C                     GOTO STP1
E001 C                     END
     C*
B001 C           CHUYA     IFNE 'Y'
     C           CHUYA     ANDNE'H'
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP1
E001 C                     END
     C*
     C                     MOVE *BLANK    CHUNM
B001 C           CHUYA     IFEQ 'Y'
     C                     MOVEL'DAY '    CHUNM
X001 C                     ELSE
B002 C           CHUYA     IFEQ 'H'
     C                     MOVEL'NGHT'    CHUNM
E002 C                     END
E001 C                     END
     C*
B001 C           KIB1      IFEQ *BLANK
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
E001 C                     END
     C*
     C           KEY1      KLIST
     C                     KFLD           KOJO
     C                     KFLD           YY
     C                     KFLD           MM
     C                     KFLD           DD
     C                     KFLD           CHUYA
     C                     KFLD           KIB1
     C                     KFLD           KIB2
     C*
     C           KEY2      KLIST
     C                     KFLD           KOJO
     C                     KFLD           KIB1
     C*
     C*  uﾇjｰ kｩｮh
     C*
     C           KEY1      CHAINMFBPL011             90
B001 C           *IN90     IFEQ '1'
     C                     MOVEA'111111'  *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERR
     C                     GOTO STP1
E001 C                     END
B001 C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     MOVEA'111111'  *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,7     ERR
     C                     GOTO STP1
E001 C                     END
     C******************************************************
     C*  EXFMT  <fﾞx] 2>                                   *
     C******************************************************
     C*
     C                     Z-ADDM1KADU    KADU
     C                     Z-ADD0         KAITEN
     C           STP3      TAG
     C           KEY2      CHAINMFAPL221             50
     C   50      KEY2      CHAINMFAPL261             50
     C  N50                Z-ADDM@RPMH    KAITEN
     C                     Z-ADD0         KEI     40
E001 C           *IN50     IFEQ '1'
     C                     MOVEA'111111'  *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,14    ERR
     C                     GOTO STP1
E001 C                     END
     C                     EXFMTMFBPW412
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'00000'   *IN,11
     C                     MOVEA'00'      *IN,16
     C                     MOVEA'0'       *IN,99
     C*  CMD-3
B001 C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
E001 C                     END
     C*
     C******************************************************
     C*  <fﾞx] 2 ﾉ kｩｮh>                                   *
     C******************************************************
     C           KTYPE     CABEQ'0'       LOP
      *
B001 C           M1KNTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,04
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1DMTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,05
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1ZMTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,06
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1KTTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,07
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1DNTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,08
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1TYTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,09
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1KSTI    IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,10
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
     C           M1KNTI    ADD  M1DMTI    KEI
     C                     ADD  M1ZMTI    KEI
     C                     ADD  M1KTTI    KEI
     C                     ADD  M1DNTI    KEI
     C                     ADD  M1TYTI    KEI
     C                     ADD  M1KSTI    KEI
     C*
B001 C           KEI       IFGT 720
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'11111'   *IN,04
     C                     MOVEA'1111'    *IN,06
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           M1DEKI    IFEQ 0
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,13
     C                     MOVELMSG,9     ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           KADU      IFEQ 0
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,15
     C                     MOVELMSG,11    ERR
     C                     GOTO STP3
E001 C                     END
     C*
B001 C           KADU      IFGT 12
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,15
     C                     MOVELMSG,12    ERR
     C                     GOTO STP3
E001 C                     END
      **
     C           M1MUHN    IFGT 1
     C           M1DEKI    SUB  M1MUHN    #DEKI   70
     C           KAITEN    MULT KADU      AAA     80
     C           AAA       IFLT #DEKI
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,13
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C                     ELSE
      *
     C           KAITEN    MULT KADU      AAA     80
     C           AAA       IFLT M1DEKI
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,13
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C                     END
      **
B001 C           M1DNKI    IFEQ 0
     C                     Z-ADD1         M1DNKI
E001 C                     END
     C*
B001 C           M1BISU    IFEQ 0
     C                     Z-ADD1         M1BISU
E001 C                     END
     C*
     C*
     C*  ENTER
     C           LOP       TAG
     C*
B001 C           *INKE     IFEQ '0'
     C                     GOTO STP3
E001 C                     END
     C*
     C   33                MOVEL'D'       M1SKJY
     C   33                Z-ADD*DATE     M1SKHZ
     C  N33                MOVE *BLANK    M1SKJY
     C  N33                Z-ADD0         M1SKHZ
     C                     Z-ADD*DATE     M1KOHZ
     C                     TIME           WTIME
     C                     MOVELUS        M1KOME
     C                     MOVE *BLANK    M1HNCD
     C**         KADU      MULT 60        M1KADU
     C                     Z-ADDKADU      M1KADU
     C*
     C  N90                UPDATMFBPL011
     C*
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C*
     C*----------------------------------------*
     C*         ...サブルーチン...           *
     C*     ...画面－１　の　クリアー...     *
     C*----------------------------------------*
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    KOJO
     C                     Z-ADD0         YMD
     C                     MOVE *BLANK    CHUYA
     C                     MOVE *BLANK    KIB1
     C                     MOVE *BLANK    KIB2
     C                     ENDSR
**  ERR
E-01 FACTORY ISN'T RIGHT
E-02 A DATE AFTER TOMORROW IS NOT RIGHT.
E-03 DATE IS NOT RIGHT.
E-04 NIGHT AND DAY <DAYTIME-H NIGHTTIME-Y>
E-05 INPUT MACHINE NO
E-06 APPLICABLE DATA NO EXIST
E-07 IT IS CANCELLED ALREADY
E-08 MORE THAN 720 MINUTES ISN'T RIGHT
E-09 INPUT FACT PRODUCTS NUMBER
E-10 FACT PRODUCTS NUMBER IS TOO MANY
E-11 INPUT OPERATION TIME
E-12 OPERATION TIME ISN'T RIGHT
E-13 UPDATE INSTRUCTION <0 1>
E-14 THERE ISN'T MCH NO INPUT INTO IN FACILITY MANAGE M/F
**  <TAB3/TAB4>
0CANCEL
1CHANGE
