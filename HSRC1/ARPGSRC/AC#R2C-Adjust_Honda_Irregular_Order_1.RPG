     H            Y.
     F** AC#R2C ******************************************************
     F*  PROGRAM: ADJUST HONDA IRREGULAR ORDER                       *
     F*          (DETECT DIFFERENT BIN# IN SAME ORDER (DUPLICATE) )  *
     F*  WRITTEN: JW (SRA) 2019.03.01                                *
     F****************************************************************
     FAB#PL2S UF  E           K        DISK
     FAB#PL2ABIF  E           K        DISK
     F            AB#PP2A1                          KRENAMEAB#PL2X
     FQPRINT  O   F     198     OF     PRINTER
      *===================================================
      *-----------------------------------------------------------
     IAB#PL2X     01
     I              ACKYMD                          XCKYMD
     I              ACKTIM                          XCKTIM
     I              ACKPGM                          XCKPGM
     I              ACEDID                          XCEDID
     I              ACPLNT                          XCPLNT
     I              ACPLNM                          XCPLNM
     I              ACSHCD                          XCSHCD
     I              ACSHNM                          XCSHNM
     I              ACSUPP                          XCSUPP
     I              ACSUNM                          XCSUNM
     I              ACPLSH                          XCPLSH
     I              ACPLDL                          XCPLDL
     I              ACSHTM                          XCSHTM
     I              ACDLTM                          XCDLTM
     I              ACSCQL                          XCSCQL
     I              ACSCAC                          XCSCAC
     I              ACSHNO                          XCSHNO
     I              ACPRJC                          XCPRJC
     I              ACMHIN                          XCMHIN
     I              ACMHN1                          XCMHN1
     I              ACMHN2                          XCMHN2
     I              ACMHN3                          XCMHN3
     I              ACMHN4                          XCMHN4
     I              ACCOLR                          XCCOLR
     I              ACMNAM                          XCMNAM
     I              ACREVN                          XCREVN
     I              ACAUTH                          XCAUTH
     I              ACLOTN                          XCLOTN
     I              ACSLTN                          XCSLTN
     I              ACLTSQ                          XCLTSQ
     I              ACRTNB                          XCRTNB
     I              ACCTTP                          XCCTTP
     I              ACPLTP                          XCPLTP
     I              ACTOKU                          XCTOKU
     I              ACNONY                          XCNONY
     I              ACNKOJ                          XCNKOJ
     I              ACNUKE                          XCNUKE
     I              ACODRN                          XCODRN
     I              ACBIN                           XCBIN
     I              ACSERL                          XCSERL
     I              AC864                           XC864
     I              ACCQTY                          XCCQTY
     I              ACQNTY                          XCQNTY
     I              ACUPID                          XCUPID
     I              ACRENO                          XCRENO
     I              ACCRDT                          XCCRDT
     I              ACSAD1                          XCSAD1
     I              ACSAD2                          XCSAD2
     I              ACCITY                          XCCITY
     I              ACSTAT                          XCSTAT
     I              ACZIPC                          XCZIPC
     I              ACCNTY                          XCCNTY
     I              ACASDT                          XCASDT
     I              ACTRLR                          XCTRLR
     I              ACTMQL                          XCTMQL
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#PL2S                  88
     C   88                LEAVE
      *
     C           ACQNTY    IFEQ 0
     C           ACPLSH    ORLE TODAY
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     EXSR #PRINT
      * UPDATE
     C           $UPFLG    IFEQ 'Y'
     C                     MOVE 'D'       ACUPID
     C                     MOVEL'AC#R2C  'ACCOLR
     C                     UPDATAB#PP2A1
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      * SET RETURN FLAG
     C           SEQ#      IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      * PRINT FOOT
     C           SEQ#      IFEQ 0
     C           $UPFLG    ANDNE'Y'
     C                     EXCPT@HDR1
     C                     EXCPT@FOT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * CHECK ORDERS
      *======================================================
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
      * CHECK DUPLICATE
      * WITH SHIP DATE
     C                     Z-ADDACTOKU    KCTOKU  40
     C                     Z-ADDACNONY    KCNONY  40
     C                     Z-ADDACPLSH    KCPLSH  80
     C                     MOVELACPLNT    KCPLNT  3
     C                     MOVELACSHCD    KCSHCD 10
     C           K#2AB     SETLLAB#PL2AB
     C                     DO   *HIVAL
     C           K#2AB     READEAB#PL2AB                 95
     C   95                LEAVE
      *
     C           XCBIN     IFEQ ACBIN
     C                     ITER
     C                     ENDIF
      *
     C           ACPLSH    IFNE ACASDT
     C                     ITER
     C                     ENDIF
      *
     C           XCUPID    IFEQ '1'
     C           XCUPID    OREQ '3'
     C                     MOVE *ON       *IN85
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      * CHECK DUPLICATE
      * WITHOUT SHIP DATE
     C                     Z-ADDACTOKU    KCTOKU  40
     C                     Z-ADDACNONY    KCNONY  40
     C                     Z-ADDACPLSH    KCPLSH  80
     C                     MOVELACPLNT    KCPLNT  3
     C                     MOVELACSHCD    KCSHCD 10
     C           K#2AB     SETLLAB#PL2AB
     C                     DO   *HIVAL
     C           K#2AB     READEAB#PL2AB                 95
     C   95                LEAVE
      *
     C           XCBIN     IFEQ ACBIN
     C                     ITER
     C                     ENDIF
      *
     C           ACPLSH    IFNE ACASDT
     C                     ITER
     C                     ENDIF
      *
     C           XCUPID    IFEQ '1'
     C           XCUPID    OREQ '3'
     C                     MOVE *ON       *IN85
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           XCHK1     ENDSR
      *======================================================
      * PRINT
      *======================================================
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 60
     C                     EXCPT@HDR1
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     MOVELACODRN    XXODRN 11
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPFLG  1
     C                     PARM           $RTN    1
      *
     C           K#2AB     KLIST
     C                     KFLD           KCTOKU  40
     C                     KFLD           KCNONY  40
     C                     KFLD           KCPLSH  80
     C                     KFLD           KCPLNT  3
     C                     KFLD           KCSHCD 10
      *
     C                     MOVE *BLANK    $RTN
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD80        LIN#    30
     C                     TIME           SDATE
      * PRINT HEADER
     C**         LIN#      IFGE 60
     C**                   EXCPT@HDR1
     C**                   Z-ADD3         LIN#
     C**                   ENDIF
      *
     C                     ENDSR
      *====================================================
     OQPRINT  E   01           @HDR1
     O                         #PGM      10
     O                                   40 '** HONDA IRREGULAR O'
     O                                   60 'RDER REPORT **   UPD'
     O                                   64 'FLG='
     O                         $UPFLG    65
     O                                   99 'DATE'
     O                         TODAY    102 '    /  /  '
     O                         NOW      112 '  :  :  '
     O                                  116 'P.'
     O                         PAGE  Z  120
     O        E   02           @HDR1
     O                                   40 '** DETECT DIFFERENT '
     O                                   60 'BIN# IN SAME ORDER ('
     O                                   80 'DUPLICATE) **       '
     O        E   03           @HDR1
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'NONY'
     O                                   27 'SHP DATE'
     O                                   34 'BIN#'
     O                                   41 'ORDER#'
     O                                   56 'USER PART'
     O                                   72 'PLANT'
     O                                   80 'SHIP TO'
     O                                   93 'QTY'
     O                                   97 '**'
      *
     O        E 1              @DTL1
     O                         SEQ#  Z +001
     O                         ACTOKU  +002
     O                         ACNONY  +002
     O                         ACPLSH  +002 '    /  /  '
     O                         ACBIN   +002
     O                         XXODRN  +002
     O                         ACMHIN  +001
     O                         ACPLNT  +001
     O                         ACSHCD  +002
     O                         ACQNTYZ +001
     O                         XCBIN   +002
      *
     O        E 1              @FOT1
     O                                   22 '** NO TARGET ORDER **'
