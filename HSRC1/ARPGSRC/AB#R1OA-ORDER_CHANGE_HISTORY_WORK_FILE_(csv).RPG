     H            Y.
     F** AB#R1OA ***************************************************************
     F*  ORDER CHANGE HISTORY WORK FILE (CSV)                                  *
     F*  JW    2022.06.07                                                      *
     F**************************************************************************
     FAB#WP1H IF  E           K        DISK
     FAB#WP1K O   E                    DISK
     F****************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80AHNOHZ
     I                                        1   40AHNOYY
     I                                        5   60AHNOMM
     I                                        7   80AHNODD
     I            DS
     I                                        1  20 AHMHIN
     I                                        1   5 AHMHN1
     I                                        6  10 AHMHN2
     I                                       11  15 AHMHN3
     I                                       16  20 AHMHN4
     I            DS
     I                                        1  12 AHSHIN
     I                                        1   5 AHSHN1
     I                                        6  10 AHSHN2
     I                                       11  12 AHSHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I**************************************************************
      *
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#WP1H
     C                     DO   *HIVAL
     C                     READ AB#WP1H                  98
     C   98                LEAVE
      * IGNORE
     C           AHQTY1    IFEQ AHQTY2
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #HEAD
     C                     ENDIF
      *
     C                     EXSR #DTL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
      * SET HEADER
      *------------------------------------------------------------
     C           #HEAD     BEGSR
      *
     C                     MOVEL'CUST#   'AJTOKU    P
     C                     MOVEL'DELV#   'AJNONY    P
     C                     MOVEL'FACTORY 'AJNKOJ    P
     C                     MOVEL'DOCK    'AJNUKE    P
     C                     MOVEL'USR_PART'AJMHIN    P
     C                     MOVEL'IAF_PART'AJSHIN    P
     C                     MOVEL'SHP_DATE'AJNOHZ    P
     C                     MOVEL'BIN#    'AJNOBN    P
     C                     MOVEL'ORDER#  'AJODRN    P
     C                     MOVEL'INVOICE#'AJINVN    P
     C                     MOVEL'ORIG QTY'AJQTY1    P
     C                     MOVEL'AFTR CHG'AJQTY2    P
     C                     MOVEL'CHG_DATE'AJKOHZ    P
     C                     MOVEL'CHG_TIME'AJKOTM    P
     C                     MOVEL'CHG_USER'AJKOUS    P
     C                     MOVEL'CHG_NAME'AJKONM    P
     C                     MOVEL'CHG_PGM 'AJKOPG    P
     C                     MOVEL#PGM      AJNOTE    P
     C                     WRITEAB#WP1K1
      *
     C                     ENDSR
      *------------------------------------------------------------
      * SET DETAIL
      *------------------------------------------------------------
     C           #DTL      BEGSR
      *
     C                     MOVELAHTOKU    $IN       P
     C                     MOVEL'04'      $LONG     P
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      AJTOKU    P
     C*
     C                     MOVELAHNONY    $IN       P
     C                     MOVEL'04'      $LONG     P
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      AJNONY    P
      *
     C                     MOVELAHNKOJ    $IN       P
     C                     MOVEL'01'      $LONG     P
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      AJNKOJ    P
      *
     C                     MOVELAHNUKE    $IN       P
     C                     MOVEL'04'      $LONG     P
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      AJNUKE    P
      *
     C                     MOVELAHMHIN    $MHIN     P
     C                     CALL 'EDTR02A'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    AJMHIN    P
      *
     C                     MOVELAHSHIN    $SHIN     P
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    AJSHIN    P
      *
     C                     MOVELAHNOHZ    $DATE1
     C                     MOVE *BLANK    $TIME1
     C                     MOVE 'YMD'     $YMD
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    AJNOHZ
      *
     C                     MOVELAHNOBN    $IN       P
     C                     MOVEL'02'      $LONG     P
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      AJNOBN    P
      *
     C                     MOVELAHODRN    AJODRN    P
     C                     MOVELAHINVN    AJINVN    P
     C                     MOVELAHQTY1    AJQTY1    P
     C                     MOVELAHQTY2    AJQTY2    P
      *
     C                     MOVELAHKYMD    $DATE1
     C                     MOVELAHKTIM    $TIME1
     C                     MOVE 'YMD'     $YMD
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    AJKOHZ
     C                     MOVEL$TIME2    AJKOTM
     C                     MOVELAHKMID    AJKOUS    P
      *
     C                     MOVELAJKOUS    $USER     P
     C                     CALL 'UTLR31D'
     C                     PARM           $USER  10
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     AJKONM    P
      *
     C                     MOVELAHKPGM    AJKOPG    P
     C                     MOVE *BLANK    AJNOTE
      *
     C                     WRITEAB#WP1K1
      *
     C                     ENDSR
      *------------------------------------------------------------
      * INITIAL SETTING
      *------------------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
