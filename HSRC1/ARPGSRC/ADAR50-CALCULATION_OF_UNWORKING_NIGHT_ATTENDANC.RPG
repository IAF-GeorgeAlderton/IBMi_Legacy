     C                     KFLD           #KHN3
      *---------------------------------------------------*
      *  еИЭжЬЯеЗ¶зРЖ                                     *
      *---------------------------------------------------*
     C           INSW      IFEQ *BLANK
     C                     Z-ADD*DATE     HYMD8
     C                     TIME           TIME
     C                     MOVE '1'       INSW    1
     C                     END
      *---------------------------------------------------*
      *  еЙНеЈ•з®ЛйГ®йЦАгБЃдЊњжХ∞гВТпЉСгБЂгБЩгВЛ                     *
      *---------------------------------------------------*
     C           *INL3     IFEQ '1'
     C                     Z-ADD1         STBIN   20
     C                     END
      *---------------------------------------------------*
      *  зЩЇи°МжЧ•гБЃеЗЇеЛ§зКґжЕЛгВИгВКдЊњж±ЇеЃЪ                     *
      *---------------------------------------------------*
     C           *INL2     IFEQ '1'
     C                     MOVE '0'       HNSW    1
     C                     Z-ADD0         WKBIN   20
     C                     SETOF                     21
     C           KEYF81    CHAINAGDPL111             21
     C           *IN21     IFEQ '0'
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ'*'
     C                     MOVE '1'       HNSW
     C                     END
      *
     C                     END
     C                     Z-ADD1         STBIN   20
     C                     END
      *---------------------------------------------------*
      *  жМЗеЃЪдЊњгБЃгГБгВІгГГгВѓ                               *
      *---------------------------------------------------*
     C           *INL1     IFEQ '1'
      *---------------------------------------------------*
      *  еЙНеЈ•з®ЛйГ®йЦАгБЃдЊњжХ∞гВТеПЦеЊЧгБЩгВЛ                     *
      *---------------------------------------------------*
     C                     Z-ADD0         WBMON   40
     C                     MOVE *BLANK    WKCD1   1
     C                     MOVE *BLANK    WSW1    1
     C                     MOVE DABMON    #KBMN
     C                     MOVE DABRUI    #KKDAI
     C                     MOVE DAHIN1    #KHN1
     C                     MOVE DAHIN2    #KHN2
     C                     MOVE DAHIN3    #KHN3
      *
     C                     Z-ADD0111      WBMON
     C                     SETOF                     21
     C           WBMON     CHAINAAIPL11              21
     C           *IN21     IFEQ '0'
     C                     Z-ADDCDCIBI    MAXBN   20
     C                     END
      *
     C           HNSW      IFEQ '1'
     C           MAXBN     DIV  2         WKBIN   20
     C                     Z-ADDWKBIN     MAXBN
     C                     END
      *======*
     C                     MOVE '0'       STSW    1
     C                     MOVE DABMON    #KBMN
     C                     MOVE DAHIN1    #KHN1
     C                     MOVE DAHIN2    #KHN2
     C                     MOVE DAHIN3    #KHN3
      *
     C                     SETOF                     8167
     C           KEYCB1    SETLLAGATL321
      *
     C                     DO   *HIVAL
     C           KEYCB1    READEAGATL321                 81
     C                     SETOF                     66
     C           *IN81     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     66
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN66     ANDEQ'0'
     C                     SETON                     67
     C                     Z-ADD0         CTRX    50
     C*                    XFOOTHTR       CTRX
     C                     Z-ADD0         I       20
     C                     DO   24
     C                     ADD  1         I       20
     C           HTR,I     IFNE 0
     C                     ADD  1         CTRX
     C                     END
     C                     END
      *жМЗеЃЪдЊњгБМжЬЙгВК
     C           CTRX      IFNE 0
     C                     MOVE '1'       STSW    1
     C                     Z-ADD1         SIKIS   10
      *еНКзЫі
     C           HNSW      IFEQ '1'
     C           CTRX      ANDGT1
     C                     EXSR $SB900
     C                     END
     C                     EXSR $SB901
     C                     END
      *
     C                     END
      *
     C  N81N67             END
      *
     C                     END
     C*------------------------------------------------------------*
     C* дЊњи®≠еЃЪгААгААгАА                                             *
     C*------------------------------------------------------------*
      *жМЗеЃЪдЊњзД°
     C           STSW      IFEQ '0'
     C                     Z-ADDSTBIN     DAHTBB
     C                     END
      *жМЗеЃЪдЊњжЬЙ
     C           STSW      IFEQ '1'
      *
     C                     Z-ADDSIKIS     IX      20
     C                     EXSR $SB910
     C                     Z-ADDHTR,IX    DAHTBB
     C                     Z-ADDHTR,IX    STBIN
     C                     Z-ADDIX        SIKIS
     C                     END
      *
     C*--------------------*
     C* еЙНеЈ•з®ЛеЗЇеЇЂ       *
     C* гГ°гГГгВ≠зіНеЕ•жЧ•     *
     C* еК†еЈ•зіНеЕ•жЧ•и®ИзЃЧгБЄ *
     C*--------------------*
     C                     MOVE DAHTYY    WETYY
     C                     MOVE DAHTMM    WETMM
     C                     MOVE DAHTDD    WETDD
     C                     MOVE DAHIN1    P1      5         *еУБпЉС
     C                     MOVE DAHIN2    P2      5         *еУБпЉТ
     C                     MOVE DAHIN3    P3      2         *еУБпЉУ
     C                     MOVE WETBI     P4      8         *гБЛгВУгБ∞гВУзЩЇи°МжЧ•
     C                     MOVE DAHTBB    P5      2         *дЊњ
     C                     MOVE 'R'       P6      1         * пЊТпЊЗn hпЊОпЊЮ]
     C                     MOVE 'H'       P7      1         * пЊОпЊЮy] hпЊОпЊЮ]
     C                     MOVE '00000000'P10     8         * udпЊГcmbпЊНпЊЮ
     C                     MOVE '00'      P11     2         * udпЊГcmb пЊНпЊЮ]
     C                     MOVE '00000000'P20     8         * xlg пЊНпЊЮ
     C                     MOVE '00'      P21     2         * xlg пЊНпЊЮ]
     C                     MOVE '00000000'P30     8         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ
     C                     MOVE '00'      P31     2         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ]
     C                     MOVE *BLANK    PSKJ    1         * evпљЃn
     C                     MOVE *BLANK    PMSG    1         * xпљЃпЊИпљ∞пЊЖпЊЮ
     C                     MOVE 'ADAR50'  PGMNO   6
     C                     CALL 'ATAR95'
     C                     PARM           P1      5         *еУБпЉС
     C                     PARM           P2      5         *еУБпЉТ
     C                     PARM           P3      2         *еУБпЉУ
     C                     PARM           P4      8         *гБЛгВУгБ∞гВУзЩЇи°МжЧ•
     C                     PARM           P5      2         *дЊњ
     C                     PARM           P6      1         * пЊТпЊЗn hпЊОпЊЮ]
     C                     PARM           P7      1         * пЊОпЊЮy] hпЊОпЊЮ]
     C                     PARM           P10     8         * udпЊГcmbпЊНпЊЮ
     C                     PARM           P11     2         * udпЊГcmb пЊНпЊЮ]
     C                     PARM           P20     8         * xlg пЊНпЊЮ
     C                     PARM           P21     2         * xlg пЊНпЊЮ]
     C                     PARM           P30     8         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ
     C                     PARM           P31     2         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ]
     C                     PARM           PSKJ              * evпљЃn
     C                     PARM           PMSG              * xпљЃпЊИпљ∞пЊЖпЊЮ
      *
     C                     PARM           PGMNO
     C                     PARM           PUSER
     C           PSKJ      IFEQ 'D'
     C                     GOTO LAST
     C                     END
     C                     MOVE P10       WETBI
     C                     MOVE WETYY     DASYYY
     C                     MOVE WETMM     DASYMM
     C                     MOVE WETDD     DASYDD
     C                     MOVE P11       DASYBB
     C                     MOVE P20       WETBI
     C                     MOVE WETYY     DAMKYY
     C                     MOVE WETMM     DAMKMM
     C                     MOVE WETDD     DAMKDD
     C                     MOVE P21       DAMKBB
     C                     MOVE P30       WETBI
     C                     MOVE WETYY     DAKAYY
     C                     MOVE WETMM     DAKAMM
     C                     MOVE WETDD     DAKADD
     C                     MOVE P31       DAKABB
      *
     C                     Z-ADDHYY       DAKOYY
     C                     Z-ADDHMM       DAKOMM
     C                     Z-ADDHDD       DAKODD
     C                     Z-ADDTIMEHH    DAKOHH
     C                     Z-ADDTIMESS    DAKOSS
     C                     WRITEADAWP601
      *
     C                     ADD  1         STBIN
      *
     C           STSW      IFEQ '1'
     C                     ADD  1         SIKIS
     C                     END
      *--------------------*
      *зє∞гВКињФгБЧдЊњгБЃгВїгГГгГИ*
      *--------------------*
      *жМЗеЃЪдЊњзД°
     C           STBIN     IFGT MAXBN
     C                     Z-ADD1         STBIN
     C                     END
      *
     C           LAST      TAG
      *
     CLR                   MOVE *BLANK    P1      5         *еУБпЉС
     CLR                   MOVE *BLANK    P2      5         *еУБпЉТ
     CLR                   MOVE *BLANK    P3      2         *еУБпЉУ
     CLR                   MOVE '00000000'P4      8         *гБЛгВУгБ∞гВУзЩЇи°МжЧ•
     CLR                   MOVE '00'      P5      2         *дЊњ
     CLR                   MOVE 'N'       P6      1         * пЊТпЊЗn hпЊОпЊЮ]
     CLR                   MOVE 'R'       P7      1         * пЊОпЊЮy] hпЊОпЊЮ]
     CLR                   MOVE '00000000'P10     8         * udпЊГcmbпЊНпЊЮ
     CLR                   MOVE '00'      P11     2         * udпЊГcmb пЊНпЊЮ]
     CLR                   MOVE '00000000'P20     8         * xlg пЊНпЊЮ
     CLR                   MOVE '00'      P21     2         * xlg пЊНпЊЮ]
     CLR                   MOVE '00000000'P30     8         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ
     CLR                   MOVE '00'      P31     2         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ]
     CLR                   MOVE *BLANK    PSKJ              * evпљЃn
     CLR                   MOVE *BLANK    PMSG              * xпљЃпЊИпљ∞пЊЖпЊЮ
     CLR                   CALL 'ATAR95'
     CLR                   PARM           P1      5         *еУБпЉС
     CLR                   PARM           P2      5         *еУБпЉТ
     CLR                   PARM           P3      2         *еУБпЉУ
     CLR                   PARM           P4      8         *гБЛгВУгБ∞гВУзЩЇи°МжЧ•
     CLR                   PARM           P5      2         *дЊњ
     CLR                   PARM           P6      1         * пЊТпЊЗn hпЊОпЊЮ]
     CLR                   PARM           P7      1         * пЊОпЊЮy] hпЊОпЊЮ]
     CLR                   PARM           P10     8         * udпЊГcmbпЊНпЊЮ
     CLR                   PARM           P11     2         * udпЊГcmb пЊНпЊЮ]
     CLR                   PARM           P20     8         * xlg пЊНпЊЮ
     CLR                   PARM           P21     2         * xlg пЊНпЊЮ]
     CLR                   PARM           P30     8         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ
     CLR                   PARM           P31     2         * 2пЊЖпЊЮfпЊГc пЊНпЊЮ]
     CLR                   PARM           PSKJ              * evпљЃn
     CLR                   PARM           PMSG              * xпљЃпЊИпљ∞пЊЖпЊЮ
