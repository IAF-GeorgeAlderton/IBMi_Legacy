     FAB#EP40 IF  E                    DISK
     FAB#FPCL UF  E           K        DISK                      A
     F*PRINT  O   F     132     OF     PRINTER
      *-----------------------------------------
     E                    AY         30  1
     E                    AX         30  1
      *-----------------------------------------
     I            DS
     I                                       01  30 EMHIN
     I                                       01  05 PART1
     I                                       06  10 PART2
     I                                       11  15 PART3
     I                                       16  20 PART4
      *-----------------------------------------
     C           KEY1      KLIST
     C                     KFLD           ETOKU
     C                     KFLD           ENONY
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
     C                     KFLD           PART4
      *
     C                     MOVE ' '       @ENTER  1
      *
     C           *IN90     DOWEQ'0'
     C                     READ AB#EP40                  90
B2   C           *IN90     IFEQ '0'
B3   C           ENONY     IFEQ '0602'
     C           ENONY     OREQ '0601'
      *
     C                     MOVE '1'       @ENTER
      *
     C           KEY1      CHAINAB#FPCL1             65
B4   C           *IN65     IFEQ '0'
     C           ENONY     IFEQ '0602'
     C                     Z-ADDEBOXQ     AFACQY
     C                     ELSE
     C                     EXSR #STRIP
     C                     ENDIF
     C                     MOVE EODRN     AFODRN
     C                     UPDATAB#FPCL1
     C                     ELSE
     C                     MOVE ETOKU     AFTOKU
     C                     MOVE ENONY     AFNONY
     C                     MOVE PART1     AFMHN1
     C                     MOVE PART2     AFMHN2
     C                     MOVE PART3     AFMHN3
     C                     MOVE PART4     AFMHN4
     C           ENONY     IFEQ '0602'
     C                     Z-ADDEBOXQ     AFACQY
     C                     ELSE
     C                     EXSR #STRIP
     C                     ENDIF
     C                     MOVE EODRN     AFODRN
     C                     WRITEAB#FPCL1
     C                     CLEARAB#FPCL1
E4   C                     ENDIF
E3   C                     ENDIF
E2   C                     ENDIF
      *
     C                     ENDDO
      * PRINT DIFFERENCE
     C*          @ENTER    IFEQ '1'
     C*                    EXCPT@HED
     C*          *LOVAL    SETLLAB#FPCL
B0   C*          *IN55     DOWEQ'0'
B1   C*          *INOF     IFEQ *ON
     C*                    EXCPT@HED
E1   C*                    ENDIF
     C*                    READ AB#FPCL1                 55
B1   C*          *IN55     IFEQ '0'
     C*          AFACQY    ANDNEAFIFYY
     C*                    EXCPT@DTL
E1   C*                    ENDIF
E0   C*                    ENDDO
     C*                    ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     C*=============================================
     C           #STRIP    BEGSR
     C                     CLEARAY
     C                     MOVE *ALL'0'   AX
     C*                    MOVE EREFP     AFACQY
     C                     MOVEAEREFP     AY
     C                     Z-ADD31        Y       20
     C                     Z-ADD30        K       20
     C           1         DO   30        X       20
     C           Y         SUB  1         Y
     C           AY,Y      IFNE ' '
     C                     MOVE AY,Y      AX,K
     C           K         SUB  1         K
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAAX        EREFP
     C                     MOVE EREFP     AFACQY
     C                     ENDSR
      *
     O*PRINT  E   01           @HED
     O*                                   8 'AB#RFCL'
     O*                                  50 'FACIL ACUM DIF. LIST'
     O*                        UDATE Y  100
     O*       E   05           @HED
     O*                                  10 'PART'
     O*                                  35 'FACIL ACUM'
     O*                                  55 'IAF TOT SHIP'
     O*       E 11             @DTL
     O*                        AFMHN1     7
     O*                        AFMHN2    13
     O*                        AFMHN3    19
     O*                        AFMHN4    25
     O*                        AFACQY4   35
     O*                        AFIFYY4   55
