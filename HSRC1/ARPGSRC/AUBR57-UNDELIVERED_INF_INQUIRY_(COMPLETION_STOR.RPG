     C           CFMHKO    IFEQ CFBHK1
     C                     MOVE CFBYY1    WKY
     C           WKY       IFEQ '0000'
     C                     MOVE *BLANK    WK02
     C                     ELSE
     C                     MOVE '.'       WKH1
     C                     MOVE CFBMM1    WKM
     C                     MOVE '.'       WKH2
     C                     MOVE CFBDD1    WKD
     C                     MOVE '-'       WKH3
     C                     MOVE CFBBB1    WKB
     C                     END
     C                     END
     C                     END
     C                     END
