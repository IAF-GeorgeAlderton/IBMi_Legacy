     C                     MOVE CFMNMM    WKM
     C                     MOVE '.'       WKH2
     C                     MOVE CFMNDD    WKD
     C                     MOVE '-'       WKH3
     C                     MOVE CFMNBB    WKB
     C                     END
     C                     END
     C                     MOVE WK02      @BANK1
     C** NUMBER OF BOXES **
     C                     MOVE CFBHK1    @HAKO1
     C           CFMNKB    IFEQ '2'
     C           CFMAIS    SUB  CFMHKO    @HAKO1
     C                     END
     C** RETRIEVAL DAY 2**
     C                     MOVE CFBYY2    WKY
     C           WKY       IFEQ '0000'
     C                     MOVE *BLANK    WK02
     C                     ELSE
