     H            Y.
     F** AAMR85 ********************************************
     F*かんばん回転日数データ作成(AAHPP01)               *
     F*   MSK.                            2011.02.15       *
     F******************************************************
     FAAHPP01 IF  E                    DISK
     FAAMWP80 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80L6SKHZ
     I                                        1   40L6SKYY
     I                                        5   60L6SKMM
     I                                        7   80L6SKDD
      *
     I            DS
     I                                        1   80L6UKHZ
     I                                        1   40L6UKYY
     I                                        5   60L6UKMM
     I                                        7   80L6UKDD
     I            DS
     I                                        1   80L6STHZ
     I                                        1   40L6STYY
     I                                        5   60L6STMM
     I                                        7   80L6STDD
      *
     I            DS
     I                                        1   3 L6JBN
     I                                        1   1 L6ATK1
     I                                        2   3 L6ATK2
      *
     I            DS
     I                                        1   3 WKF
     I                                        1   1 WKK1F
     I                                        2   3 WKT1F
      *
     I            DS
     I                                        1   3 WKT
     I                                        1   1 WKK1T
     I                                        2   3 WKT1T
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I            DS
     I                                        1   6 W@TKR
     I                                        1   1 W@TKR1
     I                                        2   3 W@TKR2
     I                                        4   5 W@TKR3
     I                                        6   6 W@TKR4
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
     C           ACALL     PLIST
     C                     PARM           ASTLR            SETON LR ﾍｭcﾆg
     C                     PARM           L6KSSU
     C                     PARM           L6KEIS
     C                     PARM           L6LTIM
     C                     PARM           L6SYOS
     C                     PARM           L6LOTO
     C                     PARM           L6MAXH
     C                     PARM           WMAIS
      *１箱メッキ用
     C           ABCR87    PLIST
     C                     PARM           PIKSSU  90
     C                     PARM           PISYSS  50
     C                     PARM           PILTKE  50
     C                     PARM           PILOTO  20
     C                     PARM           PIMXHK  30
     C                     PARM           POMAIS  40
      * AMER81
     C           AMER81    PLIST
     C                     PARM           PIHIN1  5
     C                     PARM           PIHIN2  5
     C                     PARM           PIHIN3  2
     C                     PARM           PICTKR  6
     C                     PARM           PIKCD1  1
     C                     PARM           PIKCD2  1
     C                     PARM           PIMBMN  4
     C                     PARM           PIKOTE  3
     C                     PARM           PIMKER  4
     C                     PARM           PIDATE 10
     C                     PARM           POHNTE  1
     C                     PARM           POLINE  2
     C                     PARM           POURLT  4
     C                     PARM           POKTLT  4
     C                     PARM           POHILT  4
     C                     PARM           POTOLT  4
     C                     PARM           POMELT  4
     C                     PARM           POTRLT  4
     C                     PARM           PONYLT  4
     C                     PARM           POINLT  4
     C                     PARM           POSKLT  4
     C                     PARM           POUNLT  4
     C                     PARM           PONKLT  4
     C                     PARM           POSKAI  3
     C                     PARM           POFRLT  4
     C                     PARM           POANLT  4
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKT1T
     C                     ENDIF
      *
     C                     READ AAHPP011                 81
     C           *IN81     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AAHPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           L6ATOB    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
     C           PKOTE     IFNE *BLANK
     C           L6ATOK    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           L6JBN     IFLT WKF
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C           L6JBN     IFGT WKT
     C                     MOVEL'0'       WKOK
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELL6ATOB    W0BMON
     C                     MOVELL6SHN1    W0SHN1
     C                     MOVELL6SHN2    W0SHN2
     C                     MOVELL6SHN3    W0SHN3
     C                     MOVELL6ATOK    W0KOTE
     C                     MOVELL6ATK1    W0TKR1
     C                     MOVELL6ATK2    W0TKR2
     C                     MOVELL6ATK3    W0TKR3
     C                     MOVELL6ATK4    W0TKR4
     C           L6KTSU    MULT 20        W0KTSU
     C           L6KSSU    MULT 20        W0KSSU
     C           L6SYOS    IFNE 0
     C           L6KSSU    DIV  L6SYOS    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDL6SYOS    W0SYUY
     C                     Z-ADD0         W0LOTK
     C                     Z-ADD0         W0KJNK
     C                     Z-ADD0         W0SETO
     C                     Z-ADDL6KMAX    W0KMAX
     C                     MOVELL6KCD1    W0KCD1
     C                     MOVELL6KCD2    W0KCD2
      *
     C                     MOVE *BLANK    W0KSN1
     C                     MOVE *BLANK    W0KSN3
     C                     MOVE *BLANK    W0KSN2
     C                     Z-ADD0         W0HITO
     C                     Z-ADD0         W0TYLT
     C                     Z-ADDL6LTIM    W0LTIM
     C                     Z-ADDL6KEIS    W0KEIS
     C                     Z-ADDL6MAXH    W0MAXS
     C                     MOVE *BLANK    W0KKEY
      *
     C           L6SYOS    IFNE 0
     C                     EXSR $SB600
     C                     END
     C                     MOVE WMAIS     W0SMAX
     C                     MOVE L6LOTO    W0SLOT
     C                     MOVE *BLANK    W0SJNK
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
     C*****************************************************************
     C           $SB600    BEGSR
     C*----------------------------------------*
     C*     ...かんばん枚数　の　計算...     *
     C*----------------------------------------*
      *
     C                     MOVELL6UKHZ    WKDTA6  6
     C                     MOVE *ALL'0'   WKDTA8  8
     C                     CALL 'DATR00'
     C                     PARM           WKDTA6
     C                     PARM           WKDTA8
     C                     MOVE WKDTA8    @CHKDT  80
      *
     C                     Z-ADD0         WMAIS   50
      *１箱メッキ対象品のチェック
     C                     SETOF                     26
     C                     MOVE '0'       @1MEKI  1
     C**                   EXSR $SB950
     C**         POHNTE    IFEQ '1'
     C**                   MOVE '1'       @1MEKI
     C**                   END
      *
     C           @1MEKI    IFEQ '0'
     C****       @2MEKI    OREQ '1'                        eｰ[b]
     C                     MOVE *BLANK    ASTLR   2        SETON LR ﾍｭcﾆg
     C                     CALL 'ABCR07'  ACALL
     C                     ELSE
      *
     C                     EXSR $SB999
     C                     Z-ADDL6KSSU    PIKSSU
     C                     Z-ADDL6SYOS    PISYSS
     C                     Z-ADDL6LOTO    PILOTO
     C                     Z-ADDL6MAXH    PIMXHK
     C                     Z-ADD0         POMAIS
     C                     CALL 'ABCR87'  ABCR87
     C                     Z-ADDPOMAIS    WMAIS
     C                     END
      *
     C           $S600E    ENDSR
      *--------------------------------------------------------------*
      *　　多回集荷対象品の判定　　　　　　　　　　　　　　　　　  *
      *--------------------------------------------------------------*
     CSR         $SB950    BEGSR
     C                     CLEARW@TKR
     C                     MOVE L6ATK1    W@TKR1
     C                     MOVE L6ATK2    W@TKR2
     C                     MOVE L6ATK3    W@TKR3
     C                     MOVE L6ATK4    W@TKR4
      *
     C                     MOVE L6SHN1    PIHIN1
     C                     MOVE L6SHN2    PIHIN2
     C                     MOVE L6SHN3    PIHIN3
     C                     MOVE W@TKR     PICTKR
     C                     MOVE L6KCD1    PIKCD1
     C                     MOVE L6KCD2    PIKCD2
     C                     MOVE L6MAKB    PIMBMN  4
     C                     MOVE L6ATOK    PIKOTE  3
     C                     MOVE L6ATOB    PIMKER  4
     C                     MOVEL@CHKDT    PIDATE 10
     C                     MOVE L6UBIN    PIDATE
     C*                    MOVEL*DATE     PIDATE 10
     C*                    MOVE '01'      PIDATE
     C                     MOVE *BLANK    POHNTE  1
     C                     MOVE *BLANK    POLINE  2
     C                     CALL 'AMER81'  AMER81
     CSR         $S950E    ENDSR
      *--------------------------------------------------------------*
      *　　１箱メッキ用かんばん枚数計算用パラメータセット          *
      *--------------------------------------------------------------*
     CSR         $SB999    BEGSR
      *パラメータ値セット
     C           POHNTE    IFEQ '1'
      *
     C                     Z-ADD0         PILTKE
      *
     C                     MOVE POINLT    AMINLT  40
     C                     MOVE POSKLT    AMSKLT  40
     C                     MOVE POUNLT    AMUNLT  40
     C                     MOVE PONKLT    AMNKLT  40
     C                     MOVE POFRLT    AMFRLT  40
     C                     MOVE POANLT    AMANLT  40
      *
     C                     ADD  AMINLT    PILTKE
     C                     ADD  AMSKLT    PILTKE
     C                     ADD  AMUNLT    PILTKE
     C                     ADD  AMNKLT    PILTKE
     C                     ADD  AMFRLT    PILTKE
     C                     ADD  AMANLT    PILTKE
      *
     C                     END
      *
     CSR         $S999E    ENDSR
