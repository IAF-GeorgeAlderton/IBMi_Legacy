     C           *ENTRY    PLIST
     C                     PARM           P9ER1   1
     C                     PARM           P9ER2   1
      *
     C           KEY1      KLIST
     C                     KFLD           BAHIN1
     C                     KFLD           BAHIN2
     C                     KFLD           BAHIN3
     C                     KFLD           BACGYM
     C           KEY2      KLIST
     C                     KFLD           BAHIN1
     C                     KFLD           BAHIN2
     C                     KFLD           BAHIN3
      *
     C           KEY3      KLIST
     C                     KFLD           BACGYM
     C                     KFLD           BAHIN1
     C                     KFLD           BAHIN2
     C                     KFLD           BAHIN3
     C                     KFLD           BACGDD
      *
     C  N99                MOVEL' '       P9ER1
     C  N99                MOVEL' '       P9ER2
     C  N99                MOVELCMT,1     @CMT  146
     C**N99                MOVELCMT,2     @CMTX  73
     C**N99                MOVE @CMTX     @CMT
     C  N99                SETON                     99
      *
     C                     MOVE ' '       WORK    1
     C                     MOVE ' '       BAWORK  1
      *----------------------*
      *入力値１０００超え？*
      * INPUT DATA IS OVER 1000 ?
      *----------------------*
     C                     SETOF                     29
     C           KEY3      CHAINBTCPP8Y1             29
     C           *IN29     IFEQ '0'
     C           B@CASU    IFGE 1000
     C           B@CMSU    ORGE 1000
     C                     MOVEL'9'       WORK
     C                     END
     C                     ENDIF
      *
     C                     SETOF                     2029
     C                     EXSR #SB000
      *
     C           *IN20     IFEQ '0'
     C                     Z-ADDBACGDD    #Z      20
      *
     C                     SETOF                     10
     C           KEY1      CHAINBTAPL041             10
     C                     SETOF                       90
      *
S1   C           *IN10     IFEQ '0'
      *
 S2  C           BTSKJY    IFEQ 'D'
     C           BTSKH8    ANDLE*DATE
     C                     EXSR $SB999
     C  N90                EXSR #SB003
 X2  C                     ELSE
     C                     EXSR $SB999
     C  N90                EXSR #SB002
 E2  C                     END
      *
X1   C                     ELSE
      *
     C                     MOVEL*ALL'0'   HTP
     C                     MOVEL*ALL'0'   HTM
     C                     EXSR $SB999
     C  N90                EXSR #SB001
E1   C                     END
     C                     ELSE
      * AGAPL31 NOT-FOUND
     C                     MOVEL'1'       BAWORK
S1   C           WORK      IFEQ '9'
     C                     MOVEL'2'       BAWORK
E1   C                     ENDIF
     C                     MOVEL'1'       P9ER1
      *
     C  N97                EXCPTHD
     C                     EXCPTDT
     C                     SETON                     97
     C                     END
      *
     C           LAST      TAG
      *-----------------------------------------------------------*
      *          #SB001    BTCPP04_WRITE PROCESS                 *
      *-----------------------------------------------------------*
     C           #SB001    BEGSR
      *
     C                     MOVEL*ALL'0'   HTP
     C                     MOVEL*ALL'0'   HTM
     C                     MOVEA*BLANK    HTZ
     C                     MOVELBAHIN1    BTSHN1
     C                     MOVELBAHIN2    BTSHN2
     C                     MOVELBAHIN3    BTSHN3
     C                     Z-ADDBACGYM    BTKEYM
     C* * *                Z-ADDBACGYM    BTKYM6
     C                     Z-ADDBACASU    HTP,#Z
     C                     Z-ADDBACMSU    HTM,#Z
     C                     EXSR #SB004
     C                     WRITEBTAPL041
      *
     C           ESB001    ENDSR
      *-----------------------------------------------------------*
      *          #SB002    BTCPP04_UPDATE PROCESS                 *
      *-----------------------------------------------------------*
     C           #SB002    BEGSR
      *
     C                     ADD  BACASU    HTP,#Z
     C                     ADD  BACMSU    HTM,#Z
     C                     EXSR #SB004
     C                     UPDATBTAPL041
      *
     C           ESB002    ENDSR
      *-----------------------------------------------------------*
      *          #SB003    BTCPP04_UPDATE PROCESS               *
      *-----------------------------------------------------------*
     C           #SB003    BEGSR
      *
     C                     MOVEL*ALL'0'   HTP
     C                     MOVEL*ALL'0'   HTM
     C                     MOVEA*BLANK    HTZ
     C                     Z-ADDBACASU    HTP,#Z
     C                     Z-ADDBACMSU    HTM,#Z
     C                     EXSR #SB004
     C                     UPDATBTAPL041
      *
     C           ESB003    ENDSR
      *-----------------------------------------------------------*
      *          #SB004    SET UP UPDATE FIELDS                   *
      *-----------------------------------------------------------*
     C           #SB004    BEGSR
     C                     MOVEL*BLANK    BTSKJY
     C                     Z-ADD0         BTSKH8
     C                     Z-ADD*DATE     BTKOH8
     C                     TIME           BTKOTI
     C                     MOVELUSID      BTKOME
     C           ESB004    ENDSR
      *-----------------------------------------------------------*
      *          #SB000  CHECK AGAPP31 (LEVELED ORDER FILE)
      *-----------------------------------------------------------*
     C           #SB000    BEGSR
      *
     C* * *      KEY2      CHAINAGAPL311             20
     C* * *      *IN20     IFEQ '0'
     C* * *      CBSKJY    IFEQ 'D'
     C* * *      CBSKH8    ANDLE*DATE
     C* * *                SETON                     20
     C* * *                END
     C* * *                END
      *
     C           ESB000    ENDSR
      *----------------------------------------------------------------
      * Ａ－ＰＩＣＳ計画発行管理マスターの既存値との比較
      * COMPARE  BTCPP85 AND BTAPP04
      *----------------------------------------------------------------
     CSR         $SB999    BEGSR
     C                     SETOF                     90
     C           BTSKJY    IFEQ 'D'
     C           BTSKH8    ANDLE*DATE
     C                     Z-ADDBACASU    W@CASU  50
     C                     Z-ADDBACMSU    W@CMSU  50
     C                     ELSE
     C           HTP,#Z    ADD  BACASU    W@CASU
     C           HTM,#Z    ADD  BACMSU    W@CMSU
     C                     END
      *
     C                     MOVE *BLANK    XMSG    8
      *
     C           W@CASU    IFGE 1000
     C           W@CMSU    ORGE 1000
     C                     MOVE '9'       WORK
     C                     MOVEL'1'       P9ER2
     C                     SETON                     90
     C                     MOVELWORK      BAWORK
      *
JW1  C           W@CASU    IFGE 1000
 .   C                     MOVE W@CASU    XMSG
 .   C                     MOVEL'(+)'     XMSG
 .   C                     ENDIF
 .    *
 .   C           W@CMSU    IFGE 1000
 .   C                     MOVE W@CMSU    XMSG
 .   C                     MOVEL'(-)'     XMSG
JW1  C                     ENDIF
      *
     C  N97                EXCPTHD
     C   90                EXCPTDT
     C                     SETON                     97
      *
     C                     END
     CSR         $S999E    ENDSR
     OBTCWP86 E                HD
     O                                      'PART NO.'
     O                                      ','
     O                                      'PLAN DATE'
     O                                      ','
     O                                      '="+ BOXES"'
     O                                      ','
     O                                      '="- BOXES"'
     O                                      ','
     O                                      'ERR'
     O                                      ','
     O                         @CMT
     O                                      ','
     O        E                DT
     O                                      '="'
     O                         BAHIN1
     O                         BAHIN2
     O                         BAHIN3
     O                                      '"'
     O                                      ','
     O                         BACGYM
     O                         BACGDD
     O                                      ','
     O                         BACASU
     O                                      ','
     O                         BACMSU
     O                                      ','
     O                         BAWORK
     O                                      ','
JW1  O                         XMSG
     O                                      ','
