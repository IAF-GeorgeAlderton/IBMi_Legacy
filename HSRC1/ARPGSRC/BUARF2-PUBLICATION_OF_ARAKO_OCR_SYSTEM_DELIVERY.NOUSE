     C*** CHKDG1 ***********************************
     C*チェック・デジット計算処理のサブ・ルーチン*
     C*   INPUT=>DAT1(38 LENGTH)   OUTPUT=>CDANS1  *
     C**********************************************
     C           CHKDG1    BEGSR
     C                     Z-ADD1         J       20
     C                     Z-ADD7         OMOMI   10
     C                     Z-ADD0         WA
     C                     Z-ADD0         SEKI
     C*
     C                     DO   38        J
     C*****入力データが空白の時０入力*****
     C           DAT1,J    IFEQ *BLANK
     C                     MOVEA'0'       DAT1,J
     C                     END
     C*****入力データが英字かチェック*****
     C                     Z-ADD1         E       20
     C                     SETOF                     07
     C           DAT1,J    LOKUPEIJ,E                    07
     C           *IN07     IFEQ '1'
     C*****入力データが英字の時*****
     C           ESUU,E    MULT OMOMI     SEKI
     C           WA        ADD  SEKI      WA
     C                     ELSE
     C*****入力データが数字の時*****
     C                     MOVEADAT1,J    SDAT1M  1
     C                     MOVE SDAT1M    SDAT1S  10
     C           SDAT1S    MULT OMOMI     SEKI    40
     C           WA        ADD  SEKI      WA      40
     C                     END
     C*
     C           OMOMI     SUB  1         OMOMI
     C           OMOMI     IFEQ 0
     C                     Z-ADD7         OMOMI
     C                     END
     C*
     C                     END
     C*
     C           WA        DIV  11        SIYOU   50
     C                     MVR            AMARI   20
     C           11        SUB  AMARI     CDANS1  10
     C                     ENDSR
     C*** CHKDG2 ***********************************
     C*チェック・デジット計算処理のサブ・ルーチン*
     C*   INPUT=>DAT2(38+1LENGTH)  OUTPUT=>CDANS2  *
     C**********************************************
     C           CHKDG2    BEGSR
     C                     Z-ADD1         J
     C                     Z-ADD6         OMOMI
     C                     Z-ADD0         WA
     C                     Z-ADD0         SEKI
     C*
     C                     DO   39        J
     C*****入力データが空白の時０入力*****
     C           DAT2,J    IFEQ *BLANK
     C                     MOVEA'0'       DAT2,J
     C                     END
     C*****入力データが英字かチェック*****
     C                     Z-ADD1         E       20
     C                     SETOF                     07
     C           DAT2,J    LOKUPEIJ,E                    07
     C           *IN07     IFEQ '1'
     C*****入力データが英字の時*****
     C           ESUU,E    MULT OMOMI     SEKI
     C           WA        ADD  SEKI      WA
     C                     ELSE
     C*****入力データが数字の時*****
     C                     MOVEADAT2,J    SDAT2M  1
     C                     MOVE SDAT2M    SDAT2S  10
     C           SDAT2S    MULT OMOMI     SEKI    40
     C           WA        ADD  SEKI      WA      40
     C                     END
     C**
     C           OMOMI     SUB  1         OMOMI
     C           OMOMI     IFEQ 0
     C                     Z-ADD7         OMOMI
     C                     END
     C**
     C                     END
     C**
     C           WA        DIV  11        SIYOU   50
     C                     MVR            AMARI   20
     C           11        SUB  AMARI     CDANS2  10
     C                     ENDSR
     C*** CHKDG3 ***********************************
     C*チェック・デジット計算処理のサブ・ルーチン*
     C*   INPUT=>DAT3(5 LENGTH)    OUTPUT=>CDANS3  *
     C**********************************************
     C           CHKDG3    BEGSR
     C                     Z-ADD0         WA1
     C**
     C           DAT31     MULT 7         SEKI1   20
     C           WA1       ADD  SEKI1     WA1     30
     C**
     C           DAT32     MULT 5         SEKI1
     C           WA1       ADD  SEKI1     WA1
     C**
     C           DAT33     MULT 3         SEKI1
     C           WA1       ADD  SEKI1     WA1
     C**
     C           DAT34     MULT 1         SEKI1
     C           WA1       ADD  SEKI1     WA1
     C**
     C           DAT35     MULT 6         SEKI1
     C           WA1       ADD  SEKI1     WA1
     C**
     C           WA1       DIV  11        SYOU1   50
     C                     MVR            AMARI1  20
     C           11        SUB  AMARI1    CDANS3  10
     C                     ENDSR
     C*** ERRPRT ***********************************
     C*発行データエラーリスト処理のサブ・ルーチン*
     C**********************************************
     C           ERRPRT    BEGSR
     C                     EXCPTME
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     ENDSR
