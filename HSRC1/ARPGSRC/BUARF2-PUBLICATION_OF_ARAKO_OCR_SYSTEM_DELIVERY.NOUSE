     C                     MOVE *BLANK    SIREN1
     C                     MOVE NAME,2    SIREN1
     C                     MOVE *BLANK    SKYUN1
     C                     MOVE '2'       IGETA1
     C                     MOVELKN        KANRI1
     C                     Z-ADDSY        SYUYO1
