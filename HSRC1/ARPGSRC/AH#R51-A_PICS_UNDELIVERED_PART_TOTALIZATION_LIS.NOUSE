     H            Y.                                                      DAD000
     F** AH#R51 **********************************
     F* ... A-PICS UNDELIVERED PART TOTALIZATION LIST...*
     F* ...  UNDELIVERED TOTALIZATION BY COST CENTER...*
     F* ... CALCULATION OF OPERATION DAYS.  ETC...*
     F*                 A.IDOTA 1991.02.26 *
     F********************************** AH#R51 **
     FAH#WP20 IP  F      60            DISK
     FNCHNP01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAH#WP21 O   F      60            DISK
     E                    HN1       200 12
     E                    HN2       200 12
     E                    HN3       200 12
     IAH#WP20 AA
     I                                        1   3 KBAN  L1
     I                                        4  15 HINBAN
     I                                       16  190BMON  L2
     I                                       20  22 KOTEI
     I                                       23  250HINGOK
     I                                       26  290HAKGOK
     I                                       30  320HIKTEN
     I                                       33  410HIKJIS
     I                                       42  490KHIZ
     I                                       50  570MHIZ
     C*
     C*--- 稼動日数 ---*
     C*
     C           *IN01     IFEQ '0'
     C           UMONTH    IFEQ 1
     C           *YEAR     SUB  1         SNNEN   40
     C                     Z-ADD12        SNTUK   20
     C                     ELSE
     C                     Z-ADD*YEAR     SNNEN
     C           UMONTH    SUB  1         SNTUK
     C                     END
     C*-- 合成ＫＥＹ --*
     C           SETHI     KLIST
     C                     KFLD           SNNEN
     C                     KFLD           SNTUK
     C                     Z-ADD*ZERO     KADOHI  20
     C           SETHI     SETLLAGDPL121             25
     C                     DO   *HIVAL
     C           SETHI     READEAGDPL121                 25
     C           *IN25     IFEQ '0'
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         KADOHI
     C                     END
     C  N25                END
     C                     SETON                     01
     C                     END
     C*
     C*--- 引当実績 ---*
     C*
     C*-- 合成ＫＥＹ --*
     C           HIK       KLIST
     C                     KFLD           BMON
     C                     KFLD           KBAN
     C                     Z-ADD*ZERO     JISEK   90
     C                     Z-ADD*ZERO     WRK1    90
     C                     Z-ADD*ZERO     B       30
     C                     Z-ADD*ZERO     C       30
     C                     Z-ADD*ZERO     TENSU   30
     C           HIK       SETLLNCHNP01                  26
     C           1         DO   200       B
     C           HIK       READENCHNP01                  26
     C           *IN26     IFEQ '0'
     C                     ADD  P1SRYO    WRK1
     C                     ADD  1         TENSU
     C                     MOVE P1HIN1    HN1,B
     C                     MOVE P1HIN2    HN2,B
     C                     MOVE P1HIN3    HN3,B
     C                     END
     C  N26                END
     C           WRK1      DIV  KADOHI    JISEK
     C                     SUB  1         B
     C           1         DO   B         C
     C                     MOVE HN1,C     HNA     5
     C                     MOVE HN2,C     HNB     5
     C                     MOVE HN3,C     HNC     2
     C                     EXCPTDT
     C                     END
     OAH#WP21 E                DT
     O                         KBAN       3
     O                         HNA        8
     O                         HNB       13
     O                         HNC       15
     O                         BMON      19
     O                         JISEK     28
     O                         KOTEI     31
     O                         HINGOK    34
     O                         HAKGOK    38
     O                         KHIZ      46
     O                         MHIZ      54
     O                         TENSU     57
