     H            Y.
     F** AM#R97  *******************************************
     F* PLAN START END                                     *
     F*      ITS.        2015.06.24                        *
     F******************************************************
     FAM#WP64 UF  E           K        DISK
     FAM#WP96 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1FIXD  80
     C                     PARM           P1FIXT  60
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           KEY51     KLIST
     C                     KFLD           K1FIXD  80
     C                     KFLD           K1FIXT  60
      *
     C           KEY84     KLIST
     C                     KFLD           W4FIXD
     C                     KFLD           W4FIXT
     C                     KFLD           W4TRKB
     C                     KFLD           W4IAFB
     C                     KFLD           W4EXTR
      *
     C                     Z-ADDP1FIXD    K1FIXD  80
     C                     Z-ADDP1FIXT    K1FIXT  60
     C           KEY51     SETLLAM#WP641
     C           KEY51     READEAM#WP641                 80
     C           *IN80     DOWEQ'0'
     C           W4IAFB    IFNE *BLANK
     C                     EXSR #SB400
     C                     UPDATAM#WP641
     C                     ENDIF
     C           KEY51     READEAM#WP641                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *開始
     C           KEY84     SETLLAM#WP961
     C           KEY84     READEAM#WP961                 30
     C           *IN30     IFEQ '0'
     C                     Z-ADDW6DATE    W4PSTD
     C                     MOVELW6TIME    W4PSTT
     C                     ENDIF
      *終了
     C           KEY84     SETGTAM#WP961
     C           KEY84     REDPEAM#WP961                 30
     C           *IN30     IFEQ '0'
     C                     Z-ADDW6DATE    W4PEDD
     C                     MOVELW6TIME    W4PEDT
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
