     H            Y/
     F***************************************************
     F*   ASJ WASHER - QUICK SCHEDULE                     *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGDGPW65 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FAGDPL12 IF  E           K        DISK
     FALDPL24 IF  E           K        DISK
     FGDGWP65 UF  E           K        DISK                      A
     FGDGWP66 O   F      52            DISK
      *------------------------------------------------------------
     E                    DT1         4  8 0
     E                    DT2         4  8 0
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8YMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80A1YMD
     I                                        1   40A1KSYY
     I                                        5   60A1KSMM
     I                                        7   80A1KSDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           A1SHN1
     C                     KFLD           A1SHN2
     C                     KFLD           A1SHN3
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C           *INKE     WHEQ *ON
     C                     EXSR #WRT
     C                     MOVEL'99'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #WRT      BEGSR
      * LATEST WEDNESDAY
     C                     EXSR #DATE
      *
     C                     Z-ADDDT2,1     K@YMD
     C           K#AGD     SETLLALDPL24
     C           *IN90     DOUEQ*ON
     C                     READ ALDPL24                  90
     C           *IN90     IFEQ *OFF
     C           A1YMD     IFGT DT1,4
     C                     LEAVE
     C                     ENDIF
      *
     C           K#KEY     CHAINGDGWP65              95
     C           *IN95     IFEQ *ON
     C                     CLEARGDGWP651
     C                     MOVE A1SHN1    WPART1
     C                     MOVE A1SHN2    WPART2
     C                     MOVE A1SHN3    WPART3
     C                     ENDIF
      *
     C           A1USYS    IFNE *ZERO
     C                     Z-ADDA1USYS    @@QTY   50
     C                     ELSE
     C                     Z-ADDA1SSYS    @@QTY
     C                     ENDIF
      *
     C                     SELEC
     C           A1YMD     WHGE DT2,4
     C                     ADD  @@QTY     WQTY4
     C           A1YMD     WHGE DT2,3
     C                     ADD  @@QTY     WQTY3
     C           A1YMD     WHGE DT2,2
     C                     ADD  @@QTY     WQTY2
     C           A1YMD     WHGE DT2,1
     C                     ADD  @@QTY     WQTY1
     C                     ENDSL
      *
     C   95                WRITEGDGWP651
     C  N95                UPDATGDGWP651
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DATE
      *------------------------------------------------------
     C           #DATE     BEGSR
     C                     Z-ADD*ZERO     DT1
     C                     Z-ADD*ZERO     DT2
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8YOBI    IFEQ 2
     C                     ADD  1         X
     C                     Z-ADDF8YMD     DT1,X
     C                     ENDIF
     C           F8YOBI    IFEQ 3
     C           Y         ANDLTX
     C                     ADD  1         Y
     C                     Z-ADDF8YMD     DT2,Y
     C                     ENDIF
      *
     C           Y         IFEQ 4
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADT1
     C                     SORTADT2
      *
     C                     Z-ADDDT1,1     @MD11   40
     C                     Z-ADDDT1,2     @MD21   40
     C                     Z-ADDDT1,3     @MD31   40
     C                     Z-ADDDT1,4     @MD41   40
     C                     Z-ADDDT2,1     @MD12   40
     C                     Z-ADDDT2,2     @MD22   40
     C                     Z-ADDDT2,3     @MD32   40
     C                     Z-ADDDT2,4     @MD42   40
      *
     C                     EXCPT@ADD
      *
     C                     ENDSR
     OGDGWP66 E                @ADD
     O                         @MD12      5 '  /  '
     O                                    7 '-'
     O                         @MD11     13 '  /  '
     O                         @MD22     18 '  /  '
     O                                   20 '-'
     O                         @MD21     26 '  /  '
     O                         @MD32     31 '  /  '
     O                                   33 '-'
     O                         @MD31     39 '  /  '
     O                         @MD42     44 '  /  '
     O                                   46 '-'
     O                         @MD41     52 '  /  '
