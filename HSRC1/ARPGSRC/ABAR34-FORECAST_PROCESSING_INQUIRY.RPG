     H            Y.
     F** ABAR34 *************************************************************
     F*  FORECAST PROCESS INQUIRY                                           *
     F*                                                                     *
"    F* JW    11/16/20 ADD HSP  (0390-1013)                                 *
"    F* JW    06/16/21 ADD HSP  (0390-2050)                                 *
     F***********************************************************************
     FABAPW34 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FABBPL52 IF  E           K        DISK
     FABBPL61 IF  E           K        DISK
     FABFPL13 IF  E           K        DISK
     FABRPL17 IF  E           K        DISK
     E*****************************************************************
     E                    KEY     1   1 78
JW   E                    NAM     1 205 70
     I*****************************************************************
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(8)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     I*
     I            DS
     I                                        1  70 W@NAM
     I                                        1   4 W@NAM1
     I                                        5   5 W@NAM2
     I                                        6  35 W@NAM3
     I                                       36  36 W@NAM4
     I                                       37  44 W@NAM5
     I                                       45  45 W@NAM6
     I                                       46  60 W@NAM7
      *
     I            DS
     I                                        1   80ABKODT
     I                                        1   40ABKOYY
     I                                        5   60ABKOMM
     I                                        7   80ABKODD
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C* INITIAL ROUTINE
      *------------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     TIME           WWTIME
     C                     MOVE '01'      W@ID    2
     C                     EXSR #SET
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@CLBL  1
      *
     C           P@CL41    PLIST
     C                     PARM           P@AR41  1
     C*
     C                     ENDSR
      *------------------------------------------------------
     C* SET DATA
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD*ZERO     RRN1    40
JW   C*JW        1         DO   154       X       30
JWB  C           1         DO   205       IX      30
     C                     CLEARSFL01
     C                     MOVELNAM,IX    W@NAM
     C                     MOVELW@NAM1    S@NONY
     C                     MOVELW@NAM3    S@NONM
     C                     MOVELW@NAM5    S@CYCL
     C                     MOVELW@NAM7    S@METH
      *
     C                     SELEC
      * FORD
     C           S@NONY    WHEQ '5149'
     C           *HIVAL    SETGTABFPL13
     C                     READPABFPL13                  90
     C           *IN90     IFEQ *OFF
     C           20000000  ADD  FDDATE    S@UPDT
     C                     ENDIF
      * ANDROID
     C           S@NONY    WHEQ '2855'
     C           'AIW01'   SETGTABRPL17
     C                     READPABRPL17                  90
     C           *IN90     IFEQ *OFF
     C           20000000  ADD  FBDATE    S@UPDT
     C                     ENDIF
      *
     C           S@NONY    WHEQ *BLANK
     C*
     C                     OTHER
     C                     MOVELS@NONY    K@NONY  40
     C                     EXSR #DAT
      *
     C                     ENDSL
      *
     C                     MOVELS@NONY    H@NONY
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C* RECEIVED DATA
      *------------------------------------------------------
     C           #DAT      BEGSR
      * FROM PP50
     C           K@NONY    SETGTABBPL52
     C                     DO   *HIVAL
     C           K@NONY    REDPEABBPL52                  98
     C   98                LEAVE
      *
     C           BBFLG1    IFEQ 'D'                        DELETE FLAG
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDBBRCDT    S@UPDT
     C                     MOVEL'WEEKLY  'S@CYCL
      * METHOD
     C                     SELEC
     C           BBFLG2    WHEQ 'E'
     C                     MOVEL'EDI(830)'S@METH    P
     C           BBFLG2    WHEQ 'I'
     C                     MOVEL'IFS ENTR'S@METH    P
     C           BBFLG2    WHEQ 'S'
     C                     MOVEL'EXCEL   'S@METH    P
     C           BBFLG2    WHEQ 'W'
     C                     MOVEL'WEB     'S@METH    P
     C                     OTHER
     C                     MOVEL'UPLOAD  'S@METH    P
     C                     ENDSL
     C                     GOTO XDAT
     C                     ENDDO
      * FROM PP60
     C           K@NONY    SETGTABBPL61
     C                     DO   *HIVAL
     C           K@NONY    REDPEABBPL61                  97
     C   97                LEAVE
      *
     C           ABSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDABKODT    S@UPDT
     C                     MOVEL'MANUAL  'S@METH    P
     C                     MOVEL'MONTHLY 'S@CYCL
     C                     LEAVE
     C                     ENDDO
      *
     C           S@UPDT    IFEQ 0
     C                     MOVE *BLANK    S@METH
     C                     MOVE *BLANK    S@CYCL
     C                     ENDIF
      *
     C           XDAT      ENDSR
      *------------------------------------------------------
     C* 1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE KEY,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKY     WHEQ *ON
     C                     MOVEL'1'       P@AR41
     C                     CALL 'ABAR41'  P@CL41
     C                     OTHER
     C                     ENDSL
      *
     C                     ENDSR
     C***********************************************************
     C* S@NONY(1-4), S@NONM(6-35), S@CYCL(37-44), S@METH(46-60)
** KEY
F1:END
