     C                     MVR            @@MVR   50
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         @BOX
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDBASRYO    @SQTY
     C           @OQTY     SUB  @SQTY     @BQTY
     C           K#FCE     CHAINFCEPL01              95
     C           *IN95     IFEQ *OFF
     C           A2KASI    MULT BASRYO    @@WGHT  70
     C                     ADD  @@WGHT    @@TWGH  90
     C                     ELSE
     C                     ADD  1         @@TWGH
     C                     ENDIF
