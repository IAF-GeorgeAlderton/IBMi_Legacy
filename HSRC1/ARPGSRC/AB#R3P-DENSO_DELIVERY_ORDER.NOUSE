     C  N98                MOVE *ON       *IN98
     C                     ENDIF
     C                     WRITE@DTL
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN98     IFEQ *ON
     C           @@TWGH    DIV  100       @@KG    90H
IH   C           @@KG      MULT 2.2046    @WGHT     H
     C                     WRITE@TOT
