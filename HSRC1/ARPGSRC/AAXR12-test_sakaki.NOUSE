     H            Y.
     F** AAXR11 **************************************
     F* .. LTEST                                     *
     F* T-SAKAKI                        87.10.09     *
     F************************************** AAXR11 **
     FABHPP01 IF  E                    DISK
     FAAHPP01 IF  E                    DISK
     FAAXWP22 O   F     256            DISK
      *
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OSH        15  1               かんばん種類
     E                    OKO        15  3               工程
     E                    OHB        15 12               品番
      *
     I            DS
     I                                        1  12 CFHINA
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
      *
     C                     EXCPTOHED
      *
      *-----------------------------------
     C                     SETOF                     40
     C           1         SETLLABHPP01
     C                     DO   *HIVAL
     C                     READ ABHPP01                  40
     C           *IN40     IFEQ '0'
     C*
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           M6STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      *
     C           M6AKT1    IFEQ 'SB'
     C           M6AKT2    OREQ 'SB'
     C           M6AKT3    OREQ 'SB'
     C           M6AKT4    OREQ 'SB'
     C                     MOVELM6AKT1    WPRC1   3
     C                     MOVELM6AKT2    WPRC2   3
     C                     MOVELM6AKT3    WPRC3   3
     C                     MOVELM6AKT4    WPRC4   3
     C                     MOVELM6HIN1    W1SHN1  5
     C                     MOVELM6HIN2    W1SHN2  5
     C                     MOVELM6HIN3    W1SHN3  2
     C                     MOVEL'A'       WKIND   1
     C                     MOVELM6JBN2    W1LOC2  2
     C                     MOVELM6JBN3    W1LOC3  2
     C                     Z-ADDM6KTSU    W1SET   70
     C                     Z-ADDM6SYUY    W1QTY   70
     C                     Z-ADDM6KMAX    W1KAN   50
     C                     MOVELM6MTK2    PLOC2   2
     C                     MOVELM6MTK3    PLOC3   2
     C                     MOVELM6MKOT    PPRC    3
     C*
     C                     EXCPTODAT
     C*
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C  N40                ENDDO
      *-----------------------------------
      *-----------------------------------
     C                     SETOF                     40
     C           1         SETLLAAHPP01
     C                     DO   *HIVAL
     C                     READ AAHPP01                  40
     C           *IN40     IFEQ '0'
     C*
     C           L6SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           L6STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      *
     C           L6JOK1    IFEQ 'SB'
     C           L6JOK2    OREQ 'SB'
     C           L6JOK3    OREQ 'SB'
     C                     MOVELL6ATOK    WPRC1   3
     C                     MOVEL*BLANK    WPRC2   3
     C                     MOVEL*BLANK    WPRC3   3
     C                     MOVEL*BLANK    WPRC4   3
     C                     MOVELL6SHN1    W1SHN1  5
     C                     MOVELL6SHN2    W1SHN2  5
     C                     MOVELL6SHN3    W1SHN3  2
     C                     MOVEL'E'       WKIND   1
     C                     MOVELL6ATK2    W1LOC2  2
     C                     MOVELL6ATK3    W1LOC3  2
     C           L6KTSU    MULT 20        W1SET   70
     C                     Z-ADDL6SYOS    W1QTY   70
     C                     Z-ADDL6KMAX    W1KAN   50
     C                     MOVELL6MTK2    PLOC2   2
     C                     MOVELL6MTK3    PLOC3   2
     C                     MOVELL6MAEK    PPRC    3
     C*
     C                     EXCPTODAT
     C*
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C  N40                ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *
     OAAXWP22 E                OHED
     O                                      'PART #,'
     O                                      'KANBAN KIND,'
     O                                      'LOCATION,'
     O                                      'SETTING #/M,'
     O                                      'QPC,'
     O                                      '# OF KANBAN,'
     O                                      '1ST PROC.,'
     O                                      '2ND PROC.,'
     O                                      '3RD PROC.,'
     O                                      '4TH PROC.,'
     O                                      'PRE PROCESS,'
     O                                      'PRE LOCATION,'
      *
     OAAXWP22 E                ODAT
      *
     O                         W1SHN1
     O                                      '-'
     O                         W1SHN2
     O                                      '-'
     O                         W1SHN3
     O                                      ','
     O                         WKIND
     O                                      ',="'
     O                         W1LOC2
     O                                      '-'
     O                         W1LOC3
     O                                      '",'
     O                         W1SET
     O                                      ','
     O                         W1QTY
     O                                      ','
     O                         W1KAN
     O                                      ','
     O                         WPRC1
     O                                      ','
     O                         WPRC2
     O                                      ','
     O                         WPRC3
     O                                      ','
     O                         WPRC4
     O                                      ','
