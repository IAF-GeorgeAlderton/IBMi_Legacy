     C           #SUB1     BEGSR
     C                     SETOF                     30
     C                     MOVE *BLANK    @KNM
     C           #KEY4     CHAINGCMPL311             30
     C           *IN30     IFEQ '0'
     C           T3SKJY    IFEQ 'D'
     C           T3SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
