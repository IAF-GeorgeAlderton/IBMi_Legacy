     C           L9STI1    CHAINAABPL011             30
     C           *IN30     IFEQ '0'
     C           A4SKJY    IFEQ 'D'
     C           A4SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
      *
     C           *IN30     IFEQ '0'
     C                     MOVELA4SETN    @STNM
     C*                    BITOF'01234567'BITC
     C*                    BITON'4567'    BITC
     C                     END
     C                     ENDSR
      *
     C*****************************************************
     C*  SUB    部門別L.T uﾇjｰ (メッキ部門)
     C*****************************************************
     C           #SUB3     BEGSR
     C                     MOVE 'B'       @SURI   1
     C                     MOVE *BLANK    @KONM
     C                     MOVE *BLANK    #YOB
     C                     Z-ADD0         WSKRU
     C                     Z-ADD0         #TTM
      *
     C                     SETOF                     2330
     C           #KEY7     CHAINGCKPL211             30
     C           *IN30     IFEQ '0'
     C           T2SKJY    IFEQ 'D'
     C           T2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVELT2NAMN    @KONM
     C                     Z-ADD1         A       10
     C                     Z-ADD0         B       10
     C           1         DO   5         A
     C           #YBI,A    IFEQ '1'
     C                     ADD  1         B
     C                     MOVE TBL1,A    #YOB,B
     C                     END
     C                     END
     C                     Z-ADDT2SKRU    WSKRU
     C           WSKRU     COMP 0                    2323
     C                     Z-ADD#TTI      #TTM
     C                     END
     C           @009      ENDSR
      *
     C*****************************************************
