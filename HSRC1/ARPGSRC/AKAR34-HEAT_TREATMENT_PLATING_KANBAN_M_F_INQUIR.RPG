     C           1         DO   2         X
     C           JK1,X     IFNE *BLANK
     C                     SETOF                     30
     C                     MOVE JK1,X     WJKN    2
     C           #KEY11    CHAINAAAPL011             30
     C           *IN30     IFEQ '0'
     C           A5SKJY    IFEQ 'D'
     C           A5SKHZ    IFLE *DATE
     C                     SETON                     30
     C                     END
     C                     END
     C                     END
     C  N30                MOVELA5JOKM    JM1,X
     C                     END
     C                     END
     C                     ENDSR
