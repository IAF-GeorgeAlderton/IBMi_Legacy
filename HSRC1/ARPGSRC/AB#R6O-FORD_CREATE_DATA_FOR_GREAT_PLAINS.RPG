     H            Y.
     F** AB#R6O ********************************************
     F*     PRINT EDI REMITANCE ADVICE FOR FORD            *
     F*                   FROM FORD                        *
     F* TCHK1 03/28/06 CREATE                              *
     F* TCHK2 10/02/08 RE-MAKE                             *
     F******************************************************
     FAB#PW6O CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                              KINFDS @INFDS
     FAB#PL6R IF  E           K        DISK
     FAB#PP6Q IF  E           K        DISK
     FAB#PP6P IF  E           K        DISK
     FABF9P01 IF  E           K        DISK
     FAB#PL1C IF  E           K        DISK
     FAB#PL76 IF  E           K        DISK
     FAB#PP6S O   E                    DISK                           UC
     FAB#PP6T O   E                    DISK                           UC
      **********************************************************
     E                    AR1        20  1
     E                    AR2        10  1
     E                    CMD     1   2 70
     E                    ERR     1   1 70
      **********************************************************
     I            DS
     I                                        1   80BADATE
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80PUDATE
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     C****************************************************
     C                     EXSR @SET1
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVE *ON       *IN56
     C                     WRITEDSP99
     C                     Z-ADDW@RRN1    #RCNO1
     C                     EXFMTCTL010
     C                     MOVE *OFF      *IN56                       C
     C                     MOVEL*BLANK    D@ERR
     C*
     C   KA                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W@RRN1
     C                     END
     C*
     C   KE                EXSR @WRT1
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C****************************************************
     C           @SET1     BEGSR
     C*
     C                     MOVE *ON       *IN57
     C                     WRITECTL010
     C                     MOVE *OFF      *IN57
     C                     Z-ADD*ZERO     RRN1    40
     C*
     C           K#KEY1    SETLLAB#PL6R
     C*
     C                     DO   *HIVAL
     C*
     C           K#KEY1    READEAB#PL6R                  98
     C   98                LEAVE
     C*
     C                     CLEARSFL010
     C*
     C                     MOVELALRENO    S@RENO
     C                     Z-ADDALMAMT    S@MAMT
     C                     ADD  1         RRN1
     C*
     C                     WRITESFL010
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL010
     C                     MOVEL*ON       *IN41
     C                     Z-ADD1         RRN1
     C                     WRITESFL010
     C                     MOVEL*OFF      *IN41
     C                     MOVELERR,1     D@ERR
     C                     END
     C*
     C                     Z-ADD1         W@RRN1  40
     C*
     C                     ENDSR
     C****************************************************
     C           @WRT1     BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL010               97
     C   97                LEAVE
     C*
     C           S@SLCT    IFEQ *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVELCMD,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     MOVELCMD,2     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#PP6S
     C                     OPEN AB#PP6T
     C*
     C           K#KEY2    CHAINAB#PL6R              96
     C   96                LEAVE
     C*
     C                     CLEARAB#PP6S1
     C                     MOVELALRENO    ASRENO
     C                     MOVELALCNM1    ASCNM1
     C                     MOVELALCNM2    ASCNM2
     C                     Z-ADDALMAMT    ASMAMT
     C                     Z-ADDALPRDT    ASPRDT
     C                     Z-ADDALPRTM    ASPRTM
     C                     WRITEAB#PP6S1
      *
     C           K#KEY     SETLLAB#PP6P
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAB#PP6P                  90
     C           *IN90     IFEQ *OFF
     C                     CLEARAB#PP6T1
     C                     MOVELAPRENO    ATREF1
     C                     MOVELAPCNM1    ATCNM1
     C                     MOVELAPCNM2    ATCNM2
     C                     Z-ADDAPADAT    ATRMDT
     C                     MOVELAPADSC    ATNOTE
     C                     MOVELAPREFN    ATREF2
     C                     Z-ADDAPAJST    ATRM04
     C                     Z-ADDAPPRDT    ATPRDT
     C                     Z-ADDAPPRTM    ATPRTM
     C                     WRITEAB#PP6T1
     C                     END
     C                     ENDDO
     C*
     C                     Z-ADD*ZERO     @@AMT  154
     C*
     C           K#KEY     SETLLAB#PP6Q
     C                     DO   *HIVAL
     C           K#KEY     READEAB#PP6Q                  90
     C   90                LEAVE
     C           APIQTY    IFEQ *ZERO
     C                     ITER
     C                     END
     C*
     C                     CLEARAB#PP6T1
     C                     MOVELAPRENO    ATREF1
     C                     MOVELAPCNM1    ATCNM1
     C                     MOVELAPCNM2    ATCNM2
     C                     Z-ADDAFDTM2    ATRMDT
     C*
     C           APRM02    IFNE *BLANK
     C                     MOVELAPRM02    ATREF2
     C                     ELSE
     C                     MOVELAPREF2    ATREF2
     C                     END
     C*
     C           APPART    IFNE *BLANK
     C                     MOVELAPPART    ATNOTE
     C                     ELSE
     C                     MOVELAPNTE2    ATNOTE
     C                     ENDIF
      *
     C                     MOVELAPPLNT    ATPLNT
     C           APPLNT    CAT  'A':0     W@5     5
     C           W@5       IFEQ 'AP19A'
     C                     MOVE 'AP10A'   W@5
     C                     ENDIF
     C           W@5       CHAINABF9P01              95
     C           *IN95     IFEQ *OFF
     C                     MOVELF9DELY    ATNONY
     C                     ELSE
     C                     MOVELAPPONO    @PONO  10
     C           @PONO     IFNE '11111'
     C           @PONO     SETLLAB#PL1C
     C           *IN96     DOUEQ*ON
     C           @PONO     READEAB#PL1C                  96
     C           *IN96     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     MOVELBANONY    ATNONY
     C                     Z-ADDBADATE    ATSHDT
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C           ATNONY    IFEQ *BLANK
     C                     MOVELATREF2    @9      9
     C           @9        CHAINAB#PL76              96
     C           *IN96     IFEQ *OFF
     C                     MOVELPUNONY    ATNONY
     C                     Z-ADDPUDATE    ATSHDT
     C                     END
     C                     END
     C                     END
      *
     C                     MOVELAPPONO    ATINVN
     C           APRM04    IFEQ *ZERO
     C           APIQTY    MULT APUNIT    ATRM04
     C                     ELSE
     C                     Z-ADDAPRM04    ATRM04
     C                     END
     C                     Z-ADDAPIQTY    ATIQTY
     C                     Z-ADDAPUNIT    ATUNIT
     C                     Z-ADDAPPRDT    ATPRDT
     C                     Z-ADDAPPRTM    ATPRTM
     C*
     C                     WRITEAB#PP6T1
     C*
     C                     ENDDO
     C*
     C                     CLOSEAB#PP6S
     C                     CLOSEAB#PP6T
     C*
     C                     MOVEL*BLANK    S@SLCT
     C                     UPDATSFL010
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*--------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@YMD   80
     C                     PARM           P@TIM   60
     C*
     C                     Z-ADDP@YMD     K@DATE  80
     C                     Z-ADDP@TIM     K@TIME  60
     C                     TIME           @TIME   60
     C           K#KEY1    KLIST
     C                     KFLD           K@DATE
     C                     KFLD           K@TIME
     C           K#KEY2    KLIST
     C                     KFLD           K@DATE
     C                     KFLD           K@TIME
     C                     KFLD           S@RENO
     C           K#KEY     KLIST
     C                     KFLD           ALPRDT
     C                     KFLD           ALPRTM
     C                     KFLD           ALRENO
     C                     KFLD           ALCNM1
     C*
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C                     Z-ADD70        P@LEN
     C*
     C                     ENDSR
** CMD
CLRPFM AB#PP6S
CLRPFM AB#PP6T
** ERR
NO DATA!
