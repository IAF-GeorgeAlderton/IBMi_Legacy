     H            Y.
     F**************************************************************************
     F*  PROGRAM    : TRANSFERT DIE MASTER DATA TO IFS WORK FILE               *
     F*  WRITTEN    : 04/23/2021                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   : READ GCQWP61 AND COPY TO GCQWP62                         *
     F**************************************************************************
     FGCQWP61 IF  E                    DISK
     FGCQWP62 O   E                    DISK
      *------------------------------------------------------------
     E                    CMM     1   1  1
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *******************************************************
      *                    MAIN ROUTINE
      *******************************************************
     C                     MOVE 'Y'       FIRST   1
      *
     C                     DO   *HIVAL
     C                     READ GCQWP61                  98
     C   98                LEAVE
      *
     C           FIRST     IFEQ 'Y'
     C                     EXSR #HDR1
     C                     MOVE 'N'       FIRST
     C                     ENDIF
      *
     C                     EXSR #DTL1
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  HEADER
      *------------------------------------------------------
     C           #HDR1     BEGSR
      *
     C                     CLEARGCQWP62R
     C                     MOVEL'DIE#_1  'G2DIE1
     C                     MOVEL'DIE#_2  'G2DIE2
     C                     MOVEL'DIE#_3  'G2DIE3
     C                     MOVEL'LOC1    'G2LC1
     C                     MOVEL'LOC2    'G2LC2
     C                     MOVEL'LOC3    'G2LC3
     C                     MOVEL'LOC4    'G2LC4
     C                     MOVEL'LCC5    'G2LC5
     C                     MOVEL'CHG_DATE'G2CDAT
     C                     MOVEL'DELIV#  'G2NONY
     C                     MOVEL'MONTH_QT'G2MQTY
     C                     MOVEL'MAX     'G2MAX
     C                     MOVEL'ACCOM_QT'G2ACCM
      *
     C                     WRITEGCQWP62R
      *
     C                     ENDSR
      *------------------------------------------------------
      *  DETAIL
      *------------------------------------------------------
     C           #DTL1     BEGSR
      *
     C                     CLEARGCQWP62R
     C                     MOVELTWKAT1    LTR9    9 P
     C                     MOVELCMM,1     G2DIE1
     C                     MOVE LTR9      G2DIE1
      *
     C                     MOVELTWKAT2    LTR9      P
     C                     MOVELCMM,1     G2DIE2
     C                     MOVE LTR9      G2DIE2
      *
     C                     MOVELTWKAT3    LTR9      P
     C                     MOVELCMM,1     G2DIE3
     C                     MOVE LTR9      G2DIE3
      *
     C                     MOVELTWTKR1    G2LC1
     C                     MOVELTWTKR2    G2LC2
      *
     C                     MOVELTWTKR3    LTR9      P
     C                     MOVELCMM,1     G2LC3
     C                     MOVE LTR9      G2LC3
      *
     C                     MOVELTWTKR4    G2LC4
     C                     MOVELTWTKR5    G2LC5
      *
     C                     MOVELTWKIHZ    G2CDAT
     C                     MOVELTWKOCD    G2NONY
      *
     C                     Z-ADDTWSRYO    $IN
     C                     CALL 'UTLR64'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     G2MQTY
      *
     C                     MOVELTWKMAX    G2MAX
     C                     MOVELTWSYOS    G2ACCM
      *
     C                     WRITEGCQWP62R
      *
     C                     ENDSR
** CNN
'
