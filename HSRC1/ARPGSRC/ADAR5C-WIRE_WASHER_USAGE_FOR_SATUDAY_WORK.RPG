     H            Y.
     F** ADAR5C ************************************
     F* WIRE/WASHER USAGE FOR SATUDAY WORK                *
TCH26F* WASHER DIV 0 PROBLEM FIX                          *
TCHK1F* #RED1  DIV 0 PROBLEM FIX                          *
TCHK2F* TCHK1 01/01/08 CHG 0002 TO 8990                   *
     F************************************ ADAR5C **
     FADATL62 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FIZAPL01 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FADAWP61 UF  E           K        DISK                      A
     FADAWP62 UF  E           K        DISK                      A
     FADAPR5C O   E             70     PRINTER
     FADAPR5D O   E             71     PRINTER
      *---------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------------
     C                     EXSR #WRT
     C                     EXSR #RED1
     C                     EXSR #RED2
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PARM2   8
     C                     PARM           PCHK1   1
     C                     PARM           PCHK2   1
     C                     MOVE PARM2     @YMD
      *
     C           K#FCE     KLIST
     C                     KFLD           DAHIN1
     C                     KFLD           DAHIN2
     C                     KFLD           DAHIN3
     C           K#W61     KLIST
     C                     KFLD           A2ZANM
     C                     KFLD           A2KAZI
     C           K#W62     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
      *
     C                     MOVE *BLANK    PCHK1
     C                     MOVE *BLANK    PCHK2
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #WRT      BEGSR
      *
     C           @YMD      SETLLADATL62
     C           *IN80     DOUEQ*ON
     C           @YMD      READEADATL62                  80
     C           *IN80     IFEQ *OFF
      *
     C           K#FCE     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
      ** WIRE
     C           DASRYO    MULT DASYUY    @QTY    90
     C                     EXSR #WIRE
      ** WASHER
     C                     EXSR #WASH
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #WIRE     BEGSR
      *
     C           A2ZANM    IFNE *BLANK
      *
     C           K#W61     SETLLIZAPL01
     C           *IN95     DOUEQ*ON
     C           K#W61     READEIZAPL01                  95
     C           *IN95     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSTYY    ANDEQ9999
TCHK2C*          ZCKAKE    ANDEQ0002
TCHK2C           ZCKAKE    ANDEQ8990
      *
     C           K#W61     CHAINADAWP61              91
     C           *IN91     IFEQ *ON
     C                     CLEARADAWP611
     C                     MOVE A2ZANM    D6ZAIS
     C                     Z-ADDA2KAZI    D6ZAIK
     C                     Z-ADDZCTKJR    D6WGCL
     C                     MOVELZCKAKE    D6SUPL
     C                     ENDIF
     C           A2SOZI    MULT @QTY      @@WEIG 112
     C                     ADD  @@WEIG    D6WEGH
     C  N91                UPDATADAWP611
     C   91                WRITEADAWP611
     C                     MOVE '1'       PCHK1
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #WASH     BEGSR
      *
     C           A21HB5    IFNE *BLANK
     C                     MOVE A21HB5    K@PRT1
     C                     MOVE A22HB5    K@PRT2
     C                     MOVE A23HB2    K@PRT3
     C                     Z-ADDA2SYK1    @USE    10
     C                     EXSR #WASH1
     C                     ENDIF
      *
     C           A24HB5    IFNE *BLANK
     C                     MOVE A24HB5    K@PRT1
     C                     MOVE A25HB5    K@PRT2
     C                     MOVE A26HB2    K@PRT3
     C                     Z-ADDA2SYK2    @USE    10
     C                     EXSR #WASH1
     C                     ENDIF
      *
     C           A27HB5    IFNE *BLANK
     C                     MOVE A27HB5    K@PRT1
     C                     MOVE A28HB5    K@PRT2
     C                     MOVE A29HB2    K@PRT3
     C                     Z-ADDA2SYK3    @USE    10
     C                     EXSR #WASH1
     C                     ENDIF
      *
     C           A210H5    IFNE *BLANK
     C                     MOVE A210H5    K@PRT1
     C                     MOVE A211H5    K@PRT2
     C                     MOVE A212H2    K@PRT3
     C                     Z-ADDA2SYK4    @USE    10
     C                     EXSR #WASH1
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #WASH1    BEGSR
      *
     C           K#W62     CHAINADAWP62              91
     C           *IN91     IFEQ *ON
     C                     CLEARADAWP621
     C                     MOVE K@PRT1    D6HIN1
     C                     MOVE K@PRT2    D6HIN2
     C                     MOVE K@PRT3    D6HIN3
     C           K#W62     SETLLAKBPL04
     C           *IN92     DOUEQ*ON
     C           K#W62     READEAKBPL04                  92
     C           *IN92     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STYY    ANDEQ9999
     C                     Z-ADDL1SYOS    D6SYOS
     C                     MOVELL1BMON    D6SUPL
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
TCH26C           D6SYOS    IFEQ *ZERO
   | C                     Z-ADD0         D6SUPL
     C                     Z-ADDA2SSYS    D6SYOS
     C           D6SYOS    IFEQ *ZERO
     C                     Z-ADD1         D6SYOS
   | C                     ENDIF
TCH26C                     ENDIF
      *
     C                     ENDIF
     C           @QTY      MULT @USE      @UQTY   90
     C                     ADD  @UQTY     D6QNTY
     C   91                WRITEADAWP621
     C  N91                UPDATADAWP621
     C                     MOVE '1'       PCHK2
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #RED1     BEGSR
      *
     C                     CLOSEADAWP61
     C                     OPEN ADAWP61
     C                     MOVE *OFF      *IN98
     C           *LOVAL    SETLLADAWP61
     C           *IN90     DOUEQ*ON
     C                     READ ADAWP61                  90
     C           *IN90     IFEQ *OFF
     C           *IN98     IFEQ *OFF
     C           *IN70     OREQ *ON
     C                     WRITE@HED1
     C                     ENDIF
     C   70                MOVE *OFF      *IN70
     C  N98                MOVE *ON       *IN98
      *
     C           D6SUPL    CHAINFGBPL011             20
     C           *IN20     IFEQ '0'
     C           B2SKJY    ANDEQ*BLANK
     C                     MOVELB2SMEI    @SUPL
     C                     END
      *
     C           D6WEGH    DIV  1000      @WIGHT    H
     C                     ADD  @WIGHT    @TOTQ
TCHK1C           D6WGCL    IFNE *ZERO
     C           @WIGHT    DIV  D6WGCL    @COILS
     C                     MVR            @MVR    50
     C           @MVR      IFGT *ZERO
     C                     ADD  1         @COILS
     C                     ENDIF
TCHK1C                     ELSE
TCHK1C                     Z-ADD1         @COILS
TCHK1C                     END
      *
     C                     ADD  @COILS    @TOTC
      *
     C                     WRITE@DETL
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN98     IFEQ *ON
     C                     WRITE@TOTL
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #RED2     BEGSR
      *
     C                     CLOSEADAWP62
     C                     OPEN ADAWP62
     C                     MOVE *OFF      *IN98
     C           *LOVAL    SETLLADAWP62
     C           *IN90     DOUEQ*ON
     C                     READ ADAWP62                  90
     C           *IN90     IFEQ *OFF
     C           *IN98     IFEQ *OFF
     C           *IN71     OREQ *ON
     C                     WRITE@HED2
     C                     ENDIF
     C   71                MOVE *OFF      *IN71
     C  N98                MOVE *ON       *IN98
      *
     C           D6SUPL    CHAINFGBPL011             20
     C           *IN20     IFEQ '0'
     C           B2SKJY    ANDEQ*BLANK
     C                     MOVELB2SMEI    @SUPL
     C                     END
      *
     C                     ADD  D6QNTY    @TOTQ2
     C           D6QNTY    DIV  D6SYOS    @BOX
     C                     MVR            @MVR    50
     C           @MVR      IFGT *ZERO
     C                     ADD  1         @BOX
     C                     ENDIF
     C                     ADD  @BOX      @TOTB2
     C                     WRITE@DETL2
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN98     IFEQ *ON
     C                     WRITE@TOTL2
     C                     ENDIF
      *
     C                     ENDSR
