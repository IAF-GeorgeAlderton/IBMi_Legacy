     C           *ENTRY    PLIST
     C                     PARM           US     10
      *------*
      * KEYS *
      *------*
      *
     C           KEY2      KLIST
     C                     KFLD           SHN1
     C                     KFLD           SHN2
     C                     KFLD           SHN3
     C                     KFLD           LOT
      *
     C           KEY3      KLIST
     C                     KFLD           SHN1
     C                     KFLD           SHN2
     C                     KFLD           SHN3
     C           KEY4      KLIST
     C                     KFLD           ZETI
     C                     KFLD           LOT
     C                     KFLD           PAGN
      *
      *****************************************
      *---------------------------------------*
      *<<<<<    ALDR51   EXECUSION       >>>>>*
      *---------------------------------------*
      *****************************************
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     Z-ADD0         CNT     50
      *
     C                     EXSR NAMSUB
      *
     C                     MOVE *BLANK    PUSNM  15
     C                     CALL 'APLR00'
     C                     PARM           US
     C                     PARM           PUSNM
     C                     MOVELPUSNM     TANNAM  8
      *
     C                     WRITEALDPR501
     C                     GOTO SKP
     C                     ENDIF
      *
     C           *IN95     IFEQ '1'
     C                     WRITEALDPR501
     C                     SETOF                     95
     C                     ENDIF
     C           SKP       TAG
      *
     C                     Z-ADDSYHZ      WWYMD
     C                     SUB  6         WWMM
     C           WWMM      IFLE 0
     C                     ADD  12        WWMM
     C                     SUB  1         WWYY
     C                     ENDIF
     C                     SETOF                     52
     C                     MOVE *BLANK    OZBR1
     C                     MOVE *BLANK    OZBR2
     C                     Z-ADD*ZERO     @@DAT   80
      *
     C           KEY2      SETLLAJSPL261
     C                     DO   *HIVAL
     C                     SETOF                     50
     C           KEY2      READEAJSPL261                 50
     C           *IN50     IFEQ '0'
     C           J2YMD     ANDGTWWYMD
      *
     C           J2SKJY    IFEQ 'D'
     C           J2SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETOF                     51
     C           PAGN      LOKUPHPG1                     51
     C           *IN51     IFEQ '1'
     C***                  SETON                     5052
     C                     SETON                     52
     C           J2YMD     IFGT @@DAT
     C           J2YMD     ANDLESYHZ
     C                     MOVE J2ZBR1    OZBR1
     C                     MOVE J2ZBR2    OZBR2
     C                     ENDIF
      *
     C                     Z-ADDJ2YMD     @@DAT
     C                     END
      *
     C                     END
     C                     END
     C  N50                END
      *
     C           *IN52     IFEQ '0'
      *
     C           KEY2      SETLLAJSPL661
     C                     DO   *HIVAL
     C                     SETOF                     50
     C           KEY2      READEAJSPL661                 50
     C           *IN50     IFEQ '0'
     C           J6YMD     ANDGTWWYMD
      *
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETOF                     51
     C           PAGN      LOKUPHPG2                     51
     C           *IN51     IFEQ '1'
     C           J6YMD     IFGT @@DAT
     C           J6YMD     ANDLESYHZ
     C*******              SETON                     50
     C                     MOVE J6ZBR1    OZBR1
     C                     MOVE J6ZBR2    OZBR2
     C                     ENDIF
      *
     C                     END
      *
     C                     Z-ADDJ6YMD     @@DAT
     C                     END
     C                     END
     C  N50                END
      *
     C                     END
      *
     C                     Z-ADDSYHZ      OHIZ
     C                     Z-ADDSYJK      OJIKN
     C                     MOVE SHN1      OSHN1
     C                     MOVE SHN2      OSHN2
     C                     MOVE SHN3      OSHN3
     C                     MOVE UHN1      OUHN1
     C                     MOVE UHN2      OUHN2
     C                     MOVE UHN3      OUHN3
     C                     MOVE UHN4      OUHN4
     C                     MOVE ZETI      OZETI
     C                     MOVE LOTN      OLOTN
     C                     Z-ADDSSYS      OINQT
     C                     Z-ADDUSYS      OUSQT
     C                     MOVE TKR1      OTKR1
     C                     MOVE TKR2      OTKR2
     C                     MOVE TKR3      OTKR3
     C                     MOVE TKR4      OTKR4
     C                     MOVE UPAG      OUPAG
      *
     C           FLAG      IFEQ '*'
     C                     SETON                     70
     C                     MOVE LOT2      OLOT2
     C                     ELSE
     C                     SETOF                     70
     C                     MOVE PAGN      OPAGN
     C                     END
      * 3 BOND
     C                     Z-ADD2255      @@SUPP  40
     C                     Z-ADD*ZERO     X       20
     C           KEY3      CHAINAAMPL11              90
     C           *IN90     IFEQ *OFF
     C           @@SUPP    LOKUPBMN                      98
     C           *IN98     IFEQ *ON
     C           KEY4      SETLLAFAPL85
     C           *IN98     DOUEQ*ON
     C           KEY4      READEAFAPL85                  98
     C           *IN98     IFEQ *OFF
     C                     ADD  1         X
     C           X         IFEQ 1
     C                     MOVELA0LTNO    OZBR1
     C                     ELSE
     C                     MOVELA0LTNO    OZBR2
     C                     ENDIF
     C           X         IFEQ 2
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     WRITEALDPR502
     C           CNT       ADD  1         CNT
      *
     CLR                   Z-ADDCNT       OCNT
     CLR                   WRITEALDPR503
      *
      *--------*
      * NAMSUB *
      *--------*
     C           NAMSUB    BEGSR
      *
     C                     ENDSR
