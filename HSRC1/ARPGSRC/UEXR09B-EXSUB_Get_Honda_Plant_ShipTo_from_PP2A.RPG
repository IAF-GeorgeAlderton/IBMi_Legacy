     H            Y.
     F** UEXR09B *******************************************
     F*  PROGRAM: GET HONDA PLANT/SHIPTO FROM AB#PP2A      *
     F*  WRITTEN: JW (SRA) 2025.04.29                      *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR09B'
     F*                    PARM           $NONY   4
     F*                    PARM           $ODRN  10
     F*                    PARM           $PLNT   3
     F*                    PARM           $SHCD  10
     F*  IN  $NONY :  4A DELV#
     F*      $ODRN : 10A ORDER#
     F*  OUT $PLNT :  3A PLANT CODE
     F*      $SHCD : 10A SHIP TO CODE
     F******************************************************
     FAB#PL2ACIF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#2A      SETLLAB#PL2AC
     C                     DO   *HIVAL
     C           KNONY     READEAB#PL2AC                 88
     C   88                LEAVE
      * END
     C                     MOVELACODRN    AODRN6  6
     C           AODRN6    IFNE $ODRN6
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           ACUPID    IFNE '3'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELACPLNT    $PLNT
     C                     MOVELACSHCD    $SHCD
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4        IN
     C                     PARM           $ODRN  10        "
     C                     PARM           $PLNT   3        OUT
     C                     PARM           $SHCD  10        "
      *
     C           K#2A      KLIST
     C                     KFLD           KNONY   40
     C                     KFLD           KODRN  20
      *
     C                     MOVEL$NONY     KNONY
     C                     MOVEL$ODRN     $ODRN6  6
     C                     MOVEL$ODRN6    KODRN     P
     C                     MOVE *BLANK    $PLNT
     C                     MOVE *BLANK    $SHCD
     C                     TIME           SDATE
      *
     C                     ENDSR
