     F********************************************* MCER46 ***
     FMCEWP46 IF  F     128            DISK
     FFGBPL01 IF  E           K        DISK
     FRGAPL11 IF  E           K        DISK
     FMCEPR46 O   E             55     PRINTER
     E                    TBL1    1   2  1   TBL2   10   ﾎﾞ]ﾓbjbﾎﾟ
     E                    TBL3    1   3  1   TBL4   12   gﾒfd hﾎﾞ]
     IMCEWP46 AA  01
     I                                        1   5 T1HIN1
     I                                        6  10 T1HIN2
     I                                       11  12 T1HIN3
     I                                       13  21 T1SPEN
     I                                       22  22 T1HKB1
     I                                       23  23 T1HKB2
     I                                       24  270T1TOKU
     I                                       28  28 T1KOJO
     I                                       29  32 T1UKER
