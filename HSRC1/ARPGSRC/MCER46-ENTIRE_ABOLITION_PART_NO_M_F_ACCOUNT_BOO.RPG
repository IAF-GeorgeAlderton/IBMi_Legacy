     C           *ENTRY    PLIST
     C                     PARM           PARM1   8        *ﾆｬcib fbﾆﾍﾞ
     C                     PARM           PARM2   8        *ﾆｬcib ﾆｬcﾒｭcﾍﾞ
     C                     PARM           PARM3   1        *ﾎﾞ]ﾓb jbﾎﾟ
     C                     PARM           PARM4  10        *ﾏｰﾅﾞｰ
     C*
     C* ﾆｭgﾆｭﾒ
     C*
     C                     MOVE *BLANK    FSW1    1
     C                     SETOF                     81
     C                     DO   *HIVAL
     C                     READ MCEWP46                  81
     C           *IN81     IFEQ '0'
     C*
     C           FSW1      IFEQ *BLANK
     C                     SETON                       20
     C           PARM1     IFEQ '00000000'
     C           PARM2     ANDEQ'99999999'
     C                     SETOF                       20
     C                     END
     C                     MOVELPARM1     @SDAY
     C                     MOVELPARM2     @EDAY
     C                     SETOF                     82
     C                     MOVE *BLANK    @NAME1
     C           PARM4     CHAINRGAPL111             82
     C           *IN82     IFEQ '0'
     C                     MOVELJ8NAME    @NAME1
     C                     END
     C                     MOVE *BLANK    @TYPE
     C                     SETOF                     30
     C                     Z-ADD1         X       10
     C           PARM3     LOKUPTBL1,X                   30
     C   30                MOVE TBL2,X    @TYPE
     C                     MOVE 1         @PAGE
     C                     WRITEMCEPR461
     C                     MOVE '*'       FSW1
     C                     END
     C*
     C                     SETOF                       82
     C                     MOVE *BLANK    @TONM
     C           T1TOKU    CHAINFGBPL011             82
     C           *IN82     IFEQ '0'
     C                     MOVELB2SMEI    @TONM
     C                     MOVEL'-'       @TONM
     C                     END
     C                     MOVE *BLANK    H1
     C                     MOVE *BLANK    H2
     C                     MOVE T1HIN1    @HIN1
     C                     MOVE T1HIN2    @HIN2
     C                     MOVE T1HIN3    @HIN3
     C           @HIN2     IFEQ *BLANK
     C                     ELSE
     C                     MOVE '-'       H1
     C                     END
     C           @HIN3     IFEQ *BLANK
     C                     ELSE
     C                     MOVE '-'       H2
     C                     END
     C                     MOVE *BLANK    @KRNM
     C                     MOVE T1KKBN    @KKBN
     C                     Z-ADD1         A       10
     C                     SETOF                     30
     C           T1KKBN    LOKUPTBL3,A                   30
     C   30                MOVE TBL4,A    @KRNM
     C                     MOVE T1TOKU    @TOKU
     C                     MOVE T1SPEN    @SPEN
     C                     MOVE T1HKB1    @HKB1
     C                     MOVE T1HKB2    @HKB2
     C                     MOVE T1KOJO    @KOJO   1
     C                     MOVE T1UKER    @UKER   4
     C                     MOVE T1ZIKO    @ZIKO
     C                     MOVE T1HAKO    @HAKO
     C                     MOVE T1JRYO    @JRYO
     C                     MOVE T1KRYY    @KRYY
     C                     MOVE T1KRMM    @KRMM
     C                     MOVE T1KRDD    @KRDD
     C                     MOVE T1UKYY    @UKYY
     C                     MOVE T1UKMM    @UKMM
     C                     MOVE T1UKDD    @UKDD
     C                     MOVE T1TANT    @TANT
     C                     MOVE T1BKO1    @BKO1
     C                     WRITEMCEPR462
     C                     ADD  1         WKENS1  50
     C                     ADD  1         CTR     50
     C*
     C           CTR       IFGT 16
     C                     ADD  1         @PAGE
     C                     WRITEMCEPR461
     C                     Z-ADD0         CTR
     C                     END
     C                     END
     C  N81                END
     C*
     C           *IN81     IFEQ '1'
     C                     MOVE WKENS1    @KENS1
     C                     WRITEMCEPR463
     C                     END
     C*
     C                     SETON                       LR
     C   LR                RETRN
