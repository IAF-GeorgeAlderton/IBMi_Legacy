     FBTBPP41 UF  E           K        DISK                      A
     C           *ENTRY    PLIST
     C                     PARM           P@SIRE  4
     C                     PARM           P@UKEI  4
     C                     PARM           P@PTCD  1
     C                     PARM           P@ZAIS 15
     C                     PARM           P@ZAIK  5
     C                     PARM           P@NADJ  3
      *
     C                     MOVE P@SIRE    K@SIRE
     C                     MOVE P@UKEI    K@UKEI
     C                     MOVE P@PTCD    K@PTCD
     C                     MOVE P@ZAIS    K@ZAIS
     C                     MOVE P@ZAIK    K@ZAIK
      *
     C           KEY       KLIST
     C                     KFLD           K@SIRE  40
     C                     KFLD           K@UKEI  40
     C                     KFLD           K@PTCD  1
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
      *
     C           KEY       SETLLBTBPP41
     C                     DO   *HIVAL
     C           KEY       READEBTBPP41                  88
     C   88                LEAVE
     C           B4SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     MOVE P@NADJ    B4MAIS
     C                     UPDATBTBPP411
     C                     LEAVE
     C                     ENDDO
      *
     C           *IN88     IFEQ '1'
