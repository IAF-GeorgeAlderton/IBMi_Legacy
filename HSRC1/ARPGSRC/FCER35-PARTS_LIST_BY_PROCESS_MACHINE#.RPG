      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C           *IN01     IFEQ *OFF
     C                     EXSR #OUT1
     C                     MOVE *ON       *IN01
     C                     ENDIF
     C                     EXSR #OUT2
     C           *IN97     IFEQ *OFF
     C                     SETON                     619962
     C                     MOVE ERR,1     D@MSG
     C                     ELSE
     C                     MOVE *BLANK    D@PROC
     C                     MOVE *BLANK    D@MCHN
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     616299
     C                     MOVE *BLANK    D@MSG
     C           D@PROC    IFEQ *BLANK
     C                     SETON                     6199
     C                     ENDIF
     C           D@MCHN    IFEQ *BLANK
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  OUTPUT
      *------------------------------------------------------
     C           #OUT1     BEGSR
      * WRK DAYS
     C                     Z-ADD0         @W10    31
     C                     Z-ADD*DATE     K@YMD
     C                     SUB  1         K@MM
     C           K@MM      IFEQ *ZERO
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
     C                     ENDIF
     C           K#AGD     SETLLAGDPL121
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL121                 90
     C           *IN90     IFEQ *OFF
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
     C                     ENDIF
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @W10
     C                     ELSE
     C                     ADD  0.5       @W10
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           *LOVAL    SETLLAAMPL11
     C           *IN92     DOUEQ*ON
     C                     READ AAMPL11                  92
     C           *IN92     IFEQ *OFF
     C           CKSKJY    ANDEQ*BLANK
     C           1         DO   15        X       20
     C           MCN,X     IFNE *BLANK
     C                     MOVE MCN,X     F5MCHN
     C                     MOVE PRC,X     F5PROC
      *
     C                     MOVE CKHIN1    F5PAR1
     C                     MOVE CKHIN2    F5PAR2
     C                     MOVE CKHIN3    F5PAR3
     C                     WRITEFCEWP351
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     CLOSEFCEWP35
     C                     OPEN FCEWP35
      *
     C                     ENDSR
      *------------------------------------------------------
      *  OUTPUT
      *------------------------------------------------------
     C           #OUT2     BEGSR
      *
     C                     Z-ADD*ZERO     @@BTOT
     C                     Z-ADD*ZERO     @@QTOT
     C                     MOVEA'00'      *IN,97
     C           K#FC5     SETLLFCEWP35
     C           *IN92     DOUEQ*ON
     C           K#FC5     READEFCEWP35                  92
     C           *IN92     IFEQ *OFF
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVE *OFF      *IN97
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
      *
     C                     EXSR #ACT
     C           K#FCE     CHAINAAMPL11              92
      *
     C                     EXCPT@DTL
     C  N97                MOVE *ON       *IN97
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN97     IFEQ *ON
     C           @@QTOT    IFNE *ZERO
     C   OF                EXCPT@HED
     C                     EXCPT@STOT
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #ACT      BEGSR
      *------------------------------------------------------
     C                     Z-ADD*ZERO     @ACQY   90
     C                     Z-ADD*ZERO     @ABOX
      *
     C           K#FCE     SETLLMBDPL01
     C           *IN26     DOUEQ*ON
     C           K#FCE     READEMBDPL01                  26
     C           *IN26     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
      *
     C                     ADD  F3TNSU    @ACQY
     C                     ENDIF
     C                     ENDDO
      *
     C           K#FCE     CHAINFCEPL01              26
     C           @ACQY     DIV  A2SSYS    @ABOX   71H
     C           A2GEKN    DIV  A2SSYS    A2BOX   71H
     C           A2BOX     DIV  20        A2DBX   51H
      * PER DAY
     C           @W10      IFNE *ZERO
     C           @ACQY     DIV  @W10      @DQY    91H
     C           @ABOX     DIV  @W10      @DBX    71H
     C                     ENDIF
      *
     C                     ADD  @DQY      @@QTOT 111
     C                     ADD  @DBX      @@BTOT  91
      *
     C                     ENDSR
