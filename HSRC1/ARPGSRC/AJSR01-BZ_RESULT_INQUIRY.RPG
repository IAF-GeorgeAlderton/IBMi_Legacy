      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           K@MKKB  2
     C                     KFLD           K@YY
     C                     KFLD           K@MM
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     EXSR #SET
     C           RRN1      IFEQ *ZERO
     C                     MOVE ERR,2     D@MSG
     C                     ELSE
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@TO      IFEQ *ZERO
     C                     Z-ADD999999    D@TO
     C                     ENDIF
      *
     C           D@FROM    IFGT D@TO
     C                     MOVE ERR,1     D@MSG
     C                     SETON                     616299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     Z-ADDD@FROM    K@YYMM
     C           *LOVAL    SETLLAJSPL21
     C           *IN81     DOUEQ*ON
     C                     READ AJSPL21                  81
     C           *IN81     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
     C                     MOVE J2MKKB    K@MKKB
     C                     Z-ADD*ZERO     W@YYMM
     C                     Z-ADD*ZERO     W2QTY
      *
     C           K#KEY     SETLLAJSPL21
     C           *IN80     DOUEQ*ON
     C                     READ AJSPL21                  80
     C           *IN80     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
      *
     C           J2YYMM    IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           J2YYMM    IFNE W@YYMM
     C           W@YYMM    IFNE *ZERO
     C                     WRITEAJSWP011
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W2QTY
     C                     Z-ADDJ2YYMM    W@YYMM
     C                     MOVE J2MKKB    W2MKKB
     C           J2MKKB    IFEQ '23'
     C                     MOVE '02'      W2MKKB
     C                     ENDIF
      *
     C                     Z-ADDJ2KEIY    W2KEIY
     C                     Z-ADDJ2KEIM    W2KEIM
     C                     ENDIF
      *
     C           1         DO   4         X
     C           PAG,X     IFNE *BLANK
     C                     ADD  1         W2QTY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           W2QTY     IFNE *ZERO
     C                     WRITEAJSWP011
     C                     ENDIF
      *
     C           K@MKKB    SETGTAJSPL21
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
