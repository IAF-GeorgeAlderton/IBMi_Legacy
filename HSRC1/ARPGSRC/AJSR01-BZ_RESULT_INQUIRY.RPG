     C                     ADD  W2QTY     BT,X
     C                     ENDIF
      *
     C                     Z-ADDW2KEYM    W@YYMM
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           W@YYMM    IFNE *ZERO
     C                     ADD  1         RRN1
     C                     MOVE MON,WM    S@MNTH
     C                     XFOOTBX        S@TOTL
     C                     ADD  S@TOTL    D@TOTL
     C                     WRITESFL01
     C                     CLEARSFL01
