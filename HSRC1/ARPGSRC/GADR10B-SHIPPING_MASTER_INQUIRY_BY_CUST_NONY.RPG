     H            Y.
     F** GADR10B *******************************************
     F*  SHIPPING MASTER INQUIRY BY CUSR/NONY              *
     F*  J.W     2022.12.16                                *
     F******************************************************
     FGADPW10BCF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFL01
     FGADPL11 IF  E           K        DISK
      *
     E                    MSG     1   1 60
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120@TODAY
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
      * DSPLAY SCREEN 1
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *---------*
      * F3: END *
      *---------*
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '#END    '@STEP
     C                     GOTO XDSP1
     C                     ENDIF
      *------------------*
      * F7: SHOW DELETED
      *------------------*
     C           *INKG     IFEQ *ON
     C                     CALL 'GADR10C'
     C                     GOTO XDSP1
     C                     ENDIF
      *--------------*
      * PAGE UP/DOWN *
      *--------------*
JW   C           *IN73     IFEQ *ON
 .   C                     MOVE '#DSP1   '@STEP
 .   C                     GOTO XDSP1
JW   C                     ENDIF
      *-------------*
      * ENTR KEY    *
      *-------------*
     C                     EXSR #SET
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     GOTO XDSP1
      *
     C           XDSP1     ENDSR
     C*===============================================================
     C* SET SUBFILE
     C*===============================================================
     C           #SET      BEGSR
      *  SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     CLEARSFL01
JW   C                     Z-ADD0         SVTOKU  40
JW   C                     Z-ADD0         SVNONY  40
      *
      *-------------------------
     C           K#11      SETLLGADPL11
S1   C                     DO   *HIVAL
     C                     READ GADPL11                  98
     C   98                LEAVE
      *
     C           B5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           XTOKU     IFNE 0
     C           XTOKU     ANDGTB5TOKU
     C                     ITER
     C                     ENDIF
      *
     C           XNONY     IFNE 0
     C           XNONY     ANDGTB5NONY
     C                     ITER
     C                     ENDIF
      * BREAK?
     C           B5TOKU    IFNE SVTOKU
     C           SVTOKU    ANDNE0
     C           B5NONY    ORNE SVNONY
     C           SVNONY    ANDNE0
     C                     Z-ADD0         S1CUS#
     C                     Z-ADD0         S1DEL#
     C                     MOVE *BLANK    S1NKOJ
     C                     MOVE *BLANK    S1DOCK
     C                     Z-ADD0         S1KOHZ
     C                     MOVE *BLANK    S1KOME
     C                     MOVE *BLANK    S1NAME
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     ENDIF
     C                     Z-ADDB5TOKU    SVTOKU
     C                     Z-ADDB5NONY    SVNONY
      * DETAIL
     C                     Z-ADDB5TOKU    S1CUS#
     C                     Z-ADDB5NONY    S1DEL#
     C                     MOVELB5NKOJ    S1NKOJ
     C                     MOVELB5NUKE    S1DOCK
     C                     Z-ADDB5KOHZ    S1KOHZ
     C                     MOVELB5KOME    S1KOME
     C                     MOVELB5KMEI    S1NAME
      *
     C                     ADD  1         RRN
     C                     WRITESFL01
E1   C                     ENDDO
      *
     C           RRN       IFEQ 0
     C                     ADD  1         RRN
     C                     MOVELMSG,1     S1NAME
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDSR
     C*===============================================================
     C* INITIAL SETTINGS
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           K#11      KLIST
     C                     KFLD           XTOKU
     C                     KFLD           XNONY
      *
     C                     Z-ADD0         XTOKU
     C                     Z-ADD0         XNONY
      *
     C                     MOVEA*ALL'0'   *IN
JW   C                     TIME           SDATE
     C*-------------------------
     C                     EXSR #SET
      *
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
      *
     C                     ENDSR
