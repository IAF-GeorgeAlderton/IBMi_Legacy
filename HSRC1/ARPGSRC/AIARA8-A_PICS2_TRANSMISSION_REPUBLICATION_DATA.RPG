      * INSTRUCTION KANBAN M/F
     FCADTL01 IF  E           K        DISK
      *
      * A-PICS2 LEVELLING                                              UMBER *
     FCABPL01 IF  E           K        DISK
      *
      * A-PICS2 LEVELLING WORK                                         UMBER *
     FCABWL01 IF  E           K        DISK
      *
     FAIANP07 O   F     300            DISK                      A
      *================================================================
     I            DS
     I                                        1   80C3SKHZ
     I                                        1   40C3SKYY
     I                                        5   60C3SKMM
     I                                        7   80C3SKDD
     I            DS
     I                                        1   80GBSKHZ
     I                                        1   40GBSKYY
     I                                        5   60GBSKMM
     I                                        7   80GBSKDD
      *================================================================
     C           KEYHIN    KLIST
     C                     KFLD           C2SHN1  5
     C                     KFLD           C2SHN2  5
     C                     KFLD           C2SHN3  2
      *
     C*----------------------------*
     C* GET DAY 1 YEAR AGO        *
     C*----------------------------*
     C                     MOVE *DATE     PDATE
     C                     MOVE '-'       PPORM
     C                     MOVE '0365'    PDAYS
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     XDATE   80
      *----------------------------*
      *  A-PICS2 KANBAN M/F        *
      *----------------------------*
S1   C                     DO   *HIVAL
     C                     SETOF                         01
     C                     READ CADTL011                 01
     C   01                LEAVE
     C*
     C           C2SKJY    IFEQ 'D'
     C           C2SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           C2STHZ    IFLT XDATE
     C                     ITER
     C                     ENDIF
     C*
     C           C2SYOS    IFEQ 0
     C                     ITER
     C                     ENDIF
     C*
      *
      * A-PICS2 LEVELING FILE                                          UMBER *
     C                     SETOF                     8889
     C*
     C           KEYHIN    CHAINCABPL01              88
 S2  C           *IN88     IFEQ *OFF
     C           C3SKJY    IFEQ 'D'
     C           C3SKHZ    ANDLE*DATE
     C                     SETON                     88
     C                     ENDIF
     C           *IN88     IFEQ *OFF
     C           C3SJSR    ANDNE'F'
     C                     SETON                     88
     C                     ENDIF
 E2  C                     ENDIF
      *****
      * A-PICS2 LEVVELING WORK                                         UMBER *
 S2  C           *IN88     IFEQ *ON
     C           KEYHIN    CHAINCABWL01              89
  S3 C           *IN89     IFEQ *OFF
     C           GBSKJY    ANDEQ'D'
     C           GBSKHZ    ANDLE*DATE
     C                     SETON                     89
  E3 C                     ENDIF
  S3 C           *IN89     IFEQ *OFF
     C           GBSJSR    ANDNE'F'
     C                     SETON                     89
  E3 C                     ENDIF
 E2  C                     ENDIF
     C*
     C   89                ITER
     C*
     C*  WRITE DATA
     C                     EXCPTDT1
      *------------------------------*
E1   C                     ENDDO
      *------------------------------*
      *
      *
     C                     SETON                     LR
