     H            Y.
     F** ABMR56 ***************************
     F* NO PART M/F LIST
     F*    HOTTA.         2018.10.16      *
     F*************************************
     FABMWP54 IF  E           K        DISK
     FABMWP56 O   F    0256            DISK                      A
      *
      *--------------------------------------------------------*
      *    パラメータＴＲＡＮＳＵＦＥＲ
      *--------------------------------------------------------*
      *
     C                     EXCPTHD
     C                     READ ABMWP541                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #DTOUT
     C                     READ ABMWP541                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*
      *--------------------------------------------------------*
      *                                                        *
      *--------------------------------------------------------*
     CSR         #DTOUT    BEGSR
      *
     C                     MOVELW1TOKU    @TOKU   4
     C                     MOVELW1NONY    @NOYN   4
     C                     MOVELW1NKOJ    @KOJ    1
     C                     MOVELW1NUKE    @UKEC   4
     C                     MOVEL*BLANK    @MHIN  17
     C           W1MHN1    CAT  '-':0     @MHIN
     C           @MHIN     CAT  W1MHN2:0  @MHIN
     C           @MHIN     CAT  '-':0     @MHIN
     C           @MHIN     CAT  W1MHN3:0  @MHIN
     C                     MOVEL*BLANK    @SHIN  14
     C           W1SHN1    CAT  '-':0     @SHIN
     C           @SHIN     CAT  W1SHN2:0  @SHIN
     C           @SHIN     CAT  '-':0     @SHIN
     C           @SHIN     CAT  W1SHN3:0  @SHIN
     C                     Z-ADDW1NNNM    @NNNM   90
     C                     Z-ADDW11NNM    @1NNM   90
     C                     Z-ADDW12NNM    @2NNM   90
     C                     EXCPTDT
      *
     CSR         EDTOUT    ENDSR
     OABMWP56 EADD             HD
     O                                      'CUST,'
     O                                      'DELI,'
     O                                      'FACT,'
     O                                      'DOCK,'
     O                                      'USER PART NO.,'
     O                                      'INTR PART NO.,'
     O                                      'FORECAST(N),'
     O                                      'FORECAST(N+1),'
     O                                      'FORECAST(N+2),'
     O        EADD             DT
     O                         @TOKU
     O                                      ','
     O                         @NOYN
     O                                      ','
     O                         @KOJ
     O                                      ','
     O                         @UKEC
     O                                      ','
     O                         @MHIN
     O                                      ','
     O                         @SHIN
     O                                      ','
     O                         @NNNM
     O                                      ','
     O                         @1NNM
     O                                      ','
     O                         @2NNM
     O                                      ','
