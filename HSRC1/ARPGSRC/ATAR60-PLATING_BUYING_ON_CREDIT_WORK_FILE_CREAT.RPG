     H            Y
     F************************************************
     F* PLATING BUYING ON CREDIT WORK FILE CREATE ATAR60 *
     F************************************************
     FATAPW60 CF  E                    WORKSTN
     FAS#PL11 IF  E           K        DISK
     FAASPL11 IF  E           K        DISK
     FATAWP60 O   E           K        DISK
     E                    $MSG    1   3 60
     C**************************
     C*  合成キー            *
     C**************************
     C           #KEY1     KLIST
     C                     KFLD           #KAKO   40
     C                     KFLD           #HIN1   5
     C                     KFLD           #HIN2   5
     C                     KFLD           #HIN3   2
     C           *ENTRY    PLIST
     C                     PARM           PARM1   8
     C                     PARM           @SHAKO  1
     C*********************
     C*画面チェツク     *
     C*********************
     C           START     TAG
     C                     EXFMTATAPW601
     C                     SETOF                     202199
     C                     SETOF                     9098
     C                     MOVE *BLANK    @ERR
     C           *INKA     IFEQ '1'
     C                     MOVE '9'       @SHAKO
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C           @SHAKO    IFNE 'G'
     C           @SHAKO    IFNE ' '
     C                     SETON                       2199
     C                     MOVEL$MSG,1    @ERR
     C                     GOTO START
     C                     END
     C                     END
     C**************************
     C*  日付チエック        *
     C**************************
     C                     MOVEL@SIME     HYM     60
     C                     MOVELHYM       HY      40
     C                     MOVE HYM       HM      20
     C                     MOVE @SIME     HD      20
     C           HY        SUB  *YEAR     YY      40
     C           YY        IFGE 1
     C                     SETON                       2099
     C                     MOVEL$MSG,2    @ERR
     C                     GOTO START
     C                     END
     C           @SHAKO    IFNE 'G'
     C           YY        IFLE -2
     C                     SETON                       2099
     C                     MOVEL$MSG,2    @ERR
     C                     GOTO START
     C                     END
     C                     END
     C           HY        DIV  4         URUDOS  50
     C                     MVR            AMARI   50
     C*  01
     C           HM        IFEQ 01
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  02
     C           HM        IFEQ 02
     C           AMARI     IFEQ *ZERO
     C           HD        IFLT 01
     C           HD        ORGT 29
     C                     SETON                       90
     C                     END
     C                     ELSE
     C           HD        IFLT 01
     C           HD        ORGT 28
     C                     SETON                       90
     C                     END
     C                     END
     C                     END
     C*  03
     C           HM        IFEQ 03
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  04
     C           HM        IFEQ 04
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  05
     C           HM        IFEQ 05
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  06
     C           HM        IFEQ 06
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  07
     C           HM        IFEQ 07
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  08
     C           HM        IFEQ 08
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  09
     C           HM        IFEQ 09
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  10
     C           HM        IFEQ 10
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  11
     C           HM        IFEQ 11
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  12
     C           HM        IFEQ 12
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  01 -- 12
     C           HM        IFLT 01
     C           HM        ORGT 12
     C                     SETON                       98
     C                     END
     C           HY        IFEQ *ZERO
     C                     SETON                       98
     C                     END
     C           *IN90     IFEQ '1'
     C           *IN98     OREQ '1'
     C                     SETON                       99
     C                     MOVEL$MSG,3    @ERR
     C                     GOTO START
     C                     END
     C/SPACE 3
     C**************************
     C*  ファイル選択処理    *
     C**************************
     C                     DO   *HIVAL
     C                     READ AS#PL111                 81
     C           *IN81     CABEQ'1'       LAST
     C           CUKNHZ    IFEQ *ZERO
     C                     GOTO TRY
     C                     ELSE
     C           @SHAKO    IFEQ 'G'
     C           CUKNHZ    IFLE @SIME
     C           CUKIHZ    ANDEQ@SIME
     C                     GOTO SYOR10
     C                     END
     C                     ELSE
     C           CUKNHZ    IFLE @SIME
     C           CUKIHZ    ANDEQ*ZERO
     C                     GOTO SYOR10
     C                     END
     C                     END
     C                     END
     C                     GOTO TRY
     C**************************
     C*  ファイル作成処理    *
     C**************************
     C           SYOR10    TAG
     C                     MOVE CUKAKO    #KAKO
     C                     MOVE CUHIN1    #HIN1
     C                     MOVE CUHIN2    #HIN2
     C                     MOVE CUHIN3    #HIN3
     C           #KEY1     CHAINAASPL111             31
     C                     MOVE CUKAKO    TASHIR
     C                     MOVE CUZENO    TAZENO
     C                     MOVE CUTHNO    TATHNO
     C                     MOVE CUBKAS    TABKAS
     C                     MOVE CUKNHZ    TAKNHZ
     C                     MOVE CUHIN1    TAHIN1
     C                     MOVE CUHIN2    TAHIN2
     C                     MOVE CUHIN3    TAHIN3
     C                     MOVE CUSYUY    TASYUY
     C                     MOVE CURKHK    TARKHK
     C                     MOVE CURHSU    TARHSU
     C           CUSYUY    MULT CURKHK    WCNT1   70
     C           WCNT1     ADD  CURHSU    TASURY
     C           *IN31     IFEQ '0'
     C           CRTANI    IFEQ 'G'
     C                     MOVE CRTANJ    JYU     73
     C                     ELSE
     C           CRTANJ    MULT 1000      JYU     73
     C                     END
     C                     MOVE CRHSYR    TAHSYR
     C           CRMKHZ    IFLE CUKNHZ
     C           CRMTKN    IFEQ 'C'
     C                     Z-ADDCRMTNN    TATANK
     C                     ELSE
     C           CRMTNN    MULT JYU       WCNT2  139
     C           WCNT2     DIV  1000      TATANK
     C                     END
     C                     ELSE
     C           CRMTKO    IFEQ 'C'
     C                     Z-ADDCRMTNO    TATANK
     C                     ELSE
     C           CRMTNO    MULT JYU       WCNT2  139
     C           CRMTNO    DIV  1000      TATANK
     C                     END
     C                     END
     **
     C           CRMHHZ    IFLE CUKNHZ
     C           CRTANI    IFEQ 'G'
     C           CRMHSN    MULT 1000      WKSO    80
     C           CRTANJ    IFNE *ZERO
     C           WKSO      DIV  CRTANJ    TAHOSO  50H
     C                     END
     C                     ELSE
     C           CRMHSN    DIV  CRTANJ    TAHOSO
     C                     END
     C                     ELSE
     **
     C           CRTANI    IFEQ 'G'
     C           CRMHSO    MULT 1000      WKSO    80
     C           CRTANJ    IFNE *ZERO
     C           WKSO      DIV  CRTANJ    TAHOSO  50H
     C                     END
     C                     ELSE
     C           CRMHSO    DIV  CRTANJ    TAHOSO
     C                     END
     C                     END
     C                     ELSE
     C                     MOVE *ZERO     TATANK
     C                     MOVE *ZERO     TAHOSO
     C                     END
     C                     WRITEATAWP601
     C                     MOVE *BLANK    TAZENO
     C                     MOVE *ZERO     TASHIR
  K.YC                     MOVE *ALL'0'   TATHNO
     C                     MOVE *ZERO     TABKAS
     C                     MOVE *ZERO     TAKNHZ
     C                     MOVE *BLANK    TAHIN1
     C                     MOVE *BLANK    TAHIN2
     C                     MOVE *BLANK    TAHIN3
     C                     MOVE *BLANK    TAHSYR
     C                     MOVE *ZERO     TASYUY
     C                     MOVE *ZERO     TARKHK
     C                     MOVE *ZERO     TARHSU
     C                     MOVE *ZERO     TASURY
     C                     MOVE *ZERO     TATANK
     C                     MOVE *ZERO     TAHOSO
     C                     MOVE *ZERO     WKSO
     C                     SETOF                         31
     C           TRY       TAG
     C                     END
     C************************
     C*プログラムの終了    *
     C************************
     C           LAST      TAG
     C                     MOVE @SIME     PARM1
     C                     SETON                       LR
     C                     RETRN
**
REPUBLICATION INSTRUCTION APPOINTMENT ERROR
CLOSE DAY ERROR
DATE APPOINTMENT ERROR
