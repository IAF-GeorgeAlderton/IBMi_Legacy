      *-----------------------------------------------------
      *  Main control routine
      *-----------------------------------------------------
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KA                LEAVE
     C*
     C                     SELEC
     C           F1PRT     WHEQ '1'
     C                     MOVEL'LANPRT02'W#OUTQ  8
     C           F1PRT     WHEQ '2'
     C                     MOVEL'LANPRT07'W#OUTQ
     C           F1PRT     WHEQ '3'
     C                     MOVEL'LANPRT08'W#OUTQ
     C           F1PRT     WHEQ '4'
     C                     MOVEL'LANPRT03'W#OUTQ
     C           F1PRT     WHEQ '5'
     C                     MOVEL'QPRINTA 'W#OUTQ
     C           F1PRT     WHEQ '6'
     C                     MOVEL'LANPRT09'W#OUTQ
     C           F1PRT     WHEQ '7'
     C                     MOVEL'LANPRT10'W#OUTQ
     C           F1PRT     WHEQ '8'
     C                     MOVEL'LANPRT05'W#OUTQ
     C           F1PRT     WHEQ '9'
     C                     MOVEL'QDKT    'W#OUTQ
     C                     OTHER
     C                     MOVELERR,1     EMSG
     C                     MOVEL*ON       *IN31
     C                     ITER
     C                     ENDSL
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @SELCT
     C                     CLOSEABRWP58
     C                     OPEN ABRWP58
     C                     EXSR @PRINT
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      *  Initialize
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     TIME           W@TIME
      *
     C                     MOVE *ALL'-'   @LINE 132
      *
     C                     ENDSR
      *------------------------------------------------------
      *   Data select routine
      *------------------------------------------------------
     C           @SELCT    BEGSR
      *
      * WIXOM
     C           2855      SETLLMBDPL02
     C                     DO   *HIVAL
     C*
     C           2855      READEMBDPL02                  98
     C   98                LEAVE
     C           F3SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    W#FND   1
     C                     EXSR @JUDGE
     C           W#FND     IFNE *BLANK
     C                     EXSR @OUTF
     C                     END
     C*
     C                     ENDDO
      *
      * LOUISVILLE
     C           2856      SETLLMBDPL02
     C                     DO   *HIVAL
     C*
     C           2856      READEMBDPL02                  98
     C   98                LEAVE
     C           F3SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    W#FND
     C                     EXSR @JUDGE
     C           W#FND     IFNE *BLANK
     C                     EXSR @OUTF
     C                     END
     C*
     C                     ENDDO
      *
     C                     ENDSR
     C*-----------------------------------------------------
     C*  Judge for returnable or not
     C*-----------------------------------------------------
     C           @JUDGE    BEGSR
     C*
     C           K#MPRT    KLIST
     C                     KFLD           F3SHN1
     C                     KFLD           F3SHN2
     C                     KFLD           F3SHN3
     C*
     C                     DO
     C*
     C           K#MPRT    SETGTAAFTL01
     C                     DO
     C           K#MPRT    REDPEAAFTL01                  97
     C   97                LEAVE
     C           A3JOK3    IFEQ 'FD'
     C           A3JOK4    OREQ 'FD'
     C           A3JOK5    OREQ 'FD'
     C           A3JOK6    OREQ 'FD'
     C           A3JOK3    IFEQ 'PU'
     C           A3JOK4    OREQ 'PU'
     C           A3JOK5    OREQ 'PU'
     C           A3JOK6    OREQ 'PU'
     C                     MOVEL'F'       W#FND
     C                     LEAVE
     C                     END
     C                     END
     C                     ENDDO
     C*
     C           W#FND     IFNE *BLANK
     C                     LEAVE
     C                     END
     C*
     C           K#MPRT    SETGTAAHTL01
     C                     DO
     C           K#MPRT    REDPEAAHTL01                  97
     C   97                LEAVE
     C           L6JOK4    IFEQ 'FD'
     C           L6JOK5    OREQ 'FD'
     C           L6JOK6    OREQ 'FD'
     C           L6JOK7    OREQ 'FD'
     C           L6JOK4    IFEQ 'PU'
     C           L6JOK5    OREQ 'PU'
     C           L6JOK6    OREQ 'PU'
     C           L6JOK7    OREQ 'PU'
     C                     MOVEL'H'       W#FND
     C                     LEAVE
     C                     END
     C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C*  Create temporary work file
     C*-----------------------------------------------------
     C           @OUTF     BEGSR
     C*
     C                     CLEARABRWP581
     C*
     C                     Z-ADDF3TOKU    A8TOKU
     C                     Z-ADDF3NONY    A8NONY
     C                     MOVELF3NKOJ    A8NKOJ
     C                     MOVELF3NUKE    A8NUKE
     C                     MOVELF3SHN1    A8SHN1
     C                     MOVELF3SHN2    A8SHN2
     C                     MOVELF3SHN3    A8SHN3
     C                     MOVELF3MHN1    A8MHN1
     C                     MOVELF3MHN2    A8MHN2
     C                     MOVELF3MHN3    A8MHN3
     C                     MOVELF3MHN4    A8MHN4
     C*
     C           K#MPRT    CHAINFCEPL01              94
     C           *IN94     IFEQ *OFF
     C                     MOVEL@LOC      A8LOC
     C                     Z-ADDA2SSYS    A8BOXQ
     C                     END
     C*
     C                     MOVELW#FND     A8FLFG
     C           W#FND     IFEQ 'F'
     C                     MOVELA3JOK3    A8JOKA
     C                     MOVELA3JOK4    A8JOKB
     C                     MOVELA3JOK5    A8JOKC
     C                     MOVELA3JOK6    A8JOKD
     C                     ELSE
     C                     MOVELL6JOK4    A8JOKA
     C                     MOVELL6JOK5    A8JOKB
     C                     MOVELL6JOK6    A8JOKC
     C                     MOVELL6JOK7    A8JOKD
     C                     END
     C                     Z-ADDF3TNSU    A8TNSU
     C                     Z-ADDF3ANSU    A8ANSU
     C                     Z-ADDF3BNSU    A8BNSU
     C                     Z-ADDF3CNSU    A8CNSU
     C                     Z-ADDF3DNSU    A8DNSU
     C                     Z-ADDF3ENSU    A8ENSU
     C*
     C                     WRITEABRWP581
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C*  Print "Shipment History(# of Box)
     C*-----------------------------------------------------
     C           @PRINT    BEGSR
     C*
     C                     EXSR @P@INT
     C*
     C                     MOVEL*BLANK    W#SHN
     C*
     C           *LOVAL    SETLLABRWP58
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABRWP58                  95
     C   95                LEAVE
     C*
     C           W#SHN     IFEQ *BLANK
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C*
     C           W#SHN     IFNE *BLANK
     C           A8SHN     ANDNEW#SHN
     C                     MOVELTOT,1     W#TOT  11
     C                     Z-ADDW#PBX1    W#SBX1
     C                     Z-ADDW#PBX2    W#SBX2
     C                     Z-ADDW#PBX3    W#SBX3
     C                     Z-ADDW#PBX4    W#SBX4
     C                     Z-ADDW#PBX5    W#SBX5
     C                     Z-ADDW#PBX6    W#SBX6
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C                     EXCPT@TOT
     C                     Z-ADD*ZERO     W#PBX1
     C                     Z-ADD*ZERO     W#PBX2
     C                     Z-ADD*ZERO     W#PBX3
     C                     Z-ADD*ZERO     W#PBX4
     C                     Z-ADD*ZERO     W#PBX5
     C                     Z-ADD*ZERO     W#PBX6
     C                     END
     C* detail N-1
     C           A8TNSU    IFNE *ZERO
     C           A8TNSU    DIV  A8BOXQ    W#BOX1  60
     C                     MVR            W#BOX2  60
     C           W#BOX2    IFNE *ZERO
     C                     ADD  1         W#BOX1
     C                     END
     C                     Z-ADDW#BOX1    W#DBX1
     C                     ELSE
     C                     Z-ADD*ZERO     W#DBX1
     C                     END
     C* detail N-2
     C           A8ANSU    IFNE *ZERO
     C           A8ANSU    DIV  A8BOXQ    W#BOX1
     C                     MVR            W#BOX2
     C           W#BOX2    IFNE *ZERO
     C                     ADD  1         W#BOX1
     C                     END
     C                     Z-ADDW#BOX1    W#DBX2
     C                     ELSE
     C                     Z-ADD*ZERO     W#DBX2
     C                     END
     C* detail N-3
     C           A8BNSU    IFNE *ZERO
     C           A8BNSU    DIV  A8BOXQ    W#BOX1
     C                     MVR            W#BOX2
     C           W#BOX2    IFNE *ZERO
     C                     ADD  1         W#BOX1
     C                     END
     C                     Z-ADDW#BOX1    W#DBX3
     C                     ELSE
     C                     Z-ADD*ZERO     W#DBX3
     C                     END
     C* detail N-4
     C           A8CNSU    IFNE *ZERO
     C           A8CNSU    DIV  A8BOXQ    W#BOX1
     C                     MVR            W#BOX2
     C           W#BOX2    IFNE *ZERO
     C                     ADD  1         W#BOX1
     C                     END
     C                     Z-ADDW#BOX1    W#DBX4
     C                     ELSE
     C                     Z-ADD*ZERO     W#DBX4
     C                     END
     C* detail N-5
     C           A8DNSU    IFNE *ZERO
     C           A8DNSU    DIV  A8BOXQ    W#BOX1
     C                     MVR            W#BOX2
     C           W#BOX2    IFNE *ZERO
     C                     ADD  1         W#BOX1
     C                     END
     C                     Z-ADDW#BOX1    W#DBX5
     C                     ELSE
     C                     Z-ADD*ZERO     W#DBX5
     C                     END
     C* detail N-6
     C           A8ENSU    IFNE *ZERO
     C           A8ENSU    DIV  A8BOXQ    W#BOX1
     C                     MVR            W#BOX2
     C           W#BOX2    IFNE *ZERO
     C                     ADD  1         W#BOX1
     C                     END
     C                     Z-ADDW#BOX1    W#DBX6
     C                     ELSE
     C                     Z-ADD*ZERO     W#DBX6
     C                     END
     C* summary of part# total
     C                     ADD  W#DBX1    W#PBX1
     C                     ADD  W#DBX2    W#PBX2
     C                     ADD  W#DBX3    W#PBX3
     C                     ADD  W#DBX4    W#PBX4
     C                     ADD  W#DBX5    W#PBX5
     C                     ADD  W#DBX6    W#PBX6
     C* summary of grand total
     C                     ADD  W#DBX1    W#GBX1
     C                     ADD  W#DBX2    W#GBX2
     C                     ADD  W#DBX3    W#GBX3
     C                     ADD  W#DBX4    W#GBX4
     C                     ADD  W#DBX5    W#GBX5
     C                     ADD  W#DBX6    W#GBX6
     C* print detail
     C           A8SHN     IFNE W#SHN
     C                     MOVELA8SHN1    W8SHN1  5
     C                     MOVELA8SHN2    W8SHN2  5
     C                     MOVELA8SHN3    W8SHN3  2
     C                     ELSE
     C                     MOVEL*BLANK    W8SHN1
     C                     MOVEL*BLANK    W8SHN2
     C                     MOVEL*BLANK    W8SHN3
     C                     END
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C*
     C           A8NONY    CHAINFGBPL01              93
     C   93                MOVEL*BLANK    W#DVNM 15
     C  N93                MOVELB2SMEI    W#DVNM
     C*
     C                     EXCPT@DTL
     C                     MOVELA8SHN     W#SHN
     C*
     C                     ENDDO
     C* grand total
     C           W#SHN     IFNE *BLANK
     C* part# total
     C                     MOVELTOT,1     W#TOT  11
     C                     Z-ADDW#PBX1    W#SBX1
     C                     Z-ADDW#PBX2    W#SBX2
     C                     Z-ADDW#PBX3    W#SBX3
     C                     Z-ADDW#PBX4    W#SBX4
     C                     Z-ADDW#PBX5    W#SBX5
     C                     Z-ADDW#PBX6    W#SBX6
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C                     EXCPT@TOT
     C* grand total
     C                     MOVELTOT,2     W#TOT
     C                     Z-ADDW#GBX1    W#SBX1
     C                     Z-ADDW#GBX2    W#SBX2
     C                     Z-ADDW#GBX3    W#SBX3
     C                     Z-ADDW#GBX4    W#SBX4
     C                     Z-ADDW#GBX5    W#SBX5
     C                     Z-ADDW#GBX6    W#SBX6
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C                     EXCPT@TOT
     C                     END
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C*  Clear fields for Print
     C*-----------------------------------------------------
     C           @P@INT    BEGSR
     C* Detail print fields
     C                     Z-ADD*ZERO     W#DBX1  60
     C                     Z-ADD*ZERO     W#DBX2  60
     C                     Z-ADD*ZERO     W#DBX3  60
     C                     Z-ADD*ZERO     W#DBX4  60
     C                     Z-ADD*ZERO     W#DBX5  60
     C                     Z-ADD*ZERO     W#DBX6  60
     C* Summary print fields
     C                     Z-ADD*ZERO     W#SBX1  60
     C                     Z-ADD*ZERO     W#SBX2  60
     C                     Z-ADD*ZERO     W#SBX3  60
     C                     Z-ADD*ZERO     W#SBX4  60
     C                     Z-ADD*ZERO     W#SBX5  60
     C                     Z-ADD*ZERO     W#SBX6  60
     C* Summary fields for Part#
     C                     Z-ADD*ZERO     W#PBX1  60
     C                     Z-ADD*ZERO     W#PBX2  60
     C                     Z-ADD*ZERO     W#PBX3  60
     C                     Z-ADD*ZERO     W#PBX4  60
     C                     Z-ADD*ZERO     W#PBX5  60
     C                     Z-ADD*ZERO     W#PBX6  60
     C* Summary fields for Grand total
     C                     Z-ADD*ZERO     W#GBX1  60
     C                     Z-ADD*ZERO     W#GBX2  60
     C                     Z-ADD*ZERO     W#GBX3  60
     C                     Z-ADD*ZERO     W#GBX4  60
     C                     Z-ADD*ZERO     W#GBX5  60
     C                     Z-ADD*ZERO     W#GBX6  60
     C*
     C                     MOVEACMD,1     ARX
     C                     MOVEAW#OUTQ    ARX,27
     C                     MOVEAARX       P@CMD     P
     C                     Z-ADD105       P@LEN
     C                     CALL 'QCMDEXC' P#CMD
      *
     C                     OPEN QPRINT
     C*
     C                     Z-ADDW@DM      X       20
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           Y         IFGT 6
     C                     LEAVE
     C                     END
     C                     SUB  1         X
     C           X         IFLE *ZERO
     C                     Z-ADD12        X
     C                     END
     C                     MOVELMON,X     W#M,Y
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   02           @HED
     O                         #PGM      10
     O                         UDATE Y  110
     O                         @@TIME   119 '  :  :  '
     O                                  122 'P.'
     O                         PAGE  Z  126
     O        E   03           @HED
     O                         TTX,1    100
     O        E   05           @HED
     O                                    8 'PART#'
     O                                   29 'DELIVERY'
     O                                   43 'F'
     O                                   48 'DOCK'
     O                                   57 'LOCATION'
     O                                   69 'QTY/BOX'
     O                         W#MON1    77
     O                         W#MON2    85
     O                         W#MON3    94
     O                         W#MON4   102
     O                         W#MON5   110
     O                         W#MON6   118
     O        E   07           @HED
     O                         @LINE    132
     O        E 1              @DTL
     O                         W8SHN1     8
     O                         W8SHN2    14
     O                         W8SHN3    17
     O                         A8NONY    25
     O                         W#DVNM    41
     O                         A8NKOJ    43
     O                         A8NUKE    48
     O                         A8LOC     58
     O                         A8BOXQ1   69
     O                         W#DBX11   77
     O                         W#DBX21   85
     O                         W#DBX31   94
     O                         W#DBX41  102
     O                         W#DBX51  110
     O                         W#DBX61  118
     O        E 11             @TOT
     O                         W#TOT     69
     O                         W#SBX11   77
     O                         W#SBX21   85
     O                         W#SBX31   94
     O                         W#SBX41  102
     O                         W#SBX51  110
     O                         W#SBX61  118
** TTL(TITLE)
<< ANDROID RETURNABLE PART SHIPMENT HISTORY(# OF BOX) >>
** TOT(TITLE FOR TOTAL)
PART# TOTAL
GRAND TOTAL
** CMD
OVRPRTF FILE(QPRINT) OUTQ(        )
