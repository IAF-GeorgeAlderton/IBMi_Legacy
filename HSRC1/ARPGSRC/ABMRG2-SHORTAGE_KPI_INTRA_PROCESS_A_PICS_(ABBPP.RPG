     H            Y.
     F** ABMRG2 *********************************************
     F*未納ＫＰＩ工程内・A-PICS(ABBPP70)
     F*   HOTTA.          2018.10.05                        *
     F*******************************************************
     FABBPL71 IF  E           K        DISK
     FABMWPG2 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I            DS
     I                                        1   80K@DATE
     I                                        1   60K@NTYM
     I                                        7   80K@NTDD
      *
     I            DS
     I                                        1   80Z@DATE
     I                                        1   60Z@NTYM
     I                                        7   80Z@NTDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NTYM  60
     C                     PARM           P9APCS  70
     C                     PARM           P9KTNA  70
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     Z-ADD0         K@DATE
     C                     Z-ADDP@NTYM    K@NTYM
     C                     Z-ADD1         K@NTDD
     C                     Z-ADDP@NTYM    Z@NTYM
     C                     Z-ADD99        Z@NTDD
     C                     Z-ADD0         P9APCS
     C                     Z-ADD0         P9KTNA
     C           K@DATE    SETLLABBPL71
     C                     READ ABBPL71                  80
     C           *IN80     DOWEQ'0'
     C           A7DATE    ANDLEZ@DATE
     C           A7TIME    IFLE 070000
     C           A7KQTY    ANDNE0
     C                     EXSR #SB200
     C                     ENDIF
     C                     READ ABBPL71                  80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C                     MOVEL*BLANK    ZETI    4
     C                     MOVEL*BLANK    TEHI    3
     C           4         SUBSTA7BRCD:2  ZETI
     C           3         SUBSTA7BRCD:6  TEHI
     C           KEYW      KLIST
     C                     KFLD           ZETI
     C                     KFLD           TEHI
     C           A7KNID    IFEQ 'A'
     C           KEYW      CHAINABMWPG21             22
     C           *IN22     IFEQ '1'
     C                     CLEARABMWPG21
     C                     MOVELZETI      W2ZETI
     C                     MOVELTEHI      W2TEHI
     C                     Z-ADD1         W2CNT
     C                     WRITEABMWPG21
     C                     ELSE
     C                     ADD  1         W2CNT
     C                     UPDATABMWPG21
     C                     ENDIF
     C                     ENDIF
      *
     C           A7KNID    IFEQ 'A'
     C           *IN22     IFEQ '1'
     C                     ADD  A7KQTY    P9APCS
     C                     ENDIF
     C                     ELSE
     C                     EXSR #SB210
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *工程内                                            *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     MOVELA7MCHN    A7MCN1  1
     C           A7MCN1    IFEQ 'H'
     C           A7MCN1    OREQ 'R'
     C           A7MCN1    OREQ 'T'
     C           A7MCN1    OREQ 'S'
     C           A7KNID    IFNE 'A'
     C           A7KNID    ANDNE'P'
     C                     ADD  A7KQTY    P9KTNA
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
