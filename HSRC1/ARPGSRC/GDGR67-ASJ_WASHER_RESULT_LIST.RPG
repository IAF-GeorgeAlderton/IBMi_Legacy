     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #WRT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@YM    6
      *
     C           K#KEYX    KLIST
     C                     KFLD           L1TKR1
     C                     KFLD           L1TKR2
     C                     KFLD           L1TKR3
     C                     KFLD           L1TKR4
     C           K#KEY     KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           K#APP     KLIST
     C                     KFLD           MCSHN1
     C                     KFLD           MCSHN2
     C                     KFLD           MCSHN3
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C           K#MCN     KLIST
     C                     KFLD           MCSHN1
     C                     KFLD           MCSHN2
     C                     KFLD           MCSHN3
     C           K#AGD     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
      *
     C                     MOVELP@YM      K@YY
     C                     MOVE P@YM      K@MM
     C                     Z-ADD1         K@DD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     Z-ADD*ZERO     @DAY    20
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @DAY
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN80     DOUEQ*ON
     C                     READ AKBPL03                  80
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STYY    ANDEQ9999
     C           L1BMON    ANDEQ8990
      *
     C           K#KEYX    SETGTAKBPL03
     C           *IN81     DOUEQ*ON
     C           K#KEYX    REDPEAKBPL03                  81
     C           *IN81     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STYY    ANDEQ9999
     C*****      L1UKHZ    ANDLEK@YMD
      *
     C                     CLEARGDGWP671
      *
     C                     MOVE L1TKRO    WLOC
     C                     MOVE L1SHN1    WPART1
     C                     MOVE L1SHN2    WPART2
     C                     MOVE L1SHN3    WPART3
     C                     Z-ADDL1SYOS    WQBOX
     C           L1KTSU    MULT @DAY      WSETQ
      *
      * ACTUAL BOX
     C                     EXSR #BOX
     C                     Z-ADD@@QTY     WACTQ
     C                     WRITEGDGWP671
     C           K#KEYX    SETGTAKBPL03
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SHIPPED BOXES
      *------------------------------------------------------
     C           #BOX      BEGSR
      *
     C                     Z-ADD*ZERO     @@QTY  112
     C                     Z-ADD*ZERO     W@QTY  112
     C           K#KEY     SETLLMCENP131
     C           *IN94     DOUEQ*ON
     C           K#KEY     READEMCENP131                 94
     C           *IN94     IFEQ *OFF
     C                     EXSR #BOX1
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SHIPPED BOXES
      *------------------------------------------------------
     C           #BOX1     BEGSR
      *
     C                     Z-ADD*ZERO     WKNEC   10
     C           K#MCN     SETLLFCEPL01
     C           *IN90     DOUEQ*ON
     C           K#MCN     READEFCEPL01                  90
     C           *IN90     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     Z-ADD1         B       10
     C           L1HIN     LOKUPCOM,B                    79
     C           *IN79     IFEQ '1'
     C                     Z-ADDNEC,B     WKNEC
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C* ACTUAL
     C           K#APP     SETLLAB#PL18
     C           *IN90     DOUEQ*ON
     C           K#APP     READEAB#PL18                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ' '
      *
     C           BASRYO    MULT WKNEC     WKSAIZ  92
     C                     ADD  WKSAIZ    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
