     H            Y.
     F** MRAR00 *********************************************
     F* NEW PRODUCTION CONTROL                              *
     F*     TRANCOM ITS.           2012.09.11               *
     F*******************************************************
     FMRAPW00 CF  E                    WORKSTN
      *
     E                    ER      1  15 60
      *
     C           *ENTRY    PLIST
     C                     PARM           P1NO1   1
     C                     PARM           P1NO2   1
     C                     PARM           PCMD    2
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     SELEC
     C           P1NO1     WHEQ '1'
     C                     MOVELP1NO1     D1NO1
     C                     MOVEL'02'      DSPSW   2
     C           P1NO1     WHEQ '2'
     C                     MOVELP1NO1     D1NO1
     C                     MOVEL'03'      DSPSW   2
     C                     ENDSL
     C                     MOVEL*BLANK    PCMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'03'
     C                     EXSR #SB230
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTMRAPW001
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     SELEC
     C           D1NO1     WHEQ '1'
     C                     MOVEL'02'      DSPSW
     C           D1NO1     WHEQ '2'
     C                     MOVEL'03'      DSPSW
     C                     OTHER
     C                     SETON                     3199
     C                     MOVELER,1      D1ERR
     C                     GOTO ESB210
     C                     ENDSL
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTMRAPW002
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D1ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1NO1
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     SELEC
     C           D2NO2     WHEQ '1'
     C           D2NO2     OREQ '2'
     C           D2NO2     OREQ '3'
     C           D2NO2     OREQ '4'
     C                     MOVELD1NO1     P1NO1
     C                     MOVELD2NO2     P1NO2
     C                     MOVEL'05'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     OTHER
     C                     SETON                     3199
     C                     MOVELER,2      D2ERR
     C                     GOTO ESB220
     C                     ENDSL
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB230    BEGSR
      *
     C                     EXFMTMRAPW003
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D3ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1NO1
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB230
     C                     ENDIF
      *
     C                     SELEC
     C           D3NO2     WHEQ '1'
     C           D3NO2     OREQ '2'
     C                     MOVELD1NO1     P1NO1
     C                     MOVELD3NO2     P1NO2
     C                     MOVEL'05'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     OTHER
     C                     SETON                     3199
     C                     MOVELER,1      D3ERR
     C                     GOTO ESB230
     C                     ENDSL
      *
     CSR         ESB230    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
**
ER-1 INPUT NO.(1,2)
ER-2 INPUT NO.(1,2,3,4)
ER-3
ER-4
ER-5
ER-6
ER-7
ER-8
