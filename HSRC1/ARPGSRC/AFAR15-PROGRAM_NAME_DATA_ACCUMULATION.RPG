     C                     MOVE *BLANK    WATK2   2
     C                     MOVE *BLANK    WATK3   2
     C                     MOVE *BLANK    WATK4   1
     C           WTKR      LOKUPHTR,A                    14
     C           *IN14     IFEQ '1'
