      *
     C           *IN14     IFEQ '0'
     C                     Z-ADD1         A       20
     C                     Z-ADD0         X       20
     C           1         DO   15        A
     C                     MOVELNUKH,A    WUKH    80
     C           *DATE     IFLT WUKH
     C           OKOT,A    IFNE *BLANK
     C           OKOT,A    IFNE 'ARS'
     C                     ADD  1         X
     C                     MOVE OKOT,A    HKT,X
     C                     Z-ADDOKBM,A    HBM,X
     C                     MOVE OTKR,A    HTR,X
     C                     MOVE OTKR,A    WTKR
     C                     END
     C                     END
     C                     ELSE
     C           NKOT,A    IFNE *BLANK
