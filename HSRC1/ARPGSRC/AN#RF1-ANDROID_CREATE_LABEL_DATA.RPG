     C**************************************************************************
     C*  @MOVE1 SUBROUTINE: MOVE DATA FROM DBFILES TO FILE ABR7P01
     C**************************************************************************
     C           @MOVE1    BEGSR
     C*
     C                     MOVE FCDELY    F7NONY
     C                     MOVE '*'       @DATA   1
TCHK C                     MOVELFCCPAR    F7PBAR
TCHK C                     MOVELFCCPAR    F7PART
     C***                  MOVEAFCCPAR    PNO
     C***                  MOVE *BLANK    NOB
     C***        1         DO   20        M
     C***        PNO,M     IFEQ *BLANK
     C***        M         ADD  1         P
     C***        PNO,P     IFEQ *BLANK
     C***                  LEAVE
     C***                  ENDIF
     C***                  MOVE '-'       NOB,M
     C***                  ELSE
     C***                  MOVE PNO,M     NOB,M
     C***                  ENDIF
     C***                  ENDDO
      ***
     C***                  MOVEANOB       F7PART
     C*
     C* FIND THE FIRST BLANK BEFORE THE SUFIX PART NUMBER
     C***                  Z-ADD20        M       20
     C***                  MOVEAFCCPAR    PNO
     C***        PNO,M     DOUNE*BLANK
     C***                  SUB  1         M
     C***                  END
     C***
     C***        PNO,M     DOUEQ*BLANK
     C***                  SUB  1         M
