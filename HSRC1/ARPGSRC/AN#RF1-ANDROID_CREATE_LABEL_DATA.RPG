     C  N60                MOVELMES,5     FMEMSG
     C                     SETON                     3160
     C                     ENDIF
      *
     C           D@SHDT    IFEQ *ZERO
     C  N60                MOVELMES,2     FMEMSG
     C                     SETON                     3260
     C                     ENDIF
      *
     C           D@BIN     IFEQ *ZERO
     C  N60                MOVELMES,6     FMEMSG
