      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      * N
     C                     Z-ADD*DATE     W@DATE
     C                     Z-ADDW@DTYM    D1YMN   60
      * N+1
     C                     Z-ADDW@DTYM    W@P1YM
     C           W@DTMM    IFEQ 12
     C                     ADD  1         W@P1YY
     C                     Z-ADD1         W@P1MM
     C                     ELSE
     C                     ADD  1         W@P1MM
     C                     ENDIF
     C                     Z-ADDW@P1YM    D1YMN1  60
      * N+2
     C                     Z-ADDW@P1YM    W@P2YM
     C           W@P1MM    IFEQ 12
     C                     ADD  1         W@P2YY
     C                     Z-ADD1         W@P2MM
     C                     ELSE
     C                     ADD  1         W@P2MM
     C                     ENDIF
     C                     Z-ADDW@P2YM    D1YMN2  60
      * N+3
     C                     Z-ADDW@P2YM    W@P3YM
     C           W@P2MM    IFEQ 12
     C                     ADD  1         W@P3YY
     C                     Z-ADD1         W@P3MM
     C                     ELSE
     C                     ADD  1         W@P3MM
     C                     ENDIF
     C                     Z-ADDW@P3YM    D1YMN3  60
      * N+4
     C                     Z-ADDW@P3YM    W@P4YM
     C           W@P3MM    IFEQ 12
     C                     ADD  1         W@P4YY
     C                     Z-ADD1         W@P4MM
     C                     ELSE
     C                     ADD  1         W@P4MM
     C                     ENDIF
     C                     Z-ADDW@P4YM    D1YMN4  60
      * N+5
     C                     Z-ADDW@P4YM    W@P5YM
     C           W@P4MM    IFEQ 12
     C                     ADD  1         W@P5YY
     C                     Z-ADD1         W@P5MM
     C                     ELSE
     C                     ADD  1         W@P5MM
     C                     ENDIF
     C                     Z-ADDW@P5YM    D1YMN5  60
      * N+6
     C                     Z-ADDW@P5YM    W@P6YM
     C           W@P5MM    IFEQ 12
     C                     ADD  1         W@P6YY
     C                     Z-ADD1         W@P6MM
     C                     ELSE
     C                     ADD  1         W@P6MM
     C                     ENDIF
     C                     Z-ADDW@P6YM    D1YMN6  60
      *稼働日数
     C                     Z-ADD0         D1KDN   31
     C                     Z-ADD0         D1KDN1  31
     C                     Z-ADD0         D1KDN2  31
     C                     Z-ADD0         D1KDN3  31
     C                     Z-ADD0         D1KDN4  31
     C                     Z-ADD0         D1KDN5  31
