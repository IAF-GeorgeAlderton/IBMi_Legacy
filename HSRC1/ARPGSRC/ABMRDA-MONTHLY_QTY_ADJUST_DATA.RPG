     C           *LOVAL    SETLLABMPPD11
     C                     READ ABMPPD11                 24
     C           *IN24     DOWEQ'0'
     C           DDSKJY    IFEQ 'D'
     C           DDSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDDDSTAT    D2STAT  60
     C                     Z-ADDDDEND     D2END   60
     C                     Z-ADDDDQTY     D2QTY  110
     C                     EXSR #SB150
     C                     EXSR #SB200
     C           FCE       IFEQ '0'
     C                     EXSR #SB150
     C                     EXSR #SB210
     C                     ENDIF
     C                     ENDIF
     C                     READ ABMPPD11                 24
     C                     ENDDO
      *****************
      *構成品１
