     CSR         #SB200    BEGSR
      *
     C           KEYFCE    KLIST
     C                     KFLD           DDSHN1
     C                     KFLD           DDSHN2
     C                     KFLD           DDSHN3
      *
     C                     MOVEL'0'       FCE     1
     C           KEYFCE    CHAINFCEPL011             81
     C           *IN81     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       FCE
     C**         A2GEKN    MULT A2SOZI    WKSRY  162
     C                     Z-ADD0         WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    JRY1N
     C                     ADD  WKSRY@    JRY1N1
     C                     ADD  WKSRY@    JRY1N2
     C                     ADD  WKSRY@    JRY1N3
     C                     ADD  WKSRY@    JRY1N4
     C                     ADD  WKSRY@    JRY1N5
     C                     MOVELA2ZANM    W@ZANM 15
     C                     Z-ADDA2KAZI    W@KAZI  52
     C                     Z-ADDA2SOZI    W@SOZI  72
     C                     EXSR #PPD1@
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C           KEYMRH    KLIST
     C                     KFLD           DDSHN1  5
     C                     KFLD           DDSHN2  5
     C                     KFLD           DDSHN3  2
      *
     C                     Z-ADD0         EAGEKN 110
     C           KEYMRH    CHAINMRHPL211             81
     C           *IN81     IFEQ '0'
     C           EAGSJY    IFEQ 'D'
     C           EAGSHZ    ANDLE*DATE
     C                     ELSE
     C******     EAGEKN    MULT EASOZI    WKSRY  162
     C                     Z-ADD0         WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    JRY1N
     C                     ADD  WKSRY@    JRY1N1
     C                     ADD  WKSRY@    JRY1N2
     C                     ADD  WKSRY@    JRY1N3
     C                     ADD  WKSRY@    JRY1N4
     C                     ADD  WKSRY@    JRY1N5
     C                     MOVELEAZANM    W@ZANM 15
     C                     Z-ADDEAKAZI    W@KAZI  52
     C                     Z-ADDEASOZI    W@SOZI  72
     C                     EXSR #PPD1@
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * ABMPPD1                                            *
      *----------------------------------------------------*
     CSR         #PPD1@    BEGSR
      *
     C           D1YMN     IFGE D2STAT
     C           D1YMN     ANDLED2END
     C           D2QTY     DIV  20        QTY20   90
     C           QTY20     MULT D1KDN     QTY20
     C           QTY20     MULT W@SOZI    WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    XRY1N
     C                     ENDIF
      *
     C           D1YMN1    IFGE D2STAT
     C           D1YMN1    ANDLED2END
     C           D2QTY     DIV  20        QTY20   90
     C           QTY20     MULT D1KDN1    QTY20
     C           QTY20     MULT W@SOZI    WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    XRY1N1
     C                     ENDIF
      *
     C           D1YMN2    IFGE D2STAT
     C           D1YMN2    ANDLED2END
     C           D2QTY     DIV  20        QTY20   90
     C           QTY20     MULT D1KDN2    QTY20
     C           QTY20     MULT W@SOZI    WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    XRY1N2
     C                     ENDIF
      *
     C           D1YMN3    IFGE D2STAT
     C           D1YMN3    ANDLED2END
     C           D2QTY     DIV  20        QTY20   90
     C           QTY20     MULT D1KDN3    QTY20
     C           QTY20     MULT W@SOZI    WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    XRY1N3
     C                     ENDIF
      *
     C           D1YMN4    IFGE D2STAT
     C           D1YMN4    ANDLED2END
     C           D2QTY     DIV  20        QTY20   90
     C           QTY20     MULT D1KDN4    QTY20
     C           QTY20     MULT W@SOZI    WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    XRY1N4
     C                     ENDIF
      *
     C           D1YMN5    IFGE D2STAT
     C           D1YMN5    ANDLED2END
     C           D2QTY     DIV  20        QTY20   90
     C           QTY20     MULT D1KDN5    QTY20
     C           QTY20     MULT W@SOZI    WKSRY  162
     C           WKSRY     DIV  1000      WKSRY@  90H
     C                     ADD  WKSRY@    XRY1N5
     C                     ENDIF
      *
     C           JRY1N     DIV  20        SRY1N
     C                     MULT D1KDN     SRY1N
     C                     ADD  XRY1N     SRY1N
      *
     C           JRY1N1    DIV  20        SRY1N1
     C                     MULT D1KDN1    SRY1N1
     C                     ADD  XRY1N1    SRY1N1
      *
     C           JRY1N2    DIV  20        SRY1N2
     C                     MULT D1KDN2    SRY1N2
     C                     ADD  XRY1N2    SRY1N2
      *
     C           JRY1N3    DIV  20        SRY1N3
     C                     MULT D1KDN3    SRY1N3
     C                     ADD  XRY1N3    SRY1N3
      *
     C           JRY1N4    DIV  20        SRY1N4
     C                     MULT D1KDN4    SRY1N4
     C                     ADD  XRY1N4    SRY1N4
      *
     C           JRY1N5    DIV  20        SRY1N5
     C                     MULT D1KDN5    SRY1N5
     C                     ADD  XRY1N5    SRY1N5
      *
     CSR         EPPD1@    ENDSR
      *----------------------------------------------------*
      *稼働日数                                          *
      *----------------------------------------------------*
     CSR         #SBAGD    BEGSR
      *
     C           KEYF8     KLIST
     C                     KFLD           #KKAYY  40
     C                     KFLD           #KKAMM  20
     C                     Z-ADD#KYY      #KKAYY
     C                     Z-ADD#KMM      #KKAMM
     C                     Z-ADD0         WKADO   31
     C           KEYF8     SETLLAGDPL121
     C           KEYF8     READEAGDPL121                 77
     C           *IN77     DOWEQ'0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       WKADO
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       WKADO
     C                     ENDIF
     C           KEYF8     READEAGDPL121                 77
     C                     ENDDO
      *
     C           KEYF8     SETLLABMPPL11
     C           KEYF8     READEABMPPL11                 77
     C           *IN77     DOWEQ'0'
     C                     Z-ADDLLKADO    WKADO
     C           KEYF8     READEABMPPL11                 77
     C                     ENDDO
      *
     CSR         ESBAGD    ENDSR
      *----------------------------------------------------*
      *ワーク
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYWK     KLIST
     C                     KFLD           W@ZANM 15
     C                     KFLD           W@KAZI  52
     C           KEYWK     CHAINABMWPDA1             85
     C           *IN85     IFEQ '0'
     C                     ADD  SRY1N     W1S1N
     C                     ADD  SRY1N1    W1S1N1
     C                     ADD  SRY1N2    W1S1N2
     C                     ADD  SRY1N3    W1S1N3
     C                     ADD  SRY1N4    W1S1N4
     C                     ADD  SRY1N5    W1S1N5
     C                     UPDATABMWPDA1
     C                     ELSE
     C                     CLEARABMWPDA1
     C                     MOVELW@ZANM    W1ZANM
     C                     Z-ADDW@KAZI    W1KAZI
     C                     Z-ADDSRY1N     W1S1N
     C                     Z-ADDSRY1N1    W1S1N1
     C                     Z-ADDSRY1N2    W1S1N2
     C                     Z-ADDSRY1N3    W1S1N3
     C                     Z-ADDSRY1N4    W1S1N4
     C                     Z-ADDSRY1N5    W1S1N5
     C                     WRITEABMWPDA1
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
