      *================================================================
      *   MAIN
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P$NONY  4        DELIVERY
     C                     PARM           P@FRM   80       DATE START
     C                     PARM           P@TO    80       DATE END
      *------------------------------------------------------------
     C*
     C                     MOVE P$NONY    K@NONY  40       DELIVERY
     C                     MOVELP@FRM     K@FRM   8        DATE START
     C                     MOVELP@TO      K@TO    8        DATE END
     C*
     C           KEY01     KLIST
     C                     KFLD           CANONY           DELIVERY CODE
     C                     KFLD           CANKOJ           DELIVERY FACTORY
     C                     KFLD           CANUKE           DELIVERY RECEIVING
     C                     KFLD           CASHID           SHIP DATE
     C                     KFLD           CATRKB           IAF TRUCK BIN#
     C                     KFLD           CAIAFP           IAF PALLET CODE
     C*
     C           K@FRM     SETLLAL#PL09
      *-------------------------*
S1   C                     DO   *HIVAL
     C*
     C                     READ AL#PL09                  90
 S2  C  N90      CASHID    IFGT K@TO
     C                     SETON                     90
 E2  C                     ENDIF
     C   90                LEAVE
     C*
 S2  C           CASKJY    IFNE *BLANK
     C                     ITER
 E2  C                     ENDIF
     C*
 S2  C           K@NONY    IFEQ 9999                       DELIVERY
  S3 C           CANONY    IFNE 0541
     C           CANONY    ANDNE3764
     C           CANONY    ANDNE3481
     C           CANONY    ANDNE3503
     C           CANONY    ANDNE3804
     C           CANONY    ANDNE3347
     C           CANONY    ANDNE3220
     C           CANONY    ANDNE3851
     C           CANONY    ANDNE3931
     C           CANONY    ANDNE3428
JW1  C           CANONY    ANDNE3226
JW2  C           CANONY    ANDNE3770
JW2  C           CANONY    ANDNE3941
     C                     ITER
  E3 C                     ENDIF
 X2  C                     ELSE
  S3 C           CANONY    IFNE K@NONY                     DELIVERY
     C                     ITER
  E3 C                     ENDIF
 E2  C                     ENDIF
     C*
     C           KEY01     CHAINAL#WP18              91
     C*         *
 S2  C           *IN91     IFEQ *ON
     C                     CLEARAL#WP181
     C                     Z-ADDCANONY    AWNONY           DELIVERY CODE
     C                     MOVE CANKOJ    AWNKOJ           DELIVERY FACTORY
     C                     MOVE CANUKE    AWNUKE           DELIVERY RECEIVING
     C                     MOVE CASHID    AWSHID           SHIP DATE
     C                     MOVE CATRKB    AWTRKB           IAF TRUCK BIN#
     C                     MOVE CAIAFP    AWIAFP           IAF PALLET CODE
     C                     Z-ADD0         AWBOXS           # OF BOX
     C                     Z-ADD0         AWPART           # OF PART KIND
     C                     MOVE *BLANK    #HN              PART#
 E2  C                     ENDIF
     C*         *
     C                     ADD  1         AWBOXS           # OF BOX
     C* ('PART#')
     C           CAMHN     LOKUP#HN                      50:EQ
 S2  C           *IN50     IFEQ *OFF
     C                     ADD  1         AWPART           # OF PART KIND
     C                     Z-ADD1         Z       20
     C           *BLANK    LOKUP#HN,Z                    51:EQ
     C   51                MOVE CAMHN     #HN,Z            PART#
 E2  C                     ENDIF
     C*         *
     C   91                WRITEAL#WP181
     C  N91                UPDATAL#WP181
     C*         *
E1   C                     ENDDO
      *-------------------------*
      *-------------------------*
      *-------------------------*
     C           *LOVAL    SETLLAL#WP18
     C                     MOVE ' '       @1ST    1
      *-------------------------*
S1   C                     DO   *HIVAL
     C                     READ AL#WP18                  90
     C   90                LEAVE
     C           @1ST      IFEQ ' '
     C                     MOVE '*'       @1ST
     C                     EXCPT$HED
     C                     ENDIF
     C                     EXSR ##NONY
     C                     EXCPT$DATA
E1   C                     ENDDO
      *-------------------------*
      *
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *
      *================================================================
     C           ##NONY    BEGSR
     C                     MOVEL*BLANK    $$BNM   5
     C*
     C                     SELEC
     C           AWNONY    WHEQ 0541
     C                     MOVEL'NUMMI'   $$BNM
     C           AWNONY    WHEQ 3764
     C                     MOVEL'TMMAL'   $$BNM
     C           AWNONY    WHEQ 3481
     C                     MOVEL'TMMBC'   $$BNM
     C           AWNONY    WHEQ 3503
     C                     MOVEL'TMMC '   $$BNM
     C           AWNONY    WHEQ 3804
     C                     MOVEL'TMMI '   $$BNM
     C           AWNONY    WHEQ 3347
     C                     MOVEL'TMMK '   $$BNM
     C           AWNONY    WHEQ 3220
     C                     MOVEL'TMMNK'   $$BNM
     C           AWNONY    WHEQ 3851
     C                     MOVEL'TMMTX'   $$BNM
     C           AWNONY    WHEQ 3931
     C                     MOVEL'TMMWV'   $$BNM
     C           AWNONY    WHEQ 3428
     C                     MOVEL'TMMMS'   $$BNM
JW1  C           AWNONY    WHEQ 3226
"    C                     MOVEL'TMMGT'   $$BNM
JW2  C           AWNONY    WHEQ 3770
"    C                     MOVEL'MTMUS'   $$BNM
JW2  C           AWNONY    WHEQ 3941
"    C                     MOVEL'TBMNC'   $$BNM
     C                     ENDSL
     C*
     C                     ENDSR
      *================================================================
      *CSV..NAME,DELIVERY,DOCK,SHIP DATE,BIN,PALLET#,# OF BOX,# OF PART KIND
      *================================================================
     OAL#WP182E                $HED
     O                                      'NAME'
     O                                      ','
     O                                      'DELIVERY'
     O                                      ','
     O                                      'FACTORY'
     O                                      ','
     O                                      'DOCK'
     O                                      ','
     O                                      'SHIP DATE'
     O                                      ','
     O                                      'BIN'
     O                                      ','
     O                                      'PALLET#'
     O                                      ','
     O                                      '# OF BOX'
     O                                      ','
     O                                      '# OF PART KIND'
     O                                      ','
      *
     O        E                $DATA
     O                         $$BNM
     O                                      ','
     O                         AWNONY
     O                                      ','
     O                         AWNKOJ
     O                                      ','
     O                         AWNUKE
     O                                      ','
     O                         AWSHID
     O                                      ','
     O                         AWTRKB
     O                                      ','
     O                         AWIAFP
     O                                      ','
     O                         AWBOXS
     O                                      ','
     O                         AWPART
     O                                      ','
