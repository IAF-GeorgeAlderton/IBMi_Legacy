     H            Y.
     F** ALBR54 **********************************
     F*  ASSORT OF KANBAN DATA(30POCKETS)        *
     F*   (TX-5375)                              *
     F* CODING:K.OKACHI               1997.07.17 *
     F******************************** ALBR54 ****
     FALBWP43 IP  E           K        DISK
     FOAAPL13 IF  E           K        DISK
     FALBWP46 O   E           K        DISK                      A
     E                    PKR        30  1               POKET REV.
     I            DS
     I                                        1   5 TKR
     I                                        1   1 ALTKR1
     I                                        2   3 ALTKR2
     I                                        4   5 ALTKR3
     C*
     C           *ENTRY    PLIST
     C                     PARM           @BIN
     C*
     C           KEY1      KLIST
     C                     KFLD           @BIN    2
     C                     KFLD           USE
     C*  SYOKI SETTEI & SAISYUU POKETTO
     C           *IN77     IFEQ '0'
     C                     MOVE *BLANK    PKR
     C                     MOVE *BLANK    WZETI   4
     C                     MOVE *BLANK    WTKR    5
     C                     Z-ADD0         X       30
     C                     Z-ADD0         EPK     30
     C                     Z-ADD1         WSNO    20
     C                     Z-ADD1         BSNO    20
     C                     MOVE '01'      USE     2
     C*
     C                     SETOF                     30
     C           KEY1      SETGTOAAPL131
     C           KEY1      REDPEOAAPL131                 30
     C           *IN30     IFEQ '1'
     C                     GOTO END
     C                     END
     C           *IN30     IFEQ '0'
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     GOTO END
     C                     END
     C                     Z-ADDR3PKET    EPK
     C*
     C                     SETON                     77
     C                     END
     C*   ONAJI ZETAI BANGOU WA OUTPUT SINAI
     C           ALZETI    IFEQ WZETI
     C                     GOTO END
     C                     END
     C           TKR       IFEQ *BLANK
     C                     GOTO END
     C                     END
     C*   KOUJYOU TURO RETU GA ONAJI TOKI MAE NO POKETTO BANGOU
     C           TKR       IFEQ WTKR
     C                     GOTO WRT
     C                     END
     C*  SIYOU KUBUN GA '01' NO POKETTO NO. WO SAGASU
     C                     SETOF                     30
     C           KEY1      SETLLOAAPL131
     C           LOOP1     TAG
     C           KEY1      READEOAAPL131                 30
     C           *IN30     IFEQ '1'
     C                     GOTO LOOP1
     C                     END
     C           *IN30     IFEQ '0'
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     GOTO LOOP1
     C                     END
     C*
     C                     Z-ADDR3PKET    X
     C*    POKETTO NI SIWAKETARA '*'
     C           PKR,X     IFEQ *BLANK
     C                     MOVE '*'       PKR,X
     C                     ELSE
     C                     GOTO LOOP1
     C                     END
     C*
     C*
     C           WRT       TAG
     C           R3PKET    IFEQ EPK
     C                     Z-ADDBSNO      WSNO
     C                     END
     C                     MOVE ALZETI    A1ZETI
     C                     MOVE ALTKR1    A1TKR1
     C                     MOVE ALTKR2    A1TKR2
     C                     MOVE ALTKR3    A1TKR3
     C                     MOVE ALTKR4    A1TKR4
     C                     Z-ADDX         A1POCK
     C                     Z-ADDWSNO      A1SNO
     C                     WRITEALBWP461
     C* POKETTO GA SAISYUU POKETTO NARA WSNO NI 1 WO TASU
     C           R3PKET    IFEQ EPK
     C                     Z-ADDWSNO      BSNO
     C                     MOVE *BLANK    PKR
     C                     ADD  1         WSNO
     C                     END
     C*
     C           END       TAG
     C                     MOVE ALZETI    WZETI
     C                     MOVE TKR       WTKR
