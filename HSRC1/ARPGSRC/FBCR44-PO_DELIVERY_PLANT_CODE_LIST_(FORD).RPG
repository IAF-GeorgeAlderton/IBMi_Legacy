     H            Y/                                    1
     H**FBCR44  *******************************************************
     H* PO/DELIVERY/PLANT CODE LIST (FORD)                            *
     H* JW       2018.03.20                                           *
     H*****************************************************************
     FFBCPP30 IF  E           K        DISK
     FABFDL02 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FFBCWP44 UF  E           K        DISK                      A    UC
     FFBCWP45 O   E                    DISK
      *================================================================
     E                    TB      1   1  1
     E                    PO          7  5
     E                    PT         10  6
     E                    DC         10  6
      *
     I            DS
     I                                        1  35 PO
     I                                        1   5 F4PO1
     I                                        6  10 F4PO2
     I                                       11  15 F4PO3
     I                                       16  20 F4PO4
     I                                       21  25 F4PO5
     I                                       26  30 F4PO6
     I                                       31  35 F4PO7
      *
     I            DS
     I                                        1  60 PT
     I                                        1   6 F4PT1
     I                                        7  12 F4PT2
     I                                       13  18 F4PT3
     I                                       19  24 F4PT4
     I                                       25  30 F4PT5
     I                                       31  36 F4PT6
     I                                       37  42 F4PT7
     I                                       43  48 F4PT8
     I                                       49  54 F4PT9
     I                                       55  60 F4PTA
      *
     I            DS
     I                                        1  60 DC
     I                                        1   6 F4DC1
     I                                        7  12 F4DC2
     I                                       13  18 F4DC3
     I                                       19  24 F4DC4
     I                                       25  30 F4DC5
     I                                       31  36 F4DC6
     I                                       37  42 F4DC7
     I                                       43  48 F4DC8
     I                                       49  54 F4DC9
     I                                       55  60 F4DCA
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     OPEN FBCWP44
     C                     EXSR #INIT
      * READ FBCPP30
     C                     EXSR #PP30
      * READ ABFDP01
     C                     EXSR #DP01
     C                     CLOSEFBCWP44
      *
      * OUTOUT TO FBCWP45
     C                     OPEN FBCWP44
     C                     EXSR #OUT
     C                     CLOSEFBCWP44
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *   << READ FBCPP30 >>
      *===============================================================
     C           #PP30     BEGSR
      *
     C           *LOVAL    SETLLFBCPP30
     C           *IN95     DOWEQ*OFF
     C                     READ FBCPP30                  95
     C           *IN95     IFEQ *OFF
     C           FSSKJY    ANDNE'D'
     C                     MOVELTB,1      LTR5
     C                     MOVE FSNONY    LTR5
     C                     MOVELLTR5      K#NONY 10
     C           K#NONY    CHAINFBCWP44              98
     C           *IN98     IFEQ *OFF
     C                     EXSR #UPD30
     C                     ELSE
     C                     EXSR #WRT30
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *===============================================================
      *   << UPDATE FBCWP44 >>
      *===============================================================
     C           #UPD30    BEGSR
      *
     C           1         DO   7         IX      20
     C           PO,IX     IFEQ *BLANK
     C                     MOVELFSSHP1    LTR2    2
     C                     MOVELTB,1      LTR3    3
     C                     MOVE LTR2      LTR3
     C                     MOVELLTR3      PO,IX
     C                     UPDATFBCWP441
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *===============================================================
      *   << WRITE FBCWP44 >>
      *===============================================================
     C           #WRT30    BEGSR
      *
     C                     CLEARFBCWP441
     C                     MOVELTB,1      LTR5    5
     C                     MOVE FSNONY    LTR5
     C                     MOVELLTR5      F4NONY
      *
     C                     MOVELFSSHP1    LTR2
     C                     MOVELTB,1      LTR3
     C                     MOVE LTR2      LTR3
     C                     MOVELLTR3      F4PO1
      * GET NAME
     C           FSNONY    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    F4NAME
     C                     ENDIF
     C                     WRITEFBCWP441
      *
     C                     ENDSR
      *===============================================================
      *   << READ ABFPP01 >>
      *===============================================================
     C           #DP01     BEGSR
      *
     C           *LOVAL    SETLLABFDL02
     C           *IN96     DOWEQ*OFF
     C                     READ ABFDL02                  96
     C           *IN96     IFEQ *OFF
     C           QASKJY    ANDNE'D'
     C           QANONY    IFNE SVNONY
     C           QAPLAN    ORNE SVPLAN
     C           QADOCK    ORNE SVDOCK
     C                     MOVELTB,1      LTR5
     C                     MOVE QANONY    LTR5
      * SAVE KEY
     C                     Z-ADDQANONY    SVNONY
     C                     MOVELQAPLAN    SVPLAN
     C                     MOVELQADOCK    SVDOCK
      *
     C                     MOVELLTR5      K#NONY 10
     C           K#NONY    CHAINFBCWP44              98
     C           *IN98     IFEQ *OFF
     C                     EXSR #UPD01
     C                     ELSE
     C                     EXSR #WRT01
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *===============================================================
      *   << UPDATE FBCWP44 >>
      *===============================================================
     C           #UPD01    BEGSR
      *
     C           1         DO   10        IX      20
     C           PT,IX     IFEQ *BLANK
     C                     MOVELQAPLAN    PT,IX
      *
     C                     MOVELQADOCK    LTR2
     C                     MOVELTB,1      LTR3
     C                     MOVE LTR2      LTR3
     C                     MOVELLTR3      DC,IX
     C                     UPDATFBCWP441
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *===============================================================
      *   << WRITE FBCWP44 >>
      *===============================================================
     C           #WRT01    BEGSR
      *
     C                     CLEARFBCWP441
      *
     C                     MOVELTB,1      LTR5
     C                     MOVE QANONY    LTR5
     C                     MOVELLTR5      F4NONY
      *
     C                     MOVELQAPLAN    F4PT1
      *
     C                     MOVELQADOCK    LTR2
     C                     MOVELTB,1      LTR3
     C                     MOVE LTR2      LTR3
     C                     MOVELLTR3      F4DC1
      * GET NAME
     C           QANONY    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    F4NAME
     C                     ENDIF
     C                     WRITEFBCWP441
      *
     C                     ENDSR
      *===============================================================
      *   << OUT  >>
      *===============================================================
     C           #OUT      BEGSR
      *
     C           *LOVAL    SETLLFBCWP44
     C           *IN97     DOWEQ*OFF
     C                     READ FBCWP44                  97
     C           *IN97     IFEQ *OFF
     C                     WRITEFBCWP451
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *===============================================================
      *   << INIT >>
      *===============================================================
     C           #INIT     BEGSR
     C*
     C                     TIME           @TIME
     C                     Z-ADD0         SVNONY  40
     C                     MOVE *BLANK    SVPLAN  5
     C                     MOVE *BLANK    SVDOCK  4
     C* CREATE HEADER
     C                     CLEARFBCWP441
     C                     MOVELTB,1      LTR7    7
     C                     MOVE 'DELIV#'  LTR7
     C                     MOVELLTR7      F4NONY
      *
     C                     MOVEL'PO 1'    F4PO1
     C                     MOVEL'PO 2'    F4PO2
     C                     MOVEL'PO 3'    F4PO3
     C                     MOVEL'PO 4'    F4PO4
     C                     MOVEL'PO 5'    F4PO5
     C                     MOVEL'PO 6'    F4PO6
     C                     MOVEL'PO 7'    F4PO7
      *
     C                     MOVEL'PLNT 1'  F4PT1
     C                     MOVEL'PLNT 2'  F4PT2
     C                     MOVEL'PLNT 3'  F4PT3
     C                     MOVEL'PLNT 4'  F4PT4
     C                     MOVEL'PLNT 5'  F4PT5
     C                     MOVEL'PLNT 6'  F4PT6
     C                     MOVEL'PLNT 7'  F4PT7
     C                     MOVEL'PLNT 8'  F4PT8
     C                     MOVEL'PLNT 9'  F4PT9
     C                     MOVEL'PLNT10'  F4PTA
      *
     C                     MOVEL'DOCK 1'  F4DC1
     C                     MOVEL'DOCK 2'  F4DC2
     C                     MOVEL'DOCK 3'  F4DC3
     C                     MOVEL'DOCK 4'  F4DC4
     C                     MOVEL'DOCK 5'  F4DC5
     C                     MOVEL'DOCK 6'  F4DC6
     C                     MOVEL'DOCK 7'  F4DC7
     C                     MOVEL'DOCK 8'  F4DC8
     C                     MOVEL'DOCK 9'  F4DC9
     C                     MOVEL'DOCK10'  F4DCA
      *
     C                     MOVEL'NAME  '  F4NAME
      *
     C                     WRITEFBCWP441
      *
     C                     ENDSR
**
'
