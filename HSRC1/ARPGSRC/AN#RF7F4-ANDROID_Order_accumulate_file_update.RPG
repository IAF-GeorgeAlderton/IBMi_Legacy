     H            Y.
     FABRHP01 IF  E                    DISK
     FABR2L04 UF  E           K        DISK                      A
     FABRIP01 O   E                    DISK
     F******************************************************
     I            DS
     I                                        1  140W#TIME
     I                                        1   60W##TIM
     I                                        7  140W##DAT
     C*
     C           *LIKE     DEFN AFPART    W#PART
     C           *LIKE     DEFN AFSTID    W#STID
     C           *LIKE     DEFN AFDOCK    W#DOCK
     C                     MOVEL*BLANK    W#PART
     C                     MOVEL*BLANK    W#STID
     C                     MOVEL*BLANK    W#DOCK
     C*
     C                     DO   *HIVAL
     C                     READ ABRHP011                 99
     C   99                LEAVE
     C*
     C           AHPART    IFNE W#PART
     C           AHSTID    ORNE W#STID
     C           AHDOCK    ORNE W#DOCK
     C*
     C           K#2PL4    KLIST
     C                     KFLD           AHPART
     C                     KFLD           AHSTID
     C           K#2PL4    SETLLABR2P011
     C*
     C                     DO   *HIVAL
     C*
     C           K#2PL4    READEABR2P011                 98
     C   98                LEAVE
     C*
     C           AHDOCK    IFNE AFDOCK
     C                     EXSR @DLOUT
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVELAHPART    W#PART
     C                     MOVELAHSTID    W#STID
     C                     MOVELAHDOCK    W#DOCK
     C*
     C                     END
     C*
     C                     EXSR @NWOUT
     C*
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     F******************************************************
     F* DELETE FROM ABR2P01 & MAKE COPY TO ABRIP01         *
     F******************************************************
     C           @DLOUT    BEGSR
     C*
     C                     CLEARABRIP011
     C*
     C                     TIME           W#TIME
     C                     Z-ADDW##DAT    AIDLTD
     C                     Z-ADDW##TIM    AIDLTT
     C                     MOVELAFTPCD    AITPCD
     C                     MOVELAFTSID    AITSID
     C                     MOVELAFSPCD    AISPCD
     C                     MOVELAFREF#    AIREF#
     C                     MOVELAFPOR#    AIPOR#
     C                     Z-ADDAFSIDT    AISIDT
     C                     Z-ADDAFHSDT    AIHSDT
     C                     Z-ADDAFHEDT    AIHEDT
     C                     MOVELAFSTIQ    AISTIQ
     C                     MOVELAFSTID    AISTID
     C                     MOVELAFIDCD    AIIDCD
     C                     MOVELAFPART    AIPART
     C                     MOVELAFDOCK    AIDOCK
     C                     MOVELAFALFL    AIALFL
     C                     MOVELAFRALF    AIRALF
     C                     MOVELAFUBM1    AIUBM1
     C                     MOVELAFPKCD    AIPKCD
     C                     Z-ADDAFQTY1    AIQTY1
     C                     Z-ADDAFWEIT    AIWEIT
     C                     MOVELAFUBM2    AIUBM2
     C                     MOVELAFEQMT    AIEQMT
     C                     Z-ADDAFQTY2    AIQTY2
     C                     Z-ADDAFDLDT    AIDLDT
     C                     Z-ADDAFTIME    AITIME
     C                     Z-ADDAFDATE    AIDATE
     C                     MOVELAFIPAR    AIIPAR
     C                     Z-ADDAFLRDT    AILRDT
     C                     Z-ADDAFLRQY    AILRQY
     C                     Z-ADDAFLSDT    AILSDT
     C                     Z-ADDAFLSQY    AILSQY
     C                     Z-ADDAFYRDT    AIYRDT
     C                     Z-ADDAFYRQY    AIYRQY
     C                     Z-ADDAFYSDT    AIYSDT
     C                     Z-ADDAFYSQY    AIYSQY
     C                     MOVELAFEXCD    AIEXCD
     C                     MOVELAFRDCD    AIRDCD
     C                     MOVELAFODRN    AIODRN
     C*
     C                     WRITEABRIP011
     C*
     C                     DELETABR2P011
     C*
     C                     ENDSR
     F******************************************************
     F* MAKE ORDER DATA TO ABR2P01                         *
     F******************************************************
     C           @NWOUT    BEGSR
     C*
     C                     CLEARABR2P011
     C*
     C                     MOVELAHTPCD    AFTPCD
     C                     MOVELAHTSID    AFTSID
     C                     MOVELAHSPCD    AFSPCD
     C                     MOVELAHREF#    AFREF#
     C                     MOVELAHPOR#    AFPOR#
     C                     Z-ADDAHSIDT    AFSIDT
     C                     Z-ADDAHHSDT    AFHSDT
     C                     Z-ADDAHHEDT    AFHEDT
     C                     MOVELAHSTIQ    AFSTIQ
     C                     MOVELAHSTID    AFSTID
     C                     MOVELAHIDCD    AFIDCD
     C                     MOVELAHPART    AFPART
     C                     MOVELAHDOCK    AFDOCK
     C                     MOVELAHALFL    AFALFL
     C                     MOVELAHRALF    AFRALF
     C                     MOVELAHUBM1    AFUBM1
     C                     MOVELAHPKCD    AFPKCD
     C                     Z-ADDAHQTY1    AFQTY1
     C                     Z-ADDAHWEIT    AFWEIT
     C                     MOVELAHUBM2    AFUBM2
     C                     MOVELAHEQMT    AFEQMT
     C                     Z-ADDAHQTY2    AFQTY2
     C                     Z-ADDAHDLDT    AFDLDT
     C                     Z-ADDAHTIME    AFTIME
     C                     Z-ADDAHDATE    AFDATE
     C                     MOVELAHIPAR    AFIPAR
     C                     Z-ADDAHLRDT    AFLRDT
     C                     Z-ADDAHLRQY    AFLRQY
     C                     Z-ADDAHLSDT    AFLSDT
     C                     Z-ADDAHLSQY    AFLSQY
     C                     Z-ADDAHYRDT    AFYRDT
     C                     Z-ADDAHYRQY    AFYRQY
     C                     Z-ADDAHYSDT    AFYSDT
     C                     Z-ADDAHYSQY    AFYSQY
     C                     MOVELAHEXCD    AFEXCD
     C                     MOVELAHRDCD    AFRDCD
     C                     MOVELAHODRN    AFODRN
     C*
     C                     WRITEABR2P011
     C*
     C                     ENDSR
