     H            Y.
     F** AAXR22 **************************************
     F* .. LTEST                                     *
     F* T-SAKAKI                        87.10.09     *
     F************************************** AAXR05 **
     FAH#PL16 IF  E           K        DISK
     FAAXWP22 O   F     256            DISK
      *
      *
     C           KEY1      KLIST
     C                     KFLD           X1HTYY  40
     C                     KFLD           X1HTMM  20
     C                     KFLD           X1HTDD  20
      *
     C                     EXCPTOHED
      *
     C                     Z-ADD2019      X1HTYY
     C                     Z-ADD09        X1HTMM
     C                     Z-ADD30        X1HTDD
      *
     C                     SETOF                     40
     C           KEY1      SETLLAH#PL16
     C                     DO   *HIVAL
     C                     READ AH#PL16                  40
     C           *IN40     IFEQ '0'
     C*
     C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C           CFHTHZ    IFGE 20191005
     C                     LEAVE
     C                     ENDIF
     C*
     C                     CALL 'UTLR14A'
     C                     PARM           CFHIN1
     C                     PARM           CFHIN2
     C                     PARM           CFHIN3
     C                     PARM           W1PRCN  3
     C                     PARM           W1PRCR  3
     C                     PARM           W1MCNN  3
     C                     PARM           W1MCNR  3
     C                     PARM           W1DPTN  40
     C                     PARM           W1DPTR  40
     C                     PARM           W1RTN   1
     C           W1RTN     IFEQ ' '
     C                     MOVELW1PRCR    W1PRC   3
     C                     MOVELW1MCNR    W1MCN   3
     C                     Z-ADDW1DPTR    W1DPT   40
     C                     ENDIF
     C*
     C                     EXCPTODAT
     C*
     C                     ENDIF
     C  N40                ENDDO
      *
      *
      *
     C                     SETON                     LR
     C                     RETRN
      ******************************************************
     OAAXWP22 E                OHED
     O                                      'ISSUE DATE,'
     O                                      'BIN,'
     O                                      'PART #,'
     O                                      '# OF BOX,'
     O                                      'PROCESS,'
     O                                      'DEPT.,'
     O                                      'MACHINE #,'
      *
     OAAXWP22 E                ODAT
      *
     O                         CFHTHZ
     O                                      ','
     O                         CFHTBB
     O                                      ',="'
     O                         CFHIN1
     O                                      '-'
     O                         CFHIN2
     O                                      '-'
     O                         CFHIN3
     O                                      '",'
     O                         CFMAIS
     O                                      ','
     O                         W1PRC
     O                                      ',="'
     O                         W1DPT
     O                                      '",'
     O                         W1MCN
