     C           KEY1      KLIST
     C                     KFLD           X1HIN1
     C                     KFLD           X1HIN2
     C                     KFLD           X1HIN3
      *
      *--------------------------------------------------*
     C                     TIME           WTIME
     C                     Z-ADDWTIHZ     W@DATE
      *
     C                     READ AXXWP151                 87
     C           *IN87     DOWEQ'0'
      *
     C                     EXSR #FC01
     C                     EXSR #FC11
     C                     EXSR #AM11
     C                     EXSR #GHC2
      *
     C                     READ AXXWP151                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------*
      *FCEPP01 UPDATE
      *----------------------------------------------*
     C           #FC01     BEGSR
      *
     C           KEY1      CHAINFCEPL011             21
     C           *IN21     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     ELSE
     C                     Z-ADDX1SYUY    A2GEKN
     C                     MOVE 'Q'       A2GKNM
     C                     UPDATFCEPL011
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------*
      *FCEPP11 UPDATE
      *----------------------------------------------*
     C           #FC11     BEGSR
      *
     C           KEY1      CHAINFCEPL111             21
     C           *IN21     IFEQ '0'
     C           FCSKJY    IFEQ 'D'
     C                     ELSE
     C           FCKH01    IFEQ 20191102
     C           FCKM01    ANDEQ'ZIDOU'
     C                     Z-ADDX1SYUY    FCGK01
     C                     UPDATFCEPL111
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------------*
      *----------------------------------------------*
      *AAMPP11 UPDATE
      *----------------------------------------------*
     C           #AM11     BEGSR
      *
     C           KEY1      CHAINAAMPL111             21
     C           *IN21     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C           NSHN,A    IFNE *BLANK
     C                     Z-ADDX1SYUY    NSRY,A
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE 'Q'       CKKOME
     C                     UPDATAAMPL111
      *
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------------*
      *GHCPP21 UPDATE
      *---------------------------------------------------------------*
     C           #GHC2     BEGSR
      *
     C                     SETOF                     70
     C           KEY1      SETLLGHCPL21
     C                     DO   *HIVAL
     C           KEY1      READEGHCPL21                  70
     C           *IN70     IFEQ '1'
     C                     LEAVE
     C                     ENDIF
     C                     Z-ADDX1SYUY    M7SETI
     C                     Z-ADDX1SYUY    M7SRYO
     C                     UPDATGHCPL211
     C  N70                ENDDO
      *
     C                     ENDSR
