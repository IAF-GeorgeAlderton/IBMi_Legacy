     H            Y.
     F** MRAR06 *********************************************
     F* MODIFY INFORMATION                                  *
     F*     TRANCOM ITS.           2012.09.12               *
     F*******************************************************
     FMRAPW06 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FMRAWP05 IF  E           K        DISK
      *
     E                    ER      1  11 60
      *
     I            DS
     I                                        1  14 S1SHN
     I                                        1   5 S1SHN1
     I                                        6   6 S1SF1
     I                                        7  11 S1SHN2
     I                                       12  12 S1SF2
     I                                       13  14 S1SHN3
      *
     I            DS
     I                                        1  17 S1MHN
     I                                        1   5 S1MHN1
     I                                        6   6 S1MF1
     I                                        7  11 S1MHN2
     I                                       12  12 S1MF2
     I                                       13  17 S1MHN3
      *
     I            DS
     I                                        1   80W5STDT
     I                                        1   40W5STYY
     I                                        5   60W5STMM
     I                                        7   80W5STDD
      *
     I            DS
     I                                        1  10 W5KEN
     I                                        1   9 W5KENO
     I                                       10  10 W5KENA
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL*BLANK    PCMD
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *データ検索                                        *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLMRAWP051
     C                     READ MRAWP051                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRAWP051                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *   第二画面処理                                   *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEMRAPW069
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '03'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTMRAWP051
     C                     READPMRAWP051                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  14        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C                     DO   *HIVAL
     C                     EXSR #READP
     C                     READPMRAWP051                 81
     C  N81N27             ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXTP
     C  N81N66             ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLMRAWP051
     C                     READ MRAWP051                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRAWP051                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXT
     C  N81N66             ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRAWP051                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXT
     C  N81N66             ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      * CHECK
     C                     SETOF                     3199
     C                     Z-ADD1         X       20
     C                     Z-ADD0         WKSEL   20
     C           X         DOWLE14
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C           *IN99     ANDEQ'0'
     C                     SETOF                     31
     C                     EXSR #SB221
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
     C           X         DOWLE14
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C                     EXSR #SB222
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     C           P9CMD     IFEQ '05'
     C                     MOVE '05'      PCMD
     C                     MOVE '99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK SFL                                          *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'S'
     C           S1SEL     OREQ 'D'
     C                     ADD  1         WKSEL
     C           H1CHID    IFEQ 'W'
     C                     MOVELER,4      D9ERR
     C                     SETON                     3199
     C                     GOTO ESB221
     C                     ENDIF
     C                     OTHER
     C                     MOVELER,2      D9ERR
     C                     SETON                     3199
     C                     ENDSL
      *
     C           WKSEL     IFGE 2
     C                     MOVELER,3      D9ERR
     C                     SETON                     3199
     C                     ENDIF
      *
     CSR         ESB221    ENDSR
      *----------------------------------------------------*
      * CALL UPDATE PGM                                    *
      *----------------------------------------------------*
     CSR         #SB222    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ 'S'
     C                     EXSR #SB223
     C                     MOVEL*BLANK    S1SEL
     C           S1SEL     WHEQ 'D'
     C           H139      IFEQ '0'
     C                     EXSR #SB223
     C                     ENDIF
     C           P9CMD     IFEQ '05'
     C                     MOVEL'1'       H139
     C                     SETON                     39
     C                     ENDIF
     C                     ENDSL
      *
     CSR         ESB222    ENDSR
      *----------------------------------------------------*
      * CALL UPDATE PGM                                    *
      *----------------------------------------------------*
     CSR         #SB223    BEGSR
      *
     C                     MOVELS1SEL     P9SEL
     C                     MOVELH1SHN1    P9SHN1
     C                     MOVELH1SHN2    P9SHN2
     C                     MOVELH1SHN3    P9SHN3
     C                     MOVELH1SEQ     P9SEQ
     C                     MOVELH1SEKB    P9SEKB
     C                     MOVELH1PRKB    P9PRKB
     C                     CALL 'MRAR07'
     C                     PARM           P9SEL   1
     C                     PARM           P9SHN1  5
     C                     PARM           P9SHN2  5
     C                     PARM           P9SHN3  2
     C                     PARM           P9SEQ   6
     C                     PARM           P9SEKB  1
     C                     PARM           P9PRKB  1
     C                     PARM           P9CMD   2
      *
     CSR         ESB223    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 14
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      *   検索ファイル逆読み                             *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      *   検索条件判定                                   *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C           W5SKJY    IFEQ 'D'
     C                     GOTO ESELEC
     C                     ENDIF
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      *   表示項目＆サブファイルクリアー                 *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      *   編集処理                                       *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVELW5SKJY    S1SEL
     C           W5SKJY    IFEQ 'D'
     C                     MOVEL'1'       H139
     C                     SETON                     39
     C                     ELSE
     C                     MOVEL'0'       H139
     C                     SETOF                     39
     C                     ENDIF
     C                     MOVEL*BLANK    S1SHN
     C                     MOVELW5SHN1    S1SHN1
     C                     MOVEL'-'       S1SF1
     C                     MOVELW5SHN2    S1SHN2
     C                     MOVEL'-'       S1SF2
     C                     MOVELW5SHN3    S1SHN3
     C           S1SHN3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1SF2
     C                     ENDIF
      *
     C                     MOVEL*BLANK    S1MHN
     C                     MOVELW5MHN1    S1MHN1
     C                     MOVEL'-'       S1MF1
     C                     MOVELW5MHN2    S1MHN2
     C                     MOVEL'-'       S1MF2
     C                     MOVELW5MHN3    S1MHN3
     C           S1MHN3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1MF2
     C                     ENDIF
     C           S1MHN2    IFEQ *BLANK
     C                     MOVEL*BLANK    S1MF1
     C                     ENDIF
      *
     C                     MOVELW5SYKI    S1SYKI
     C                     Z-ADDW5STDT    S1STDT
     C                     Z-ADDW5IPDT    S1IPDT
     C                     MOVELW5TMEI    S1TMEI
     C                     MOVELW5KEN     S1KEN
     C                     MOVELW5SHN1    H1SHN1
     C                     MOVELW5SHN2    H1SHN2
     C                     MOVELW5SHN3    H1SHN3
     C                     MOVELW5SEQ     H1SEQ
     C                     MOVELW5SEKB    H1SEKB
     C                     MOVELW5PRKB    H1PRKB
     C                     MOVELW5CHID    H1CHID
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      *   次データ                                       *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ MRAWP051                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      *   前データ                                       *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPMRAWP051                 81
      *
     CSR         ENEXTP    ENDSR
     C*----------------------------------------------------------------
