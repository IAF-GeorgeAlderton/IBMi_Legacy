     H            Y.
     F** ABMRH2 *********************************************
     F*  SUPPLIER ORDER WARNING LIST                        *
     F*  HOTTA. 2018.11.01                                  *
JW1  F*  JW     2019.08.12 ADD FINAL LOCATION               *
     F*******************************************************
     FABMWPH1 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FABMPRH2 O   E             55     PRINTER
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
JW1  I            DS
 |   I                                        1  12 W1SHIN
 |   I                                        1   5 W1SHN1
 |   I                                        6  10 W1SHN2
JW1  I                                       11  12 W1SHN3
      *
JW1  I            DS
 |   I                                        1   6 WLOC
 |   I                                        1   1 WLOC1
 |   I                                        2   3 WLOC2
 |   I                                        4   5 WLOC3
JW1  I                                        6   6 WLOC4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     SETON                     55
     C                     READ ABMWPH11                 87
     C           *IN87     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRH21
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #DTOUT
     C                     READ ABMWPH11                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *--------------------------------------------------------*
      *                                                        *
      *--------------------------------------------------------*
     CSR         #DTOUT    BEGSR
      *
     C                     MOVELW1ATOB    P2ATOB
     C                     MOVEL*BLANK    P2ATON
     C                     MOVELW1ATOB    KATOB   40
     C           KATOB     CHAINFGBPL011             45
     C           *IN45     IFEQ '0'
     C                     MOVELB2SMEI    P2ATON
     C                     ENDIF
     C                     MOVEL*BLANK    P2SHIN
     C           W1SHN1    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W1SHN2:0  P2SHIN
     C           P2SHIN    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W1SHN3:0  P2SHIN
     C                     MOVELW1ATK2    P2ATK2
     C                     MOVELW1ATK3    P2ATK3
     C                     Z-ADDW1SSYS    P2SSYS
     C           W1GEKN    DIV  20        P2HIKN
     C                     Z-ADD0         P2BOXD
     C                     Z-ADD0         P2LTBX
     C                     Z-ADD0         P310AV
     C           W1SSYS    IFNE 0
     C           P2HIKN    DIV  W1SSYS    P2BOXD
     C           W1SRYO    DIV  W1SSYS    P2LTBX
     C           W210AV    DIV  W1SSYS    P310AV
     C                     ENDIF
     C                     Z-ADDW110AV    P210AV
     C                     MOVE W1DEHZ    P2DEHZ
     C                     Z-ADDW105AL    P205AL
     C           W105PR    MULT 100       P205PR
     C                     Z-ADDW110AL    P210AL
     C           W110PR    MULT 100       P210PR
     C                     Z-ADDW120AL    P220AL
     C           W120PR    MULT 100       P220PR
     C                     MOVE W1FLG     P2FLG
JW1   * GET FINAL LOCATION
 |   C                     MOVELW1SHIN    $SHIN
 |   C                     CALL 'UTLR21'
 |   C                     PARM           $SHIN  12
 |   C                     PARM           $LLOC   6
 |   C                     PARM           $LQC    50
 |   C                     PARM           $LPRC   3
 |   C                     PARM           $LDPT   40
 |   C                     PARM           $ZETI   4
 |   C                     PARM           $RTN    1
 |   C                     MOVEL$LLOC     WLOC
 |   C                     MOVEL'  -  '   P2FLOC
 |   C                     MOVELWLOC2     P2FLOC
JW1  C                     MOVE WLOC3     P2FLOC
      *
     C                     WRITEABMPRH22
      *
     CSR         EDTOUT    ENDSR
