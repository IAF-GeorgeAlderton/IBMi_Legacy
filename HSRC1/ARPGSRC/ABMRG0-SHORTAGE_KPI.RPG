     H            Y.
     F** ABMRG0 **************************************
     F* SHORTAGE KPI
     F*     HOTTA.           2018.10.05              *
     F************************************************
     FABMPWG0 CF  E                    WORKSTN
     E                    ER      1  19 65
      *
     I            DS
     I                                        1   60D1NTYM
     I                                        1   40D1NTYY
     I                                        5   60D1NTMM
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  120WTIYM
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         WKCKSU
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NTYM  60
     C                     PARM           P@CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     ENDDO
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
     C                     MOVE *BLANK    P@CMD   2
     C                     Z-ADD0         D1NTYM
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR $SB210
     C                     ENDDO
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   第一画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTABMPWG01
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '01'      P@CMD   2
     C                     MOVE '99'      DSPSW
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           D1NTYM    IFEQ 0
     C                     SETON                     3199
     C                     MOVELER,1      D1ERR
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           D1NTYM    IFGT WTIYM
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO $S210E
     C                     ENDIF
     C           D1NTMM    IFEQ 0
     C           D1NTMM    ORGT 12
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO $S210E
     C                     ENDIF
      * F5
     C           *IN05     IFEQ '1'
     C                     MOVE '05'      P@CMD   2
     C                     MOVE '99'      DSPSW
     C                     Z-ADDD1NTYM    P@NTYM
     C                     ENDIF
      *
     CSR         $S210E    ENDSR
**
ER-01 INPUT DATE MONTH.
ER-02 DATE MONTH ERROR.
