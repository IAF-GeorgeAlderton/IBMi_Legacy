     C                     KFLD           K@NONY
      *
     C           *LIKE     DEFN B7TOKU    K@TOKU
     C           *LIKE     DEFN F3NONY    K@NONY
      *
     C*--------------------*
     C*  ..部門コード..  *
     C*--------------------*
     C                     Z-ADD0         BUM
     C           PB0111    IFNE *BLANK
     C                     MOVE PB0111    BUM,1
     C                     END
      *
     C*----------------*
     C*  ..部門便..  *
     C*----------------*
     C                     Z-ADD0         BIN
     C           PI0111    IFNE *BLANK
     C                     MOVE PI0111    BIN,1
     C                     END
      *
     C                     MOVELF06       YMD6
     C                     MOVELF06       YMD
      *
     C*--------------------------------*
     C*  ..平準化確定発注ファイル..  *
     C*--------------------------------*
S1   C                     DO   *HIVAL
     C           STEP11    TAG
     C                     SETOF                     10
     C                     READ AGAPP411                 10
 S2  C           *IN10     IFEQ '0'
      *
  S3 C           CBSKJY    IFEQ 'D'
     C                     GOTO STEP11
  E3 C                     END
      *
  S3 C           CBMBMN    IFNE 0111
     C                     Z-ADD0111      CBMBMN
  E3 C                     END
      *
     C                     SETOF                     11
     C                     Z-ADD1         I       50
     C           CBMBMN    LOKUPBUM,I                    11
      *
      *
  S3 C           *IN11     IFEQ '1'
     C                     Z-ADD0         SUR     50
     C                     Z-ADDBIN,I     BB8
     C                     Z-ADDBIN,I     $KBBI
      *
  S4 C                     DO   BIN,I     J       50
     C           CBBI,J    IFEQ 0                          抜出便
     C           CBHK,J    IFEQ 0                          箱数
     C                     Z-ADD99        CBBI,J
     C                     ELSE
     C                     Z-ADDBIN,I     CBBI,J           抜出便
     C                     ADD  CBHK,J    SUR              箱数
     C                     END
     C                     END
  E4 C                     END
      *
     C*------------------------------------*
     C*  ..転送箱数が有る時データ出力..  *
     C*------------------------------------*
  S4 C           SUR       IFNE 0
     C                     MOVE *BLANK    HKT              箱数
     C                     MOVE *BLANK    MPLC
     C                     MOVE *BLANK    PLC
     C                     MOVE *BLANK    CFKBAN  3
     C                     MOVE *BLANK    WMTKR   6
     C                     MOVE *BLANK    WATOK   3
     C                     MOVE *BLANK    WATOB   4
     C                     MOVE *BLANK    W@BMON  4
     C                     SETOF                     15
     C*----------------------------------*
     C*  ..社内かんばん切替マスター..  *
     C*----------------------------------*
     C                     SETOF                     11
     C           KEY3      CHAINAAMPL111             11
  S5 C           *IN11     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLEYMD
     C                     SETON                     11
  E5 C                     END
      *
  S5 C           *IN11     IFEQ '0'
     C*------------------------------------*
     C*  ..工程セット　＇ＡＲＳ＇工程..  *
     C*------------------------------------*
     C                     Z-ADD1         X       20
     C                     Z-ADD0         Y       20
  S6 C           1         DO   15        X
  S7 C           CKHZ,X    IFGT YMD8
  S8 C           CKQK,X    IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVE CKQK,X    HKT,Y
  E8 C                     END
  X7 C                     ELSE
  S8 C           CKKO,X    IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVE CKKO,X    HKT,Y
  E8 C                     END
  E7 C                     END
  E6 C                     END
      *
     C                     Z-ADD16        X
     C                     Z-ADD1         Y
     C                     Z-ADD0         $$ZZ    20
  S6 C           1         DO   15        Y
     C           X         SUB  Y         Z       20
      *
  S7 C           CKHZ,Z    IFGT YMD8
     C           CKQK,Z    CABEQ*BLANK    STEP21
  S8 C           CKQT,Z    IFEQ '++++++'
     C           CKQT,Z    OREQ '------'
     C                     GOTO STEP21
  E8 C                     END
      *
  S8 C           *IN15     IFEQ '0'
  S9 C           MPLC      IFEQ *BLANK
     C           CKQR,Z    ANDEQ'C'                        種類めっき
     C                     SETON                     15
     C                     MOVE CKQT,Z    MPLC             所番地
     C                     MOVE CKQR,Z    MTYP    1        種類
     C                     MOVE CKQB,Z    W@BMON           部門
     C                     Z-ADDZ         $$ZZ
  E9 C                     END
     C                     GOTO STEP21
  X8 C                     ELSE
      *        前工程
  S9 C           PLC       IFEQ *BLANK
     C                     MOVE CKQT,Z    PLC              所番地
     C                     MOVE CKQN,Z    CFKBAN           機番
     C                     GOTO STEP22
  E9 C                     END
     C                     GOTO STEP21
  E8 C                     END
  X7 C                     ELSE
      *
     C           CKKO,Z    CABEQ*BLANK    STEP21
  S8 C           CKNB,Z    IFEQ '++++++'
     C           CKNB,Z    OREQ '------'
     C                     GOTO STEP21
  E8 C                     END
  S8 C           *IN15     IFEQ '0'
  S9 C           MPLC      IFEQ *BLANK
     C           CKKR,Z    ANDEQ'C'                        メッキ
     C                     SETON                     15
     C                     MOVE CKNB,Z    MPLC             所番地
     C                     MOVE CKKR,Z    MTYP             種類
     C                     MOVE CKBM,Z    W@BMON           部門
     C                     Z-ADDZ         $$ZZ
  E9 C                     END
     C                     GOTO STEP21
  X8 C                     ELSE
      *        前工程
  S9 C           PLC       IFEQ *BLANK
     C                     MOVE CKNB,Z    PLC              所番地
