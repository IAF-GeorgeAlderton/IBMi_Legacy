     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C           KEY3X     KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C                     KFLD           K@NONY
      *
     C           KEY4      KLIST
     C                     KFLD           PLCA
     C                     KFLD           PLCB
     C                     KFLD           PLCC
     C                     KFLD           PLCD
     C                     KFLD           YY
     C                     KFLD           MM
     C                     KFLD           DD
      *
     C           MKKEY     KLIST
     C                     KFLD           MPLCA
     C                     KFLD           MPLCB
     C                     KFLD           MPLCC
