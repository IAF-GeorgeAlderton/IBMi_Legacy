     C                     END
     C           *IN30     IFEQ '0'
     C           PARM04    IFEQ 'S'
     C                     MOVEA'1'       *IN,61
     C                     Z-ADDA2SOZI    @KASI
     C                     ELSE
     C           PARM04    IFEQ 'K'
     C                     MOVEA'1'       *IN,62
     C                     Z-ADDA2KASI    @KASI
     C                     END
     C                     END
     C                     END
     C*
     C           @ASRY     MULT @KASI     AAAAA1 101
