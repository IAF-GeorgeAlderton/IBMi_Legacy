     C                     ADD  @BJRY     $BJRY1  90
     C                     ADD  @CJRY     $CJRY1  90
     C                     ADD  @DJRY     $DJRY1  90
     C*
     CLR         $ASRY1    DIV  @DAY      AAA    101
