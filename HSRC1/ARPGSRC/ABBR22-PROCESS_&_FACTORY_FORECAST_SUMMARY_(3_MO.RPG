     C                     ELSE
     C           @DTMM     ADD  1         @MM1
     C                     Z-ADD@DTYY     @YY1
     C                     END
     C           @MM1      IFEQ 12
     C                     Z-ADD1         @MM2    20       N+2
     C           @YY1      ADD  1         @YY2    40
     C                     ELSE
     C           @MM1      ADD  1         @MM2
     C                     Z-ADD@YY1      @YY2
     C                     END
