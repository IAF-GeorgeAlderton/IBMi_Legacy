     C                     MOVE US        A5KOME
     C*
     C                     MOVE BIN       A5RGCD
     C                     MOVE ALSIRE    A5SIRE
     C                     MOVE ALSKOJ    A5SKOJ
     C                     MOVE ALKTYP    A5KTYP
     C                     MOVE ALSBAN    A5SBAN
     C                     MOVE ALNTKB    A5NTKB
