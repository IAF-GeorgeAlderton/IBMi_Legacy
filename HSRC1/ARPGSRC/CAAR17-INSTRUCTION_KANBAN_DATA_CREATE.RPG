     C***************************************************
     C* MAIN
     C***************************************************
     C                     TIME           #DATE
      *
     C                     CLEAR@KOT
     C                     CLEAR@KBN
     C                     CLEAR@HHI
      *
      * RE-PRINT  BIN '77'
     C           PBIN      IFEQ '77'
     C                     EXSR #REPR
      *
      * DAILY BIN '01','02'
      * OFF-LINE BIN '88'
     C                     ELSE
     C                     EXSR #DAIL
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     C***************************************************
     C* RE-PRINT   BIN '77'
     C***************************************************
     C           #REPR     BEGSR
      *
     C                     Z-ADD0         K8DATE  80
     C                     Z-ADD0         K8TIME  60
      *
     C           KEY8      SETLLCAAPP081
     C                     DO   *HIVAL
     C           KEY8      READECAAPP081                 10
     C   10                LEAVE
     C*
     C           C8SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDC8TBCD    K9TBCD  40
     C                     Z-ADDC8DTHZ    K9DTHZ  80
     C                     Z-ADDC8DTBB    K9DTBB  20
     C                     MOVELC8SGNO    K9SGNO  4
     C                     MOVELC8STNO    K9STNO  3
      *
     C           KEY9      SETLLCAAPL051
     C                     DO   *HIVAL
     C           KEY9      READECAAPL051                 11
     C   11                LEAVE
     C*
     C           C6SKJY    IFEQ 'D'
     C           C6SKDT    ANDLEWDATE
     C                     ITER
     C                     ENDIF
     C*  AFTER ISSUED?
     C           C6DATH    IFNE '*'
     C                     ITER
     C                     ENDIF
     C* WRITE
     C                     EXSR #PRIN
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C                     MOVEL@@USER    C8ISUS
     C                     Z-ADDSDATE     C8ISDT
     C                     Z-ADDSTIME     C8ISTM
     C                     UPDATCAAPP081
      *
     C                     ENDDO
      *
     C           EREPR     ENDSR
     C***************************************************
     C* DAILY OR OFF-LINE
     C***************************************************
     C           #DAIL     BEGSR
      *
     C                     MOVE PBMON     WBMON   40
     C                     Z-ADDPDATE     WDATE   80
     C                     MOVE PBIN      WBIN    20
      *
     C           KEY1      SETLLCAAPL051
     C                     DO   *HIVAL
     C           KEY1      READECAAPL051                 10
     C   10                LEAVE
     C*
1    C           C6SKJY    IFEQ 'D'
|    C           C6SKDT    ANDLEWDATE
|    C                     ITER
1    C                     ENDIF
      *
     C* CHECK STATUS
     C*  ISSUED OR ERROR  -DAILY OR OFF-LINE
1    C           C6DATH    IFEQ *BLANK
|    C           C6DATH    OREQ 'E'
|    C                     ELSE
|    C                     ITER
1    C                     ENDIF
     C* UPDATE
     C                     EXSR #UPDT
     C*
     C* WRITE
     C           WERR      IFEQ *BLANK
     C                     EXSR #PRIN
     C                     MOVEL'*'       C6DATH
     C                     ELSE
     C                     MOVEL'E'       C6DATH
     C  N89                EXCPTOHED
     C                     SETON                     89
     C                     EXCPTODAT
     C                     ENDIF
      *
     C                     UPDATCAAPL051
      *
     C                     ENDDO
      *
     C           EDAIL     ENDSR
     C***************************************************
     C* FOR UPDATE CAAPP05
     C***************************************************
     C           #UPDT     BEGSR
     C*
     C                     MOVEL*BLANK    WERR   20
     C*-------------------------------------*
     C* GET KANBAN M/F INFO
     C*-------------------------------------*
     C                     MOVEL*BLANK    WKCHK   1
     C                     EXSR #GETK
     C*  **NO KANBAN M/F
     C           WKCHK     IFEQ *BLANK
     C                     MOVELER,1      WERR   20
     C                     GOTO EUPDT
     C                     ENDIF
     C*
     C*-------------------------------------*
     C* GET PART M/F INFO & WIRE LOCATION
     C*-------------------------------------*
     C                     MOVEL*BLANK    WPCHK   1
     C                     EXSR #GETW
     C*  **NO PART M/F
     C           WPCHK     IFEQ *BLANK
     C                     MOVELER,2      WERR   20
     C                     GOTO EUPDT
     C                     ENDIF
     C*
     C*----------------------------*
     A* GET COMPONENT PARTS
     C*----------------------------*
     C                     EXSR #GETC
     C*
     C*
     C*----------------------------*
      * SET VALUE FOR CAAPP05      *
     C*----------------------------*
     C                     EXSR #SETV
     C*
     C           EUPDT     ENDSR
     C***************************************************
     C* FOR PRINT
     C***************************************************
     C           #PRIN     BEGSR
     C*----------------------------*
     C* CALCULATE                  *
     C*----------------------------*
     C* LOT QUANTITY
     C                     Z-ADD0         WPROLQ  90
     C           C6PROL    MULT C6SYOS    WPROLQ
     C*
     O* A2:A-PICS2  A3:A-PICS3
     C                     MOVE C6DTSB    WSYKO   1
     C*----------------------------*
     C* MATERIAL COLOR             *
     C*----------------------------*
     C                     MOVEL*BLANK    WZIIR   1
     C           C6ZANM    CHAINCACPL021             02
     C           *IN02     IFEQ '0'
     C           C1SKJY    ANDEQ*BLANK
     C                     MOVELC1ZAIR    WZIIR
     C                     ENDIF
     C*-----------------------------*
     C* SECONDARY PROCESS DIVISION  *
     C*-----------------------------*
     C                     EXSR #SECPD
     C*
     C*-----------------------------*
     C* CONDITION NAME              *
     C*-----------------------------*
     C                     EXSR #CONN
     C*
     C*----------------------------*
     C* CREATE HD BARCODE & QR     *
     C*----------------------------*
