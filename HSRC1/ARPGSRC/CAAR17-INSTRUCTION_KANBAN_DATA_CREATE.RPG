     C                     MOVEL*BLANK    W@LOCA
     C*
     C* GET WIRE LOCATION
     C                     MOVELWZANM     $ZAIS
     C                     Z-ADDWZAIK     $ZAIK
     C                     Z-ADDWKOJE     $KOJE
     C                     Z-ADDWKAKE     $KAKE
     C                     Z-ADDWDATE     $DATE
     C                     CALL 'UEXR34'
     C                     PARM           $ZAIS  15
     C                     PARM           $ZAIK   52
     C                     PARM           $KOJE   40
     C                     PARM           $KAKE   40
     C                     PARM           $DATE   80
     C                     PARM           $ZETI   4
     C                     PARM           $WLOC   6
     C                     PARM           $RTN    1
      *
     C           $RTN      IFEQ 'Y'
     C                     MOVEL$WLOC     W@LOCA
     C                     MOVELW@LOC1    WWTK1
     C                     MOVELW@LOC2    WWTK2
     C                     MOVELW@LOC3    WWTK3
     C                     MOVELW@LOC4    WWTK4
     C                     ENDIF
