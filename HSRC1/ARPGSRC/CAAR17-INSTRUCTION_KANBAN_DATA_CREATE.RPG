     C                     MOVEL*BLANK    WWTK3   2
     C                     MOVEL*BLANK    WWTK4   1
     C*
     C                     SETOF                     01
     C           KEYSHN    CHAINFCEPL011             01
     C           *IN01     IFEQ '0'
     C           A2GSKD    ANDEQ*BLANK
     C                     MOVELA2ZANM    WZANM
     C                     Z-ADDA2KAZI    WZAIK
     C                     Z-ADDA2UKER    WKOJE            0111
     C                     Z-ADDA2SIRE    WKAKE            SUPPLIER
     C                     Z-ADDA2KUBI    WKUBI
     C                     Z-ADDA2SOZI    WSOZI
     C                     Z-ADDA2TUSZ    WTUSZ
