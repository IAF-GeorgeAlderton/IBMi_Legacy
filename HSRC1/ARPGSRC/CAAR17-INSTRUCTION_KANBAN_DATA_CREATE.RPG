      *
      * DATA EXSIST
     C           WKCHK     IFEQ '1'
      *
     C*-------------------------*
     C* DEPARTMENT NAME M/F     *
     C*-------------------------*
     C                     Z-ADD1         A       20
     C           1         DO   10        A
     C                     Z-ADD$KOJ,A    WKJCD   40
     C                     MOVE 'A'       WKJKB   1
     C           $KOJ,A    IFNE 0
     C           KEY3      CHAINAATPL011             02
     C           *IN02     IFEQ '0'
     C           DCSKJY    ANDEQ*BLANK
     C                     MOVELDCNAMN    $KJN,A
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDDO
     C*-------------------------*
     C* CALENDER                *
     C*  .PROCESS COMPLETE DATE *
     C*-------------------------*
     C                     Z-ADD1         WNRD    10
     C                     Z-ADD0         WRECD   10
     C                     Z-ADDPDATE     UYMD
     C                     Z-ADD0         WYMD
      *
     C                     SETOF                         03
     C           KEY5      SETGTAGDPL121
     C                     DO   *HIVAL
     C                     READ AGDPL121                 03
     C   03                LEAVE
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         WRECD
     C           WRECD     IFEQ WNRD
     C                     Z-ADDF8KAHZ    WYMD             BASE DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
     C**
     C                     Z-ADD1         A
1    C           1         DO   10        A
|2   C           A         IFNE 10
||   C           KOT,A     ANDEQ*BLANK
||   C                     LEAVE
|2   C                     ENDIF
|     * LEAD TIME
|    C                     Z-ADDRED,A     WLTM2   40
|     *
|    C           KEY7      SETGTAGDPL121
|2   C                     DO   WLTM2
||   C           STP2      TAG
||   C                     SETOF                     03
||   C                     READ AGDPL121                 03
||3  C           *IN03     IFEQ '0'
|||4 C           F8HIRU    IFEQ '*'
|||| C           F8YORU    ANDEQ'*'
|||| C                     GOTO STP2
|||4 C                     ENDIF
||3  C                     ENDIF
|2   C  N03                ENDDO
|     *
|    C                     Z-ADDF8KAHZ    NOK,A
|    C                     Z-ADDF8KAHZ    WYMD
|    C                     Z-ADDF8KAHZ    WDUDT   80
|     *
1    C                     ENDDO
      *
     C                     ENDIF
