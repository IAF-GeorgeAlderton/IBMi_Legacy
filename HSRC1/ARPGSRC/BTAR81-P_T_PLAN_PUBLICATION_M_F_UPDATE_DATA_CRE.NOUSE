      *-----------------------------------------------------------*
      *          #SB001    BTAPP05_WRITE処理                    *
      *-----------------------------------------------------------*
     C           #SB001    BEGSR
      *
     C                     MOVEL*ALL'0'   HTP
     C                     MOVEL*ALL'0'   HTM
     C                     MOVEA*BLANK    HTZ
     C                     MOVELBAHIN1    BTSHN1
     C                     MOVELBAHIN2    BTSHN2
     C                     MOVELBAHIN3    BTSHN3
     C                     Z-ADDBACGYM    BTKEYM
     C                     Z-ADDBACASU    HTP,#Z
     C                     Z-ADDBACMSU    HTM,#Z
     C                     EXSR #SB004
     C                     WRITEBTAPL051
      *
     C           ESB001    ENDSR
      *-----------------------------------------------------------*
      *          #SB002    BTAPP05_UPDAT処理                    *
      *-----------------------------------------------------------*
     C           #SB002    BEGSR
      *
     C                     ADD  BACASU    HTP,#Z
     C                     ADD  BACMSU    HTM,#Z
     C                     EXSR #SB004
     C                     UPDATBTAPL051
      *
     C           ESB002    ENDSR
      *-----------------------------------------------------------*
      *          #SB003    BTAPP05_UPDAT処理（削除済み）        *
      *-----------------------------------------------------------*
     C           #SB003    BEGSR
      *
     C                     MOVEL*ALL'0'   HTP
     C                     MOVEL*ALL'0'   HTM
     C                     MOVEA*BLANK    HTZ
     C                     Z-ADDBACASU    HTP,#Z
     C                     Z-ADDBACMSU    HTM,#Z
     C                     EXSR #SB004
     C                     UPDATBTAPL051
      *
     C           ESB003    ENDSR
      *-----------------------------------------------------------*
      *          #SB004    更新フィールド移行処理               *
      *-----------------------------------------------------------*
     C           #SB004    BEGSR
     C                     MOVEL*BLANK    BTSKJY
     C                     Z-ADD0         BTSKHZ
     C                     Z-ADD*DATE     BTKOHZ
     C                     TIME           BTKOTI
     C                     MOVELUSID      BTKOME
     C           ESB004    ENDSR
      *-----------------------------------------------------------*
      *          #SB000    部品／構成品マスターチェック処理     *
      *-----------------------------------------------------------*
     C           #SB000    BEGSR
      *
     C           KEY2      CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ELSE
     C                     GOTO ESB000
     C                     END
     C                     END
      *
     C           KEY2      CHAINAKCPL011             20
     C           *IN20     IFEQ '0'
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     END
     C                     END
      *
     C           ESB000    ENDSR
