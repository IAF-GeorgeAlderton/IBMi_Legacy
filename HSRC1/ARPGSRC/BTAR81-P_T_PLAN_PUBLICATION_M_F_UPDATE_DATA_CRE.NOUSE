     C           KEY1      KLIST
     C                     KFLD           BAHIN1
     C                     KFLD           BAHIN2
     C                     KFLD           BAHIN3
     C                     KFLD           BACGYM
     C           KEY2      KLIST
     C                     KFLD           BAHIN1
     C                     KFLD           BAHIN2
     C                     KFLD           BAHIN3
      *
     C                     SETOF                     20
     C                     EXSR #SB000
     C           *IN20     IFEQ '0'
     C                     Z-ADDBACGDD    #Z      20
      *
     C                     SETOF                     10
     C           KEY1      CHAINBTAPL051             10
S1   C           *IN10     IFEQ '0'
 S2  C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     EXSR #SB003
 X2  C                     ELSE
     C                     EXSR #SB002
 E2  C                     END
X1   C                     ELSE
     C                     EXSR #SB001
E1   C                     END
     C                     ELSE
     C                     EXCPTDT
