      *----------------------------------------------------*
     C                     MOVE PYMD2     DSYMD
     C                     MOVE PZAIS     @ZAIS
     C                     Z-ADDPZAIK     @ZAIK
      *----------------------------------------------------*
     C           INISW     IFEQ *BLANK
     C                     Z-ADD0         GGG
     C                     MOVE *DATE     HYMD8
     C                     TIME           TIME
     C                     MOVE *BLANK    J8NM
     C           US        CHAINRGAPL111             10
     C  N10                MOVELJ8NAME    J8NM
     C                     MOVE '1'       INISW   1
     C                     END
      *----------------------------------------------------*
     C* GET SUPPLIER NAME
JW2  C                     MOVELPKAKE     $DLV
 .   C                     CALL 'UTLR62'
 .   C                     PARM           $DLV    4
 .   C                     PARM           $GRP    3
 .   C                     PARM           $NAME1 15
 .   C                     PARM           $NAME2 50
 .   C                     PARM           $RTN    1
JW2  C                     MOVEL$NAME1    @SUPPN
      *----------------------------------------------------*
     C                     SETON                     8988
     C*
     C                     WRITEHED
     C                     WRITEHED2
     C*
     C           KEY3      SETLLBTBPL06
     C           *IN91     DOUEQ*ON
TCHK1C*          KEY2      READEBTBPL06                  91
TCHK1C           KEY3A     READEBTBPL06                  91
     C           *IN91     IFEQ *OFF
     C*
     C           BTSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C*
     C                     Z-ADD1         A       20
     C                     MOVE WYYYY     LYYYY
     C                     MOVE WMMMM     LMMMM
     C           *IN87     IFEQ '0'
     C           DSDD      IFLE 0
     C           DSDD      ORGT 31
     C                     Z-ADD1         X       20
     C                     ELSE
     C           K31       IFNE BTKEYM
     C                     Z-ADD1         X
     C                     ELSE
     C                     Z-ADDDSDD      X
     C                     END
     C                     END
     C                     ELSE
     C                     Z-ADD1         X
     C                     END
     C*
     C******     X         DO   31        A
     C           1         DO   31        A
     C*
     C           #ZM,A     IFEQ *BLANK
     C           #PH,A     IFNE *ZERO
     C           #MH,A     ORNE *ZERO
     C                     Z-ADDA         LDDDD
     C                     Z-SUB#MH,A     LMINU
     C                     Z-ADD#PH,A     LPLUS
     C           LMINU     ADD  LPLUS     LTOTL
     C*
     C                     ADD  LMINU     S#MH    30
     C                     ADD  LPLUS     S#PH    30
     C                     ADD  LTOTL     SSUM    30
     C*
     C                     WRITEDTL2
     C                     MOVE *BLANK    LYYYY
     C                     MOVE *BLANK    LMMMM
     C                     SETOF                     88
     C                     END
     C                     END
     C                     END
KK   C                     SETON                     87
      *
