     FOAAPW31 CF  E                    WORKSTN
     FOAAPL31 UF  E           K        DISK                      A
     E                    KOCD    1   3  1   KONM    8   UPDATE INSTRUCT
     E                    ER      1  14 60               ERROR MESSAGE
     I            DS
     I                                        1   80R7SKHZ
     I                                        1   40R7SKYY
     I                                        5   60R7SKMM
     I                                        7   80R7SKDD
     I            DS
     I                                        1   80R7KOHZ
     I                                        1   40R7KOYY
     I                                        5   60R7KOMM
     I                                        7   80R7KODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20R7KOHH
     I                                        3   40R7KOSS
     C           *ENTRY    PLIST
     C                     PARM           PARM1  10        USER NAME
     C                     Z-ADD0         R7SKHZ
     C*
     C* fﾞx]-1
     C*
     C           @SCR1     TAG
     C                     EXFMTOAAPW311
     C                     SETOF                     020399
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C* ﾃcﾆ]hﾎﾞ]
     C*
     C                     MOVE *BLANK    @KONM   8
     C                     SETOF                     20
     C                     Z-ADD1         A       10
     C           @KOSN     LOKUPKOCD,A                   20
     C           *IN20     IFEQ '0'
     C                     SETON                     0299
     C                     MOVELER,01     MSG
     C                     GOTO @SCR1
     C                     END
     C                     MOVELKONM,A    @KONM
     C*
     C* ﾆﾑchﾎﾞ]
     C*
     C           @SKBN     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVELER,02     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C* lbf
     C*
     C                     SETOF                     30
     C           @SKBN     CHAINOAAPL311             30
     C           @KOSN     IFEQ '2'
     C           *IN30     IFEQ '0'
     C           R7SKJY    IFEQ 'D'
     C           R7SKHZ    ANDLE*DATE
     C                     GOTO @001
     C                     END
     C                     SETON                     020399
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* s]ﾃc
     C*
     C           @KOSN     IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     SETON                     020399
     C                     MOVELER,04     MSG
     C                     GOTO @SCR1
     C                     END
     C           R7SKJY    IFEQ 'D'
     C           R7SKHZ    ANDLE*DATE
     C                     SETON                     020399
     C                     MOVELER,05     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* nﾒiﾆ
     C*
     C           @KOSN     IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     SETON                     020399
     C                     MOVELER,06     MSG
     C                     GOTO @SCR1
     C                     END
     C           R7SKJY    IFEQ 'D'
     C           R7SKHZ    ANDLE*DATE
     C                     SETON                     020399
     C                     MOVELER,07     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C           @001      TAG
     C*
     C                     MOVE R7YOME    @YOME
     C           @KOSN     IFEQ '2'
     C                     MOVE *BLANK    @YOME
     C                     END
     C*
     C                     SETON                     70
     C*
     C* fﾞx]-2
     C*
     C           @SCR2     TAG
     C                     EXFMTOAAPW311
     C                     SETOF                     020399
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @SKBN
     C                     MOVE *BLANK    @YOME
     C                     SETOF                     70
     C                     GOTO @SCR1
     C                     END
     C*
     C* ﾑcnxbﾆｭc
     C*
     C           @YOME     IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,08     MSG
     C                     GOTO @SCR2
     C                     END
     C*
     C  NKE                GOTO @SCR2
     C*
     C                     MOVE @SKBN     R7SKBN
     C                     MOVE @YOME     R7YOME
     C*
     C                     MOVE @KONM     MKOSN
     C                     MOVE @SKBN     MSKBN
     C                     MOVE @YOME     MYOME
     C*
     C           @KOSN     IFEQ '0'
     C                     MOVEL'D'       R7SKJY
     C                     Z-ADD*DATE     R7SKHZ
     C                     ELSE
     C                     MOVE *BLANK    R7SKJY
     C                     Z-ADD0         R7SKHZ
     C                     END
     C                     Z-ADD*DATE     R7KOHZ
     C                     TIME           WTIME
     C                     MOVELPARM1     R7KOME
     C           *IN30     IFEQ '0'
     C                     UPDATOAAPL311
     C                     ELSE
     C                     WRITEOAAPL311
     C                     END
     C*
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @SKBN
     C                     MOVE *BLANK    @YOME
     C                     SETOF                     70
     C                     GOTO @SCR1
**  (KOCD/KONM)
00-CANCEL
11-CHANGE
22-ADD
**  ER
E-01  UPDATE INSTRUCTION IS 0.1.2
E-02  USE INSTRUCTION ISN'T INPUT
E-03  ADD WAS APPOINTED, BUT M/F EXISTS
E-04  A CHANGE WAS APPOINTED, BUT M/F DOESN'T EXIST
E-05  A CHANGE WAS APPOINTED, BUT M/F IS CANCELLED ALREADY
E-06  A CANCELLATION WAS APPOINTED, BUT M/F DOESN'T EXIST
E-07  A CANCELLATION WAS APPOINTED, BUT M/F IS CANCELLED
E-08  USE NAME ISN'T INPUT
