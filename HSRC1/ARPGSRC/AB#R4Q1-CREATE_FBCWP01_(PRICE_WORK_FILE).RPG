     H            Y.
     F** AB#R4Q1 **********************************************
     F*  CREATE FBCWP01 (PRICE WORK FILE)                     *
     F*  J.W    2024.05.08                                    *
     F*********************************************************
     FFBCPL01 IF  E           K        DISK
     FFBCWP01 IF  E           K        DISK                      A
      *========================================================
     I            DS
     I                                        1  12 SHIN1
     I                                        1   5 FBSHN1
     I                                        6  10 FBSHN2
     I                                       11  12 FBSHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      * MAIN ROUTINE
      ******************************************************
     C                     EXSR #INIT
      *
     C                     EXSR #TYT
      *
     C                     EXSR #FRD
      *
     C                     EXSR #HND
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      * CREATE FBCWP01 FROM TOYOTA PART
      ******************************************************
     C           #TYT      BEGSR
      *
     C           3411      SETLLFBCPL01
     C                     DO   *HIVAL
     C           3411      READEFBCPL01                  98
     C   98                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C           FBTSYY    ORNE 9999
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'TYT'     KBGRP
     C                     EXSR #CHK01
     C           EFLG      IFEQ 'N'
     C                     Z-ADD0         FBNONY
     C                     MOVEL'TYT'     FBGRP
     C                     WRITEFBCWP011
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * CHECK PART EXISTS IN WP01?
      ******************************************************
     C           #CHK01    BEGSR
      *
     C                     MOVE ' '       EFLG    1
     C                     MOVELFBMHN1    KBMHN1
     C                     MOVELFBMHN2    KBMHN2
     C                     MOVELFBMHN3    KBMHN3
     C                     MOVELFBMHN4    KBMHN4
     C           KEY01     CHAINFBCWP01              98
     C           *IN98     IFEQ *OFF
     C                     MOVE 'Y'       EFLG
     C                     ELSE
     C                     MOVE 'N'       EFLG
     C                     ENDIF
      *
     C                     ENDSR
      ******************************************************
      * CREATE FBCWP01 FROM FORD PART
      ******************************************************
     C           #FRD      BEGSR
      *
     C           5149      SETLLFBCPL01
     C                     DO   *HIVAL
     C           5149      READEFBCPL01                  98
     C   98                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C           FBTSYY    ORNE 9999
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'FRD'     KBGRP
     C                     EXSR #CHK01
     C           EFLG      IFEQ 'N'
     C                     Z-ADD0         FBNONY
     C                     MOVEL'FRD'     FBGRP
     C                     WRITEFBCWP011
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * CREATE FBCWP01 FROM HONDA PART
      ******************************************************
     C           #HND      BEGSR
      *
      *
     C           *LOVAL    SETLLFBCPL01
     C                     DO   *HIVAL
     C                     READ FBCPL01                  98
     C   98                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C           FBTSYY    ORNE 9999
     C                     ITER
     C                     ENDIF
      * SELECT HONDA
     C           FBTOKU    IFNE 0294
     C           FBTOKU    ANDNE0295
     C           FBTOKU    ANDNE0296
     C           FBTOKU    ANDNE0390
     C           FBTOKU    ANDNE0391
     C           FBTOKU    ANDNE0400
     C           FBTOKU    ANDNE1602
     C           FBTOKU    ANDNE3135
     C           FBTOKU    ANDNE8080
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'HND'     KBGRP
     C                     EXSR #CHK01
     C           EFLG      IFEQ 'N'
     C                     Z-ADD0         FBNONY
     C                     MOVEL'HND'     FBGRP
     C                     WRITEFBCWP011
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      * INITIAL SETTING
      ******************************************************
     C           #INIT     BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           KBGRP   3
     C                     KFLD           KBMHN1  5
     C                     KFLD           KBMHN2  5
     C                     KFLD           KBMHN3  5
     C                     KFLD           KBMHN4  5
      *
     C                     ENDSR
