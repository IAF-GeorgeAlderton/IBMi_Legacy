     C           #SET2E    ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
B001 C                     DO   *HIVAL
     C           KEY2      READEAJSPL641                 40
     C           MORE2     TAG
     C   40                GOTO @ROLE
      *
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    IFLE *DATE
     C                     GOTO MORE2
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C           J6KEHZ    CABLTSHIZ      @END1
     C           J6KEHZ    CABGTEHIZ      @ROLE
     C                     MOVEL'*'       SW
     C                     MOVE J6MKKB    @KIBN
     C                     MOVELJ6THAI    @TEHI
     C                     MOVELJ6PAG1    @PAG1
     C                     MOVELJ6PAG2    @PAG2
     C                     MOVELJ6PAG3    @PAG3
     C                     MOVELJ6PAG4    @PAG4
     C                     Z-ADDJ6MKSU    @KEIS
     C                     MOVELJ6IROK    @IRO
     C                     Z-ADDJ6WKHZ    @THIZ
     C                     Z-ADDJ6WKTM    @TTIM
     C                     Z-ADDJ6KEHZ    @HHIZ
     C                     Z-ADDJ6KETM    @HTIM
     C                     MOVELJ6KANK    #KNKB
     C                     MOVELJ6ZETI    #ZNO
     C                     MOVELJ6THAI    #TNO
     C                     MOVELJ6PAG1    #PNO1
     C                     MOVELJ6PAG2    #PNO2
     C                     MOVELJ6PAG3    #PNO3
     C                     MOVELJ6PAG4    #PNO4
     C                     MOVELJ62JKA    #2JIK
     C                     MOVELJ6TASY    #TISG
     C                     MOVELJ6SYKO    #SYKB
     C                     MOVELJ6HKBR    #HAKO
     C                     Z-ADDJ6MKSU    #KEIS
     C                     MOVELJ6IROK    #IRO
     C                     Z-ADDJ6SYUY    #SYOS
     C                     MOVELJ6HKFA    #MHKO
     C                     Z-ADDJ6TANJ    #TANJ
     C                     Z-ADDJ6WKHZ    #THIZ
     C                     Z-ADDJ6WKTM    #TTIM
     C                     Z-ADDJ6WMJY    #TNMJ
     C                     MOVE J6MKKB    #KIBN
     C                     Z-ADDJ6KEHZ    #KHIZ
     C                     Z-ADDJ6KETM    #KTIM
     C                     Z-ADDJ6WAIT    #KEIJ
     C                     MOVE J6TOCD    #TOCD
     C                     MOVE J6ZBR1    #ZAI1
     C                     MOVE J6ZBR2    #ZAI2
     C                     MOVE J6KECD    #KECD
     C                     MOVE J6GAFR    #GAFR
     C                     MOVE J6NGFR    #NGFR
     C                     MOVE J6MKFR    #MKFR
     C                     MOVE J6SAIK    #SAIK
     C                     Z-ADDJ6SOKK    #SOKK
     C                     Z-ADDJ6TMAI    #TMAI
      *
     C           J6SAIK    IFEQ '0'
