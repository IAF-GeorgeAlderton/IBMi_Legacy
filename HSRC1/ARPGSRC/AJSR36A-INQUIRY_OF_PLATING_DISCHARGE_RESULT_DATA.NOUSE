     C                     MOVE #TMAI     XXTMAI
     C                     MOVE #GAFR     XXGAFR
     C                     MOVE #NGFR     XXNGFR
     C                     MOVE #MKFR     XXMKFR
     C                     Z-ADD#SOKK     XXSOKK
     C                     MOVE #SAIK     XXSAIK
      *  EXFMT fﾞx] 2
     C                     EXSR #SET2
