      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GAD     KLIST
     C                     KFLD           EKTOKU
     C                     KFLD           K@NONY  40
     C           P#66      PLIST
     C                     PARM           D@FROM
     C                     PARM           D@TO
      *
     C                     TIME           @@TIM   60
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KDAT    D@FROM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDD@FROM    D@TO
      *
     C                     MOVE '1'       D@OUTP
      *
     C                     MOVE *ALL'-'   W@LINE190
     C                     MOVE '01'      W@ID    2
      *
     C                     MOVEL'ALDR2Z'  SHPGM  10
      *
     C           K#AMK1    KLIST
     C                     KFLD           R4PGM
     C                     KFLD           R4KOME
     C                     KFLD           A5KSDT
     C                     KFLD           A5KSTM
      *
     C                     ENDSR
      **************************************************************************
     C           #SCRN1    BEGSR
      **************************************************************************
     C                     EXFMTDSP01
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
      *
     C                     EXSR #CHK1
      * if no errors,
     C           *IN99     IFEQ *OFF
      *
     C                     SELEC
     C           *INKE     WHEQ *ON
     C           D@OUTP    IFEQ '1'
     C           D@OUTP    OREQ '2'
     C                     MOVE 'P'       @@OUT   1        output type
     C                     ELSE
     C                     MOVE 'F'       @@OUT            output type
     C                     ENDIF
     C                     OTHER
     C                     GOTO #END1
     C                     ENDSL
      *
     C           @@OUT     IFEQ 'P'
     C                     EXSR OVRPRT
     C                     ENDIF
      *
     C                     EXSR #OUT
      *
     C           @@OUT     IFEQ 'P'
     C                     CALL 'ALDR66'  P#66
     C                     ENDIF
      *
     C                     MOVE '99'      W@ID
      *
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           #END1     ENDSR
      **************************************************************************
      *  CHECK--WORKER ID
      **************************************************************************
     C           #CHK1     BEGSR
      *
     C                     SETOF                     616263
     C                     SETOF                     646566
     C                     SETOF                     99
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FROM    D@TO
     C                     ENDIF
     C           D@TO      IFLT D@FROM
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     Z-ADDD@FROM    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@TOTM    IFEQ *ZERO
     C                     Z-ADD2359      D@TOTM
     C                     ENDIF
      *
     C           D@FROM    IFEQ D@TO
     C           D@TOTM    IFLT D@FRTM
     C                     MOVEA'11'      *IN,64
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
     C           D@OTN     IFNE *BLANK
     C           D@OTN     ANDNE'1'
     C                     SETON                     6399
     C                     ENDIF
      *
     C           D@OUTP    IFNE '1'
     C           D@OUTP    ANDNE'2'
     C           D@OUTP    ANDNE'F'
     C                     SETON                     6699
     C                     ENDIF
      *
     C           D@FRTM    MULT 100       W@FRTM  60
     C           D@TOTM    MULT 100       W@TOTM  60
     C                     ADD  59        W@TOTM
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  OVERRIDE PRINT FILE - FOR OUTPUT CONTROL
      *--------------------------------------------------------
     C           OVRPRT    BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     MOVE D@OUTP    X       20
     C                     MOVELCMD,X     P@CMD
     C                     Z-ADD80        P@LEN
      *
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN QPRINT
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  OUTPUT
      *--------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN98
     C           D@FROM    SETLLALDPL50
     C           *IN80     DOUEQ*ON
     C                     READ ALDPL50                  80
     C           *IN80     IFEQ *OFF
      *
      *** ERROR 30 is not a user error. It's used to track unscanned APICS
     C           A5ERID    IFEQ '30'
     C                     ITER
     C                     ENDIF
      *
     C           A5KSDT    IFEQ D@FROM
     C           A5KSTM    ANDLTW@FRTM
     C                     ITER
     C                     ENDIF
      *
     C           A5KSDT    IFEQ D@TO
     C           A5KSTM    ANDGTW@TOTM
     C                     LEAVE
     C                     ENDIF
      *
     C           A5KSDT    IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE A5OPER    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C           *IN90     IFEQ *OFF
     C                     MOVELALWKNM    USRNAM 20
     C                     ELSE
     C                     MOVEL'UNKNOWN' USRNAM
     C                     ENDIF
      *
     C           A5ERID    IFEQ ' '
     C                     MOVE '01'      A5ERID
     C                     ENDIF
     C                     MOVE A5ERID    @2      20
     C                     MOVELERR,@2    W@MSG  15
      *
     C                     MOVE *BLANK    WSC
TCHK2C*
TCHK2C                     MOVEL*OFF      *IN95
     C                     CLEARAB#PP701
TCHK2C           A5SERL    IFNE *BLANK
     C           A5SERL    CHAINAB#PL71              95
TCHK2C                     ELSE
TCHK2C                     EXSR #PL70
TCHK2C                     END
     C           *IN95     IFEQ *OFF
     C                     MOVE EKNONY    K@NONY
     C                     MOVEL*BLANK    W5KMEI 15
     C           K#GAD     CHAINGADPL11              95
     C  N95                MOVELB5KMEI    W5KMEI
      *
B0   C           EKDATE    IFNE *ZERO
      *
     C                     MOVE '*'       W@5
TCH24C* TRY A/B LABEL (HONDA)
   | C                     ELSE
TCHK2C*                    CLEARAORB2
     C                     MOVE A5SERL    KEY6
TCHK2C                     CLEARAORB2
     C           AORB1     IFEQ 'A'
     C                     MOVE 'B'       AORB2
     C                     ELSE
     C           AORB1     IFEQ 'B'
     C                     MOVE 'A'       AORB2
     C                     ENDIF
     C                     ENDIF
     C           AORB2     IFNE ' '
     C           KEY6      CHAINAB#PL71              95
     C           EKDATE    IFNE *ZERO
     C           *IN95     ANDEQ*ZERO
     C                     MOVE '*'       W@5
   | C                     ENDIF
TCH24C                     ENDIF
      *
E0   C                     ENDIF
     C           A5ERPS    IFEQ ' '
     C           A5ERPS    OREQ '11'
     C                     MOVE '01'      A5ERPS
     C                     ENDIF
     C                     MOVE A5ERPS    @2
     C                     MOVE '*'       WSC,@2
      *
     C           D@OTN     IFEQ *BLANK
     C           W@5       ANDNE*BLANK
     C                     ITER
     C                     ENDIF
      *
     C           @@OUT     IFEQ 'P'
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
     C                     ENDIF
      *
TCHK2C   95                MOVELA5SERL    W@SERL 18
TCHK2C  N95                MOVELEKSERL    W@SERL 18
TCHK2C*
     C           @@OUT     IFEQ 'P'
     C                     EXCPT@DTL
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     ULDATE
     C                     Z-ADD*ZERO     ULTIME
     C                     MOVE *BLANKS   TLNAME
      *
     C           W@3       IFEQ '*'
     C                     EXSR GETTL
     C                     ENDIF
      *
     C           @@OUT     IFEQ 'F'
     C                     EXSR WRTDTL
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
