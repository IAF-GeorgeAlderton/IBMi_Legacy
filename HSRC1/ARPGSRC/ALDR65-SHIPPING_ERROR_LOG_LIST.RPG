      *-------------------------------------------------------
      *  GET TEAM LEADER NAME THAT UNLOCKED ERROR
      *--------------------------------------------------------
     C           GETTL     BEGSR
      *
     C                     MOVE *BLANKS   TLNAME 20
     C                     MOVE *BLANKS   KOME   10
     C                     Z-ADD*ZERO     ULDATE  80
     C                     Z-ADD*ZERO     ULTIME  60
      *
     C                     MOVELA5OPER    R4KOME
     C                     MOVE SHPGM     R4PGM
     C           K#AMK1    CHAINAM#PL32              51
     C           *IN51     IFEQ *ON
     C                     ADD  1         A5KSTM
     C           K#AMK1    CHAINAM#PL32              51
     C                     ENDIF
     C           *IN51     IFEQ *OFF
     C                     Z-ADDR4KOHU    ULDATE
     C                     Z-ADDR4KOTU    ULTIME
     C                     MOVELR4KOME    KOME
      *
      * get team leader name from worker code master file.
     C           R4WKCD    IFNE *ZERO
     C           R4WKCD    CHAINALBPL30              51
     C           *IN51     IFEQ *OFF
     C                     MOVELALWKNM    TLNAME
     C                     ENDIF
     C                     ENDIF
      *
     C           @@OUT     IFEQ 'P'
     C                     EXCPT@DTL2
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
TCHK2 *-------------------------------------------------------
      *  WRITE DETAIL TO CSV WORKFILE
      *--------------------------------------------------------
     C           WRTDTL    BEGSR
      *
     C                     MOVELUSRNAM    AEWKNM
     C                     MOVELA5KSDT    AEKSDT
     C                     MOVELA5KSTM    AEKSTM
     C                     MOVELW@1       AEW@1
     C                     MOVELW@2       AEW@2
     C                     MOVELW@3       AEW@3
     C                     MOVELW@4       AEW@4
     C                     MOVELW@5       AEW@5
     C  N95                MOVELEKDATE    AECODT
     C  N95                MOVELEKDETM    AECOTM
     C           ''''      CAT  W@SERL:0  AESERL
     C  N95                MOVELEKSHN1    AESHN1
     C  N95                MOVELEKSHN2    AESHN2
     C  N95                MOVELEKSHN3    AESHN3
     C  N95                MOVELEKLOC1    AELOC1
     C  N95                MOVELEKLOC2    AELOC2
     C  N95                MOVELEKLOC3    AELOC3
     C  N95                MOVELEKLOC4    AELOC4
     C  N95      ''''      CAT  EKODRN:0  AEODRN
     C  N95                MOVELEKNONY    AENONY
