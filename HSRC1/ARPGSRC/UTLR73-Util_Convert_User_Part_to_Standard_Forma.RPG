     H            Y.
     F** UTLR73 ***********************************************************
     F*  CONVERT USER PART TO STANDARD FORMAT
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR73'
     F*                    PARM           $IN    30
     F*                    PARM           $MHIN  20
     F*                    PARM           $MHN1   5
     F*                    PARM           $MHN2   5
     F*                    PARM           $MHN3   5
     F*                    PARM           $MHN4   5
     F*                    PARM           $RTN    1
     F*   IN  $IN    30A   ORIGINAL USER PART
     F*   OUT $MHIN  20A   IAF STANDARD FORMAT USER PART
     F*       $MHN1   5A   USER PART 1
     F*       $MHN2   5A   USER PART 2
     F*       $MHN3   5A   USER PART 3
     F*       $MHN4   5A   USER PART 4
     F*       $RTN    1A   RETURN (BLANK: OK, *: ERROR)
     F*********************************************************************
     E                    IN         30  1
     E                    OT         20  1
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
     F******************************************************************
     C           *ENTRY    PLIST
     C                     PARM           $IN    20
     C                     PARM           $MHIN  20
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $RTN    1
      *
     C                     MOVEA$IN       IN
     C                     MOVE *BLANK    $MHIN
     C                     MOVE *BLANK    $MHN1
     C                     MOVE *BLANK    $MHN2
     C                     MOVE *BLANK    $MHN3
     C                     MOVE *BLANK    $MHN4
     C                     MOVE *BLANK    $RTN
      *
     C                     MOVE *ALL' '   OT
     C                     Z-ADD0         IX      20
     C                     Z-ADD0         IY      20
     C* EXAMIN FROM BACKWARD
     C                     DO   *HIVAL
     C                     ADD  1         IX
      * END
     C           IX        IFGE 31
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           IN,IX     IFEQ *BLANK
     C           IN,IX     OREQ ','
     C           IN,IX     OREQ '-'
     C                     ITER
     C                     ENDIF
      * MOVE VALUE
     C                     ADD  1         IY
      * END
     C           IY        IFGE 21
     C                     MOVE '*'       $RTN
     C                     LEAVE
     C                     ENDIF
     C                     MOVE IN,IX     OT,IY
      *
     C                     ENDDO
      *
     C                     MOVEAOT        $MHIN
     C                     MOVEAOT        WMHIN
     C                     MOVELWMHN1     $MHN1
     C                     MOVELWMHN2     $MHN2
     C                     MOVELWMHN3     $MHN3
     C                     MOVELWMHN4     $MHN4
      *
     C                     SETON                     LR
     C                     RETRN
