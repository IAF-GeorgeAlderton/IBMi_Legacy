     H            Y.
     F** AAFR55 ***********************
     F*  ..RECEIVING CONTROL SHEET..  *
     F*    I-HASADA       97.08.15    *
     F*********************** AAFR55 **
     FAAFPW55 CF  E                    WORKSTN
     FFCEPL01 IF  E           K        DISK
     FAKCPL01 IF  E           K        DISK
     FAAFWP55 IF  E           K        DISK                      A
     E                    ER      1   6 60
     I            DS
     I                                        1  12 ISHIN
     I                                        1   5 ISHN1
     I                                        6  10 ISHN2
     I                                       11  12 ISHN3
     I            DS
     I                                        1  12 ZZSHIN
     I                                        1   5 ZZSHN1
     I                                        6  10 ZZSHN2
     I                                       11  12 ZZSHN3
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     C           KEY1      KLIST
     C                     KFLD           ISHN1
     C                     KFLD           ISHN2
     C                     KFLD           ISHN3
      *
     C           KEY2      KLIST
     C                     KFLD           ISHN1
     C                     KFLD           ISHN2
     C                     KFLD           ISHN3
     C                     KFLD           IKCD1
      *
     C           STP1      TAG
     C                     EXFMTAAFPW551
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           ISHIN     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IKCD1     IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IKCD1     IFNE '0'
     C           IKCD1     ANDNE'3'
     C           IKCD1     ANDNE'6'
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IKCD1     IFEQ '0'
     C           IKCD1     OREQ '6'
      *
     C                     SETOF                     10
     C           KEY1      CHAINFCEPL011             10
     C           *IN10     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           IKCD1     IFEQ '3'
      *
     C                     SETOF                     10
     C           KEY1      CHAINAKCPL011             10
     C           *IN10     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     SETOF                     10
     C           KEY2      CHAINAAFWP551             10
     C           *IN10     IFEQ '0'
     C                     SETON                     010299
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *
     C                     SETON                     U1
     C                     MOVE ISHIN     ZZSHIN
     C                     MOVE IKCD1     ZZKCD1
     C                     WRITEAAFWP551
      *
     C                     MOVE *BLANK    ISHIN
     C                     MOVE *BLANK    IKCD1
     C                     GOTO STP1
      *
** ER
E-01 INTRAL COMPANY PART NO.
E-02 INPUT KANBAN
E-03 KANBAN IS < 0.3.6 >
E-04 PART INFORMATION M/F DON'T EXIST
E-05 COMPONENTS PART INFORMATION M/F DON'T EXIST
E-06 RECEIVING CONTROL SHEET DATA EXIST
