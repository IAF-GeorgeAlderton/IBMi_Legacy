      *--------*
      * SCREEN 1
      *--------*
     C           @STP1     TAG
      *
     C                     EXFMTEGBPW971
      *
     C                     SETOF                     019902
     C                     SETOF                     22
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           M1USR     IFEQ *BLANK
     C           M1USRP    OREQ *BLANK
     C                     MOVELER,2      ERR
     C                     SETON                     019902
     C                     GOTO @STP1
     C                     ENDIF
      *
     C           M1USR     IFEQ M1USRP
     C                     MOVELER,3      ERR
     C                     SETON                     019902
     C                     GOTO @STP1
     C                     ENDIF
      * CHECK EXISTENCE
     C           M1USR     CHAINRGAPL111             33
     C           M1USRP    CHAINRGAPL111             22
      * 33=ON
     C           *IN33     IFEQ '1'
     C                     MOVELER,1      ERR
     C                     SETON                     0199
     C                     GOTO @STP1
     C                     ENDIF
      * 22=ON
     C           *IN22     IFEQ '1'
     C                     MOVELER,4      ERR
     C                     SETON                     0299
     C                     GOTO @STP1
     C                     ENDIF
      * 削除済み
     C           *IN22     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C                     MOVELER,4      ERR
     C                     SETON                     0299
     C                     GOTO @STP1
     C                     ENDIF
     C           *IN33     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C                     MOVELER,1      ERR
     C                     SETON                     0199
     C                     GOTO @STP1
     C                     ENDIF
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP1
     C                     END
      * DELETE ALL DATA (USER-TO)
     C                     SETOF                     39
     C           M1USRP    SETLLEGBPL111
     C                     DO   *HIVAL
     C           M1USRP    READEEGBPL111                 39
     C                     MOVEL'D'       M1SKJY
     C  N39                UPDATEGBPL111
     C  N39                ENDDO
     C                     SETOF                         88
      *
     C           M1USR     SETLLEGBPL111
      *
     C***                  DO   *HIVAL
     C***                  SETOF                     88
     C           *IN88     DOUEQ*ON
     C           M1USR     READEEGBPL111                 88
     C           *IN88     IFEQ *OFF
     C           M1SKJY    ANDEQ*BLANK
     C***                  GOTO @END
      *
     C           M1KEY     KLIST
     C                     KFLD           M1USRP
     C                     KFLD           M1MNNO
     C                     KFLD           M1MNDN
     C                     SETOF                     77
     C           M1KEY     CHAINEGBPL121             77
      * WRITE
     C                     MOVE *BLANK    MASKJY
     C                     MOVELM1USRP    MAUSRC
     C                     MOVEL*DATE     MAKOHZ
     C                     MOVELM1MNNO    MAMNNO
     C                     MOVELM1MNDN    MAMNDN
     C                     MOVELM1PGMN    MAPGMN
     C                     MOVELM1TEXT    MATEXT
     C                     MOVELM1KNJI    MAKNJI
     C                     MOVELM1KIMT    MAKIMT
     C                     MOVELM1SAYY    MASAYY
     C*                    MOVELM1SAY4    MASAY4
     C                     MOVELM1SAMM    MASAMM
     C                     MOVELM1SADD    MASADD
      *
     C           *IN77     IFEQ '1'
     C                     WRITEEGBPL121
     C                     ELSE
     C                     UPDATEGBPL121
     C                     ENDIF
      *
     C                     ENDIF
     C*          @END      TAG
     C  N88                ENDDO
      *
     C                     EXFMTEGBPW972
      *
     C                     GOTO @STP1
