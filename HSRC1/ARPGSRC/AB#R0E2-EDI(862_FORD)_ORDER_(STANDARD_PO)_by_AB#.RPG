     H            Y.
     F** AB#R0E2 ************************************************
     F*  EDI(862 FORD) ORDER (STANDARD PO)                      *
     F*  JW    2021.12.01                                       *
     F***********************************************************
     FAB#EP50 IF  E           K        DISK
     FABF5P01 O   E           K        DISK
      ****************************************************
     E                    IPAR       30  1
     E                    OPAR       20  1
      ****************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  20 A5MHIN
     I                                        1   5 A5MHN1
     I                                        6  10 A5MHN2
     I                                       11  15 A5MHN3
     I                                       16  20 A5MHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#EP50
     C                     DO   *HIVAL
     C                     READ AB#EP50                  98
     C   98                LEAVE
      * RESET QTY
     C           A5SIDT    IFNE SVSIDT
     C           A5STID    ORNE SVSTID
     C           A5DOCK    ORNE SVDOCK
     C           A5PART    ORNE SVPART
     C                     Z-ADD0         SVQTY
     C                     ENDIF
     C           A5QTY2    SUB  A5YSQY    @QTY   100
     C                     SUB  SVQTY     @QTY
      *
     C           @QTY      IFGT 0
     C                     EXSR #EDIT
     C                     WRITEABF5P011
      * SAVE
     C                     Z-ADDA5SIDT    SVSIDT           ISSUE DATE
     C                     MOVELA5STID    SVSTID           PLANT
     C                     MOVELA5DOCK    SVDOCK           DOCK
     C                     MOVELA5PART    SVPART           PART
     C                     Z-ADDA5NOHZ    SVNOHZ           SHIP DATE
     C                     ADD  A5QTY     SVQTY            QTY
      *
     C                     ENDIF
      *
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C***********************************************************
     C* EDIT DATA
     C***********************************************************
     C           #EDIT     BEGSR
      *
     C                     Z-ADDTODAY     A5CRDT
     C                     Z-ADDNOW       A5CRTM
     C                     Z-ADD5149      A5TOKU
      *
     C                     MOVELA5STID    $PLNT
     C                     MOVELA5DOCK    $DOCK
     C                     CALL 'UTLR34A'
     C                     PARM           $PLNT   5
     C                     PARM           $DOCK   4
     C                     PARM           $NONY   4
     C                     PARM           $RTN    1
     C                     MOVEL$NONY     A5NONY
      *
     C                     MOVELA5DOCK    A5NUKE
     C                     Z-ADDA5DLDT    A5NOHZ
     C                     Z-ADD@QTY      A5QTY
     C                     MOVELA5PONO    A5ODRN    P
     C                     MOVEL'11111'   A5INVN    P
     C                     MOVEL'862'     A5EDIT    P
      * PART
     C                     MOVEAA5PART    IPAR
     C                     MOVE *BLANK    OPAR
     C                     Z-ADD0         M       20
     C*
     C           1         DO   30        N       20
     C           IPAR,N    IFNE *BLANK
     C                     ADD  1         M
     C                     MOVE IPAR,N    OPAR,M
     C                     ENDIF
     C                     ENDDO
     C*
     C                     MOVEAOPAR      A5MHIN
     C                     MOVEAOPAR      A5IPAR
     C                     Z-ADDTODAY     A5DATE
     C                     Z-ADDNOW       A5TIME
      *
     C                     ENDSR
      *--------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SVSIDT  80       ISSUE DATE
     C                     MOVE *BLANK    SVSTID  5        PLANT
     C                     MOVE *BLANK    SVDOCK  4        DOCK
     C                     MOVE *BLANK    SVPART 40        PART
     C                     Z-ADD0         SVNOHZ  80       SHIP DATE
     C                     Z-ADD0         SVQTY  100       QTY
      *
     C                     ENDSR
