     C           KEY       KLIST
     C                     KFLD           @TOKU
     C                     KFLD           @NOKJ
     C                     KFLD           HIYY
     C                     KFLD           HIMM
     C*---------------
     C*  ﾆｭg ﾈｮmb
     C*---------------
     C           LAB1      TAG
     C                     Z-ADD0         @TOKU
     C                     MOVE *BLANK    @NOKJ
     C                     Z-ADD0         @HIZK
     C*--   --*
     C* SETOF *
     C*--   --*
     C                     Z-ADD0         Q       20
     C           11        DO   47        Q
     C                     MOVE '0'       *IN,Q
     C                     END  1
     C*---------------
     C*  AGDPW331 ﾍｭcﾆﾞ
     C*---------------
     C           LAB2      TAG
     C                     EXFMTAGDPW331
     C                     SETOF                     010203
     C                     SETOF                     99
     C*---------------
     C*  CMD-1 kｩｮh
     C*---------------
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*---------------
     C*  CMD-2 kｩｮh
     C*---------------
     C           *INKB     IFEQ '1'
     C                     SETON                     U1LR
     C                     RETRN
     C                     END
     C*---------------
     C*  nhbﾅg ﾉ kｩｮh
     C*---------------
     C           @TOKU     IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,1      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           @TOKU     CHAINFGBPL01              90
     C           *IN90     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      @ERR
     C                     GOTO LAB2
     C                     ELSE
     C                     MOVELB2SMEI    TKMEI
     C                     END
     C*---------------
     C*  DATE ﾉ kｩｮh
     C*---------------
     C           @HIZK     IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,3      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           HIYY      IFGE 1990
     C           HIMM      ANDGE01
     C           HIMM      ANDLE12
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,4      @ERR
     C                     GOTO LAB2
     C                     END
     C*---------------
     C*  DATA kｩｮh
     C*---------------
     C*                    SETOF                     90
     C           KEY       SETLLAGDPL31                  90
     C           *IN90     IFEQ '0'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,5      @ERR
     C                     GOTO LAB2
     C                     END
     C*---------------
     C*  ﾆｭg ﾈｮmb
     C*---------------
     C                     Z-ADD0         @YB
     C                     MOVE *BLANK    @HI
     C                     MOVE *BLANK    @YO
     C                     MOVE *BLANK    @ZE
     C                     MOVE *BLANK    @RI
     C                     MOVE *BLANK    SW      1
     C                     Z-ADD0         @KADO   31
     C                     Z-ADD0         @JUN1   31
     C                     Z-ADD0         @JUN2   31
     C                     Z-ADD0         @JUN3   31
     C*---------------
     C*  xb] ﾓｰk]
     C*---------------
     C                     DO   *HIVAL
     C                     SETOF                     90
     C           KEY       READEAGDPL31                  90
     C           *IN90     CABEQ'1'       EXIT
     C*
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C           F8RIKB    IFEQ *BLANK
     C*--         --*
     C* fnﾞcﾍﾞ kｩｮh *
     C*--         --*
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADD1         @KU     21
     C                     ELSE
     C                     Z-ADD0.5       @KU
     C                     END
     C*--         --*
     C* fnﾞcﾍﾞ ibﾅ] *
     C*--         --*
     C                     ADD  @KU       @KADO
     C*--         --*
     C*  ﾆﾞｬ] kｩｮh  *
     C*--         --*
     C           F8KADD    IFGE 01
     C           F8KADD    ANDLE10
     C                     ADD  @KU       @JUN1
     C                     END
     C           F8KADD    IFGE 11
     C           F8KADD    ANDLE20
     C                     ADD  @KU       @JUN2
     C                     END
     C           F8KADD    IFGE 21
     C           F8KADD    ANDLE31
     C                     ADD  @KU       @JUN3
     C                     END
     C                     END
     C*
     C                     END
     C*--         --*
     C*  ﾑcﾍﾞ kｩｮh  *
     C*--         --*
     C           SW        IFEQ *BLANK
     C                     Z-ADD0         C       20
     C                     MOVE '*'       SW
     C                     Z-ADD0         @YB
     C*
     C           F8YOBI    IFEQ 1
     C                     Z-ADD2         C
     C                     END
     C*
     C           F8YOBI    IFEQ 2
     C                     Z-ADD3         C
     C                     END
     C*
     C           F8YOBI    IFEQ 3
     C                     Z-ADD4         C
     C                     END
     C*
     C           F8YOBI    IFEQ 4
     C                     Z-ADD5         C
     C                     END
     C*
     C           F8YOBI    IFEQ 5
     C                     Z-ADD6         C
     C                     END
     C*
     C           F8YOBI    IFEQ 6
     C                     Z-ADD7         C
     C                     END
     C*
     C           F8YOBI    IFEQ 7
     C                     Z-ADD1         C
     C                     END
     C*
     C                     END
     C                     Z-ADDF8KADD    @YB,C
     C                     Z-ADD0         B       20
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C           C         ADD  10        B
     C                     MOVE '1'       *IN,B
     C                     END
     C*
     C           F8HIRU    IFEQ '*'
     C                     MOVE 'A'       @HI,C
     C                     END
     C*
     C           F8YORU    IFEQ '*'
     C                     MOVE 'B'       @YO,C
     C                     END
     C*
     C           F8MAEY    IFEQ 'S'
     C                     MOVE 'S'       @ZE,C
     C                     END
     C*
     C           F8MAEY    IFEQ 'E'
     C                     MOVE 'E'       @ZE,C
     C                     END
     C*
     C           F8MAEY    IFEQ 'M'
     C                     MOVE 'M'       @ZE,C
     C                     END
     C*
     C           F8RIKB    IFEQ 'R'
     C                     MOVE 'R'       @RI,C
     C                     END
     C                     ADD  1         C
     C*
     C           EXIT      TAG
     C  N90                END
