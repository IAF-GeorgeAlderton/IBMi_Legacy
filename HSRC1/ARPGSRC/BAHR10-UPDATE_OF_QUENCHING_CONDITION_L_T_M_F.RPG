     H            Y.
     F** BAHR10 ***********************************
     F*UPDATE OF QUENCHING CONDITION L / T M/F
     F*        A.IDOTA         1995.04.07         *
     F*********************************** BAHR10 **
     FBAHPW10 CF  E                    WORKSTN
     FAAAPL01 IF  E           K        DISK
     FBAHPL10 UF  E           K        DISK                      A
     E                    ER      1  10 60               MSG
     E                    BM      1   1  4 0             DEPARTMENT
     I            DS
     I                                        1   60WTIME
     I                                        1   20HH
     I                                        3   40SS
     C           *ENTRY    PLIST
     C                     PARM           US     10
      * KEY *
     C           KEY       KLIST
     C                     KFLD           BMN
     C                     KFLD           @JKN
     C                     TIME           WTIME   60
      *
     C           KEY2      KLIST
     C                     KFLD           @JKN
     C                     KFLD           WJKB
      *****************************************************************
      * 初期設定                                             MAIN   *
      *****************************************************************
     C           STP00     TAG
     C                     MOVE *BLANK    @KBN
     C                     MOVE *BLANK    @BMN
     C                     MOVE *BLANK    @JKN
     C                     Z-ADD0         @LIT
     C                     SETOF                     010203
     C                     SETOF                     047099
     C                     SETOF                     KAKCKE
      *****************************************************************
      * 画面・１                                             MAIN   *
      *****************************************************************
     C           STP10     TAG
     C                     EXFMTBAHPW101
      * END *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     SETOF                     010203
     C                     SETOF                     0499
      *更新区分*
     C           @KBN      IFNE '0'
     C           @KBN      ANDNE'1'
     C           @KBN      ANDNE'2'
     C                     MOVELER,01     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
      *部門*
     C           @BMN      IFEQ *BLANK
     C                     MOVELER,02     MSG
     C                     SETON                     0299
     C                     GOTO STP10
     C                     END
      *
     C                     MOVEL@BMN      BMN     40
     C                     SETOF                     30
     C           BMN       LOKUPBM                       30
     C           *IN30     IFEQ '0'
     C                     MOVELER,03     MSG
     C                     SETON                     0299
     C                     GOTO STP10
     C                     END
      *条件*
     C           @JKN      IFEQ *BLANK
     C                     MOVELER,04     MSG
     C                     SETON                     0399
     C                     GOTO STP10
     C                     END
      *
     C                     MOVE 'B'       WJKB    1
     C                     SETOF                     30
     C           KEY2      CHAINAAAPL011             30
     C           *IN30     IFEQ '0'
     C           A5SKJY    IFEQ 'D'
     C           A5SKHZ    COMP *DATE                  3030
     C                     END
     C                     END
     C           *IN30     IFEQ '1'
     C                     MOVELER,10     MSG
     C                     SETON                     0399
     C                     GOTO STP10
     C                     END
      * ﾎｦbﾓ kｩｮh *
     C                     SETOF                     30
     C           KEY       CHAINBAHPL101             30
      *取消*
     C           @KBN      IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     MOVELER,05     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C           *IN30     IFEQ '0'
     C           YKSKJY    ANDEQ'D'
     C                     MOVELER,06     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C                     Z-ADDYKLITM    @LIT
     C                     END
      *変更*
     C           @KBN      IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     MOVELER,07     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C           *IN30     IFEQ '0'
     C           YKSKJY    ANDEQ'D'
     C                     MOVELER,07     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C                     Z-ADDYKLITM    @LIT
     C                     END
      *追加*
     C           @KBN      IFEQ '2'
     C           *IN30     IFEQ '0'
     C           YKSKJY    ANDNE'D'
     C                     MOVELER,08     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C                     END
      *****************************************************************
      *  L/T入力                                             MAIN   *
      *****************************************************************
     C                     SETON                     70
     C           STP20     TAG
     C                     EXFMTBAHPW101
      * END *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      * KEY入力*
     C           *INKC     IFEQ '1'
     C                     GOTO STP00
     C                     END
     C                     SETOF                     010203
     C                     SETOF                     0499
      * L/T *
     C           @LIT      IFEQ 0
     C                     MOVELER,09     MSG
     C                     SETON                     0499
     C                     GOTO STP20
     C                     END
      *更新*
     C           *INKE     IFEQ '0'
     C                     GOTO STP20
     C                     END
      *
     C           @KBN      IFEQ '2'
     C                     MOVE *BLANK    YKSKJY
     C                     Z-ADD0         YKSKYY
     C                     Z-ADD0         YKSKMM
     C                     Z-ADD0         YKSKDD
     C                     Z-ADD0         YKKOYY
     C                     Z-ADD0         YKKOMM
     C                     Z-ADD0         YKKODD
     C                     Z-ADD0         YKKOHH
     C                     Z-ADD0         YKKOSS
     C                     MOVE *BLANK    YKKOME
     C                     Z-ADD0         YKBMON
     C                     MOVE *BLANK    YKJOKN
     C                     Z-ADD0         YKLITM
     C                     Z-ADDBMN       YKBMON
     C                     MOVEL@JKN      YKJOKN
     C                     END
      *
     C           @KBN      IFEQ '0'
     C                     MOVEL'D'       YKSKJY
     C                     Z-ADD*YEAR     YKSKYY
     C                     Z-ADDUMONTH    YKSKMM
     C                     Z-ADDUDAY      YKSKDD
     C                     END
      *
     C                     Z-ADD*YEAR     YKKOYY
     C                     Z-ADDUMONTH    YKKOMM
     C                     Z-ADDUDAY      YKKODD
     C                     Z-ADDHH        YKKOHH
     C                     Z-ADDSS        YKKOSS
     C                     MOVELUS        YKKOME
     C                     Z-ADD@LIT      YKLITM
      *
     C           @KBN      IFEQ '1'
     C           @KBN      OREQ '0'
     C           *IN30     IFEQ '0'
     C                     UPDATBAHPL101
     C                     END
     C                     END
     C           @KBN      IFEQ '2'
     C           *IN30     IFEQ '1'
     C                     WRITEBAHPL101
     C                     ELSE
     C                     UPDATBAHPL101
     C                     END
     C                     END
     C                     GOTO STP00
**  ERR / MSG
E-01 UPDATE INSTRUCTION <0 1 2>
E-02 INPUT SECTION CODE
E-03 SECTION CODE YOU INPUT IS NOT RIGHT
E-04 INPUT CONDITION
E-05 THERE ISN'T CANCEL DATA
E-06 DATA IS CANCELLED  ALREADY
E-07 THERE ISN'T CHANGE DATA
E-08 THERE IS DATA
E-09 INPUT L.T.
E-10 IT IS NOT IN CONDITION M/F
**  SECTION CODE
0111
