     FABMPWQ0 CF  E                    WORKSTN
     E                    ER      1  19 65
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
     I              X'0E0F40'             C         WKCKCH
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1CR1   6
     C                     PARM           P1CR2   6
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
     C                     Z-ADD0         D1CR1
     C                     Z-ADD0         D1CR2
     C                     MOVEL*BLANK    P1CR1
     C                     MOVEL*BLANK    P1CR2
     C                     MOVEL*BLANK    PCMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTABMPWQ01
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1CR1     IFEQ 0
     C                     MOVELER,1      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
     C                     Z-ADDD1CR1     A1CR1   60
     C                     Z-ADDD1CR2     A1CR2   60
     C           D1CR2     IFEQ 0
     C                     Z-ADD999999    A1CR2
     C                     ENDIF
     C           A1CR2     IFNE 0
     C           A1CR1     IFGT A1CR2
     C                     MOVELER,2      D1ERR
     C                     SETON                     313299
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     MOVELD1CR1     P1CR1
     C                     MOVELD1CR2     P1CR2
     C                     MOVEL'05'      PCMD
     C                     MOVE '99'      DSPSW
      *
     CSR         ESB210    ENDSR
