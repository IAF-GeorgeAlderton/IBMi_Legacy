     C           A#SIZE    IFEQ 'H/V'
     C                     MOVEL'6'       @SIZE
     C                     ENDIF
     C           A#SIZE    IFEQ 'E/G'
     C                     MOVEL'7'       @SIZE
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     MOVEL'02'      DSPSW
