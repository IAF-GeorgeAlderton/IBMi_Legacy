      *
     CSR         EDLT      ENDSR
      *----------------------------------------------------*
      *CHANGE                                              *
      *----------------------------------------------------*
     CSR         #UPD      BEGSR
      *
     C           *IN21     IFEQ '0'
     C*
     C                     Z-ADDWTIHZ     A#DATE
     C                     MOVELWJFB      A#TIME
     C                     MOVELW#USER    A#USER
     C                     MOVELW#PGM     A#PGID
     C                     MOVEL@MCN#     A#MANO
     C                     MOVEL@LOCT     A#LOCT
     C*                    MOVEL@SIZE     A#SIZE
     C           @SIZE     IFEQ '1'
