      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTABBPW7L1
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     99
     C                     MOVEL*BLANK    @ERR
     C                     MOVEL*BLANK    @SIZE
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO #S210E
     C                     ENDIF
      * F12
     C           *IN12     IFEQ '1'
     C                     MOVE @MCN#     P@MANO
     C                     MOVE @LOCT     P@LOCT
     C                     CALL 'ABBR7M'
     C                     PARM           P@MANO  3
     C                     PARM           P@LOCT  6
     C           P@MANO    IFNE *BLANK
     C           P@LOCT    ORNE *BLANK
     C                     MOVE P@MANO    @MCN#
     C                     MOVE P@LOCT    @LOCT
     C                     ENDIF
     C                     GOTO #S210E
     C                     ENDIF
      *
     C           @KOSN     IFEQ *BLANK
     C**JW1                MOVELER,1      @ERR
JW1  C                     MOVELER,2      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
      *
     C           @KOSN     IFEQ '0'
     C           @KOSN     OREQ '1'
     C           @KOSN     OREQ '2'
     C                     ELSE
     C                     MOVELER,2      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
      *
     C           @MCN#     IFEQ *BLANK
     C           @LOCT     ANDEQ*BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     323399
     C                     GOTO #S210E
     C                     ENDIF
     C           @MCN#     IFNE *BLANK
     C           @LOCT     ANDNE*BLANK
     C**JW1                MOVELER,1      @ERR
JW1  C                     MOVELER,8      @ERR
     C                     SETON                     323399
     C                     GOTO #S210E
     C                     ENDIF
     C*
     C           KEY01     KLIST
     C                     KFLD           @MCN#
     C                     KFLD           @LOCT
     C           KEY01     CHAINABBPP7G1             21
     C           *IN21     IFEQ '0'
     C           A#SKJY    ANDEQ'D'
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C           @KOSN     IFEQ '0'
     C           @KOSN     OREQ '1'
     C                     MOVELER,6      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
