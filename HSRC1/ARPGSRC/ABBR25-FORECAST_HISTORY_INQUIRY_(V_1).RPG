     C                     ADD  FBQTY2    H@MQT1
     C           X         WHEQ 2
     C                     ADD  FBQTY2    S@MQT2
     C                     ADD  FBQTY2    H@MQT2
     C           X         WHEQ 3
     C                     ADD  FBQTY2    S@MQT3
     C                     ADD  FBQTY2    H@MQT3
