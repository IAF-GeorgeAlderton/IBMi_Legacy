     C                     END
     C                     END
      * SHP DATE
     C           FBCEDT    ADD  20000000  W@DT8   80
     C****       W@DT8     IFGE @YMD
      *
     C           W@DT8     LOKUPDT2                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 99
     C                     Z-ADDW@DT8     DT2,Y
     C                     ENDIF
     C                     ENDIF
     C***                  ENDIF
      * RCV DATE
     C           FBSIDT    ADD  20000000  W@DT8   80
     C           W@DT8     LOKUPDT1                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C           X         IFEQ 8
     C                     Z-ADDW@DT8     @PDAT   80
     C                     LEAVE
     C                     ENDIF
     C           X         IFEQ 1
     C           W@DT8     LOKUPDAT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @D
     C                     Z-ADDW@DT8     DAT,@D
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDW@DT8     DT1,X
     C                     Z-ADDW@DT8     DTE,X
     C                     Z-ADDW@DT8     @PDAT   80
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADT2
      *
     C           1         DO   99        Y
     C           DT2,Y     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     Z-ADDDT2,Y     S@DATE
     C                     Z-ADDDT2,Y     H@DATE
     C           H@DATE    IFLE *DATE
     C                     Z-ADDRRN1      XXRRN1  40
     C                     ENDIF
     C                     WRITESFL01
     C                     ENDDO
      *
     C           1         DO   99        X
     C           DT2,X     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDDT2,X     K@CEDT
     C           K#FD1X    SETLLABFPL16
     C           *IN90     DOUEQ*ON
     C           K#FD1X    READEABFPL16                  90
     C           *IN90     IFEQ *OFF
      *
     C           FBQTCD    IFEQ 'M'
     C           FBSIDT    IFEQ H@ISDT
     C                     ELSE
     C                     ITER
     C                     END
     C                     END
      *
      *  if the delivery code doesn't match, ignore and read next.
     C           FBNONY    IFNE D@NONY
     C           FBNONY    ANDNE*ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD1         Y
     C           FBSIDT    ADD  20000000  W@DT8   80
     C           W@DT8     LOKUPDT1,Y                    10
     C           *IN10     IFEQ *ON
     C           X         CHAINSFL01                90
     C                     Z-ADDFBQTY2    QTY,Y
      *
     C**JW4      FBQTCD    IFEQ 'M'
     C**                   MOVEL'M'       S@MFST
     C**                   ELSE
     C**                   MOVEL*BLANK    S@MFST
     C**                   END
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
     C*                    Z-ADDXXRRN1    #RCNO1
     C*          #RCNO1    IFEQ *ZERO
     C*                    ADD  1         #RCNO1
     C*                    ENDIF
     C                     Z-ADDXXRRN1    W@RCN1
     C           W@RCN1    IFEQ *ZERO
     C                     ADD  1         W@RCN1
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #FPRV     BEGSR
      *------------------------------------------------------
     C                     ADD  1         @PAGE
     C                     Z-ADD@PDAT     K@ISDT
     C                     EXSR #SFRD2
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #FNXT     BEGSR
      *------------------------------------------------------
     C                     SUB  1         @PAGE
     C           @PAGE     IFEQ *ZERO
     C                     Z-ADD1         @PAGE
     C                     ELSE
     C                     Z-ADD@PAGE     X
     C                     Z-ADDDAT,X     K@ISDT
     C                     EXSR #SFRD2
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C           @PAGE     IFEQ 1
     C                     MOVE CMD,2     D@CMD
     C                     ELSE
     C                     MOVE CMD,3     D@CMD
     C                     ENDIF
JW1   * CHECK SHIPPING MASTER ------------------
 .   C           K#GA11    KLIST
 .   C                     KFLD           K#TOKU  40
 .   C                     KFLD           K#NONY  40
 .   C                     MOVE *BLANK    D@MSG2
 .   C                     Z-ADDD@TOKU    K#TOKU
 .   C                     Z-ADDD@NONY    K#NONY
 .   C           K#GA11    SETLLGADPL11
 .   C                     DO   *HIVAL
 .   C           K#GA11    READEGADPL11                  98
 .   C   98                LEAVE
 .    *
 .   C           B5SKJY    IFEQ 'D'
 .   C                     ITER
 .   C                     ENDIF
 .    * FACTORY
 .   C           D@FACT    IFNE ' '
 .   C           D@FACT    ANDNE'0'
 .   C           B5NKOJ    ANDNE' '
 .   C           B5NKOJ    ANDNE'0'
 .   C           B5NKOJ    ANDNED@FACT
 .   C                     ITER
 .   C                     ENDIF
 .    * DOCK
 .   C           D@DOCK    IFNE ' '
 .   C           D@DOCK    ANDNE'0'
 .   C           D@DOCK    ANDNE'00'
 .   C           B5NUKE    ANDNE' '
 .   C           B5NUKE    ANDNE'0'
 .   C           B5NUKE    ANDNE'00'
 .   C           B5NUKE    ANDNED@DOCK
 .   C                     ITER
 .   C                     ENDIF
 .    *
 .   C                     LEAVE
 .   C                     ENDDO
 .    *
 .   C           *IN98     IFEQ *ON
 .   C                     MOVELERR,3     D@MSG2
JW1  C                     ENDIF
      * ----------------------------------------
     C                     Z-ADDW@RCN1    #RCNO1
     C*
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C*                    Z-ADD@@REC     #RCNO1
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W@RCN1
     C                     END
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
%04  C           P@MPAR    IFNE *BLANK
  |  C                     MOVEL'99'      W@ID
%04  C                     ENDIF
     C           *INKH     WHEQ *ON
     C           @PAGE     ANDNE1
     C           @FORD     IFEQ *BLANK
     C                     EXSR #NXT
     C                     ELSE
     C                     EXSR #FNXT
     C                     ENDIF
     C           *INKI     WHEQ *ON
     C           @FORD     IFEQ *BLANK
     C                     EXSR #PRV
     C                     ELSE
     C                     EXSR #FPRV
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
** CMD
F1:END                   F7: FROM PREVIOUS MONTH
