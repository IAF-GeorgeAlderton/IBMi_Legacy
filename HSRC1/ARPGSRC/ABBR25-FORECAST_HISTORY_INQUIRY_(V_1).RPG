     C           1         DO   9         X       30
     C                     MOVE MON,M     D@M,X
     C                     Z-ADDM         @MM
     C                     Z-ADD@YYMM     YM,X
      *
     C                     ADD  1         M
     C           M         IFGT 12
     C                     Z-ADD1         M
     C                     ADD  1         @YY
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVELD@M,1     D@MON1
     C                     MOVELD@M,2     D@MON2
     C                     MOVELD@M,3     D@MON3
TCHK6C*
