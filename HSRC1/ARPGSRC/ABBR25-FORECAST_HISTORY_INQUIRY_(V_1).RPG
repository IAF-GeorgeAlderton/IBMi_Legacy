     C                     MOVE S@NKOJ    K@NKOJ
     C                     MOVE S@NUKE    K@NUKE
%0001C                     MOVELS@SEBN    C@SEBN  4
      * RECEIVED DATE
     C                     Z-ADD*DATE     K@RCDT
      *
     C                     Z-ADD1         @PAGE   20
     C                     Z-ADD*ZERO     XXRRN1  40
     C                     EXSR #SET12
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SET12    BEGSR
      *------------------------------------------------------
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     DT1
     C                     Z-ADD*ZERO     DTE
     C                     Z-ADD99999999  DT2
     C                     Z-ADD*ZERO     X       30
     C                     Z-ADD*ZERO     Y       30
     C                     Z-ADD*ZERO     @PDAT   80
     C                     MOVEA'0000000' *IN,81
      *
     C           K#KEY     SETGTABBPL51
     C           *IN90     DOUEQ*ON
     C           K#KEYX    REDPEABBPL51                  90
     C           *IN90     IFEQ *OFF
%0001C**
     C           C@SEBN    IFNE BBSEBN
JW   C           BBFLG1    OREQ 'D'
     C                     ITER
     C                     ENDIF
     C**
      * RCV DATE
     C           BBRCDT    LOKUPDT1                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C           X         IFEQ 8
     C                     Z-ADDBBRCDT    @PDAT   80
     C                     LEAVE
     C                     ENDIF
     C           X         IFEQ 1
     C           BBRCDT    LOKUPDAT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @D
     C                     Z-ADDBBRCDT    DAT,@D
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDBBRCDT    DT1,X
     C                     Z-ADDBBRCDT    DTE,X
     C                     ENDIF
      * SHP DATE
     C           BBSDAT    LOKUPDT2                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 100
     C                     Z-ADDBBSDAT    DT2,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADT2
      *
     C           1         DO   99        Y
     C           DT2,Y     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     Z-ADDDT2,Y     S@DATE
     C                     Z-ADDDT2,Y     H@DATE
     C           H@DATE    IFLE *DATE
     C                     Z-ADDRRN1      XXRRN1  40
     C                     ENDIF
     C                     WRITESFL01
     C                     ENDDO
      *
     C           1         DO   7         X
     C           DT1,X     IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDDT1,X     K@RCDT
     C           K#KEY     SETLLABBPL51
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEABBPL51                  90
     C           *IN90     IFEQ *OFF
JW   C           BBFLG1    ANDEQ' '
      *
     C                     Z-ADD1         Y
     C           BBSDAT    LOKUPDT2,Y                    10
     C           *IN10     IFEQ *ON
     C           Y         ANDLE99
     C           Y         CHAINSFL01                90
      *
     C                     Z-ADD80        X8      20
     C           BBBFLG    IFEQ '1'
     C                     ADD  X         X8
     C                     MOVEA'1'       *IN,X8
     C  N88                SETON                     88
     C                     ENDIF
      *
     C                     Z-ADD80        X8      20
     C           BBBFLG    IFNE '1'
     C                     ADD  X         X8
     C                     MOVEA'0'       *IN,X8
     C                     ENDIF
      *
     C                     ADD  BBSQTY    QTY,X
      *
     C                     UPDATSFL01
     C                     MOVEA'0'       *IN,X8
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
