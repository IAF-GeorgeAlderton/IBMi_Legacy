     C           *ENTRY    PLIST
     C                     PARM           PCD1    3
     C                     PARM           PCD2    3
     C                     PARM           PCD3    3
     C                     PARM           PCD4    3
     C                     PARM           PCD5    3
     C                     MOVE PCD1      WCD1    31
     C                     MOVE PCD2      WCD2    31
     C                     MOVE PCD3      WCD3    31
     C                     MOVE PCD4      WCD4    31
     C                     MOVE PCD5      WCD5    31
      *
     C                     TIME           WTIME   60
     C                     MOVE *ALL'-'   WLIN  131
      *
     C*----------------*
     C*  ..工場名..  *
     C*----------------*
     C           *INL2     IFEQ '1'
     C                     SETOF                     10
     C                     MOVE *BLANK    WKJNM  15
     C           IBMON     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVELB2SMEI    WKJNM
     C                     END
     C                     END
      *
     C           *INL1     IFEQ '1'
      *
     C           IZOGN     IFEQ 'Z'
     C                     MOVE ' +  '    WZONM   4
     C                     ELSE
     C                     MOVE ' -  '    WZONM
     C                     END
      *
     C*----------------------------*
     C*  ..今回設定数　増減率..  *
     C*----------------------------*
     C                     Z-ADD0         WPAR1   61
     C                     MOVE *BLANK    WPZG1   1
     C           IZHTS     IFNE 0
     C           IKHTS     DIV  IZHTS     WKTE    83H
     C           WKTE      MULT 100       WPAR1     H
     C           WPAR1     IFGE 100
     C                     MOVE '+'       WPZG1
     C           WPAR1     SUB  100       WPAR1
     C                     ELSE
     C                     MOVE '-'       WPZG1
     C           100       SUB  WPAR1     WPAR1
     C                     END
     C                     END
      *
     C*----------------------------*
     C*  ..翌月内示数　増減率..  *
     C*----------------------------*
     C                     Z-ADD0         WPAR2   61
     C                     MOVE *BLANK    WPZG2   1
     C           IZHTS     IFNE 0
     C           IN1HS     DIV  IZHTS     WKTE      H
     C           WKTE      MULT 100       WPAR2     H
     C           WPAR2     IFGE 100
     C                     MOVE '+'       WPZG2
     C           WPAR2     SUB  100       WPAR2
     C                     ELSE
     C                     MOVE '-'       WPZG2
     C           100       SUB  WPAR2     WPAR2
     C                     END
     C                     END
      *
     C*------------------------------*
     C*  ..翌々月内示数　増減率..  *
     C*------------------------------*
     C                     Z-ADD0         WPAR3   61
     C                     MOVE *BLANK    WPZG3   1
     C           IZHTS     IFNE 0
     C           IN2HS     DIV  IZHTS     WKTE      H
     C           WKTE      MULT 100       WPAR3     H
     C           WPAR3     IFGE 100
     C                     MOVE '+'       WPZG3
     C           WPAR3     SUB  100       WPAR3
     C                     ELSE
     C                     MOVE '-'       WPZG3
     C           100       SUB  WPAR3     WPAR3
     C                     END
     C                     END
      *
     C*----------------------------*
     C*  ..工程　部門　所番地..  *
     C*----------------------------*
     C                     SETOF                     30
     C                     Z-ADD1         A       20
     C                     MOVE *BLANK    HKN
     C                     MOVE *BLANK    HSM
     C                     MOVE *BLANK    HTN
     C           1         DO   15        A       20
     C           HKT,A     IFNE *BLANK
      *
     C           A         IFGE 8
     C                     SETON                     30
     C                     END
      *
     C                     MOVE HKT,A     WKOTI
     C                     MOVE '-'       WKB1
     C                     Z-ADDHBM,A     WBMON
     C                     MOVE WKTBM     HKN,A
      *
     C                     MOVE HTR,A     @TKR
     C                     MOVE @TKR1     WTKR1
     C                     MOVE @TKR2     WTKR2
     C                     MOVE @TKR3     WTKR3
     C                     MOVE @TKR4     WTKR4
     C                     MOVE '-'       WTR1
     C                     MOVE '-'       WTR2
     C                     MOVE '-'       WTR3
     C                     MOVE WTKR      HTN,A
      *
     C                     SETOF                     10
     C           WBMON     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVELB2SMEI    HSM,A
     C                     END
      *
     C                     END
     C                     END
      *
     C                     END
