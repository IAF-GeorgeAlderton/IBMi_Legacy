TCHK1C*----------------------------------------------------*
TCHK1 *  CHECK ASN DATA PATTERN SCREEN FOR SELECTION
TCHK1C*----------------------------------------------------*
TCHK1C           @P1CH2    BEGSR
TCHK1 *
TCHK1C                     Z-ADD*ZERO     RRNP1
TCHK1 *
TCHK1C                     DO   *HIVAL
TCHK1C                     ADD  1         RRNP1
TCHK1C           RRNP1     CHAINSFLP01               91
TCHK1C   91                LEAVE
TCHK1C           S1SEL     IFNE *BLANK
TCHK1C                     LEAVE
TCHK1C                     END
TCHK1C                     ENDDO
TCHK1 *
TCHK1C           *IN91     IFEQ *ON
TCHK1C                     MOVEL*ON       W#P1ER
TCHK1C                     END
TCHK1 *
TCHK1C                     ENDSR
