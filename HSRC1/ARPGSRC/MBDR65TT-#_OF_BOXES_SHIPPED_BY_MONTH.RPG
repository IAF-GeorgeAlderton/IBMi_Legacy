      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C           K#KEYX    SETLLFCEPL40
     C           *IN90     DOUEQ*ON
     C           K#KEYX    READEFCEPL40                  90
