     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C           K#KEYX    KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C           K#KEYY    KLIST
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C           K#PT      KLIST
     C                     KFLD           F4HPR1
     C                     KFLD           F4HPR2
     C                     KFLD           F4HPR3
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     Z-ADDD@YYMM    W@YM
     C           K#KEYY    CHAINAB#PL12              90
     C           *IN90     IFEQ *ON
     C                     MOVE ERR,1     D@MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     Z-ADD*ZERO     D@QTY1
     C                     Z-ADD*ZERO     D@QTY2
     C                     Z-ADD*ZERO     D@QTY3
     C                     Z-ADD*ZERO     D@BOX1
     C                     Z-ADD*ZERO     D@BOX2
     C                     Z-ADD*ZERO     D@BOX3
TCHK1C                     Z-ADD*ZERO     D@QTYT
TCHK1C                     Z-ADD*ZERO     D@BTYT
TCHK1C                     Z-ADD*ZERO     D@QFRD
TCHK1C                     Z-ADD*ZERO     D@BFRD
TCHK1C                     Z-ADD*ZERO     D@QHND
TCHK1C                     Z-ADD*ZERO     D@BHND
TCHK1C                     Z-ADD*ZERO     D@QTR1
TCHK1C                     Z-ADD*ZERO     D@BTR1
%0001C                     Z-ADD*ZERO     D@QSIA
%0001C                     Z-ADD*ZERO     D@BSIA
     C           *LOVAL    SETLLAB#PL09
     C           *IN80     DOUEQ*ON
     C                     READ AB#PL09                  80
     C           *IN80     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
      *
     C                     MOVE B1SHN1    K@PRT1
     C                     MOVE B1SHN2    K@PRT2
     C                     MOVE B1SHN3    K@PRT3
      *
     C           K#KEYX    CHAINFCEPL01              90
     C           *IN90     IFEQ *ON
     C           A2SSYS    OREQ *ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W@QTY  130
     C                     Z-ADD*ZERO     @@BOX
     C           K#KEY     SETLLAB#PL09
     C           *IN81     DOUEQ*ON
     C           K#KEY     READEAB#PL09                  81
     C           *IN81     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C***        B1SRYO    IFLT A2SSYS
     C***                  ITER
     C***                  ENDIF
     C           B1NOHZ    IFGE *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  B1SRYO    W@QTY
     C                     Z-ADDB1SRYO    X@QTY   70
     C           B1SRYO    DIV  A2SSYS    @@QTY   70
     C           B1SRYO    DIV  A2SSYS    X@BOX   81
     C                     ADD  @@QTY     @@BOX   90
      *
     C                     EXSR #OUTX
      *
     C                     SELEC
      * TOYOTA
TCHK1C           B1NONY    WHEQ 3764
TCHK1C           B1NONY    OREQ 3481
TCHK1C           B1NONY    OREQ 3503
TCHK1C           B1NONY    OREQ 3804
TCHK1C           B1NONY    OREQ 3347
TCHK1C           B1NONY    OREQ 3220
TCHK1C           B1NONY    OREQ 3851
TCHK1C           B1NONY    OREQ 3931
TCHK1C           B1NONY    OREQ 3428
TCHK1C                     ADD  B1SRYO    D@QTYT
TCHK1C                     ADD  @@QTY     D@BTYT
      * FORD
TCHK1C           B1TOKU    WHEQ 5149
TCHK1C                     ADD  B1SRYO    D@QFRD
TCHK1C                     ADD  @@QTY     D@BFRD
      * HONDA
TCHK1C           B1TOKU    WHEQ 0294
TCHK1C           B1TOKU    OREQ 0295
TCHK1C           B1TOKU    OREQ 0296
TCHK1C           B1TOKU    OREQ 0390
TCHK1C           B1TOKU    OREQ 0391
TCHK1C           B1TOKU    OREQ 3135
JW1  C           B1TOKU    OREQ 1602
TCHK1C                     ADD  B1SRYO    D@QHND
TCHK1C                     ADD  @@QTY     D@BHND
      * SIA
%0001C           B1TOKU    WHEQ 3611
     C                     ADD  B1SRYO    D@QSIA
     C                     ADD  @@QTY     D@BSIA
      * TIER1
TCHK1C                     OTHER
TCHK1C                     ADD  B1SRYO    D@QTR1
TCHK1C                     ADD  @@QTY     D@BTR1
TCHK1C                     ENDSL
TCHK1 *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           W@QTY     IFNE *ZERO
     C                     EXSR #OUT
     C                     ENDIF
     C           K#KEYX    SETGTAB#PL09
     C                     ENDIF
     C                     ENDDO
      *
     C           D@QTY1    ADD  D@QTY2    D@TOTL
     C                     ADD  D@QTY3    D@TOTL
     C           D@BOX1    ADD  D@BOX2    D@BTOT
     C                     ADD  D@BOX3    D@BTOT
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #OUTX     BEGSR
      *------------------------------------------------------
      * PASS THROUGH
     C           K#KEYX    SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           K#KEYX    READEAAPTL01                  90
     C           *IN90     IFEQ *OFF
     C           L5STYY    ANDEQ9999
     C           L5SKJY    ANDEQ*BLANK
      *
TCHK2C                     Z-ADDB1NODD    Z       20
TCHK2C                     Z-ADDB1NOHZ    @DT,Z
TCHK2C                     ADD  X@QTY     @AQ,Z
TCHK2C                     ADD  X@BOX     @AB,Z
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #OUT      BEGSR
      *------------------------------------------------------
     C******     W@QTY     DIV  A2SSYS    @@BOX   90
      * PASS THROUGH
     C           K#KEYX    SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           K#KEYX    READEAAPTL01                  90
