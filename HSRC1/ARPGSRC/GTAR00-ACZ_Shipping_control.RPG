     H            Y.                                    1
     H** GTAR00 ****************************************************************
     H* ACZ SHIPPING CONTROL                                                   *
     H*
     H* TCHK  11/15/12 CREATE
     H**************************************************************************
     FGTAPW00 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     F**************************************************************************
     E                    ERR     2  15 15
     I**************************************************************************
     I            DS
     I                                        1   80WSDATE
     I                                        1   4 WSYYYY
     I                                        5   6 WSMM
     I                                        7   8 WSDD
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C           P1        PLIST
     C                     PARM           POPR    6
     C*
     C                     SETOF                     6162
     C                     MOVEL*BLANK    F1ERR
     C*
     C                     Z-ADD*DATE     WSDATE
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT100
     C   KC                LEAVE
     C*
     C                     SETOF                     6162
     C                     MOVEL*BLANK    F1ERR
     C* WORKER CODE CHECK
     C           F1USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *ON
     C           ALSKJY    ORNE *BLANK
     C                     MOVELERR,1     F1ERR
     C                     MOVEL*ON       *IN61
     C                     ITER
     C                     END
     C*
     C                     SELEC
     C* SCAN PULL FINAL LOCATION
     C           F1SEL     WHEQ '1'
     C                     MOVE ALWKCD    POPR             SET WORKER ID
     C                     CALL 'GTAC2Y'  P1
     C* CREATE CASE LABEL
     C           F1SEL     WHEQ '2'
     C                     MOVE ALWKCD    POPR             SET WORKER ID
     C                     CALL 'GTAC20'  P1
      * SCAN PACKING MODULE
     C           F1SEL     WHEQ '3'
     C                     MOVE ALWKCD    POPR             SET WORKER ID
     C                     CALL 'GTAR30'  P1
     C* CREATE PACKING LIST DATA
     C           F1SEL     WHEQ '4'
     C                     MOVE ALWKCD    POPR             SET WORKER ID
     C                     CALL 'GTAC40'  P1
     C* SELECTION ERROR
     C                     OTHER
     C                     MOVEAERR,2     F1ERR
     C                     SETON                     62
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @END
     C**************************************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
** ERR
USER CODE ERROR
SELECT ERROR
