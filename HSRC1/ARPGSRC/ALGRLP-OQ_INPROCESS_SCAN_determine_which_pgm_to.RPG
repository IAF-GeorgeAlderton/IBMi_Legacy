     H            Y.                                    1
      * LEC      01/09/19  DETERMINE IF THE OQ LINE THIS TM IS RUNNING
      *                    HAS A LASER PRINTER OR NOT.
      **************************************************************************
     FALGPWLP CF  E                    WORKSTN
      **************************************************************************
     E                    ERR     1   2 17
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        9  140WSSDAT
     I                                        7  120WSSYM
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        7  140WSDATE
      *
     C**************************************************************************
      *                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
      *
     C                     SELEC
     C           @@ID      WHEQ '10'
     C                     EXSR #FMT10
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           YORN    1
      *
     C                     TIME           WSDT
     C                     CLEARFMT100
     C                     MOVEL'10'      @@ID    2
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     6199
      * LINE NO CHECK
     C           F1LINE    IFGE '1'
     C           F1LINE    ANDLE'8'
     C                     ELSE
     C                     SETON                     6199
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,1     F1ERR
     C                     ENDIF
     C                     ENDIF
      * PRINTER CODE CHECK
     C                     SELEC
      *** oq1
     C           F1LINE    WHEQ '1'
     C                     MOVE 'Y'       YORN
      *** oq2
     C           F1LINE    WHEQ '2'
     C                     MOVE 'Y'       YORN
      *** oq3
     C           F1LINE    WHEQ '3'
     C                     MOVE 'Y'       YORN
      *** oq4
     C           F1LINE    WHEQ '4'
     C                     MOVE 'Y'       YORN
      *** oq5
     C           F1LINE    WHEQ '5'
     C                     MOVE 'Y'       YORN
      *** oq6
     C           F1LINE    WHEQ '6'
     C                     MOVE 'Y'       YORN
      *** oq7
     C           F1LINE    WHEQ '7'
     C                     MOVE 'Y'       YORN
      *** oq8
     C           F1LINE    WHEQ '8'
     C                     MOVE 'Y'       YORN
     C                     ENDSL
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE '99'      @@ID
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
** ERR
LINE NO ERROR                    #01
ENTER Y OR N                     #02
