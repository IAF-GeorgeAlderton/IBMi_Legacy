     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         L
     C                     MOVELAY,J      A9,L
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         L
     C                     Z-ADD9         M
     C                     DO   9
     C           A9,L      IFNE *BLANK
     C                     MOVELA9,L      A9X,M
     C                     SUB  1         M
     C                     END
     C                     SUB  1         L
     C           L         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVEL@9C       @9      90
     C                     Z-ADD@9        AWSYOS
