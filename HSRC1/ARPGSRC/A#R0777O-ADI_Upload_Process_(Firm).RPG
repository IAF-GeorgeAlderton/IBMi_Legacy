     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         L
     C                     MOVE AY,J      A9,L
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         M       30
     C                     Z-ADD9         L
     C                     DO   9
     C           A9,M      IFNE *BLANK
     C                     MOVELA9,M      A9X,L
     C                     SUB  1         L
     C                     END
     C                     SUB  1         M
     C           M         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
