      *
      * BLANKET ORDER NUMBER
      *
     C           *IN99     IFEQ *OFF
     C*
     C                     Z-ADD*ZERO     J       30
     C                     Z-ADD*ZERO     L       30
     C                     Z-ADD1         X       30
      ** HEADER **
     C           'PO#'     SCAN DAT1      X              10
     C  N10      'Po#'     SCAN DAT1      X              10
     C  N10                GOTO @END
     C*
     C                     Z-ADD1         X       30
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     MOVEL*BLANK    OD
JW2  C                     MOVEA'01'      BN
     C*
     C           X         ADD  1         J
     C                     DO   *HIVAL
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         L
     C                     MOVELAY,J      OD,L
     C                     ADD  1         J
     C                     ENDDO
     C*
     C                     MOVEAOD        W#A10  10
     C                     MOVELW#A10     AWORDN
JW2   * BIN#
     C                     Z-ADD0         L
JW2  C                     MOVEA*BLANK    BN
     C* SKIP NEXT FIELD
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  1         J
     C                     DO   *HIVAL
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     ENDIF
     C                     ADD  1         L
     C                     MOVELAY,J      BN,L
     C                     ADD  1         J
     C                     ENDDO
     C*
     C                     MOVEABN        WBIN
     C                     SELEC
     C           WBN1      WHEQ *BLANK
     C           WBN2      ANDEQ*BLANK
     C                     MOVE '01'      WBIN
     C           WBN1      WHNE *BLANK
     C           WBN2      ANDEQ*BLANK
     C                     MOVE WBN1      WBN2
     C                     MOVE '0'       WBN1
     C                     ENDSL
      *
     C                     MOVELWBIN      AWSHBN
     C*
     C                     MOVEL*ON       *IN99
     C                     GOTO @END
     C*
     C                     END
     C*
      ** DETAIL **
     C* ----------
     C* SHIP DATE --> ADT
     C* ----------
     C           *IN97     IFEQ *OFF
     C*
     C                     Z-ADD1         X       30
     C           'SHIP'    SCAN DAT1      X              10
     C  N10      'Ship'    SCAN DAT1      X              10
     C  N10                GOTO @END
     C*
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADD*ZERO     K       30
     C                     Z-ADDX         J       30
      *
     C                     DO   2
     C                     ADD  1         J
     C* GET SHIP MM
     C                     MOVEAAY,J      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVEAA2        MM
     C                     ELSE
     C                     MOVEL'0'       MM
     C                     MOVE A2,1      MM
     C                     END
     C* GET SHIP MM
     C           '/'       LOKUPAY,J                     10
     C  N10                LEAVE
     C                     ADD  1         J
     C                     MOVEAAY,J      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVEAA2        DD
     C                     ELSE
     C                     MOVEL'0'       DD
     C                     MOVE A2,1      DD
     C                     END
     C* GET  SHIP YYYY
     C           '/'       LOKUPAY,J                     10
     C  N10                LEAVE
     C                     ADD  1         J
      *
     C           J         ADD  2         @X      30
      *
     C           AY,@X     IFEQ ','
     C           AY,@X     OREQ ' '
     C                     MOVEAAY,J      YYA2    2
     C                     MOVEL'20'      YY
     C                     MOVE YYA2      YY
     C                     ELSE
     C                     MOVEAAY,J      YYA4    4
     C                     MOVE YYA4      YY
     C                     END
      *
     C                     MOVELYMD8      YMD
     C                     ADD  1         K
     C                     Z-ADDYMD       ADT,K
      *
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C                     Z-ADDX         J
      *
     C                     ENDDO
      *
     C           K         IFGT *ZERO
     C                     MOVE *ON       *IN97
     C                     END
      *
     C                     GOTO @END
      *
     C                     END
     C*
JW1  C* ----------
 |   C* DELIV DATE --> DDT
 |   C* ----------
 |   C           *IN98     IFEQ *OFF
 |   C*
 |   C                     Z-ADD1         X       30
 |   C           'DELIV'   SCAN DAT1      X              10
 |   C  N10      'Deliv'   SCAN DAT1      X              10
