 |   C*
 |   C                     Z-ADD1         X
 |   C           ','       LOKUPAY,X                     10
 |   C  N10                GOTO @END
 |   C                     ADD  1         X
 |   C           ','       LOKUPAY,X                     10
 |   C  N10                GOTO @END
 |   C                     ADD  1         X
 |   C           ','       LOKUPAY,X                     10
 |   C  N10                GOTO @END
 |    *
 |   C                     Z-ADD*ZERO     K       30
 |   C                     Z-ADDX         J       30
 |    *
 |   C                     DO   2
 |   C                     ADD  1         J
 |   C* GET DELIV MM
 |   C                     MOVEAAY,J      A2
 |   C           A2,2      IFGE '0'
 |   C           A2,2      ANDLE'9'
 |   C                     MOVEAA2        MM
 |   C                     ELSE
 |   C                     MOVEL'0'       MM
 |   C                     MOVE A2,1      MM
 |   C                     END
 |   C* GET DELIV MM
 |   C           '/'       LOKUPAY,J                     10
 |   C  N10                LEAVE
 |   C                     ADD  1         J
 |   C                     MOVEAAY,J      A2
 |   C           A2,2      IFGE '0'
 |   C           A2,2      ANDLE'9'
 |   C                     MOVEAA2        DD
 |   C                     ELSE
 |   C                     MOVEL'0'       DD
 |   C                     MOVE A2,1      DD
 |   C                     END
 |   C* GET DELIV YYYY
 |   C           '/'       LOKUPAY,J                     10
 |   C  N10                LEAVE
 |   C                     ADD  1         J
 |    *
 |   C           J         ADD  2         @X      30
 |    *
 |   C           AY,@X     IFEQ ','
 |   C           AY,@X     OREQ ' '
 |   C                     MOVEAAY,J      YYA2    2
 |   C                     MOVEL'20'      YY
 |   C                     MOVE YYA2      YY
 |   C                     ELSE
 |   C                     MOVEAAY,J      YYA4    4
 |   C                     MOVE YYA4      YY
 |   C                     END
 |    *
 |   C                     MOVELYMD8      YMD
 |   C                     ADD  1         K
 |   C                     Z-ADDYMD       DDT,K
 |    *
 |   C                     ADD  1         X
 |   C           ','       LOKUPAY,X                     10
 |   C  N10                LEAVE
 |   C                     Z-ADDX         J
 |    *
 |   C                     ENDDO
 |    *
 |   C           K         IFGT *ZERO
 |   C                     MOVE *ON       *IN98
 |   C                     END
 |    *
 |   C                     GOTO @END
 |    *
JW1  C                     END
