     C*****************************************************************
     C*                   工程マスター
     C*****************************************************************
     C           $KT       BEGSR
      *
     C                     MOVE *BLANK    KT
     C                     MOVE *BLANK    NM
     C                     MOVE *BLANK    WKB
     C                     SETOF                     11
     C           KEY1      CHAINAAMPL111             11
     C           *IN11     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
      *
     C                     Z-ADD1         A
     C           1         DO   15        A
     C                     MOVEL#KI,A     WKIRI   80
     C           WKIRI     IFNE 0
      *
     C           WKIRI     IFGT *DATE
     C                     MOVE #KK,A     WKOTE
     C                     MOVE '-'       WHI
     C                     MOVE #KB,A     WBUMO
     C                     ELSE
     C                     MOVE #SK,A     WKOTE
     C                     MOVE '-'       WHI
     C                     MOVE #SB,A     WBUMO
     C                     END
      *
     C           WKOTE     IFNE *BLANK
     C                     MOVE WKB       KT,A
      *
     C                     SETOF                     12
     C                     MOVE WBUMO     WWBUMO  40
     C           WWBUMO    CHAINFGBPL011             12
     C           *IN12     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     12
     C                     END
     C           *IN12     IFEQ '0'
     C                     MOVELB2KEMI    WSMNM  10
     C                     MOVEAWSMNM     HNM
      *
     C                     Z-ADD1         B       20
     C                     Z-ADD11        C       20
     C                     MOVE '  '      W0E0F
     C           1         DO   10        B
     C                     SETOF                     13
     C                     SUB  1         C
     C           HNM,C     IFEQ W0F
     C                     SETON                     13
     C                     ELSE
     C           HNM,C     IFEQ W0E
     C                     SETON                     13
     C                     MOVE W0F       WNAME
     C                     END
     C                     END
     C  N13                END
      *
     C                     MOVE WNAME     NM,A
      *
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
