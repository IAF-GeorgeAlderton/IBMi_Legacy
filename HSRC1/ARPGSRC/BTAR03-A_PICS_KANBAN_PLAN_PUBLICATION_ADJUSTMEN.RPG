     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C                     TIME           @TIME   60
      *
     C           *IN75     IFEQ '0'
     C                     SETON                     75
     C                     MOVE *ALL'-'   WLAIN
      *
     C                     MOVE *BLANK    PUSNM  15
     C                     CALL 'APLR00'
     C                     PARM           PUS
     C                     PARM           PUSNM
     C                     MOVELPUSNM     WUSNM  11
      *
     C                     END
      *
     C*区分*
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         WRECD
      *
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C           IKUBN     LOKUPKB1,A                    01
     C           *IN01     IFEQ '1'
