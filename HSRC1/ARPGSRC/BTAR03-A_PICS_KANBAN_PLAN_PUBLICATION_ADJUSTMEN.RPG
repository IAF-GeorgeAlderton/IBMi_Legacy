      *
     C                     Z-ADD1         A
     C           1         DO   3         A
      * N+1
     C           A         IFEQ 2
     C           WMM       IFEQ 12
     C                     ADD  1         WYY
     C                     Z-ADD01        WMM
     C                     ELSE
     C                     ADD  1         WMM
     C                     END
     C                     END
      * N+2
     C           A         IFEQ 3
     C           WMM       IFEQ 12
     C                     ADD  1         WYY
     C                     Z-ADD01        WMM
     C                     ELSE
     C                     ADD  1         WMM
     C                     END
     C                     END
