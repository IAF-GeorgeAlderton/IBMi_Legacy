     C                     END
     C                     END
      *
     C           *INL1     IFEQ '1'
     C           *IN90     OREQ '1'
     C   90                WRITEBTAPR036
     C                     SETOF                     90
     C                     WRITEBTAPR031
     C                     END
      *
     C                     ADD  1         WRECD
     C                     MOVE '-'       IH1
     C                     MOVE '-'       IH2
      *
     C*得意先*
     C                     SETOF                     01
     C                     MOVE *BLANK    @TKNM
     C           ITOKU     CHAINFGBPL011             01
     C           *IN01     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '0'
     C                     MOVE B2KEMI    @TKNM
     C                     END
      *
     C*納入先*
     C                     SETOF                     01
     C                     MOVE *BLANK    @NNNM
     C           INONY     CHAINFGBPL011             01
     C           *IN01     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '0'
     C                     MOVE B2KEMI    @NNNM
     C                     END
      *
     C*収容数
     C                     SETON                     01
     C                     Z-ADD0         WBARL
     C           KEY1      CHAINAGAPL311             01
     C           *IN01     IFEQ '0'
