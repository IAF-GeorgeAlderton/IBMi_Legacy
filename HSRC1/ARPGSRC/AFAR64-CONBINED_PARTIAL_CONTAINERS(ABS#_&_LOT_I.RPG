     C                     ELSE
     C           *IN33     IFEQ '0'
     C                     WRITEAFAPW641
     C                     EXFMTAFAPW642
     C                     ELSE
     C                     EXFMTAFAPW643
     C                     END
     C                     END
     C                     MOVE *BLANK    MSG
     C                     SETOF                     3231
     C           *INKL     IFEQ '1'
     C                     MOVE *BLANK    DSZETI
     C                     MOVE *BLANK    DSNLOT
     C                     SETOF                     30
     C                     ELSE
     C           *INKE     IFEQ '1'
