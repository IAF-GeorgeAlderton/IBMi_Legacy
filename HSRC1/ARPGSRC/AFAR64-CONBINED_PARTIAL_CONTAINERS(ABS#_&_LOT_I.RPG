     C                     CALL 'AFAR63'  P1
     C                     ELSE
     C           *INKC     IFEQ '1'
     C                     ELSE
     C                     EXSR @SERR
     C*
     C                     END
     C                     END
     C                     END
     C                     END
     C                     SETON                     LR
     C                     RETRN
