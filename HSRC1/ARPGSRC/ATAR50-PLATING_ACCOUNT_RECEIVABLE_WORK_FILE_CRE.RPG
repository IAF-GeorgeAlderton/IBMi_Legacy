     H            Y
     F************************************************
     F* PLATING ACCOUNT RECEIVABLE WORK FILE CREATE ATAR50 *
     F* MAKE A CHANGE IN THE SEARCH NUMBER.        *
     F*                     K.YASUDA  2000.06.07   *
     F************************************************
     FATAPW50 CF  E                    WORKSTN
     FAS#PL11 IF  E           K        DISK
     FAARPL11 IF  E           K        DISK
     FATAWP50 O   E           K        DISK
     E                    $MSG    1   5 60
     C************************************************
     C*   K L I S T    作成                       *
     C************************************************
     C           #KEY1     KLIST
     C                     KFLD           #TOKU1
     C                     KFLD           #KAKOU
     C                     KFLD           #HIN1
     C                     KFLD           #HIN2
     C                     KFLD           #HIN3
     **
     C           *ENTRY    PLIST
     C                     PARM           PARM1   8
     C                     PARM           @SHAKO  1
     C                     PARM           @TYPE   1
     C*********************
     C*画面チェツク     *
     C*********************
     C           START     TAG
     C                     EXFMTATAPW501
     C                     SETOF                     202199
     C                     SETOF                     9098
     C                     MOVE *BLANK    @ERR
     C           *INKA     IFEQ '1'
     C                     MOVE '9'       @SHAKO
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C           @SHAKO    IFNE 'G'
     C           @SHAKO    IFNE ' '
     C                     SETON                       2199
     C                     MOVEL$MSG,1    @ERR
     C                     GOTO START
     C                     END
     C                     END
     C           @SHAKO    IFEQ 'G'
     C           @TYPE     IFEQ *BLANK
     C                     SETON                       2299
     C                     MOVEL$MSG,3    @ERR
     C                     GOTO START
     C                     END
     C           @TYPE     IFNE '1'
     C           @TYPE     ANDNE'2'
     C           @TYPE     ANDNE'3'
     C                     SETON                       2299
     C                     MOVEL$MSG,5    @ERR
     C                     GOTO START
     C                     END
     C                     END
     C**************************
     C*  日付チエック        *
     C**************************
     C                     MOVEL@SHIME    HYM     60
     C                     MOVELHYM       HY      40
     C                     MOVE HYM       HM      20
     C                     MOVE @SHIME    HD      20
     C           HY        SUB  *YEAR     YY      40
     C           YY        IFGE 1
     C                     SETON                       2099
     C                     MOVEL$MSG,2    @ERR
     C                     GOTO START
     C                     END
     C           @SHAKO    IFNE 'G'
     C           YY        IFLE -2
     C                     SETON                       2099
     C                     MOVEL$MSG,2    @ERR
     C                     GOTO START
     C                     END
     C                     END
     C           HY        DIV  4         URUDOS  50
     C                     MVR            AMARI   50
     C*  01
     C           HM        IFEQ 01
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  02
     C           HM        IFEQ 02
     C           AMARI     IFEQ *ZERO
     C           HD        IFLT 01
     C           HD        ORGT 29
     C                     SETON                       90
     C                     END
     C                     ELSE
     C           HD        IFLT 01
     C           HD        ORGT 28
     C                     SETON                       90
     C                     END
     C                     END
     C                     END
     C*  03
     C           HM        IFEQ 03
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  04
     C           HM        IFEQ 04
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  05
     C           HM        IFEQ 05
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  06
     C           HM        IFEQ 06
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  07
     C           HM        IFEQ 07
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  08
     C           HM        IFEQ 08
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  09
     C           HM        IFEQ 09
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  10
     C           HM        IFEQ 10
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  11
     C           HM        IFEQ 11
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  12
     C           HM        IFEQ 12
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  01 -- 12
     C           HM        IFLT 01
     C           HM        ORGT 12
     C                     SETON                       98
     C                     END
     C           HY        IFEQ *ZERO
     C                     SETON                       98
     C                     END
     C           *IN90     IFEQ '1'
     C           *IN98     OREQ '1'
     C                     SETON                       99
     C                     MOVEL$MSG,3    @ERR
     C                     GOTO START
     C                     END
     C/SPACE 3
     C**********************
     C* ファイル選択処理 *
     C**********************
     C*=== fﾈﾞbkｬc ﾎﾞ] ﾅbﾌlﾃc
     C           @TYPE     IFEQ '2'
     C                     MOVE @SHIME    PARM1
     C                     SETON                         LR
     C                     RETRN
     C                     END
     C*
     C                     DO   *HIVAL
     C                     READ AS#PL111                 81
     C           *IN81     CABEQ'1'       LAST
     C           CUKNHZ    IFEQ *ZERO
     C                     GOTO TRY
     C                     ELSE
     C           @SHAKO    IFEQ 'G'
     C           CUKNHZ    IFLE @SHIME
     C           CUURHZ    ANDEQ@SHIME
     C                     GOTO SECOND
     C                     END
     C                     ELSE
     C           CUKNHZ    IFLE @SHIME
     C           CUURHZ    ANDEQ*ZERO
     C                     GOTO SECOND
     C                     END
     C                     END
     C                     END
     C                     GOTO TRY
     C***********************
     C* ファイル作成処理  *
     C***********************
     C           SECOND    TAG
     C                     MOVE CUKAKO    #KAKOU  40
     C                     MOVE 8990      #TOKU1  40
     C                     MOVE CUHIN1    #HIN1   5
     C                     MOVE CUHIN2    #HIN2   5
     C                     MOVE CUHIN3    #HIN3   2
     C           #KEY1     CHAINAARPL111             55
     C                     MOVE CUZENO    TAZENO
     C                     MOVE CUKAKO    TAKAKO
     C                     MOVE CUTHNO    TATHNO
     C                     MOVE CUBKAS    TABKAS
     C                     MOVE CUKNHZ    TAKNHZ
     C                     MOVE CUHIN1    TAHIN1
     C                     MOVE CUHIN2    TAHIN2
     C                     MOVE CUHIN3    TAHIN3
     C                     MOVE CUSYUY    TASYUY
     C                     MOVE CURKHK    TARKHK
     C                     MOVE CURHSU    TARHSU
     C           CUSYUY    MULT CURKHK    CTR1    80
     C           CTR1      ADD  CURHSU    TASURY  70
     C                     MOVE *ZERO     CTR1
     C           *IN55     IFEQ '0'
     C           CSTANI    IFEQ 'G'
     C                     MOVE CSTANJ    JYU     73
     C                     ELSE
     C           CSTANJ    MULT 1000      JYU     73
     C                     END
     C                     MOVE CMHSYR    TAHSYR
     C           CMMKHZ    IFLE CUKNHZ
     C           CSMTKN    IFEQ 'C'
     C                     Z-ADDCSMTNN    TATANK
     C                     ELSE
     C           CSMTNN    MULT JYU       CTR2   139
     C           CTR2      DIV  1000      TATANK 139
     C                     END
     C                     ELSE
     C           CSMTKO    IFEQ 'C'
     C                     Z-ADDCSMTNO    TATANK
     C                     ELSE
     C           CSMTNO    MULT JYU       CTR2   139
     C           CTR2      DIV  1000      TATANK 139
     C                     END
     C                     END
     **
     C           CMMHHZ    IFLE CUKNHZ
     C           CSTANI    IFEQ 'G'
     C           CSMHSN    MULT 1000      WKSO    80
     C           CSTANJ    IFNE *ZERO
     C           WKSO      DIV  CSTANJ    TAHOSO  50H
     C                     END
     C                     ELSE
     C           CSMHSN    DIV  CSTANJ    TAHOSO    H
     C                     END
     C                     ELSE
     C           CSTANI    IFEQ 'G'
     C           CSMHSO    MULT 1000      WKSO    80
     C           CSTANJ    IFNE *ZERO
     C           WKSO      DIV  CSTANJ    TAHOSO  50H
     C                     END
     C                     ELSE
     C           CSMHSN    DIV  CSMHSO    TAHOSO    H
     C                     END
     C                     END
     **
     C                     ELSE
     C                     MOVE *ZERO     TATANK
     C                     MOVE *ZERO     TAHOSO
     C                     END
     C                     WRITEATAWP501
     C                     MOVE *BLANK    TAZENO
  K.YC                     MOVE *ALL'0'   TATHNO
     C                     MOVE *ZERO     TABKAS
     C                     MOVE *ZERO     TAKNHZ
     C                     MOVE *BLANK    TAHIN1
     C                     MOVE *BLANK    TAHIN2
     C                     MOVE *BLANK    TAHIN3
     C                     MOVE *BLANK    TAHSYR
     C                     MOVE *ZERO     TASYUY
     C                     MOVE *ZERO     TARKHK
     C                     MOVE *ZERO     TARHSU
     C                     MOVE *ZERO     TASURY
     C                     MOVE *ZERO     TATANK
     C                     MOVE *ZERO     TAHOSO
     C                     MOVE *ZERO     WKSO
     C           TRY       TAG
     C                     END
     C************************
     C*プログラムの終了    *
     C************************
     C           LAST      TAG
     C                     MOVE @SHIME    PARM1
     C                     SETON                       LR
     C                     RETRN
**
REPUBLICATION INSTRUCTION APPOINTMENT ERROR
CLOSE DAY ERROR
DATE APPOINTMENT ERROR
INPUT KIND OF REPUBLICATION
KIND OF REPUBLICATION  ERROR
