     H            Y.
      ** AB#R84 **********************************************
      *       .. PARTS EDIT MASTER MAINTENANCE ..            *
      *         K.KASHIWAGI     2000.11.27                   *
      ********************************* AB#R84 ***************
     FAB#PW84 CF  E                    WORKSTN
     FAB#PL88 UF  E           K        DISK                      A
     FGADPL11 IF  E           K        DISK
      *
     E                    MSGTBL  1  12 72
     E                    CDT        10  2 0
     E                    CDTD       10  2 0
     E                    CDTC       10  2 0
     E                    CDTA       10  2 0
     I            DS
     I                                        1  200CDT
     I                                        1   20ABCD1
     I                                        3   40ABCD2
     I                                        5   60ABCD3
     I                                        7   80ABCD4
     I                                        9  100ABCD5
     I                                       11  120ABCD6
     I                                       13  140ABCD7
     I                                       15  160ABCD8
     I                                       17  180ABCD9
     I                                       19  200ABCD10
     I*
     I            DS
     I                                        1  200CDTD
     I                                        1   20#CD1D
     I                                        3   40#CD2D
     I                                        5   60#CD3D
     I                                        7   80#CD4D
     I                                        9  100#CD5D
     I                                       11  120#CD6D
     I                                       13  140#CD7D
     I                                       15  160#CD8D
     I                                       17  180#CD9D
     I                                       19  200#CD10D
     I*
     I            DS
     I                                        1  200CDTC
     I                                        1   20#CD1C
     I                                        3   40#CD2C
     I                                        5   60#CD3C
     I                                        7   80#CD4C
     I                                        9  100#CD5C
     I                                       11  120#CD6C
     I                                       13  140#CD7C
     I                                       15  160#CD8C
     I                                       17  180#CD9C
     I                                       19  200#CD10C
     I*
     I            DS
     I                                        1  200CDTA
     I                                        1   20#CD1A
     I                                        3   40#CD2A
     I                                        5   60#CD3A
     I                                        7   80#CD4A
     I                                        9  100#CD5A
     I                                       11  120#CD6A
     I                                       13  140#CD7A
     I                                       15  160#CD8A
     I                                       17  180#CD9A
     I                                       19  200#CD10A
     I            DS
     I                                        1   80DATE
     I                                        1   20W@CT
     I                                        3   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     C*
     C           KEY1      KLIST
     C                     KFLD           ABCUST
     C           KEY2      KLIST
     C                     KFLD           B5TOKU
     C*
     C           *ENTRY    PLIST
     C                     PARM           TEAM   10
      *--------------*
      * MAIN ROUTINE *
      *--------------*
     C                     EXSR @INTR
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      @DSP1
     C           W@ID      CASEQ'02'      @DSP2
     C           W@ID      CASEQ'03'      @DSP3
     C           W@ID      CASEQ'04'      @DSP4
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
      *---------------*
      * INITIALIZATION
      *---------------*
     C           @INTR     BEGSR
     C                     MOVEL*BLANK    #MSG
     C                     MOVEL*BLANK    #MSGA
     C                     MOVEL*BLANK    #MSGD
     C                     MOVEL*BLANK    #MSGC
     C                     MOVEL*BLANK    #OPT
     C                     MOVEL'01'      W@ID    2
     C                     TIME           #TIME
     C                     MOVE *DATE     DATE
     C                     Z-ADD2000      W@YY4   40
     C                     ADD  W@YY      W@YY4
     C                     ENDSR
      *--------------*
      * FIRST SCREEN *
      *--------------*
     C           @DSP1     BEGSR
     C                     EXFMTAB#PW841
     C                     MOVEL*BLANKS   #MSG
     C                     MOVEL'0'       *IN90
     C                     MOVEL'0'       *IN01
     C                     MOVEL'0'       *IN02
     C*
     C                     SELEC
     C           *INKA     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C                     OTHER
     C                     EXSR @CHECK
     C                     ENDSL
     C                     ENDSR
      *--------------*
      * CHECK1*
      *--------------*
     C           @CHECK    BEGSR
     C           #OPT      IFNE '0'
     C           #OPT      ANDNE'1'
     C           #OPT      ANDNE'2'
     C                     MOVELMSGTBL,1  #MSG
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN01
     C                     ELSE
     C*
     C                     Z-ADD#CST      B5TOKU
     C           KEY2      CHAINGADPL11              80
     C           *IN80     IFEQ '1'
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN02
     C                     MOVELMSGTBL,2  #MSG
     C                     ELSE
     C                     Z-ADD#CST      ABCUST
     C           KEY1      CHAINAB#PL88              70
     C                     SELEC
     C           #OPT      WHEQ '0'
     C           *IN70     IFEQ '1'
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN02
     C                     MOVELMSGTBL,4  #MSG
     C                     ELSE
     C           ABSKJY    IFNE 'D'
     C                     EXSR @DELPR
     C                     ELSE
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN02
     C                     MOVELMSGTBL,4  #MSG
     C                     ENDIF
     C                     ENDIF
     C           #OPT      WHEQ '1'
     C           *IN70     IFEQ '1'
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN02
     C                     MOVELMSGTBL,4  #MSG
     C                     ELSE
     C           ABSKJY    IFNE 'D'
     C                     EXSR @CHGPR
     C                     ELSE
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN02
     C                     MOVELMSGTBL,4  #MSG
     C                     ENDIF
     C                     ENDIF
     C           #OPT      WHEQ '2'
     C           *IN70     IFEQ '0'
     C           ABSKJY    IFNE 'D'
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN02
     C                     MOVELMSGTBL,3  #MSG
     C                     ELSE
     C                     EXSR @ADDPR
     C                     ENDIF
     C                     ELSE
     C                     EXSR @ADDPR
     C                     ENDIF
     C                     ENDSL
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *---------------*
      * DELETE PREPARE*
      *---------------*
     C           @DELPR    BEGSR
     C           KEY1      CHAINAB#PL88              70
     C           *IN70     IFEQ '0'
     C                     MOVEL'02'      W@ID
     C                     MOVEL#CST      #CSTD
     C*
     C                     Z-ADD0         X       20
     C                     DO   10
     C                     ADD  1         X
     C                     MOVEACDT,X     CDTD,X
     C                     ENDDO
     C**
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDSR
     C*
      *---------------*
      * DELETE SCREEN *
      *---------------*
     C           @DSP2     BEGSR
     C                     EXFMTAB#PW842
     C                     MOVEL*BLANKS   #MSGD
     C                     MOVEL'0'       *IN90
     C*
     C                     SELEC
     C           *INKA     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C           *INKC     WHEQ '1'
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ '1'
     C                     EXSR @DEL
     C                     ENDSL
     C                     ENDSR
      *---------------*
      * DELETE PROCESS*
      *---------------*
     C           @DEL      BEGSR
     C           KEY1      CHAINAB#PL88              70
     C           *IN70     IFEQ '0'
     C                     MOVEL'D'       ABSKJY
     C                     Z-ADDW@YY4     ABSKYY
     C                     Z-ADDW@MM      ABSKMM
     C                     Z-ADDW@DD      ABSKDD
     C                     Z-ADDW@YY4     ABKOYY
     C                     Z-ADDW@MM      ABKOMM
     C                     Z-ADDW@DD      ABKODD
     C                     Z-ADDW@HH      ABKOHH
     C                     MOVELTEAM      ABKOME
     C                     UPDATAB#PP881
     C                     MOVELMSGTBL,8  #MSG
     C                     MOVEL*BLANK    #OPT
     C                     Z-ADD0         #CST
     C                     MOVEL'01'      W@ID
     C                     ENDIF
     C                     ENDSR
      *---------------*
      * CHANGE PREPARE*
      *---------------*
     C           @CHGPR    BEGSR
     C           KEY2      CHAINAB#PL88              70
     C           *IN70     IFEQ '0'
     C                     MOVEL#CST      #CSTC
     C*
     C                     Z-ADD0         X       20
     C                     DO   10
     C                     ADD  1         X
     C                     MOVEACDT,X     CDTC,X
     C                     ENDDO
     C*
     C                     MOVEL'03'      W@ID
     C                     ENDIF
     C                     ENDSR
     C*
      *---------------*
      * CHANGE SCREEN *
      *---------------*
     C           @DSP3     BEGSR
     C                     EXFMTAB#PW843
     C                     MOVEL*BLANKS   #MSGC
     C                     MOVEL'0'       *IN90
     C*
     C                     SELEC
     C           *INKA     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C           *INKC     WHEQ '1'
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ '1'
     C                     EXSR @CHGCK
     C                     EXSR @CHG
     C                     OTHER
     C                     EXSR @CHGCK
     C                     ENDSL
     C                     ENDSR
      *---------------*
      * CHANGE CHECK  *
      *---------------*
     C           @CHGCK    BEGSR
     C                     Z-ADD10        Y       20
     C                     Z-ADD0         SW      20
     C                     DO   10
     C           CDTC,Y    IFNE 0
     C                     ADD  1         SW
     C                     ENDIF
     C           SW        IFGE 1
     C           CDTC,Y    ANDEQ0
     C                     MOVELMSGTBL,5  #MSGC
     C                     MOVEL'1'       *IN90
     C                     LEAVE
     C                     ENDIF
     C           Y         SUB  1         Y
     C           Y         IFEQ 0
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           #MSGC     IFEQ *BLANKS
     C                     EXSR @TOTAL
     C                     ENDIF
     C                     ENDSR
     C*-----------------*
      * EDIT TOTAL CHECK*
      *-----------------*
     C           @TOTAL    BEGSR
     C                     Z-ADD0         Y
     C                     Z-ADD0         W@TOT   30
     C                     DO   10
     C                     ADD  1         Y
     C                     ADD  CDTC,Y    W@TOT
     C                     ENDDO
     C           W@TOT     IFGT 20
     C                     MOVELMSGTBL,11 #MSGC
     C                     MOVEL'1'       *IN90
     C                     ELSE
     C           W@TOT     IFEQ 0
     C                     MOVELMSGTBL,12 #MSGC
     C                     MOVEL'1'       *IN90
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADD0         W@TOT
     C                     ENDSR
      *-----------------*
      * CHANGE PROCESS*
      *---------------*
     C           @CHG      BEGSR
     C           #MSGC     IFEQ *BLANKS
     C                     Z-ADD0         X
     C           KEY1      CHAINAB#PL88              80
     C           *IN80     IFEQ '0'
     C                     DO   10
     C                     ADD  1         X
     C                     Z-ADDCDTC,X    CDT,X
     C                     ENDDO
     C                     Z-ADDW@YY4     ABKOYY
     C                     Z-ADDW@MM      ABKOMM
     C                     Z-ADDW@DD      ABKODD
     C                     MOVE W@HH      ABKOHH
     C                     MOVE W@MIN     ABKOSS
     C                     MOVELTEAM      ABKOME
     C                     UPDATAB#PP881
     C                     MOVEL*BLANK    #OPT
     C                     Z-ADD0         #CST
     C                     MOVELMSGTBL,9  #MSG
     C                     MOVEL'01'      W@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSR
      *---------------*
      * ADD PREPARE   *
      *---------------*
     C           @ADDPR    BEGSR
     C*          KEY2      CHAINAB#PL88              70
     C*          *IN70     IFEQ '1'
     C                     MOVEL#CST      #CSTA
     C*
     C                     Z-ADD0         X       20
     C                     DO   10
     C                     ADD  1         X
     C                     Z-ADD0         CDTA,X
     C                     ENDDO
     C*
     C                     MOVEL'04'      W@ID
     C                     ENDSR
     C*
      *---------------*
      * ADD SCREEN    *
      *---------------*
     C           @DSP4     BEGSR
     C                     EXFMTAB#PW844
     C                     MOVEL*BLANKS   #MSGA
     C                     MOVEL'0'       *IN90
     C*
     C                     SELEC
     C           *INKA     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C           *INKC     WHEQ '1'
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ '1'
     C                     EXSR @ADDCK
     C                     EXSR @ADD
     C                     OTHER
     C                     EXSR @ADDCK
     C                     ENDSL
     C                     ENDSR
      *---------------*
      * ADD CHECK     *
      *---------------*
     C           @ADDCK    BEGSR
     C                     Z-ADD10        Y       20
     C                     Z-ADD0         SW      20
     C                     DO   10
     C           CDTA,Y    IFNE 0
     C                     ADD  1         SW
     C                     ENDIF
     C           SW        IFGE 1
     C           CDTA,Y    ANDEQ0
     C                     MOVELMSGTBL,5  #MSGA
     C                     MOVEL'1'       *IN90
     C                     LEAVE
     C                     ENDIF
     C           Y         SUB  1         Y
     C           Y         IFEQ 0
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           #MSGA     IFEQ *BLANKS
     C                     EXSR @TOTAA
     C                     ENDIF
     C                     ENDSR
     C*-----------------**
      * TOTAL CHK FOR ADD*
      *------------------*
     C           @TOTAA    BEGSR
     C                     Z-ADD0         Y
     C                     Z-ADD0         W@TOT   30
     C                     DO   10
     C                     ADD  1         Y
     C                     ADD  CDTA,Y    W@TOT
     C                     ENDDO
     C           W@TOT     IFGT 20
     C                     MOVELMSGTBL,11 #MSGA
     C                     MOVEL'1'       *IN90
     C                     ELSE
     C           W@TOT     IFEQ 0
     C                     MOVELMSGTBL,12 #MSGA
     C                     MOVEL'1'       *IN90
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADD0         W@TOT
     C                     ENDSR
      *---------------*
      * ADD PROCESS*
      *---------------*
     C           @ADD      BEGSR
     C           #MSGA     IFEQ *BLANKS
     C                     Z-ADD#CSTA     ABCUST
     C*
     C                     Z-ADD0         X
     C                     DO   10
     C                     ADD  1         X
     C                     MOVEACDTA,X    CDT,X
     C                     ENDDO
     C                     Z-ADDW@YY4     ABKOYY
     C                     Z-ADDW@MM      ABKOMM
     C                     Z-ADDW@DD      ABKODD
     C                     MOVE W@HH      ABKOHH
     C                     MOVE W@MIN     ABKOSS
     C                     MOVELTEAM      ABKOME
     C           ABSKJY    IFEQ 'D'
     C                     MOVEL*BLANK    ABSKJY
     C                     UPDATAB#PP881
     C                     ELSE
     C                     WRITEAB#PP881
     C                     ENDIF
     C                     MOVEL*BLANK    #OPT
     C                     Z-ADD0         #CST
     C                     MOVELMSGTBL,10 #MSG
     C                     MOVEL'01'      W@ID
     C                     ENDIF
     C                     ENDSR
** (MSGTBL)
E-01 OPTION IS OUT OF RANGE.  CHOOSE OPTION FROM 1,2,OR 3.
E-02 INVALID CUSTOMER CODE.
E-03 CUSTOMER CODE ALREADY EXIST.  TRY DIFFERENT CUSTOMER CODE.
E-04 CUSTOMER CODE DOES NOT EXIST.  TRY DIFFERENT CUSTOMER CODE.
E-05 NO BLANK FIELD ALLOWED BETWEEN EDIT CODE.
E-06 TO CONTINUE DELETING RECORD, PRESS ENTER.
E-07 TO CONTINUE UPDATINE RECORD, PRESS ENTER.
E-08 RECORD IS DELETE.
E-09 RECORD IS UPDATE.
E-10 RECORD IS ADDED.
E-11 TOTAL OF EDIT CODE SHOULD NOT BE GREATER THAN 20.
E-12 TOTAL OF EDIT CODE SHOULD NOT BE 0.
