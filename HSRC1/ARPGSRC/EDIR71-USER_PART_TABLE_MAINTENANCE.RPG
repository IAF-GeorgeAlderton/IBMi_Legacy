     H            Y/                                    1
     H* EDIR71 ********************************************************
     H* USER PART TABLE MAINTENANCE                                   *
     H* J.W       2019.09.24                                          *
     H*****************************************************************
     FEDIPW71 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FEDIPP45 UF  E           K        DISK                      A
      *================================================================
     E                    MSG     1  20 60
      *================================================================
     I            DS
     I                                        1  140@TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 271 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     EXSR #INIT
      *
     C           @STP1     DOUEQ'END'
      *  DISPLAY (DSP01)
      *
     C                     EXFMTDSP01
     C                     SETOF                     414243
     C                     SETOF                     4445
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    XMSG
      *
     C                     SELEC
     C*  < F1 >  END JOB
     C           *INKA     WHEQ *ON
     C                     MOVE 'END'     @STP1   3
      *
     C*  < F5  >  CONTINUE
     C           *INKE     WHEQ *ON
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C                     EXSR #DSP2
     C                     ENDIF
      *
      *  < F12 >  TABLE INQUIRY
     C           *INKL     WHEQ *ON
     C                     CALL 'EDIR72'
     C                     PARM           P@MHN1  5
     C                     PARM           P@MHN2  5
     C                     PARM           P@MHN3  5
     C                     PARM           P@MHN4  5
     C                     PARM           P@NONY  4
     C           P@MHN1    IFNE *BLANK
     C                     MOVELP@MHN1    D1MHN1
     C                     MOVELP@MHN2    D1MHN2
     C                     MOVELP@MHN3    D1MHN3
     C                     MOVELP@MHN4    D1MHN4
     C                     MOVELP@NONY    D1NONY
     C                     MOVE *BLANK    XMSG
     C                     ENDIF
      *
      *  < ENTR >
     C                     OTHER
     C                     EXSR #CHK1
      *
     C                     ENDSL
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * CHECK SCREEN 1
      *===============================================================
     C           #CHK1     BEGSR
     C                     MOVE *BLANK    D1NAME
     C                     MOVE *OFF      *IN85
     C* D1MODE
     C           D1MODE    IFNE '0'
     C           D1MODE    ANDNE'1'
     C           D1MODE    ANDNE'2'
     C                     SETON                     4185
     C                     MOVELMSG,1     XMSG
     C                     GOTO #CHK1X
     C                     ENDIF
     C* D1NONY
     C           D1NONY    IFEQ 0
     C                     SETON                     4385
     C                     MOVELMSG,3     XMSG
     C                     GOTO #CHK1X
     C                     ENDIF
      *
     C           D1NONY    CHAINFGBPL01             N90
     C           *IN90     IFEQ *ON
     C           *IN90     OREQ *OFF
     C           B2SKJY    ANDEQ'D'
     C                     SETON                     4385
     C                     MOVELMSG,4     XMSG
     C                     GOTO #CHK1X
     C                     ENDIF
     C                     MOVELB2SMEI    D1NAME
     C* D1MHN
     C           D1MHN1    IFEQ *BLANK
     C           D1MHN2    ANDEQ*BLANK
     C           D1MHN3    ANDEQ*BLANK
     C           D1MHN4    ANDEQ*BLANK
     C                     SETON                     4285
     C                     MOVELMSG,2     XMSG
     C                     GOTO #CHK1X
     C                     ENDIF
      * ADD/CHG/DLT
     C                     MOVELD1MHN1    KMHN1
     C                     MOVELD1MHN2    KMHN2
     C                     MOVELD1MHN3    KMHN3
     C                     MOVELD1MHN4    KMHN4
     C                     Z-ADDD1NONY    KNONY
     C           K#PP45    CHAINEDIPP45             N99
     C           *IN99     IFEQ *OFF
     C           E5SKJY    ANDEQ'D'
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     SELEC
     C           *IN99     WHEQ *ON
     C           D1MODE    ANDNE'2'
     C                     SETON                     4185
     C                     MOVELMSG,8     XMSG
     C                     GOTO #CHK1X
      *
     C           *IN99     WHEQ *OFF
     C           D1MODE    ANDEQ'2'
     C                     SETON                     4185
     C                     MOVELMSG,9     XMSG
     C                     GOTO #CHK1X
     C                     ENDSL
      * IF NO ERROR.......
     C           *IN85     IFEQ *OFF
     C                     MOVELMSG,6     XMSG
      *
     C                     SELEC
     C           D1MODE    WHEQ '0'
     C                     MOVEL'DELETE ' D1MODN
     C                     MOVE *ON       *IN45
     C           D1MODE    WHEQ '1'
     C                     MOVEL'CAHNGE ' D1MODN
     C           D1MODE    WHEQ '2'
     C                     MOVEL'ADD    ' D1MODN
     C                     ENDSL
      *
     C           *IN99     IFEQ *OFF
     C                     MOVELE5UPRT    D2UPRT
     C                     ELSE
     C                     MOVE *BLANK    D2UPRT
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           #CHK1X    ENDSR
      *===============================================================
      * DISPLAY SCREEN 2
      *===============================================================
     C           #DSP2     BEGSR
     C                     MOVE *BLANK    @STP2   3
      *
     C           @STP2     DOUEQ'END'
      *  DISPLAY (DSP02)
     C                     EXFMTDSP02
     C                     MOVE *OFF      *IN44
     C                     MOVE *OFF      *IN86
     C                     MOVE *BLANK    XMSG
      *
     C                     SELEC
     C*  < F3 >  END JOB
     C           *INKC     WHEQ *ON
     C                     MOVE 'END'     @STP2
     C                     MOVE *BLANK    XMSG
     C*  < F5 >  UPDATE
     C           *INKE     WHEQ *ON
     C                     EXSR #CHK2
     C           *IN86     IFEQ *OFF
     C                     EXSR #UPDAT
     C                     MOVE 'END'     @STP2
     C                     MOVE *BLANK    XMSG
     C                     ENDIF
      *  < ENTR >
     C                     OTHER
     C                     EXSR #CHK2
      *
     C                     ENDSL
     C                     ENDDO
      *
      *
     C           #DSP2X    ENDSR
      *===============================================================
      * CHECK SCREEN 2
      *===============================================================
     C           #CHK2     BEGSR
      * D2UPRT
     C           D2UPRT    IFEQ *BLANK
     C                     MOVE *ON       *IN44
     C                     MOVE *ON       *IN86
     C                     MOVELMSG,5     XMSG
     C                     GOTO #CHK2X
     C                     ENDIF
      * IF NO ERROR...
     C           *IN86     IFEQ *OFF
     C                     MOVELMSG,7     XMSG
     C                     ENDIF
      *
     C           #CHK2X    ENDSR
      *===============================================================
      *  UPDATE PROCESS
      *===============================================================
     C           #UPDAT    BEGSR
      *
     C           K#PP45    CHAINEDIPP45              99
      * DELETE
     C                     SELEC
     C           *IN99     WHEQ *OFF
     C           D1MODE    ANDEQ'0'
     C                     TIME           @TIME
     C                     MOVE 'D'       E5SKJY
     C                     Z-ADDTODAY     E5SKHZ
     C                     Z-ADDNOW       E5SKTM
     C                     MOVEL#USER     E5SKME
     C**                   MOVEL#PGM      E5SKPG
     C                     UPDATEDIPP451
      * CHANGE
     C           *IN99     WHEQ *OFF
     C           D1MODE    ANDEQ'1'
     C                     TIME           @TIME
     C                     MOVELD2UPRT    E5UPRT
     C                     Z-ADDTODAY     E5KOHZ
     C                     Z-ADDNOW       E5KOTM
     C                     MOVEL#USER     E5KOME
     C                     MOVEL#PGM      E5KOPG
     C                     MOVE *BLANK    E5SKJY
     C                     Z-ADD0         E5SKHZ
     C                     Z-ADD0         E5SKTM
     C                     MOVE *BLANK    E5SKME
     C                     UPDATEDIPP451
      * ADD 1
     C           *IN99     WHEQ *OFF
     C           D1MODE    ANDEQ'2'
     C           E5SKJY    ANDEQ'D'
     C                     TIME           @TIME
     C                     MOVELD2UPRT    E5UPRT
     C                     Z-ADDTODAY     E5CRHZ
     C                     Z-ADDNOW       E5CRTM
     C                     MOVEL#USER     E5CRME
     C                     MOVEL#PGM      E5CRPG
     C                     MOVE *BLANK    E5SKJY
     C                     Z-ADD0         E5SKHZ
     C                     Z-ADD0         E5SKTM
     C                     MOVE *BLANK    E5SKME
     C                     Z-ADD0         E5KOHZ
     C                     Z-ADD0         E5KOTM
     C                     MOVE *BLANK    E5KOME
     C                     UPDATEDIPP451
      * ADD 2
     C           *IN99     WHEQ *ON
     C           D1MODE    ANDEQ'2'
     C                     TIME           @TIME
     C                     MOVELD1MHN1    E5MHN1
     C                     MOVELD1MHN2    E5MHN2
     C                     MOVELD1MHN3    E5MHN3
     C                     MOVELD1MHN4    E5MHN4
     C                     Z-ADDD1NONY    E5NONY
     C                     MOVELD2UPRT    E5UPRT
     C                     Z-ADDTODAY     E5CRHZ
     C                     Z-ADDNOW       E5CRTM
     C                     MOVEL#USER     E5CRME
     C                     MOVEL#PGM      E5CRPG
     C                     MOVE *BLANK    E5SKJY
     C                     Z-ADD0         E5SKHZ
     C                     Z-ADD0         E5SKTM
     C                     MOVE *BLANK    E5SKME
     C                     Z-ADD0         E5KOHZ
     C                     Z-ADD0         E5KOTM
     C                     MOVE *BLANK    E5KOME
     C                     WRITEEDIPP451
      *
     C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *   << INIT >>
      *===============================================================
     C           #INIT     BEGSR
      *
     C           K#PP45    KLIST
     C                     KFLD           KNONY   40
     C                     KFLD           KMHN1   5
     C                     KFLD           KMHN2   5
     C                     KFLD           KMHN3   5
     C                     KFLD           KMHN4   5
      *
     C                     TIME           @TIME
     C                     MOVE '1'       D1MODE
     C                     Z-ADD0         D1NONY
     C                     MOVE *BLANK    D1MHN1
     C                     MOVE *BLANK    D1MHN2
     C                     MOVE *BLANK    D1MHN3
     C                     MOVE *BLANK    D1MHN4
     C                     MOVE *BLANK    XMSG
      *
     C                     ENDSR
      *===============================================================
** MSG(60).........2.........3.........4.........5.........6
ERROR: MAINTENANCE MODE SHOULD BE 0, 1 OR 2 !                01
ERROR: ENTER USER PART# !                                    02
ERROR: ENTER DELIVERY CODE !                                 03
ERROR: DELIVERY CODE NOT FOUND !                             04
ERROR: ENTER ORIGINAL PART# !                                05
MSG: PRESS F5 TO CONTINUE...                                 06
MSG: PRESS F5 TO UPDATE...                                   07
ERROR: TABLE NOT FOUND !                                     08
ERROR: TABLE ALREADY EXIST !                                 09
