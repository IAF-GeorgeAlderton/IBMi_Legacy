%0001 *
     C*                    Z-ADDWKOTE1    WKOTE2
     C           WKOTE1    DIV  ZDTKJR    WKOTE2    H
%0001 *
     C                     MULT ZDSLTM    WKOTE2
     C                     MULT ZDKEIS    WKOTE2
     C                     ADD  0.9       WKOTE2
     C           ZDLOTO    SUB  1         WKOTE3
     C                     ADD  ZDCHOS    WKOTE3
     C           WKOTE2    ADD  WKOTE3    WKMAX
      *
     C           WKMAX     IFLE 3
     C                     Z-ADD3         WKMAX
     C                     END
      *
     C                     Z-ADD0         WPASR
     C           ZDKMMX    IFNE 0
     C           WKMAX     DIV  ZDKMMX    WKNO      H
     C           WKNO      MULT 100       WPASR   51
     C                     END
      *
     C           100       SUB  IPAS      WPAS1   41
     C           100       ADD  IPAS      WPAS2   41
      *
     C           WPASR     IFGE WPAS1
     C           WPASR     ANDLEWPAS2
     C                     ELSE
      *
     C                     MOVE '+'       WPASKR  1
     C           WPASR     IFLT WPAS1
     C                     MOVE '-'       WPASKR
     C                     END
      *
     C                     Z-ADD0         WJUR1R  80
     C                     Z-ADD0         WJUR2R  80
     C                     Z-ADD0         WJUR3R  80
      *
     C           KEY4      SETLLIZBPL101
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY4      READEIZBPL101                 20
     C           *IN20     IFEQ '0'
      *
     C           ZASKJY    IFEQ 'D'
     C           ZASKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD0         WGOKE
     C           KEY5      SETLLMBEPL021
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           KEY5      READEMBEPL021                 21
     C           *IN21     IFEQ '0'
     C           F2SKJY    IFEQ *BLANK
     C                     ADD  F2GOKE    WGOKE
     C                     END
     C                     END
     C  N21                END
      *
     C           WGOKE     MULT ZASOZI    WGOSO  112
     C           WGOSO     DIV  1000      WGOSO1  80H
     C                     ADD  WGOSO1    WJUR1R
      *
     C                     SETOF                     21
     C                     Z-ADD0         WN1SU
     C                     Z-ADD0         WN2SU
     C           KEY6      CHAINABBPL211             21
     C           *IN21     IFEQ '1'
     C                     Z-ADDZAGEKN    WN1SU
     C                     Z-ADDZAGEKN    WN2SU
     C                     ELSE
      *
     C           U1NGKB    IFEQ 'N'
     C                     Z-ADDU1N1NM    WN1SU
     C                     Z-ADDU1N2NM    WN2SU
     C                     ELSE
     C                     Z-ADDU1S1NM    WN1SU
     C                     Z-ADDU1S2NM    WN2SU
     C                     END
     C                     END
      *
     C           WN1SU     MULT ZASOZI    WGOSO
     C           WGOSO     DIV  1000      WGOSO1    H
     C                     ADD  WGOSO1    WJUR2R
      *
     C           WN2SU     MULT ZASOZI    WGOSO
     C           WGOSO     DIV  1000      WGOSO1    H
     C                     ADD  WGOSO1    WJUR3R
      *
     C                     END
     C                     END
     C  N20                END
      *
     C                     SETON                     U2
     C                     EXCPTDT2
      *
     C                     END
%0002 *
     C                     ELSE
     C                     MOVE '2'       CFLG
     C                     END
     C                     END
%0002 *
