      *
     C                     Z-ADD*DATE     WYMD
     C                     Z-ADD0         IPAS
      *
     C           STP1      TAG
     C                     EXFMTIZAPW301
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           INO       IFNE '1'
     C           INO       ANDNE'2'
     C           INO       ANDNE'3'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IPAS      IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *
     C           INO       IFEQ '1'
     C           INO       OREQ '3'
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ IZAPP011                 10
     C           *IN10     IFEQ '0'
      *
     C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ELSE
%0002 *
     C           ZCSTHZ    IFEQ 99999999
     C           ZCTKJR    IFNE 0
%0002 *
     C           ZCMSJR    DIV  20        WKOTE1  80H
     C           ZCTKJR    IFNE 0
     C           WKOTE1    DIV  ZCTKJR    WKOTE2 102H
     C                     ELSE
     C                     Z-ADDWKOTE1    WKOTE2
     C                     END
     C                     MULT ZCSLTM    WKOTE2
     C                     MULT ZCKEIS    WKOTE2
     C                     ADD  0.9       WKOTE2
     C           ZCLOTO    SUB  1         WKOTE3  30
     C                     ADD  ZCCHOS    WKOTE3
     C           WKOTE2    ADD  WKOTE3    WKMAX   30
      *
     C           WKMAX     IFLE 3
     C                     Z-ADD3         WKMAX
     C                     END
      *
     C                     Z-ADD0         WPASW
     C           ZCKMMX    IFNE 0
     C           WKMAX     DIV  ZCKMMX    WKNO    63H
     C           WKNO      MULT 100       WPASW   51
     C                     END
      *
     C           100       SUB  IPAS      WPAS1   41
     C           100       ADD  IPAS      WPAS2   41
      *
     C           WPASW     IFGE WPAS1
     C           WPASW     ANDLEWPAS2
     C                     ELSE
      *
     C                     MOVE '+'       WPASKW  1
     C           WPASW     IFLT WPAS1
     C                     MOVE '-'       WPASKW
     C                     END
      *
     C                     Z-ADD0         WJUR1W  80
     C                     Z-ADD0         WJUR2W  80
     C                     Z-ADD0         WJUR3W  80
      *
     C           KEY1      SETLLIZAPL101
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEIZAPL101                 20
     C           *IN20     IFEQ '0'
      *
     C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD0         WGOKE   70
     C           KEY2      SETLLMBEPL021
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           KEY2      READEMBEPL021                 21
     C           *IN21     IFEQ '0'
     C           F2SKJY    IFEQ *BLANK
     C                     ADD  F2GOKE    WGOKE
     C                     END
     C                     END
     C  N21                END
      *
     C           WGOKE     MULT ZBSOZI    WGOSO  112
     C           WGOSO     DIV  1000      WGOSO1  80H
     C                     ADD  WGOSO1    WJUR1W
      *
     C                     SETOF                     21
     C                     Z-ADD0         WN1SU   90
     C                     Z-ADD0         WN2SU   90
     C           KEY3      CHAINABBPL211             21
     C           *IN21     IFEQ '1'
     C                     Z-ADDZBGEKN    WN1SU
     C                     Z-ADDZBGEKN    WN2SU
     C                     ELSE
      *
     C           U1NGKB    IFEQ 'N'
     C                     Z-ADDU1N1NM    WN1SU
     C                     Z-ADDU1N2NM    WN2SU
     C                     ELSE
     C                     Z-ADDU1S1NM    WN1SU
     C                     Z-ADDU1S2NM    WN2SU
     C                     END
     C                     END
      *
     C           WN1SU     MULT ZBSOZI    WGOSO
     C           WGOSO     DIV  1000      WGOSO1    H
     C                     ADD  WGOSO1    WJUR2W
      *
     C           WN2SU     MULT ZBSOZI    WGOSO
     C           WGOSO     DIV  1000      WGOSO1    H
     C                     ADD  WGOSO1    WJUR3W
      *
     C                     END
     C                     END
     C  N20                END
      *
     C                     SETON                     U1
     C                     EXCPTDT1
      *
     C                     END
%0002 *
     C                     ELSE
     C                     MOVE '1'       CFLG
     C                     END
     C                     END
%0002 *
     C                     END
     C                     END
     C  N10                END
     C                     END
      *
     C           INO       IFEQ '2'
     C           INO       OREQ '3'
      *
     C                     DO   *HIVAL
