     F********************************** IZAR40 **
     FIZAPW40 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FIZAPL04 IF  E           K        DISK
     FIZAPL10 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
      *
      *------------------------------------------------------
     E                    CMD     1   2 78
     E                    MON    12  12  3
     E                    MSG     1   2 70
      *
     E                    D@M         5  3
     E                    DAT         5  6 0
     E                    ACT         5  7 0
     E                    QTY         5 11 0
      *------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   60K@YM
     I                                        1   40K@YY
     I                                        5   60K@MM
     I            DS
     I                                        1   60BAYM
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I            DS
     I                                        1  15 D@M
     I                                        1   3 D@MON1
     I                                        4   6 D@MON2
     I                                        7   9 D@MON3
     I                                       10  12 D@MON4
     I                                       13  15 D@MON5
     I            DS
     I                                        1  35 ACT
     I                                        1   70S@ACT1
     I                                        8  140S@ACT2
     I                                       15  210S@ACT3
     I                                       22  280S@ACT4
     I                                       29  350S@ACT5
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C           KEYZB1    KLIST
     C                     KFLD           ZCZAIS
     C                     KFLD           ZCZAIK
     C                     KFLD           ZCKOJE
     C                     KFLD           ZCKAKE
     C           KEYF21    KLIST
     C                     KFLD           ZBSHN1
     C                     KFLD           ZBSHN2
     C                     KFLD           ZBSHN3
     C           K#18      KLIST
     C                     KFLD           ZBSHN1
     C                     KFLD           ZBSHN2
     C                     KFLD           ZBSHN3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
      *
     C                     MOVE '01'      W@ID    2
     C                     Z-ADD*ZERO     DAT
     C                     Z-ADD*YEAR     K@YY
     C           *DAY      IFLT 10
     C           *MONTH    SUB  1         K@MM
     C           K@MM      IFEQ *ZERO
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*MONTH    K@MM
     C                     ENDIF
      *
     C           1         DO   5         X       20
     C                     Z-ADDK@YM      DAT,X
     C                     MOVE MON,K@MM  D@M,X
     C                     SUB  1         K@MM
     C           K@MM      IFEQ *ZERO
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *------------------------------------------------------
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '02'      W@ID
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *------------------------------------------------------
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
JW1   * CHECK SUPPLIER
     C           D@SUPL    IFEQ *BLANK
     C                     MOVELMSG,1     D@MSG
     C                     SETON                     61  99
     C                     GOTO XCHK1
JW1  C                     ENDIF
      *
JW1  C                     MOVELD@SUPL    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTNX   1
     C           $RTNX     IFNE *BLANK
     C                     MOVELMSG,2     D@MSG
     C                     SETON                     61  99
     C                     GOTO XCHK1
     C                     ENDIF
JW1  C                     MOVEL$NAME1    D@NAME
      *
     C           D@SUPL    IFNE *BLANK
     C                     MOVE D@SUPL    K@SUPL  40
     C           K@SUPL    CHAINIZAPL04              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
TCHK1C                     ELSE
TCHK1C                     SETON                     6199
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *------------------------------------------------------
     C           #SET      BEGSR
      *------------------------------------------------------
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
      *
     C           K@SUPL    SETLLIZAPL04
     C                     EXSR #SET11
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SET11    BEGSR
      *------------------------------------------------------
     C                     Z-ADD*ZERO     @CNT    20
     C           *IN80     DOUEQ*ON
     C           K@SUPL    READEIZAPL04                  80
     C           *IN80     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSTYY    ANDEQ9999
      *
     C                     CLEARSFL01
     C                     MOVE ZCZAIS    S@ZAIS
     C                     Z-ADDZCZAIK    S@ZAIK
     C                     Z-ADDZCMSJR    S@SETT
     C                     EXSR #ACT
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ADD  1         @CNT
     C           @CNT      IFEQ 17
     C                     LEAVE
     C                     ENDIF
     C           @CNT      IFEQ 1
     C                     Z-ADDRRN1      #RCNO
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #ACT      BEGSR
      *------------------------------------------------------
     C                     Z-ADD*ZERO     W@ACT   70
     C           KEYZB1    SETLLIZAPL101
     C           *IN81     DOUEQ*ON
     C           KEYZB1    READEIZAPL101                 81
     C           *IN81     IFEQ *OFF
     C           ZBSKJY    ANDEQ*BLANK
      *
     C*          KEYF21    SETLLMBDPL01
     C*          *IN82     DOUEQ*ON
     C*          KEYF21    READEMBDPL01                  82
     C*          *IN82     IFEQ *OFF
     C*          F3SKJY    ANDEQ*BLANK
     C*          *DAY      IFLT 10
     C*                    ADD  F3TNSU    QTY,1
     C*                    ADD  F3ANSU    QTY,2
     C*                    ADD  F3BNSU    QTY,3
     C*                    ADD  F3CNSU    QTY,4
     C*                    ADD  F3DNSU    QTY,5
     C*                    ELSE
     C*                    ADD  F3TNSU    QTY,2
     C*                    ADD  F3ANSU    QTY,3
     C*                    ADD  F3BNSU    QTY,4
     C*                    ADD  F3CNSU    QTY,4
     C                     Z-ADD0         QTY
     C           1         DO   5         X
     C                     Z-ADDDAT,X     K@YM
     C                     EXSR #NEW
     C           QTY,X     MULT ZBSOZI    WKJIT  152
     C           WKJIT     DIV  1000      WGOSO1  80H
     C                     ADD  WGOSO1    ACT,X
     C                     ENDDO
     C**                   ENDIF
     C*                    ENDIF
     C*                    ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #NEW      BEGSR
      *------------------------------------------------------
     C           K#18      SETLLAB#PL18
     C           *IN83     DOUEQ*ON
     C           K#18      READEAB#PL18                  83
     C           *IN83     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOMM    IFEQ *MONTH
     C           BANODD    ANDGE*DAY
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  BASRYO    QTY,X
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *------------------------------------------------------
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #SET11
     C                     OTHER
     C                     MOVE '01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
