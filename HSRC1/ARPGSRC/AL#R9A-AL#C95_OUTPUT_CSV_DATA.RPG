     H            Y.
     F** AL#R9A **************************************
     F* AL#C95 OUTPUT CSV DATA                       *
     F*     M.OKUMURA     2016.08.04                 *
     F************************************************
     FAL#WP96 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAL#PP81 IF  E           K        DISK
     FAL#WP9A O   E                    DISK
      *
      * PROGRAM START *
     C                     SETOF                         25
     C                     DO   *HIVAL
     C                     READ AL#WP961                 25
     C   25                LEAVE
      *
     C           W1TYPE    IFNE '5'
     C                     ITER
     C                     ENDIF
      *
      * A1SMEI *
     C                     SETOF                     35
     C           W1NONY    CHAINFGBPL011             35
      *
     C           *IN35     IFEQ '0'
     C                     MOVELB2SMEI    W1SMEI 15
     C                     ELSE
     C                     MOVEL*BLANK    W1SMEI
     C                     ENDIF
      *
      * A1EGBC *
     C           KEY81     KLIST
     C                     KFLD           W1SHN1
     C                     KFLD           W1SHN2
      *
     C                     MOVEL*BLANK    W1EGBC  1
     C                     SETOF                     45
     C           KEY81     CHAINAL#PP811             45
      *
     C           *IN45     IFEQ '0'
     C                     MOVEL'1'       W1EGBC
     C                     ENDIF
      *
     C                     EXSR #OUT
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *****************************************************************
     C           #OUT      BEGSR
      *
     C                     CLEARAL#WP9A1
     C                     Z-ADDW1KADT    A1KADT
     C                     Z-ADDW1KATI    A1KATI
     C                     MOVELW1SHID    A1SHID
     C                     MOVELW1SHIT    A1SHIT
     C                     MOVELW1SURT    A1SURT
     C                     MOVELW1TRKB    A1TRKB
     C                     MOVELW1IAFB    A1IAFB
     C                     Z-ADDW1TOKU    A1TOKU
     C                     Z-ADDW1NONY    A1NONY
     C                     MOVELW1NKOJ    A1NKOJ
     C                     MOVELW1NUKE    A1NUKE
     C                     MOVELW1SMEI    A1SMEI
     C                     MOVELW1MHN     A1MHN
     C                     Z-ADDW1EXTR    A1EXTR
     C                     MOVELW1IAFP    A1IAFP
     C                     MOVELW1PPUL    A1PPUL
     C                     MOVELW1EGBC    A1EGBC
     C                     MOVELW1TKR1    A1TKR1
     C                     MOVELW1TKR2    A1TKR2
     C                     MOVELW1TKR3    A1TKR3
     C                     MOVELW1TKR4    A1TKR4
     C                     WRITEAL#WP9A1
      *
     C           EOUT      ENDSR
