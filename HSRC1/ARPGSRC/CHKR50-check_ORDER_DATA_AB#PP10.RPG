     C                     DO   *HIVAL
     C           K#NONY    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C           BAURYY    ORNE 0
     C                     ITER
     C                     ENDIF
      * CHECK PART# VS DOCK
     C                     Z-ADD1         IY      20
     C                     SELEC
     C           BANUKE    WHEQ 'W6'
     C           MHIN      LOKUPW6,IY                    98
     C           *IN98     IFEQ *OFF
     C                     MOVELERR,4     MSG1
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C           BANUKE    WHEQ 'W8'
     C           MHIN      LOKUPW8,IY                    98
     C           *IN98     IFEQ *OFF
     C                     MOVELERR,5     MSG1
     C                     EXSR #PRINT
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      * PRINT PERIOD..
