     C                     PARM           $DATE   8
     C                     PARM           $DAY    1
     C                     PARM           $WEEK#  1
     C                     PARM           $RTN    1
      *
     C           $DAY      IFEQ '1'                        MON
     C           $DAY      OREQ '2'                        TUE
     C           $DAY      OREQ '3'                        WED
     C           $DAY      OREQ '5'                        FRI
