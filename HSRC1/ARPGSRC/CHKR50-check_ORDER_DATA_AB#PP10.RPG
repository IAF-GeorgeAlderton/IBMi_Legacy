     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** INCORRECT ORDER D'
     O                                   60 'ATA **              '
     O                                   80 '                    '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   31 'SHP_DATE'
     O                                   37 'BIN'
     O                                   47 'USER_PART'
     O                                   62 'ORDER#'
     O                                   80 'QTY'
     O                                   98 '*** ERROR MSG'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         BATOKU  +001
     O                         BANONY  +001
     O                         BANKOJ  +001
     O                         BANUKE  +001
     O                         BANOHZY +001
     O                         BANOBN  +002
     O                         BAMHN1  +001
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         BAODRN  +001
     O                         BASRYOJ +001
     O                         BAEDIK  +001
     O                         MSG1    +002
     O        E 1              @DTL2
     O                                    1 '.'
