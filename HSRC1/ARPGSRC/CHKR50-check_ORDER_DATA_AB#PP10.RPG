     H            Y.
     F***CHKR50*****************************************************************
     F*  PROGRAM    : CHECK ORDER DATA                                         *
     F*             : RUN IN FCKC00 (10:10AM BY JOBSCDE)                       *
     F*  WRITTEN    : 2019.05.28                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL1L IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    TBL     1   7  3
     E                    ERR     1   7 40
     E                    W6      1  10 20
     E                    W8      1  15 20
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100K#NOYY
     I                                       11  120K#NOMM
     I                                       13  140K#NODD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  20 MHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
      * CHECK DELIV#=0000
     C                     Z-ADD0         K#NONY
     C                     EXSR #CHK0
      * DENSO MI
     C*****************    Z-ADD3032      K#NONY
     C*****************    EXSR #CHK1                      MON:1
      * DENSO GNC
     C*****************    Z-ADD3056      K#NONY
     C*****************    EXSR #CHK1                      MON:1
      * DENSO MX T1
     C*****************    Z-ADD3062      K#NONY
     C*****************    EXSR #CHK4                      THU:4
      * DENSO MX S1
     C*****************    Z-ADD3070      K#NONY
     C*****************    EXSR #CHK13                     MON:1, WED:3
      * DENSO AR
     C*****************    Z-ADD3076      K#NONY
     C*****************    EXSR #CHK5                      FRI:5
      * DENSO CANADA
     C*****************    Z-ADD3086      K#NONY
     C*****************    EXSR #CHK1                      MON:1
      * DENSO TN
     C*****************    Z-ADD3092      K#NONY
     C*****************    EXSR #CHK1                      MON:1
      * AWTX
     C*****************    Z-ADD0493      K#NONY
     C*****************    EXSR #CHK6                      W6 OR W8
      * BOCAR
     C*****************    Z-ADD2320      K#NONY
     C*****************    EXSR #CHK7
      * FORD-EMDO (FEDEX)
     C                     Z-ADD5126      K#NONY
     C                     EXSR #CHK8
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * CHECK SHIP DATE (MON)                              *
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     Z-ADD0         CNT
      *
     C           K#PL1L    SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#NONY    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C           BAURYY    ORNE 0
     C                     ITER
     C                     ENDIF
      * CHECK SUPPLIER
     C           BAPGID    IFEQ *BLANK
     C                     MOVELERR,2     MSG1
     C                     EXSR #PRINT
     C                     ENDIF
      * CHECK DAY
     C                     MOVELBANOHZ    $DATE
     C                     CALL 'UTLR02'
     C                     PARM           $DATE   8
     C                     PARM           $DAY    1
     C                     PARM           $WEEK#  1
     C                     PARM           $RTN    1
      *
     C**         $DAY      IFEQ '1'                        MON
     C           $DAY      IFEQ '2'                        TUE
     C           $DAY      OREQ '3'                        WED
     C           $DAY      OREQ '4'                        THU
     C           $DAY      OREQ '5'                        FRI
     C           $DAY      OREQ '6'                        SAT
     C           $DAY      OREQ '7'                        SUN
     C                     MOVEL$DAY      IX
     C                     MOVELERR,1     MSG1
     C                     MOVELTBL,IX    MSG1
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      * PRINT PERIOD..
     C           CNT       IFNE 0
     C                     EXCPT@DTL2
     C                     ADD  1         LIN#
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * CHECK SHIP DATE (TUE)                              *
