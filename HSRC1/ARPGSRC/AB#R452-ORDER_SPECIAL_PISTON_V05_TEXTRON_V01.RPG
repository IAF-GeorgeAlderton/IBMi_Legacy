TCHK6C*** FOR PISTON PA1
     C                     Z-ADD*ZERO     W@SHDT
     C                     Z-ADD*ZERO     W#SHDT
TCHK9C                     Z-ADD*ZERO     W@WEDT
TCHKAC                     Z-ADD*ZERO     W@TUET
TCHKAC                     Z-ADD*ZERO     W@MONT
TCHKAC                     MOVEL*BLANK    W8YOBI  1
      *
     C                     DO
      *
     C           K#AGD     KLIST
     C                     KFLD           W@DY    40
     C                     KFLD           W@DM    20
     C                     KFLD           W@DD    20
     C           K#AGD     CHAINAGDPL12              91    TODAY IS
     C   91                LEAVE
     C                     SELEC
     C           F8YOBI    WHEQ 1                          MONDAY
TCHKAC           F8YOBI    WHEQ 5                          FRIDAY
TCHKAC           F8YOBI    WHEQ 4                          THURSEDAY
     C           F8YOBI    WHEQ 2                          TUESEDAY
     C                     READPAGDPL12                  91SEARCH MONDAY
     C   91                LEAVE
     C           F8HIRU    IFEQ *BLANK                     NOT HOLIDAY
     C                     LEAVE
     C                     END
     C                     OTHER                           WED,THU,SAT,SUN
     C                     LEAVE
     C                     ENDSL
      *
TCHKAC                     MOVELF8YOBI    W8YOBI
      *
     C           K#AGD     SETLLAGDPL12                    TODAY IS
     C                     DO   *HIVAL
     C                     READPAGDPL12                  92
     C   92                LEAVE
TCHK9C           F8YOBI    IFEQ 7
TCHK9C                     Z-ADDF8KAYY    W@SHYY
TCHK9C                     Z-ADDF8KAMM    W@SHMM
TCHK9C                     Z-ADDF8KADD    W@SHDD
TCHK9C                     LEAVE
TCHK9C                     END
TCHK9C                     ENDDO
TCHK9C*
TCHKAC                     Z-ADD*ZERO     W@CNT2
TCHK9C           K#AGD     SETLLAGDPL12                    TODAY IS
TCHK9C                     DO   *HIVAL
TCHK9C                     READ AGDPL12                  92
TCHK9C   92                LEAVE
TCHKAC                     ADD  1         W@CNT2
TCHKAC           W@CNT2    IFGE 7                          1 WEEK LOOP
TCHKAC                     LEAVE
TCHKAC                     END
TCHKAC           F8YOBI    IFEQ 1
TCHKAC                     Z-ADDF8KAYY    W@MONY
TCHKAC                     Z-ADDF8KAMM    W@MONM
TCHKAC                     Z-ADDF8KADD    W@MOND
TCHKAC                     END
TCHKAC           F8YOBI    IFEQ 2
TCHKAC                     Z-ADDF8KAYY    W@TUEY
TCHKAC                     Z-ADDF8KAMM    W@TUEM
TCHKAC                     Z-ADDF8KADD    W@TUED
TCHKAC                     END
TCHK9C           F8YOBI    IFEQ 3
TCHK9C                     Z-ADDF8KAYY    W@WEDY
TCHK9C                     Z-ADDF8KAMM    W@WEDM
TCHK9C                     Z-ADDF8KADD    W@WEDD
TCHK9C                     END
TCHK9C           F8YOBI    IFEQ 6
TCHK9C                     Z-ADDF8KAYY    W#SHYY
TCHK9C                     Z-ADDF8KAMM    W#SHMM
TCHK9C                     Z-ADDF8KADD    W#SHDD
TCHKAC*TCHK9               LEAVE
TCHK9C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C*** FOR PISTON PA2
