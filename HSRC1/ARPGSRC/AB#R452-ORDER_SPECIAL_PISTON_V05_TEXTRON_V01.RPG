     C                     DO   *HIVAL
      *
     C                     READ AB#WP453                 90
     C   90                LEAVE
      *
JW3  C           ITOKU     IFEQ 3611                       SUBARU
 |   C           INOBN     ANDEQ12
 |   C                     MOVELI@DAT     O@DAT
 |   C                     EXCPTDT
 |   C                     ITER
JW3  C                     ENDIF
      *
     C           ITOKU     IFNE 7448
     C           ITOKU     ANDNE7449
     C           ITOKU     ANDNE7450
     C           ITOKU     ANDNE7451
JW1  C           ITOKU     ANDNE7452
     C           ITOKU     ANDNE5535
     C                     MOVELI@DAT     O@DAT 256
     C                     EXCPTDT
     C                     ITER
     C                     END
      *
     C           INONY     IFEQ 7449
TCHK3C           INOHZ     IFEQ W@SHTZ                     wednesday
     C           INOHZ     OREQ W#SHHZ                     friday
     C                     MOVELI@DAT     W@SAVE
TCHK3C                     Z-ADDW@SHHZ    WNOHZ            monday
     C           W@SHHF    IFNE *BLANK
     C                     Z-ADDW#SHHZ    WNOHZ            friday
     C                     ENDIF
     C                     MOVELW@SAVE    O@DAT 256
     C                     EXCPTDT
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
TCHK9C           INONY     IFEQ 7448
     C           INONY     OREQ 7450
     C           INONY     OREQ 7451
JW1  C           INONY     OREQ 7452
TCHK9C                     MOVELI@DAT     W@SAVE256
      *
JW2  C**JW4      INONY     IFEQ 7448
TCHKAC**         W8YOBI    IFEQ '4'
TCHKAC**         W8YOBI    OREQ '5'
TCHKAC**                   Z-ADDW@MONT    WNOHZ            monday
     C**                   ENDIF
     C**                   ENDIF
      *
TCHKAC**JW2                ELSE
TCHK9C**JW2                ITER
TCHKAC**JW2                END
      *
TCHK9C                     MOVELW@SAVE    O@DAT 256
TCHK9C                     EXCPTDT
TCHK9C                     ITER
TCHK9C                     END
TCHK8C*
     C           INONY     IFEQ 5535
     C           INOHZ     IFEQ T1SLDT
     C           INOHZ     OREQ T2SLDT
     C                     MOVELI@DAT     W@SAVE
     C                     Z-ADDT3SHDT    WNOHZ
