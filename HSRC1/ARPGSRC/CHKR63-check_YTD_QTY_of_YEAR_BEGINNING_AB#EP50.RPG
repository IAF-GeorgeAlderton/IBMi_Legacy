     H            Y.
     F** CHKR63  ***************************************************************
     F*  PROGRAM    : CHECK YTD QTY OF THE YEAR (FORD)                         *
     F*  WRITTEN    : 2020.10.28                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FABFDL02 IF  E           K        DISK
     FAB#EL50SIF  E           K        DISK
     FABFDP01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLABFDL02
     C                     DO   *HIVAL
     C                     READ ABFDL02                  98
     C   98                LEAVE
      * SELECT
     C           QAPLAN    IFEQ SVPLAN
     C                     ITER
     C                     ENDIF
      * SELECT
     C           QASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * PRINT
     C                     EXSR #GET
     C           RCNT      IFNE 0
     C           X5YSQY    ANDNE0
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     MOVELQAPLAN    SVPLAN  5
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * GET DELIVERY CODE
     C           K#DP01    KLIST
     C                     KFLD           KAPLAN  5
     C                     KFLD           KADOCK  4
     C                     MOVELQAPLAN    KAPLAN
     C                     MOVELX5DOCK    KADOCK
      *
     C           K#DP01    CHAINABFDP01              99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDQANONY    XNONY   40
     C                     ELSE
     C                     Z-ADD0         XNONY
     C                     ENDIF
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  GET YTD QTY                                       *
      *----------------------------------------------------*
     C           #GET      BEGSR
      *
     C                     MOVE *BLANK    X5DOCK  4
     C                     Z-ADD0         X5LSDT  80
     C                     Z-ADD0         X5YSQY 100
     C                     Z-ADD0         RCNT    40
      * SET KEY
     C           K#EL50    KLIST
     C                     KFLD           K5STID  5
     C                     KFLD           K5SVDT  80
     C                     KFLD           K5SVTM  60
     C                     MOVELQAPLAN    K5STID
     C                     Z-ADD20200000  K5SVDT
     C                     Z-ADD0         K5SVTM
      *
     C           K#EL50    SETLLAB#EL50S
     C                     DO   *HIVAL
     C           QAPLAN    READEAB#EL50S                 98
     C   98                LEAVE
      *
     C                     ADD  1         RCNT
     C                     MOVELA5DOCK    X5DOCK
     C                     Z-ADDA5LSDT    X5LSDT
     C                     Z-ADDA5YSQY    X5YSQY
     C                     LEAVE
      *
     C                     ENDDO
      *
     C           X5DOCK    IFEQ *BLANK
     C                     MOVEL'00  '    X5DOCK
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     MOVE *BLANK    SVPLAN  5
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK FORD EDI862'
     O                                   60 ' **                 '
     O                                   80 '                    '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'PLANT'
     O                                   17 'DOCK'
     O                                   33 'LAST SHP DATE'
     O                                   51 'YTD CUM QTY'
     O                                   61 'DELIV#'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         QAPLAN  +001
     O                         X5DOCK  +002
     O                         X5LSDT  +006 '    /  /  '
     O                         X5YSQY1 +005
     O                         XNONY   +005
