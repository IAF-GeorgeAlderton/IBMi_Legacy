     H            Y.                                                      DAD000
     F** ABAR75 ****************************************
     F* ﾏｰﾅﾞｰ内示数大幅増減チェック用ファイル作成    *
     F* MSK.KUNIEDA                                    *
     F* 1998.02.17                                     *
     F**************************************************
     FABAWP32 IP  F      32            DISK
     FFCEPL01 IF  E           K        DISK
     FABBPL01 IF  E           K        DISK
     FABAWP75 O   F     128            DISK
   #@E*
   #@E                    ##@        15  1
     IABAWP32 AA  10
     I                                        1   40TOKU
     I                                        5   80NONY
     I                                        9   9 GKOJ
     I                                       10  13 GUKE
     I                                       14  18 MHN1
     I                                       19  23 MHN2
     I                                       24  28 MHN3
     I                                       29  32 SEBN
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1   80YYMD
     I                                        1   40HY
     I                                        5   60HM
     I                                        7   80HD
      *--- KEY LIST ---*
     C           KEYAB1    KLIST
     C                     KFLD           #KTOKU  40
     C                     KFLD           #KNONY  40
     C                     KFLD           #KGKOJ  1
     C                     KFLD           #KGUKE  4
     C                     KFLD           #KSEBN  4
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  5
    UC                     KFLD           #KMHN4  5
      *
     C           KEYA2     KLIST
     C                     KFLD           #KBHB1  5
     C                     KFLD           #KBHB2  5
     C                     KFLD           #KBHB3  2
      *
      *---初期処理---*
     C           FIRST     IFEQ *BLANK
     C           *ENTRY    PLIST
     C                     PARM           PST     3
     C                     PARM           PED     3
     C                     MOVE PST       WKST    30
     C                     MOVE PED       WKED    30
     C                     MOVE '*'       FIRST   1
     C                     MOVE *YEAR     HY      40
     C                     MOVE UMONTH    HM      20
     C                     MOVE UDAY      HD      20
     C                     END
      *---内示データ累積ファイルを読む---*
     C                     MOVE TOKU      #KTOKU
     C                     MOVE NONY      #KNONY
     C                     MOVE GKOJ      #KGKOJ
     C                     MOVE GUKE      #KGUKE
     C                     MOVE MHN1      #KMHN1
     C                     MOVE MHN2      #KMHN2
     C                     MOVE MHN3      #KMHN3
     C                     MOVE SEBN      #KSEBN
     C                     SETOF                     20
     C                     Z-ADD0         WKSA1   70
     C                     Z-ADD0         WKSA2   70
     C                     Z-ADD0         WKSA3   70
      *
    UC                     MOVE *BLANK    #KMHN4
      *
     C           KEYAB1    CHAINABBPL011             20
     C           *IN20     IFEQ '0'
      *-- 新内示と旧内示の差分を求める--*
     C           Q5NNNM    SUB  Q5NNOM    WKSA1
     C           Q51NNM    SUB  Q51NOM    WKSA2
     C           Q52NNM    SUB  Q52NOM    WKSA3
      *-- 部品情報マスター検索---*
     C                     MOVE Q5SHN1    #KBHB1
     C                     MOVE Q5SHN2    #KBHB2
     C                     MOVE Q5SHN3    #KBHB3
     C                     SETOF                       21
     C           KEYA2     CHAINFCEPL011             21
   #@C*
     C           *IN21     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
   #@C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C           *IN21     IFEQ '0'
     C           A2TEHI    ANDEQ'G'
      *--収容数の確定---*
     C                     Z-ADD0         WKSYSU  50
   #@C*
   #@C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    WKSYSU
     C                     ELSE
     C                     Z-ADDA2SSYS    WKSYSU
     C                     END
      *--箱数を求める---*
     C                     Z-ADD0         WKHAK1  50
     C                     Z-ADD0         AMARI1  50
     C                     Z-ADD0         WKHAK2  50
     C                     Z-ADD0         AMARI2  50
     C                     Z-ADD0         WKHAK3  50
     C                     Z-ADD0         AMARI3  50
     C           WKSA1     IFNE *ZERO
     C           WKSA1     DIV  WKSYSU    WKHAK1
     C                     MVR            AMARI1
     C                     END
     C           WKSA2     IFNE *ZERO
     C           WKSA2     DIV  WKSYSU    WKHAK2
     C                     MVR            AMARI2
     C                     END
     C           WKSA3     IFNE *ZERO
     C           WKSA3     DIV  WKSYSU    WKHAK3
     C                     MVR            AMARI3
     C                     END
      *--端数調整---*
     C           AMARI1    IFNE *ZERO
     C                     ADD  1         WKHAK1
     C                     END
     C           AMARI2    IFNE *ZERO
     C                     ADD  1         WKHAK2
     C                     END
     C           AMARI3    IFNE *ZERO
     C                     ADD  1         WKHAK3
     C                     END
     C                     Z-ADD0         WKRIT1  40
     C                     Z-ADD0         WKRIT2  40
     C                     Z-ADD0         WKRIT3  40
     C                     Z-ADD0         WRIT1   72
     C                     Z-ADD0         WRIT2   72
     C                     Z-ADD0         WRIT3   72
     C                     MOVE *BLANK    WKSW    1
      *---変動率を求める---*
      *Ｎ月
     C           Q5NNNM    IFEQ *ZERO
     C           Q5NNOM    ANDEQ*ZERO
     C                     Z-ADD0         WKRIT1
     C                     ELSE
     C           Q5NNNM    IFNE *ZERO
     C           Q5NNOM    ANDNE*ZERO
     C           Q5NNNM    DIV  Q5NNOM    WRIT1
     C                     MOVE '1'       WKSW
     C                     EXSR $SB900
     C                     ELSE
     C           Q5NNNM    IFEQ *ZERO
     C           Q5NNOM    ANDNE*ZERO
     C                     Z-ADD0         WKRIT1
     C                     END
     C           Q5NNNM    IFNE *ZERO
     C           Q5NNOM    ANDEQ*ZERO
     C                     Z-ADD9999      WKRIT1
     C                     END
     C                     END
     C                     END
      *Ｎ＋１月
     C           Q51NNM    IFEQ *ZERO
     C           Q51NOM    ANDEQ*ZERO
     C                     Z-ADD0         WKRIT2
     C                     ELSE
     C           Q51NNM    IFNE *ZERO
     C           Q51NOM    ANDNE*ZERO
     C           Q51NNM    DIV  Q51NOM    WRIT2
     C                     MOVE '2'       WKSW
     C                     EXSR $SB900
     C                     ELSE
     C           Q51NNM    IFEQ *ZERO
     C           Q51NOM    ANDNE*ZERO
     C                     Z-ADD0         WKRIT2
     C                     END
     C           Q51NNM    IFNE *ZERO
     C           Q51NOM    ANDEQ*ZERO
     C                     Z-ADD9999      WKRIT2
     C                     END
     C                     END
     C                     END
      *Ｎ＋２月
     C           Q52NNM    IFEQ *ZERO
     C           Q52NOM    ANDEQ*ZERO
     C                     Z-ADD0         WKRIT3
     C                     ELSE
     C           Q52NNM    IFNE *ZERO
     C           Q52NOM    ANDNE*ZERO
     C           Q52NNM    DIV  Q52NOM    WRIT3
     C                     MOVE '3'       WKSW
     C                     EXSR $SB900
     C                     ELSE
     C           Q52NNM    IFEQ *ZERO
     C           Q52NOM    ANDNE*ZERO
     C                     Z-ADD0         WKRIT3
     C                     END
     C           Q52NNM    IFNE *ZERO
     C           Q52NOM    ANDEQ*ZERO
     C                     Z-ADD9999      WKRIT3
     C                     END
     C                     END
     C                     END
      *--内示数大幅増減チェック用ファイル作成
     C                     EXSR $SB910
      *
     C                     END
     C                     END
      *---------------------------------------------------*
      *      計算変動率調整           ($SB900)          *
      *---------------------------------------------------*
     CSR         $SB900    BEGSR
     C                     Z-ADD0         WWRIT1  60
     C                     Z-ADD0         WWRIT2  60
     C                     Z-ADD0         WWRIT3  60
      *-Ｎ月-*
     C           WKSW      IFEQ '1'
     C           WRIT1     MULT 100       WWRIT1    H
     C           WWRIT1    IFLT 1
     C                     Z-ADD1         WWRIT1
     C                     END
     C           WWRIT1    IFGE 10000
     C                     Z-ADD9999      WKRIT1
     C                     ELSE
     C                     Z-ADDWWRIT1    WKRIT1
     C                     END
     C                     END
      *-Ｎ＋１月-*
     C           WKSW      IFEQ '2'
     C           WRIT2     MULT 100       WWRIT2    H
     C           WWRIT2    IFLT 1
     C                     Z-ADD1         WWRIT2
     C                     END
     C           WWRIT2    IFGE 10000
     C                     Z-ADD9999      WKRIT2
     C                     ELSE
     C                     Z-ADDWWRIT2    WKRIT2
     C                     END
     C                     END
      *-Ｎ＋２月-*
     C           WKSW      IFEQ '3'
     C           WRIT3     MULT 100       WWRIT3    H
     C           WWRIT3    IFLT 1
     C                     Z-ADD1         WWRIT3
     C                     END
     C           WWRIT3    IFGE 10000
     C                     Z-ADD9999      WKRIT3
     C                     ELSE
     C                     Z-ADDWWRIT3    WKRIT3
     C                     END
     C                     END
     CSR                   ENDSR
      *---------------------------------------------------*
      *  ユーザー内示数大幅増減チェック用ファイル作成   *
      *---------------------------------------------------*
     CSR         $SB910    BEGSR
      *--箱数絶対値に変換
     C           WKHAK1    IFLT 0
     C                     MULT -1        WKHAK1
     C                     END
     C           WKHAK2    IFLT 0
     C                     MULT -1        WKHAK2
     C                     END
     C           WKHAK3    IFLT 0
     C                     MULT -1        WKHAK3
     C                     END
      *
     C                     Z-ADDQ5NNOM    WKNNOM  70
     C                     Z-ADDQ51NOM    WK1NOM  70
     C                     Z-ADDQ52NOM    WK2NOM  70
     C                     Z-ADDQ5NNNM    WKNNNM  70
     C                     Z-ADDQ51NNM    WK1NNM  70
     C                     Z-ADDQ52NNM    WK2NNM  70
      *
      *Ｎ月
     C           WKHAK1    IFGT 3
     C           WKRIT1    IFLT WKST
     C           WKRIT1    ORGT WKED
     C                     EXCPTFILE
     C                     GOTO $S910E
     C                     END
     C                     END
      *Ｎ＋１月
     C           WKHAK2    IFGT 3
     C           WKRIT2    IFLT WKST
     C           WKRIT2    ORGT WKED
     C                     EXCPTFILE
     C                     GOTO $S910E
     C                     END
     C                     END
      *Ｎ＋２月
     C           WKHAK3    IFGT 3
     C           WKRIT3    IFLT WKST
     C           WKRIT3    ORGT WKED
     C                     EXCPTFILE
     C                     GOTO $S910E
     C                     END
     C                     END
     C                     Z-ADD0         WKNNOM
     C                     Z-ADD0         WK1NOM
     C                     Z-ADD0         WK2NOM
     C                     Z-ADD0         WKNNNM
     C                     Z-ADD0         WK1NNM
     C                     Z-ADD0         WK2NNM
     CSR         $S910E    ENDSR
     OABAWP75 E                FILE
     O                         Q5TOKU     4
     O                         Q5NONY     8
     O                         Q5GKOJ     9
     O                         Q5GUKE    13
     O                         Q5SHN1    18
     O                         Q5SHN2    23
     O                         Q5SHN3    25
     O                         Q5MHN1    30
     O                         Q5MHN2    35
     O                         Q5MHN3    40
     O                         Q5SYUY    45
     O                         WKNNOM    52
     O                         WK1NOM    59
     O                         WK2NOM    66
     O                         WKNNNM    73
     O                         WK1NNM    80
     O                         WK2NNM    87
     O                         WKRIT1    92
     O                         WKRIT2    97
     O                         WKRIT3   102
     O                         YYMD     110
     O                         Q5NTYM   116
     O                         Q5SEBN   120
