TCHK1C           ','       LOKUPAY,X                     10
TCHK1C  N10                GOTO @END
      *
     C                     Z-ADDX         J
     C*
     C                     MOVEL*BLANK    A9X
     C                     MOVEL*ZERO     A9
     C                     Z-ADD*ZERO     K
     C                     Z-ADD*ZERO     L       30
     C                     DO   *HIVAL
     C                     ADD  1         J
TTHK1C           AY,J      IFEQ ' '
TTTT C           AY,J      OREQ ','
     C                     EXSR #QTY
     C                     ADD  1         L
     C                     MOVEAA9        W##9X   9
     C                     MOVELW##9X     W##9N   90
     C                     Z-ADDW##9N     QTY,L
     C                     MOVEL*BLANK    A9X
     C                     MOVEL*ZERO     A9
     C                     Z-ADD*ZERO     K
TCHK1C           L         IFGE 10
TCHK1C                     LEAVE
TCHK1C                     ENDIF
     C           AY,J      IFEQ ','
     C                     ITER
     C                     ENDIF
     C           AY,J      IFEQ ' '
TCHK1C                     LEAVE
TCHK1C*                    ITER
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         K
     C                     MOVELAY,J      A9X,K
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     I       30
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           ADT,I     IFEQ *ZERO
     C           QTY,I     ANDEQ*ZERO
     C                     LEAVE
     C                     ENDIF
     C                     Z-ADDQTY,I     AWSRYO
     C                     Z-ADDADT,I     AWSTRD
      * get END-DATE
     C                     MOVE '0'       *IN44
     C           KEY3      SETLLAGDPL121
