     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C           KEY3      KLIST
     C                     KFLD           NAYY    40
     C                     KFLD           NAMM    20
     C                     KFLD           NADD    20
      * CONSTANT
     C**                   Z-ADD3201      AWTOKU
JW   C                     Z-ADD3315      AWTOKU
     C                     Z-ADD3201      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
      *
     C                     MOVEADAT1      AY,1
     C                     MOVEADAT2      AY,257
     C* ======
     C* HEADER
     C* ======
     C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
     C           'IAF'     SCAN DAT1      X              10
     C   10                GOTO @END
      *
     C                     Z-ADD1         X       30
     C           'FIRM'    SCAN DAT1      X              10
     C  N10      'Firm'    SCAN DAT1      X              10
     C   10                MOVE *ON       *IN99
     C   10                GOTO @END
      *
     C                     ENDIF
      *
      * * * * * * * * * * * * * * * * * * * * * * * * *
      *
     C           *IN98     IFEQ *OFF
      *
     C* ======
     C*  DATE
     C* ======
      *
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
TCHK1C                     ADD  1         X
TCHK1C           ','       LOKUPAY,X                     10
TCHK1C  N10                GOTO @END
     C                     Z-ADD*ZERO     K       30
     C                     Z-ADDX         J       30
      *
     C                     DO   *HIVAL
     C                     ADD  1         J
     C* GET MM
     C                     MOVEAAY,J      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVEAA2        MM
     C                     ELSE
     C                     MOVEL'0'       MM
     C                     MOVE A2,1      MM
     C                     ENDIF
     C* GET DD
     C           '/'       LOKUPAY,J                     10
     C  N10                LEAVE
     C                     ADD  1         J
     C                     MOVEAAY,J      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVEAA2        DD
     C                     ELSE
     C                     MOVEL'0'       DD
     C                     MOVE A2,1      DD
     C                     ENDIF
     C* GET YYYY
     C           '/'       LOKUPAY,J                     10
     C  N10                LEAVE
     C                     ADD  1         J
      *
     C           J         ADD  2         @X      30
      *
     C           AY,@X     IFEQ ','
     C           AY,@X     OREQ ' '
     C                     MOVEAAY,J      YYA2    2
     C                     MOVEL'20'      YY
     C                     MOVE YYA2      YY
     C                     ELSE
     C                     MOVEAAY,J      YYA4    4
     C                     MOVE YYA4      YY
     C                     ENDIF
      * YY
     C                     MOVELMM        MM##N   20
     C           MM##N     IFLT W@DM
     C           W@DY      ADD  1         YY##N   40
     C                     ELSE
     C                     Z-ADDW@DY      YY##N
     C                     ENDIF
     C                     MOVELYY##N     YY
      *
     C                     MOVELYMD8      YMD
     C                     ADD  1         K
     C                     Z-ADDYMD       ADT,K
      *
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C                     Z-ADDX         J
      *
     C                     ENDDO
      *
     C           K         IFGT *ZERO
     C                     MOVE *ON       *IN98
     C                     ENDIF
      *
     C                     GOTO @END
      *
     C                     ENDIF
     C*=======
      * DETAIL
     C*=======
     C                     MOVEL*OFF      *IN97
     C                     Z-ADD1         X
     C           'PP'      SCAN DAT1      X              10
     C  N10                MOVEL*ON       *IN97
     C           AY,1      IFEQ ','
     C                     MOVEL*ON       *IN97
     C                     ENDIF
      *
     C   97                GOTO @END
      *
      * -------------
      *   PART NUMBER
      * -------------
      *
     C                     MOVEL*BLANK    MHN
     C                     Z-ADD*ZERO     J
     C                     Z-ADD*ZERO     K
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C                     LEAVE
     C                     ENDIF
     C           AY,J      IFEQ '-'
     C                     ITER
     C                     ENDIF
     C                     ADD  1         K
     C                     MOVELAY,J      MHN,K
     C                     ENDDO
      *
     C                     MOVEAMHN       #PART
