     C           *ENTRY    PLIST
     C                     PARM           US     10
      *--------*
      *初期化*
      *--------*
     C                     Z-ADD*DATE     KDATE
     C                     MOVE '-'       @HN1
     C                     MOVE '-'       @HN2
     C                     MOVE '-'       @HN3
     C                     MOVE '-'       @HN4
      *--------*
      *画面１*
      *--------*
     C                     EXSR #INZ
     C           @STP1     TAG
     C                     EXFMTAFAPW831
     C                     SETOF                     0199
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           @CODE     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     0199
     C                     GOTO @STP1
     C                     END
      *
     C           @CODE     IFEQ '1'
     C           @CODE     OREQ '2'
     C                     ELSE
     C                     MOVELER,2      @ERR
     C                     SETON                     0199
     C                     GOTO @STP1
     C                     END
     C           @CODE     IFEQ '1'
     C                     GOTO @STP20
     C                     END
     C           @CODE     IFEQ '2'
     C                     GOTO @STP40
     C                     END
      *--------*
      *画面２*
      *--------*
     C           @STP20    TAG
     C                     EXSR #INZ
     C           @STP2     TAG
     C                     EXFMTAFAPW832
     C                     SETOF                     010203
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           @KUBN     IFEQ *BLANK
     C                     MOVELER,3      @ERR
     C                     SETON                     0199
     C                     GOTO @STP2
     C                     END
      *
     C           @KUBN     IFEQ '0'
     C           @KUBN     OREQ '1'
     C           @KUBN     OREQ '2'
     C                     ELSE
     C                     MOVELER,4      @ERR
     C                     SETON                     0199
     C                     GOTO @STP2
     C                     END
      *
     C           @SUPP     IFEQ *BLANK
     C                     MOVELER,5      @ERR
     C                     SETON                     0299
     C                     GOTO @STP2
     C                     END
      *
     C                     MOVE @SUPP     KSUPP   40
     C                     SETOF                     30
     C           KSUPP     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0299
     C                     MOVELER,6      @ERR
     C                     GOTO @STP2
     C                     END
     C                     MOVELB2SMEI    @SUPPN
     C                     MOVE @SUPP     @SUPPC
      *
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     MOVELER,7      @ERR
     C                     SETON                     0399
     C                     GOTO @STP2
     C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C                     KFLD           WZETI
     C                     KFLD           WTEHI
      *
     C                     MOVEL*BLANK    WZETI   4
     C                     MOVEL*BLANK    WTEHI   3
      *
     C                     MOVEL*BLANK    #KOSN   1
     C                     SETOF                     30
     C           KEY1      CHAINAFAPL911             30
     C           *IN30     IFEQ '0'
     C                     MOVEL'*'       #KOSN
     C           A9SKJY    IFEQ 'D'
     C           A9SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C           @KUBN     IFEQ '0'
     C           @KUBN     OREQ '1'
     C           *IN30     IFEQ '1'
     C                     MOVELER,8      @ERR
     C                     SETON                     010203
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
      *
     C           @KUBN     IFEQ '2'
     C           *IN30     IFEQ '0'
     C                     MOVELER,9      @ERR
     C                     SETON                     010203
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
      *--------*
      *画面３*
      *--------*
     C                     SETOF                     50
     C           @KUBN     IFEQ '0'
     C                     SETON                     50
     C                     END
     C           @KUBN     IFEQ '0'
     C           @KUBN     OREQ '1'
     C                     Z-ADDA9SYOS    @SYOS
     C                     Z-ADDA9HAKO    @HAKO
     C                     Z-ADDA9WEIT    @WEIT
     C                     END
      *
     C                     SETOF                     31
     C                     Z-ADD1         A       20
     C           @KUBN     LOKUPKBN,A                    31
     C           *IN31     IFEQ '1'
     C                     MOVE CMT,A     @KBNM
     C                     END
      *
     C           @STP3     TAG
     C                     EXFMTAFAPW833
     C                     SETOF                     010203
     C                     SETOF                     99
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO @STP20
     C                     END
      *
     C           @SYOS     IFEQ 0
     C                     MOVELER,10     @ERR
     C                     SETON                     0199
     C                     GOTO @STP3
     C                     END
      *
     C           @HAKO     IFEQ 0
     C                     MOVELER,11     @ERR
     C                     SETON                     0299
     C                     GOTO @STP3
     C                     END
      *
     C           @WEIT     IFEQ 0
     C                     MOVELER,12     @ERR
     C                     SETON                     0399
     C                     GOTO @STP3
     C                     END
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP3
     C                     END
      *--------*
      * DELETE *
      *--------*
     C           @KUBN     IFEQ '0'
     C                     MOVEL'D'       A9SKJY
     C                     Z-ADD*DATE     A9SKHZ
     C                     Z-ADD*DATE     A9KOHZ
     C                     TIME           A9KOTI
     C                     MOVELUS        A9KOME
     C                     MOVEL'AFAR83'  A9KOPG
     C                     END
      *------------*
      * CHANGE,ADD *
      *------------*
     C           @KUBN     IFEQ '1'
     C           @KUBN     OREQ '2'
     C                     MOVE *BLANK    A9SKJY
     C                     Z-ADD0         A9SKHZ
     C                     Z-ADD*DATE     A9KOHZ
     C                     TIME           A9KOTI
     C                     MOVELUS        A9KOME
     C                     MOVEL'AFAR83'  A9KOPG
     C                     MOVEL*BLANK    A9ZETI
     C                     MOVEL*BLANK    A9TEHI
     C                     MOVEL@HIN1     A9PAR1
     C                     MOVEL@HIN2     A9PAR2
     C                     MOVEL@HIN3     A9PAR3
     C                     Z-ADD@SYOS     A9SYOS
     C                     Z-ADD@HAKO     A9HAKO
     C                     MOVE @WEIT     A9WEIT
     C                     MOVEL'B'       A9ORCD
     C                     MOVEL@SUPP     A9SUPP
     C                     END
      *-------*
      * UPDAT *
      *-------*
     C           @KUBN     IFEQ '2'
     C                     EXSR #SB999
     C                     Z-ADD*DATE     A9DATE
     C                     Z-ADDWKRENO    A9RENO
     C                     END
     C           #KOSN     IFEQ '*'
     C                     UPDATAFAPL911
     C                     ELSE
     C                     WRITEAFAPL911
     C                     END
      *
     C                     GOTO @STP20
      *--------*
      *画面４*
      *--------*
     C           @STP40    TAG
     C                     EXSR #INZ
     C           @STP4     TAG
     C                     EXFMTAFAPW834
     C                     SETOF                     010299
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           @SUPP     IFEQ *BLANK
     C                     MOVELER,13     @ERR
     C                     SETON                     0199
     C                     GOTO @STP4
     C                     END
      *
     C                     MOVE @SUPP     KSUPP   40
     C                     SETOF                     30
     C           KSUPP     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,14     @ERR
     C                     GOTO @STP4
     C                     END
     C                     MOVELB2SMEI    @SUPPN
     C                     MOVE @SUPP     @SUPPC
      *
     C           KEY2      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C                     SETOF                     70
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     ELSE
     C                     SETOF                     30
     C                     SETON                     70
     C           KEY2      CHAINFCEPL011             30
     C           *IN30     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C           *IN30     IFEQ '1'
     C                     MOVELER,15     @ERR
     C                     SETON                     0299
     C                     GOTO @STP4
     C                     END
     C                     END
     C                     EXSR #APICS
      *----------------------------------------------------*
      *    RECORD NUMBER GET                             *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
     C                     SETOF                       30
     C           KYYMM     CHAINAFANP901             30
     C           *IN30     IFEQ '1'
     C                     MOVE KYYMM     AZYYMM
     C                     Z-ADD1         AZNO
     C                     Z-ADDAZNO      WKRENO  50
     C                     WRITEAFANP901
     C                     ELSE
     C                     ADD  1         AZNO
     C                     Z-ADDAZNO      WKRENO
     C                     UPDATAFANP901
     C                     END
     CSR         ESB999    ENDSR
      *----------------------------------------------------*
      *    INQUIRY OF THE READOUT DATA                   *
      *----------------------------------------------------*
     CSR         #APICS    BEGSR
      *
     C           @RETRN    TAG
     C           KEY3      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C                     MOVEL*BLANK    #NO
     C                     MOVEL*BLANK    #SH
     C                     MOVEL*BLANK    #ZE
     C                     MOVEL*BLANK    #TE
     C                     Z-ADD0         #MA
     C                     Z-ADD0         #SY
     C                     MOVEL*ALL'0'   #WE
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00'      *IN,09
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'00'      *IN,19
      *
     C                     Z-ADD0         Z       30
     C                     Z-ADD10        ZZ      30
     C                     SETOF                     30
     C  N70      @SUPP     SETLLAFAPL911
     C   70      KEY3      SETLLAFAPL911
     C                     DO   *HIVAL
     C  N70      @SUPP     READEAFAPL911                 30
     C   70      KEY3      READEAFAPL911                 30
     C           *IN30     IFEQ '0'
     C           A9SKJY    IFEQ 'D'
     C           A9SKHZ    ANDLE*DATE
     C                     ELSE
     C           A9ZETI    IFNE *BLANK
     C           A9TEHI    ANDNE*BLANK
     C                     ADD  1         Z
     C                     ADD  1         ZZ
     C                     MOVELA9PAR     #SH,Z
     C                     MOVELA9ZETI    #ZE,Z
     C                     MOVELA9TEHI    #TE,Z
     C                     Z-ADDA9HAKO    #MA,Z
     C                     Z-ADDA9SYOS    #SY,Z
     C                     MOVE A9WEIT    #WE,Z
     C                     MOVELA9PAR1    HPAR1   5
     C                     MOVELA9PAR2    HPAR2   5
     C                     MOVELA9PAR3    HPAR3   2
     C                     MOVELA9ZETI    HZETI   4
     C                     MOVELA9TEHI    HTEHI   3
     C           A9ERR     IFNE *BLANK
     C                     MOVEA'1'       *IN,ZZ
     C                     END
     C           Z         IFEQ 1
     C                     MOVELA9PAR1    LPAR1   5
     C                     MOVELA9PAR2    LPAR2   5
     C                     MOVELA9PAR3    LPAR3   2
     C                     MOVELA9ZETI    LZETI   4
     C                     MOVELA9TEHI    LTEHI   3
     C                     END
     C           Z         IFEQ 10
     C                     SETON                     30
     C                     END
     C                     END
     C                     END
     C                     END
     C  N30                ENDDO
      *--------*
      *画面５*
      *--------*
     C           @STP5     TAG
     C                     EXFMTAFAPW835
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     1099
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO @STP40
     C                     END
      *
     C           KEY4      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           WPAR1
     C                     KFLD           WPAR2
     C                     KFLD           WPAR3
     C                     KFLD           WZETI
     C                     KFLD           WTEHI
      *
     C           *IN90     IFEQ '1'
     C                     EXSR #ROLUP
     C           Z         IFEQ 0
     C                     MOVELER,16     @ERR
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C                     END
     C           *IN95     IFEQ '1'
     C                     EXSR #ROLDW
     C           Z         IFEQ 11
     C                     MOVELER,17     @ERR
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C           Z         IFNE 1
     C                     GOTO @RETRN
     C                     END
     C                     END
      *
     C                     Z-ADD0         K       20
     C           1         DO   10
     C                     ADD  1         K
     C           #NO,K     IFEQ *BLANK
     C           #NO,K     OREQ '0'
     C           #NO,K     OREQ '1'
     C           #NO,K     IFEQ '0'
     C           #NO,K     OREQ '1'
     C           #SH,K     IFEQ *BLANK
     C                     MOVELER,18     @ERR
     C                     MOVEA'1'       *IN,K
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C                     END
     C                     ELSE
     C                     MOVELER,19     @ERR
     C                     MOVEA'1'       *IN,K
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C                     ENDDO
      *
     C                     SETOF                     50
     C                     Z-ADD0         K       20
     C           1         DO   10
     C                     ADD  1         K
     C           #NO,K     IFEQ '0'
     C           #NO,K     OREQ '1'
     C                     MOVEL#SH,K     KPAR   14
     C                     MOVEL#ZE,K     KZETI   4
     C                     MOVEL#TE,K     KTEHI   3
     C           #NO,K     IFEQ '0'
     C                     SETON                     50
     C                     END
      *
     C           KEY5      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           KPAR1
     C                     KFLD           KPAR2
     C                     KFLD           KPAR3
     C                     KFLD           KZETI
     C                     KFLD           KTEHI
      *
     C                     SETOF                     30
     C           KEY5      CHAINAFAPL911             30
     C           *IN30     IFEQ '0'
     C           A9SKJY    IFEQ 'D'
     C           A9SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
      *
     C           *IN30     IFEQ '0'
     C                     MOVELA9PAR1    @HIN1
     C                     MOVELA9PAR2    @HIN2
     C                     MOVELA9PAR3    @HIN3
     C                     MOVELA9ZETI    @ZETI
     C                     MOVELA9TEHI    @TEHI
     C                     Z-ADDA9HAKO    @MAIS
     C                     Z-ADDA9SYOS    @SYOS
     C                     Z-ADDA9WEIT    @WEIT
     C                     MOVELA9ERR1    @ERR1
     C                     MOVELA9ERR2    @ERR2
     C                     MOVELA9ERR3    @ERR3
     C                     MOVELA9ERR4    @ERR4
     C                     MOVELA9ERR5    @ERR5
     C                     MOVELA9ERR6    @ERR6
     C                     GOTO @STP6
     C                     ELSE
     C                     MOVELER,20     @ERR
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
      *
     C                     END
     C                     ENDDO
     C                     GOTO @STP5
      *--------*
      *画面６*
      *--------*
     C           @STP6     TAG
     C                     EXFMTAFAPW836
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     99
      *
     C           *INKC     IFEQ '1'
     C                     GOTO @RETRN
     C                     END
     C           *IN50     IFEQ '0'
     C           @MAIS     IFEQ 0
     C                     MOVELER,21     @ERR
     C                     SETON                     0199
     C                     GOTO @STP6
     C                     END
      *
     C           @SYOS     IFEQ 0
     C                     MOVELER,22     @ERR
     C                     SETON                     0299
     C                     GOTO @STP6
     C                     END
      *
     C           @WEIT     IFEQ 0
     C                     MOVELER,23     @ERR
     C                     SETON                     0399
     C                     GOTO @STP6
     C                     END
      *
     C           @ERR1     IFEQ ' '
     C           @ERR1     OREQ '*'
     C                     ELSE
     C                     MOVELER,24     @ERR
     C                     SETON                     0499
     C                     GOTO @STP6
     C                     END
      *
     C           @ERR2     IFEQ ' '
     C           @ERR2     OREQ '*'
     C                     ELSE
     C                     MOVELER,24     @ERR
     C                     SETON                     0599
     C                     GOTO @STP6
     C                     END
      *
     C           @ERR3     IFEQ ' '
     C           @ERR3     OREQ '*'
     C                     ELSE
     C                     MOVELER,24     @ERR
     C                     SETON                     0699
     C                     GOTO @STP6
     C                     END
      *
     C           @ERR4     IFEQ ' '
     C           @ERR4     OREQ '*'
     C                     ELSE
     C                     MOVELER,24     @ERR
     C                     SETON                     0799
