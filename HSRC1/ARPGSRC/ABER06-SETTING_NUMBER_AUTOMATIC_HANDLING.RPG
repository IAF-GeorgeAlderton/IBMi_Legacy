     C                     GOTO STP6
     C                     END
      *
     C                     MOVE *BLANK    ASURI
     C                     Z-ADD0         WMAIS
     C*------------------------------------------*
     C*  .. ABCR06                               *
     C*  ..構成品トンネルかんばん枚数　計算..  *
     C*------------------------------------------*
     C                     CALL 'ABCR06'
     C                     PARM           ASURI
     C                     PARM           WRURO
     C                     PARM           E2SYOS
     C                     PARM           E2KEIS
     C                     PARM           E2LTIM
     C                     PARM           E2BARA
     C                     PARM           E2CBKO
     C                     PARM           E2LOTO
     C                     PARM           E2MAXH
     C                     PARM           WMAIS
      *
     C                     MOVE E2KCD1    $KCD1
     C                     MOVE E2AKRO    $TKRO
     C                     MOVE E2SHIN    $SHIN
     C                     Z-ADDE2BARA    $NLOT
     C                     Z-ADDWMAIS     $NMAS
     C                     Z-ADDE2KMAX    $OMAS
     C                     Z-ADDE2SYOS    $SYOS
     C                     MOVE *BLANK    $KTEI
     C                     Z-ADD0         $KBMN
     C                     Z-ADDE2KOCD    $BMON
     C                     Z-ADDE2UKOJ    $UKOJ
      *
     C                     Z-ADD0         $KSTS
     C                     Z-ADD0         $KHTS
     C                     Z-ADD0         $ZSTS
     C                     Z-ADD0         $ZHTS
     C                     Z-ADD0         $$N1SU
     C                     Z-ADD0         $N1HS
     C                     Z-ADD0         $$N2SU
     C                     Z-ADD0         $N2HS
     C                     Z-ADD0         $$ZGSU
     C                     Z-ADD0         $ZGHS
     C                     Z-ADDA@TENS    $TENS
      *
     C                     Z-ADDA@GEKN    $$KSTS
     C           WRURO     MULT 20        $KSTS     H
     C           E2SYOS    IFNE 0
     C           WRURO     DIV  E2SYOS    $KHTS     H
     C                     END
      *
     C           E2KTSU    MULT 20        $ZSTS     H
     C           E2SYOS    IFNE 0
     C           E2KTSU    DIV  E2SYOS    $ZHTS     H
     C                     END
      *
     C                     Z-ADDA@N1NM    $$N1SU
     C           $$N1SU    DIV  WCD3      WKTE      H
     C           WKTE      MULT 20        $N1SU
     C           E2SYOS    IFNE 0
     C           WKTE      DIV  E2SYOS    $N1HS     H
     C                     END
      *
     C                     Z-ADDA@N2NM    $$N2SU
     C           $$N2SU    DIV  WCD4      WKTE      H
     C           WKTE      MULT 20        $N2SU
     C           E2SYOS    IFNE 0
     C           WKTE      DIV  E2SYOS    $N2HS     H
