      *
     C                     Z-ADDA@ZGSU    $$ZGSU
     C           $$ZGSU    DIV  WCD2      WKTE      H
     C           WKTE      MULT 20        $ZGSU
     C           E2SYOS    IFNE 0
     C           WKTE      DIV  E2SYOS    $ZGHS     H
