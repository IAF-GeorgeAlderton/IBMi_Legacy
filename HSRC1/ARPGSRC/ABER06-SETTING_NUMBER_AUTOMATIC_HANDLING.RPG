     H            Y.
     F** ABER06 **************************
     F* .. SETTING NUMBER AUTOMATIC HANDLING *
     F* .. COMPONENTS KANBAN INCREASE AND DECREASE HANDLING *
     F* I-HASADA             92.10.03    *
     F************************** ABER06 **
     FABEWP05 IP  E           K        DISK
     FAKHPL05 IF  E           K        DISK
     FAKBPL01 UF  E           K        DISK
     FAKGPL01 UF  E           K        DISK
     FAKIPL01 UF  E           K        DISK
     FABEWP06 O   F     200            DISK                      A
      *
     C           KEY1      KLIST
     C                     KFLD           A@KHN1
     C                     KFLD           A@KHN2
     C                     KFLD           A@KHN3
     C                     KFLD           A@KBMN
     C                     KFLD           A@UKER
      *
     C           KEY2      KLIST
     C                     KFLD           M5NTK1
     C                     KFLD           M5NTK2
     C                     KFLD           M5NTK3
     C                     KFLD           M5NTK4
     C                     KFLD           M5KBMJ
     C                     KFLD           M5UKRJ
      *
     C           *ENTRY    PLIST
     C                     PARM           PKBN    1
     C                     PARM           PCD     3
     C                     PARM           PCD1    3
     C                     PARM           PCD2    3
     C                     PARM           PCD3    3
     C                     PARM           PCD4    3
     C                     PARM           PLIST   1
     C                     PARM           PKANB   1
     C                     MOVE PCD       WCD     31
     C                     MOVE PCD1      WCD1    31
     C                     MOVE PCD2      WCD2    31
     C                     MOVE PCD3      WCD3    31
     C                     MOVE PCD4      WCD4    31
      *
     C           PKBN      IFEQ 'B'
     C           PKBN      OREQ 'C'
     C           PKBN      OREQ 'D'
     C                     SETON                     99
     C                     END
      *
     C           A@GEKN    DIV  WCD       WRURO   90
      *
     C*------------------------------------------*
     C*  ..構成品番工程　所番地登録マスター..  *
     C*------------------------------------------*
     C           KEY1      SETLLAKHPL051
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAKHPL051                 10
     C           *IN10     IFEQ '0'
     C           M5SKJY    IFEQ 'D'
     C           M5SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C*--------------------------------*
     C*  .. AKBPL01                    *
     C*  ..構成品かんばんマスター..  *
     C*--------------------------------*
     C           PKANB     IFEQ '3'
     C           KEY2      SETLLAKBPL011
      *
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      READEAKBPL011                 11
     C           *IN11     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           L1STHZ    IFLE *DATE
     C                     GOTO STP1
     C                     END
      *
     C           L1DTKO    IFEQ '2'
     C           L1DTKO    OREQ 'D'
     C                     GOTO STP2
     C                     END
     C           L1SYOS    IFEQ 0
     C                     GOTO STP2
     C                     END
     C           L1KTSU    IFEQ WRURO
     C                     GOTO STP2
     C                     END
      *
     C           L1KTSU    DIV  L1SYOS    WMO    102H
     C           WRURO     DIV  L1SYOS    WMN    102H
     C                     Z-ADD0         WMON1   93
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON    51
      *
     C                     MOVE 'Z'       $ZOGN   1
     C           WMN       IFLT WMO
     C                     MOVE 'G'       $ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           $ZOGN     ANDEQ'G'
     C                     GOTO STP2
     C                     END
      *
     C*--------------------------------------------*
     C*  ..増減比率　＋－２０％未満処理しない..  *
     C*--------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO STP2
     C                     END
      *
     C                     MOVE *BLANK    ASURI   2
     C                     Z-ADD0         WMAIS   40
     C*----------------------------------*
     C*  .. ABCR16                       *
     C*  ..構成品かんばん枚数　計算..  *
     C*----------------------------------*
     C                     CALL 'ABCR16'
     C                     PARM           ASURI
     C                     PARM           WMAIS
     C                     PARM           WRURO
     C                     PARM           L1SYOS
     C                     PARM           L1LTIM
     C                     PARM           L1ROTO
     C                     PARM           L1KISU
     C                     PARM           L1UZAR
     C                     PARM           L1HITO
      *
     C                     MOVE L1KCD1    $KCD1   1
     C                     MOVE L1TKRO    $TKRO   6
     C                     MOVE L1SHIN    $SHIN  12
     C                     Z-ADDL1ROTO    $NLOT   30
     C                     Z-ADDWMAIS     $NMAS   30
     C                     Z-ADDL1KMAX    $OMAS   30
     C                     Z-ADDL1SYOS    $SYOS   50
     C                     MOVE L1KTEI    $KTEI   3
     C                     Z-ADDL1BMON    $KBMN   40
     C                     Z-ADDL1BMON    $BMON   40
     C                     Z-ADDL1UKOJ    $UKOJ   40
      *
     C                     Z-ADD0         $KSTS   90
     C                     Z-ADD0         $KHTS   62
     C                     Z-ADD0         $ZSTS   90
     C                     Z-ADD0         $ZHTS   62
     C                     Z-ADD0         $$N1SU  90
     C                     Z-ADD0         $N1HS   62
     C                     Z-ADD0         $$N2SU  90
     C                     Z-ADD0         $N2HS   62
     C                     Z-ADD0         $$ZGSU  90
     C                     Z-ADD0         $ZGHS   62
     C                     Z-ADDA@TENS    $TENS   30
      *
     C                     Z-ADDA@GEKN    $$KSTS  90
     C           WRURO     MULT 20        $KSTS     H
     C           L1SYOS    IFNE 0
     C           WRURO     DIV  L1SYOS    $KHTS     H
     C                     END
      *
     C           L1KTSU    MULT 20        $ZSTS     H
     C           L1SYOS    IFNE 0
     C           L1KTSU    DIV  L1SYOS    $ZHTS     H
     C                     END
      *
     C                     Z-ADDA@N1NM    $$N1SU
     C           $$N1SU    DIV  WCD3      WKTE    90H
     C           WKTE      MULT 20        $N1SU   90
     C           L1SYOS    IFNE 0
     C           WKTE      DIV  L1SYOS    $N1HS     H
     C                     END
      *
     C                     Z-ADDA@N2NM    $$N2SU
     C           $$N2SU    DIV  WCD4      WKTE      H
     C           WKTE      MULT 20        $N2SU   90
     C           L1SYOS    IFNE 0
     C           WKTE      DIV  L1SYOS    $N2HS     H
     C                     END
      *
     C                     Z-ADDA@ZGSU    $$ZGSU
     C           $$ZGSU    DIV  WCD2      WKTE      H
     C           WKTE      MULT 20        $ZGSU   90
     C           L1SYOS    IFNE 0
     C           WKTE      DIV  L1SYOS    $ZGHS     H
     C                     END
      *
     C           $UKOJ     IFNE 0111
     C                     Z-ADD0111      $UKOJ
     C                     END
      *
     C                     MOVE '*'       PLIST
     C                     EXCPTGDT
      *
     C           STP2      TAG
     C                     Z-ADDWRURO     L1KSSU
     C                     UPDATAKBPL011
      *
     C           STP1      TAG
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C*--------------------------------------*
     C*  .. AKGPL01                          *
     C*  ..構成品メッキかんばんマスター..  *
     C*--------------------------------------*
     C           PKANB     IFEQ 'P'
     C           KEY2      SETLLAKGPL011
      *
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      READEAKGPL011                 11
     C           *IN11     IFEQ '0'
     C           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           E1STHZ    IFLE *DATE
     C                     GOTO STP3
     C                     END
      *
     C           E1DTKO    IFEQ '2'
     C           E1DTKO    OREQ 'D'
     C                     GOTO STP4
     C                     END
     C           E1SSYS    IFEQ 0
     C                     GOTO STP4
     C                     END
     C           E1KTSU    IFEQ WRURO
     C                     GOTO STP4
     C                     END
      *
     C           E1KTSU    DIV  E1SSYS    WMO       H
     C           WRURO     DIV  E1SSYS    WMN       H
     C                     Z-ADD0         WMON1
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON
      *
     C                     MOVE 'Z'       $ZOGN
     C           WMN       IFLT WMO
     C                     MOVE 'G'       $ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           $ZOGN     ANDEQ'G'
     C                     GOTO STP4
     C                     END
      *
     C*--------------------------------------------*
     C*  ..増減比率　＋－２０％未満処理しない..  *
     C*--------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO STP4
     C                     END
      *
     C                     MOVE *BLANK    ASURI
     C                     Z-ADD0         WMAIS
     C*----------------------------------------*
     C*  .. ABCR05                             *
     C*  ..構成品メッキかんばん枚数　計算..  *
     C*----------------------------------------*
     C                     CALL 'ABCR05'
     C                     PARM           ASURI
     C                     PARM           WRURO
     C                     PARM           E1SSYS
     C                     PARM           E1KEIS
     C                     PARM           E1READ
     C                     PARM           E1BARA
     C                     PARM           E1CBKO
     C                     PARM           E1LOTO
     C                     PARM           E1MAXH
     C                     PARM           WMAIS
      *
     C                     MOVE E1KCD1    $KCD1
     C                     MOVE E1ATKR    $TKRO
     C                     MOVE E1SHIN    $SHIN
     C                     Z-ADDE1BARA    $NLOT
     C                     Z-ADDWMAIS     $NMAS
     C                     Z-ADDE1KMAX    $OMAS
     C                     Z-ADDE1SSYS    $SYOS
     C                     MOVE *BLANK    $KTEI
     C                     Z-ADD0         $KBMN
     C                     Z-ADDE1ATOB    $BMON
     C                     Z-ADDE1UKOJ    $UKOJ
      *
     C                     Z-ADD0         $KSTS
     C                     Z-ADD0         $KHTS
     C                     Z-ADD0         $ZSTS
     C                     Z-ADD0         $ZHTS
     C                     Z-ADD0         $$N1SU
     C                     Z-ADD0         $N1HS
     C                     Z-ADD0         $$N2SU
     C                     Z-ADD0         $N2HS
     C                     Z-ADD0         $$ZGSU
     C                     Z-ADD0         $ZGHS
     C                     Z-ADDA@TENS    $TENS
      *
     C                     Z-ADDA@GEKN    $$KSTS
     C           WRURO     MULT 20        $KSTS     H
     C           E1SSYS    IFNE 0
     C           WRURO     DIV  E1SSYS    $KHTS     H
     C                     END
      *
     C           E1KTSU    MULT 20        $ZSTS     H
     C           E1SSYS    IFNE 0
     C           E1KTSU    DIV  E1SSYS    $ZHTS     H
     C                     END
      *
     C                     Z-ADDA@N1NM    $$N1SU
     C           $$N1SU    DIV  WCD3      WKTE      H
     C           WKTE      MULT 20        $N1SU
     C           E1SSYS    IFNE 0
     C           WKTE      DIV  E1SSYS    $N1HS     H
     C                     END
      *
     C                     Z-ADDA@N2NM    $$N2SU
     C           $$N2SU    DIV  WCD4      WKTE      H
     C           WKTE      MULT 20        $N2SU
     C           E1SSYS    IFNE 0
     C           WKTE      DIV  E1SSYS    $N2HS     H
     C                     END
      *
     C                     Z-ADDA@ZGSU    $$ZGSU
     C           $$ZGSU    DIV  WCD2      WKTE      H
     C           WKTE      MULT 20        $ZGSU
     C           E1SSYS    IFNE 0
     C           WKTE      DIV  E1SSYS    $ZGHS     H
     C                     END
      *
     C           $UKOJ     IFNE 0111
     C                     Z-ADD0111      $UKOJ
     C                     END
      *
     C                     MOVE '*'       PLIST
     C                     EXCPTGDT
      *
     C           STP4      TAG
     C                     Z-ADDWRURO     E1KSSU
     C                     UPDATAKGPL011
      *
     C           STP3      TAG
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C*----------------------------------------*
     C*  .. AKIPL01                            *
     C*  ..構成品トンネルかんばんマスター..  *
     C*----------------------------------------*
     C           PKANB     IFEQ 'Q'
     C           KEY2      SETLLAKIPL011
      *
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      READEAKIPL011                 11
     C           *IN11     IFEQ '0'
     C           E2SKJY    IFEQ 'D'
     C           E2SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           E2STHZ    IFLE *DATE
     C                     GOTO STP5
     C                     END
      *
     C           E2DTKO    IFEQ '2'
     C           E2DTKO    OREQ 'D'
     C                     GOTO STP6
     C                     END
     C           E2SYOS    IFEQ 0
     C                     GOTO STP6
     C                     END
     C           E2KTSU    IFEQ WRURO
     C                     GOTO STP6
     C                     END
      *
     C           E2KTSU    DIV  E2SYOS    WMO       H
     C           WRURO     DIV  E2SYOS    WMN       H
     C                     Z-ADD0         WMON1
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON
      *
     C                     MOVE 'Z'       $ZOGN
     C           WMN       IFLT WMO
     C                     MOVE 'G'       $ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           $ZOGN     ANDEQ'G'
     C                     GOTO STP6
     C                     END
      *
     C*--------------------------------------------*
     C*  ..増減比率　＋－２０％未満処理しない..  *
     C*--------------------------------------------*
     C           WMON      IFGE 75.0
