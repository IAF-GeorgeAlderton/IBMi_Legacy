     O                         $SYOS     79
     O                         $KTEI     82
     O                         $KBMN     86
     O                         $TENS     89
     O                         $KHTS     95
     O                         $ZHTS    101
     O                         $ZGHS    107
     O                         $N1HS    113
     O                         $N2HS    119
     O                         $BMON    123
     O                         $UKOJ    127
     O                         $$KSTS   136
     O                         $$N1SU   145
     O                         $$N2SU   154
     O                         $$ZGSU   163
