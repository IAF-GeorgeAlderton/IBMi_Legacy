      *
     C                     SETOF                     OF
      *
     C           *ENTRY    PLIST
     C**                   PARM           PWEIG   32
      *
     C                     PARM           P@BAR   9
     C                     PARM           P@ODRN 10
     C                     PARM           P@WGT   3
     C                     PARM           P@MAN# 18
     C                     PARM           P@RTN   1
     C                     MOVELP@WGT     PWEIG   32
      *
     C                     TIME           WTIME   60
     C                     TIME           WSSDT
     C                     Z-ADDWSSDAT    PHZ8
     C                     Z-ADDPMM8      PMM
     C                     Z-ADDPDD8      PDD
     C                     Z-ADDPYY8      PYY
     C                     Z-ADDINOHZ     K@YMD
      *
     C                     MOVELINONY     PSIRE   4
     C                     MOVELIMHN      IMHNA
     C           INONY     IFEQ 3530
     C                     MOVELIMHN1     @MHN1
     C                     MOVELIMHN2     @MHN2
     C                     MOVELIMHN3     @MHN3
     C                     MOVEL@MHN      @PART     P
     C                     ELSE
     C                     MOVELIMHN      OPAR
     C                     MOVE OPAR1     WPAR1
     C                     MOVE OPAR2     WPAR2
     C                     MOVE OPAR3     WPAR3
     C                     MOVELWPAR      @PART
     C                     ENDIF
     C* DENSO
     C           INONY     IFEQ 3032
JW   C           INONY     OREQ 3062
JW   C           INONY     OREQ 3070
JW   C           INONY     OREQ 3076
JW   C           INONY     OREQ 3086
     C                     MOVELIMHN      IMHNB
     C                     MOVELIMHB1     @MHB1
     C                     MOVELIMHB2     @MHB3
     C                     MOVEL@MHNB     @PART
     C                     ENDIF
      *
     C           INONY     IFEQ 3530
     C                     MOVELIINV#     @MAN#
     C                     ELSE
     C                     MOVELIODRN     @MAN#
     C                     ENDIF
     C*
     C                     Z-ADD0         WKASI   72
     C                     MOVE *BLANK    WTKRO
     C           KEY1      CHAINFCEPL011             50
     C           *IN50     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLEWTODAY
     C                     SETON                     50
     C                     ENDIF
     C*
     C           *IN50     IFEQ '0'
     C                     Z-ADDA2KASI    WKASI
     C           A2TRHZ    IFGT INOHZ
     C                     MOVE A2KTKR    WTKRO
     C                     ELSE
     C                     MOVE A2STKR    WTKRO
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDISRYO     WSRYO   60
      *
     C           ISYOS     MULT WKASI     WKOT1   92
     C           WKOT1     DIV  1000      WKOT2   93
     C           WKOT2     ADD  PWEIG     WGROS   62H
      *
     C           ISRYO     DIV  ISYOS     WKT1    40
     C                     MVR            WKT2    40
     C           WKT2      IFNE 0
     C                     ADD  1         WKT1
     C                     ENDIF
      *
     C                     ADD  WKT1      TKT1
      *
     C           WGROS     MULT WKT1      WEIGH   62
     C                     ADD  WEIGH     TEIGH   72
     C           TEIGH     MULT 2.2046    WLB1    82H
      *
      * BAR CODE
     C           *INL1     IFEQ *ON
     C                     MOVE *BLANK    NADD1  40
     C                     MOVE *BLANK    NADD2  40
     C                     MOVE *BLANK    NADD3  40
     C                     MOVE *BLANK    NADD4  40
     C                     MOVE *BLANK    NADD5  40
     C                     MOVE *BLANK    NADD6  40
     C                     MOVE *BLANK    WNONY   4
     C                     MOVE INONY     WNONY
     C                     SETOF                     10
     C           WNONY     CHAINEDIPL401             10
     C           *IN10     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLEWTODAY
     C                     ELSE
     C                     MOVELE4ADD1    NADD1
     C                     MOVELE4ADD2    NADD2
     C                     MOVELE4ADD3    NADD3
     C                     MOVELE4ADD4    NADD4
     C                     MOVELE4ADD5    NADD5
     C                     MOVELE4ADD6    NADD6
     C                     ENDIF
     C                     ENDIF
     C                     MOVE *BLANK    SADD1  38
     C                     MOVE *BLANK    SADD2  38
     C                     MOVE *BLANK    SADD3  38
     C                     MOVE *BLANK    SADD4  38
     C                     MOVE *BLANK    SADD5  38
     C                     MOVE *BLANK    SADD6  38
     C                     MOVE '0111'    WNONY
     C                     SETOF                     10
     C           WNONY     CHAINEDIPL401             10
     C           *IN10     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLEWTODAY
     C                     ELSE
     C                     MOVELE4ADD1    SADD1
     C                     MOVELE4ADD2    SADD2
     C                     MOVELE4ADD3    SADD3
     C                     MOVELE4ADD4    SADD4
     C                     MOVELE4ADD5    SADD5
     C                     MOVELE4ADD6    SADD6
     C                     ENDIF
     C                     ENDIF
     C                     EXSR #NMBR
     C*
     C                     MOVEL*BLANK    P@TTLA
     C           INOTM     IFEQ 33
     C                     MOVELC#SPBN    P@TTLA
     C                     ENDIF
     C*
     C                     EXSR #HED
      *
     C                     ELSE
      *
     C           *IN77     IFEQ *ON
     C                     EXSR #HED
     C                     ENDIF
     C                     ENDIF
      *
     C                     WRITE@3JDTL
      *
     CL1                   EXSR #TTL
