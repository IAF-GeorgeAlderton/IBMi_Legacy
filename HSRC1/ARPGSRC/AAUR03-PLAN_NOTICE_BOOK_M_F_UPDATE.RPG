      *
     C*----------------------------------*
     C*  ..社内かんばん切替マスター..  *
     C*----------------------------------*
     C                     SETOF                     01
     C           KEY1      CHAINAAMPL111             01
     C           *IN01     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '0'
      *
     C*--------------------------------------*
     C*  ..かんばん種類　Ｃ・Ｄチェック..  *
     C*--------------------------------------*
     C                     SETOF                     02
     C           'C'       LOKUPNKB                      02
     C           *IN02     IFEQ '0'
     C           'D'       LOKUPNKB                      02
     C                     END
     C           *IN02     IFEQ '1'
      *
     C                     SETOF                     10
     C                     Z-ADD1         A       20
     C                     Z-ADD16        B       20
     C           1         DO   15        A
     C                     SUB  1         B
     C           NKB,B     IFNE *BLANK
      *
     C           NKB,B     IFEQ 'C'
     C           NKB,B     OREQ 'D'
     C                     SETON                     10
     C                     MOVE '*'       WKUBN   1
     C                     MOVE NTR,B     WTKRO
     C                     Z-ADDNHZ,B     WUKHZ
     C                     EXSR SUBR
     C                     END
     C                     END
     C  N10                END
      *
     C                     ELSE
     C                     MOVE *BLANK    WKUBN
     C                     EXSR SUBR
      *
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C*----------------------*
     C*  ..サブルーチン..  *
     C*----------------------*
     C           SUBR      BEGSR
      *
     C*----------------------------*
     C*  ..計画通知書マスター..  *
     C*----------------------------*
     C                     SETOF                     03
     C           KEY1      CHAINAAUPL011             03
     C           *IN03     IFEQ '0'
     C           J1SKJY    ANDEQ'D'
     C           J1SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
     C           *IN03     IFEQ '0'
      *
     C                     Z-ADD0         WMKCD   40
     C           WKUBN     IFEQ '*'
      *
     C*--------------------------------*
     C*  ..メッキかんばんマスター..  *
     C*--------------------------------*
     C           NKB,B     IFEQ 'C'
     C                     SETOF                     04
     C           KEY2      CHAINAAFPL031             04
     C           *IN04     IFEQ '0'
     C           A3SKJY    ANDEQ'D'
     C           A3SKHZ    ANDLE*DATE
     C                     SETON                     04
     C                     END
     C           *IN04     IFEQ '0'
     C                     Z-ADDA3ATOB    WMKCD
     C                     END
     C                     END
      *
     C*----------------------------------*
     C*  ..トンネルかんばんマスター..  *
     C*----------------------------------*
     C           NKB,B     IFEQ 'D'
     C                     SETOF                     04
     C           KEY2      CHAINAAGPL031             04
     C           *IN04     IFEQ '0'
     C           O4SKJY    ANDEQ'D'
     C           O4SKHZ    ANDLE*DATE
     C                     SETON                     04
     C                     END
     C           *IN04     IFEQ '0'
     C                     Z-ADDO4KOCD    WMKCD
     C                     END
     C                     END
     C                     END
      *
     C*------------------------*
     C*  ..新旧メッキ部門..  *
     C*------------------------*
     C           J1LIST    IFEQ '#'
     C                     Z-ADD1         J1KOSN
     C                     MOVE *BLANK    J1LIST
     C                     MOVE *BLANK    J1MCDH
     C                     MOVE *BLANK    J1KUBH
     C                     MOVE *BLANK    J1MEKH
     C                     MOVE *BLANK    J1TSZH
     C                     MOVE *BLANK    J1KAZH
     C                     MOVE *BLANK    J1KATH
