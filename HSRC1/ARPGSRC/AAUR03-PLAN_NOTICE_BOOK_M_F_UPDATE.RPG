     C                     MOVE *BLANK    J1MKLH
     C                     MOVE *BLANK    J1YKLH
     C                     MOVE *BLANK    J1GEKH
     C                     MOVE *BLANK    J1SYSH
     C                     MOVE *BLANK    J1JOKH
     C                     MOVE *BLANK    J1HBNH
     C                     MOVE *BLANK    J1KOBH
     C                     MOVE *BLANK    J1KTRH
     C                     MOVE *BLANK    J1KH
     C                     MOVE *BLANK    J1TAHH
     C                     MOVE *BLANK    J1SYHH
     C                     MOVE *BLANK    J1TRHH
     C                     MOVE *BLANK    J1GEHH
     C                     Z-ADD0         JTU
