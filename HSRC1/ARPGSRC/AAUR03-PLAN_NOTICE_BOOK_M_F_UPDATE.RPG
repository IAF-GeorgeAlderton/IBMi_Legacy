      *
     C           WMKCD     IFNE J1NMCD
      *
     C           J1KOSN    IFNE 2
     C                     MOVE '*'       J1MCDH
     C                     Z-ADDJ1NMCD    J1OMCD
      *
     C                     SETOF                     05
     C           'BZ '     LOKUPJ1KO                     05
     C           *IN05     IFEQ '1'
     C                     Z-ADD1         J1TU24
     C                     END
     C                     ELSE
      *
     C                     SETOF                     05
     C           'BZ '     LOKUPJ1KO                     05
     C           *IN05     IFEQ '1'
     C                     Z-ADD1         J1TU24
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADDWMKCD     J1NMCD
      *
     C                     Z-ADD*DATE     J1KOHZ
     C                     TIME           J1TIME
