     C           *IN75     DOWEQ*OFF
     C           ZCSKJY    IFEQ ' '
     C           ZCSTYY    ANDEQ9999
     C                     LEAVE
     C                     ENDIF
     C           IZA02     READEIZAPL02                  75
     C                     ENDDO
      *
     C           *IN75     IFEQ *ON
     C                     SETON                     3149
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     ELSE
     C                     MOVELZCZAIS    F1MATN
     C                     Z-ADDZCZAIK    F1DIAM
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           F1MATN    IFNE *BLANKS
     C           F1DIAM    ORNE *ZERO
      *
     C           IZA01     CHAINIZAPL01              75
     C           *IN75     DOWEQ*OFF
     C           ZCSKJY    IFEQ ' '
     C           ZCSTYY    ANDEQ9999
     C                     LEAVE
     C                     ENDIF
     C           IZA01     READEIZAPL01                  75
