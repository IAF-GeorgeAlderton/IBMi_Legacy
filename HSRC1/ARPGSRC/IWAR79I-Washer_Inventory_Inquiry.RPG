      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     4748
     C                     MOVELW#PGM     #PGM
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
