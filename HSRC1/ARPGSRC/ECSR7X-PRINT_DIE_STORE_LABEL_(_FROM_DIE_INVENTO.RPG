     H            Y.
     F** ECSR7X *******************************************
     F*  PRINT DIE STORE LABEL ( FROM DIE INVENTOTU FILE )*
     F*          2018.04.04  KIRI                         *
     F*****************************************************
     F*          FILE DEFINITION                          *
     F*****************************************************
     F*==< INSTRUCTION SCREEN >==*
     FECSPW7X CF  E                    WORKSTN
     F*
      *==< DIE INVENTORY FILE >==*
     FECSPL11 IF  E           K        DISK
     FGCQPL14 IF  E           K        DISK
     F*
     F*
     F*==< MANAGING ISSUE NUMBERS FOR DIE STORE LABEL >==*
     FECSPP73 UF  E           K        DISK                      A
     F*
     F*==< DIE STORE LABEL ISSUE DATA >==*
     FECSWP73 O   E                    DISK
      *===============================================================
      *          ARRAY DEFINITION                         *
      *===============================================================
     E                    @MM     1  12  1
     E                    @ER     1  10 60
      *===============================================================
      *          DATA STRUCTURE                           *
      *===============================================================
     I*==< SYSTEM INFORMATION >==*
     I           SDS
     I                                     *PROGRAM @@PGID
     I                                      244 253 @@WSID
     I                                      254 263 @@USID
     I                                      264 269 @@JBNO
     I*==< SYSTEM DATE/TIME >==*
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        7  140S@YMD
     I                                        7  100S@YYYY
     I                                       11  120S@MM
     I                                       13  140S@DD
     I*==< SCREEN ITEM >==*
     I            DS
     I                                        1   6 D1LOC
     I                                        1   1 D1LOC1
     I                                        2   3 D1LOC2
     I                                        4   5 D1LOC3
     I                                        6   6 D1LOC4
     I            DS
     I                                        1   6 D2LOC
     I                                        1   1 D2LOC1
     I                                        2   3 D2LOC2
     I                                        4   5 D2LOC3
     I                                        6   6 D2LOC4
     I*==< WORK >==*
     I*         ( DIE NUMBER )
     I            DS
     I                                        1   8 E1KAT@
     I                                        1   2 E1KAT1
     I                                        3   6 E1KAT2
     I                                        7   7 E1KAT4
     I                                        8   8 E1KAT3
     I            DS
     I                                        1   6 E1LOC
     I                                        1   1 E1LOC1
     I                                        2   3 E1LOC2
     I                                        4   5 E1LOC3
     I                                        6   6 E1LOC4
     I*         ( BARCODE )
     I            DS
     I                                        1  15 W@BAR@
     I                                        1   8 W@BKAT
     I                                        9   90W@BISY
     I                                       10  10 W@BISM
     I                                       11  140W@BISN
     I                                       15  15 W@BCDG
     I*
      *===============================================================
     C*==< ECSPP73 : MANAGING ISSUE NUMBERS FOR DIE STORE LABEL >==*
     C           K@PP73    KLIST
     C                     KFLD           K@KAT1  2         DIE NO.1
     C                     KFLD           K@KAT2  4         DIE NO.2
     C                     KFLD           K@KAT3  1         DIE NO.3
     C                     KFLD           K@KAT4  1         DIE NO.4
     C                     KFLD           K@KEYY  40        YEAR
     C                     KFLD           K@KEYM  20        MONTH
     C*==< GCQPP11 > ==*
     C           K@PP11    KLIST
     C                     KFLD           K@KAT1  2         DIE NO.1
     C                     KFLD           K@KAT2  4         DIE NO.2
     C                     KFLD           K@KAT3  1         DIE NO.3
     C*
      *===============================================================
      *          MAIN ROUTINE                             *
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1LOC
     C                     MOVE *BLANK    D2LOC
     C                     MOVE *BLANK    D1ERR
      *
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *画面１*
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     SETOF                     313299
     C                     MOVE *BLANK    D1ERR
      *-------*
     C                     SELEC
     C* (F1)  *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* (F5)  *
     C           *INKE     WHEQ *ON
     C                     MOVE '#CHK1 F5'@STEP
     C*       *
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *-------*
     C                     ENDSR
      *===============================================================
      *画面１チェック
      *===============================================================
     C           #CHK1     BEGSR
     C           D1LOC     IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVEL@ER,1     D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C           D2LOC     IFEQ *BLANK
     C                     MOVE D1LOC     D2LOC
     C                     ENDIF
     C           D1LOC     IFGT D2LOC
     C                     SETON                     313299
     C                     MOVEL@ER,2     D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
     C           @STEP     IFEQ '#CHK1 F5'
     C                     MOVE ' '       @UMU    1
     C                     EXSR #WRT1
     C           @UMU      IFEQ ' '
     C                     SETON                     313299
     C                     MOVEL@ER,3     D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C                     MOVE '#END    '@STEP
     C                     ENDIF
      *-------------------------*
     C           $CHK1Z    TAG
      *-------------------------*
     C           @STEP     IFNE '#END    '
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #WRT1     BEGSR
     C*
     C                     TIME           S@TIME
     C*
     C           KEY01     KLIST
     C                     KFLD           D1LOC1
     C                     KFLD           D1LOC2
     C                     KFLD           D1LOC3
     C                     KFLD           D1LOC4
     C*
     C           KEY01     SETLLECSPL11
      *-----------------------------------
S1   C                     DO   *HIVAL
     C                     READ ECSPL11                  90
     C  N90      E1LOC     IFGT D2LOC
     C                     SETON                     90
     C                     ENDIF
     C   90                LEAVE
     C*
     C           E1SQTY    IFEQ 0
     C                     ITER
     C                     ENDIF
     C           E1KAT1    IFEQ '21'
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELE1KAT1    K@KAT1
     C                     MOVELE1KAT2    K@KAT2
     C                     MOVELE1KAT3    K@KAT3
     C                     MOVELE1KAT4    K@KAT4
     C                     Z-ADDE1SQTY    D#CUNT  50
     C                     MOVEL*BLANK    WGET    1
     C                     SETOF                     91
     C           K@PP11    SETLLGCQPL14
     C                     DO   *HIVAL
     C           K@PP11    READEGCQPL14                  91
     C           *IN91     IFEQ '1'
     C                     LEAVE
     C                     END
     C           T6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     MOVEL'*'       WGET
     C                     LEAVE
     C                     ENDDO
     C*
     C           WGET      IFEQ '*'
     C                     EXSR #DATA
     C                     MOVE '*'       @UMU
     C                     END
     C*
     C                     ENDDO
      *-----------------------------------
     C                     ENDSR
      *================================================================
      *  #DATA   ECSWP73 RECORD OUTPUT                    *
      *================================================================
     C           #DATA     BEGSR
     C*
     C*==< GET OF ISSUE NUMBER >==*
     C                     Z-ADDS@YYYY    K@KEYY            YEAR
     C                     Z-ADDS@MM      K@KEYM            MONTH
     C*                    ____________
     C           K@PP73    CHAINECSPP73              93
     C*                    ~~~~~~~~~~~~
I----C           *IN93     IFEQ '1'
|    C                     MOVELE1KAT1    N0KAT1            DIE NO.1
|    C                     MOVELE1KAT2    N0KAT2            DIE NO.2
|    C                     MOVELE1KAT4    N0KAT3            DIE NO.3
|    C                     MOVELE1KAT3    N0KAT4            DIE NO.4
|    C                     Z-ADDS@YYYY    N0KEYY            YEAR
|    C                     Z-ADDS@MM      N0KEYM            MONTH
|    C                     Z-ADD*ZERO     N0ISNO            ISSUE NUMBER
|    C*
+----C                     ELSE
|I---C           N0ISNO    IFEQ 9999
||   C                     Z-ADD*ZERO     N0ISNO            ISSUE NUMBER
|E---C                     ENDIF
E----C                     ENDIF
     C*
     C*==< ECSWP73 EDIT & OUTPUT >==*
     C                     MOVELE1KAT1    W0KAT1            DIE NO.1
     C                     MOVELE1KAT2    W0KAT2            DIE NO.2
     C                     MOVELE1KAT4    W0KAT3            DIE NO.3
     C                     MOVELE1KAT3    W0KAT4            DIE NO.4
     C                     Z-ADDS@YYYY    W0ISYY            YEAR
     C                     Z-ADDS@MM      W0ISMM            MONTH
     C                     Z-ADDS@DD      W0ISDD            ISSUE DATE
     C                     Z-ADDS@HMS     W0ISJK            ISSUE TIME
     C                     MOVEL*BLANK    W0REDK            READ BARCODE
     C*
     C                     Z-ADD1         C@LOOP  50
D----C           C@LOOP    DOWLED#CUNT
|    C                     ADD  1         N0ISNO
|    C                     Z-ADDN0ISNO    W0ISNO            ISSUE NUMBER
|    C*
|    C                     MOVEL*BLANK    W@BAR@
|    C                     MOVELE1KAT@    W@BKAT
|    C                     Z-ADDS@YYYY    W@BISY
|    C                     Z-ADDS@MM      J       20
|    C                     MOVEL@MM,J     W@BISM
|    C                     Z-ADDN0ISNO    W@BISN
|    C*
|    C*CHECK DIGIT ADDING BY PC (NOT AS400)
|    C                     MOVEL*BLANK    W@BCDG
|    C                     MOVELW@BAR@    W0BAR@            BARCODE
|    C                     MOVELE1LOC1    W0LOC1
|    C                     MOVELE1LOC2    W0LOC2
|    C                     MOVELE1LOC3    W0LOC3
|    C                     MOVELE1LOC4    W0LOC4
|    C*                    _____________
|    C                     WRITEECSWP731
|    C*                    ~~~~~~~~~~~~~
|    C                     ADD  1         C@LOOP
E----C                     ENDDO
     C*
     C*==< UPDATE OF ISSUE NUMBER >==*
     C*                    _____________
     C  N93                UPDATECSPP731
     C   93                WRITEECSPP731
     C*                    ~~~~~~~~~~~~~
     C*
     C           #DATAE    ENDSR
      *================================================================
      *================================================================
----+-*--1----+----2----+----3----+----4----+----5----+----6
** @MM
1
2
3
4
5
6
7
8
9
A
B
C
** @ER
E-01 INPUT IS NEEDED.
E-02 LOCATION ERROR. FROM > TO
E-03 NO DATA
E-04
E-05





