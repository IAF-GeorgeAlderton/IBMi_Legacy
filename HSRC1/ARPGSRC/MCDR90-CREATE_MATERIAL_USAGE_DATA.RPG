      *-------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@END   1
     C                     Z-ADD*YEAR     D@YEAR
     C                     MOVE *BLANK    P@END
      *
     C           K#KEY     KLIST
     C                     KFLD           D@YEAR
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#KEY1    KLIST
     C                     KFLD           A2ZANM
     C                     KFLD           A2KAZI
     C           K#KEY2    KLIST
     C                     KFLD           @@15
     C                     KFLD           @@52
     C           K#KEY3    KLIST
     C                     KFLD           @@15
     C                     KFLD           @@52
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C           K#KEY4    KLIST
     C                     KFLD           @@15
     C                     KFLD           @@52
     C                     KFLD           K@ORD
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     MOVE '1'       P@END
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRTH
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK      BEGSR
      *
     C                     SETOF                     6199
     C           D@YEAR    CHAINMBEPL05              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE HEADER
      *------------------------------------------------------
     C           #WRTH     BEGSR
      *
     C                     MOVE D@YEAR    @2      2
     C           1         DO   12        X       20
     C           MON,X     CAT  @2:0      PMN,X
     C                     ENDDO
      *
     C                     WRITEMCDWP981
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE DATA
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     MOVE *BLANK    @@15   15
     C                     Z-ADD*ZERO     @@52    52
     C                     Z-ADD*ZERO     Y       20
     C                     Z-ADD*ZERO     QTT
     C                     Z-ADD*ZERO     TAG
     C                     Z-ADD*ZERO     TWG
     C                     MOVE *BLANK    SUP
     C                     Z-ADD*ZERO     PW1
     C                     Z-ADD*ZERO     PW2
     C                     Z-ADD*ZERO     PW3
     C                     Z-ADD*ZERO     PW4
     C                     Z-ADD*ZERO     PW5
     C                     MOVE *OFF      *IN10
     C           *LOVAL    SETLLFCEPL02
     C           *IN90     DOUEQ*ON
     C                     READ FCEPL02                  90
     C           *IN90     IFEQ *OFF
     C           A2ZANM    ANDNE*BLANK
     C           A2GSKD    ANDEQ*BLANK
      *
     C           *IN10     IFEQ *ON
     C           A2ZANM    IFNE @@15
     C           A2KAZI    ORNE @@52
     C                     EXSR #WRT2
     C                     Z-ADD*ZERO     QTT
     C                     MOVE *OFF      *IN10
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXSR #WRT1
     C                     MOVE A2ZANM    @@15
     C                     Z-ADDA2KAZI    @@52
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN10     IFEQ *ON
     C                     EXSR #WRT2
     C                     ENDIF
      *
      *
     C                     CLEARMCDWP991
     C                     MOVEL'SHP TOT' WPSUPL
     C                     Z-ADDTWG       PWG
     C                     WRITEMCDWP991
     C                     CLEARMCDWP991
     C                     MOVEL'ORD TOT' WPSUPL
     C                     Z-ADDTAG       PWG
     C                     WRITEMCDWP991
      *
     C           1         DO   5         X
     C           SUP,X     IFNE *BLANK
     C                     CLEARMCDWP991
     C                     MOVELSUP,X     WPSUPL
     C                     SELEC
     C           X         WHEQ 1
     C                     Z-ADDPW1       PWG
     C           X         WHEQ 2
     C                     Z-ADDPW2       PWG
     C           X         WHEQ 3
     C                     Z-ADDPW3       PWG
     C           X         WHEQ 4
     C                     Z-ADDPW4       PWG
     C           X         WHEQ 5
     C                     Z-ADDPW5       PWG
     C                     ENDSL
     C                     WRITEMCDWP991
     C                     ENDIF
     C                     ENDDO
      * %
     C           1         DO   5         X
     C           SUP,X     IFNE *BLANK
     C                     CLEARMCDWP991
     C           1         DO   12        Z       30
     C           TWG,Z     IFNE *ZERO
     C                     Z-ADD*ZERO     @@PCT
     C                     SELEC
     C           X         WHEQ 1
     C           PW1,Z     DIV  TWG,Z     @@PCT   54H
     C           X         WHEQ 2
     C           PW2,Z     DIV  TWG,Z     @@PCT   54H
     C           X         WHEQ 1
     C           PW3,Z     DIV  TWG,Z     @@PCT   54H
     C           X         WHEQ 1
     C           PW4,Z     DIV  TWG,Z     @@PCT   54H
     C           X         WHEQ 1
     C           PW5,Z     DIV  TWG,Z     @@PCT   54H
     C                     ENDSL
     C           @@PCT     MULT 100       PWG,Z
     C                     ENDIF
     C                     ENDDO
     C                     MOVEL' %   '   WPSUPL
     C                     WRITEMCDWP991
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE DATA
      *------------------------------------------------------
     C           #WRT1     BEGSR
      *
     C                     Z-ADD*ZERO     @CT     20
     C           K#KEY     CHAINMBEPL05              95
     C           *IN95     IFEQ *OFF
     C           1         DO   12        X
     C           QTY,X     IFNE *ZERO
     C  N10                MOVE *ON       *IN10
     C           A2SOZI    MULT QTY,X     @@QTY  110H
     C                     ADD  @@QTY     QTT,X
     C                     Z-ADDX         @CT
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE DATA
      *------------------------------------------------------
     C           #WRT2     BEGSR
      *
     C           @@52      IFNE *ZERO
     C                     CLEARMCDWP991
     C                     MOVE @@15      WPZAIS
     C                     Z-ADD@@52      WPZAIK
      * SUPPLIER
     C           K#KEY2    SETLLIZAPL01
     C           *IN93     DOUEQ*ON
     C           K#KEY2    READEIZAPL01                  93
     C           *IN93     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSTYY    ANDEQ*ALL'9'
      *
     C                     Z-ADDZCTKJR    @@TKR   50
     C                     Z-ADDZCMSJR    @@MSR   80
      *
     C           ZCKAKE    SETLLFGBPL01
     C           *IN91     DOUEQ*ON
     C           ZCKAKE    READEFGBPL01                  91
     C           *IN91     IFEQ *OFF
     C           B2SKJY    ANDEQ*BLANK
     C                     MOVELB2SMEI    @@SUPL 10
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           1         DO   12        X
     C           QTT,X     DIV  1000      @@WGHT 120H
     C********             MOVE @@WGHT    @@2X    20
     C******     @@WGHT    DIV  1000      PWG,X
     C                     Z-ADD@@WGHT    PWG,X
     C*****      @@2X      IFNE *ZERO
     C*****                ADD  0.1       PWG,X
     C****                 ENDIF
     C                     ENDDO
      *
     C                     ADD  PWG       TWG
     C                     MOVEL'ACT SHIP'WPTRAN
     C                     Z-ADD@@MSR     WPSETQ
     C                     WRITEMCDWP991
      *
     C                     EXSR #ORD
     C                     EXSR #ORD2
      *
     C                     Z-ADD1         X
     C           WPSUPL    LOKUPSUP,X                    50
     C           *IN50     IFEQ *OFF
     C                     ADD  1         Y
     C                     MOVE WPSUPL    SUP,Y
     C                     Z-ADDY         X
     C                     ENDIF
      *
     C                     SELEC
     C           X         WHEQ 1
     C                     ADD  PWG       PW1
     C           X         WHEQ 2
     C                     ADD  PWG       PW2
     C           X         WHEQ 3
     C                     ADD  PWG       PW3
     C           X         WHEQ 4
     C                     ADD  PWG       PW4
     C           X         WHEQ 5
     C                     ADD  PWG       PW5
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      * OREDER INF
      *------------------------------------------------------
     C           #ORD      BEGSR
      *
     C                     Z-ADDD@YEAR    K@YY
     C                     Z-ADD*ZERO     PWG
     C           1         DO   12        X
     C                     Z-ADDX         K@MM
     C           K#KEY3    SETLLGDLPL14
     C           *IN80     DOUEQ*ON
     C           K#KEY3    READEGDLPL14                  80
     C           *IN80     IFEQ *OFF
     C           LBSKJY    ANDEQ*BLANK
     C           LBMAIS    MULT @@TKR     @@WGHT
     C                     ADD  @@WGHT    PWG,X
     C                     ENDIF
     C                     ENDDO
     C                     ENDDO
      *
     C                     ADD  PWG       TAG
      *
     C******               Z-ADD*ZERO     WPSETQ
     C*                    MOVE @@SUPL    WPSUPL
     C*                    MOVEL'ORDER   'WPTRAN
     C***                  WRITEMCDWP991
      *
     C                     ENDSR
      *------------------------------------------------------
      * OREDER INF
      *------------------------------------------------------
     C           #ORD2     BEGSR
      *
     C                     Z-ADDD@YEAR    K@YY
     C           1         DO   12        X
     C                     Z-ADDX         K@MM
     C           K@YM4     MULT 100       K@ORD   60
     C           K@ORD     ADD  99        K@END   60
     C           K#KEY4    SETLLAFCPL96
     C           *IN80     DOUEQ*ON
     C           K#KEY2    READEAFCPL96                  80
     C           *IN80     IFEQ *OFF
     C           C9SKJY    ANDEQ*BLANK
     C           C9ODNO    IFGT K@END
     C                     LEAVE
     C                     ENDIF
      *
     C           C9COIL    MULT @@TKR     @@WGHT
     C                     ADD  @@WGHT    PWG,X
     C                     ENDIF
     C                     ENDDO
     C                     ENDDO
      *
     C                     ADD  PWG       TAG
      *
     C                     Z-ADD*ZERO     WPSETQ
     C                     MOVE @@SUPL    WPSUPL
     C                     MOVEL'ORDER   'WPTRAN
     C                     WRITEMCDWP991
      *
     C                     ENDSR
