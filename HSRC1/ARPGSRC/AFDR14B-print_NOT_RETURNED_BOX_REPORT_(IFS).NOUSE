     H            Y.
     F* AFDR14B**********************************************************
     F* PRINT NOT RETURNED BOX REPORT                                   *
     F* JW    2018.09.18                                                *
     F*******************************************************************
     FAFDWP14 IF  E           K        DISK
     FAFDWP14BO   E                    DISK
      *------------------------------------------------------------------
     E                    TTL     1   1 80
     I            DS
     I                                        1  12 A4SHIN
     I                                        1   5 A4SHN1
     I                                        6  10 A4SHN2
     I                                       11  12 A4SHN3
     I            DS
     I                                        1  14 @PART
     I                                        1   5 @PART1
     I                                        6   6 @P1
     I                                        7  11 @PART2
     I                                       12  12 @P2
     I                                       13  14 @PART3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************
      * MAIN ROUTINE
      *************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AFDWP14                  98
     C   98                LEAVE
      *
     C                     MOVELA4SUPP    B4SUPP    P
     C                     MOVELA4SHN1    @PART1
     C                     MOVELA4SHN2    @PART2
     C                     MOVELA4SHN3    @PART3
     C           @PART2    IFEQ *BLANK
     C                     MOVE *BLANK    @P1
     C                     ELSE
     C                     MOVE '-'       @P1
     C                     ENDIF
     C           @PART3    IFEQ *BLANK
     C                     MOVE *BLANK    @P2
     C                     ELSE
     C                     MOVE '-'       @P2
     C                     ENDIF
     C                     MOVEL@PART     B4SHIN    P
     C                     MOVELA4BOX     B4BOX     P
     C                     MOVE *BLANK    B4PGM
     C                     WRITEAFDWP4B1
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *************************************************
      * INITIAL SET
      *************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           @FROM  10
     C                     PARM           @TO    10
      * CREATE HEADER
     C                     MOVEL'SUPPLIER'B4SUPP
     C                     MOVEL'PART#   'B4SHIN
     C                     MOVEL'# OF BOX'B4BOX
      * TITLE
     C                     MOVEL@FROM     FROM8   8
     C                     MOVEL@TO       TO8     8
     C                     MOVELTTL,1     LTR48  48
     C                     MOVE FROM8     LTR48
     C                     MOVELLTR48     LTR53  53
     C                     MOVE ' TO: '   LTR53
     C                     MOVELLTR53     LTR61  61
     C                     MOVE TO8       LTR61
     C                     MOVELLTR61     B4PGM
      *
     C                     WRITEAFDWP4B1
      *
     C                     ENDSR
**
PGM:AFDC14 ** NOT RETURNED BOX ** FROM: YYYYMMDD TO: YYYYMMDD
