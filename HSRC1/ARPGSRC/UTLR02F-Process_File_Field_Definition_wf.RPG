     H            Y.
      *  UTLR02F   ********************************************************
      *  UTILITY- Process File/Field Definition wf to Data Dictionary wf
      *----------------------------------------------------*
      *
      ******************************************************************
     F##FILFMTIF  E           K        DISK
     FFFDPP01 O   E           K        DISK                      A
      *
     IQWHDRFFD
     I              WHHDNCOL                        HDNCOL
      *
     I            DS
     I                                        1  10 WHFLDI
     I                                        3  10 ALIAS
      *----------------------------------------------------
      * MAIN ROUTINE
      *----------------------------------------------------
     C                     DO   *HIVAL
      *
     C                     READ ##FILFMT                 50
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELWHFILE    FILE
     C                     MOVELWHLIB     LIBR
     C                     MOVELWHTEXT    FILDSC
      *
     C           FILDSC    IFEQ *BLANK
     C                     EXSR GETDSC
     C                     ENDIF
      *
     C                     MOVELWHFTXT    FLDDSC
     C                     MOVELWHFLDI    FLDNAM
      *
     C                     SELEC
     C           WHFLDT    WHEQ 'S'
     C           WHFLDT    OREQ 'P'
     C                     MOVEL'N'       FLDTYP
     C                     OTHER
     C                     MOVELWHFLDT    FLDTYP
     C                     ENDSL
      *
     C           FLDTYP    IFEQ 'N'
     C                     MOVEL'00000'   LEN5A   5
     C                     MOVE WHFLDD    LEN5A
     C                     MOVELLEN5A     FLDLEN
     C                     MOVELWHFLDP    FLDDEC
     C                     ELSE
     C                     MOVELWHFLDB    FLDLEN
     C                     ENDIF
      *
     C                     MOVELALIAS     FLDAKA
      *
     C                     WRITEFFDPP011
     C                     CLEARFFDPP011
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------
      *  get file description from dds source member
      *
     C           GETDSC    BEGSR
     C                     CALL 'UTLC75D'
     C                     PARM           FILE
     C                     PARM           FILDSC
     C                     ENDSR
      *----------------------------------------------------
