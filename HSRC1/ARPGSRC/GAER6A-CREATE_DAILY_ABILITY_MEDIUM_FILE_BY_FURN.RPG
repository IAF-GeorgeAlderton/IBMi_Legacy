     H            Y.
     F*******************************************************
     F*CREATE DAILY ABILITY MEDIUM FILE BY FURNACE NO GAER6A
     F*            TABLE            M S K        87.06.08   *
     F*******************************************************
     FGAEPW16 CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
     FGAEWP03 O   F       8            DISK
     E                    $EMSG   1   2 60
     I            DS
     I                                        1   8 @YMD
     I                                        1   4 @Y
     I                                        5   6 @M
     I                                        7   8 @D
     C*-------------------*
     C*  K L I S T        *
     C*-------------------*
     C           #KEY      KLIST
     C                     KFLD           WY      40
     C                     KFLD           WM      20
     C                     KFLD           WD      20
     C           #KEY1     KLIST
     C                     KFLD           #HIN1   5
     C                     KFLD           #HIN2   5
     C                     KFLD           #HIN3   2
     C*
     C           *ENTRY    PLIST
     C                     PARM           PARM1   1
     C                     PARM           PARM2   8
     C                     PARM           PARM3   8
     C                     PARM           PARM4   8
     C                     PARM           PARM5   8
     C                     PARM           PARM6   8
     C                     PARM           PARM7   8
     C                     PARM           PARM8   8
     C                     PARM           PARM9   8
     C                     PARM           PARM10  8
     C                     PARM           PARM11  8
     C/SPACE 1
     C                     MOVE *DATE     @DATE
     C                     TIME           @TIME
     C           PARM1     IFEQ 'L'
     C                     SETON                       97
     C                     MOVEL$EMSG,2   @MSG
     C                     END
     C**************
     C*  fﾞx] ﾆｭﾒ  *
     C**************
     C           $100S     TAG
     C                     EXFMTGAEPW161
     C                     MOVE *BLANK    @ERR
     C           *IN01     IFEQ '1'
     C                     MOVE '9'       PARM1
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C           *IN02     IFEQ '1'
     C                     MOVE 'M'       PARM1
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C/SPACE 1
     C           @YM       IFEQ 'Y'
     C           @YM       OREQ 'N'
     C                     ELSE
     C                     MOVEL$EMSG,1   @ERR
     C                     SETON                       1199
     C                     GOTO $100S
     C                     END
     C/SPACE 1
     C*--------------------*
     C* gｬcﾆﾞl ･ ﾎhw       *
     C*--------------------*
     C           @YM       IFEQ 'Y'
     C                     MOVE @Y        WY
     C                     MOVE @M        WM
     C                     MOVE @D        WD
     C           #KEY      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     READ AGDPL121                 81
     C           *IN81     IFEQ '0'
     C                     ADD  1         CTR     20
     C                     MOVELF8KAYY    WKYM    60
     C                     MOVE F8KAMM    WKYM
     C                     MOVELWKYM      WKYMD   80
     C                     MOVE F8KADD    WKYMD
     C                     EXSR $SAB
     C           CTR       COMP 10                   82
     C                     END
     C  N81N82             END
     C                     END
     C*--------------------*
     C* gｬcﾆﾞl ･ ﾎhuob     *
     C*--------------------*
     C           @YM       IFEQ 'N'
     C                     MOVE @Y        WY
     C                     MOVE @M        WM
     C                     MOVE @D        WD
     C           #KEY      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     READ AGDPL121                 81
     C           *IN81     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C                     ADD  1         CTR
     C                     MOVELF8KAYY    WKYM
     C                     MOVE F8KAMM    WKYM
     C                     MOVELWKYM      WKYMD
     C                     MOVE F8KADD    WKYMD
     C                     EXSR $SAB
     C           CTR       COMP 10                   82
     C                     END
     C                     END
     C  N81N82             END
     C                     END
     C           *INKE     IFEQ '1'
     C                     EXSR $FILE
     C                     SETON                       97
     C                     MOVEL$EMSG,2   @MSG
     C                     WRITEGAEPW161
     C                     MOVE ' '       PARM1
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C                     GOTO $100S
     C*--------------------------------*
     C*  ﾎabﾓ ﾅhﾈb                     *
     C*--------------------------------*
     CSR         $FILE     BEGSR
