      *** INVRS2 *****************************************************
      *   INQUIRY CUT OFF TIME MASTER
      *
      *     KIRI                         2014.08.08
      ****************************************************************
     H            Y/                                    1
     FAB#PWM2 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFREC1
      *
     FAB#PPM1 IF  E           K        DISK
      *
     FFGBPL01 IF  E           K        DISK
      *================================================================
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4        :DELV.
     C                     PARM           P@BIN   2        :BIN
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     WRITEW1
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           KEY01     KLIST
     C                     KFLD           K@NONY  4        :DELV.
     C                     KFLD           K@BIN   2        :BIN
     C*
     C                     MOVELP@NONY    K@NONY           :DELV.
     C                     MOVELP@BIN     K@BIN            :BIN
     C                     MOVEL*BLANK    P@NONY           :DELV.
     C                     MOVEL*BLANK    P@BIN            :BIN
      *
     C           KEY01     SETLLAB#PPM1
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AB#PPM1                  90
     C   90                LEAVE
     C*
     C           M@SKJY    IFEQ 'D'                        DELETE CODE
     C           M@SKDT    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELM@NONY    S1NONY           DELIVERY CODE
     C                     MOVEL*BLANK    S1SMEI
     C                     MOVELM@BIN     S1BIN            BIN
     C                     Z-ADDM@OTIM    S1OTIM           OLD TIME
     C                     Z-ADDM@NTIM    S1NTIM           NEW TIME
     C                     Z-ADDM@CHGD    S1CHGD           CHAGE DATE
     C                     EXSR ##SMEI                     SUPPLIER NAME
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *------------------------------------------------------------------
      *          VELEVRY  NAME
      *------------------------------------------------------------------
     C           ##SMEI    BEGSR
     C                     MOVELM@NONY    K$NONY  40
     C           K$NONY    CHAINFGBPL01              91
     C  N91      B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C  N91                MOVELB2SMEI    S1SMEI           DETAIL NAME KANA
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < PAGE UP/DOWN >
     C           *IN75     WHEQ *ON
     C           *IN76     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* < F3 > 終了
     C           *INKC     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* <    >
     C                     OTHER
     C           RTNRRN    CHAINSFREC1               94
     C           *IN94     IFEQ *OFF
     C                     MOVELS1NONY    P@NONY           :DELV.
     C                     MOVELS1BIN     P@BIN            :BIN
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDSL
     C*----------
     C                     ENDSR
      *===============================================================
      *===============================================================
