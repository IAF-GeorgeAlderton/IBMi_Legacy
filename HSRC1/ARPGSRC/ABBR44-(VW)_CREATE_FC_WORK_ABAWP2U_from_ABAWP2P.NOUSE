      *--------------------------------------------------
     C                     EXSR #INIT
      * UPDATE ABBPP60
     C**                   EXSR #PP60
      * WRITE ABAWP2U
     C                     EXSR #WP2U
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------
      *  UPDATE ABBPP60
      *-----------------------------------
     C**         #PP60     BEGSR
      *
     C**         *LOVAL    SETLLABAWP2P
     C**                   MOVE *OFF      *IN91
      *
     C**         *IN91     DOWEQ*OFF
     C**                   READ ABAWP2P                  91
     C**         *IN91     IFEQ *OFF
      *
     C**                   Z-ADDABDATE    K@DATE
     C**                   Z-ADDABTOKU    K@TOKU
     C**                   Z-ADDABNONY    K@NONY
     C**                   MOVELABNKOJ    K@NKOJ
     C**                   MOVELABNUKE    K@NUKE
     C**                   MOVELABSBAN    K@SEBN
     C**                   MOVELABMHN1    K@MHN1
     C**                   MOVELABMHN2    K@MHN2
     C**                   MOVELABMHN3    K@MHN3
     C**                   MOVELABMHN4    K@MHN4
     C**         K#PL60    CHAINABBPL60              99
     C**         *IN99     IFEQ *OFF
     C**                   EXSR #UP60
     C**                   ELSE
     C**                   EXSR #WT60
     C**                   ENDIF
      *
     C**                   ENDIF
     C**                   ENDDO
      *
     C**                   ENDSR
      *-----------------------------------
      * UPDATE ABBPP60
      *-----------------------------------
     C**         #UP60     BEGSR
      *
     C**         1         DO   31        IX      20
     C**         HIS,IX    IFNE 0
     C**                   Z-ADDHIS,IX    PP6,IX
     C**                   ENDIF
     C**                   ENDDO
      *
     C**                   XFOOTPP6       ABGEKN
      *
     C**                   Z-ADD@DATE     ABKOHZ
     C**                   MOVEL@TIME     ABKOTM
     C**                   MOVEL#USER     ABKOME
      *
     C**                   UPDATABBPL601
      *
     C**                   ENDSR
      *-----------------------------------
      * WRITE  ABBPP60
      *-----------------------------------
     C**         #WT60     BEGSR
      * TEMP
     C**                   MOVE *BLANK    X       1
      *
     C**                   Z-ADD@DATE     ABKOHZ
     C**                   MOVEL@TIME     ABKOTM
     C**                   MOVEL#USER     ABKOME
     C**                   MOVELABSBAN    ABSEBN
     C**                   MOVE X         ABSHN1
     C**                   MOVE X         ABSHN2
     C**                   MOVE X         ABSHN3
     C**                   Z-ADD0         PP6
      *
     C**         1         DO   31        IX      20
     C**                   Z-ADDHIS,IX    PP6,IX
     C**                   ENDDO
      *
     C**                   XFOOTPP6       ABGEKN
      *
     C**                   WRITEABBPL601
      *
     C**                   ENDSR
      *-----------------------------------
      * WRITE ABAWP2U
      *-----------------------------------
     C           #WP2U     BEGSR
      * *IN89=ON TAKATA
     C           *IN89     IFEQ *OFF
     C           K@2P      SETLLABAWP2P
     C                     ELSE
     C           K@TOKU    SETLLABAWP2P
     C                     ENDIF
      *
     C           *IN90     DOWEQ*OFF
      *
     C           *IN89     IFEQ *OFF
     C           K@2P      READEABAWP2P                  90
     C                     ELSE
     C           K@TOKU    READEABAWP2P                  90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C                     Z-ADDABTOKU    K@TOKU
     C                     Z-ADDABNONY    K@NONY
     C                     MOVE ABNKOJ    K@NKOJ
     C                     MOVE ABNUKE    K@NUKE
     C                     MOVE ABMHN1    K@MHN1
     C                     MOVE ABMHN2    K@MHN2
     C                     MOVE ABMHN3    K@MHN3
     C                     MOVE ABMHN4    K@MHN4
     C                     Z-ADD0         WNJS1   90
     C                     Z-ADD0         WNJS2   90
     C                     Z-ADD0         WNJS3   90
     C                     Z-ADD0         WNJS4   90
     C                     Z-ADD0         WNJS5   90
     C                     Z-ADD0         HWS
      **                   MOVE *OFF      *IN96
      *
     C           1         DO   5         IX      20
     C                     Z-ADDHYM,IX    K@NYM
      *
     C           K#KEY     CHAINABAWP2P              99
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           IX        WHEQ 1
     C                     Z-ADDABNNSU    WNJS1
     C                     Z-ADDHIS       HWS
     C                     Z-ADDABDATE    SVDATE  60
     C           IX        WHEQ 2
     C                     Z-ADDABNNSU    WNJS2
     C           IX        WHEQ 3
     C                     Z-ADDABNNSU    WNJS3
     C           IX        WHEQ 4
     C                     Z-ADDABNNSU    WNJS4
     C           IX        WHEQ 5
     C                     Z-ADDABNNSU    WNJS5
     C                     ENDSL
     C**N96                MOVE *ON       *IN96
     C                     ENDIF
     C                     ENDDO
      *
     C** 96                EXCPTDT
     C                     Z-ADDSVDATE    ABDATE
     C                     Z-ADDWNJS1     ABNJS1
     C                     Z-ADDWNJS2     ABNJS2
     C                     Z-ADDWNJS3     ABNJS3
     C                     Z-ADDWNJS4     ABNJS4
     C                     Z-ADDWNJS5     ABNJS5
     C                     Z-ADDHWS       HIS
     C                     WRITEABAWP2U1
      *
     C           K#KEYX    SETGTABAWP2P
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------------
      * INITIALIZE
      *---------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PNONY   4        NONY
     C                     PARM           PYYMM   6        BEGINNING YYMM
      *
     C           K@2P      KLIST
     C                     KFLD           K@TOKU
     C                     KFLD           K@NONY
      *
     C           K#KEY     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@NYM   60
      *
     C           K#PL60    KLIST
     C                     KFLD           K@DATE  60
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@SEBN  4
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
      *
     C           K#KEYX    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
      *
     C                     MOVE PNONY     K@TOKU
     C                     MOVE PNONY     K@NONY
     C           PNONY     IFEQ '5672'
     C                     MOVE 5671      K@TOKU
     C                     ENDIF
     C* TAKATA MULTI NONY (*IN89=ON)
     C           PNONY     IFEQ '3712'
     C           PNONY     OREQ '3656'
     C           PNONY     OREQ '3682'
     C           PNONY     OREQ '3824'
     C           PNONY     OREQ '3842'
     C           PNONY     OREQ '3713'
JW   C           PNONY     OREQ '3714'
     C                     Z-ADD3656      K@TOKU
     C                     MOVEL*ON       *IN89
     C                     ELSE
     C                     MOVEL*OFF      *IN89
     C                     END
      * SET YYYY/MM TABLE 5 MONTH (HYM)
     C                     Z-ADD*DATE     UYMD
     C                     MOVE PYYMM     UYM
     C                     Z-ADD0         HYM
     C           1         DO   5         IX      20
     C                     Z-ADDUYM       HYM,IX
      *
     C                     ADD  1         UMM
     C           UMM       IFGT 12
     C                     SUB  12        UMM
     C                     ADD  1         UYY
     C                     ENDIF
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
      *
     C                     ENDDO
      *
     C                     ENDSR
