JW1  F* JW    04/22/20 CHG KANBAN QTY CALCULATION
JW2  F* JW    04/28/20 CHG KANBAN QTY CALCULATION (UEXR24)
     F***********************************************
     FIZAPL01 UF  E           K        DISK
     FABMWPZ1 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80ZCSKHZ
     I                                        1   40ZCSKYY
     I                                        5   60ZCSKMM
     I                                        7   80ZCSKDD
      *
     I            DS
     I                                        1   80ZCUKHZ
     I                                        1   40ZCUKYY
     I                                        5   60ZCUKMM
     I                                        7   80ZCUKDD
      *
     I            DS
     I                                        1   80ZCSTHZ
     I                                        1   40ZCSTYY
     I                                        5   60ZCSTMM
     I                                        7   80ZCSTDD
      *
     I            DS
     I                                        1   80ZCKOHZ
     I                                        5   80@CKOMD
     I                                        1   40ZCKOYY
     I                                        5   60ZCKOMM
     I                                        7   80ZCKODD
      *
     I            DS
     I                                        1   40XXMD
     I                                        1   20XXMM
     I                                        3   40XXDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
      *----------------------------------------------------*
      *  PARAMETER TRANSFER                                *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
     C                     TIME           WTIME
     C                     READ IZAPL011                 80
     C           *IN80     DOWEQ'0'
     C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ELSE
     C           ZCUKHZ    IFLE *DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     EXSR $SB910
     C                     EXSR $SB240
     C                     EXSR $SB500
     C                     ENDIF
     C                     ENDIF
     C                     READ IZAPL011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         $SB240    BEGSR
      *
     C           @CDTKO    IFNE '0'
      *
     C                     Z-ADDKSKBN     @CKOSN
      * KANBAN CALCULATION
     C                     Z-ADD0         WKMAIS  30
     C                     EXSR $SB911
     C                     Z-ADDWKMAIS    @CKMMX
     C**JW1      @CKMMX    IFLE 2
     C**         P@MKJR    IFGE ZCTKJR
     C**                   ADD  1         @CKMMX
     C**                   ENDIF
     C**                   ENDIF
      *
     C           @CDTKO    IFEQ '2'
     C           @CDTKO    OREQ 'D'
     C                     ELSE
     C           @CDOUT    IFNE *BLANK
     C                     Z-ADDWALL      @CKMAL
     C                     Z-ADDWMAX      @CKMMN
     C                     ENDIF
     C           *YEAR     CABEQ@CKOYY    CA2
     C           *YEAR     SUB  @CKOYY    WYY     40
     C           WYY       IFLE 01
     C                     Z-ADDUMONTH    XXMM
     C                     Z-ADDUDAY      XXDD
     C           XXMD      CABLE@CKOMD    CA2
     C                     ENDIF
     C           @CKMAL    CABLT@CKMMN    CA2
     C           @CKMMN    CABGE30        CA2
      *
     C           CA2       TAG
     C                     Z-ADD0         @CSRMS
     C           @CDOUT    IFNE *BLANK
     C                     MOVE *BLANK    @CKSHK
     C                     Z-ADD0         @CALHK
     C                     Z-ADD0         @CMXHK
     C                     ENDIF
     C           @CKOSN    IFEQ KSKBN
     C           @CDOUT    CABEQ'Y'       CAE
     C           @CKSHK    CABEQ*BLANK    CAE
     C                     Z-ADD@CALHK    WKALL
     C                     Z-ADD@CMXHK    WMAX
     C                     ELSE
     C           @CKSHK    IFNE *BLANK
     C                     Z-ADD@CALHK    WKALL
     C                     Z-ADD@CMXHK    WMAX
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADD0         @CKMAL
     C                     Z-ADD0         @CKMMN
     C           WKALL     IFGT WMAX
     C           WKALL     SUB  WMAX      @CSRMS
     C                     ENDIF
     C           CAE       TAG
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     CSR         $S240E    ENDSR
      *----------------------------------------------------*
      *    UPDATE
      *----------------------------------------------------*
     CSR         $SB500    BEGSR
     C                     SETOF                       25
      *
     C           @CKOSN    IFEQ KSKBN
     C           @CDOUT    CABEQ'Y'       STP5
     C           @CKSHK    CABEQ*BLANK    STP5
     C                     ENDIF
     C           @CDOUT    IFNE *BLANK
     C                     MOVE 'H'       @CKSHK
     C                     Z-ADDWKALL     @CALHK
     C                     Z-ADDWMAX      @CMXHK
     C                     ENDIF
      *
     C           STP5      TAG
     C           @CDTKO    IFNE '2'
     C           @CDTKO    ANDNE'D'
     C           KSKBN     IFEQ @CKOSN
     C           @CKMMN    IFEQ @CKMMX
     C                     GOTO SP1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVE *BLANK    @CDOUT
     C                     MOVE 'Y'       @CKOUT
     C           SP1       TAG
      *
     C           @CDTKO    IFNE '0'
     C                     Z-ADDWTIYY     ZCKOYY
     C                     Z-ADDWTIMM     ZCKOMM
     C                     Z-ADDWTIDD     ZCKODD
     C                     Z-ADDTIMHH     ZCKOHH
     C                     Z-ADDTIMMM     ZCKOSS
     C                     MOVEL*BLANK    ZCKOME
     C                     MOVEL'JIDOU'   ZCKOME
     C           @CDTKO    IFNE '6'
     C           @CDTKO    ANDNE'2'
     C           @CDTKO    ANDNE'D'
     C           ZCUKHZ    ANDLE*DATE
     C           @CDTKO    IFNE 'E'
     C                     MOVE '1'       @CDTKO
     C                     ENDIF
     C                     ELSE
     C           @CDTKO    IFNE 'E'
     C           @CDTKO    IFEQ 'D'
     C                     MOVE 'E'       @CDTKO
     C                     ELSE
     C                     MOVE '1'       @CDTKO
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE @CKOSN    ZCKOSN
     C                     Z-ADD@CKMMX    ZCKMMX
     C                     MOVE @CDOUT    ZCDOUT
     C                     MOVE @CKOUT    ZCKOUT
     C                     Z-ADD@CKMAL    ZCKMAL
     C                     Z-ADD@CKMMN    ZCKMMN
     C                     MOVE @CKSHK    ZCKSHK
     C                     Z-ADD@CALHK    ZCALHK
     C                     Z-ADD@CMXHK    ZCMXHK
     C                     Z-ADD@CSRMS    ZCSRMS
     C                     Z-ADDP@MKJR    ZCMKJR
     C                     MOVE '*'       ZCDTHE
     C                     MOVE @CDTKO    ZCDTKO
     C                     UPDATIZAPL011
     C                     EXSR #SB510
      *
     C                     ENDIF
      *
     CSR         $S500E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     CLEARABMWPZ11
     C                     Z-ADDZCKOJE    W1KOJE
     C                     MOVELZCKOJK    W1KOJK
     C                     MOVELZCZAIS    W1ZAIS
     C                     Z-ADDZCZAIK    W1ZAIK
     C                     Z-ADDZCKAKE    W1KAKE
     C                     MOVELZCKAKK    W1KAKK
     C                     MOVELZCKNO1    W1KNO1
     C                     MOVELZCKNO2    W1KNO2
     C                     MOVELZCKNO3    W1KNO3
     C                     MOVELZCKNOE    W1KNOE
     C                     Z-ADDZCTKJR    W1TKJR
     C                     MOVELZCNISG    W1NISG
     C                     MOVELZCKOSN    W1KOSN
     C                     MOVELZCZIRO    W1ZIRO
     C                     Z-ADDSCMKJR    W1MKJR
     C                     Z-ADDSCMSJR    W1MSJR
     C                     MOVELZCADR1    W1ADR1
     C                     MOVELZCADR2    W1ADR2
     C                     MOVELZCADR3    W1ADR3
     C                     MOVELZCADR4    W1ADR4
     C                     MOVELZCUKIR    W1UKIR
     C                     Z-ADDZCLOTO    W1LOTO
     C                     Z-ADDZCMSSU    W1MSSU
     C                     Z-ADDZCSLTM    W1SLTM
     C                     Z-ADDZCKEIS    W1KEIS
     C                     Z-ADDZCSETI    W1SETI
     C                     Z-ADDSCKMAL    W1KMAL
     C                     Z-ADDSCKMMN    W1KMMN
     C                     Z-ADDSCKMMX    W1KMMX
     C                     Z-ADDSCSRMS    W1SRMS
     C                     Z-ADDSCALHK    W1ALHK
     C                     Z-ADDSCMXHK    W1MXHK
     C                     MOVELZCKSHK    W1KSHK
     C                     MOVELZCKOUT    W1KOUT
     C                     MOVELZCDOUT    W1DOUT
     C                     MOVELZCDTKO    W1DTKO
     C                     MOVELZCDTHE    W1DTHE
     C                     Z-ADDZCCHOS    W1CHOS
     C                     MOVELZCYOSI    W1YOSI
     C                     MOVELZCBAD1    W1BAD1
     C                     MOVELZCBAD2    W1BAD2
     C                     MOVELZCBAD3    W1BAD3
     C                     MOVELZCBAD4    W1BAD4
     C                     Z-ADDZCBZIK    W1BZIK
     C                     MOVELZCKIBN    W1KIBN
     C                     MOVELZCSNJ1    W1SNJ1
     C                     MOVELZCSNJ2    W1SNJ2
     C                     MOVELZCSNJ3    W1SNJ3
     C                     MOVELZCSNJ4    W1SNJ4
     C                     MOVELZCKHKO    W1KHKO
     C                     MOVELZCDHKO    W1DHKO
     C                     Z-ADDZCUKYY    W1UKYY
     C                     Z-ADDZCUKMM    W1UKMM
     C                     Z-ADDZCUKDD    W1UKDD
     C                     Z-ADDZCUBIN    W1UBIN
     C                     Z-ADDZCSTYY    W1STYY
     C                     Z-ADDZCSTMM    W1STMM
     C                     Z-ADDZCSTDD    W1STDD
     C                     Z-ADDZCSBIN    W1SBIN
     C                     Z-ADDZCBZJR    W1BZJR
     C                     Z-ADDZCMKJR    W2MKJR
     C                     Z-ADDZCMSJR    W2MSJR
     C                     Z-ADDZCKMAL    W2KMAL
     C                     Z-ADDZCKMMN    W2KMMN
     C                     Z-ADDZCKMMX    W2KMMX
     C                     Z-ADDZCSRMS    W2SRMS
     C                     Z-ADDZCALHK    W2ALHK
     C                     Z-ADDZCMXHK    W2MXHK
     C           W1MKJR    IFEQ 0
     C                     ELSE
     C           W2MKJR    DIV  W1MKJR    W2BOXP
     C                     ENDIF
     C           W2KMMX    SUB  W1KMMX    W2SA
     C                     Z-ADDW2SA      W2SA@
     C**         W2SA@     IFLT 0
     C**                   MULT -1        W2SA@
     C**                   ENDIF
     C                     WRITEABMWPZ11
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         $SB910    BEGSR
      *
     C                     Z-ADDZCKMAL    @CKMAL  30
     C                     Z-ADDZCKMMN    @CKMMN  30
     C                     Z-ADDZCKMMX    @CKMMX  30
     C                     Z-ADDZCCHOS    @CHOS   30
     C                     Z-ADDZCKMAL    WKALL   30
     C                     Z-ADDZCKMMN    WMIN    30
     C                     Z-ADDZCKMMX    WMAX    30
     C           ZCKMAL    IFLT ZCKMMX
     C                     Z-ADDZCKMMX    WALL    30
     C                     ELSE
     C                     Z-ADDZCKMAL    WALL
     C                     ENDIF
     C                     MOVE ZCDTKO    @CDTKO  1
     C                     MOVE ZCDOUT    @CDOUT  1
     C                     MOVE ZCKOYY    @CKOYY  40
     C                     MOVE ZCKSHK    @CKSHK  1
     C                     MOVE ZCALHK    @CALHK  30
     C                     MOVE ZCMXHK    @CMXHK  30
     C                     MOVE ZCKOSN    @CKOSN  10
     C                     MOVE ZCKOSN    KSKBN   10
     C                     MOVE ZCSRMS    @CSRMS  30
     C                     MOVE ZCKOUT    @CKOUT  1
      *
     C                     Z-ADDZCMKJR    SCMKJR  80
     C                     Z-ADDZCMSJR    SCMSJR  80
     C                     Z-ADDZCKMAL    SCKMAL  30
     C                     Z-ADDZCKMMN    SCKMMN  30
     C                     Z-ADDZCKMMX    SCKMMX  30
     C                     Z-ADDZCSRMS    SCSRMS  30
     C                     Z-ADDZCALHK    SCALHK  30
     C                     Z-ADDZCMXHK    SCMXHK  30
      *
     CSR         $S910E    ENDSR
      *----------------------------------------------------*
      *    KABAN CALUCATION                              *
      *----------------------------------------------------*
     CSR         $SB911    BEGSR
      *
     C                     Z-ADDP@DTYM    A@DTYM
     C                     Z-ADD0         P@MSJR
     C                     Z-ADD0         P@MKJR
     C                     CALL 'ABMR4B'
     C                     PARM           A@DTYM  60
     C                     PARM           ZCZAIS 15
     C                     PARM           ZCZAIK  52
     C                     PARM           ZCKOJE  40
     C                     PARM           ZCKAKE  40
     C                     PARM           P@MSJR 150
     C                     PARM           P@MKJR 150
      *
     C**JW1      P@MKJR    DIV  20        @DKJR   70H
     C**                   MOVE ZCSLTM    @LT     30
     C**                   MOVE ZCKEIS    @BARA   32
     C**                   Z-ADDZCCHOS    @CHOS   30
     C**                   MOVE ZCLOTO    @LOT    20
     C**                   Z-ADD0         WKKJR  124H
     C**                   Z-ADD0         WKLOT   30
     C**         ZCTKJR    IFNE 0
     C**         @DKJR     DIV  ZCTKJR    WKKJR  124H
     C**                   ELSE
     C**                   Z-ADD@DKJR     WKKJR
     C**                   ENDIF
     C**                   MULT @LT       WKKJR
     C**                   MULT @BARA     WKKJR
     C**                   ADD  0.9999    WKKJR
     C**         @LOT      SUB  1         WKLOT
     C**                   ADD  @CHOS     WKLOT
     C**         WKKJR     ADD  WKLOT     WKMAIS
     C**         WKMAIS    IFEQ 1
     C**                   ADD  1         WKMAIS
     C**                   ENDIF
      *
JW2  C                     MOVELZCZAIS    $ZAIS
 |   C                     Z-ADDZCZAIK    $ZAIK
 |   C                     Z-ADDP@MKJR    $MSET
 |   C                     Z-ADDZCTKJR    $CWGT
 |   C                     Z-ADDZCKEIS    $SCOE
 |   C                     Z-ADDZCSLTM    $LT
 |   C                     Z-ADDZCLOTO    $LOT
 |   C                     Z-ADDZCCHOS    $ADJ
 |   C                     CALL 'UEXR24'
 |   C                     PARM           $ZAIS  15
 |   C                     PARM           $ZAIK   52
 |   C                     PARM           $MSET   80
 |   C                     PARM           $CWGT   50
 |   C                     PARM           $SCOE   32
 |   C                     PARM           $LT     30
 |   C                     PARM           $LOT    20
 |   C                     PARM           $ADJ    30
 |   C                     PARM           $KQTY   30
 |   C                     PARM           $RTN    1
JW2  C                     Z-ADD$KQTY     WKMAIS
      *
     CSR         $S911E    ENDSR
