     H            Y.
     F** VVVRA0 ****************************
     F* CREATE PGM-FILE TABLE              *
     F* %0001 REMOVE CHECK LIGIC FOR MANE  TUCKER *
     F**************************************
     FVVVWPA0 IF  E                    DISK
     FVVVPPA0 O   E                    DISK                      A
      *
     I            DS
     I                                        1  10 WHPNAM
     I                                        4   4 KBN
      *
     I            DS
     I                                        1  11 WHFNAM
     I                                        4   5 PP
      *
     C                     READ VVVWPA0                  81
     C           *IN81     DOWEQ'0'
     C           KBN       IFEQ 'R'
     C           WHOBJT    IFEQ 'F'
     C                     EXSR #SB001
     C                     ENDIF
     C                     ENDIF
     C                     READ VVVWPA0                  81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------*
      *                                         *
      *-----------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     MOVELWHPNAM    VVPNAM
     C                     MOVELWHFNAM    VVFNAM
     C                     MOVEL*BLANK    VVRFI
     C* %0001 REMOVE CHECK LOGIC FOR NAME
     C***        PP        IFEQ 'PP'
     C***        PP        OREQ 'NP'
     C***        PP        OREQ 'TP'
     C***        PP        OREQ 'WP'
     C***        PP        OREQ 'PR'
     C***        PP        OREQ 'PW'
     C                     MOVELWHFNAM    VVRFI
     C***                  ENDIF
     C                     WRITEVVVPPA01
      *
     CSR         ESB001    ENDSR
