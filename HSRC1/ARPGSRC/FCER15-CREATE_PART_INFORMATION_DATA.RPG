     H            Y.                                                      MMM020
     F** FCER15 *************************
     F* CREATE PART INFORMATION DATA   *.
     F*                                     *
     F*                                 *
     F************************* FCER14 **
     FFCEPW15 CF  E                    WORKSTN
     FFCEPL01 IF  E           K        DISK
     FAGAPL31 IF  E           K        DISK
     FFCEWP15 O   E                    DISK                           UC
      *------------------------------------------------------------
     E                    CMD     1   1 75
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------------
      *  MAIN
      *------------------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           K#KEY     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     EXSR #WRT
     C                     MOVE '99'      @@ID
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     MOVE CMD,1     P@CMD
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN FCEWP15
      *
     C           *IN80     DOUEQ*ON
     C                     READ FCEPL01                  80
     C           *IN80     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C           K#KEY     CHAINAGAPL31              90
     C           *IN90     IFEQ *OFF
     C           CBSKJY    ANDEQ*BLANK
     C                     Z-ADDCBBARL    @@BARL
     C                     ELSE
     C                     Z-ADD*ZERO     @@BARL
     C                     ENDIF
     C                     WRITEFCEWP151
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
** CMD
CLRPFM FCEWP15
