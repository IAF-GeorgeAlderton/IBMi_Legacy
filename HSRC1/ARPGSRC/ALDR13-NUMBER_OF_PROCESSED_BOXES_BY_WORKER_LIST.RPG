     H            Y.
     F** ALDR13 ********************************************************
     F*  THE NUMBER OF PROCESSED BOXES BY WORKER LIST FOR SCREEN       *
     F*      DATA SELECT                                               *
     F*                                                                *
     F* TCHK1 04/21/06 CREATE(COPY FROM ALDR05)                        *
     F*  TCH.2004.11.15                                                *
     F*                                                                *
     F* *IN90=1(NOT READ ALDPP20)                                      *
     F* *IN91=1(NOT READ ALDPP30)                                      *
     F* *IN92=1(NOT READ ALDPP40)                                      *
     F* *IN93=1(NOT READ ALBPL30)                                      *
     F********************************************  ALDR13 *************
     FALDPL24 IF  E           K        DISK
     FALDPL34 IF  E           K        DISK
     FALDPL44 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FALDPP70 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALDWP05 O   E                    DISK
     I******************************************************************
     I            DS
     I                                        1  120A1DATI
     I                                        1   80A1DATE
     I                                        1   40A1KSYY
     I                                        5   60A1KSMM
     I                                        7   80A1KSDD
     I                                        9  120A1TIM
     I                                        9  100A1KSJI
     I                                       11  120A1KSPN
     I            DS
     I                                        1  120A3DATI
     I                                        1   80A3DATE
     I                                        1   40A3KSYY
     I                                        5   60A3KSMM
     I                                        7   80A3KSDD
     I                                        9  120A3TIM
     I                                        9  100A3KSJI
     I                                       11  120A3KSPN
     I            DS
     I                                        1  120A5DATI
     I                                        1   80A5DATE
     I                                        1   40A5KSYY
     I                                        5   60A5KSMM
     I                                        7   80A5KSDD
     I                                        9  120A5TIM
     I                                        9  100A5KSJI
     I                                       11  120A5KSPN
     I            DS
     I                                        1   80D5DATE
     I                                        1   40D5YYYY
     I                                        5   60D5MMMM
     I                                        7   80D5DDDD
     I            DS
     I                                        1   80WWDATE
     I                                        1   40WWYY
     I                                        5   60WWMM
     I                                        7   80WWDD
     I            DS
     I                                        1   80KKDATE
     I                                        1   40KYYYY
     I                                        5   60KMMMM
     I                                        7   80KDDDD
     I            DS
     I                                        1   40A2TIM
     I                                        1   20A2KSJI
     I                                        3   40A2KSPN
     I* SYSTEM(TIME + DATE)
     I            DS
     I                                        1  120WWTIME
     I                                        1   6 Z6TIME
     I                                        7  12 Z6DATE
      *
     I            DS
     I                                        1  120X1DATI
     I                                        1   40X1KSYY
     I                                        5   60X1KSMM
     I                                        7   80X1KSDD
     I                                        9  120X1TIM
      *
     I            DS
     I                                        1  120X2DATI
     I                                        1   80X2DAT
     I                                        1   40X2KSYY
     I                                        5   60X2KSMM
     I                                        7   80X2KSDD
     I                                        9  120X2TIM
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PYYYY   40
     C                     PARM           PMMMM   20
     C                     PARM           PDDDD   20
     C                     PARM           P1TIM1  40
     C                     PARM           P1YY2   40
     C                     PARM           P1MM2   20
     C                     PARM           P1DD2   20
     C                     PARM           P1TIM2  40
     C* ALDPL24,ALDPL34,ALDPL44
     C           K1        KLIST
     C                     KFLD           KYYYY
     C                     KFLD           KMMMM
     C                     KFLD           KDDDD
     C*
     C           K2        KLIST
     C                     KFLD           K21     60
      *
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C           P1TIM2    IFEQ *ZERO
     C                     Z-ADD2359      P1TIM2
     C                     ENDIF
      *
     C                     Z-ADDPYYYY     WWYY
     C                     Z-ADDPMMMM     WWMM
     C                     Z-ADDPDDDD     WWDD
      *
     C                     Z-ADDPYYYY     KYYYY
     C                     Z-ADDPMMMM     KMMMM
     C                     Z-ADDPDDDD     KDDDD
      *
     C           K1        SETLLAGDPL12
     C                     READPAGDPL12                  80
     C           *IN80     IFEQ *OFF
     C                     Z-ADDF8KAYY    KYYYY
     C                     Z-ADDF8KAMM    KMMMM
     C                     Z-ADDF8KADD    KDDDD
     C                     ENDIF
     C*
      ******
     C                     Z-ADDPYYYY     KYYYY
     C                     Z-ADDPMMMM     KMMMM
     C                     Z-ADDPDDDD     KDDDD
      ******
     C                     Z-ADD0         X1DATI
     C                     Z-ADD0         X2DATI
     C                     Z-ADDPYYYY     X1KSYY
     C                     Z-ADDPMMMM     X1KSMM
     C                     Z-ADDPDDDD     X1KSDD
     C                     Z-ADDP1TIM1    X1TIM
     C                     Z-ADDP1YY2     X2KSYY
     C                     Z-ADDP1MM2     X2KSMM
     C                     Z-ADDP1DD2     X2KSDD
     C                     Z-ADDP1TIM2    X2TIM
     C           X2DAT     IFEQ 0
     C                     Z-ADD99999999  X2DAT
     C                     ENDIF
     C           X2DAT     IFEQ 0
     C           X2TIM     ANDEQ0
     C                     Z-ADD2359      X2TIM
     C                     ENDIF
      ******
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
     C                     EXSR @P20
     C                     EXSR @P30
     C                     EXSR @P40
     C*
     C                     ENDSR
     C**************************************************************************
     C*          @P20 WRITE ALDPL24
     C**************************************************************************
     C           @P20      BEGSR
     C*
     C                     SETON                     80
     C*
     C           K1        SETLLALDPP201
     C                     READ ALDPP201                 90
B01  C           *IN90     DOWEQ'0'
      *
     C           A1DATI    IFGT X2DATI
     C                     GOTO @SKP1
     C                     ENDIF
      *
     C           A1DATI    IFLT X1DATI
     C                     GOTO @SKP1
     C                     ENDIF
      *
     C           A1OPER    CHAINALDPP70              95
     C* FIRST RECORD
B02  C           *IN80     IFEQ '1'
     C                     SETOF                     80
     C                     MOVE A1OPER    D5OPER
     C                     MOVE A1OPER    K21
     C           K2        CHAINALBPL30              93
B03  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E03  C                     END
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
B03  C           A1OPER    IFNE D5OPER
     C                     WRITEALDWP051
     C                     CLEARALDWP051
     C                     MOVE A1OPER    D5OPER
     C                     MOVE A1OPER    K21
     C           K2        CHAINALBPL30              93
B04  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E04  C                     END
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
     C                     ADD  1         D5BOX
     C                     END
E02  C                     END
     C*
     C           @SKP1     TAG
     C                     READ ALDPP201                 90
E01  C                     END
     C*
     C  N80                WRITEALDWP051
     C  N80                CLEARALDWP051
     C*
     C                     ENDSR
     C**************************************************************************
     C*          @P30 WRITE ALDPL34
     C**************************************************************************
     C           @P30      BEGSR
     C*
     C                     SETON                     80
     C*
     C           K1        SETLLALDPP301
     C                     READ ALDPP301                 91
B01  C           *IN91     DOWEQ'0'
      *
     C           A3DATI    IFGT X2DATI
     C                     GOTO @SKP2
     C                     ENDIF
      *
     C           A3DATI    IFLT X1DATI
     C                     GOTO @SKP2
     C                     ENDIF
      *
     C           A3OPER    CHAINALDPP70              95
     C* FIRST RECORD
B02  C           *IN80     IFEQ '1'
     C                     SETOF                     80
     C                     MOVE A3OPER    D5OPER
     C                     MOVE A3OPER    K21
     C           K2        CHAINALBPL30              93
B03  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E03  C                     END
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
B03  C           A3OPER    IFNE D5OPER
     C                     WRITEALDWP051
     C                     CLEARALDWP051
     C                     MOVE A3OPER    D5OPER
     C                     MOVE A3OPER    K21
     C           K2        CHAINALBPL30              93
B04  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E04  C                     END
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
     C                     ADD  1         D5BOX
E03  C                     END
E02  C                     END
     C*
     C           @SKP2     TAG
     C                     READ ALDPP301                 91
E01  C                     END
     C*
     C  N80                WRITEALDWP051
     C  N80                CLEARALDWP051
     C*
     C                     ENDSR
     C**************************************************************************
     C*          @P40 WRITE ALDPL44
     C**************************************************************************
     C           @P40      BEGSR
     C*
     C                     SETON                     80
     C*
     C           K1        SETLLALDPP401
     C                     READ ALDPP401                 92
B01  C           *IN92     DOWEQ'0'
      *
     C           A5DATI    IFGT X2DATI
     C                     GOTO @SKP3
     C                     ENDIF
      *
     C           A5DATI    IFLT X1DATI
     C                     GOTO @SKP3
     C                     ENDIF
      *
     C           A5OPER    CHAINALDPP70              95
     C* FIRST RECORD
B02  C           *IN80     IFEQ '1'
     C                     SETOF                     80
     C                     MOVE A5OPER    D5OPER
     C                     MOVE A5OPER    K21
     C           K2        CHAINALBPL30              93
B03  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E03  C                     END
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
B03  C           A5OPER    IFNE D5OPER
     C                     WRITEALDWP051
     C                     CLEARALDWP051
     C                     MOVE A5OPER    D5OPER
     C                     MOVE A5OPER    K21
     C           K2        CHAINALBPL30              93
B04  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E04  C                     END
     C                     Z-ADDWWDATE    D5DATE
     C                     ADD  1         D5BOX
     C                     ELSE
     C                     ADD  1         D5BOX
E03  C                     END
E02  C                     END
     C*
     C           @SKP3     TAG
     C                     READ ALDPP401                 92
E01  C                     END
     C*
     C  N80                WRITEALDWP051
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @END
     C**************************************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
