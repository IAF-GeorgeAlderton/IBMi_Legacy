     H            Y.                                    1
      ** IZAR00   **************************************************************
      * WIRE LABELING MENU PROGRAM
      * LEC  CREATE 2025/12/18
      **************************************************************************
     FIZAPW00 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     F**************************************************************************
     E                    ERR     1   2 15
     I**************************************************************************
     I            DS
     I                                        1   80WSDATE
     I                                        1   4 WSYYYY
     I                                        5   6 WSMM
     I                                        7   8 WSDD
     I            DS
     I                                        1  140XXTIME
     I                                        1   60XXHMS
     I                                        7  140XXDATE
      *
      **************************************************************************
      * ENTRY LIST
      **************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PWKCD   6
     C                     PARM           PUSR   10
      **************************************************************************
      * PARAMETER LIST
      **************************************************************************
     C           P1        PLIST
     C                     PARM           PWKCD
     C                     PARM           PUSR
      *
     C           P2        PLIST
     C                     PARM           PWKCD
     C                     PARM           PUSR2  20
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
      **************************************************************************
      *                    @INT
      **************************************************************************
     C           @INT      BEGSR
      *
     C                     TIME           XXTIME
     C                     SETOF                     303132
     C                     MOVEL*BLANK    MSG
     C                     MOVELPUSR      PUSR2            NAME
     C                     MOVELPWKCD     WKCD    60
      *
     C                     ENDSR
      **************************************************************************
      *                    @MAIN
      **************************************************************************
     C           @MAIN     BEGSR
      *
     C           *IN01     DOWEQ*OFF
     C                     MOVEL*BLANK    SNO
     C                     EXFMTIZAPW001
     C                     SETOF                     303132
     C                     MOVEL*BLANK    MSG
      * F3=End
     C           *IN01     IFEQ *ON
      * Enter
     C                     ELSE
      * Worker Code Check
     C           WKCD      CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDNE'D'
      *
     C                     MOVE ALWKCD    POPR    6        SET WORKER ID
     C                     MOVEL*BLANK    PUSR2
     C                     MOVELALWKNM    PUSR             SET NAME
     C                     MOVELALWKNM    PUSR2            SET NAME
      *
     C                     SELEC
      * print wire kanban info
     C           SNO       WHEQ '1'
     C                     CALL 'IZAR465S'
      * print wire sample tags
     C           SNO       WHEQ '2'
     C                     CALL 'IZAC65S2'
      * print wire lot id tags
     C           SNO       WHEQ '3'
     C                     CALL 'IZAC65S'
      ** otherwise, error
     C                     OTHER
     C                     SETON                     3032
     C                     MOVEAERR,2     MSG
     C                     ENDSL
      **
      *  NOT in worker code master file
     C                     ELSE
     C                     SETON                     3031
     C                     MOVEAERR,1     MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDSR
      **************************************************************************
      *                    @END
      **************************************************************************
     C           @END      BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     ENDSR
      **************************************************************************
** ERR
USER CODE ERROR
INPUT NO. ERROR
