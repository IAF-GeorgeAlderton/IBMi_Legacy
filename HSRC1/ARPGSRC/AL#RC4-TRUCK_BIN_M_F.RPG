     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KIHZ  8
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *全部削除
     C                     EXSR #SB400
      *
     C           *LOVAL    SETLLAL#WPC11
     C                     READ AL#WPC11                 80
     C           *IN80     DOWEQ'0'
     C           W1SURT    IFNE *BLANK
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ AL#WPC11                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      *全部削除
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVE P1KIHZ    K1KIHZ  80
     C           K1KIHZ    SETLLAL#PPC11
     C           K1KIHZ    READEAL#PPC11                 25
     C           *IN25     DOWEQ'0'
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'D'       C5SKJY
     C                     Z-ADD*DATE     C5SKHZ
     C                     UPDATAL#PPC11
     C                     ENDIF
     C           K1KIHZ    READEAL#PPC11                 25
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYCC     KLIST
     C                     KFLD           K1KIHZ  80
     C                     KFLD           W1TRKB
     C                     MOVE P1KIHZ    K1KIHZ  80
     C           KEYCC     CHAINAL#PPC11             25
     C                     CLEARAL#PPC11
     C                     MOVEL*BLANK    C5SKJY
     C                     Z-ADD0         C5SKHZ
     C                     Z-ADD*DATE     C5KOHZ
     C                     TIME           C5KOTI
     C                     MOVELW#USER    C5KOME
     C                     MOVELW1TRKB    C5TRKB
     C                     MOVELW1SURT    C5SURT
     C                     Z-ADDW1STTN    C5STTN
     C                     Z-ADDW1EDTN    C5EDTN
     C                     MOVE P1KIHZ    C5KIHZ
     C           *IN25     IFEQ '0'
     C                     UPDATAL#PPC11
     C                     ELSE
     C                     WRITEAL#PPC11
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
