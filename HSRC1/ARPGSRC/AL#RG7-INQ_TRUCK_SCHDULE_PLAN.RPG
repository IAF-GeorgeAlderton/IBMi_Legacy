JW1  F*  J.WATANABE  2021.08.16 ADD ORIGINAL TIME          *
     F******************************************** AL#RG7 **
     FAL#PWG7 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FAGDPL12 IF  E           K        DISK
     FAL#WPG5 IF  E           K        DISK
      *
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I            DS
     I                                        1   80WKSDAT
     I                                        1   60WKSYM
     I                                        1   40WKSDYY
     I                                        5   60WKSDMM
     I                                        7   80WKSDDD
     I            DS
     I                                        1   80F8KYMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *-----------------------------------------------------
      *  ENTRY LIST
      *-----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P1SDAT  80
     C                     PARM           P1EDAT  80
      *-----------------------------------------------------
      *  KEY LIST
      *-----------------------------------------------------
     C           KEYAG     KLIST
     C                     KFLD           WKSDYY
     C                     KFLD           WKSDMM
     C                     KFLD           WKSDDD
      *-----------------------------------------------------
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     Z-ADDP1SDAT    WKSDAT
     C                     Z-ADD0         @KAD    40
      * GET WORKING DATE
     C           KEYAG     SETLLAGDPL121
     C                     READ AGDPL121                 81
     C           *IN81     DOWEQ'0'
     C           F8KYMD    IFGT P1EDAT
     C                     LEAVE
     C                     ENDIF
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @KAD
     C                     ENDIF
     C                     READ AGDPL121                 81
     C                     ENDDO
      *
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITESFCTL1
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ AL#WPG5                  90
     C   90                LEAVE
     C*
     C                     SELEC
     C           W3WDIV    WHEQ '1'
     C                     MOVEL'E.G.BOLT'@WDIV
     C           W3WDIV    WHEQ '2'
     C                     MOVEL'PULLING '@WDIV
     C           W3WDIV    WHEQ '3'
     C                     MOVEL'PACKING '@WDIV
     C                     ENDSL
     C*
     C                     MOVELW3TRKB    @TRKB
     C                     MOVELW3SURT    @SURT
     C*
     C           W3PERC    MULT 100       @PERC
     C*
     C           W3BOX     DIV  @KAD      @BOXD
     C                     MVR            WK2BOX  83       MVR
   S2C           WK2BOX    IFNE 0
     C                     ADD  1         @BOXD
   E2C                     ENDIF
     C*
     C                     Z-ADDW3PLST    @PLST
     C                     Z-ADDW3PLED    @PLED
      *
JW1  C                     Z-ADDW3STTN    @STTN
 "   C                     Z-ADDW3EDTN    @EDTN
JW1  C                     Z-ADDP1SDAT    H@SDAT
 "   C                     Z-ADDP1EDAT    H@EDAT
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F1 *
      *----*
     C   KA                MOVE '#END    '@STEP
     C                     ENDSR
