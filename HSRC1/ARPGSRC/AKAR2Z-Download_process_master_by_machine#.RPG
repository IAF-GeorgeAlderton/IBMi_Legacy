      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #SCRN1
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     TIME           W@TIME
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*BLANK    F1MCN#
     C                     SETOF                     4149
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KA                LEAVE
     C                     MOVEL*OFF      W@ERR   1
     C                     SETOF                     4149
     C                     EXSR #CHK1
     C           W@ERR     IFEQ *ON
     C                     ITER
     C                     END
     C           *INKE     IFEQ *ON
     C                     MOVEL*OFF      W@OUT   1
     C                     EXSR #OUT
     C           W@OUT     IFEQ *OFF
     C                     SETON                     4149
     C                     MOVELEMSG,2    MSG
     C                     ITER
     C                     END
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*   CHECK
     C*------------------------------------------------------
     C           #CHK1     BEGSR
     C*
     C           F1MCN#    IFEQ *BLANK
     C                     MOVELEMSG,1    MSG
     C                     SETON                     4149
     C                     MOVEL*ON       W@ERR
     C                     ENDIF
     C*
     C                     ENDSR
      *------------------------------------------------------
      *   DATA CREATE
      *------------------------------------------------------
     C           #OUT      BEGSR
     C*
     C           *LOVAL    SETLLAAMPL11
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AAMPL11                  98
     C   98                LEAVE
     C           CKSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     Z-ADD1         X       20
     C           F1MCN#    LOKUPNMCN,X                   90
     C  N90                ITER
     C*
     C                     CLEARAKAWP2Z1
     C                     MOVELCKHIN1    AKHIN1
     C                     MOVELCKHIN2    AKHIN2
     C                     MOVELCKHIN3    AKHIN3
     C*
     C                     Z-ADD*ZERO     W@GEKN  90
     C                     Z-ADD*ZERO     W@SSYS  70
     C           K#FCE     KLIST
     C                     KFLD           CKHIN1
     C                     KFLD           CKHIN2
     C                     KFLD           CKHIN3
     C           K#FCE     CHAINFCEPL01              97
     C           *IN97     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     Z-ADDA2GEKN    W@GEKN
     C                     Z-ADDA2SSYS    W@SSYS
     C                     ENDIF
      *
     C           K#FCE     CHAINFCEPL11              97
     C           *IN97     IFEQ *OFF
     C           FCSKJY    ANDEQ*BLANK
     C           FCGK01    DIV  FCCD01    @@QTY   90
     C           @@QTY     MULT 20        W@GEKN
     C                     ENDIF
     C*
     C           W@SSYS    IFNE *ZERO
     C           W@GEKN    DIV  W@SSYS    W@BKPM 103
     C           W@BKPM    DIV  20        W@20DY  93
     C           W@20DY    ADD  0.009     AKBXPD
     C                     END
     C*
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           Y         IFGT 15
     C                     LEAVE
     C                     END
     C           NPRC,Y    IFEQ *BLANK
     C                     ITER
     C                     END
     C                     MOVEL*BLANK    W@P@B
     C                     MOVELNPRC,Y    W@PRC
     C           W@PRC3    IFEQ *BLANK
     C                     MOVELNPRC,Y    W@PRCB
     C           NBMN,Y    IFNE *ZERO
     C                     MOVEL'-'       W@DASB
     C                     MOVELNBMN,Y    W@BMNB
     C                     END
     C                     ELSE
     C                     MOVELNPRC,Y    W@PRCA
     C           NBMN,Y    IFNE *ZERO
     C                     MOVEL'-'       W@DASA
     C                     MOVELNBMN,Y    W@BMNA
     C                     END
     C                     END
     C                     MOVELW@P@B     OP@B,Y
     C                     ENDDO
     C*
     C                     MOVEANMCN      OMCN
     C                     MOVEANLOC      OLOC
     C*
     C                     WRITEAKAWP2Z1
     C                     MOVEL*ON       W@OUT
     C*
     C                     ENDDO
     C*
     C                     ENDSR
** EMSG
