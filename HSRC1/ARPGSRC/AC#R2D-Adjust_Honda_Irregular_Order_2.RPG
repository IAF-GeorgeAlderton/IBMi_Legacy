     H            Y.
     F** AC#R2D *********************************************
     F*  PROGRAM: ADJUST HONDA IRREGULAR ORDER 2            *
     F*          (DETECT DIFFERENT SHIP CODE IN SAME BIN#)  *
     F*  WRITTEN: JW (SRA) 2019.03.04                       *
     F******************************************************
     FAB#PL2S UF  E           K        DISK
     FAB#PL2ABIF  E           K        DISK
     F            AB#PP2A1                          KRENAMEAB#PL2X
     FAB#PL1L IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      *===================================================
     E                    MSG     1   2 60
      *-----------------------------------------------------------
     IAB#PL2X     01
     I              ACKYMD                          XCKYMD
     I              ACKTIM                          XCKTIM
     I              ACKPGM                          XCKPGM
     I              ACEDID                          XCEDID
     I              ACPLNT                          XCPLNT
     I              ACPLNM                          XCPLNM
     I              ACSHCD                          XCSHCD
     I              ACSHNM                          XCSHNM
     I              ACSUPP                          XCSUPP
     I              ACSUNM                          XCSUNM
     I              ACPLSH                          XCPLSH
     I              ACPLDL                          XCPLDL
     I              ACSHTM                          XCSHTM
     I              ACDLTM                          XCDLTM
     I              ACSCQL                          XCSCQL
     I              ACSCAC                          XCSCAC
     I              ACSHNO                          XCSHNO
     I              ACPRJC                          XCPRJC
     I              ACMHIN                          XCMHIN
     I              ACMHN1                          XCMHN1
     I              ACMHN2                          XCMHN2
     I              ACMHN3                          XCMHN3
     I              ACMHN4                          XCMHN4
     I              ACCOLR                          XCCOLR
     I              ACMNAM                          XCMNAM
     I              ACREVN                          XCREVN
     I              ACAUTH                          XCAUTH
     I              ACLOTN                          XCLOTN
     I              ACSLTN                          XCSLTN
     I              ACLTSQ                          XCLTSQ
     I              ACRTNB                          XCRTNB
     I              ACCTTP                          XCCTTP
     I              ACPLTP                          XCPLTP
     I              ACTOKU                          XCTOKU
     I              ACNONY                          XCNONY
     I              ACNKOJ                          XCNKOJ
     I              ACNUKE                          XCNUKE
     I              ACODRN                          XCODRN
     I              ACBIN                           XCBIN
     I              ACSERL                          XCSERL
     I              AC864                           XC864
     I              ACCQTY                          XCCQTY
     I              ACQNTY                          XCQNTY
     I              ACUPID                          XCUPID
     I              ACRENO                          XCRENO
     I              ACCRDT                          XCCRDT
     I              ACSAD1                          XCSAD1
     I              ACSAD2                          XCSAD2
     I              ACCITY                          XCCITY
     I              ACSTAT                          XCSTAT
     I              ACZIPC                          XCZIPC
     I              ACCNTY                          XCCNTY
     I              ACASDT                          XCASDT
     I              ACTRLR                          XCTRLR
     I              ACTMQL                          XCTMQL
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1   80ACPLSH
     I                                        1   50XXNOYY
     I                                        5   60XXNOMM
     I                                        7   80XXNODD
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#PL2S                  88
     C   88                LEAVE
      *  CHECK QTY=0
     C           ACQNTY    IFEQ 0
     C                     ITER
     C                     ENDIF
      *  CHECK DATE
     C           ACPLSH    IFLT TODAY
     C                     ITER
     C                     ENDIF
      *  CHECK IF EXIST IN PP10
     C                     EXSR #CHK1
     C           *IN86     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *  FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELACNONY    SVNONY  40
     C                     MOVELACNKOJ    SVNKOJ  1
     C                     MOVELACNUKE    SVNUKE  4
     C                     MOVELACPLSH    SVPLSH  80
     C                     MOVELACBIN     SVBIN   20
     C                     MOVELACSHCD    SVSHCD 10
     C                     ENDIF
      * BREAK ?
     C           ACNONY    IFNE SVNONY
     C           ACNKOJ    ORNE SVNKOJ
     C           ACNUKE    ORNE SVNUKE
     C           ACPLSH    ORNE SVPLSH
     C           ACBIN     ORNE SVBIN
     C                     EXSR #BREAK
     C                     ENDIF
      * DETAIL
     C           ACSHCD    IFNE SVSHCD
     C                     EXSR #BIN
      * EXIST --> DELETE
     C           *IN85     IFEQ *OFF
     C                     MOVELMSG,1     XMSG   30
     C                     EXSR #PRINT
     C           $UPFLG    IFEQ 'Y'
     C                     MOVE 'D'       ACUPID
     C                     MOVEL'AC#R2D  'ACCOLR
     C                     UPDATAB#PP2A1
     C                     ENDIF
     C                     ENDIF
      * NOT EXIST --> CAHANGE BIN#
     C           *IN85     IFEQ *ON
     C                     EXSR #PRINT
      * UPDATE
     C           $UPFLG    IFEQ 'Y'
     C                     Z-ADD@@BIN#    ACBIN
     C                     MOVEL'AC#R2D  'ACCOLR
     C                     UPDATAB#PP2A1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      * SET RETURN FLAG
     C           SEQ#      IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      * PRINT FOOT
     C           SEQ#      IFEQ 0
     C           $UPFLG    ANDEQ'N'
     C                     EXCPT@FOT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * DETECT IF ORDER IS IN AB#PP10
      * *IN86=OFF: EXIST
      * *IN86=ON : NOT EXIST
      *======================================================
     C           #CHK1     BEGSR
      *
     C                     MOVE *ON       *IN86
      * SET KEY
     C                     Z-ADDACNONY    KANONY
     C                     Z-ADDXXNOYY    KANOYY
     C                     Z-ADDXXNOMM    KANOMM
     C                     Z-ADDXXNODD    KANODD
     C                     MOVEL'00  '    KANUKE
     C                     MOVELACODRN    KAODRN
     C                     MOVELACMHN1    KKMHN1
     C                     MOVELACMHN2    KAMHN2
     C                     MOVELACMHN3    KAMHN3
     C                     MOVELACMHN4    KAMHN4
      *
     C           K#PL1L    SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#PL1L    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFNE 'D'
     C                     MOVE *OFF      *IN86
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * BREAK PROCESS
      *======================================================
     C           #BREAK    BEGSR
      *
     C                     MOVELACNONY    SVNONY
     C                     MOVELACNKOJ    SVNKOJ
     C                     MOVELACNUKE    SVNUKE
     C                     MOVELACPLSH    SVPLSH
     C                     MOVELACBIN     SVBIN
     C                     MOVELACSHCD    SVSHCD
      *
     C                     ENDSR
      *======================================================
      * DETECT ORDER ALREADY EXISTS IN PP2A ?
      * *IN85=OFF: EXIST
      * *IN85=ON : NOT EXIST
      *======================================================
     C           #BIN      BEGSR
      *
     C                     MOVE *ON       *IN85
     C                     Z-ADD0         @@BIN#  20
      * CHECK DUPLICATE
     C                     Z-ADDACTOKU    KCTOKU  40
     C                     Z-ADDACNONY    KCNONY  40
     C                     Z-ADDACPLSH    KCPLSH  80
     C                     MOVELACPLNT    KCPLNT  3
     C                     MOVELACSHCD    KCSHCD 10
     C           K#2AB     SETLLAB#PL2AB
     C                     DO   *HIVAL
     C           K#2AB     READEAB#PL2AB                 95
     C   95                LEAVE
      *
     C           XCBIN     IFEQ ACBIN
     C                     ITER
     C                     ENDIF
      *
     C           XCUPID    IFNE 'D'
     C                     MOVE *OFF      *IN85
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           XBIN      ENDSR
      *======================================================
      * PRINT
      *======================================================
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 60
     C                     EXCPT@HDR1
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     MOVELACODRN    XXODRN 11
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPFLG  1
     C                     PARM           $RTN    1
      *
     C           K#2AB     KLIST
     C                     KFLD           KCTOKU  40
     C                     KFLD           KCNONY  40
     C                     KFLD           KCPLSH  80
     C                     KFLD           KCPLNT  3
     C                     KFLD           KCSHCD 10
      *
     C           K#PL1L    KLIST
     C                     KFLD           KANONY  40
     C                     KFLD           KANOYY  40
     C                     KFLD           KANOMM  20
     C                     KFLD           KANODD  20
     C                     KFLD           KANUKE  4
     C                     KFLD           KAODRN 10
     C                     KFLD           KKMHN1  5
     C                     KFLD           KAMHN2  5
     C                     KFLD           KAMHN3  5
     C                     KFLD           KAMHN4  5
      *
     C           $UPFLG    IFNE 'Y'
     C                     MOVE 'N'       $UPFLG
     C                     ENDIF
      *
     C                     MOVE *BLANK    $RTN
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD80        LIN#    30
     C                     TIME           SDATE
      *
     C           LIN#      IFGE 60
     C                     EXCPT@HDR1
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ENDSR
      *====================================================
     OQPRINT  E   01           @HDR1
     O                         #PGM      10
     O                                   40 '** HONDA IRREGULAR O'
     O                                   60 'RDER REPORT **   UPD'
     O                                   64 'FLG='
     O                         $UPFLG    65
     O                                   99 'DATE'
     O                         TODAY    102 '    /  /  '
     O                         NOW      112 '  :  :  '
     O                                  116 'P.'
     O                         PAGE  Z  120
     O        E   02           @HDR1
     O                                   40 '** DETECT DIFFERENT '
     O                                   60 'SHIP CODE IN SAME BI'
     O                                   80 'N# **               '
     O        E   03           @HDR1
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'NONY'
     O                                   27 'SHP DATE'
     O                                   34 'BIN#'
     O                                   41 'ORDER#'
     O                                   56 'USER PART'
     O                                   72 'PLANT'
     O                                   80 'SHIP TO'
     O                                   93 'QTY'
      *
     O        E 1              @DTL1
     O                         SEQ#  Z +001
     O                         ACTOKU  +002
     O                         ACNONY  +002
     O                         ACPLSH  +002 '    /  /  '
     O                         ACBIN   +002
     O                         XXODRN  +002
     O                         ACMHIN  +001
     O                         ACPLNT  +001
     O                         ACSHCD  +002
     O                         ACQNTYZ +001
     O                         XMSG    +002
      *
     O        E 1              @FOT1
     O                                   22 '** NO TARGET ORDER **'
** MSG   +.........+.........+
ORDER REPLACED
BIN# HAS BEEN CHANGED.
