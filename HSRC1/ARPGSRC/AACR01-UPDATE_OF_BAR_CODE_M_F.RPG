     H            Y.
     **** AACR01 **********************************
     **   UPDATE OF BAR CODE M/F      ..RPG..     *
     **                               86.08.27    *
     **********************************************
     FAACPW01 CF  E                    WORKSTN
     FAACPL01 UF  E           K        DISK                      A
     FFGBPL01 IF  E           K        DISK
     E                    KOS     1   3  1   KON     6   ﾃcﾆ]hﾎﾞ]
     E                    ER      1  10 60
     I            DS
     I                                        1   60WTIME
     I                                        1   20T8KOHH
     I                                        3   40T8KOSS
     I            DS
     I                                        1   80T8SKHZ
     I                                        1   40T8SKYY
     I                                        5   60T8SKMM
     I                                        7   80T8SKDD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   80T8KOHZ
     I                                        1   40T8KOYY
     I                                        5   60T8KOMM
     I                                        7   80T8KODD
     C           *ENTRY    PLIST
     C                     PARM           USER   10        ﾏｰﾅﾞｰ xb
     C                     Z-ADD0         T8SKHZ
     C           STP1      TAG
     C                     EXFMTAACPW011
     C                     SETOF                     010299
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C*----------------------------------------*
     C*     ...更新区分　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C                     Z-ADD1         A       10
     C           KTYPE     LOKUPKOS,A                    90
     C           *IN90     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      ERRMSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KON,A     WNAME
     C*
     C*------------------------------------------*
     C*     ...部門コード　の　チェック...     *
     C*------------------------------------------*
     C                     MOVE WBMNCD    T8BUKO
     C           WBMNCD    IFLT '0'
     C                     SETON                     0299
     C                     MOVE ER,2      ERRMSG
     C                     GOTO STP1
     C                     END
     C*----------------------------------------*
     C*     ...マスター　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C           T8BUKO    CHAINAACPL011             90
     C           KTYPE     IFEQ '2'
     C           *IN90     IFEQ '0'
     C           T8SKJY    IFEQ 'D'
     C           T8SKHZ    ANDLE*DATE
     C                     GOTO STP3
     C                     END
     C                     SETON                     010299
     C                     MOVE ER,3      ERRMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C           KTYPE     IFEQ '1'
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,4      ERRMSG
     C                     GOTO STP1
     C                     END
     C           T8SKJY    IFEQ 'D'
     C           T8SKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,5      ERRMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C           KTYPE     IFEQ '0'
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,6      ERRMSG
     C                     GOTO STP1
     C                     END
     C           T8SKJY    IFEQ 'D'
     C           T8SKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,7      ERRMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           STP3      TAG
     C*--------------------*
     C*   細目マスター   *
     C*--------------------*
     C                     SETOF                     30
     C           T8BUKO    CHAINFGBPL011             30
     C           *IN30     IFEQ '1'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0299
     C                     MOVE ER,10     ERRMSG
     C                     GOTO STP1
     C                     END
     C                     MOVELB2SMEI    WNM
     C*
     C           KTYPE     IFEQ '2'
     C                     MOVE *BLANK    BKO1
     C                     MOVE *BLANK    BKO2
     C                     ELSE
     C                     MOVE T8BKO1    BKO1
     C                     MOVE T8BKO2    BKO2
     C                     END
     C*
     C*------------------------------*
     C*     ...画面　－　２...     *
     C*------------------------------*
     C           STP4      TAG
     C                     EXFMTAACPW012
     C                     SETOF                     040599
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
     C*
     C*--------------------------------------*
     C*     ...設定名　の　チェック...     *
     C*--------------------------------------*
     C           BKO1      IFEQ *BLANK
     C                     MOVE '0'       BKO1
     C                     END
     C           BKO1      IFLT '0'
     C                     SETON                     0499
     C                     MOVE ER,8      ERRMSG
     C                     GOTO STP4
     C                     END
     C*
     C           BKO2      IFLT '00'
     C                     SETON                     0599
     C                     MOVE ER,9      ERRMSG
     C                     GOTO STP4
     C                     END
     C*
     C                     MOVE BKO1      T8BKO1
     C                     MOVE BKO2      T8BKO2
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO STP4
     C                     END
     C*
     C           KTYPE     IFEQ '0'
     C                     MOVE 'D'       T8SKJY
     C                     Z-ADD*DATE     T8SKHZ
     C                     ELSE
     C                     MOVE *BLANK    T8SKJY
     C                     Z-ADD0         T8SKHZ
     C                     END
     C                     Z-ADD*DATE     T8KOHZ
     C                     TIME           WTIME
     C           *IN90     IFEQ '0'
     C                     UPDATAACPL011
     C                     ELSE
     C                     WRITEAACPL011
     C                     END
     C*
     C                     MOVE KTYPE     MTYPE
     C                     MOVE WBMNCD    MBMNCD
     C                     MOVE WNAME     MNAME
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C*
     C*----------------------------------------*
     C*         ...サブルーチン...           *
     C*     ...画面－１　の　クリアー...     *
     C*----------------------------------------*
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    WBMNCD
     C                     ENDSR
**  KOS.KON
0CANCEL
1CHANGE
2ADD
**  MSG (ERROR MESSAGE)
E-01 UPDATE INSTRUCTION IS <0 1 2>
E-02 INPUT SECTION CODE WITH NUMBER
E-03 ADD WAS APPOINTED BUT M/F EXIST
E-04 CHANGE WAS APPOINTED BUT M/F DON'T EXIST
E-05 CHANGE WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-06 CANCEL WAS APPOINTED BUT M/F DON'T EXIST
E-07 CANCEL WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-08 INPUT BAR CODE(1  COLUMN)  WITH  NUMBER
E-09 INPUT BAR CODE(2 COLUMN) WITH NUMBER
E-10 DEPARTMENT CODE IS NOT IN DETAILS M/F
