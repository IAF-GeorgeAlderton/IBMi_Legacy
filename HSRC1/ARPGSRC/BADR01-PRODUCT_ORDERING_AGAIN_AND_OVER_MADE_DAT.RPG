     H            Y.
     F** BADR01 **********************************
     F*PRODUCT ORDERING AGAIN AND OVER MADE  DATA SITUATION LIST
     F* PROGRAM ID. : BADR01. <RPG> *
     F* CREATE DATE. : MAR.08,'90.               *
     F* AUTHOR.         : E.KAWASHIMA            *
     F********************************** BADR01 **
     FADAPP01 IF  E                    DISK
     FBADWP01 O   F     100            DISK
     I            DS
     I                                        1   80ADKOHZ
     I                                        1   40ADKOYY
     I                                        5   60ADKOMM
     I                                        7   80ADKODD
     I            DS
     I                                        1  10 ADKOME
     I                                        1   2 WKOME
     I                                        1   5 WKOM5
     C******************************************************
     C*  START  PROGRAM  <BADR01>                          *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           @KBN    1
     C                     PARM           @KOJO   4
     C                     PARM           @STHZ   8
     C                     PARM           @ENHZ   8
     C                     MOVEL@KOJO     KOJO    40
     C                     MOVE @STHZ     STHZ    80
     C                     MOVE @ENHZ     ENHZ    80
     C*
     C           @KBN      IFEQ '1'
     C                     MOVEL'S'       KBN     1
     C                     ELSE
     C                     MOVEL'T'       KBN
     C                     END
     C*
     C*  mﾞｰj qgjﾞﾆ
     C*
B001 C                     DO   *HIVAL
     C                     READ ADAPP011                 10
B002 C           *IN,10    IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
E002 C                     END
     C*
B002 C           *IN,10    IFEQ '0'
     C*
     C           WKOME     IFNE 'A0'
     C           WKOM5     IFNE 'A2002'
     C           WKOM5     ANDNE'A2024'
     C           WKOM5     ANDNE'A2027'
     C           WKOM5     ANDNE'A2028'
     C                     GOTO @END
     C                     END
     C                     END
     C*
B003 C           @KBN      IFNE '3'
     C           KBN       CABNEADDTKB    @END
E003 C                     END
     C*
B003 C           KOJO      IFNE 9999
     C           ADZBMN    CABNEKOJO      @END
E003 C                     END
     C*
     C           STHZ      CABGTADKOHZ    @END
     C           ENHZ      CABLTADKOHZ    @END
     C*
     C                     SETON                     U1
     C                     EXCPTF01
     C*
E002 C                     END
     C           @END      TAG
E001 C  N10                END
     C*
     C*
     C*
     OBADWP01 E                F01
     O                         KOJO       4
     O                         ADHIN1     9
     O                         ADHIN2    14
     O                         ADHIN3    16
     O                         ADKBN1    19
     O                         ADKBN2    20
     O                         ADMAIS    23
     O                         ADKAIS    28
     O                         ADSYOS    33
     O                         ADSYOT    34
     O                         ADMBMN    38
     O                         ADZBMN    42
     O                         ADCHAK    44
     O                         ADLAIN    45
     O                         ADDTKB    46
     O                         ADKOYY    50
     O                         ADKOMM    52
     O                         ADKODD    54
     O                         @KBN      55
