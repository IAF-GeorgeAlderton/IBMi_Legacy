     H** AB#RH3 *******************************************************
     H* UPDATE OF HONDA (DISTRIBUTING MASTER)                           *
     H*
     H*  KIRI 15.09.01
     H*****************************************************************
     H            Y/                                    1
     FAB#PWH3 CF  E                    WORKSTN
     F                                              KINFDS INFDS
      * DETAIL CODE MANAGEMENT RECORD .LAYOUT ..LOGICAL FILE ..        *
     FFGBPL01 IF  E           K        DISK
      *
     FAB#PPHD UF  E           K        DISK                      A
      *================================================================
     E                    MSG     1  20 60               d[ｰ xｮﾈｰﾆﾞ
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2 F5'#CHK2
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *   << INIT >>
      *===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1KBN
     C                     Z-ADD0         D1TOKU
     C                     Z-ADD0         D1NONY
     C                     MOVE *BLANK    D1SHCD
     C                     MOVE *BLANK    D1ERR            エラー
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00000000'*IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    D1ERR            エラー
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F12 >  INQUIRY
     C           *INKL     IFEQ *ON
     C                     Z-ADDD1TOKU    P@TOKU
     C                     Z-ADDD1NONY    P@NONY
     C                     MOVELD1SHCD    P@SHCD
     C                     CALL 'AB#RH4'
     C                     PARM           P@TOKU  40
     C                     PARM           P@NONY  40
     C                     PARM           P@SHCD 10
     C           P@TOKU    IFNE 0
     C           P@NONY    ORNE 0
     C           P@SHCD    ORNE *BLANK
     C                     Z-ADDP@TOKU    D1TOKU
     C                     Z-ADDP@NONY    D1NONY
     C                     MOVELP@SHCD    D1SHCD
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C*--------------------
     C* D1KBN (21)
     C*--------------------
     C                     SELEC
     C           D1KBN     WHEQ '0'
     C                     MOVEL'0-CANCEL'D2KBN
     C                     SETON                     30
     C           D1KBN     WHEQ '1'
     C                     MOVEL'1-CHANGE'D2KBN
     C                     SETOF                     30
     C           D1KBN     WHEQ '2'
     C                     MOVEL'2-ADD   'D2KBN
     C                     SETOF                     30
     C                     OTHER
     C                     SETON                     2199
     C                     MOVELMSG,1     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDSL
     C*--------------------
     C* D1TOKU (22)
     C*--------------------
     C                     MOVEL*BLANK    D2TNAM
     C           D1TOKU    IFNE 0
     C           D1TOKU    CHAINFGBPL01              91
     C  N91      B2SKJY    IFEQ 'D'
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C                     SETON                     2299
     C                     MOVELMSG,2     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     MOVELB2SMEI    D2TNAM
     C                     ENDIF
     C*--------------------
     C* D1NONY (23)
     C*--------------------
     C                     MOVEL*BLANK    D2NNAM
     C           D1NONY    IFNE 0
     C           D1NONY    CHAINFGBPL01              91
     C  N91      B2SKJY    IFEQ 'D'
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C                     SETON                     2399
     C                     MOVELMSG,3     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     MOVELB2SMEI    D2NNAM
     C                     ENDIF
     C*--------------------
     C* D1SHCD (24)
     C*--------------------
     C           D1TOKU    IFEQ 0
     C           D1NONY    ANDEQ0
     C                     SETON                     222399
     C                     MOVELMSG,4     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C*--------------------
     C           KEY01     KLIST
     C                     KFLD           D1TOKU
     C                     KFLD           D1NONY
     C                     KFLD           D1SHCD
     C*
     C           KEY01     CHAINAB#PPHD             N90
     C  N90      ADSKJY    IFEQ 'D'                        DELETE CODE
     C           ADSKDT    ANDLE@SYSHZ                     DELETE DATE
     C                     SETON                     90
     C                     ENDIF
     C*
S1   C           *IN90     IFEQ *OFF
     C           D1KBN     IFEQ '2'                        2-ADD
     C                     SETON                     212223
     C                     SETON                     24  99
     C                     MOVELMSG,6     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     MOVE ADDEST    D2DEST
X1   C                     ELSE
     C           D1KBN     IFNE '2'                        NE 2-ADD
     C                     SETON                     212223
     C                     SETON                     24  99
     C                     MOVELMSG,5     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     MOVE *BLANK    D2DEST
E1   C                     ENDIF
     C*-------------------------
     C           @CHK1Z    TAG
     C*-------------------------
     C*
S1   C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
X1   C                     ELSE
     C                     MOVEA'00000000'*IN,31
     C                     MOVEL*BLANK    D2ERR
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     EXFMTDSP02
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,31
     C                     MOVE *BLANK    D2ERR
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVEA'00000000'*IN,21
     C                     MOVE *BLANK    D1ERR
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2 F5'@STEP
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE '#UPDAT  '@STEP
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　チェック
      *===============================================================
     C           #CHK2     BEGSR
      *--------------------
      * DESTINATION (31)
      *--------------------
     C                     SELEC
     C           D2DEST    WHEQ *BLANK
     C                     SETON                     3199
     C                     MOVELMSG,7     D2ERR
     C                     GOTO @CHK2Z
     C           D2DEST    WHEQ '1'
     C           D2DEST    WHEQ '2'
     C                     OTHER
     C                     SETON                     3199
     C                     MOVELMSG,8     D2ERR
     C                     GOTO @CHK2Z
     C                     ENDSL
     C*-------------------------
     C           @CHK2Z    TAG
     C*-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2 F5'
     C                     MOVEL'#UPDAT  '@STEP
     C                     ELSE
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  更新処理
      *===============================================================
     C           #UPDAT    BEGSR
     C*
     C           KEY01     CHAINAB#PPHD              90
     C*
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE 'D'       ADSKJY           DELETE CODE
     C                     Z-ADD@SYSHZ    ADSKDT           DELETE DATE
     C  N90                UPDATAB#PPHD1
     C                     ELSE
     C                     MOVE *BLANK    ADSKJY           DELETE CODE
     C                     Z-ADD0         ADSKDT           DELETE DATE
     C                     Z-ADD@SYSHZ    ADKODT           UPDATE DATE
     C                     Z-ADD@SYSTM    ADKOTM           UPDATE TIME
     C                     MOVELW@PGM     ADKOME           UPDATE PGM
     C                     MOVELW@USER    ADPGMN           UPDATE USER
     C                     Z-ADDD1TOKU    ADTOKU
     C                     Z-ADDD1NONY    ADNONY
     C                     MOVELD1SHCD    ADSHCD
     C                     MOVE D2DEST    ADDEST
     C   90                WRITEAB#PPHD1
     C  N90                UPDATAB#PPHD1
     C                     ENDIF
      *
     C                     MOVE *BLANK    D1KBN
     C                     Z-ADD0         D1TOKU
     C                     Z-ADD0         D1NONY
     C                     MOVE *BLANK    D1SHCD
     C                     MOVE *BLANK    D1ERR
     C                     MOVEA'00000000'*IN,21
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
      *===============================================================
**  MSG
 INPUT < 0.1.2. > FOR UPDATE INSTRUCTION
 CUSTMER CODE IS NOT IN MASTER FILE.
 DELIVERY CODE IS NOT IN MASTER FILE.
 INPUT CUSTMER CODE OR DELIVERY CODE
 IT IS NOT IN MASTER FILE.
 IT HAS BEEN ALREADY ADDED
 INPUT DESTINATION
 DESTINATION IS "1" OR "2"


