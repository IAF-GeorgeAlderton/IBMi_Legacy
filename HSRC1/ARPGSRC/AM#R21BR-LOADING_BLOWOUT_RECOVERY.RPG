      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *　⒳�痧���Ј灈�聭饎�　　　　　　　　　　　　�
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      PCMD    2
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           B2D       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVELB2D       TT
     C                     MOVE '00'      TTSHTM
      *
      * ｴｹｶｴｽ ﾔﾊﾕｴｽ ﾔｻｴｽｶﾔ ｵｲﾔｶ ｲﾀｵ ﾔｻｿｶ ｷﾁﾊ ｳｾｲﾀｽﾐ.
      * ｻｷ ｵｲﾔｶ ｲﾀｵ ﾔｻｿｶ ｴﾁﾀﾔｲｻﾀﾐ ｲ ｳｾｲﾀｽ ｻﾔ'ﾐ ｻﾀﾖｲｾｻｵ.
     C                     MOVE *BLANKS   TICK
      *
     C                     MOVEATTDTTM    TICK
     C                     DO   12        X       30
     C           TICK,X    IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,11     MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDDO
      *
      *鼇����束
     C                     EXSR #SB920
     C                     MOVEL'Tﾊﾕｴｽ'   D1BIN
     C                     MOVELTTSURT    D1IAFB
      *
     C                     MOVELTTSHYY    SHYY
     C                     MOVELTTSHMM    SHMM
     C                     MOVELTTSHDD    SHDD
     C                     MOVELSHDT      D1SHDT
      *
     C                     MOVELTTSHHH    SHHH
     C                     MOVELTTSHMN    SHMN
     C                     MOVELTTSHSS    SHSS
     C                     MOVELSHTM      D1SHTM
      *
     C                     MOVEL'02'      DSPSW   2
     C                     CLEARMAN
