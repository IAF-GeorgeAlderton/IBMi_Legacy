     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *　⒳�痧���樠肁瘌�沜�Č�　　　　　　　　　　�
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTDSP02
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
      *
      * ｻｷ ｷ3, ﾔｹｶﾀ ｸﾁ ｳｲｴｽ ﾔﾁ ﾐｴﾊｶｶﾀ 1.
     C           *IN03     IFEQ '1'
     C                     CLEARB2D
     C                     MOVEL'01'      DSPSW   2
     C                     GOTO ESB220
     C                     ENDIF
      *
      * ｻｷ ｷ4, ﾔｹｶﾀ ｵｻﾐﾂｾｲﾙ ｵｶｾｶﾔｶ ｿｲﾀｻｷｶﾐﾔ ﾐｴﾊｶｶﾀ ｲﾀｵ ﾊｶｴｲｾｴﾕｾｲﾔｶ ﾔﾁﾔｲｾﾐ.
     C           *IN04     IFEQ *ON
     C                     EXSR #SB400
     C                     EXSR #SB920
     C                     GOTO ESB220
     C                     ENDIF
      *
      * ｴｹｶｴｽ ｿｲﾀｻｷｶﾐﾔ ﾐｴﾊｶｶﾀ ｷﾁﾊ ｶﾊﾊﾁﾊﾐ.
     C           MAN       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKHNTE  2
     C                     MOVELMAN       MF
      *
      * ｴｹｶｴｽ ﾀｲｿｴ ｵｶﾐﾔｻﾀｲﾔｻﾁﾀ ｴﾁｵｶ ｶﾘｻﾐﾔﾐ ｻﾀ M/F ﾁﾊ ｻﾔ'ﾐ ｲﾀ Eﾘﾂﾁﾊﾔ.
     C           MFNAMC    CHAINAL#PP21              44
     C           *IN44     IFEQ *ON
     C           MFTYPE    ANDNE'EXP'
     C                     SETON                     3199
     C                     MOVELER,9      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     GOTO ESB220
     C                     ENDIF
      *
      * ｴｹｶｴｽ ﾔﾁ ﾖｶﾊｻｷﾙ ﾔｹｻﾐ ｿｲﾀｻｷｶﾐﾔ ｹｲﾐ ﾀﾁﾔ ｲｾﾊｶｲｵﾙ ｳｶｶﾀ ｶﾀﾔｶﾊｶｵ.
      * ﾔｹｶﾀ ｻｷ ｿｲﾀｻｷｶﾐﾔ ｻﾐ ﾀｶﾗ, ｴｹｶｴｽ ﾔﾁ ﾖｶﾊｻｷﾙ ｻｷ ｿｲﾀｻｷｶﾐﾔ ｻﾐ ｻﾀ ﾂｲｴｽｻﾀｸ ｷｻｾｶ.
     C                     EXSR #SB710
     C           *IN99     IFEQ *OFF
     C                     EXSR #SB720
     C                     ENDIF
      *
      * ﾔﾊｶｲﾔ ﾔｹｶﾐｶ ｶﾊﾊﾁﾊﾐ ｵｻｷｷｶﾊｶﾀﾔｾﾙ ｳｶｴｲﾕﾐｶ ﾔｹｶﾙ ﾀｶｶｵ ﾔﾁ ｹｲﾖｶ ﾔｹｶ ﾁﾂﾔｻﾁﾀ
      * ﾔﾁ ﾁﾖｶﾊﾊｻｵｶ ﾔｹｶ ｶﾊﾊﾁﾊ ｲﾀｵ ｾｶﾔ ﾔｹｶｿ ｳｶ ｲｵｵｶｵ ｻｷ TL ﾐｲﾙﾐ ｻﾔ'ﾐ ﾁｽｲﾙ.
      * ｴﾁﾕｾｵ ｳｶ ﾐﾕﾂﾂｾｶｿｶﾀﾔｲｾ ﾁﾊｵｶﾊ, ｾｲﾐﾔ ｿｻﾀﾕﾔｶ ｲｵｵ-ﾁﾀ.
     C           *IN99     IFEQ *ON
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARMAN
     C                     GOTO ESB220
     C                     ENDIF
      *
      * ﾀﾁ ｶﾊﾊﾁﾊﾐ, ﾐﾁ ﾗﾊｻﾔｶ ﾔﾁ ｾﾁｲｵｻﾀｸ ﾁﾕﾔ-ｷｻｾｶ ｲﾀｵ ﾊｶｴｲｾｴﾕｾｲﾔｶ ﾔﾁﾔｲｾﾐ.
     C           *IN99     IFEQ *OFF
     C                     MOVEL'OK'      WKHNTE  2
     C                     TIME           WTIME
     C                     MOVEL*BLANK    MSG
     C                     EXSR #SB500
     C                     CLEARMAN
     C                     EXSR #SB920
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * WRITE ERROR TO LOADING OUT-FILE AND LOCK DISPLAY.  *
      *----------------------------------------------------*
     CSR         #SB229    BEGSR
      *
     C           WKHNTE    IFEQ 'NG'
     C                     TIME           WTIME
     C                     EXSR #SB500
     C                     Z-ADD3         P1PGM
     C                     MOVELMSG       P1ERR
     C                     MOVELW#PGM     P1PID
