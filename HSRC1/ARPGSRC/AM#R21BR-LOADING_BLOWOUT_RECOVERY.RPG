     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARMAN
      *
     CSR         ESB229    ENDSR
      *----------------------------------------------------*
      *　⒳�痧���痡瘏�黬�砑ⓓ���鰖槖　　　　　　�
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           *IN03     DOUEQ*ON
      *
     C                     EXFMTDSP04
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
      * F3 ﾔﾁ ｴｲﾀｴｶｾ ｵｶｾｶﾔｶ ｲﾀｵ ｸﾁ ｳｲｴｽ ﾔﾁ ﾐｴﾊｶｶﾀ 2.
     C           *IN03     IFEQ *ON
     C                     MOVEL'02'      DSPSW
     C                     CLEARMAN
     C                     LEAVE
     C                     ENDIF
      *
      * ﾖｶﾊｻｷﾙ ﾔｹｲﾔ ｿｲﾀｻｷｶﾐﾔ ｹｲﾐ ｳｶｶﾀ ﾐｴｲﾀﾀｶｵ ﾔﾁ ｾﾁｲｵ ﾁﾕﾔ-ｷｻｾｶ.
     C           MAN       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARMAN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'A'       MFSIDE
     C                     MOVE *OFF      *IN26
     C           MAN       SETLLAM#PL21
     C           *IN26     DOWEQ*OFF
     C           MAN       READEAM#PL21                  26
     C           *IN26     IFEQ *OFF
     C           R2SURT    ANDEQTTSURT
     C           R2SHID    ANDEQTTSHDT
     C           R2SHIT    ANDEQTTSHTM
     C           R2SKJY    ANDEQ' '
     C           R2HNTE    ANDEQ'OK'
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
      * ｻｷ ｿｲﾀｻｷｶﾐﾔ ﾗｲﾐ ﾀﾁﾔ ｷﾁﾕﾀｵ ｻﾀ ｾﾁｲｵｻﾀｸ ﾁﾕﾔ-ｷｻｾｶ, ｵｻﾐﾂｾｲﾙ ｶﾊﾊﾁﾊ.
     C           *IN26     IFEQ *ON
     C                     SETON                     3199
     C                     MOVELER,8      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARMAN
     C                     ITER
     C                     ENDIF
      *
      * ｻｷ ｿｲﾀｻｷｶﾐﾔ ﾗｲﾐ ｷﾁﾕﾀｵ...
     C           *IN26     IFEQ *OFF
      *
      *  ｲﾀｵ ｻﾔ ｿｲﾔｴｹｶﾐ ﾔｹｶ ﾊﾁﾕﾔｶ/ﾐｹｻﾂ ｵｲﾔｶ, ﾔｹｶﾀ ｵｶｾｶﾔｶ
     C           R2SURT    IFEQ TTSURT
     C           R2SHID    ANDEQTTSHDT
     C           R2SHIT    ANDEQTTSHTM
     C                     MOVEL'D'       R2SKJY
     C                     Z-ADDSDATE     R2SKHZ
     C                     UPDATAM#PP211
     C                     CLEARMAN
     C                     LEAVE
     C                     ELSE
      *  ｻｷ ｻﾔ ｵﾁｶﾐﾀ'ﾔ ｿｲﾔｴｹ, ﾔｹｶﾀ ﾕﾀｾﾁｴｽ ﾊｶｴﾁﾊｵ ｲﾀｵ ｵｻﾐﾂｾｲﾙ ｶﾊﾊﾁﾊ.
     C                     UNLCKAM#PL21                31
     C                     SETON                     3199
     C                     MOVELER,8      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARMAN
     C                     ITER
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
