     C                     PARM           P1ERR  25
      *
     CSR         ESB999    ENDSR
      *----------------------------------------------------*
      * END PROGRAM.                                       *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * WRITE TO LOADING OUT-FILE AM#PP21.                 *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAM#PP211
     C                     Z-ADDSDATE     R2KOHZ
     C                     Z-ADDSTIME     R2KOTI
     C                     MOVELWORKER    R2KOME
     C                     MOVELW#PGM     R2KPGM
     C                     Z-ADDSDATE     R2SSHZ
     C                     Z-ADDSTIME     R2SSTI
     C                     MOVELWORKER    R2USCD
     C                     MOVELALWKNM    R2USNM
     C                     MOVELWKHNTE    R2HNTE
     C                     MOVELER,3      R2ERR
      *
     C                     MOVELTT        R2TICK
     C                     MOVELTTSURT    R2SURT    P
     C                     MOVELTTSHDT    R2SHID
     C                     MOVELTTSHTM    R2SHIT
      *
     C                     MOVE 'A'       MFSIDE
     C                     MOVELMAN       R22D
     C                     MOVELMFNAMC    R2NAMC
     C                     MOVELMFSUPP    R2SUPP
     C                     MOVELMFDOCK    R2NUKE
     C                     MOVELMFORD#    R2ORDN
     C                     MOVELMFMRTE    R2MRTE
     C                     MOVELMFSDCK    R2DOCK
     C                     MOVELMFPALT    R2PLTC
     C                     MOVELMFMROS    R2MRSO
     C                     MOVELMFSKID    R2SKID
     C                     MOVELMFFILR    R2FIL2
      *
     C                     MOVEL'Y'       R2F5OV
     C                     MOVELR1SURT    R2PSUR
     C                     MOVELR1SHID    R2PSHD
     C                     MOVELR1SHIT    R2PSHT
     C                     MOVEL'14'      R2EXCD
      *
     C                     WRITEAM#PP211
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *  CHECK TO VERIFY NOT ALREADY SCANNED.              *
      *----------------------------------------------------*
     CSR         #SB710    BEGSR
      *
     C                     MOVE 'A'       MFSIDE
     C                     MOVE *OFF      *IN26
      *
     C           MAN       SETLLAM#PL21
     C           *IN26     DOWEQ*OFF
     C           MAN       READEAM#PL21                  26
     C           *IN26     IFEQ *OFF
     C           R2SKJY    ANDEQ' '
     C           R2HNTE    ANDEQ'OK'
     C           R2EXCD    ANDEQ'13'
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * ｻｷ ﾀﾁﾔ ﾐｴｲﾀﾀｶｵ ｲﾐ ｲ ｳｾﾁﾗﾁﾕﾔ, ﾐｶﾔ ｶﾊﾊﾁﾊ ｿｶﾐﾐｲｸｶ.
     C           *IN26     IFEQ *ON
     C                     SETON                     3199
     C                     MOVELER,7      MSG
     C                     GOTO ESB710
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN26
      *
     C           MAN       SETLLAM#PL21
     C           *IN26     DOWEQ*OFF
     C           MAN       READEAM#PL21                  26
     C           *IN26     IFEQ *OFF
     C           R2SURT    ANDEQTTSURT
     C           R2SHID    ANDEQTTSHDT
     C           R2SHIT    ANDEQTTSHTM
     C           R2SKJY    ANDEQ' '
     C           R2HNTE    ANDEQ'OK'
     C           R2EXCD    ANDEQ'14'
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * ｻｷ ｲｾﾊｶｲｵﾙ ﾐｴｲﾀﾀｶｵ ｲﾐ ｲ ｳｾﾁﾗﾁﾕﾔ ﾊｶｴﾁﾖｶﾊﾙ, ﾐｶﾔ ｶﾊﾊﾁﾊ ｿｶﾐﾐｲｸｶ.
     C           *IN26     IFEQ *OFF
     C                     SETON                     3199
     C                     MOVELER,5      MSG
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *----------------------------------------------------*
      *  CHECK TO VERIFY THIS MANIFEST WAS SCANNED IN      *
      *  PACKING PROGRAM.                                  *
      *----------------------------------------------------*
     CSR         #SB720    BEGSR
      *
     C                     SETOF                     26
     C                     MOVE 'A'       MFSIDE
     C           MAN       SETLLAM#PL05
     C           *IN26     DOWEQ*OFF
     C           MAN       READEAM#PL05                  26
      *
     C           *IN26     IFEQ *OFF
     C           R1SKJY    ANDEQ' '
     C           R1HNTE    ANDEQ'OK'
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * ｻｷ ﾀﾁﾔ ﾐｴｲﾀﾀｶｵ ｻﾀ ﾂｲｴｽｻﾀｸ ﾁﾕﾔ-ｷｻｾｶ, ﾐｶﾔ ｶﾊﾊﾁﾊ ｿｶﾐﾐｲｸｶ.
     C           *IN26     IFEQ *ON
     C                     SETON                     3199
     C                     MOVELER,6      MSG
     C                     MOVE *BLANKS   R1SURT
     C                     MOVE *BLANKS   R1SHID
     C                     MOVE *BLANKS   R1SHIT
     C                     GOTO ESB720
     C                     ENDIF
      *
     CSR         ESB720    ENDSR
      *----------------------------------------------------*
      * NUMBER OF MANIFESTS                                *
      *----------------------------------------------------*
     CSR         #SB920    BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           KKSURT  9
     C                     KFLD           KKSHID  8
      *
     C                     MOVELTTSURT    KKSURT    P
     C                     MOVELTTSHDT    KKSHID
     C                     Z-ADD0         COUNT   30
      *
     C           KEY01     SETLLAM#PL22
     C           KEY01     READEAM#PL22                  50
     C           *IN50     DOWEQ*OFF
      *
     C           R2SKJY    IFEQ *BLANK
     C           R2HNTE    ANDEQ'OK'
     C           R2SHIT    ANDEQTTSHTM
     C           R2EXCD    ANDEQ'14'
     C                     ADD  1         COUNT
     C                     ENDIF
      *
     C           KEY01     READEAM#PL22                  50
     C                     ENDDO
      *
     C                     Z-ADDCOUNT     D1TOTL
      *
     CSR         ESB920    ENDSR
      *----------------------------------------------------*
**
INPUT TRUCK TICKET.
INPUT MANIFEST BARCODE.
BLOWOUT RECOVERY
 ER #4
ALREADY SCANNED.
MANIFEST NOT IN PACKING.
SKID NOT A BLOWOUT.
MAN# NOT SCANNED TO TRUCK.
