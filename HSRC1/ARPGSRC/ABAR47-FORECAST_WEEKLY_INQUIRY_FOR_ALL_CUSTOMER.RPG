     C                     ADD  W@CONT    @CM,X
     C                     ADD  1         Y
     C           Y         IFGT W@TDD
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     ELSE
     C                     DO   *HIVAL
     C           @NN,Y     DIV  A2SSYS    W@CONT  71H
     C                     ADD  W@CONT    @CM,X
     C                     ADD  1         Y
     C           Y         IFGT 31
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C                     ELSE
     C                     Z-ADD1         Y       20
     C                     DO   *HIVAL
     C           @NN,Y     DIV  A2SSYS    W@CONT  71H
     C                     ADD  W@CONT    @CM,X
     C                     ADD  1         Y
