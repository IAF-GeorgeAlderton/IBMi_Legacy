     C                     END
      *
     C           F8YOBI    IFNE 1
     C                     DO   *HIVAL
     C                     READPAGDPL12                  91
     C   91                LEAVE
     C           F8YOBI    IFEQ 1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C   91                LEAVE
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Z       20
     C                     Z-ADD*ZERO     W@BUS   20
     C                     DO   *HIVAL
      *
     C           F8YOBI    IFEQ 1
     C                     ADD  1         X
     C           X         SUB  1         Z
     C           Z         IFGT *ZERO
     C                     Z-ADDW@BUS     BUS,Z
     C                     Z-ADD*ZERO     W@BUS
     C                     END
     C           X         IFGT 30
     C                     LEAVE
     C                     END
     C                     Z-ADDF8DATE    SDT,X
     C                     ELSE
     C                     Z-ADDF8DATE    EDT,X
     C                     END
     C*
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         W@BUS
     C                     END
     C*
     C                     READ AGDPL12                  91
     C   91                LEAVE
      *
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     ENDSR
