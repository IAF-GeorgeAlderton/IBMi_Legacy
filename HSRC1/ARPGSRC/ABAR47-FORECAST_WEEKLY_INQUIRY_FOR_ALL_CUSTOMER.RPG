     C                     CLEARSDT
     C                     CLEAREDT
     C                     CLEARBUS
     C                     CLEAR#A
     C                     CLEAR##W
     C                     CLEAR##D
     C*
     C                     EXSR #SET21
     C*
     C                     CLOSEABAWP47A
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN ABAWP47A
     C*
     C                     EXSR #SET22
     C*
     C                     Z-ADD*ZERO     J       20
     C                     Z-ADD*ZERO     K       20
     C                     Z-ADD*ZERO     L       20
     C* DATE SET
     C                     DO   6         J
     C                     MOVELSDT,J     #DT,J
     C                     ENDDO
     C* CONT SET
     C           *LOVAL    SETLLABAWP47A
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABAWP47A                 94
     C   94                LEAVE
     C           AWNONM    IFNE *BLANK
     C**         AWNONM    ANDNE'*TOTAL*'
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL02
     C*
     C                     MOVEL*BLANK    WSSHIN
     C                     MOVELAWSHIN    WSSHIN
     C                     EXSR #WS
     C                     MOVELAWSHIN    S2BPRT
     C*
     C                     DO   6         J
     C                     Z-ADD@AW,J     #A,J
     C                     ADD  @AW,J     ##W,J
     C                     ENDDO
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C*
     C                     ENDDO
     C*
     C           RRN2      IFGT 0
     C                     DO   6         J
     C           BUS,J     IFNE *ZERO
     C           ##W,J     DIV  BUS,J     ##D,J
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     Z-ADD1         #RCNO2
      *
     C                     ENDSR
