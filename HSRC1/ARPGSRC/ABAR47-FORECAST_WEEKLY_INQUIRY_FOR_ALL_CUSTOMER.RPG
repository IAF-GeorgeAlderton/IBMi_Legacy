     C                     MOVELSDT,K     #DT,L
     C                     ADD  1         K
     C                     ENDDO
     C*
     C           *LOVAL    SETLLABAWP47A
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABAWP47A                 94
     C   94                LEAVE
     C           AWNONM    IFNE *BLANK
     C**         AWNONM    ANDNE'*TOTAL*'
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL02
     C*
     C                     MOVEL*BLANK    WSSHIN
     C                     MOVELAWSHIN    WSSHIN
     C                     MOVELAWSHIN    S2BPRT
     C*
     C                     Z-ADDJ         K
     C                     DO   6         L
     C                     Z-ADD@AW,K     #A,L
     C                     ADD  @AW,K     ##W,L
     C                     ADD  1         K
     C                     ENDDO
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C*
     C                     ENDDO
     C*
     C                     Z-ADDJ         K
     C                     DO   6         J
     C           BUS,K     IFNE *ZERO
     C           ##W,J     DIV  BUS,K     ##D,J
     C                     END
     C                     ADD  1         K
     C                     ENDDO
     C*
     C                     ENDSR
     C*-----------------------------------------------------
JW1  C* EDIT SHN
     C*-----------------------------------------------------
     C           #WS       BEGSR
      *
     C                     MOVE ' '       WS1
     C                     MOVE ' '       WS2
     C           WSSHN2    IFNE *BLANK
     C                     MOVE '-'       WS1
     C                     ENDIF
      *
     C           WSSHN3    IFNE *BLANK
     C                     MOVE '-'       WS2
     C                     ENDIF
      *
     C                     ENDSR
     C*-----------------------------------------------------
JW1  C* DOWNLOAD ABAWP47B
     C*-----------------------------------------------------
     C           #DL       BEGSR
      *
     C                     MOVELD@FRM     $STDT
     C                     CALL 'ABAC47B'
     C                     PARM           $STDT   8
