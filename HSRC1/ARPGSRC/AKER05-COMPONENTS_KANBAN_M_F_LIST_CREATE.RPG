     H            Y.
     F** AKER05 ************************************
     F* .. COMPONENTS KANBAN M/F LIST CREATE .. *.
     F* I-HASADA                    93.07.27       *
     F************************************ AKER05 **
     FAKEWP05 IP  F     100            DISK
     FAKHPL02 IF  E           K        DISK
     FAKGPL03 IF  E           K        DISK
     FAKIPL03 IF  E           K        DISK
     FAKEWP03 IF  E           K        DISK                      A
     IAKEWP05 AA  01
     I                                        1  12 IKHIN
     I                                        1   5 IKHN1
     I                                        6  10 IKHN2
     I                                       11  12 IKHN3
     I                                       13  18 ITKR3
     I                                       19  24 ITKRP
     I                                       19  19 ITRP1
     I                                       20  21 ITRP2
     I                                       22  23 ITRP3
     I                                       24  24 ITRP4
     I                                       25  30 ITKRQ
     I                                       25  25 ITRQ1
     I                                       26  27 ITRQ2
     I                                       28  29 ITRQ3
     I                                       30  30 ITRQ4
     C           KEY1      KLIST
     C                     KFLD           IKHN1
     C                     KFLD           IKHN2
     C                     KFLD           IKHN3
      *
     C           KEY2      KLIST
     C                     KFLD           ITRP1
     C                     KFLD           ITRP2
     C                     KFLD           ITRP3
     C                     KFLD           ITRP4
      *
     C           KEY3      KLIST
     C                     KFLD           ITRQ1
     C                     KFLD           ITRQ2
     C                     KFLD           ITRQ3
     C                     KFLD           ITRQ4
      *
     C           KEY4      KLIST
     C                     KFLD           IKHIN
     C                     KFLD           WTKR3
     C                     KFLD           WTKRP
     C                     KFLD           WTKRQ
      *
      *
     C*------------------------*
     C*  ..構成品かんばん..  *
     C*------------------------*
     C           ITKR3     IFNE *BLANK
      *
     C                     SETOF                     12
     C                     MOVE ITKR3     WTKR3   6
      *
     C*------------------------------------------*
     C*  ..構成品番工程　所番地登録マスター..  *
     C*------------------------------------------*
     C           KEY1      SETLLAKHPL021
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAKHPL021                 10
     C           *IN10     IFEQ '0'
     C           M5SKJY    IFEQ 'D'
     C           M5SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE *BLANK    WTKRP   6
     C                     MOVE *BLANK    WTKRQ   6
      *
     C           M5KDAI    IFEQ 'P'
     C                     SETON                     12
     C                     MOVE M5NTKR    WTKRP
     C                     EXSR SUBR
     C                     ELSE
      *
     C           M5KDAI    IFEQ 'Q'
     C                     SETON                     12
     C                     MOVE M5NTKR    WTKRQ
     C                     EXSR SUBR
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C  N10                END
      *
     C           *IN12     IFEQ '0'
     C                     MOVE *BLANK    WTKRP
     C                     MOVE *BLANK    WTKRQ
     C                     EXSR SUBR
     C                     END
     C                     ELSE
      *
      *
     C*------------------------------*
     C*  ..構成品メッキかんばん..  *
     C*------------------------------*
     C           ITKRP     IFNE *BLANK
      *
     C                     MOVE ITKRP     WTKRP
     C                     MOVE *BLANK    WTKRQ
     C                     MOVE *BLANK    WTKR3
      *
     C*--------------------------------------*
     C*  ..構成品メッキかんばんマスター..  *
     C*--------------------------------------*
     C           KEY2      SETGTAKGPL031
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY2      REDPEAKGPL031                 10
     C           *IN10     IFEQ '0'
     C           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     10
     C                     MOVE E1MTKR    WTKR3
     C                     EXSR SUBR
      *
     C                     END
     C                     END
     C  N10                END
     C                     ELSE
      *
      *
     C*--------------------------------*
     C*  ..構成品トンネルかんばん..  *
     C*--------------------------------*
     C           ITKRQ     IFNE *BLANK
      *
     C                     MOVE ITKRQ     WTKRQ
     C                     MOVE *BLANK    WTKRP
     C                     MOVE *BLANK    WTKR3
      *
     C*----------------------------------------*
     C*  ..構成品トンネルかんばんマスター..  *
     C*----------------------------------------*
     C           KEY3      SETGTAKIPL031
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY3      REDPEAKIPL031                 10
     C           *IN10     IFEQ '0'
     C           E2SKJY    IFEQ 'D'
     C           E2SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     10
     C                     MOVE E2MTKR    WTKR3
     C                     EXSR SUBR
      *
     C                     END
     C                     END
     C  N10                END
      *
     C                     END
     C                     END
     C                     END
      *
      *
     C*--------------------------------------------------------*
     C*  ..サブルーチン..                                    *
     C*  ..構成品かんばんマスターリストＷＯＲＫデータ出力    *
     C*--------------------------------------------------------*
     C           SUBR      BEGSR
      *
     C                     SETOF                     11
     C           KEY4      CHAINAKEWP031             11
     C           *IN11     IFEQ '1'
     C                     MOVE IKHIN     AKKHIN
     C                     MOVE WTKR3     AKTKR3
     C                     MOVE WTKRP     AKTKRP
     C                     MOVE WTKRQ     AKTKRQ
     C                     WRITEAKEWP031
     C                     END
      *
     C                     ENDSR
