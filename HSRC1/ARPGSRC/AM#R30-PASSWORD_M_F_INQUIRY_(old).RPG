     C           R3PGM4    IFEQ '1'
     C           S1PGM     CAT  PG,4:1    S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
     C                     ENDIF
     C           R3PGM5    IFEQ '1'
     C           S1PGM     CAT  PG,5:1    S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
     C                     ENDIF
     C           R3PGM6    IFEQ '1'
     C           S1PGM     CAT  PG,6:1    S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
     C                     ENDIF
     C           R3PGM7    IFEQ '1'
     C           S1PGM     CAT  PG,7:1    S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
     C                     ENDIF
     C           R3PGM8    IFEQ '1'
     C           S1PGM     CAT  PG,8:1    S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
     C                     ENDIF
     C           R3PGM9    IFEQ '1'
     C           S1PGM     CAT  PG,9:1    S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
