     C           R3PGMA    IFEQ '1'
     C           S1PGM     CAT  PG,10:1   S1PGM
     C           S1PGM     CAT  ',':0     S1PGM
     C                     ENDIF
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * NEXT                                               *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
