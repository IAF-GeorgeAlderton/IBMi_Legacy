     I                                       13  14 W1SHN3
      *================================================================
      *----------------------------------------------------*
      *   ENTRY     L  I  S  T                             *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PDEST  50
      *================================================================
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CRT    '#CRT             作成
     C                     ENDCS
     C                     ENDDO
     C*
     C                     MOVELD1DEST    PDEST
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * INITIAL SETTING
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     CLEARDSP01
     C                     MOVELPDEST     D1DEST
     C                     TIME           @TIME
     C*
     C           *NAMVAR   DEFN MCEDP01   @@YMD
     C                     IN   @@YMD
     C                     Z-ADD@@YY      D1YY
     C                     Z-ADD@@MM      D1MM
     C*
     C                     MOVEL*BLANK    D1MSG
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      * SCREEN 1
     C*===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1:END
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* F5:RUN
     C           *INKE     WHEQ *ON
     C                     MOVE '#CRT    '@STEP
     C******
     C                     OTHER
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
      *===============================================================
      *  MONTHLY SHIPPNG REPORT
      *===============================================================
     C           #CRT      BEGSR
      *
     C*-------------------------
     C           KEY01     KLIST
     C                     KFLD           K@TOKU  40       CUSTOMER
     C                     KFLD           K@NONY  40       DELIVERY
     C                     KFLD           K@NKOJ  1        N FACTORY
     C                     KFLD           K@NUKE  4        N RECEIVING LINE
     C                     Z-ADD0         K@TOKU  40       CUSTOMER
     C                     Z-ADD0         K@NONY  40       DELIVERY
     C                     MOVEL*BLANK    K@NKOJ  1        N FACTORY
     C                     MOVEL*BLANK    K@NUKE  4        N RECEIVING LINE
     C                     MOVEL' '       @1ST    1
      * DELIVERY MONTHLY REPORT FILE
     C           *LOVAL    SETLLMBEPL03
      *-------------------------
      *-------------------------
S1   C                     DO   *HIVAL
     C                     READ MBEPL03                  90
     C   90                LEAVE
     C           F2SKJY    IFEQ 'D'                        DELETE FLAG
     C                     ITER
     C                     ENDIF
     C*
 S2  C           F2TOKU    IFEQ K@TOKU                     CUSTOMER
     C           F2NONY    ANDEQK@NONY                     DELIVERY
     C           F2NKOJ    ANDEQK@NKOJ                     N FACTORY
     C           F2NUKE    ANDEQK@NUKE                     N RECEIVING LINE
     C           @1ST      ANDEQ'*'
 X2  C                     ELSE
     C                     Z-ADDF2TOKU    K@TOKU           CUSTOMER
     C                     Z-ADDF2NONY    K@NONY           DELIVERY
     C                     MOVELF2NKOJ    K@NKOJ           N FACTORY
     C                     MOVELF2NUKE    K@NUKE           N RECEIVING LINE
     C           @1ST      IFEQ ' '
     C                     EXCPT$HED
     C                     ENDIF
     C                     MOVEL'*'       @1ST
     C           KEY01     CHAINGADPL11              91
  S3 C  N91      B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE@SYSHZ
     C                     SETON                     91
  E3 C                     ENDIF
     C   91                MOVEL*BLANK    B5KMEI           FACTORY NAME (KANA)
 E2  C                     ENDIF
      *
     C                     MOVELF2MHN1    W1MHN1
     C                     MOVELF2MHN2    W1MHN2
     C                     MOVELF2MHN3    W1MHN3
     C                     MOVELF2MHN4    W1MHN4
     C                     MOVE '-'       W1MHF1
     C                     MOVE '-'       W1MHF2
     C                     MOVE '-'       W1MHF3
     C           W1MHN4    IFEQ *BLANK
     C                     MOVE ' '       W1MHF3
     C           W1MHN3    IFEQ *BLANK
     C                     MOVE ' '       W1MHF2
     C           W1MHN2    IFEQ *BLANK
     C                     MOVE ' '       W1MHF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVELF2SHN1    W1SHN1
     C                     MOVELF2SHN2    W1SHN2
     C                     MOVELF2SHN3    W1SHN3
     C                     MOVE '-'       W1SHF1
     C                     MOVE '-'       W1SHF2
     C           W1SHN3    IFEQ *BLANK
     C                     MOVE ' '       W1SHF2
     C           W1SHN2    IFEQ *BLANK
     C                     MOVE ' '       W1SHF1
     C                     ENDIF
     C                     ENDIF
     C           F2GOKE    MULT F2TANK    W1KIN  110H
JW1   * GET GROUP
 .   C                     MOVELF2TOKU    $DLV
 .   C                     CALL 'UTLR62'
 .   C                     PARM           $DLV    4
 .   C                     PARM           $GRP    3
 .   C                     PARM           $NAME1 15
 .   C                     PARM           $NAME2 50
 .   C                     PARM           $RTN    1
 .   C           $GRP      CHAINEDIPP43              98
 .   C           *IN98     IFEQ *OFF
 .   C                     MOVELE3GPNM    XXGRP  10
 .   C                     ELSE
 .   C                     MOVE *BLANK    XXGRP
JW1  C                     ENDIF
      *
     C                     EXCPT$MEI
      *
     C                     ENDDO
     C*-------------------------
     C*-------------------------
     C           @1ST      IFEQ ' '
     C                     SETON                     99
     C                     MOVELER,1      D1MSG
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
