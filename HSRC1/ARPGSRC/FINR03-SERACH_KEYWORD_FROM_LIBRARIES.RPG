     H            Y.
     F** FINR03 ******************************************
     F*   ..ＳＲＣＦＩＬＥ文字列検索プログラム..       *
     F*  SERACH KEYWORD FROM LIBRARIES                   *
     F*                           A.MAMIYA   2002.03.11  *
     F****************************************** FINR03 **
     FFINWP02 IF  F     256            DISK
     FFINWP03 O   F     256            DISK
     E                    CHK     1   3 50
     IFINWP02 AA  01
     I                                        1 256 IDATA
     I                                       28  37 IFILE
     I                                       30  39 ILIBL
     I                                       28  77 IKENS
     I*JW   --------------------------------- 6  55 ICHK1
JW   I                                        5  55 ICHK1
     I                                       40  89 ICHK2
     I*JW   ---------------------------------24  73 ICHK3
JW   I                                       40  89 ICHK3
     I                                        3  12 IMENB
     I                                       15  24 ITYPE
     I                                       27  34 IMDAT
     I                                       37  44 ICDAT
     I                                       47  54 ICTIM
     I                                       57  63 IRECD
     I                                       66  72 IDREC
     I                                       75 124 ITEXT
     C                     SETOF                     10
     C           2         CHAINFINWP02              10
     C           *IN10     IFEQ '0'
     C                     MOVELIFILE     @FILE  10
     C                     END
      *
     C                     SETOF                     10
     C           3         CHAINFINWP02              10
     C           *IN10     IFEQ '0'
     C                     MOVELILIBL     @LIBL  10
     C                     END
      *
     C                     SETOF                     10
     C           6         CHAINFINWP02              10
     C           *IN10     IFEQ '0'
     C                     MOVELIKENS     @KENS  50
     C                     END
      *
     C                     SETOF                     10
     C           14        SETLLFINWP02
     C                     DO   *HIVAL
     C                     READ FINWP02                  10
     C           *IN10     IFEQ '0'
     C           ICHK1     IFEQ CHK,1
     C           ICHK2     OREQ CHK,2
     C                     ELSE
     C           ICHK3     IFEQ CHK,3
     C                     SETOF                     20
     C                     DO   12
     C                     READ FINWP02                  20
     C  N20                ENDDO
     C                     ELSE
     C           ITYPE     IFNE 'NOUSE'
     C                     EXCPTDT
     C                     ENDIF
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     OFINWP03 E                DT
     O                         @KENS
     O                         @LIBL
     O                         @FILE
     O                         IMENB
     O                         ITYPE
     O                         IMDAT
     O                         ICDAT
     O                         ICTIM
     O                         IRECD
     O                         IDREC
     O                         ITEXT
**  CHK
