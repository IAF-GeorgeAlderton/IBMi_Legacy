      *
     C           *ENTRY    PLIST
     C                     PARM           PMSHIN 12
     C                     MOVELPMSHIN    WPSHIN
      *
      *------------------------------------------------------
      *    M  A  I  N  L  I  N  E
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'00'      #SCRN0
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#ABP     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
      *
     C           KAGD12    KLIST
     C                     KFLD           WSYYYY
     C                     KFLD           WSMM
     C                     KFLD           WSDD
      *
     C                     TIME           WSDT
     C                     EXSR GETWDT
      *
     C                     ENDSR
      *------------------------------------------------------
      *   Get Week Dates...
      *------------------------------------------------------
     C           GETWDT    BEGSR
      *
      *  get begin month/day for week 1...current week
     C           KAGD12    CHAINAGDPL12              50
     C           *IN50     DOWEQ*OFF
     C           F8YOBI    IFEQ 1
     C                     Z-ADDF8MMDD    D@WKD1
     C                     LEAVE
     C                     ELSE
     C                     READPAGDPL12                  50
     C                     ENDIF
     C                     ENDDO
      *
      *  get begin month/day for week 2...next week
     C           KAGD12    SETGTAGDPL12
     C                     READ AGDPL12                  50
     C           *IN50     DOWEQ*OFF
     C           F8YOBI    IFEQ 1
     C                     Z-ADDF8MMDD    D@WKD2
     C                     LEAVE
     C                     ELSE
     C                     READ AGDPL12                  50
     C                     ENDIF
     C                     ENDDO
      *
      *  get begin month/day for week 3... week after next
     C           *IN50     IFEQ *OFF
      *
     C                     READ AGDPL12                  50
     C           *IN50     DOWEQ*OFF
     C           F8YOBI    IFEQ 1
     C                     Z-ADDF8MMDD    D@WKD3
     C                     LEAVE
     C                     ELSE
     C                     READ AGDPL12                  50
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   Display Screen 1...
      *------------------------------------------------------
     C           #SCRN0    BEGSR
      *
     C           PMSHIN    IFEQ *BLANK
     C                     WRITEDSP99
     C                     EXFMTDSP01
     C                     ELSE
     C                     MOVELWPSHN1    D@PRT1
     C                     MOVELWPSHN2    D@PRT2
     C                     MOVELWPSHN3    D@PRT3
     C                     ENDIF
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK0
      *
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET0
     C                     MOVEL'01'      W@ID
      *
     C                     ELSE
      *
     C           PMSHIN    IFNE *BLANK
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK Screen 1...
      *------------------------------------------------------
     C           #CHK0     BEGSR
      *
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
      *
     C           K#ABP     CHAINAB#PL1P              90
     C           *IN90     IFEQ *ON
     C                     MOVE ERR,1     D@MSG
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA
      *------------------------------------------------------
     C           #SET0     BEGSR
      *
     C                     Z-ADD*ZERO     RRN0    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL00
     C                     MOVE *OFF      *IN54
      *
     C                     Z-ADD*ZERO     D@MQT1
     C                     Z-ADD*ZERO     D@MQT2
     C                     Z-ADD*ZERO     D@MQT3
      *
     C           K#ABP     SETLLAB#PL1P
     C           *IN90     DOUEQ*ON
     C           K#ABP     READEAB#PL1P                  90
      *
     C           *IN90     IFEQ *OFF
      *
     C                     ADD  1         RRN0
     C                     CLEARSFL00
     C                     MOVE BANONY    W@NONY
     C                     MOVE BANKOJ    W@NKOJ
     C                     MOVE BANUKE    W@NUKE
      *
     C           BATOKU    IFEQ 5149
     C                     MOVE BANUKE    W@NUKE
     C                     ENDIF
      *
     C                     Z-ADDBANONY    S@NONY
     C                     MOVELBANKOJ    S@NKOJ
     C                     MOVELBANUKE    S@NUKE
      *
     C           BATOKU    IFEQ 5149
     C                     MOVE BANUKE    S@NUKE
     C                     ENDIF
      *
     C                     MOVE BAMHN1    S@MPR1
     C                     MOVE BAMHN2    S@MPR2
     C                     MOVE BAMHN3    S@MPR3
     C                     MOVE BAMHN4    S@MPR4
     C                     Z-ADDBASRYO    S@MQT1
      *
     C                     ENDIF
      *
     C                     ENDDO
