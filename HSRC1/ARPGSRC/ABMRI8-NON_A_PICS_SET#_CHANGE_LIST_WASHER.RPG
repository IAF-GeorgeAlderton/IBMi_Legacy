     H            Y.
     F** ABMRI8 *********************************************
     F* WASEHR KANBAN SET# CHECK LIST
     F*    HOTTA.               2018.09.14                  *
     F*******************************************************
     FABMWPI8 IF  E           K        DISK
     FAKBPL03 IF  E           K        DISK
     FABMPRI8 O   E             55     PRINTER
     FFGBPL01 IF  E           K        DISK
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     MOVEL*BLANK    SVATOB  4
     C                     SETON                     55
     C           *HIVAL    SETGTABMWPI81
     C                     READPABMWPI81                 87
     C           *IN87     DOWEQ'0'
     C           W0KCD1    IFEQ '3'
     C           W0KMAX    ANDNEW0KMAA
     C           *IN55     IFEQ '1'
     C           SVATOB    ORNE W0ATOB
     C                     EXSR #FGB
     C                     WRITEABMPRI81
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #SB001
     C                     ENDIF
     C                     READPABMWPI81                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FGBPP01                                          *
      *--------------------------------------------------*
     CSR         #FGB      BEGSR
      *
     C                     MOVELW0ATOB    SVATOB
     C                     MOVELW0ATOB    P1ATOB
     C                     Z-ADD0         W@BMON  40
     C                     MOVELW0ATOB    W@BMON
     C                     MOVEL*BLANK    P1SMEI
     C           W@BMON    CHAINFGBPL011             74
     C           *IN74     IFEQ '0'
     C                     MOVELB2SMEI    P1SMEI
     C                     ENDIF
      *
     CSR         EFGB      ENDSR
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           KEYTKR    KLIST
     C                     KFLD           W0ATK1
     C                     KFLD           W0ATK2
     C                     KFLD           W0ATK3
     C                     KFLD           W0ATK4
     C                     Z-ADD0         W@BMON  40
     C                     Z-ADD0         P2GEHZ
     C           KEYTKR    SETLLAKBPL031
     C           KEYTKR    READEAKBPL031                 74
     C           *IN74     DOWEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
     C           L1STHZ    IFEQ 99999999
     C                     Z-ADDL1BMON    W@BMON
     C                     Z-ADDL1UKHZ    P2GEHZ
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    READEAKBPL031                 74
     C                     ENDDO
      *
     C                     MOVELW0KCD1    P2KCD1
     C                     MOVELW0ATK1    P2ATK1
     C                     MOVELW0ATK2    P2ATK2
     C                     MOVELW0ATK3    P2ATK3
     C                     MOVELW0ATK4    P2ATK4
     C                     MOVEL*BLANK    P2SHIN
     C           W0SHN1    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W0SHN2:0  P2SHIN
     C           P2SHIN    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W0SHN3:0  P2SHIN
     C                     Z-ADDW0SSYS    P2SSYS
     C                     Z-ADDW0KTSU    P2KTSU
     C                     Z-ADDW0KTSA    P2KTSA
     C                     Z-ADDW0BOXM    P2BOXM
     C                     Z-ADDW0BOXD    P2BOXD
     C******               Z-ADDW0AUAJ    P2AUAJ
     C******               Z-ADDW0AUAA    P2AUAA
     C                     Z-ADDW0KMAX    P2KMAX
     C                     Z-ADDW0KMAA    P2KMAA
     C                     Z-ADDW0BOXP    P2BOXP
     C                     Z-ADDW0SA      P2SA
      *
     C                     WRITEABMPRI82
      *
     CSR         ESB001    ENDSR
      *
