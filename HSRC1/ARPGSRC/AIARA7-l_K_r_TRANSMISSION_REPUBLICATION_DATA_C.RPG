     F** AIARA7 *******************************************************
     F*つるべ生産指示 TRANSMISSION REPUBLICATION DATA CREATE PLATING
     F*  2020.08.05
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.10|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F*****************************************************************
      *メッキかんばんマスター
     FAAFTL01 IF  E           K        DISK
      *
     C*  ..Ａ－ＰＩＣＳ　転送先判断マスター..  *
     FACAPL11 IF  E           K        DISK
      *
      *つるべ平準化マスター                                          UMBER *
     FAGAPL41 IF  E           K        DISK
      *つるべ平準化マスター更新ワーク                                UMBER *
     FAGAWL41 IF  E           K        DISK
      *
     FAIANP07 O   F     300            DISK                      A
      * BOX COLOR MASTER FILE                                  *
     FABHPP40 IF  E           K        DISK
      *================================================================
     I            DS
     I                                        1   80A3SKHZ
     I                                        1   40A3SKYY
     I                                        5   60A3SKMM
     I                                        7   80A3SKDD
     I            DS
     I                                        1   80A3UKHZ
     I                                        1   40A3UKYY
     I                                        5   60A3UKMM
     I                                        7   80A3UKDD
     I            DS
     I                                        1   80A3STHZ
     I                                        1   40A3STYY
     I                                        5   60A3STMM
     I                                        7   80A3STDD
      *================================================================
     C           KEY1      KLIST
     C                     KFLD           XMAKB
     C                     KFLD           WKCD
      *
     C           KEY2      KLIST
     C                     KFLD           XMAKB
     C                     KFLD           WKCD
     C                     KFLD           WHIN1
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3
      *
     C           KEYHIN    KLIST
     C                     KFLD           A31HB5  5
     C                     KFLD           A32HB5  5
     C                     KFLD           A33HB2  2
      *
     C*----------------------------*
     C* GET DAY 1 YEAR AGO        *
     C*----------------------------*
     C                     MOVE *DATE     PDATE
     C                     MOVE '-'       PPORM
     C                     MOVE '0365'    PDAYS
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     XDATE   80
      *----------------------------*
      *  メッキかんばんマスター  *
      *----------------------------*
S1   C                     DO   *HIVAL
     C                     SETOF                         01
     C                     READ AAFTL011                 01
     C   01                LEAVE
     C*
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           A3STHZ    IFLT XDATE
     C                     ITER
     C                     ENDIF
     C*
     C           A3MAKB    IFEQ 0
     C                     ITER
     C                     ENDIF
     C*
      *
      *つるべ平準化マスター                                          UMBER *
     C                     SETOF                     8889
     C*
     C           KEYHIN    CHAINAGAPL41              88
 S2  C           *IN88     IFEQ *OFF
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     88
     C                     ENDIF
     C           *IN88     IFEQ *OFF
     C           CBKDAI    ANDNE'C'
     C                     SETON                     88
     C                     ENDIF
 E2  C                     ENDIF
      *****
 S2  C           *IN88     IFEQ *ON
     C           KEYHIN    CHAINAGAWL41              89
  S3 C           *IN89     IFEQ *OFF
     C           WBSKJY    ANDEQ'D'
     C           WBSKHZ    ANDLE*DATE
     C                     SETON                     89
  E3 C                     ENDIF
  S3 C           *IN89     IFEQ *OFF
     C           WBKDAI    ANDNE'C'
     C                     SETON                     89
  E3 C                     ENDIF
 E2  C                     ENDIF
     C*
     C   89                ITER
     C*****     前工程部門
 S2  C           A3MAKB    IFEQ 0111
     C                     EXSR #IRO
     C                     Z-ADDA3KALL    @3KALL  30
     C                     Z-ADDA3KAIS    @3KAIS  30
     C                     Z-ADDA3KMIN    @3KMIN  30
     C                     Z-ADDA3KMAX    @3KMAX  30
     C                     Z-ADDA3SRMS    @3SRMS  30
     C                     Z-ADDA3ALHK    @3ALHK  30
     C                     Z-ADDA3MXHK    @3MXHK  30
     C                     Z-ADDA3JDMS    @3JDMS  30
     C                     EXCPTDT1
     C                     ITER
 E2  C                     ENDIF
      *
     C                     Z-ADDA3MAKB    XMAKB   40
     C                     MOVE A3KCD1    WKCD    1
     C                     MOVE A31HB5    WHIN1   5
     C                     MOVE A32HB5    WHIN2   5
     C                     MOVE A33HB2    WHIN3   2
      *
     C                     Z-ADD0         WMAKB   40
     C                     MOVE *BLANK    WKCD1   1
     C                     MOVE *BLANK    WSW1    1
      *----------*
      *         かんばん種類
      *----------*
 S2  C           WKCD      IFEQ '0'
     C           XMAKB     OREQ 8907
     C                     Z-ADD8907      WMAKB
 X2  C                     ELSE
     C*
     C*  ..Ａ－ＰＩＣＳ　転送先判断マスター..  *
     C           KEY1      SETLLACAPL111
     C*----------
  S3 C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEACAPL111                 10
     C   10                LEAVE
  S4 C           I1SKJY    IFEQ 'D'
     C           I1SKHZ    ANDLE*DATE
  X4 C                     ELSE
     C                     MOVE '*'       WSW1
     C                     Z-ADDI1BMON    WMAKB
     C                     MOVE I1KCD1    WKCD1
     C                     LEAVE
  E4 C                     ENDIF
  E3 C                     ENDDO
     C*----------
  S3 C           WSW1      IFEQ *BLANK
     C                     Z-ADD8990      WMAKB
  X3 C                     ELSE
     C                     SETOF                     11
     C           KEY2      CHAINACAPL111             11
  S4 C           *IN11     IFEQ '0'
     C           I1SKJY    ANDEQ'D'
     C           I1SKHZ    ANDLE*DATE
     C                     SETON                     11
  E4 C                     ENDIF
  S4 C           *IN11     IFEQ '0'
     C                     Z-ADDI1BMON    WMAKB
  X4 C                     ELSE
  S5 C           WMAKB     IFEQ 8907
     C           WKCD1     ANDNE'0'
     C                     Z-ADD8990      WMAKB
  E5 C                     ENDIF
  E4 C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDIF
      *----------*
 S2  C           WMAKB     IFEQ 0111
     C                     EXSR #IRO
     C                     Z-ADDA3KALL    @3KALL
     C                     Z-ADDA3KAIS    @3KAIS
     C                     Z-ADDA3KMIN    @3KMIN
     C                     Z-ADDA3KMAX    @3KMAX
     C                     Z-ADDA3SRMS    @3SRMS
     C                     Z-ADDA3ALHK    @3ALHK
     C                     Z-ADDA3MXHK    @3MXHK
     C                     Z-ADDA3JDMS    @3JDMS
     C                     EXCPTDT1
 E2  C                     ENDIF
E1   C                     ENDDO
      *------------------------------*
      *
      *
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      * BOX COLOR MASTER FILE                                  *
      *================================================================
     C           #IRO      BEGSR
     C*
     C                     MOVEL*BLANK    $$NAME 16        COLOR NAME
     C*
     C           A3HSYU    CHAINABHPP40              95
     C           *IN95     IFEQ *OFF
     C           A4SKJY    ANDEQ' '
     C                     MOVELA4NAME    $$NAME           COLOR NAME
     C                     ENDIF
     C           A3HSYU    IFEQ 'O'
     C                     MOVEL*BLANK    $$NAME           COLOR NAME
     C                     MOVEL'ORANGE ' $$NAME           COLOR NAME
     C                     END
     C*
     C                     ENDSR
      *================================================================
     OAIANP07 EADD             DT1
