     C           *ENTRY    PLIST
     C                     PARM           US     10
      *--------*
      *初期化*
      *--------*
     C                     Z-ADD*DATE     KDATE
     C                     MOVE '-'       @HN1
     C                     MOVE '-'       @HN2
     C                     MOVE '-'       @HN3
     C                     MOVE '-'       @HN4
      *--------*
      *画面１*
      *--------*
     C                     EXSR #INZ
     C           @STP1     TAG
     C                     EXFMTAFBPW831
     C                     SETOF                     0199
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           @CODE     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     0199
     C                     GOTO @STP1
     C                     END
      *
     C           @CODE     IFEQ '1'
     C           @CODE     OREQ '2'
     C                     ELSE
     C                     MOVELER,2      @ERR
     C                     SETON                     0199
     C                     GOTO @STP1
     C                     END
     C           @CODE     IFEQ '1'
     C                     GOTO @STP20
     C                     END
     C           @CODE     IFEQ '2'
     C                     GOTO @STP40
     C                     END
      *--------*
      *画面２*
      *--------*
     C           @STP20    TAG
     C                     EXSR #INZ
     C           @STP2     TAG
     C                     EXFMTAFBPW832
     C                     SETOF                     010203
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           @KUBN     IFEQ *BLANK
     C                     MOVELER,3      @ERR
     C                     SETON                     0199
     C                     GOTO @STP2
     C                     END
      *
     C           @KUBN     IFEQ '0'
     C           @KUBN     OREQ '1'
     C           @KUBN     OREQ '2'
     C                     ELSE
     C                     MOVELER,4      @ERR
     C                     SETON                     0199
     C                     GOTO @STP2
     C                     END
      *
     C           @SUPP     IFEQ *BLANK
     C                     MOVELER,5      @ERR
     C                     SETON                     0299
     C                     GOTO @STP2
     C                     END
      *
     C                     MOVE @SUPP     KSUPP   40
     C                     SETOF                     30
     C           KSUPP     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0299
     C                     MOVELER,6      @ERR
     C                     GOTO @STP2
     C                     END
     C                     MOVELB2SMEI    @SUPPN
     C                     MOVE @SUPP     @SUPPC
      *
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     MOVELER,7      @ERR
     C                     SETON                     0399
     C                     GOTO @STP2
     C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C                     KFLD           WZETI
      *
     C                     MOVEL*BLANK    WZETI   4
      *
     C                     MOVEL*BLANK    #KOSN   1
     C                     SETOF                     30
     C           KEY1      CHAINAFBPL911             30
     C           *IN30     IFEQ '0'
     C                     MOVEL'*'       #KOSN
     C           B9SKJY    IFEQ 'D'
     C           B9SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C           @KUBN     IFEQ '0'
     C           @KUBN     OREQ '1'
     C           *IN30     IFEQ '1'
     C                     MOVELER,8      @ERR
     C                     SETON                     010203
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
      *
     C           @KUBN     IFEQ '2'
     C           *IN30     IFEQ '0'
     C                     MOVELER,9      @ERR
     C                     SETON                     010203
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
      *--------*
      *画面３*
      *--------*
     C                     SETOF                     50
     C           @KUBN     IFEQ '0'
     C                     SETON                     50
     C                     END
     C           @KUBN     IFEQ '0'
     C           @KUBN     OREQ '1'
     C                     Z-ADDB9SYOS    @SYOS
     C                     Z-ADDB9HAKO    @HAKO
     C                     END
      *
     C                     SETOF                     31
     C                     Z-ADD1         A       20
     C           @KUBN     LOKUPKBN,A                    31
     C           *IN31     IFEQ '1'
     C                     MOVE CMT,A     @KBNM
     C                     END
      *
     C           @STP3     TAG
     C                     EXFMTAFBPW833
     C                     SETOF                     0102
     C                     SETOF                     99
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO @STP20
     C                     END
      *
     C           @SYOS     IFEQ 0
     C                     MOVELER,10     @ERR
     C                     SETON                     0199
     C                     GOTO @STP3
     C                     END
      *
     C           @HAKO     IFEQ 0
     C                     MOVELER,11     @ERR
     C                     SETON                     0299
     C                     GOTO @STP3
     C                     END
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP3
     C                     END
      *--------*
      * DELETE *
      *--------*
     C           @KUBN     IFEQ '0'
     C                     MOVEL'D'       B9SKJY
     C                     Z-ADD*DATE     B9SKHZ
     C                     Z-ADD*DATE     B9KOHZ
     C                     TIME           B9KOTI
     C                     MOVELUS        B9KOME
     C                     MOVEL'AFBR83'  B9KOPG
     C                     END
      *------------*
      * CHANGE,ADD *
      *------------*
     C           @KUBN     IFEQ '1'
     C           @KUBN     OREQ '2'
     C                     MOVE *BLANK    B9SKJY
     C                     Z-ADD0         B9SKHZ
     C                     Z-ADD*DATE     B9KOHZ
     C                     TIME           B9KOTI
     C                     MOVELUS        B9KOME
     C                     MOVEL'AFBR83'  B9KOPG
     C                     MOVEL*BLANK    B9ZETI
     C                     MOVEL@HIN1     B9PAR1
     C                     MOVEL@HIN2     B9PAR2
     C                     MOVEL@HIN3     B9PAR3
     C                     Z-ADD@SYOS     B9SYOS
     C                     Z-ADD@HAKO     B9HAKO
     C                     MOVEL'B'       B9ORCD
     C                     MOVEL@SUPP     B9SUPP
     C                     END
      *-------*
      * UPDAT *
      *-------*
     C           @KUBN     IFEQ '2'
     C                     EXSR #SB999
     C                     Z-ADD*DATE     B9DATE
     C                     Z-ADDWKRENO    B9RENO
     C                     END
     C           #KOSN     IFEQ '*'
     C                     UPDATAFBPL911
     C                     ELSE
     C                     WRITEAFBPL911
     C                     END
      *
     C                     GOTO @STP20
      *--------*
      *画面４*
      *--------*
     C           @STP40    TAG
     C                     EXSR #INZ
     C           @STP4     TAG
     C                     EXFMTAFBPW834
     C                     SETOF                     010299
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           @SUPP     IFEQ *BLANK
     C                     MOVELER,13     @ERR
     C                     SETON                     0199
     C                     GOTO @STP4
     C                     END
      *
     C                     MOVE @SUPP     KSUPP   40
     C                     SETOF                     30
     C           KSUPP     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,14     @ERR
     C                     GOTO @STP4
     C                     END
     C                     MOVELB2SMEI    @SUPPN
     C                     MOVE @SUPP     @SUPPC
      *
     C           KEY2      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C                     SETOF                     70
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     ELSE
     C*構成品かんばんマスター
     C                     MOVEL*BLANK    #OK     1
     C                     SETOF                     30
     C           KEY2      SETLLAKBPL051
     C                     DO   *HIVAL
     C           KEY2      READEAKBPL051                 30
     C           *IN30     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDNE*DATE
     C                     ELSE
     C           *DATE     IFGE L1UKHZ
     C           *DATE     ANDLEL1STHZ
     C                     MOVEL'*'       #OK
     C                     SETON                     30
     C                     END
     C                     END
     C                     END
     C  N30                ENDDO
     C*
     C           #OK       IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVELER,15     @ERR
     C                     GOTO @STP4
     C                     END
      *
     C                     SETON                     70
     C                     END
     C                     EXSR #APICS
      *----------------------------------------------------*
      *    RECORD NUMBER GET                             *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
     C                     SETOF                       30
     C           KYYMM     CHAINAFBNP901             30
     C           *IN30     IFEQ '1'
     C                     MOVE KYYMM     BZYYMM
     C                     Z-ADD1         BZNO
     C                     Z-ADDBZNO      WKRENO  50
     C                     WRITEAFBNP901
     C                     ELSE
     C                     ADD  1         BZNO
     C                     Z-ADDBZNO      WKRENO
     C                     UPDATAFBNP901
     C                     END
     CSR         ESB999    ENDSR
      *----------------------------------------------------*
      *    INQUIRY OF THE READOUT DATA                   *
      *----------------------------------------------------*
     CSR         #APICS    BEGSR
      *
     C           @RETRN    TAG
     C           KEY3      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C                     MOVEL*BLANK    #NO
     C                     MOVEL*BLANK    #SH
     C                     MOVEL*BLANK    #ZE
     C                     Z-ADD0         #MA
     C                     Z-ADD0         #SY
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00'      *IN,09
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'00'      *IN,19
      *
     C                     Z-ADD0         Z       30
     C                     Z-ADD10        ZZ      30
     C                     SETOF                     30
     C  N70      @SUPP     SETLLAFBPL911
     C   70      KEY3      SETLLAFBPL911
     C                     DO   *HIVAL
     C  N70      @SUPP     READEAFBPL911                 30
     C   70      KEY3      READEAFBPL911                 30
     C           *IN30     IFEQ '0'
     C           B9SKJY    IFEQ 'D'
     C           B9SKHZ    ANDLE*DATE
     C                     ELSE
     C           B9ZETI    IFNE *BLANK
     C                     ADD  1         Z
     C                     ADD  1         ZZ
     C                     MOVELB9PAR     #SH,Z
     C                     MOVELB9ZETI    #ZE,Z
     C                     Z-ADDB9HAKO    #MA,Z
     C                     Z-ADDB9SYOS    #SY,Z
     C                     MOVELB9PAR1    HPAR1   5
     C                     MOVELB9PAR2    HPAR2   5
     C                     MOVELB9PAR3    HPAR3   2
     C                     MOVELB9ZETI    HZETI   4
     C           B9ERR     IFNE *BLANK
     C                     MOVEA'1'       *IN,ZZ
     C                     END
     C           Z         IFEQ 1
     C                     MOVELB9PAR1    LPAR1   5
     C                     MOVELB9PAR2    LPAR2   5
     C                     MOVELB9PAR3    LPAR3   2
     C                     MOVELB9ZETI    LZETI   4
     C                     END
     C           Z         IFEQ 10
     C                     SETON                     30
     C                     END
     C                     END
     C                     END
     C                     END
     C  N30                ENDDO
      *--------*
      *画面５*
      *--------*
     C           @STP5     TAG
     C                     EXFMTAFBPW835
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     1099
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO @STP40
     C                     END
      *
     C           KEY4      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           WPAR1
     C                     KFLD           WPAR2
     C                     KFLD           WPAR3
     C                     KFLD           WZETI
      *
     C           *IN90     IFEQ '1'
     C                     EXSR #ROLUP
     C           Z         IFEQ 0
     C                     MOVELER,16     @ERR
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C                     END
     C           *IN95     IFEQ '1'
     C                     EXSR #ROLDW
     C           Z         IFEQ 11
     C                     MOVELER,17     @ERR
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C           Z         IFNE 1
     C                     GOTO @RETRN
     C                     END
     C                     END
      *
     C                     Z-ADD0         K       20
     C           1         DO   10
     C                     ADD  1         K
     C           #NO,K     IFEQ *BLANK
     C           #NO,K     OREQ '0'
     C           #NO,K     OREQ '1'
     C           #NO,K     IFEQ '0'
     C           #NO,K     OREQ '1'
     C           #SH,K     IFEQ *BLANK
     C                     MOVELER,18     @ERR
     C                     MOVEA'1'       *IN,K
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C                     END
     C                     ELSE
     C                     MOVELER,19     @ERR
     C                     MOVEA'1'       *IN,K
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
     C                     ENDDO
      *
     C                     SETOF                     50
     C                     Z-ADD0         K       20
     C           1         DO   10
     C                     ADD  1         K
     C           #NO,K     IFEQ '0'
     C           #NO,K     OREQ '1'
     C                     MOVEL#SH,K     KPAR   14
     C                     MOVEL#ZE,K     KZETI   4
     C           #NO,K     IFEQ '0'
     C                     SETON                     50
     C                     END
      *
     C           KEY5      KLIST
     C                     KFLD           @SUPP
     C                     KFLD           KPAR1
     C                     KFLD           KPAR2
     C                     KFLD           KPAR3
     C                     KFLD           KZETI
      *
     C                     SETOF                     30
     C           KEY5      CHAINAFBPL911             30
     C           *IN30     IFEQ '0'
     C           B9SKJY    IFEQ 'D'
     C           B9SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
      *
     C           *IN30     IFEQ '0'
     C                     MOVELB9PAR1    @HIN1
     C                     MOVELB9PAR2    @HIN2
     C                     MOVELB9PAR3    @HIN3
     C                     MOVELB9ZETI    @ZETI
     C                     Z-ADDB9HAKO    @MAIS
     C                     Z-ADDB9SYOS    @SYOS
     C                     MOVELB9ERR1    @ERR1
     C                     MOVELB9ERR2    @ERR2
     C                     GOTO @STP6
     C                     ELSE
     C                     MOVELER,20     @ERR
     C                     SETON                     99
     C                     GOTO @STP5
     C                     END
      *
     C                     END
     C                     ENDDO
     C                     GOTO @STP5
      *--------*
      *画面６*
      *--------*
     C           @STP6     TAG
     C                     EXFMTAFBPW836
     C                     SETOF                     010203
     C                     SETOF                     0499
      *
     C           *INKC     IFEQ '1'
     C                     GOTO @RETRN
     C                     END
     C           *IN50     IFEQ '0'
     C           @MAIS     IFEQ 0
     C                     MOVELER,21     @ERR
     C                     SETON                     0199
     C                     GOTO @STP6
     C                     END
      *
     C           @SYOS     IFEQ 0
     C                     MOVELER,22     @ERR
     C                     SETON                     0299
     C                     GOTO @STP6
     C                     END
      *
     C           @ERR1     IFEQ ' '
     C           @ERR1     OREQ '*'
     C                     ELSE
     C                     MOVELER,24     @ERR
     C                     SETON                     0399
     C                     GOTO @STP6
     C                     END
      *
     C           @ERR2     IFEQ ' '
     C           @ERR2     OREQ '*'
     C                     ELSE
     C                     MOVELER,24     @ERR
     C                     SETON                     0499
     C                     GOTO @STP6
     C                     END
      *
     C                     END
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP6
     C                     END
      *
     C           *IN50     IFEQ '0'
     C                     MOVE *BLANK    B9SKJY
     C                     Z-ADD0         B9SKHZ
     C                     Z-ADD*DATE     B9KOHZ
     C                     TIME           B9KOTI
     C                     MOVELUS        B9KOME
     C                     MOVEL'AFBR83'  B9KOPG
     C                     Z-ADD@SYOS     B9SYOS
     C                     Z-ADD@MAIS     B9HAKO
     C                     MOVEL@ERR1     B9ERR1
     C                     MOVEL@ERR2     B9ERR2
     C                     ELSE
     C                     MOVEL'D'       B9SKJY
     C                     Z-ADD*DATE     B9SKHZ
     C                     Z-ADD*DATE     B9KOHZ
     C                     TIME           B9KOTI
     C                     MOVELUS        B9KOME
     C                     MOVEL'AFBR83'  B9KOPG
     C                     END
      *
     C                     UPDATAFBPL911
     C                     GOTO @RETRN
      *
     CSR                   ENDSR
      *----------------------------------------------------*
      *    ROLL UP                                       *
      *----------------------------------------------------*
     CSR         #ROLUP    BEGSR
     C                     MOVEL*BLANK    #NO
     C                     MOVELHPAR1     WPAR1   5
     C                     MOVELHPAR2     WPAR2   5
     C                     MOVELHPAR3     WPAR3   2
     C                     MOVELHZETI     WZETI   4
     C                     Z-ADD0         Z
     C                     Z-ADD10        ZZ
     C                     SETOF                       30
     C           KEY4      SETGTAFBPL911
     C                     DO   *HIVAL
     C  N70      @SUPP     READEAFBPL911                 30
     C   70      KEY3      READEAFBPL911                 30
     C           *IN30     IFEQ '0'
     C           B9SKJY    IFEQ 'D'
     C           B9SKHZ    ANDLE*DATE
     C                     ELSE
     C           B9ZETI    IFNE *BLANK
     C                     ADD  1         Z
     C                     ADD  1         ZZ
     C           Z         IFEQ 1
     C                     MOVEL*BLANK    #SH
     C                     MOVEL*BLANK    #ZE
     C                     Z-ADD0         #MA
     C                     Z-ADD0         #SY
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'00'      *IN,19
     C                     MOVELB9PAR1    LPAR1   5
     C                     MOVELB9PAR2    LPAR2   5
     C                     MOVELB9PAR3    LPAR3   2
     C                     MOVELB9ZETI    LZETI   4
     C                     END
     C                     MOVELB9PAR     #SH,Z
     C                     MOVELB9ZETI    #ZE,Z
     C                     Z-ADDB9HAKO    #MA,Z
     C                     Z-ADDB9SYOS    #SY,Z
     C                     MOVELB9PAR1    HPAR1   5
     C                     MOVELB9PAR2    HPAR2   5
     C                     MOVELB9PAR3    HPAR3   2
     C                     MOVELB9ZETI    HZETI   4
     C           B9ERR     IFNE *BLANK
     C                     MOVEA'1'       *IN,ZZ
     C                     END
     C           Z         IFEQ 10
     C                     GOTO EROLUP
     C                     END
     C                     END
     C                     END
     C                     END
     C  N30                ENDDO
     CSR         EROLUP    ENDSR
      *----------------------------------------------------*
      *    ROLL DWN                                      *
      *----------------------------------------------------*
     CSR         #ROLDW    BEGSR
     C                     MOVEL*BLANK    #NO
     C                     MOVELLPAR1     WPAR1   5
     C                     MOVELLPAR2     WPAR2   5
     C                     MOVELLPAR3     WPAR3   2
     C                     MOVELLZETI     WZETI   4
     C                     Z-ADD11        Z
     C                     Z-ADD21        ZZ
     C                     SETOF                       30
     C           KEY4      SETLLAFBPL911
     C                     DO   *HIVAL
     C  N70      @SUPP     REDPEAFBPL911                 30
     C   70      KEY3      REDPEAFBPL911                 30
     C           *IN30     IFEQ '0'
     C           B9SKJY    IFEQ 'D'
     C           B9SKHZ    ANDLE*DATE
     C                     ELSE
     C           B9ZETI    IFNE *BLANK
     C                     SUB  1         Z
     C                     SUB  1         ZZ
     C           Z         IFEQ 10
     C                     MOVEL*BLANK    #SH
     C                     MOVEL*BLANK    #ZE
     C                     Z-ADD0         #MA
     C                     Z-ADD0         #SY
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'00'      *IN,19
     C                     MOVELB9PAR1    HPAR1   5
     C                     MOVELB9PAR2    HPAR2   5
     C                     MOVELB9PAR3    HPAR3   2
     C                     MOVELB9ZETI    HZETI   4
     C                     END
     C                     MOVELB9PAR     #SH,Z
     C                     MOVELB9ZETI    #ZE,Z
     C                     Z-ADDB9HAKO    #MA,Z
     C                     Z-ADDB9SYOS    #SY,Z
     C                     MOVELB9PAR1    LPAR1   5
     C                     MOVELB9PAR2    LPAR2   5
     C                     MOVELB9PAR3    LPAR3   2
     C                     MOVELB9ZETI    LZETI   4
     C           B9ERR     IFNE *BLANK
     C                     MOVEA'1'       *IN,ZZ
     C                     END
     C           Z         IFEQ 1
     C                     GOTO EROLDW
     C                     END
     C                     END
     C                     END
     C                     END
     C  N30                ENDDO
     CSR         EROLDW    ENDSR
      *----------------------------------------------------*
      *    INZ                                           *
      *----------------------------------------------------*
     CSR         #INZ      BEGSR
     C                     MOVE *BLANK    @CODE
     C                     MOVE *BLANK    @KUBN
     C                     MOVE *BLANK    @SUPP
     C                     MOVE *BLANK    @HIN1
     C                     MOVE *BLANK    @HIN2
     C                     MOVE *BLANK    @HIN3
     C                     MOVE *BLANK    @KBNM
     C                     MOVE *BLANK    @SUPPC
     C                     MOVE *BLANK    @SUPPN
     C                     Z-ADD0         @SYOS
     C                     Z-ADD0         @HAKO
     C                     MOVE *BLANK    #NO
     C                     MOVE *BLANK    #SH
     C                     MOVE *BLANK    #ZE
     C                     MOVE *BLANK    #MA
     C                     MOVE *BLANK    #SY
     C                     MOVE *BLANK    @ZETI
     C                     MOVE *BLANK    @ERR1
     C                     MOVE *BLANK    @ERR2
     CSR         EINZ      ENDSR
