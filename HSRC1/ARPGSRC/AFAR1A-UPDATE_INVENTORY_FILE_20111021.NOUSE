     C           K#KEY     KLIST
     C                     KFLD           CFHIN1
     C                     KFLD           CFHIN2
     C                     KFLD           CFHIN3
      *
     C           CFSKJY    CABEQ'D'       SKP01
     C           K#KEY     CHAINFCEPL01              91
     C           *IN91     CABEQ*ON       SKP01
      * HEADR FILE
     C           K#KEY     CHAINAH#PL50              90
     C   90                CLEARAH#PP501
     C                     Z-ADD*DATE     A5KODT
     C                     TIME           A5KOTM
