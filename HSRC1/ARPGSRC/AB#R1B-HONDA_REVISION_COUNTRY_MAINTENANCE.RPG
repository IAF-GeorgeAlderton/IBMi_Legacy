     C                     MOVEA'00'      *IN,61
      * CHECK PART
     C           D@PRT1    IFEQ *BLANK
     C           D@PRT2    OREQ *BLANK
     C                     MOVE MSG,1     D@MSG
     C                     SETON                     6199
     C                     ELSE
     C           K#KEYX    CHAINAB#PL56             N90
     C           *IN90     IFEQ *ON
