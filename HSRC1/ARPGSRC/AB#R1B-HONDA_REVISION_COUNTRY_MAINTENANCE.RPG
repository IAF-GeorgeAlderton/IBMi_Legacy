     C                     MOVE SHN2      A5SHN2
     C                     MOVE SHN3      A5SHN3
     C                     MOVELD@EDI     A5EDIC
     C                     MOVELD@LBL     A5LBLC
     C                     MOVELD@NONY    A5NONY
     C                     MOVELD@DCEC    A5DCLV
JW3  C                     MOVELD@SHDT    A5SHDT
JW2  C                     MOVEL@CGRP     A5CGRP
      *
     C           *IN90     IFEQ *OFF
     C                     UPDATAB#PP551
JW2  C                     ELSE
JW2  C                     Z-ADD*DATE     A5CRHZ
JW2  C                     TIME           A5CRTM
JW2  C                     MOVEL#USER     A5CRME
JW2  C                     MOVEL#PGM      A5CRPG
     C                     WRITEAB#PP551
JW2  C                     ENDIF
