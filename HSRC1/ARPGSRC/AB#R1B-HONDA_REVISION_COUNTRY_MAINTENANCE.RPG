     C           #DLT      BEGSR
      *----------------------------------------------------
JW2  C           K#KEYY    CHAINAB#PL56              90
     C           *IN90     IFEQ *OFF
     C                     DELETAB#PP551
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #UPD      BEGSR
      *----------------------------------------------------
     C           K#KEY     SETLLFAAPL05
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEFAAPL05                  90
     C           *IN90     IFEQ *OFF
     C           B7SKBN    ANDEQ*BLANK
     C           D@NONY    IFNE *ZERO
     C           D@NONY    ANDNEB7NONY
     C                     ITER
     C                     ENDIF
     C                     MOVE B7SHN1    SHN1
     C                     MOVE B7SHN2    SHN2
     C                     MOVE B7SHN3    SHN3
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
JW2  C           K#KEYY    CHAINAB#PL56              90
      *
     C                     Z-ADD*DATE     A5KODT
     C                     TIME           A5KOTN
     C                     MOVEL#USER     A5KOME
     C                     MOVE D@PRT1    A5MHN1
