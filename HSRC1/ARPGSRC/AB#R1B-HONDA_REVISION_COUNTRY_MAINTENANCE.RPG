     C                     MOVE *BLANK    D@LBL
     C                     MOVE *BLANK    D@DCEC
     C                     ELSE
     C                     MOVELA5EDIC    D@EDI
     C                     MOVELA5LBLC    D@LBL
     C                     MOVELA5DCLV    D@DCEC
JW3  C                     MOVELA5SHDT    D@SHDT
     C                     ENDIF
     C                     ENDIF
