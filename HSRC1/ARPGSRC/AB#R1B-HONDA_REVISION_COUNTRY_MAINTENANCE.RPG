     C                     MOVELA5SHN2    S@PRT2
     C                     MOVELA5SHN3    S@PRT3
     C                     MOVELA5MHN1    S@MHN1
     C                     MOVELA5MHN2    S@MHN2
     C                     MOVELA5MHN3    S@MHN3
     C                     MOVELA5MHN4    S@MHN4
     C                     MOVELA5EDIC    S@EDI
     C                     MOVELA5LBLC    S@LBL
     C                     MOVELA5NONY    S@NONY
     C                     MOVELA5DCLV    S@DCLV
JW3  C                     MOVELA5SHDT    S@SHDT
     C                     WRITESFL01
     C                     ENDIF
