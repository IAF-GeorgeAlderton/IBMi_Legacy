     C           #SET      BEGSR
      *----------------------------------------------------
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
JW2  C           @CGRP     SETLLAB#PL56
     C           *IN90     DOUEQ*ON
JW2  C           @CGRP     READEAB#PL56                  90
     C           *IN90     IFEQ *OFF
