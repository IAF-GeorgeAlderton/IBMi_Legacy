     C           *INKX     WHEQ *ON
     C                     EXSR #DLT
JW1  C           *IN90     IFEQ *OFF
JW1  C                     MOVE MSG,5     D@MSG
JW1  C                     MOVE '01'      @@ID
JW1  C                     ELSE
JW1  C                     MOVE MSG,6     D@MSG
JW1  C                     ENDIF
      *
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
      *
JW1  C           *IN90     IFEQ *OFF
JW1  C                     MOVE MSG,4     D@MSG
JW1  C                     ELSE
JW1  C                     MOVE MSG,3     D@MSG
JW1  C                     ENDIF
      *
     C           P@MHN1    IFEQ *BLANK
     C                     MOVE '01'      @@ID
     C                     ELSE
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #CHK2     BEGSR
      *----------------------------------------------------
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'000'     *IN,61
      * CHECK EFFECTIVE DATE
     C           D@DCEC    IFNE *BLANK
     C           D@SHDT    ANDEQ*BLANK
     C                     SETON                     6399
     C                     MOVE MSG,7     D@MSG
     C                     GOTO ECHK2
     C                     ENDIF
      * CHECK EFFECTIVE DATE
     C           D@DCEC    IFEQ *BLANK
     C           D@SHDT    ANDNE*BLANK
     C                     SETON                     6399
     C                     MOVE MSG,10    D@MSG
     C                     GOTO ECHK2
     C                     ENDIF
      * CHECK EFFECTIVE DATE
     C           D@SHDT    IFNE *BLANK
     C                     MOVELD@SHDT    $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE     D@SHDT    P
     C                     ELSE
     C                     SETON                     6399
     C                     MOVE MSG,8     D@MSG
     C                     GOTO ECHK2
     C                     ENDIF
     C                     ENDIF
      *
     C           D@EDI     IFEQ *BLANK
     C                     SETON                     6199
     C                     MOVE MSG,9     D@MSG
     C                     GOTO ECHK2
     C                     ENDIF
      *
     C           D@LBL     IFEQ *BLANK
     C                     MOVE MSG,9     D@MSG
     C                     SETON                     6299
     C                     GOTO ECHK2
     C                     ENDIF
      *
     C           ECHK2     ENDSR
