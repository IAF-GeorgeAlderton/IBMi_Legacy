     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------
     C           *INZSR    BEGSR
      *----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@MHN1  5
     C                     PARM           P@MHN2  5
     C                     PARM           P@MHN3  5
     C                     PARM           P@MHN4  5
     C                     PARM           P@NONY  40
      *
     C           K#KEY     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           D@PRT4
      *
     C           K#KEYY    KLIST
JW2  C                     KFLD           @CGRP
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           D@PRT4
      *
     C           K#KEYX    KLIST
JW2  C                     KFLD           @CGRP
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           D@PRT4
     C                     KFLD           D@NONY
      *
     C                     MOVE '01'      @@ID    2
JW2  C                     MOVEL'HND'     @CGRP   3
      *
     C           P@MHN1    IFNE *BLANK
     C                     MOVE P@MHN1    D@PRT1
     C                     MOVE P@MHN2    D@PRT2
     C                     MOVE P@MHN3    D@PRT3
     C                     MOVE P@MHN4    D@PRT4
