     H            Y.
     F** EJRR17 **********************************************
     F*  R820FORD REM ADV (COPY EB#PP6J/K/L TO AB#PP6J/K/L)  *
     F*  J.WATANABE 2017.07.12                               *
     F********************************************************
     FEB#PP6J IF  E                    DISK
     FEB#PP6K IF  E                    DISK
     FEB#PP6L IF  E                    DISK
     FAB#PP6J O   E                    DISK
     FAB#PP6K O   E                    DISK
     FAB#PP6L O   E                    DISK
      **********************************************************
      ** COPY EB#PP6J TO AB#PP6J     **
     C                     MOVE *OFF      *IN90
     C           *IN90     DOUEQ*ON
     C                     READ EB#PP6J                  90
     C           *IN90     IFEQ *OFF
     C                     WRITEAB#PP6J1
     C                     ENDIF
     C                     ENDDO
      *
      ** COPY EB#PP6K TO AB#PP6K     **
     C                     MOVE *OFF      *IN90
     C           *IN91     DOUEQ*ON
     C                     READ EB#PP6K                  91
     C           *IN91     IFEQ *OFF
     C                     WRITEAB#PP6K1
     C                     ENDIF
     C                     ENDDO
      *
      ** COPY EB#PP6L TO AB#PP6L     **
     C                     MOVE *OFF      *IN90
     C           *IN92     DOUEQ*ON
     C                     READ EB#PP6L                  92
     C           *IN92     IFEQ *OFF
     C                     WRITEAB#PP6L1
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
