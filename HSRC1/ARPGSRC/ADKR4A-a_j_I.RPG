     H            Y.
     F** ADKR4A *******************************************************
     F*つるべ生産指示 便あたり上限の計算
     F*  2020.07.14
     F*****************************************************************
     FAGAPL41 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAAIPL11 IF  E           K        DISK
     FADKPP4A IF  E           K        DISK
     FADKPP42 O   E                    DISK                      A
     FADKPL53 UF  E           K        DISK                      A
     E                    OKT        15  3               工程
     E                    OTK        15  6               所番地
     E                    OSY        15  1               か種
     E                    OBM        15  4               部門
      *
     I            DS
     I                                        1   6 WKTKR
     I                                        1   1 WKTKR1
     I                                        2   3 WKTKR2
     I                                        4   5 WKTKR3
     I                                        6   6 WKTKR4
      *
     I            DS
     I                                        1  100WKAP
     I                                        1   80WKAPHZ
     I                                        9  100WKAPBN
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WDATE
     C           *ENTRY    PLIST
     C                     PARM           PHM     4
     C                     CALL 'ADKR90'
     C                     PARM           PHM     4
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     Z-ADDP1APHZ    WKAPHZ  80
     C                     Z-ADDP1APBN    WKAPBN  20
      *
     C                     EXSR #SB780
     C                     EXSR #SB790
     C                     MOVEL'1'       OPNCLS
      *
     C                     Z-ADD0         WKTOTL 122
     C                     READ AGAPL411                 22
     C           *IN22     DOWEQ'0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB390
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ AGAPL411                 22
     C                     ENDDO
      *
     C                     Z-ADD0         WKSETB 122
     C           WKBINS    IFNE 0
     C           WKTOTL    DIV  WKBINS    WKSETB
     C                     ENDIF
     C                     CLEARADKPP421
     C                     Z-ADDSDATE     D4KOHZ
     C                     Z-ADDSTIME     D4KOTI
     C                     MOVELW#PGM     D4KOME
     C                     Z-ADDWKAPHZ    D4APHZ
     C                     Z-ADDWKAPBN    D4APBN
     C                     Z-ADDWKTOTL    D4TOTL
     C                     Z-ADDWKSETB    D4SETB
     C                     Z-ADDWKKSU     D4KSU
     C           WKSETB    MULT WKKSU     D4LIMT
     C                     WRITEADKPP421
      *
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *工程情報                         *
      *-----------------------------------*
     CSR         #SB390    BEGSR
      *
     C                     CLEAROKT
     C                     CLEAROTK
     C                     CLEAROSY
     C                     CLEAROBM
     C                     MOVE WKAP      INYMDB
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
     C           STATUS    IFEQ '9'
     C                     GOTO ESB390
     C                     ENDIF
      *
     C                     MOVEAPKOT      OKT
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSY
     C                     MOVEAPBMN      OBM
      *
     C                     Z-ADD0         IDX1    30
     C                     Z-ADD15        X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWGE1
     C           IDX1      ANDEQ0
     C           OSY,X     IFEQ CBKDAI
     C                     Z-ADDX         IDX1
     C                     ENDIF
     C                     SUB  1         X
     C                     ENDDO
      *前工程
     C                     EXSR #SB391
      *
     CSR         ESB390    ENDSR
      *----------------------------------------------------*
      *前工程
      *----------------------------------------------------*
     CSR         #SB391    BEGSR
      *前工程
     C                     Z-ADD0         IDX2    30
     C                     Z-ADD0         X
     C                     MOVEL*BLANK    WKKT    3
     C                     MOVEL*BLANK    WKBM    4
     C           IDX1      SUB  1         X
     C           X         DOWGE1
     C           IDX2      ANDEQ0
     C           OTK,X     IFNE '------'
     C           OTK,X     ANDNE'++++++'
     C                     Z-ADDX         IDX2
     C                     MOVELOKT,X     WKKT
     C                     MOVELOBM,X     WKBM
     C                     ENDIF
     C                     SUB  1         X
     C                     ENDDO
      *
     CSR         ESB391    ENDSR
      *-----------------------------------*
      *                                   *
      *-----------------------------------*
     CSR         #SB400    BEGSR
      *部品Ｍ
     C           KEYSHN    KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C           KEYSHN    CHAINFCEPL011             22
     C           *IN22     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '1'
     C                     GOTO ESB400
     C                     ENDIF
      *便数
     C                     Z-ADDWKCIBI    WKBINS  20
      *設定数
     C                     Z-ADD0         WKGEKN 120
     C                     Z-ADD0         P9GEKN 120
     C                     CALL 'ADKR96'
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           P9GEKN 120
     C                     Z-ADDP9GEKN    WKGEKN
      *日当り箱数
     C                     Z-ADD0         WKSETD 122
     C           CBSYUY    IFNE 0
     C           WKGEKN    DIV  CBSYUY    WKSETD    H
     C           WKSETD    DIV  20        WKSETD    H
     C                     ENDIF
      *
     C           WKSETD    IFLE 0
     C                     Z-ADD1         WKSETD
     C                     ENDIF
      *
     C                     ADD  WKSETD    WKTOTL
      *
     C                     EXSR #SB450
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *工程別                                            *
      *----------------------------------------------------*
     CSR         #SB450    BEGSR
      *
     C                     MOVELCBSHN1    P1SHN1
     C                     MOVELCBSHN2    P1SHN2
     C                     MOVELCBSHN3    P1SHN3
     C                     Z-ADDP1APHZ    P2APHZ
     C                     Z-ADDP1APBN    P2APBN
     C                     CALL 'ADKR44'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P9DATA  1
     C                     PARM           P9CODE  1
     C                     PARM           P9GROP  2
     C                     PARM           P9PROC  3
     C                     PARM           P9KBN   3
     C           P9DATA    IFEQ '1'
     C           P9DATA    OREQ '2'
     C                     MOVELWKBM      KKBMON  40
     C                     MOVELP9CODE    KKCODE
     C                     MOVELP9GROP    KKGROP
     C                     MOVELP9PROC    KKPRC
     C           P9CODE    IFEQ '1'
     C                     MOVELP9KBN     KKKBN
     C                     ELSE
     C                     MOVEL*BLANK    KKKBN
     C                     ENDIF
     C                     EXSR #SB451
     C                     ENDIF
      *
     CSR         ESB450    ENDSR
      *----------------------------------------------------*
      *工程別                                            *
      *----------------------------------------------------*
     CSR         #SB451    BEGSR
      *
     C           KEY51     KLIST
     C                     KFLD           KKCODE  1
     C                     KFLD           KKGROP  2
     C                     KFLD           KKPRC   3
     C                     KFLD           KKKBN   3
     C                     KFLD           KKAPHZ
     C                     KFLD           KKAPBN
     C                     Z-ADDWKAPHZ    KKAPHZ  80
     C                     Z-ADDWKAPBN    KKAPBN  20
      *
     C           KEY51     CHAINADKPL531             85
      *
     C                     Z-ADD0         WKSETB 122
     C           WKBINS    IFNE 0
     C           WKSETD    DIV  WKBINS    WKSETB
     C                     ENDIF
      *
     C           *IN85     IFEQ '1'
     C                     CLEARADKPL531
     C                     Z-ADDSDATE     D5KOHZ
     C                     Z-ADDSTIME     D5KOTI
     C                     MOVELW#PGM     D5KOME
     C                     MOVELKKBMON    D5BMON
     C                     MOVELKKCODE    D5CODE
     C                     MOVELKKGROP    D5GROP
     C                     MOVELKKPRC     D5PROC
     C           D5CODE    IFEQ '1'
     C                     MOVELKKKBN     D5KBN
     C                     ENDIF
     C                     Z-ADDWKAPHZ    D5APHZ
     C                     Z-ADDWKAPBN    D5APBN
     C                     Z-ADDWKSETD    D5TOTL
     C                     Z-ADDWKSETB    D5SETB
     C                     Z-ADDWKKSUP    D5KSU
     C           D5SETB    MULT WKKSUP    D5LIMT
     C                     Z-ADD0         D5MAIS
     C                     WRITEADKPL531
     C                     ELSE
     C                     ADD  WKSETD    D5TOTL
     C                     ADD  WKSETB    D5SETB
     C           D5SETB    MULT WKKSUP    D5LIMT
     C                     UPDATADKPL531
     C                     ENDIF
      *
     CSR         ESB451    ENDSR
      *----------------------------------------------------*
      *係数                                              *
      *----------------------------------------------------*
     CSR         #SB780    BEGSR
      *
     C                     MOVEL'TOTAL'   KKKEY  10
     C                     Z-ADD1.00      WKKSU   52
     C           KKKEY     CHAINADKPP4A1             20
     C           *IN49     IFEQ '0'
     C                     Z-ADDD@KSU     WKKSU
     C                     ENDIF
      *工程別
     C                     MOVEL*BLANK    KKKEY
     C                     MOVEL'PROCESS' KKKEY  10
     C                     Z-ADD1.00      WKKSUP  52
     C           KKKEY     CHAINADKPP4A1             20
     C           *IN49     IFEQ '0'
     C                     Z-ADDD@KSU     WKKSUP
     C                     ENDIF
      *
     CSR         ESB780    ENDSR
      *----------------------------------------------------*
      *便数                                              *
      *----------------------------------------------------*
     CSR         #SB790    BEGSR
      *
     C                     Z-ADD0         WKCIBI  20
     C           0111      CHAINAAIPL111             49
     C           *IN49     IFEQ '0'
     C                     Z-ADDCDCIBI    WKCIBI
     C                     ENDIF
      *
     CSR         ESB790    ENDSR
