     C  N44                READ AGDPL121                 44
     C  N44                Z-ADDAWENDD    DTE,Z
     C  N44                READ AGDPL121                 44
     C  N44                Z-ADDAWENDD    DTE,Z
     C  N44                READ AGDPL121                 44
     C  N44                Z-ADDAWENDD    DTE,Z
     C  N44                READ AGDPL121                 44
     C  N44                Z-ADDAWENDD    DTE,Z
     C  N44                READ AGDPL121                 44
     C  N44                Z-ADDAWENDD    DTE,Z
     C  N44                READ AGDPL121                 44
     C  N44                Z-ADDAWENDD    DTE,Z
     C*
