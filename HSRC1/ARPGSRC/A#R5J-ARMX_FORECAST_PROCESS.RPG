     C           @DATE1    BEGSR
     C******************************************************
     C                     CLEARMMS
     C                     CLEARDDS
     C*
     C                     DO
     C*
TCHK2C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C           *IN10     IFEQ *OFF
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C* MMDD
     C           X         ADD  1         Y
     C                     MOVEAAY,Y      W@MNDD
     C           W@MNDD    IFEQ *BLANK
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD1         I       20
     C           W@MN      LOKUPMN1,I                    11
     C           *IN11     IFEQ *OFF
     C                     Z-ADD1         I
     C           W@MN      LOKUPMN2,I                    11
     C           *IN11     IFEQ *OFF
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C                     END
     C*
     C                     MOVEAW@DD      A21
     C           A21,1     IFLT '0'
     C           A21,1     ORGT '3'
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C           A21,2     IFLT '0'
     C           A21,2     ORGT '9'
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     ADD  1         Z
     C           Z         IFGT 20
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C                     Z-ADDI         MMS,Z
     C                     MOVELW@DD      DDS,Z
     C*
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C           @DATE2    BEGSR
     C******************************************************
     C                     CLEARDTS
     C                     CLEARDTE
     C*
     C                     DO
     C* YY
TCHK2C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C           *IN10     IFEQ *OFF
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C*
     C           X         ADD  1         Y
     C                     MOVEAAY,Y      W@YY    2
     C           W@YY      IFEQ *BLANK
     C                     LEAVE
     C                     END
     C*
     C                     MOVEAW@YY      A21
     C           A21,1     IFLT '0'
     C           A21,1     ORGT '9'
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C           A21,2     IFLT '0'
     C           A21,2     ORGT '9'
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     ADD  1         Z
     C           Z         IFGT 20
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C                     MOVELW@YY      W@YYNN  20
     C           W@YYNN    ADD  2000      YEAR
