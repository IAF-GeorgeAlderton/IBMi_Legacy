     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
      * CONSTANT
     C                     CLEARABAWMXF1
     C                     Z-ADD3316      AWTOKU
     C                     Z-ADD3316      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
      *
     C                     CLEARAY
     C                     MOVEADAT2      AY,1
     C* =====================
     C* HEADER #1(DATE.MM/DD)
     C* =====================
     C           *IN99     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'QTY PER 'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'qty per 'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Qty Per 'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Qty per 'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'qty Per 'SCAN DAT2      X              10
     C  N10                GOTO @@END
     C*
TCHK2C                     MOVEL*OFF      W@ERR
TCHK2C                     EXSR @SKP14
TCHK2C           W@ERR     IFEQ *ON
TCHK2C                     GOTO @@END
TCHK2C                     END
TCHK2C*
     C                     MOVEL*OFF      W@ERR   1
     C                     EXSR @DATE1
     C           W@ERR     IFEQ *OFF
     C                     MOVE *ON       *IN99
     C                     END
     C                     GOTO @@END
     C                     END
     C* =========
     C* HEADER #2(DATE.YY)
     C* =========
     C           *IN98     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'LAST CUM'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'last cum'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Last Cum'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Last cum'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'last Cum'SCAN DAT2      X              10
     C  N10                GOTO @@END
     C*
TCHK2C                     MOVEL*OFF      W@ERR
TCHK2C                     EXSR @SKP14
TCHK2C           W@ERR     IFEQ *ON
TCHK2C                     GOTO @@END
TCHK2C                     END
TCHK2C*
     C                     MOVEL*OFF      W@ERR
     C                     EXSR @DATE2
     C           W@ERR     IFEQ *OFF
     C                     MOVE *ON       *IN98
     C                     END
     C                     GOTO @@END
     C                     END
     C*
     C*=======
     C* DETAIL
     C*=======
     C                     Z-ADD1         X
     C           '-'       SCAN DAT2      X              10
     C  N10                GOTO @@END
     C*
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C* -------------
     C*   PART NUMBER
     C* -------------
     C                     MOVEL*BLANK    APT
     C                     Z-ADDX         Y       30
     C                     Z-ADD*ZERO     Z       30
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,Y      IFEQ '-'
     C           AY,Y      OREQ ' '
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      APT,Z
     C                     ENDDO
     C                     MOVEAAPT       #PART
     C* -------
     C* QTY/BOX
     C* -------
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C*
     C                     MOVE *BLANKS   AQT
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,Y      IFLT '0'
     C           AY,Y      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      AQT,Z
     C                     ENDDO
     C*
     C                     MOVEL*ALL'0'   SQT
     C                     EXSR #QTY
     C                     MOVEASQT       AWXXXX
     C                     MOVE AWXXXX    AW5555  5
     C                     MOVELAW5555    AWSYOS
      * ---
      * QTY
      * ---
TCHK2C                     MOVEL*OFF      W@ERR
TCHK2C                     EXSR @SKP14
TCHK2C           W@ERR     IFEQ *ON
TCHK2C                     GOTO @@END
TCHK2C                     END
TCHK2C*
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVE *BLANKS   AQT
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     J       20
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,Y      IFLT '0'
     C           AY,Y      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         J
     C                     MOVELAY,Y      AQT,J
     C                     ENDDO
     C*
     C                     MOVEL*ALL'0'   SQT
     C                     EXSR #QTY
     C                     MOVEASQT       AWXXXX  9
     C                     MOVELAWXXXX    AWSRYO
     C*
     C                     ADD  1         Z
     C                     Z-ADDDTS,Z     AWSTRD
     C                     Z-ADDDTE,Z     AWENDD
     C*
     C* WRITE
     C*
     C                     WRITEABAWMXF1
     C                     MOVE '1'       PID
     C*
     C                     ENDDO
     C*-------------------------------------------------
     C*
     C*
     C           @@END     TAG
     C******************************************************
     C           @SKP14    BEGSR
     C******************************************************
     C*
     C                     Z-ADD*ZERO     X1      20
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         X1
     C           X1        IFGT 14
     C                     LEAVE
     C                     END
     C*
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                MOVEL*ON       W@ERR
     C  N10                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
