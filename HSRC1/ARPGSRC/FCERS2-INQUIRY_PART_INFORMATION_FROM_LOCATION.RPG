      *** FCERS2 *****************************************************
      *   INQUIRY PART INFORMATION FROM LOCATION
      *
      *     KIRI                         2014.10.16
      ****************************************************************
     H            Y/                                    1
     FFCEPWS2 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFREC1
      * .. PART INFORMATION M/F   *.
     FFCEPL03 IF  E           K        DISK
     FFCEPL06 IF  E           K        DISK
      *================================================================
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I* DELETE DUE DATE *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I* LOCATION CODE CHANGE DATE *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I* PART NO. *
     I            DS
     I                                        1  14 S1BHB
     I                                        1   5 S1BHB1
     I                                        6   6 S1HF1
     I                                        7  11 S1BHB2
     I                                       12  12 S1HF2
     I                                       13  14 S1BHB3
     I* OLD LOCATION *
     I            DS
     I                                        1   9 S1OLD
     I                                        1   1 A2KTRK
     I                                        2   2 S1OH1
     I                                        3   4 A2KTRT
     I                                        5   5 S1OH2
     I                                        6   7 A2KTRR
     I                                        8   8 S1OH3
     I                                        9   9 A2KTRD
     I* NEW LOCATION *
     I            DS
     I                                        1   9 S1NEW
     I                                        1   1 A2STRK
     I                                        2   2 S1NH1
     I                                        3   4 A2STRT
     I                                        5   5 S1NH2
     I                                        6   7 A2STRR
     I                                        8   8 S1NH3
     I                                        9   9 A2STRD
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@TKR1  1        LOCATION 1
     C                     PARM           P@TKR2  2        LOCATION 2
     C                     PARM           P@TKR3  2        LOCATION 3
     C                     PARM           P@TKR4  1        LOCATION 4
     C                     PARM           P@HIN1  5        PART NO. 1
     C                     PARM           P@HIN2  5        PART NO. 2
     C                     PARM           P@HIN3  2        PART NO. 3
     C                     PARM           P@RTN   1        9:該当なし
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C*         ５日前
     C                     MOVE *DATE     QQDATE  8
     C                     MOVE '-'       QQPORM  1        + OR -
     C                     MOVE '0005'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR1A'
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C                     MOVE QQRDAT    $5MAE   80       ５日前
     C*         ５日後
     C                     MOVE *DATE     QQDATE  8
     C                     MOVE '+'       QQPORM  1        + OR -
     C                     MOVE '0005'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR1A'
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C                     MOVE QQRDAT    $5ATO   80       ５日後
     C*
     C           KEY01     KLIST
     C                     KFLD           K@TKR1  1        LOCATION 1
     C                     KFLD           K@TKR2  2        LOCATION 2
     C                     KFLD           K@TKR3  2        LOCATION 3
     C                     KFLD           K@TKR4  1        LOCATION 4
     C           KEY02     KLIST
     C                     KFLD           K@TKR1  1        LOCATION 1
     C                     KFLD           K@TKR2  2        LOCATION 2
     C                     KFLD           K@TKR3  2        LOCATION 3
     C*
     C                     MOVELP@TKR1    K@TKR1           LOCATION 1
     C                     MOVELP@TKR2    K@TKR2           LOCATION 2
     C                     MOVELP@TKR3    K@TKR3           LOCATION 3
     C                     MOVELP@TKR4    K@TKR4           LOCATION 4
     C                     MOVEL*BLANK    P@HIN1           PART NO. 1
     C                     MOVEL*BLANK    P@HIN2           PART NO. 2
     C                     MOVEL*BLANK    P@HIN3           PART NO. 3
     C                     MOVEL*BLANK    P@RTN            9:該当なし
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C****ＫＥＹ＝所番地４まで
     C                     SETOF                     50
     C                     MOVEL'NEW'     @@DTA   3
     C                     EXSR #READ1
     C                     MOVEL'OLD'     @@DTA
     C                     EXSR #READ1
     C*
     C           RRN1      IFEQ 0
     C****ＫＥＹ＝所番地３まで
     C                     SETON                     50
     C                     MOVEL'NEW'     @@DTA
     C                     EXSR #READ1
     C                     MOVEL'OLD'     @@DTA
     C                     EXSR #READ1
     C                     ENDIF
     C*
     C                     SELEC
     C           RRN1      WHEQ 0
     C                     MOVEL'9'       P@RTN            9:該当なし
     C                     MOVE '#END    '@STEP
     C           RRN1      WHEQ 1
     C                     MOVELS1BHB1    P@HIN1           PART NO. 1
     C                     MOVELS1BHB2    P@HIN2           PART NO. 2
     C                     MOVELS1BHB3    P@HIN3           PART NO. 3
     C                     MOVE '#END    '@STEP
     C                     OTHER
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1
     C                     MOVE '#DSP1   '@STEP
     C                     WRITEW1
     C                     ENDSL
     C*
     C                     ENDSR
      *================================================================
      *================================================================
     C           #READ1    BEGSR
     C           @@DTA     IFEQ 'NEW'
     C  N50      KEY01     SETLLFCEPL03
     C   50      KEY02     SETLLFCEPL03
     C                     ELSE
     C  N50      KEY01     SETLLFCEPL06
     C   50      KEY02     SETLLFCEPL06
     C                     ENDIF
      *-----------------------------------
     C                     DO   *HIVAL
     C           @@DTA     IFEQ 'NEW'
     C  N50      KEY01     READEFCEPL03                  90
     C   50      KEY02     READEFCEPL03                  90
     C                     ELSE
     C  N50      KEY01     READEFCEPL06                  90
     C   50      KEY02     READEFCEPL06                  90
     C                     ENDIF
     C   90                LEAVE
     C*
     C           A2GSKD    IFEQ 'D'                        DELETE CODE
     C           A2GSHZ    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C           @@DTA     IFEQ 'NEW'
     C           A2TRHZ    ANDGT$5ATO                      ５日後
     C                     ITER
     C                     ENDIF
     C           @@DTA     IFEQ 'OLD'
     C           A2TRHZ    ANDLT$5MAE                      ５日前
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVE *BLANK    S1SEL
     C                     MOVE '-'       S1HF1
     C                     MOVE '-'       S1HF2
     C                     MOVE '-'       S1OH1
     C                     MOVE '-'       S1OH2
     C                     MOVE '-'       S1OH3
     C                     MOVE '-'       S1NH1
     C                     MOVE '-'       S1NH2
     C                     MOVE '-'       S1NH3
     C                     MOVE A2BHB1    S1BHB1
     C                     MOVE A2BHB2    S1BHB2
     C                     MOVE A2BHB3    S1BHB3
     C           S1BHB3    IFEQ *BLANK
     C                     MOVE ' '       S1HF2
     C           S1BHB2    IFEQ *BLANK
     C                     MOVE ' '       S1HF1
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDA2TRHZ    S1YMD
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C*
     C                     ENDDO
      *-----------------------------------
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     7071
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < PAGE UP/DOWN >
     C           *IN75     WHEQ *ON
     C           *IN76     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C*----------
     C* < F3 > 終了
     C           *INKC     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C                     OTHER
     C           CSRN1     CHAINSFREC1               92
     C           *IN92     IFEQ *OFF
     C                     MOVELS1BHB1    P@HIN1           PART NO. 1
     C                     MOVELS1BHB2    P@HIN2           PART NO. 2
     C                     MOVELS1BHB3    P@HIN3           PART NO. 3
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSL
     C                     ENDSR
      *===============================================================
      *===============================================================
