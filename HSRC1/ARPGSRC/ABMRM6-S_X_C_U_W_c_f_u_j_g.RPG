     C                     MOVELJ6BRAH    WBRAH   2
     C                     MOVELJ6UKYY    WUKYY   4
     C                     MOVELJ6UKMM    WUKMM   2
     C                     MOVELJ6UKDD    WUKDD   2
     C                     MOVELJ6UBIN    WUBIN   2
     C                     MOVELJ6MAKB    WMAKB   4
     C                     MOVEL*BLANK    WERR    1
      *自動処理調整をゼロにする
     C                     SETOF                         80
     C                     Z-ADD0         W1MAIS  40
     C                     ADD  J6DAND    W1MAIS
     C                     ADD  J6KYOT    W1MAIS
     C                     ADD  J6FRYO    W1MAIS
     C                     ADD  J6SENY    W1MAIS
     C                     ADD  J61NAI    W1MAIS
     C                     ADD  J62NAI    W1MAIS
