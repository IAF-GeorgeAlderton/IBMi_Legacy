     C                     SETOF                     22
     C                     TIME           WTIME
     C           1         SETLLABMWP211
     C                     READ ABMWP211                 21
     C           *IN21     DOWEQ'0'
     C           W2OMIT    IFEQ '0'
     C           W2PAS     ANDEQ'0'
     C                     EXSR #SB200
     C                     UPDATABMWP211
     C                     ENDIF
     C                     READ ABMWP211                 21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *焼入れかんばん検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYJ61    KLIST
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
      *
     C                     MOVELW2SHN1    #K1HB5
     C                     MOVELW2SHN2    #K2HB5
     C                     MOVELW2SHN3    #K3HB2
     C           KEYJ61    SETGTADHTL051
     C           KEYJ61    REDPEADHTL051                 82
     C           *IN82     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           J6STHZ    IFEQ 99999999
     C*****      J6KMAX    IFEQ 999
     C           J6KMAX    IFEQ 99999
     C                     MOVEL'6'       W2OMIT
     C                     ELSE
     C********             Z-ADDW2NSRY    WKSRYO
     C                     EXSR #SB400
     C                     EXSR #SB410
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYJ61    REDPEADHTL051                 82
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      * GHCPP21より設定数       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SETOF                     99
     C           KEYMD1    KLIST
     C                     KFLD           #KMBN1  1
     C                     KFLD           #KMBN2  2
     C                     KFLD           #KMBN3  2
     C                     KFLD           #KMBN4  1
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C                     MOVELJ6ATK1    #KMBN1
     C                     MOVELJ6ATK2    #KMBN2
     C                     MOVELJ6ATK3    #KMBN3
     C                     MOVELJ6ATK4    #KMBN4
     C                     MOVELJ6SHN1    #KMHN1
     C                     MOVELJ6SHN2    #KMHN2
     C                     MOVELJ6SHN3    #KMHN3
     C                     MOVEL'0'       FGET2   1
     C                     Z-ADD0         WKSRYO  90
     C                     Z-ADD0         GHSRYO  90
     C           KEYMD1    SETLLGHDTL211
     C           KEYMD1    READEGHDTL211                 83
     C           *IN83     DOWEQ'0'
     C                     Z-ADDMDSRYO    GHSRYO
     C                     EXSR #SB405
     C                     MOVEL'1'       FGET2
     C           KEYMD1    READEGHDTL211                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *---------------------------*
      * ABMPL21より設定数       *
      *---------------------------*
     CSR         #SB405    BEGSR
      *
     C           KEY21     KLIST
     C                     KFLD           W2NTYM
     C                     KFLD           MDJHN1
     C                     KFLD           MDJHN2
     C                     KFLD           MDJHN3
     C                     Z-ADD0         W@FFF   90
      *
     C           W2OMIT    IFEQ '0'
     C                     Z-ADDW2NSRY    W@FFF
     C           W2FSMN    IFGT W@FFF
     C                     Z-ADD0         W@EEE   90
     C           W2NWDY    IFNE 0
     C           W2FSMN    DIV  W2NWDY    W@EEE   90
     C                     ENDIF
     C           W@EEE     MULT 20        W@FFF
     C                     ENDIF
     C           W2FSM1    IFGT W2FSMN
     C           W2FSM1    ANDGTW2NSRY
     C                     Z-ADD0         W@EEE   90
     C           W2AWDY    IFNE 0
     C           W2FSM1    DIV  W2AWDY    W@EEE   90
     C                     ENDIF
     C           W@EEE     MULT 20        W@FFF
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDMDSETI    W@FFF
     C                     SETON                     99
     C                     ENDIF
      *
     C                     ADD  W@FFF     WKSRYO
      *
     CSR         ESB405    ENDSR
      *---------------------------*
      *かんばん枚数計算         *
      *---------------------------*
     CSR         #SB410    BEGSR
      *
     C                     Z-ADDJ6SYOS    @BSSYS  70
     C                     MOVELJ6SYOT    @BSSYT  1
     C                     Z-ADDJ6KTSU    @BKTSU  90
     C                     Z-ADDJ6KMAX    @BKMAX  90
     C                     Z-ADDJ6TSEI    @BMAXH  30
     C                     Z-ADDJ6LOTO    @BKLOT  30
     C                     Z-ADD0         @BPADJ  30
     C                     Z-ADDJ6AUAJ    @BAUAJ  30
     C                     Z-ADD0         @BDUPH  30
     C                     Z-ADDJ6OTHH    @BOTHH  30
      *
     C           WKSRYO    DIV  20        W@KSSU  90
     C                     Z-ADD0         W@HAKD  51
     C           W2SSYS    IFNE 0
     C           W@KSSU    DIV  W2SSYS    W@HAKD
     C                     ENDIF
     C           W@HAKD    IFEQ 0
     C                     Z-ADD0.1       W@HAKD
     C                     ENDIF
     C                     EXSR #SB710
      *
     C                     Z-ADDJ6KALL    WKALL   50
     C                     Z-ADDJ6KMIN    WMIN    50
     C                     Z-ADDJ6KMAX    WMAX    50
     C           J6KALL    IFLT J6KMAX
     C                     Z-ADDJ6KMAX    WALL    50
     C                     ELSE
     C                     Z-ADDJ6KALL    WALL
     C                     ENDIF
      *
     C           J6SYOS    IFEQ 0
     C                     MOVEL'6'       W2OMIT
     C                     GOTO ESB410
     C                     ENDIF
      *
     C                     SELEC
     C           WKSRYO    WHLT J6KTSU
     C                     MOVEL'51'      J6STI1
     C           WKSRYO    WHGT J6KTSU
     C                     MOVEL'52'      J6STI1
     C                     ENDSL
     C                     Z-ADDGHSRYO    J6KSSU
     C                     Z-ADDWKSRYO    J6KTSU
     C                     Z-ADDJ6KMAX    SVKMAX  50
      *
     C                     MOVE '00000'   WMISU   5
     C                     MOVE J6KTSU    WKTSU   9
     C                     MOVELJ6SYOS    WSYOS   7
     C                     MOVELJ6KAKE    WKAKE   2
     C                     MOVELJ6NKOJ    WATOB   4
     C                     MOVELJ6HKLT    WHKLT   2
     C                     MOVELJ6LOTO    WLOTO   2
     C                     MOVELJ6TOLT    WTOLT   3
     C                     MOVELJ6ANZR    WANZR   3
