     H            Y.
     F** APLR84 *********************************************
     F* MULTIPLE PROCESS CONTROL FILE INQUIRY               *
     F*       T.SAKAKI .......         2016.10.13           *
     F********************************************* APLR84 **
     FAPLPW84 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     F                                              KINFDS INFDS
     FAPLPP80 IF  E           K        DISK
     FEGBPL11 IF  E           K        DISK
      *
     E                    ER      1   8 70
     I            DS
     I                                        1   30@1MNNO
     I                                        1   20@@MNNO
     I                                        3   30@@MNDN
      *
     I            DS
     I                                        1   80A1SKHZ
     I                                        1   40A1SKYY
     I                                        5   60A1SKMM
     I                                        7   80A1SKDD
     I            DS
     I                                        1   80A1STHZ
     I                                        1   40A1STYY
     I                                        5   60A1STMM
     I                                        7   80A1STDD
     I            DS
     I                                        1   60A1STTI
     I                                        1   20A1STTH
     I                                        3   40A1STTM
     I                                        5   60A1STTS
      *
     IINFDS       DS
     I                                    B 370 3710#CUR
     I                                    B 378 3790#POS
      *----------------------------------------------------*
      * PARAMETER                                          *
      *----------------------------------------------------*
     C           APLR81    PLIST
     C                     PARM           P1PGMN 10
      *----------------------------------------------------*
      * KEY LIST                                           *
      *----------------------------------------------------*
     C           KEYI1     KLIST
     C                     KFLD           #1PGMN 10
     C           KEYSV1    KLIST
     C                     KFLD           #SPGMN 10
      *----------------------------------------------------*
      * MAIN ROUTINE                                       *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           *IN01     DOWEQ'0'
     C                     EXSR #SB200
     C                     END
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INITIALIZE                                         *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
     C                     MOVEL*BLANK    DSPSW1  1
     C                     MOVEL*BLANK    DSPSW2  1
     C                     MOVEL*BLANK    @ERR
      *
     C                     SETON                     10
     C                     MOVE '1'       DSPSW1  1
     CSR         #S100E    ENDSR
      *----------------------------------------------------*
      * MAIN PROCESS                                       *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
     C           *IN01     DOWEQ'0'
     C           *IN05     ANDEQ'0'
     C           *IN10     ANDEQ'1'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           *IN01     DOWEQ'0'
     C           DSPSW2    ANDEQ'1'
     C                     EXSR #SB220
     C                     ENDDO
     CSR         #S200E    ENDSR
      *----------------------------------------------------*
      * 1ST SCREEN    (SFLCTL)                           *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
      *--------------------*
      * DISPLAY DETAIL   *
      *--------------------*
     C                     EXSR #SB410
     C                     SETOF                     816699
     C                     Z-ADD0         CTRX    40
     C                     MOVEL*BLANK    #1PGMN
     C           KEYI1     SETLLAPLPP801
     C                     DO   *HIVAL
     C                     EXSR #SB400
     C  N66N81             ENDDO
      * NO RECORD
     C           CTRX      IFEQ 0
     C                     MOVELER,5      @ERR
     C                     SETON                     9981
     C                     DO   *HIVAL
     C                     EXFMTAPLPW842
      * CMD-1
     C           *IN01     IFEQ '1'
     C                     EXSR #SB410
     C                     MOVE '0'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     GOTO #S210E
     C                     END
      * CMD-10
     C           *IN10     IFEQ '1'
     C                     EXSR #SB410
     C                     MOVE '1'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     GOTO #S210E
     C                     END
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     EXSR #SB900
      *
     C                     Z-ADD1         WKPAGE  30
      *
     C                     MOVE '0'       DSPSW1
     C                     MOVE '1'       DSPSW2
      *
     CSR         #S210E    ENDSR
      *----------------------------------------------------*
      * 1ST SCREEN    (SFL)                              *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
     C                     SETON                     7270
     C                     WRITEAPLPW841
     C                     EXFMTSFLCTL
     C                     SETOF                     7270
      *
     C                     SETOF                     9935
     C                     MOVE *BLANK    @ERR
      * CMD-1
     C           *IN01     IFEQ '1'
     C                     EXSR #SB410
     C                     MOVE '0'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     GOTO #S220E
     C                     END
      * CMD-10
     C           *IN10     IFEQ '1'
     C                     EXSR #SB410
     C                     MOVE '1'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     GOTO #S220E
     C                     END
      *-------------------*
      * ROLLDOWN          *
      *-------------------*
     C           *IN52     IFEQ '1'
     C                     ADD  1         CTRX
      *
     C           WKPAGE    IFEQ 1
     C                     GOTO #S220E
     C                     END
      *
     C           *IN81     IFEQ '1'
     C                     SETOF                       81
     C           KEYI1     SETGTAPLPP801
     C                     END
      *
     C                     SUB  1         WKPAGE  30
     C                     ADD  15        CTRX
     C                     SETOF                       27
     C                     DO   *HIVAL
     C                     EXSR #SB401
     C  N27N81             ENDDO
      *
     C                     EXSR #SB410
      *
     C           *IN81     IFEQ '1'
     C                     SETOF                       81
     C           KEYI1     SETLLAPLPP801
     C                     END
      *
     C                     Z-ADD0         CTRX
     C                     SETOF                       66
     C                     DO   *HIVAL
     C                     EXSR #SB400
     C  N81N66             ENDDO
     C                     EXSR #SB900
     C                     GOTO #S220E
     C                     END
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     IFEQ '0'
     C                     ADD  1         WKPAGE  30
      *
     C                     EXSR #SB410
      *
     C                     Z-ADD0         CTRX    40
     C                     SETOF                       66
     C                     DO   *HIVAL
     C                     EXSR #SB400
     C  N66N81             ENDDO
     C                     EXSR #SB900
     C                     END
     C                     GOTO #S220E
     C                     END
      *--------------------*
      * DELETE PROCESS     *
      *--------------------*
     C           *IN05     IFEQ '0'
     C                     GOTO #S220E
     C                     END
      *
     C                     SETOF                     25
     C                     Z-ADD1         X       20
     C           1         DO   *HIVAL    X
     C           X         CHAINSFL                  25
     C   25                LEAVE
     C           OP        IFNE *BLANK
     C           OP        ANDNE'0'
     C                     SETON                     99
     C                     MOVELER,6      @ERR
     C                     END
      *
     C  N99      OP        IFEQ '0'
     C                     EXSR #SB910
     C                     MOVE '0'       @OPSTS
     C                     SETON                         21
     C                     END
      *
     C           @OPSTS    IFEQ '0'
     C                     SETON                         21
     C                     END
      *
     C  N99                MOVE *BLANK    OP
     C                     UPDATSFL
     C                     SETOF                         21
      *
     C  N99                ENDDO
      *
     CSR         #S220E    ENDSR
      *----------------------------------------------------*
      * END PROCESS                                        *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         #S300E    ENDSR
      *----------------------------------------------------*
      * DATA READING                              *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
     C                     SETOF                     66
     C                     READ APLPP801            N    81
     C                     MOVE '0'       GETSW   1
     C                     SETOF                     67
     C           *IN81     IFEQ '0'
     C           A1SKJY    ANDEQ'D'
     C           A1SKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
      *
     C                     EXSR #SB499
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
     C                     SETOF                       21
      *
     C                     END
      *
     C           CTRX      IFEQ 15
     C                     SETON                       66
     C                     END
      *
     CSR         #S400E    ENDSR
      *----------------------------------------------------*
      * BACKWARD READING                                   *
      *----------------------------------------------------*
     CSR         #SB401    BEGSR
     C                     SETOF                       66
     C                     READPAPLPP801            N    81
     C                     MOVE '0'       GETSW
     C                     SETOF                     67
     C           *IN81     IFEQ '0'
     C           A1SKJY    ANDEQ'D'
     C           A1SKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
      *
     C                     SUB  1         CTRX           27
      *
     C                     END
     CSR         #S401E    ENDSR
      *----------------------------------------------------*
      * TABLE SUBFILE CLEAR                                *
      *----------------------------------------------------*
     CSR         #SB410    BEGSR
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     71
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    50
     C                     Z-ADD1         @SFRC1
     CSR         #S410E    ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #SB499    BEGSR
      *
     C                     MOVE *BLANK    OP
     C                     MOVELA1PGMN    @1PGMN
     C                     MOVELA1PGMN    K1PGMN  6
     C                     MOVE A1WSID    @1WSID
     C                     MOVE A1USID    @1USID
     C                     MOVE A1KONA    @1KONA
     C                     MOVE A1STHZ    @1STHZ
     C                     MOVE A1STTI    @1STTI
     C                     MOVE *BLANK    @OPSTS
      *SET MENU NO.
     C           KEY1      KLIST
     C                     KFLD           @1USID
     C                     KFLD           K1PGMN
     C                     SETOF                     88
     C                     Z-ADD0         @1MNNO
     C           KEY1      CHAINEGBPL11              88
     C           *IN88     IFEQ '0'
     C                     Z-ADDM1MNNO    @@MNNO
     C                     Z-ADDM1MNDN    @@MNDN
     C                     ENDIF
     C*
     CSR         #S499E    ENDSR
      *----------------------------------------------------*
      * SET NEXT RECORD                                    *
      *----------------------------------------------------*
     CSR         #SB900    BEGSR
     C                     SETOF                     68
     C                     DO   *HIVAL
     C                     READ APLPP801            N    81
     C                     MOVE '0'       GETSW
     C                     SETOF                     67
     C           *IN81     IFEQ '0'
     C           A1SKJY    ANDEQ'D'
     C           A1SKHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
      *
     C                     MOVE A1PGMN    #SPGMN
     C                     SETON                     68
      *
     C                     END
      *
     C  N81N68             ENDDO
      *
     C           *IN68     IFEQ '1'
     C           KEYSV1    SETLLAPLPP801
     C                     END
      *
     CSR         #S900E    ENDSR
      *----------------------------------------------------*
      *  DELETE FLAG         　　　　　                  *
      *----------------------------------------------------*
     CSR         #SB910    BEGSR
     C                     MOVEL@1PGMN    P1PGMN
     C                     CALL 'APLR81'  APLR81
     CSR         #S910E    ENDSR
** MSG
ER-01
ER-02
ER-03
ER-04
