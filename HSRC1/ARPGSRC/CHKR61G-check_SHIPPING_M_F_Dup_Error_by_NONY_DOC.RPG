     H            Y.
     F** CHKR61G ***************************************************************
     F*  PROGRAM    : CHECK SHIPPING M/F ERROR BY NONY/DOCK                    *
     F*  WRITTEN    : 2022.12.19                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FGADPL11CIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100@YEAR
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLGADPL11C
      *
     C                     DO   *HIVAL
     C                     READ GADPL11C                 98
     C   98                LEAVE
      * IGNORE
     C           B5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELB5NONY    SVNONY  40
     C                     MOVELB5NUKE    SVNUKE  4
     C                     ENDIF
      * BREAK?
     C           B5NONY    IFNE SVNONY
     C           B5NUKE    ORNE SVNUKE
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C                     ADD  1         RCNT
     C                     SELEC
     C           SVTOK1    WHEQ 0
     C                     Z-ADDB5TOKU    SVTOK1
     C           SVTOK2    WHEQ 0
     C           SVTOK1    IFNE B5TOKU
     C                     Z-ADDB5TOKU    SVTOK2
     C                     ENDIF
     C           SVTOK3    WHEQ 0
     C           SVTOK1    IFNE B5TOKU
     C           SVTOK2    ANDNEB5TOKU
     C                     Z-ADDB5TOKU    SVTOK3
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      * TOTAL
     C           SEQ#      IFEQ 0
     C                     EXCPT@HDR
     C                     EXCPT@TTL1
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     EXCPT@TTL2
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C           RCNT      IFGE 2
     C                     EXSR #PRINT
     C                     ENDIF
      * RESET
     C                     Z-ADDB5NONY    SVNONY
     C                     MOVELB5NUKE    SVNUKE
     C                     Z-ADD0         RCNT
     C                     Z-ADD0         SVTOK1
     C                     Z-ADD0         SVTOK2
     C                     Z-ADD0         SVTOK3
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE ' '       $RTN
     C                     Z-ADD0         RCNT    40       RECORD#
     C                     Z-ADD0         SVTOK1  40
     C                     Z-ADD0         SVTOK2  40
     C                     Z-ADD0         SVTOK3  40
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SHIPPING M/F DUPL'
     O                                   60 'ICATE ERROR (GADPP11'
     O                                   80 ') **                '
     O                                   80 'DATE'
     O                         TODAY     91 '    .  .  '
     O                         NOW      101 '  :  :  '
     O                                  105 'P.'
     O                         PAGE  Z  109
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'NONY'
     O                                   16 'DOCK'
     O                                   22 'CUS1'
     O                                   28 'CUS2'
     O                                   34 'CUS3'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         SVNONY  +001
     O                         SVNUKE  +002
     O                         SVTOK1Z +002
     O                         SVTOK2Z +002
     O                         SVTOK3Z +002
      *
     O        E 1              @TTL1
     O                                 +000 ' ** THERE IS NO ERRO'
     O                                 +000 'R FOR THIS REPORT **'
      *
     O        E 1              @TTL2
     O                                 +000 ' ** TOTAL ERROR'
     O                         SEQ#  1 +001
     O                                 +001 '**'
