      *
      *=====
      *  F1
     C           *INKA     IFEQ '1'
     C                     SETON                     U2LR
     C                     RETRN
     C                     END
      *
      *--------------*
      * 実績日付年 *
      *--------------*
     C           IJSYY     IFEQ 0
     C                     SETON                     5199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IJSYY     IFLT 2017
     C                     SETON                     5199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
      *=====
      *  F5
     C           *INKE     IFEQ '0'
