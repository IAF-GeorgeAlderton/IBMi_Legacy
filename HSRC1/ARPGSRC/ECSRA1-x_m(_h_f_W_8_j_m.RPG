      ******************
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ ECSPL071                 10
     C           *IN10     IFEQ '1'
     C                     LEAVE
     C                     END
     C           EQSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           IJSYY     IFNE EQYOYY
     C                     ITER
     C                     END
      *
     C                     Z-ADD0         WSYOS   30
     C                     MOVE *BLANK    WTKR1   1
     C                     MOVE *BLANK    WTKR2   2
     C                     MOVE *BLANK    WTKR3   2
     C                     MOVE *BLANK    WTKR4   1
     C                     Z-ADD0         WSRYO   72
