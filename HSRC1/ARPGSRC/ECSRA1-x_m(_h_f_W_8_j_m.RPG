     C           *DATE     IFGE T6KIHZ
     C                     Z-ADDT6SYOS    WSYOS
     C                     MOVELT6TKR1    WTKR1
     C                     MOVELT6TKR2    WTKR2
     C                     MOVELT6TKR3    WTKR3
     C                     MOVELT6TKR4    WTKR4
