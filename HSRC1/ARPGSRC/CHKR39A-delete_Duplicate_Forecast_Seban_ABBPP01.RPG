     H            Y.
     F***CHKR39A ***************************************************************
     F*  PROGRAM    : DELETE DUPLICATE ORDERS (ABBPP01) FC SEBAN               *
     F*             : READ ABBPL04                                             *
     F*  WRITTEN    : 2021.10.19                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FCHKWP39 IF  E                    DISK
     FABBPL04 UF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ CHKWP39                  98
     C   98                LEAVE
      * DELETE ABBPP01
     C                     MOVELQ5TOKU    K#TOKU
     C                     MOVELQ5MHN1    K#MHN1
     C                     MOVELQ5MHN2    K#MHN2
     C                     MOVELQ5MHN3    K#MHN3
     C                     MOVELQ5MHN4    K#MHN4
     C                     MOVELQ5NONY    K#NONY
     C                     MOVELQ5NKOJ    K#NKOJ
     C                     MOVELQ5NUKE    K#NUKE
     C           K#PL04    SETLLABBPL04
     C                     DO   *HIVAL
     C           K#PL04    READEABBPL04                  97
     C   97                LEAVE
      *
     C           Q5SEBN    IFEQ *BLANK
     C           Q5NNNM    ANDEQ0
     C           Q51NNM    ANDEQ0
     C                     DELETABBPP011
     C                     EXSR #PRINT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           K#PL04    KLIST
     C                     KFLD           K#TOKU  40
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** DUPLICATE ORDER ('
     O                                   60 'DELETED) ABBPP01 ** '
     O                                   99 'DATE'
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   20 'F'
     O                                   26 'DOCK'
     O                                   37 'USER_PART'
     O                                   55 ' SEBAN'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         Q5TOKU  +002
     O                         Q5NONY  +002
     O                         Q5NKOJ  +002
     O                         Q5NUKE  +002
     O                         Q5MHN1  +002
     O                         Q5MHN2  +001
     O                         Q5MHN3  +001
     O                         Q5MHN4  +001
     O                         Q5SEBN  +001
