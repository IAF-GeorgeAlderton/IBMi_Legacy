     C           #NEXT     BEGSR
      *
     C                     MOVE O@HIN1    PIHIN1  5
     C                     MOVE O@HIN2    PIHIN2  5
     C                     MOVE O@HIN3    PIHIN3  2
     C                     MOVE *BLANK    PIBMON  4
     C                     MOVE *BLANK    PIKOTE  3
     C                     MOVE *BLANK    PIKIBN  3
     C                     MOVE M6JBN1    PIBAN1  1
     C                     MOVE M6JBN2    PIBAN2  2
     C                     MOVE M6JBN3    PIBAN3  2
     C                     MOVE M6JBN4    PIBAN4  1
     C                     MOVE *DATE     PIDATE  8
     C                     MOVE '01'      PIBIN   2
      *
     C                     MOVE *BLANK    POBMON  4
     C                     MOVE *BLANK    POKOTE  3
     C                     MOVE *BLANK    POKIBN  3
      *
     C           AAMRS6    PLIST
     C                     PARM           PIHIN1  5
     C                     PARM           PIHIN2  5
     C                     PARM           PIHIN3  2
     C                     PARM           PIBMON  4
     C                     PARM           PIKOTE  3
     C                     PARM           PIKIBN  3
     C                     PARM           PIBAN1  1
     C                     PARM           PIBAN2  2
     C                     PARM           PIBAN3  2
     C                     PARM           PIBAN4  1
     C                     PARM           PIDATE  8
     C                     PARM           PIBIN   2
      *
     C                     PARM           POBMON  4
     C                     PARM           POKOTE  3
     C                     PARM           POKIBN  3
      *
     C                     CALL 'AAMRS6'  AAMRS6
      *
     C                     MOVELPOKOTE    O@KOTE  3
     C                     MOVE *BLANK    O@KIBN 15
     C                     MOVELPOKIBN    O@KIBN
     C           POBMON    IFNE *BLANK
     C           POBMON    ANDNE'0111'
     C                     MOVE POBMON    N@BMON  40
     C           N@BMON    CHAINFGBPL01              65
     C  N65                MOVELB2SMEI    O@KIBN
     C                     END
      *
     C           ENEXT     ENDSR
      *================================================================
      *指定した部門・工程・機番の前の部門・工程・機番を取得
      *================================================================
     C           #PRE      BEGSR
      *
     C                     MOVE O@HIN1    PIHIN1  5
     C                     MOVE O@HIN2    PIHIN2  5
     C                     MOVE O@HIN3    PIHIN3  2
     C                     MOVE *BLANK    PIBMON  4
     C                     MOVE *BLANK    PIKOTE  3
     C                     MOVE *BLANK    PIKIBN  3
     C                     MOVE M6JBN1    PIBAN1  1
     C                     MOVE M6JBN2    PIBAN2  2
     C                     MOVE M6JBN3    PIBAN3  2
     C                     MOVE M6JBN4    PIBAN4  1
     C                     MOVE *DATE     PIDATE  8
     C                     MOVE '01'      PIBIN   2
      *
     C                     MOVE *BLANK    POBMON  4
     C                     MOVE *BLANK    POKOTE  3
     C                     MOVE *BLANK    POKIBN  3
      *
     C                     CALL 'AAMRS5'  AAMRS6
      *
     C                     MOVELPOKOTE    @@KOTE  3
     C                     MOVE *BLANK    @@KIBN 15
     C                     MOVELPOKIBN    @@KIBN
     C**         POBMON    IFNE *BLANK
     C**         POBMON    ANDNE'0111'
     C**                   MOVE POBMON    N@BMON  40
     C**         N@BMON    CHAINFGBPL01              65
     C**N65                MOVELB2SMEI    @@KIBN
     C**                   END
      *
     C                     ENDSR
      *================================================================
      *
      *================================================================
     C           #CMP      BEGSR
      *
     C                     MOVE *BLANK    W@ENGN 15
      *
     C           CMPKEY    KLIST
     C                     KFLD           K@CMP1  5
     C                     KFLD           K@CMP2  5
     C                     KFLD           K@CMP3  2
     C           CMPKEY    SETGTFCGPP05
     C           CMPKEY    REDPEFCGPP05                  75
     C   75                Z-ADD0         EDHDSC
     C   75                Z-ADD0         ED2SDS
     C   75                GOTO ECMP
      *
     C           FCGKKK    KLIST
     C                     KFLD           EDSHP1
     C                     KFLD           FCGKY1  1
     C                     KFLD           FCGKY2  1
      *
     C                     MOVE '4'       FCGKY1
     C                     MOVE EDSHP4    FCGKY2
     C           FCGKKK    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    W@ENGN
     C                     END
      *
     C           ECMP      ENDSR
      *================================================================
      *
      *================================================================
     C           #CLR2     BEGSR
     C                     Z-ADD0         WWGOKE  80
     C                     Z-ADD0         WWNNNM 100
     C                     Z-ADD0         WW1NNM 100
     C                     Z-ADD0         WW2NNM 100
     C                     Z-ADD0         WWGEKN  90
     C                     Z-ADD0         WWKADO 100
     C           ECLR2     ENDSR
      *================================================================
      *
      *================================================================
     C           #OUT2     BEGSR
     C*見出し
     C           *IN97     IFEQ *OFF
     C                     MOVEL'SET#/D'  @@SET#  6
     C           D1KBN     IFEQ '1'                        :FUTURE
     C                     MOVELD1YYM     @@SET#
     C                     ENDIF
     C                     EXCPTOHED2
     C                     ENDIF
     C*
     C                     SETON                     97
     C*
     C           T1KEY     KLIST
     C                     KFLD           M6HIN1
     C                     KFLD           M6HIN2
     C                     KFLD           M6HIN3
     C*
     C           D1KBN     IFEQ '1'                        :FUTURE
     C           WWGEKN    MULT D1RITU    W$GEKN 120
     C           W$GEKN    DIV  100       WWGEKN
JW2  C**         T1KEY     CHAINABHPPT1              92
 |   C**N92      M#SKJY    IFEQ 'D'                        DELETE CODE
 |   C**         M#SKDT    ANDLE*DATE                      DELETE DATE
 |   C**                   SETON                     92
 |   C**                   ENDIF
 |   C**N92      M#ADDS    DIV  20        M#ADDS
JW2  C**N92                ADD  M#ADDS    WWGEKN
     C                     ENDIF
     C*
     C           M6SETO    IFEQ 0
     C                     Z-ADD1         M6SETO
     C                     END
JW4   * EDIT WWKADO
