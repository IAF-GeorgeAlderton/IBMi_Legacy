      ******************************** ABHRS1 **
     FABHPWS1 CF  E                    WORKSTN
     FABHPL03 IF  E           K        DISK
     FGHCTL21 IF  E           K        DISK
     FAAFPL09 IF  E           K        DISK
     FAAHPL09 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FMFAPL25 IF  E           K        DISK
     FFCGPP31 IF  E           K        DISK
     FFCGPP41 IF  E           K        DISK
     FFCGPP05 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
JW2  F**ABHPPT1 IF  E           K        DISK
     FABHWPS1 O   F    2048            DISK
     FABHWPS2 O   F    2048            DISK
JW1  FABHWPS4 O   E                    DISK
JW1  FABBPP7G IF  E           K        DISK
      *================================================================
     E                    MSG     1  10 60
      *================================================================
     I            DS
     I                                        1   60D1YYM
     I                                        1   40D1YY
     I                                        5   60D1MM
      *================================================================
      *  ENTRY LIST
      *===============================================================
     C           *ENTRY    PLIST
     C                     PARM           K1KBN   1
     C                     PARM           K1YYM   60
     C                     PARM           K1RITU  30
      *================================================================
      *================================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C           @STEP     CASEQ'#JIKKO  '#JIKKO
     C                     ENDCS
     C                     ENDDO
     C*
     C                     MOVELD1KBN     P1KBN   1
     C                     Z-ADDD1YYM     P1YYM   60
     C                     Z-ADDD1RITU    P1RITU  30
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1KBN
     C                     Z-ADD0         D1YYM
     C                     Z-ADD0         D1RITU
     C                     MOVE *BLANK    D1ERR            エラー
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     SETOF                     111213
     C                     SETOF                         99
     C                     MOVE *BLANK    D1ERR            エラー
     C*
     C                     SELEC
     C* < F1 >
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* < F5 >
     C           *INKE     WHEQ *ON
     C                     MOVE '#CHK1 F5'@STEP
     C* <    >
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C*----------
     C*
     C*----------
     C           D1KBN     IFNE ' '
     C           D1KBN     ANDNE'1'
     C                     SETON                     1199
     C                     MOVELMSG,1     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C*
     C           D1KBN     IFEQ ' '
     C           D1YYM     IFNE 0
     C                     SETON                     1299
     C                     MOVELMSG,2     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C           D1RITU    IFNE 0
     C                     SETON                     1399
     C                     MOVELMSG,3     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1KBN     IFEQ '1'
     C           D1YYM     IFEQ 0
     C                     SETON                     1299
     C                     MOVELMSG,4     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C           D1YY      IFLT *YEAR
     C                     SETON                     1299
     C                     MOVELMSG,6     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C           D1MM      IFLE 0
     C           D1MM      ORGT 12
     C                     SETON                     1299
     C                     MOVELMSG,7     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C           D1RITU    IFEQ 0
     C                     SETON                     1399
     C                     MOVELMSG,5     D1ERR
     C                     GOTO $$CHK1
     C                     ENDIF
     C                     ENDIF
     C*
     C*-------------------------*
     C           $$CHK1    TAG
     C*-------------------------*
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1 F5'
     C                     MOVE '#JIKKO  '@STEP
X1   C                     ELSE
     C                     MOVE '#DSP1   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #JIKKO    BEGSR
     C           *LOVAL    SETLLABHPL03
     C*-------------------------
     C                     DO   *HIVAL
     C                     READ ABHPL03                  91
     C   91                LEAVE
     C*
     C           M6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C           M6STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
     C           M6LOTK    IFEQ 0
     C                     ITER
     C                     ENDIF
      *::
     C* U0615-A1179-
     C           M6HIN1    IFEQ 'U0615'
     C           M6HIN2    ANDEQ'A1179'
     C                     Z-ADD0         SAKA    40
     C                     END
     C*
     C           M6AKT4    IFNE *BLANK
     C                     EXSR #CLR2
     C                     MOVE M6AKT4    W@AKT   3
     C                     MOVE M6KBN4    W@KBN
     C                     MOVE M6HIN1    O@HIN1  5
     C                     MOVE M6HIN2    O@HIN2  5
     C                     MOVE M6HIN3    O@HIN3  2
     C                     EXSR #OUT
     C                     EXSR #OUT2
     C                     ENDIF
     C*
     C           M6AKT3    IFNE *BLANK
     C           M6KBN3    IFNE M6KBN4
     C           M6KBN3    OREQ *BLANK
     C                     EXSR #CLR2
     C                     MOVE M6AKT3    W@AKT   3
     C                     MOVE M6KBN3    W@KBN
     C                     MOVE M6HIN1    O@HIN1  5
     C                     MOVE M6HIN2    O@HIN2  5
     C                     MOVE M6HIN3    O@HIN3  2
     C                     EXSR #OUT
     C                     EXSR #OUT2
     C                     ENDIF
     C                     ENDIF
     C*
     C           M6AKT2    IFNE *BLANK
     C           M6KBN2    IFNE M6KBN3
     C           M6KBN2    OREQ *BLANK
     C                     EXSR #CLR2
     C                     MOVE M6AKT2    W@AKT   3
     C                     MOVE M6KBN2    W@KBN
     C                     MOVE M6HIN1    O@HIN1  5
     C                     MOVE M6HIN2    O@HIN2  5
     C                     MOVE M6HIN3    O@HIN3  2
     C                     EXSR #OUT
     C                     EXSR #OUT2
     C                     ENDIF
     C                     ENDIF
     C*
     C           M6KBN1    IFNE M6KBN2
     C           M6KBN1    OREQ *BLANK
     C                     EXSR #CLR2
     C                     MOVE M6AKT1    W@AKT   3
     C                     MOVE M6KBN1    W@KBN   3
     C                     MOVE M6HIN1    O@HIN1  5
     C                     MOVE M6HIN2    O@HIN2  5
     C                     MOVE M6HIN3    O@HIN3  2
     C                     EXSR #OUT
     C                     EXSR #OUT2
     C                     ENDIF
     C*::
     C                     ENDDO
     C*-------------------------
     C                     MOVE '#END    '@STEP
     C                     ENDSR
      *===============================================================
      *
      *================================================================
     C           #OUT      BEGSR
      *
     C                     EXSR #MFA
      *
     C           FCEKEY    KLIST
     C                     KFLD           O@HIN1
     C                     KFLD           O@HIN2
     C                     KFLD           O@HIN3
      *
     C                     EXSR #FCE
     C   55                GOTO EOUT
      *
     C                     MOVE 'A'       O@FLG   1
      *
     C  N96                EXCPTOHED
     C                     SETON                     96
      *
     C                     EXCPTODAT
      *
     C           M6SYUY    IFNE 0
     C****       M6KTSU    DIV  M6SYUY    W@BOX   61H
     C           M6KSSU    DIV  M6SYUY    W@BOX   61H
     C                     ELSE
     C***        M6KTSU    DIV  A2SSYS    W@BOX   61H
     C           M6KSSU    DIV  A2SSYS    W@BOX   61H
     C                     END
      *
     C           W@BOX     DIV  20        W@BXPD  72H
      *
     C           W@BXPD    DIV  M6LOTK    W@LTPD  62H
      *
     C           BANKEY    KLIST
     C                     KFLD           M6JBN1
     C                     KFLD           M6JBN2
     C                     KFLD           M6JBN3
     C                     KFLD           M6JBN4
      *
     C* * *                EXSR #AAF
     C* * *                EXSR #AAH
      *
     C                     EXSR #GHC
      *
     C           EOUT      ENDSR
      *===============================================================
      *
      *================================================================
     C           #GHC      BEGSR
      *
     C           BANKEY    SETLLGHCTL21
