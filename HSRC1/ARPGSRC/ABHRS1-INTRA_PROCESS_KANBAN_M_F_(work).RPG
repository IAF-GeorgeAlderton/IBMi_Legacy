      *================================================================
      *
      *================================================================
     C           #FCE      BEGSR
      *
     C           FCEKEY    CHAINFCEPL01              55
     C           *IN55     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     SETON                     55
     C                     END
     C                     END
      *設定数
     C                     Z-ADD0         W@GEKN
     C           *IN55     IFEQ '0'
     C           A2GEKN    DIV  20        W@GEKN  90
     C                     ADD  W@GEKN    WWGEKN
     C                     END
      *内示
      * P@TNSU:内示がなかった納入先の実績
     C                     CALL 'ABBRS6'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@N2NM 100
     C                     PARM           P@N1NM 100
     C                     PARM           P@NNNM 100
     C                     PARM           P@1NNM 100
     C                     PARM           P@2NNM 100
     C                     PARM           P@NTYM  60
     C                     PARM           P@TNSU 100
      *内示月度
     C                     MOVELP@NTYM    F@NTYM
     C                     CALL 'AGDRS1'
     C                     PARM           F@NTYM  6
     C                     PARM           F@DAYS  2
     C                     MOVE F@DAYS    F#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@NTYM    F@NTMM  2
     C****       F@NTMM    IFEQ '07'
     C****                 SUB  5         F#DAYS
     C****                 END
JW3   * 2020/04 SPECIAL
 |   C           F#DAYS    IFEQ 0
 |   C           P@NTYM    ANDEQ202004
 |   C                     Z-ADD22        F#DAYS
JW3  C                     ENDIF
      *
     C           P@NNNM    DIV  F#DAYS    F@NNNM 100
     C                     ADD  F@NNNM    WWNNNM
      * N/N+1/N+2を求める
     C                     CALL 'ABBRSD'
     C                     PARM           F@NTYM
     C                     PARM           F@N1
     C                     PARM           F@N2
      * N+1の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N1    6
     C                     PARM           F@DAY1  2
     C                     MOVE F@DAY1    F#DAY1  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N1      F@N1MM  2
     C***        F@N1MM    IFEQ '07'
     C***                  SUB  5         F#DAY1
     C***                  END
      *
     C           P@1NNM    DIV  F#DAY1    F@1NNM 100
     C                     ADD  F@1NNM    WW1NNM
      * N+2の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N2    6
     C                     PARM           F@DAY2  2
     C                     MOVE F@DAY2    F#DAY2  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N2      F@N2MM  2
     C***        F@N2MM    IFEQ '07'
     C***                  SUB  5         F#DAY2
     C***                  END
      *
     C           P@2NNM    DIV  F#DAY2    F@2NNM 100
     C                     ADD  F@2NNM    WW2NNM
      *実績
     C                     CALL 'MBERS1'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GOKE  80
      *実績月度
     C                     CALL 'MCEC00'
     C                     PARM           R@DATE  8
     C                     MOVELR@DATE    R@YYMM  6
      *実績月度の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           R@YYMM  6
     C                     PARM           R@DAYS  2
     C                     MOVE R@DAYS    R#DAYS  20
      * CHECK WORK DAYS
JW3  C           R#DAYS    IFEQ 0
 |   C                     Z-ADD1         R#DAYS
JW3  C                     ENDIF
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE R@YYMM    R@MM    2
     C***        R@MM      IFEQ '07'
     C***                  SUB  5         R#DAYS
     C***                  END
      *
     C           P@GOKE    DIV  R#DAYS    R@GOKE  80
     C                     ADD  R@GOKE    WWGOKE
      *内示なし実績
     C           P@TNSU    DIV  R#DAYS    R@TNSU  80
      * N
     C                     ADD  R@TNSU    F@NNNM
     C                     ADD  R@TNSU    WWNNNM
      * N+1
     C                     ADD  R@TNSU    F@1NNM
     C                     ADD  R@TNSU    WW1NNM
      * N+2
     C                     ADD  R@TNSU    F@2NNM
     C                     ADD  R@TNSU    WW2NNM
