     C                     MOVE 'G'       O@FLG
     C                     EXCPTODAT
      *
     C                     ENDDO
      *
     C           EGHC      ENDSR
      *================================================================
      *
      *================================================================
     C           #AAF      BEGSR
      *
     C           BANKEY    SETLLAAFPL09
     C                     DO   *HIVAL
     C           BANKEY    READEAAFPL09                  77
     C   77                LEAVE
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           A3STYY    IFNE 9999
     C                     ITER
     C                     END
     C           M6HIN1    IFEQ A31HB5
     C           M6HIN2    ANDEQA32HB5
     C           M6HIN3    ANDEQA33HB2
     C                     ITER
     C                     END
      *
     C                     MOVE A31HB5    O@HIN1
     C                     MOVE A32HB5    O@HIN2
     C                     MOVE A33HB2    O@HIN3
     C                     EXSR #FCE
     C   55                GOTO EAAF
