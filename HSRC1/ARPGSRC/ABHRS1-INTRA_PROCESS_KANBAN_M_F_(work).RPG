     C           BANKEY    READEAAHPL09                  77
     C   77                LEAVE
     C           L6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           L6STYY    IFNE 9999
     C                     ITER
     C                     END
     C           M6HIN1    IFEQ L6SHN1
     C           M6HIN2    ANDEQL6SHN2
     C           M6HIN3    ANDEQL6SHN3
     C                     ITER
     C                     END
      *
     C                     MOVE L6SHN1    O@HIN1
     C                     MOVE L6SHN2    O@HIN2
     C                     MOVE L6SHN3    O@HIN3
