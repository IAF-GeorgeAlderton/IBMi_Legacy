     H            Y.                                    1
     F** CVTR11 *************************************
     F*  ..１バイト<---> ２バイト（ＨＥＸ） ..  *
     F*  CONVERT 1 BYTE TO 2 BYTES HEX              *
     F*---------------------------------------------*
     F*  ﾌﾟ[xｰj:PTYPE ---- 1:2ﾌﾞbn(HEX)--->1ﾌﾞbn    *
     F*                    2:1ﾌﾞbn--->2ﾌﾞbn(HEX)    *
     F*         PCHR1 ---- 1ﾌﾞbn                    *
     F*         PCHR2 ---- 2ﾌﾞbn                    *
     F*  CODING:K.OKACHI             2000.07.10     *
     F************************************* CVTR11 **
     I              '0123456789ABCDEF'    C         #HEX
     I            DS
     I I            0                     B   1   20DSBIN
     I I            ' '                       2   2 DSNBL
      *
     IBYTE       IDS
     I                                        1   1 UPPER
     I                                        2   2 LOWER
      *
     C           *ENTRY    PLIST
     C                     PARM           PTYPE   1        変換タイプ
     C                     PARM           PCHR1   1        1ﾌﾞbn
     C           BYTE      PARM BYTE      PCHR2   2        2ﾌﾞbn
      *
     C           PTYPE     CASEQ'1'       #CHR1
     C           PTYPE     CASEQ'2'       #CHR2
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------*
      *               2ﾌﾞbn(HEX) ---> 1ﾌﾞbn                 *
      *-----------------------------------------------------*
     C           #CHR1     BEGSR
     C                     MOVE *LOVAL    PCHR1
     C           LOWER     SCAN #HEX:1    W1      30     70
     C   70      UPPER     SCAN #HEX:1    W2      30     70
      *
     C           *IN70     IFEQ '1'
     C                     SUB  1         W1
     C                     SUB  1         W2
     C                     MULT 16        W2
     C           W1        ADD  W2        DSBIN
     C                     MOVE DSNBL     PCHR1
     C                     END
     C           ECHR1     ENDSR
      *-----------------------------------------------------*
      *               1ﾌﾞbn ---> 2ﾌﾞbn(HEX)                 *
      *-----------------------------------------------------*
     C           #CHR2     BEGSR
     C                     MOVE PCHR1     DSNBL
     C           DSBIN     DIV  16        W1
     C                     MVR            W2
      *
     C                     ADD  1         W1
     C                     ADD  1         W2
      *
     C           1         SUBST#HEX:W1   UPPER
     C           1         SUBST#HEX:W2   LOWER
     C           UPPER     CAT  LOWER     PCHR2
      *
     C           ECHR2     ENDSR
