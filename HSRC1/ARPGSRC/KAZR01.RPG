     C                     KFLD           INOMM
      *
     C           *ENTRY    PLIST
     C                     PARM           PNONY   4
     C                     PARM           PNOYM   6
      *
     C                     Z-ADD0         INOYM
     C                     Z-ADD0         ISEHZ
      *
     C           STP1      TAG
     C                     EXFMTAB#PW621
     C                     SETOF                     010203
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           INONY     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE INONY     WNONY   40
      *
     C                     SETOF                     10
     C           WNONY     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOYM     IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOYY     IFGE 1997
     C           INOMM     ANDGE01
     C           INOMM     ANDLE12
     C                     ELSE
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ISEHZ     IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ISEYY     IFGE 1997
     C           ISEMM     ANDGE01
     C           ISEMM     ANDLE12
     C           ISEDD     ANDGE01
     C           ISEDD     ANDLE31
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *
     C                     SETON                     U1
     C                     MOVE INONY     PNONY
     C                     MOVE INOYM     PNOYM
      *
     C           KEY1      SETLLAB#PL061
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY1      READEAB#PL061                 30
     C           *IN30     IFEQ '0'
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           B1NONY    IFEQ WNONY
     C                     SETON                     U2
      *
     C                     MOVE B1TOKU    @TOKU   4
     C                     MOVE B1NONY    @NONY   4
     C                     MOVE B1NKOJ    @NKOJ   1
     C                     MOVE B1NUKE    @NUKE   4
     C                     MOVE B1MHIN    @MHIN  20
     C                     MOVE B1NOHZ    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
     C           @TANK     IFEQ 0
     C                     SETON                     U3
     C                     END
      *
     C                     Z-ADDISEHZ     B1SEHZ
     C                     Z-ADD@TANK     B1TANK
      *
     C                     Z-ADDB1TOKU    #TOKU   40
     C                     Z-ADDB1NONY    #NONY   40
     C                     MOVE B1NKOJ    #NKOJ   1
     C                     MOVE B1NUKE    #NUKE   4
     C                     MOVE B1SBAN    #SBAN   4
     C                     MOVE B1UHIN    #MHIN  20
     C                     MOVE B1ODR1    #ODR1  10
     C                     Z-ADDB1NOHZ    #NOHZ   80
     C                     Z-ADDB1SYUY    #SYUY   50
     C                     Z-ADDB1SRYO    #SRYO   70
     C                     Z-ADDB1TANK    #TANK   94
     C                     MOVE B1CARD    #CARD   4
      *
     C                     EXCPTDT
      *
     C           B1NONY    IFEQ 3347
     C           B1NONY    OREQ 3931
     C           B1NONY    OREQ 3804
     C           B1NONY    OREQ 0506
      *
     C           B1NONY    IFEQ 3347
     C                     MOVE '1406'    #SIRE   4
     C                     MOVE '0'       #SIRK   1
     C                     END
      *
     C           B1NONY    IFEQ 3931
     C                     MOVE '1406'    #SIRE
     C                     MOVE '0'       #SIRK
     C                     END
      *
     C           B1NONY    IFEQ 3804
     C                     MOVE '1406'    #SIRE
     C                     MOVE '0'       #SIRK
     C                     END
     C           B1NONY    IFEQ 0506
     C                     MOVE 'C742'    #SIRE
     C                     MOVE '0'       #SIRK
     C                     END
      *
     C                     Z-ADDB1NOHZ    WNOHZ   60
     C                     MOVELB1NUKE    WNUKE   2
     C                     Z-ADDB1SRYO    WSRYO  100
     C                     MOVELB1UHIN    WMHIN  30
     C                     Z-ADDB1TANK    WTANK  134
     C                     MOVE B1CARD    WCARD   4
     C                     EXCPTDT1
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N30                ENDDO
      *
     C           WNONY     IFEQ 3347
      *
     C           KEY2      SETLLAB#PL111
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY2      READEAB#PL111                 30
     C           *IN30     IFEQ '0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           BACARD    IFEQ 'MA02'
      *
     C                     MOVE BATOKU    PTOKU   4
     C                     MOVE BANONY    PNONY   4
     C                     MOVE BANKOJ    PNKOJ   1
     C                     MOVE BANUKE    PNUKE   4
     C                     MOVE BAMHIN    $MHIN
     C                     MOVE *BLANK    $SHIN  12
     C                     MOVE *BLANK    $FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           $MHIN
     C                     PARM           $SHIN  12
     C                     PARM           $FLG    1
      *
     C           $FLG      IFEQ '*'
     C                     MOVE *BLANK    $MHN3
     C                     MOVE *BLANK    $MHN4
     C                     END
      *
     C                     MOVE BATOKU    @TOKU
     C                     MOVE BANONY    @NONY
     C                     MOVE BANKOJ    @NKOJ
     C                     MOVE BANUKE    @NUKE
     C                     MOVE $MHIN     @MHIN
     C                     MOVE BANOHZ    @HIZK
     C                     Z-ADD0         @TANK
     C                     MOVE *BLANK    @CHEK
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
     C           @TANK     IFEQ 0
