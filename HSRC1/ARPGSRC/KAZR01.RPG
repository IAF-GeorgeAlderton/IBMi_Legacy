     C                     MOVE BANKOJ    #NKOJ
     C                     MOVE BANUKE    #NUKE
     C                     MOVE BASBAN    #SBAN
     C                     MOVE BAMHIN    #MHIN
     C                     MOVE BAODRN    #ODR1
     C                     Z-ADDBANOHZ    #NOHZ
     C                     Z-ADDBASYOS    #SYUY
