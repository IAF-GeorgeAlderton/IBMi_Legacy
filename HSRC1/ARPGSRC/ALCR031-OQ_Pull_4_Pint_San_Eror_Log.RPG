     H            Y.
     F** ALCR031********************************************
     F*  OQ PULL SCAN ERROR LOG LIST                       *
     F*  COPIED ALCR03                                     *
     F******************************************************
     FALCPW031CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
     F*
     E                    ERR     1   5 70
     I*
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80W@SCDT
     I                                        1   40W@SCYY
     I                                        5   60W@SCMM
     I                                        7   80W@SCDD
     I            DS
     I                                        1  14 W@PRT
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     C*
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    D@FROM
     C                     MOVEL*BLANK    D@SHFT
     C                     MOVE '1'       D@PRTR
     C                     SETOF                     616263
     C                     SETOF                     69
     C                     MOVEL*BLANK    MSG
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTDSP01
     C   KA                LEAVE
     C                     SETOF                     616263
     C                     SETOF                     69
     C                     MOVEL*BLANK    MSG
     C*
     C                     EXSR @CHK
     C           *IN69     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C                     MOVELD@SHFT    P@SHFT  1
     C                     MOVELD@FROM    P@SCDT  8
     C                     MOVEL*OFF      P@RFLG  1
     C                     MOVELD@PRTR    P@PRTR  1
     C                     CALL 'ALCC022'
     C                     PARM           P@SHFT
     C                     PARM           P@SCDT
     C                     PARM           P@RFLG
     C                     PARM           P@PRTR
     C           P@RFLG    IFEQ *OFF
     C                     SETON                     616269
     C                     MOVELERR,3     MSG
     C                     ITER
     C                     ELSE
     C                     LEAVE
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* CHECK
     C*-----------------------------------------------------
     C           @CHK      BEGSR
     C*
     C                     DO
     C*
     C                     MOVELD@FROM    W@SCDT
     C           K#AGDP    KLIST
     C                     KFLD           W@SCYY
     C                     KFLD           W@SCMM
     C                     KFLD           W@SCDD
     C           K#AGDP    CHAINAGDPL12              91
     C           *IN91     IFEQ *ON
     C                     SETON                     6169
     C                     MOVELERR,1     MSG
     C                     LEAVE
     C                     END
     C*
     C           D@SHFT    IFLT '1'
     C           D@SHFT    ORGT '3'
     C                     SETON                     6269
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     END
     C*
     C           D@PRTR    IFNE '1'
     C           D@PRTR    ANDNE'2'
     C           D@PRTR    ANDNE'9'
     C                     SETON                     6369
     C                     MOVELERR,4     MSG
     C                     LEAVE
     C                     END
     C*
     C                     END
     C* PRESS F5
     C           *IN69     IFEQ *OFF
     C                     MOVELERR,5     MSG
     C                     ENDIF
     C*
     C                     ENDSR
      *
** ERR
DATE IS INVALID!
SHIFT CODE SHOULD BE 1, 2 OR 3!
