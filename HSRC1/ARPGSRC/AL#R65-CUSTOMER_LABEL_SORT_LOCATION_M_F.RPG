     FAL#WP61 UF  E                    DISK                      A
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P9SORT  5
     C                     PARM           P9BLK   2
     C                     PARM           P9BLK2  2
     C                     PARM           P9SITE  1
     C                     PARM           P9SECT  1
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     MOVE P9SORT    WKSORT  50
      *
     C                     EXSR #SB400
      *
     C                     MOVELWKSORT    W1SORT
     C                     MOVELP9BLK     W1BLK
     C                     MOVELP9BLK2    W1BLK2
     C                     MOVELP9SITE    W1SITE
     C                     MOVE P9SECT    W1SECT
     C                     WRITEAL#WP611
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           1         SETLLAL#WP611
     C                     READ AL#WP611                 83
     C           *IN83     DOWEQ'0'
     C           W1SORT    IFGE WKSORT
     C                     ADD  1         W1SORT
     C           W1SORT    IFLE 999
     C                     UPDATAL#WP611
     C                     ELSE
     C                     DELETAL#WP611
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#WP611                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
