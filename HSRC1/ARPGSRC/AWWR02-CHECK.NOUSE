     H            Y.
     F************************ AAAR01 **
     FAB#TEMP IP  E                    DISK
     F            AB#TEMP                           KRENAMEABR
     FAU#PL24 IF  E           K        DISK
     FAGAPL31 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     IABR
     I                                              BASHN1L1
     I                                              BASHN2L1
     I                                              BASHN3L1
     C           K#KEY     KLIST
     C                     KFLD           BANONY
     C                     KFLD           BANUKE
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C           K#KEX     KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
      *
     C           K#KEX     CHAINAGAPL31              90
     C           *IN90     IFEQ *OFF
     C           CBSKJY    ANDEQ*BLANK
      *
     C   L1                Z-ADD*ZERO     TOT    110
     C   L1                Z-ADD*ZERO     TBX     50
     C                     Z-SUBBASRYO    @@SRYO 100
     C           K#KEY     SETLLAU#PL24
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAU#PL24                  90
     C           *IN90     IFEQ *OFF
     C           CQSRYO    ANDEQ@@SRYO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     ADD  @@SRYO    TOT
     C  N98
     COR OF                EXCPT@HED
     C  N98                MOVE *ON       *IN98
     C           BASYOS    IFNE 0
     C           BASRYO    DIV  BASYOS    BOX     50
     C                     ELSE
     C           BAUSYS    IFNE 0
     C           BASRYO    DIV  BAUSYS    BOX     50
     C                     ELSE
     C                     Z-ADD0         BOX
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  BOX       TBX
     C                     EXCPT@DTL
     C                     ENDIF
     C                     ENDIF
     CL1                   EXSR #TOT
      *
     C           #TOT      BEGSR
     C           TOT       IFNE *ZERO
     C                     EXCPT@TOT
     C                     ENDIF
     C                     ENDSR
      *
     OQPRINT  E   01           @HED
     O                                   50 'NOT CREATED MINUS DATA'
     O        E   03           @HED
     O                                    5 'PART#'
     O                                   27 'QTY'
     O                                   34 'BOX'
     O                                   40 'CUST'
     O                                   45 'DELV'
     O                                   56 'SHIP DATE'
     O                                   69 'RELEASE DATE'
     O        E 1              @DTL
     O                         BASHN1     5
     O                         BASHN2    11
     O                         BASHN3    14
     O                         @@SRYOJ   28
     O                         BOX   1   35
     O                         BATOKU    40
     O                         BANONY    45
     O                         BANOYY    50
     O                                   51 '/'
     O                         BANOMM    53
     O                                   54 '/'
     O                         BANODD    56
     O                         BADEYY    62
     O                                   63 '/'
     O                         BADEMM    65
     O                                   66 '/'
     O                         BADEDD    68
     O        E 0              @TOT
     O                         TOT   J   80
     O                         TBX   1   87
