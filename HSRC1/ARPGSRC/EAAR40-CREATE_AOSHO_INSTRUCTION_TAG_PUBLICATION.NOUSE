     I            DS
     I                                        1  17 UHINP
     I                                        1   5 MHN1
     I                                        6   6 BAR1
     I                                        7  11 MHN2
     I                                       12  12 BAR2
     I                                       13  17 MHN3
     I            DS
     I                                        1  14 SHINP
     I                                        1   5 HBAN1
     I                                        6   6 BAR3
     I                                        7  11 HBAN2
     I                                       12  12 BAR4
     I                                       13  14 HBAN3
     I            DS
     I                                        1   9 TBANTI
     I                                        1   1 FTKR1
     I                                        2   2 BAR5
     I                                        3   4 FTKR2
     I                                        5   5 BAR6
     I                                        6   7 FTKR3
     I                                        8   8 BAR7
     I                                        9   9 FTKR4
     I            DS
     I                                        1   80A2SHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1   80BHIZK
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     MOVE '-'       BAR1    1
     C                     MOVE '-'       BAR2    1
     C                     MOVE '-'       BAR3    1
     C                     MOVE '-'       BAR4    1
     C                     MOVE '-'       BAR5    1
     C                     MOVE '-'       BAR6    1
     C                     MOVE '-'       BAR7    1
     C                     TIME           JIKAN   60
     C                     EXCPTHD
     C                     END
     C*アオショーのデータかチェック
     C           TOKUM     CHAINFGBPL011             14
     C           *IN14     IFEQ '0'
     C           B2GRUP    CABNE'3'       END
     C                     ELSE
     C                     GOTO END
     C                     END
     C*細目マスターで納入先名を引く。*
     C           NONYM     CHAINFGBPL011             11
     C           *IN11     IFEQ '1'
     C                     MOVE *BLANK    NOUMEI 16
     C                     ELSE
     C           B2SKJY    IFEQ 'D'
     C                     MOVE *BLANK    NOUMEI
     C                     ELSE
     C                     MOVELB2SMEI    NOUMEI
     C                     END
     C                     END
     C*出荷マスターで工場名を引く。*
     C           KEY1      KLIST
     C                     KFLD           TOKUM
     C                     KFLD           NONYM
     C                     KFLD           NKOJM
     C                     KFLD           NUKEM
     C           KEY1      CHAINGADPL111             12
     C           *IN12     IFEQ '1'
     C                     MOVE *BLANK    NKJMEI 15
     C                     ELSE
     C           B5SKJY    IFEQ 'D'
     C                     MOVE *BLANK    NKJMEI
     C                     ELSE
     C                     MOVELB5KMEI    NKJMEI
     C                     END
     C                     END
     C*部品マスターで収容数・所番地を入力*
     C           KEY2      KLIST
     C                     KFLD           HBAN1
     C                     KFLD           HBAN2
     C                     KFLD           HBAN3
     C           KEY2      CHAINFCEPL011             13
     C           *IN13     IFEQ '1'
     C                     Z-ADD0         SYUUYO
     C                     ELSE
     C           A2GSKD    IFEQ 'D'
     C                     Z-ADD0         SYUUYO
     C                     ELSE
     C           A2SHZ     IFLE SHIZM
     C                     Z-ADDA2SSYS    SYUUYO  50
     C                     ELSE
     C                     Z-ADDA2KSYS    SYUUYO
     C                     END
     C                     END
     C                     END
     C*
     C           *IN13     IFEQ '1'
     C                     MOVE *BLANK    BANC1   1
     C                     MOVE *BLANK    BANC2   2
     C                     MOVE *BLANK    BANC3   2
     C                     MOVE *BLANK    BANC4   1
     C                     ELSE
     C           BHIZK     IFGT SHIZM
     C                     MOVE A2KTRK    BANC1
     C                     MOVE A2KTRT    BANC2
     C                     MOVE A2KTRR    BANC3
     C                     MOVE A2KTRD    BANC4
     C                     ELSE
     C                     MOVE A2STRK    BANC1
     C                     MOVE A2STRT    BANC2
     C                     MOVE A2STRR    BANC3
     C                     MOVE A2STRD    BANC4
     C                     END
     C                     END
     C           FTKRO     IFEQ *BLANK
     C                     MOVE BANC1     FTKR1
     C                     MOVE BANC2     FTKR2
     C                     MOVE BANC3     FTKR3
     C                     MOVE BANC4     FTKR4
     C                     END
     C*収容数と納入数で箱数を算出*
     C                     Z-ADD0         HAKO
     C                     Z-ADD0         AMARI
     C           SYUUYO    IFEQ 0
     C                     Z-ADD999       HAKO
     C                     Z-ADD1         ONE
     C                     Z-ADDSRYOM     AMARI
     C                     ELSE
     C           SRYOM     DIV  SYUUYO    HAKO    30
     C                     MVR            AMARI   40
     C           AMARI     IFEQ 0
     C                     Z-ADD0         ONE     10
     C                     ELSE
     C                     Z-ADD1         ONE
     C                     END
     C                     END
     C*
     C           HAKO      IFEQ 0
     C                     SETOF                     15
     C                     ELSE
     C                     SETON                     15
     C                     END
     C*
     C           ONE       IFEQ 0
     C                     SETOF                     16
     C                     ELSE
     C                     SETON                     16
     C                     END
     C*受注区分入力*
     C                     MOVE *BLANK    JKBNN
     C           JKBNM     IFEQ 'A'
     C                     MOVE 'V-PROD'  JKBNN   6
     C                     END
     C           JKBNM     IFEQ 'K'
     C                     MOVE 'LIMIT '  JKBNN
     C                     END
     C           JKBNM     IFEQ 'J'
     C                     MOVE 'TR MFG'  JKBNN
     C                     END
     C           JKBNM     IFEQ 'L'
     C                     MOVE 'P-PROD'  JKBNN
     C                     END
     C           JKBNM     IFEQ 'W'
     C                     MOVE 'M-PREP'  JKBNN
     C                     END
     C*プリンター　出力*
     C                     EXCPTME
     C           *INOF     IFEQ '1'
     C                     SETOF                     OF
     C                     EXCPTHD
     C                     END
     C           END       TAG
     OQPRINT  E   02           HD
