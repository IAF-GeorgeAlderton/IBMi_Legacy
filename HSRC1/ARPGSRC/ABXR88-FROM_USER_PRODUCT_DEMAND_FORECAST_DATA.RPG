     F***************************************** ABAR32 **
     FAXXPP01 UP  E                    DISK
      *
     I            DS
     I                                        1  20 P@MHIN
     I                                        1   5 ABMHN1
     I                                        6  10 ABMHN2
     I                                       11  15 ABMHN3
     I                                       16  20 ABMHN4
TCHK5I            DS
TCHK5I                                        1  12 ABSHNA
TCHK5I                                        1   5 X1SHN1
TCHK5I                                        6  10 X1SHN2
TCHK5I                                       11  12 X1SHN3
      *
     C                     MOVE X1PM03    P@TOKU
     C                     MOVE X1PM04    P@NONY
     C                     MOVE '0'       P@NKOJ
     C                     MOVELX1PM06    P@NUKE
     C                     MOVELX1PM07    ABMHN1
     C                     MOVELX1PM08    ABMHN2
     C                     MOVELX1PM09    ABMHN3
     C                     MOVELX1PM10    ABMHN4
