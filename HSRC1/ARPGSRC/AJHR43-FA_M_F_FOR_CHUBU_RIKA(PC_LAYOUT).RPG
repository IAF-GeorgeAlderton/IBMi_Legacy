     C*総件数チェック
     C           SOUKEN    ADD  1         SOUKEN  50
     C*ＦＡマスター削除の為のポインターセット
     C                     SETOF                     99
     C           KEY1      KLIST
     C                     KFLD           SHIN1
     C                     KFLD           SHIN2
     C                     KFLD           SHIN3
     C           KEY1      SETLLAJHPL011
     C                     SETOF                     11
     C           LOOP1     TAG
     C           KEY1      READEAJHPL011                 11
     C           *IN11     IFEQ '1'
     C                     SETON                     99
     C                     ELSE
     C           JHSKJY    IFEQ 'D'
     C           JHSKHZ    IFLE *DATE
     C                     GOTO LOOP1
     C                     END
     C                     END
     C                     END
     C*ファイル無しチェック
     C           *IN99     IFEQ '1'
     C                     GOTO END
     C                     END
     C*ファイル件数チェック
     C           ALLKEN    ADD  1         ALLKEN  50
     C*ファイル区分チェックKUBUN='*' THEN DELETE
     C                     MOVE '1'       JHMENT
     C           KUBUN     IFEQ '*'
     C                     MOVE 'D'       JHSKJY
     C                     Z-ADD*YEAR     JHSKYY
     C                     Z-ADDUMONTH    JHSKMM
     C                     Z-ADDUDAY      JHSKDD
     C                     MOVE *BLANK    JHKOME
     C                     MOVEL'AJHR43'  JHKOME
     C                     MOVE '0'       JHMENT
     C                     UPDATAJHPL011
     C                     END
     C*
     C           MEK2      IFEQ 'A'
     C           AENKEN    ADD  1         AENKEN  50
     C                     ELSE
     C           JHMEK1    IFEQ '.GM.'
     C           JHMEK2    ANDEQ'SP'
     C           JHMEK3    ANDEQ'.'
     C           DKRKEN    ADD  1         DKRKEN  50
     C                     ELSE
     C           SONOTA    ADD  1         SONOTA  50
     C                     END
     C                     END
     C*亜鉛メッキの時ファイル１出力
     C           MEK2      IFEQ 'A'
     C           A         ADD  1         A       50
     C                     EXCPTDAT1
     C                     END
     C*ダクロメッキの時ファイル３出力
     C           JHMEK1    IFEQ '.GM.'
     C           JHMEK2    ANDEQ'SP'
     C           JHMEK3    ANDEQ'.'
     C           DK        ADD  1         DK      50
     C                     EXCPTDAT3
     C                     END
     C           END       TAG
