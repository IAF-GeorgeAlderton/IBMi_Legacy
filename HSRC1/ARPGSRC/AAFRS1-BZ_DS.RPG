     H            Y.
     F******************************************************
     F* BZ/DS
     F******************************************************
     FAAFPL03 IP  E                    DISK
     FAAFWPS1 O   F    2048            DISK
      *
     C           A3SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
      *
     C           A3SBIN    IFNE 99
     C                     GOTO @END
     C                     END
      *
     C           A3SSYS    IFEQ 0
     C                     GOTO @END
     C                     END
      *
     C           A3KCD1    IFNE 'C'
     C           A3KCD2    ORNE 'A'
     C                     GOTO @END
     C                     END
      *
     C           A3KTSU    DIV  A3SSYS    O@BXPD  51
      *
     C                     MOVE A31HB5    P@HIN1  5
     C                     MOVE A32HB5    P@HIN2  5
     C                     MOVE A33HB2    P@HIN3  2
     C                     MOVE A3ATK1    P@BAN1  1
     C                     MOVE A3ATK2    P@BAN2  2
     C                     MOVE A3ATK3    P@BAN3  2
     C                     MOVE A3ATK4    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'BZ '     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
     C                     MOVE *BLANK    P@FLG   1
      *
     C                     CALL 'AAMRS8'  AAMRS8
      *
     C           AAMRS8    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@BMON  4
     C                     PARM           P@KOTE  3
     C                     PARM           P@KIBN  3
     C                     PARM           P@KHIN 12
     C                     PARM           P@FLG   1
      *
     C           P@BMON    IFNE '0111'
     C                     MOVE A3ATK1    P@BAN1  1
     C                     MOVE A3ATK2    P@BAN2  2
     C                     MOVE A3ATK3    P@BAN3  2
     C                     MOVE A3ATK4    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'DS '     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
     C                     MOVE *BLANK    P@FLG   1
      *
     C                     CALL 'AAMRS8'  AAMRS8
     C                     END
      *
     C           P@BMON    IFEQ *BLANK
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE *BLANK    P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     GOTO @END
     C                     END
      *
      *
     C  N77                EXCPTOHED
     C                     SETON                     77
     C                     EXCPTODAT
      *
     C           @END      TAG
      *
     OAAFWPS1 E                OHED
     O                                      'PARTS#,'
     O                                      'LOCATION,'
     O                                      'KANBAN#,'
     O                                      'SET#/DAY,'
     O                                      'QTY/BOX,'
     O                                      'BOX/DAY,'
     O                                      'SUPPLIER,'
     O                                      'PROCESS,'
     O                                      'LINE,'
     O                                      'ST CODE,'
     OAAFWPS1 E                ODAT
      *
     O                                      '="'
     O                         A31HB5
     O                         A32HB5
     O                         A33HB2
     O                                      '"'
     O                                      ','
     O                                      '="'
     O                         A3ATK2
     O                                      '-'
     O                         A3ATK3
     O                                      '"'
     O                                      ','
     O                         A3KMAX
     O                                      ','
     O                         A3KTSU
     O                                      ','
     O                         A3SSYS
     O                                      ','
     O                         O@BXPD       '  0 . '
     O                                      ','
     O                         P@BMON
     O                                      ','
     O                         P@KOTE
     O                                      ','
     O                         P@KIBN
     O                                      ','
     O                         A3MEKI
     O                                      ','
