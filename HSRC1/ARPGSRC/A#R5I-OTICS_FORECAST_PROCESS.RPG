     H            Y.
     F** AB#R5I ********************************************
     F*  OTICS FORECAST PROCESSING                         *
     F*                                                    *
     F*                                                    *
TCHK1F* TCHK1 12/14/05 CREATE(copy from AB#R5D)            *
     F******************************************** AB#R5I **
     FOTICS   IP  F     800            DISK
     FABAWOTF O   E                    DISK
     FAGDPL12 IF  E           K        DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    A2          2  1
     E                    A9          9  1
     E                    A9X         9  1
      *
     E                    ADT        30  8 0
     E                    MHN        15  1
      *--------------------------------------------------------
     IOTICS   AA  01
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 780 DAT3
     I            DS
     I                                        1   80YMD8N
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   80DAY
     I            DS
     I                                        1   8 YMD8A
     I                                        1   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1   80AWENDD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     I            DS
     I                                        1  15 #PART
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
     I            DS
     I                                        1   80AWSTRD
     I                                        1   40NAYY
     I                                        5   60NAMM
     I                                        7   80NADD
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C           KEY3      KLIST
     C                     KFLD           NAYY    40
     C                     KFLD           NAMM    20
     C                     KFLD           NADD    20
      * CONSTANT
     C                     Z-ADD0740      AWTOKU
     C                     Z-ADD0740      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
      *
     C                     MOVEADAT1      AY,1
     C                     MOVEADAT2      AY,257
     C* ======
     C* HEADER
     C* ======
     C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
     C           'FORECAST'SCAN DAT1      X              10
     C  N10      'Forecast'SCAN DAT1      X              10
     C  N10                GOTO @END
      *
     C                     MOVEL*ON       *IN99
      *
     C                     GOTO @END
      *
     C                     END
      *
     C* ======
     C*  DATE
     C* ======
     C           *IN98     IFEQ *OFF
      *
     C                     Z-ADD1         X
     C           '/'       SCAN DAT1      X              10
     C  N10                GOTO @END
      *
     C                     Z-ADD1         X
     C           '/'       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         I       30
     C                     DO   *HIVAL
     C                     SUB  1         I
     C           I         IFLE *ZERO
     C                     LEAVE
     C                     END
     C           AY,I      IFEQ ','
     C           AY,I      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ENDDO
     C           I         IFLE *ZERO
     C                     GOTO @END
     C                     ELSE
     C                     Z-ADDI         X
     C                     END
      *
     C                     MOVEL*ZERO     ADT
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     W@SDT   20
      *
     C                     DO   *HIVAL
      *
     C                     Z-ADDX         J       30
     C                     MOVEL*ZERO     YMD8A
     C* GET MM
     C                     ADD  1         J
     C                     MOVEAAY,J      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVEAA2        MM
     C                     ELSE
     C                     MOVE A2,1      MM
     C                     END
     C* GET DD
     C           '/'       LOKUPAY,J                     10
     C  N10                LEAVE
     C                     ADD  1         J
     C                     MOVEAAY,J      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVEAA2        DD
     C                     ELSE
     C                     MOVE A2,1      DD
     C                     END
     C* GET YYYY
     C           '/'       LOKUPAY,J                     10
     C  N10                LEAVE
     C                     ADD  1         J
     C                     MOVEAAY,J      YY
      *
     C                     MOVELYMD8A     YMD8N
     C                     ADD  1         I
     C                     Z-ADDYMD8N     ADT,I
     C                     ADD  1         W@SDT
      * search next date
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C                     Z-ADDX         J
      *
     C                     ENDDO
      *
     C           W@SDT     IFGT *ZERO
     C                     MOVE *ON       *IN98
     C                     END
      *
     C                     GOTO @END
      *
     C                     END
     C*=======
      * DETAIL
     C*=======
     C                     Z-ADD1         X
     C           '-'       SCAN DAT1      X              10
     C           *IN10     IFEQ *OFF
     C           *IN97     IFEQ *ON
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C                     ELSE
     C                     GOTO @END
     C                     END
     C                     END
      *
     C  N97                MOVEL*ON       *IN97
      *
      * -------------
      *   PART NUMBER
      * -------------
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     MOVEL*BLANK    MHN
     C                     Z-ADDX         I
     C                     Z-ADD*ZERO     J
      *
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           AY,I      IFEQ ','
     C           AY,I      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,I      IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         J
     C                     MOVELAY,I      MHN,J
     C                     ENDDO
      *
     C                     MOVEAMHN       #PART
      * ---
      * QTY
      * ---
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADD*ZERO     K       30
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         K
     C           K         IFGT W@SDT
     C                     LEAVE
     C                     END
      *
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
      *
     C                     Z-ADDX         I
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     J
      *
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           AY,I      IFEQ ','
     C           AY,I      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         J
     C                     MOVELAY,I      A9,J
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         I
     C                     Z-ADD9         J
     C                     DO   9
     C           A9,I      IFNE *BLANK
     C                     MOVELA9,I      A9X,J
     C                     SUB  1         J
     C                     END
     C                     SUB  1         I
     C           I         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
     C                     Z-ADDADT,K     AWSTRD
      * get END-DATE
     C                     MOVE '0'       *IN44
     C           KEY3      SETLLAGDPL121
     C           *IN44     DOWEQ'0'
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     LEAVE
     C                     ENDDO
     C* WRITE
     C                     WRITEABAWOTF1
     C                     MOVE '1'       PID
      *
     C                     ENDDO
      *
     C           @END      TAG
      ******************************************************
     C           *INZSR    BEGSR
      ******************************************************
      *
     C                     TIME           W@TIME
      *
     C                     ENDSR
