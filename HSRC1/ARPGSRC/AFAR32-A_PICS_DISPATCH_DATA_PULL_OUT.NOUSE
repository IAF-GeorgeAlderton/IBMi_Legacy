      *
      *かんばん発行での有効日チェック
      *
     C           *IN25     IFEQ '0'
     C           DAHTHZ    IFGE AHYUHZ
     C           DAHTHZ    ANDLEAHSTHZ
     C                     ELSE
     C                     SETON                     25
     C                     END
     C                     END
      *
     C           WMAIS     DIV  @@BARL    @@KAIS  30
      *箱数：ゼロ以下又は｣バレルと等しい時ロット単位の
      *バラシは、実行しない
      *
     C           WMAIS     IFLE 0
     C           WMAIS     ORLE @@BARL
     C                     SETON                     25
     C                     END
      *
     C           *IN25     IFEQ '0'
      *
     C                     DO   @@KAIS
     C                     ADD  1         @@LOTN
TCHK1C                     MOVE @@LOTN    CBLOTN
     C                     Z-ADDCBBARL    WMAIS
     C                     EXCPTDT
     C                     ENDDO
TCHK1C*                    MOVE @@LOTN    CBLOTN
     C                     ELSE
      *
     C                     ADD  1         @@LOTN
TCHK1C                     MOVE @@LOTN    CBLOTN
     C                     EXCPTDT
TCHK1C*                    MOVE @@LOTN    CBLOTN
     C                     END
      *
     C                     END
