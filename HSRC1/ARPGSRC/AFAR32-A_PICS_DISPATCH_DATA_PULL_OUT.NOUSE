     C** MSK 2007.03.20    EXCPTDT
      * MSK 2005.03.19
      *
     C                     SETOF                       25
     C           KEY1      CHAINAHDPP601             25
     C           *IN25     IFEQ '0'
     C           AHSKJY    ANDEQ'D'
     C           AHSKHZ    ANDLE*DATE
     C                     SETON                     25
