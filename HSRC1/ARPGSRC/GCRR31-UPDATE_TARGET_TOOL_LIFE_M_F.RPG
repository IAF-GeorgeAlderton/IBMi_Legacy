     H            Y.
     F** GCRR31 **************************************
     F* UPDATE TARGET TOOL LIFE M/F                  *
     F*       ITS.                    2013.10.24     *
     F************************************************
     FGCRPW31 CF  E                    WORKSTN
     FFCQPL31 IF  E           K        DISK
     FGCRPL11 UF  E           K        DISK                      A
      *
     E                    KOSN    1   3 10
     E                    ER      1  20 60
      *
     I            DS
     I                                        1   60TIME
     I                                        1   20TIMHH
     I                                        3   40TIMFN
     I                                        5   60TIMTS
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     MOVEL'0111'    @@FACT  4
      *
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INI                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
     C                     TIME           TIME
     C                     MOVE '01'      DSPSW   2
      *
     C                     MOVEL*BLANK    D1UPD
     C                     MOVEL*BLANK    D1KAT1
     C                     MOVEL*BLANK    D1KAT2
     C                     MOVEL*BLANK    D1KAT3
     C                     MOVEL@@FACT    D1BMON
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTGCRPW311
     C                     SETOF                     313233
     C                     SETOF                     343599
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     END
      * F12
     C           *IN12     IFEQ '1'
     C                     CALL 'GCRR32'
     C                     GOTO ESB210
     C                     END
      * CHECK
     C           D1UPD     IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1UPD     IFNE '0'
     C           D1UPD     ANDNE'1'
     C           D1UPD     ANDNE'2'
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1KAT1    IFEQ *BLANK
     C                     MOVELER,3      D1ERR
     C                     SETON                     3299
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1KAT2    IFEQ *BLANK
     C                     MOVELER,3      D1ERR
     C                     SETON                     3399
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1BMON    IFNE @@FACT
     C                     MOVELER,6      D1ERR
     C                     SETON                     3599
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           KEYF5     KLIST
     C                     KFLD           D1KAT1
     C                     KFLD           D1KAT2
     C           KEYF5     CHAINFCQPL311             21
     C           *IN21     IFEQ '0'
     C           Q4SKJY    ANDEQ'D'
     C           Q4SKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
     C           *IN21     IFEQ '1'
     C                     MOVELER,7      D1ERR
     C                     SETON                     323334
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           KEYDR     KLIST
     C                     KFLD           D1KAT1
     C                     KFLD           D1KAT2
     C                     KFLD           D1KAT3
     C                     KFLD           D1BMON
     C           KEYDR     CHAINGCRPL111             21
     C           *IN21     IFEQ '0'
     C           DRSKJY    ANDEQ'D'
     C           DRSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C           D1UPD     IFEQ '0'
     C           D1UPD     OREQ '1'
     C                     SETON                     3199
     C                     MOVELER,4      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ELSE
     C           D1UPD     IFEQ '2'
     C                     SETON                     3199
     C                     MOVELER,5      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADD0         SVTGTN  90
     C                     MOVEL*BLANK    D2KSNM
     C                     SETOF                       39
     C                     SETOF                       30
     C           D1UPD     IFEQ '0'
     C                     SETON                       39
     C                     MOVELKOSN,1    D2KSNM
     C                     Z-ADDDRTGTN    D2TGTN
     C                     Z-ADDDRPLAN    D2PLAN
     C                     Z-ADDDRTGTO    D2TGTO
     C                     Z-ADDDRLAST    D2LAST
     C                     Z-ADDDRSTDT    D2STDT
     C                     Z-ADDDRSTLF    D2STLF
     C                     ENDIF
     C           D1UPD     IFEQ '1'
     C                     SETON                       30
     C                     MOVELKOSN,2    D2KSNM
     C                     Z-ADDDRTGTN    D2TGTN
     C                     Z-ADDDRPLAN    D2PLAN
     C                     Z-ADDDRTGTN    SVTGTN  90
     C                     Z-ADDDRTGTO    D2TGTO
     C                     Z-ADDDRLAST    D2LAST
     C                     Z-ADDDRSTDT    D2STDT
     C                     Z-ADDDRSTLF    D2STLF
     C                     ENDIF
     C           D1UPD     IFEQ '2'
     C                     MOVELKOSN,3    D2KSNM
     C                     Z-ADD0         D2TGTN
     C                     Z-ADD0         D2PLAN
     C                     Z-ADD0         D2TGTO
     C                     Z-ADD0         D2LAST
     C                     Z-ADD0         D2STDT
     C                     Z-ADD0         D2STLF
     C                     ENDIF
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * 2ND                                                *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTGCRPW312
     C                     SETOF                     313299
     C                     SETOF                     3334
     C                     MOVEL*BLANK    D2ERR
      *-------------------*
      *  CMD-3            *
      *-------------------*
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1UPD
     C                     MOVEL*BLANK    D1KAT1
     C                     MOVEL*BLANK    D1KAT2
     C                     MOVEL*BLANK    D1KAT3
     C                     MOVEL@@FACT    D1BMON
     C                     MOVE '01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D2STDT    IFEQ 0
     C                     MOVELER,9      D2ERR
     C                     SETON                     3399
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     MOVE D2STDT    PDATE   8
     C                     CALL 'DATR10'
     C                     PARM           PDATE   8
     C                     PARM           PRTN    1
     C           PRTN      IFEQ '1'
     C                     MOVELER,10     D2ERR
     C                     SETON                     3399
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D2STLF    IFEQ 0
     C                     MOVELER,11     D2ERR
     C                     SETON                     3499
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D2TGTN    IFEQ 0
     C                     MOVELER,8      D2ERR
     C                     SETON                     303199
     C                     GOTO ESB220
     C                     ENDIF
      * UPDATE
     C           *IN05     IFEQ '1'
     C                     EXSR #SB500
     C                     MOVEL*BLANK    D1UPD
     C                     MOVEL*BLANK    D1KAT1
     C                     MOVEL*BLANK    D1KAT2
     C                     MOVEL*BLANK    D1KAT3
     C                     MOVEL@@FACT    D1BMON
     C                     MOVE '01'      DSPSW
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     TIME           TIME
     C           KEYDR     CHAINGCRPL111             21
      *
     C                     SELEC
     C           D1UPD     WHEQ '0'
     C                     MOVE 'D'       DRSKJY
     C                     Z-ADD*DATE     DRSKHZ
     C                     EXSR #SB510
     C           D1UPD     WHEQ '1'
     C                     Z-ADD*DATE     DRKOHZ
     C                     TIME           DRKOTI
     C                     MOVELW#USER    DRKOME
     C                     Z-ADDD2TGTN    DRTGTN
     C                     Z-ADDD2PLAN    DRPLAN
     C                     Z-ADDSVTGTN    DRTGTO
     C                     Z-ADD*DATE     DRLAST
     C                     Z-ADDD2STDT    DRSTDT
     C                     Z-ADDD2STLF    DRSTLF
     C                     EXSR #SB510
     C           D1UPD     WHEQ '2'
     C                     CLEARGCRPL111
     C                     Z-ADD*DATE     DRKOHZ
     C                     TIME           DRKOTI
     C                     MOVELW#USER    DRKOME
     C                     MOVELD1KAT1    DRKAT1
     C                     MOVELD1KAT2    DRKAT2
     C                     MOVELD1KAT3    DRKAT3
     C                     MOVELD1BMON    DRBMON
     C                     Z-ADDD2TGTN    DRTGTN
     C                     Z-ADDD2PLAN    DRPLAN
     C                     Z-ADDD2TGTN    DRTGTO
     C                     Z-ADD*DATE     DRLAST
     C                     Z-ADDD2STDT    DRSTDT
     C                     Z-ADDD2STLF    DRSTLF
     C                     EXSR #SB512
     C                     ENDSL
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * CANCEL CHANGE                                      *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     UPDATGCRPL111
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      * ADD                                                *
      *----------------------------------------------------*
     CSR         #SB512    BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     UPDATGCRPL111
     C                     ELSE
     C                     WRITEGCRPL111
     C                     ENDIF
      *
     CSR         ESB512    ENDSR
      *****************************************************************
** KOSN
0 : CANCEL
1 : CHANGE
2 : ADD
** ERR
ER-01 INPUT UPDATE TYPE.
ER-02 INPUT 0,1,2.
ER-03 INPUT DIE NO.
ER-04 NOT FOUND DATA.
ER-05 ALREADY EXIST.
ER-06 INPUT FACTORY.0111
ER-07 NOT FOUND DIE SPEC M/F.
ER-08 INPUT TARGET TOOL LIFE.
ER-09 INPUT START DATE.
ER-10 DATE ERR.
ER-11 INPUT START TOOL LIFE.
