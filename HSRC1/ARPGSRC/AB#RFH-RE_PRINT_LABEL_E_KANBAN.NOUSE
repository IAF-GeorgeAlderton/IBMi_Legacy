%0001C           QASKJY    WHEQ 'D'
%0001C           QASKHZ    ANDLE*DATE
%0001C                     ITER                            DOCK CODE
     C           QAEFHZ    WHGT *DATE
%0001C                     ITER                            DOCK CODE
%0001C                     OTHER
