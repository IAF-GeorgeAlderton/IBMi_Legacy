     C                     Z-ADD*ZERO     J       20
     C                     Z-ADD*ZERO     L       20
     C                     Z-ADD*ZERO     M       20
     C                     MOVE *ALL'0'   WKBLK  15
     C                     MOVE *ALL'0'   SEQ
     C                     MOVE *BLANK    DEL
     C                     MOVE *ZERO     SHD
     C                     MOVE *BLANK    PAR
     C*
     C*
     C           *IN01     DOUEQ'1'
     C                     EXFMTFMT01
     C                     SETOF                     3031
     C                     MOVE *BLANK    FMEMSG
     C                     MOVE WKBLK     *IN,32
     C* F1
     C           *IN01     IFEQ '1'
     C* F5
     C                     ELSE
     C           *IN05     IFEQ '1'
     C                     EXSR @CHK
     C  N30                EXSR @F5
     C*
     C* ENTER
     C                     ELSE
     C                     EXSR @CHK
     C                     EXSR @SET
     C                     END
     C                     END
     C                     END
     C*
     C                     EXSR @END
