     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @SET : SET FIELD OF DISPLAY
     C**************************************************************************
     C           @SET      BEGSR
     C*
     C                     Z-ADD1         J
     C           1         DO   15        J
     C           SEQ,J     IFNE *ZERO
     C                     MOVEAWCDELY    DEL,J            DELIVERY
     C                     MOVEAWCSHDT    SHD,J            SHIPPING DATE
     C                     MOVEAWCIPAR    PAR,J            PART
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @CHK : CHECK INPUT FIELD
     C**************************************************************************
     C           @CHK      BEGSR
     C*
     C           #SEQFR    IFEQ *ZERO
     C           #SEQTO    ANDEQ*ZERO
     C*
     C           #SEQ1     IFEQ *ZERO
     C                     SETON                     3031
     C                     MOVEAMES,1     FMEMSG
     C                     END
     C*
     C                     ELSE
     C           #SEQFR    IFNE *ZERO
     C           #SEQTO    ANDNE*ZERO
     C*
     C           #SEQFR    IFGT #SEQTO
     C                     SETON                     3031
     C                     MOVEAMES,1     FMEMSG
     C                     END
     C*
     C                     ELSE
     C                     SETON                     3031
     C                     MOVEAMES,1     FMEMSG
     C                     END
     C                     END
     C*
     C                     Z-ADD1         L
     C           1         DO   15        L
     C           SEQ,L     IFNE *ZERO
     C                     MOVE SEQ,L     KSEQ
     C           KEY1      CHAINABF6L01             N90
     C*
     C           *IN90     IFEQ '1'
     C                     SETON                     30
     C           L         ADD  31        M
     C                     MOVEA'1'       *IN,M
     C                     MOVEAMES,1     FMEMSG
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @F5 : RE-CREATE LABEL DATE
     C**************************************************************************
     C           @F5       BEGSR
     C*
     C* FROM - TO
     C           #SEQFR    IFNE *ZERO
     C                     Z-ADD#SEQFR    KSEQ
     C           KEY1      SETLLABF6L01
     C                     READ ABF6L01                  90
     C           *IN90     DOUEQ'1'
     C           FCSEQ#    ORGT #SEQTO
     C*
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C                     EXSR @MOVE
     C                     EXSR @MOVE1
     C           FCPRNT    IFEQ *BLANK
     C                     MOVE 'P'       FCPRNT
     C                     ENDIF
      *
     C                     UPDATABF6P011
      *
     C                     WRITEABF8P011
     C           FCPBCD    IFEQ 'M'
     C                     WRITEABF8P011
     C                     END
     C                     END
     C*
     C                     READ ABF6L01                  90
     C                     END
     C                     END
     C*
     C* INDIVISUAL
     C           #SEQFR    IFEQ *ZERO
     C                     Z-ADD1         L
     C           1         DO   15        L
     C*
     C           SEQ,L     IFNE *ZERO
     C                     MOVE SEQ,L     KSEQ
     C           KEY1      SETLLABF6L01
     C           KEY1      READEABF6L01                  90
     C*
     C           *IN90     DOWEQ'0'
     C*
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C                     EXSR @MOVE
     C                     EXSR @MOVE1
     C                     WRITEABF8P011
     C           FCPBCD    IFEQ 'M'
     C                     WRITEABF8P011
     C                     END
     C                     END
     C           KEY1      READEABF6L01                  90
     C                     END
     C*
     C                     END
     C*
     C                     END
     C                     END
     C*
     C                     MOVE *ZERO     #SEQFR
     C                     MOVE *ZERO     #SEQTO
     C                     MOVE *ALL'0'   SEQ
     C                     MOVE *BLANK    DEL
     C                     MOVE *ZERO     SHD
     C                     MOVE *BLANK    PAR
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @MOVE1 SUBROUTINE: MOVE DATA FROM DBFILES TO FILE ABF8P01
     C**************************************************************************
     C           @MOVE1    BEGSR
     C*
     C                     MOVE 'P'       F8KUB1
     C                     MOVE 'C'       F8KUB2
     C*
     C* FIND THE FIRST BLANK BEFORE THE SUFIX PART NUMBER
     C                     Z-ADD20        M       20
     C                     MOVEAFCCPAR    PNO
     C           PNO,M     DOUNE*BLANK
     C                     SUB  1         M
     C                     END
     C*
     C           PNO,M     DOUEQ*BLANK
     C                     SUB  1         M
     C                     END
     C*
     C                     Z-ADD*ZERO     W       20
     C                     MOVE *BLANK    NOB
     C           M         SUB  1         P       20
     C           1         DO   P         W
     C                     MOVE PNO,W     NOB,W
     C                     END
     C                     MOVEANOB       F8PA1R
     C                     MOVEANOB       F8PAR1
     C*
     C                     Z-ADD*ZERO     W       20
     C                     Z-ADD1         T       20
     C                     MOVE *BLANK    NOA
     C           M         ADD  1         P       20
     C           P         DO   20        W
     C                     MOVE PNO,W     NOA,T
     C           T         IFEQ 4
     C           T         ADD  1         TT      20
     C           PNO,TT    IFNE *BLANK
     C                     ADD  1         T
     C*******              MOVE '-'       NOA,T
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         T
     C                     END
     C                     MOVEANOA       F8PA2R
     C                     MOVEANOA       F8PAR2
     C*
%0001C                     Z-ADDFCRQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWRQTY 15
%0001C                     Z-ADDFCUQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWUQTY 15
     C*
   B1C           FCPBCD    IFEQ 'M'
%0001C                     MOVELWWRQTY    F8QTYR
     C                     ELSE
%0001C                     MOVELWWUQTY    F8QTYR
   E1C                     END
     C*
     C                     Z-ADD1         I       20
     C                     MOVEAF8QTYR    QT
     C           1         DO   15        I
     C           QT,I      IFNE '0'
     C                     MOVEAQT,I      AR2
     C                     LEAVE
     C                     END
     C                     END
     C*
     C*
     C                     MOVE *BLANK    AR     16
     C                     MOVEAAR2       F8QTYR
     C                     MOVE F8QTYR    AR     16
     C                     MOVEL'Q'       AR
     C                     MOVE AR        F8QTY
     C                     MOVE *BLANK    F8RCOD
     C                     MOVEL*BLANK    F8LINE
     C*
%0001C                     MOVEL'0'       WNKOJ   1
%0001C                     MOVE FCSHTM    WSHTM   20
     C*
%0001C                     SETOF                     20
%0001C           KEY8      SETLLAB#PL141
C    C           *IN20     DOUEQ*ON
%0001C           KEY8      READEAB#PL141                 20
%0001C           *IN20     IFEQ '0'
%0001C           BASKJY    ANDEQ*BLANK
%0001C                     MOVELBARESE    F8RCOD
%0001C                     MOVELBAALFL    F8LINE
     C                     Z-ADDBATOKU    EKTOKU
     C                     MOVELBAMHN1    EKMHN1
     C                     MOVELBAMHN2    EKMHN2
     C                     MOVELBAMHN3    EKMHN3
     C                     MOVELBAMHN4    EKMHN4
     C                     MOVE BANOBN    EKNOBN
     C                     Z-ADDBADEYY    EKRLYY
     C                     Z-ADDBADEMM    EKRLMM
     C                     Z-ADDBADEDD    EKRLDD
     C                     LEAVE
%0001C                     ENDIF
%0001C                     ENDDO
     C*
     C                     MOVELFCSEQ#    F8SEQR
     C                     MOVELFCPBCD    F8SEQ
     C                     MOVE FCSEQ#    F8SEQ
     C                     MOVELFCPBCD    F8LCOD
     C                     MOVELFCSHDT    F8SHDT
     C                     MOVE FC#PLT    F8PLTN
     C                     MOVE *BLANK    WDELY   4
     C                     MOVE FCDELY    WDELY
     C                     Z-ADD*DATE     F8CDAT
     C           KEY3      CHAINABF9L01              91
     C           *IN91     IFEQ '0'
     C                     MOVELF9SHIP    F8SHIP
     C                     MOVELF9PLID    F8PLID
     C                     MOVE F9PLID    FLD9    4
     C                     MOVE FLD9      F8PLQY
     C                     MOVEL'D'       F8PLQY
     C                     MOVELF9ADD1    F8ADD1
     C                     MOVELF9ADD2    F8ADD2
     C                     END
     C                     Z-ADDFCDELY    F8NONY           DELIV CODE
     C********             MOVE FCSFCT    F8NKOJ           FACTORY CODE
     C                     MOVE '0'       F8NKOJ           FACTORY CODE
     C                     MOVE FCDOCK    F8NUKE           DOCK CODE
      *
     C                     MOVE *BLANK    F8TKRO
     C                     MOVE *BLANK    F8ZETI
     C                     MOVE *BLANK    F8SYOS
     C           KEY4      CHAINFCEPL011             15
     C           *IN15     IFEQ '0'
     C*          A2GSKD    IFEQ 'D'
     C*          A2GSHZ    ANDLE*DATE
     C*                    ELSE
     C                     MOVELA2ZETI    F8ZETI
     C*
     C           A2TRHZ    IFLE *DATE
     C                     MOVELA2STKR    F8TKRO
     C                     ELSE
     C                     MOVELA2KTKR    F8TKRO
     C                     END
     C*
     C           A2SSHZ    IFLE *DATE
     C                     MOVE A2SSYS    F8SYOS           QTY/CONT.
     C                     ELSE
     C                     MOVE A2KSYS    F8SYOS
     C                     END
     C                     END
     C*                    END
     C*
     C**************       MOVE FCPGM     F8PGM            PROGRAM ID
     C                     MOVE FCORD#    F8ORD#           ORDER NUMBER
     C* NIRVANA
      *
%0001C                     MOVEL*BLANK    WDOCK   4
%0001C                     MOVELFCDOCK    WDOCK   4
%0001C                     MOVE *BLANK    F8DOCK           DOCK CODE
%0001C           KEY7      SETGTABFDL01R
