     H            Y.
      ** ALFR52  *******************************************
      *  CONVEYANCE WASHER PULL SCAN ERROR LOG LIST        *
      *                                                    *
      * LEC   2018/12/10 CREATE(COPY FROM ALFR02)          *
      ******************************************************
     FALFPP01 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1  120W@FROM
     I                                        1   80W@SCDT
     I                                        1   40W@SCYY
     I                                        5   60W@SCMM
     I                                        7   80W@SCDD
     I                                        9  120W@SCTM
     I            DS
     I                                        1  120W@TO
     I                                        1   80W@ECDT
     I                                        1   40W@ECYY
     I                                        5   60W@ECMM
     I                                        7   80W@ECDD
     I                                        9  120W@ECTM
     I            DS
     I                                        1  14 W@PRT
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     I            DS
     I                                        1  15 W8BRC@
     I                                        2  15 W8BRC4
      *
      * SCAN DATE/TIME
     I            DS
     I                                        1   80A8DATE
     I                                        9  140A8TIME
     I                                        1  120A8DTTM
     I                                        9  120A8HHMM
      *
     C           K#01      KLIST
     C                     KFLD           W@SCDT
     C                     KFLD           W@STTM
      *
     C           K#01      SETLLALFPP01
      *
     C                     DO   *HIVAL
      *
     C                     READ ALFPP01                  99
     C   99                LEAVE
      *
     C           A8ERR     IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           A8DTTM    IFGT W@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     MOVELA8TMCD    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C  N97                MOVELALWKNM    P@WKNM 20
     C   97                MOVEL*BLANK    P@WKNM
      *
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELA8PRT1    W@PRT1
     C                     MOVELA8PRT2    W@PRT2
     C                     MOVELA8PRT3    W@PRT3
     C           A8PRT2    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     ENDIF
     C           A8PRT3    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     ENDIF
     C                     MOVELW@PRT     P@PRT1 14
     C*
     C           A8DKND    IFEQ 'A'
     C                     MOVELA8BRC2    W@BRC2 17 P
     C                     MOVEL*BLANK    W@BRC3 15 P
     C                     MOVEL'ASJ '    P@KND   4
     C                     ELSE
     C                     MOVELA8BRC3    W@BRC2    P
     C                     MOVELA8BRC4    W8BRC@
     C                     MOVELW8BRC4    W@BRC3    P
     C           A8DKND    IFEQ 'F'
     C                     MOVEL'FRWY'    P@KND
     C                     ELSE
     C           A8DKND    IFEQ 'R'
     C                     MOVEL'RKMT'    P@KND
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXCPT@DTL
     C                     MOVEL*ON       PMRFLG
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PMFRDT 12
     C                     PARM           PMTODT 12
     C                     PARM           PMRFLG  1
     C                     MOVEL*OFF      PMRFLG
      *
     C                     TIME           WSDT
      *
     C                     MOVELPMFRDT    W@FROM
     C                     MOVELPMTODT    W@TO
      *
     C           W@SCTM    MULT 100       W@STTM  60
     C           W@ECTM    MULT 100       W@EDTM  60
      *
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   16 'DATE RANGE FROM:'
     O                         W@SCDTY   28
     O                         W@SCTM    36 '  :  '
     O                                   43 'TO:'
     O                         W@ECDTY   55
     O                         W@ECTM    63 '  :  '
     O        E   05           @HED
     O                                    4 'DATE'
     O                                   15 'TIME'
     O                                   31 'TEAM MEMBER'
     O                                   49 'LOCATION'
     O                                   60 'KIND'
     O                                   75 'ASJ/FRWY/RKMTL'
     O                                   90 'RETRIEVAL'
     O                                  112 'ERROR MESSAGE'
     O        E 1              @DTL
     O                         A8DATEY   10
     O                         A8TIME    19 '  :  :  '
     O                         P@WKNM    40
     O                         A8BRC1    51
     O                         P@KND     60
     O                         W@BRC2    78
     O                         A8BRC5    96
     O                         A8EM01   119
     O        E 1              @DTL
     O                         P@PRT1    55
     O                         W@BRC3    76
     O                         A8EM02   119
** TBL
<< CONVEYANCE WASHER PULL SCAN ERROR LOG LIST >>
