     C                     Z-ADD0         W@FSD1  90
     C                     Z-ADD0         W@FSD2  90
     C                     Z-ADD0         W@USD1  90
     C                     Z-ADD0         W@USD2  90
     C                     Z-ADD0         W@USD3  90
     C           *IN80     DOWEQ'0'
     C           W1SHN     ANDEQW@SHN
     C           W1OMIT    IFEQ '0'
     C           W1OMIT    OREQ '2'
     C           W1OMIT    OREQ '3'
     C           W1OMIT    OREQ '4'
     C                     ADD  W1NSRY    W@NSRY
