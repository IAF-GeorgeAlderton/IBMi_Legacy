     H            Y.
     F* TMPR03B ************************************************
     F* ASSIGN CREATE DATE BY SHIP-DATE/UPD-DATE               *
     F* JW   2022.11.15                                        *
     F**********************************************************
     FAB#PL1O UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     I            DS
     I                                        1   80BAKOHZ
     I                                        1   40BAKOYY
     I                                        5   60BAKOMM
     I                                        7   80BAKODD
     I            DS
     I                                        1   60BAKOTM
     I                                        1   20BAKOHH
     I                                        3   40BAKOSS
     I                                        5   60BAKOXX
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************
      * MAIN ROUTINE *
      ****************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#PL1O
      *
     C                     DO   *HIVAL
     C                     READ AB#PL1O                  98
     C   98                LEAVE
      *
     C           BACRHZ    IFNE 0
     C                     ITER
     C                     ENDIF
      *
     C                     SELEC
     C           BANOHZ    WHLE BAKOHZ
     C                     Z-ADDBANOHZ    BACRHZ
     C                     Z-ADDBAKOTM    BACRTM
     C                     MOVELBANOHZ    BACRME
     C                     MOVEL#PGM      BACRPG
     C                     UPDATAB#PP101
     C           BANOHZ    WHGT BAKOHZ
     C                     Z-ADDBAKOHZ    BACRHZ
     C                     Z-ADDBAKOTM    BACRTM
     C                     MOVELBAKOME    BACRME
     C                     MOVEL#PGM      BACRPG
     C                     UPDATAB#PP101
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      **************
      * INIT
      **************
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
      *
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    XMSG    8
     C                     Z-ADD0         BAKOXX
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O**                                 14 'UPD='
     O**                       ¥UPD      15
     O                                   45 '** ASSIGN CREATE DAT'
     O                                   65 'E BY PPA1 **        '
     O                                   85 '                    '
     O                                  106 'DATE'
     O                         TODAY    109 '    .  .  '
     O                         NOW      119 '  :  :  '
     O                                  122 'P.'
     O                         PAGE  Z  126
     O        E   02           @HDR
     O                                    1 '.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   15 'CRT_DATE'
     O                                   25 'CRT_TIME'
     O                                   30 'CUST'
     O                                   35 'DELV'
     O                                   47 'MHIN'
     O                                   70 'PO#'
     O                                   87 'SHIP_DATE'
     O        E 1              @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         BACRHZ  +001 '    /  /  '
     O                         BACRTM  +001 '0 :  :  '
     O                         BATOKU  +001
     O                         BANONY  +001
     O                         BANKOJ  +001
     O                         BANUKE  +001
     O                         BAMHN1  +001
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         BAMHN4  +001
     O                         BAODRN  +001
     O                         BANOYY  +001
     O                         BANOMM  +001
     O                         BANODD  +001
     O                         BANOBN  +001
     O                         BADEYY  +001
     O                         BADEMM  +001
     O                         BADEDD  +001
     O                         BAIAF#  +001
     O                         XMSG    +001
