      *       TCH                 2002.07.18
      *
     F************************************ GBFR46 **
     FGBFPW46 CF  E                    WORKSTN
     FGBFNP44 UF  E           K        DISK                      A
     FGBFWP90 IF  E           K        DISK
     E                    ER      1   3 60
     I            DS
     I                                        1  15 @HINBN
     I                                        1   5 @HIN1
     I                                        6  10 @HIN2
     I                                       11  15 @HIN3
     I            DS
     I                                        1  15 GRHIN
     I                                        1   5 GRHIN1
     I                                        6  10 GRHIN2
     I                                       11  15 GRHIN3
     C*
     C*_____
     C* KEY
     C*~~~~~
     C           KEY1      KLIST
     C                     KFLD           @@TOKU
     C                     KFLD           @KOJO
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C           KEY2      KLIST
     C                     KFLD           @@TOKU
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C*_________
     C* ﾌﾟ[xｰjｰ
     C*~~~~~~~~~
     C           *ENTRY    PLIST
     C                     PARM           @TOKU   4        nhbﾅg
     C                     PARM           @KOJO   1        ﾃcﾆﾞｭc
     C                     MOVE @TOKU     @@TOKU  40
     C*___________
     C* PRG START
     C*~~~~~~~~~~~
     C*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     C*                    2fﾞx]
     C*_____________________________________________________
     C           STEP1     TAG
     C                     MOVE *BLANK    @KOKU
     C                     MOVE *BLANK    @HINBN
     C                     Z-ADD0         GRSRYO
     C                     Z-ADD0         GRKOTA
     C                     Z-ADD0         GRRATA
     C                     Z-ADD0         GRKDTA
     C                     Z-ADD0         GRZRTA
     C                     Z-ADD0         GRVATA
     C           STEP2     TAG
     C                     EXFMTGBFPW462
     C                     SETOF                     030499
     C*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C           @KOKU     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,1      @ERR
     C                     GOTO STEP2
     C                     END
     C*
     C           @KOKU     IFLT '0'
     C           @KOKU     ORGT '2'
     C                     SETON                     0399
     C                     MOVE ER,2      @ERR
     C                     GOTO STEP2
     C                     END
     C*
     C           @HINBN    IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,1      @ERR
     C                     GOTO STEP2
     C                     END
     C*
     C                     SETOF                     11
     C           KEY1      CHAINGBFNP441             11
     C           *IN11     IFEQ '1'
     C           @KOKU     IFNE '2'
     C                     SETON                     030499
     C                     MOVE ER,3      @ERR
     C                     GOTO STEP2
     C                     END
     C                     END
      *
     C           KEY2      CHAINGBFWP90              90
     C           *IN90     IFEQ *OFF
     C           GBNQTY    ANDNE*ZERO
     C                     Z-ADDGBNQTY    GRSRYO
     C                     ENDIF
      *
     C*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     C*                    3fﾞx]
     C*_____________________________________________________
     C           STEP3     TAG
     C                     EXFMTGBFPW463
     C                     SETOF                     050607
     C                     SETOF                     0809
     C                     SETOF                     99
     C*
     C           *INKC     IFEQ '1'
     C                     GOTO STEP1
     C                     END
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO STEP3
     C                     END
     C*
     C*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     C*                    ﾃcﾆ]
     C*_____________________________________________________
     C*
     C           *IN11     IFEQ '0'
     C           @KOKU     IFEQ '0'
     C                     DELETGBFNP441
     C                     END
     C           @KOKU     IFEQ '1'
     C                     UPDATGBFNP441
     C                     END
     C                     ELSE
     C                     MOVE @@TOKU    GRTOKU
     C                     MOVE @KOJO     GRKOJO
     C                     MOVE @HINBN    GRHIN
     C                     WRITEGBFNP441
     C                     END
     C                     GOTO STEP1
**  ER (d[ｰ xｮﾈｰﾆﾞ)
E-01  INPUT REVERSED.
E-02  REVERSED IS INCORRECT.
E-03  DATA CANNOT BE FOUND.
