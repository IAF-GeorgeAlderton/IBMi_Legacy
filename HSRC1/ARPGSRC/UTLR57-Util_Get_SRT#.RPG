     H            Y.
     F** UTLR57 ********************************************
     F*  PROGRAM: UTILITY- RETRIEVE SRT#                   *
     F*  WRITTEN: JW (SRA)                                 *
     F*           02/15/2018                               *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR57'
     F*                    PARM           $SHIN  12
     F*                    PARM           $SRTN  20
     F*                    PARM           $SRT#  20
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A IAF PART#
     F*  OUT $SRTN : 10A SORT NAME
     F*      $SRT# : 10A SORT #
     F*      $RTN  :  1A RETURN CODE (BLANK/*)
     F******************************************************
     FAAFTL06 IF  E           K        DISK
      *PF (AAFPP01)
     FAAHTL06 IF  E           K        DISK
      *PF (AAHPP01)
     FCADTL03 IF  E           K        DISK
      *PF (CADPP01)
      *
     I            DS
     I                                        1  16 A3JOKA
     I                                        1   2 A3JOK1
     I                                        3   4 A3JOK2
     I                                        5   6 A3JOK3
     I                                        7   8 A3JOK4
     I                                        9  10 A3JOK5
     I                                       11  12 A3JOK6
     I                                       13  14 A3JOK7
     I                                       15  16 A3JOK8
     I            DS
     I                                        1  16 L6JOKA
     I                                        1   2 L6JOK1
     I                                        3   4 L6JOK2
     I                                        5   6 L6JOK3
     I                                        7   8 L6JOK4
     I                                        9  10 L6JOK5
     I                                       11  12 L6JOK6
     I                                       13  14 L6JOK7
     I                                       15  16 L6JOK8
     I            DS
     I                                        1  14 C2JOKA
     I                                        1   2 C2SJK1
     I                                        3   4 C2SJK2
     I                                        5   6 C2SJK3
     I                                        7   8 C2NJK1
     I                                        9  10 C2NJK2
     I                                       11  12 C2NJK3
     I                                       13  14 C2NJK4
     I            DS
     I                                        1   6 P@LOC
     I                                        1   1 P@LOC1
     I                                        2   3 P@LOC2
     I                                        4   5 P@LOC3
     I                                        6   6 P@LOC4
     I            DS
     I                                        1  12 P@SHIN
     I                                        1   5 P@SHN1
     I                                        6  10 P@SHN2
     I                                       11  12 P@SHN3
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * GET LAST LOCATION
     C                     EXSR #GETL
      *
     C           $RTN1     IFEQ '*'
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     EXSR #AAF
      *
     C           P#SNAM    IFEQ *BLANK
     C                     EXSR #AAH
     C                     ENDIF
      *
     C           P#SNAM    IFEQ *BLANK
     C                     EXSR #CAD
     C                     ENDIF
      *
     C           P#SNAM    IFNE *BLANK
     C           P#SRT#    ORNE *BLANK
     C                     MOVE P#SNAM    $SRTN
     C                     MOVE P#SRT#    $SRT#
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *
      *===================================================
      *          GET LAST LOCATION
      *===================================================
     C           #GETL     BEGSR
      *
     C                     CALL 'UTLR21'
     C                     PARM           $SHIN  12
     C                     PARM           $LLOC   6
     C                     PARM           $LQC    50
     C                     PARM           $LPRC   3
     C                     PARM           $LDPT   40
     C                     PARM           $ZETI   4
     C                     PARM           $RTN1   1
      *
     C                     MOVEL$LLOC     P@LOC
      *
     C                     ENDSR
      *===================================================
      *          CHECK AAF
      *===================================================
     C           #AAF      BEGSR
      *
     C           HINKEY    SETLLAAFTL06
     C                     DO   *HIVAL
     C           HINKEY    READEAAFTL06                  88
     C   88                LEAVE
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           @DATE     IFGE A3UKHZ
     C           @DATE     ANDLTA3STHZ
     C                     ELSE
     C                     ITER
     C                     END
      *
     C           P@LOC1    IFNE *BLANK
     C           P@LOC1    IFNE A3ATK1
     C           P@LOC2    ORNE A3ATK2
     C           P@LOC3    ORNE A3ATK3
     C           P@LOC4    ORNE A3ATK4
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVE A3KCD1    P#KANB
     C                     MOVELA3JOKA    P#KOJA
     C                     MOVE *BLANK    P#NAMA
     C                     MOVE *BLANK    P#SNAM
     C                     MOVE *BLANK    P#SRT#
     C                     CALL 'AAARS3'
     C                     PARM           P#KANB  1
     C                     PARM           P#KOJA 20
     C                     PARM           P#NAMA200
     C                     PARM           P#SNAM 20
     C                     PARM           P#SRT# 20
      *
     C                     ENDDO
      *
     C                     ENDSR
      *===================================================
      *          CHECK AAH
      *===================================================
     C           #AAH      BEGSR
      *
     C           HINKEY    SETLLAAHTL06
     C                     DO   *HIVAL
     C           HINKEY    READEAAHTL06                  88
     C   88                LEAVE
     C           L6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           @DATE     IFGE L6UKHZ
     C           @DATE     ANDLTL6STHZ
     C                     ELSE
     C                     ITER
     C                     END
      *
     C           P@LOC1    IFNE *BLANK
     C           P@LOC1    IFNE L6ATK1
     C           P@LOC2    ORNE L6ATK2
     C           P@LOC3    ORNE L6ATK3
     C           P@LOC4    ORNE L6ATK4
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVE L6KCD1    P#KANB
     C                     MOVELL6JOKA    P#KOJA
     C                     MOVE *BLANK    P#NAMA
     C                     MOVE *BLANK    P#SNAM
     C                     MOVE *BLANK    P#SRT#
     C                     CALL 'AAARS3'
     C                     PARM           P#KANB  1
     C                     PARM           P#KOJA 20
     C                     PARM           P#NAMA200
     C                     PARM           P#SNAM 20
     C                     PARM           P#SRT# 20
      *
     C                     ENDDO
      *
     C                     ENDSR
      *===================================================
      *          CHECK CAD
      *===================================================
     C           #CAD      BEGSR
      *
     C           HINKEY    SETLLCADTL03
     C                     DO   *HIVAL
     C           HINKEY    READECADTL03                  88
     C   88                LEAVE
     C           C2SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           @DATE     IFGE C2UKHZ
     C           @DATE     ANDLTC2STHZ
     C                     ELSE
     C                     ITER
     C                     END
      *
     C           P@LOC1    IFNE *BLANK
     C           P@LOC1    IFNE C2TKR1
     C           P@LOC2    ORNE C2TKR2
     C           P@LOC3    ORNE C2TKR3
     C           P@LOC4    ORNE C2TKR4
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVE C2KCD1    P#KANB
     C                     MOVELC2JOKA    P#KOJA
     C                     MOVE *BLANK    P#NAMA
     C                     MOVE *BLANK    P#SNAM
     C                     MOVE *BLANK    P#SRT#
     C                     CALL 'AAARS3'
     C                     PARM           P#KANB  1
     C                     PARM           P#KOJA 20
     C                     PARM           P#NAMA200
     C                     PARM           P#SNAM 20
     C                     PARM           P#SRT# 20
      *
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
      *
     C                     PARM           $SHIN  12
     C**                   PARM           $LOC    6
     C                     PARM           $SRTN  20
     C                     PARM           $SRT#  20
     C                     PARM           $RTN    1
      *
     C                     MOVEL$SHIN     P@SHIN
     C**                   MOVEL$LOC      P@LOC
     C                     MOVE *BLANK    $SRTN
     C                     MOVE *BLANK    $SRT#
     C                     MOVE *BLANK    $RTN
      * SYSTEM DATE
     C                     TIME           @TMDT  140
     C                     Z-ADD@TMDT     @DATE   80
      *
     C                     MOVE P@SHN1    K@HIN1
     C                     MOVE P@SHN2    K@HIN2
     C                     MOVE P@SHN3    K@HIN3
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C                     ENDSR
      *====================================================
