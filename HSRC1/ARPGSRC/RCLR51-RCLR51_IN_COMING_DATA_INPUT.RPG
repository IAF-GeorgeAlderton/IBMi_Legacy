     C****************************************************************
     C* CL.6.1.1  fﾞx] ﾎb-ﾓnﾞ hﾒa-                                   *
     C****************************************************************
     C           STEP1     TAG
     C                     Z-ADD1         I       20
     C           1         DO   32        I
     C                     MOVE *BLANK    TN,I
     C                     MOVE '0'       *IN,I
     C                     END
     C                     SETOF                     90
     C                     MOVE *BLANK    MSG
     C****************************************************************
     C* CL.6.1.2  fﾞx]1 ﾍﾑcﾆﾞ                                        *
     C****************************************************************
     C           STEP2     TAG
     C                     EXFMTRCLPW511
     C   KA                SETON                     LR
     C   KA                RETRN
     C****************************************************************
     C* CL.6.1.2.1 fﾞx]1 kdlh                                         *
     C****************************************************************
     C                     Z-ADD1         I
     C           1         DO   32        I
     C                     MOVE '0'       *IN,I
     C                     END
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    ERSW    1
     C                     EXSR #CHE
     C           ERSW      CABEQ'*'       STEP2          90
     C   KE                GOTO ED
     C                     GOTO STEP2
     C           ED        TAG
     C                     EXSR #UP
     C                     GOTO STEP1
     C****************************************************************
     C* CL.6.1.2.1 fﾞx]1 kdlh                                         *
     C****************************************************************
     C           #CHE      BEGSR
     C                     Z-ADD1         I
     C           1         DO   32        I
     C                     SETOF                         90
     C           TN,I      IFNE *BLANK
     C                     MOVE TN,I      WWW
     C                     Z-ADD1         Z       20
     C           WWW3      LOKUPNN,Z                     50
     C   50                Z-ADD1         Z
     C   50      WWW4      LOKUPNN,Z                     50
     C   50                Z-ADD1         Z
     C   50      WWW5      LOKUPNN,Z                     50
     C   50                Z-ADD1         Z
     C   50      WWW6      LOKUPNN,Z                     50
     C  N50                MOVE '*'       ERSW
     C  N50                MOVELER,2      MSG
     C  N50                SETON                     90
     C  N50                MOVE '1'       *IN,I
     C  N50                GOTO CHEEND
     C                     MOVE TN,I      TTT
     C           TNKEY     CHAINDC#PL111             40
     C   40                MOVE '*'       ERSW
     C   40                MOVELER,1      MSG
     C   40                MOVE '1'       *IN,I
     C   40                SETON                     90
     C  N40      P5SKJY    IFEQ 'D'
     C                     MOVE '*'       ERSW
     C                     MOVELER,1      MSG
     C                     MOVE '1'       *IN,I
     C                     SETON                     90
     C                     ELSE
     C                     EXSR #ZCHE
     C                     EXSR #HICHE
     C                     END
     C           CHEEND    TAG
     C                     END
     C  N90                END
     C                     ENDSR
     C****************************************************************
     C* CL.6.1.2.2 Zﾌﾞ]k uﾇj- kdlh                                    *
     C****************************************************************
     C           #ZCHE     BEGSR
     C           BAN2      CABNE'Z'       ZCHEED
     C                     MOVE TN,I      ZZZ
     C           ZKEY      CHAINFCLPL221             50
     C   50                GOTO ERR
     C           P3SKJY    CABEQ'D'       ERR
     C           P3HINB    CABNEP5HINB    ERR
     C                     GOTO ZCHEED
     C           ERR       TAG
     C                     MOVE '*'       ERSW
     C                     MOVELER,3      MSG
     C                     MOVE '1'       *IN,I
     C                     SETON                     90
     C           ZCHEED    ENDSR
     C****************************************************************
     C* CL.6.1.2.2 pﾏcﾃ ﾍﾞ kdlh                                       *
     C****************************************************************
     C           #HICHE    BEGSR
     C           P5NKYY    COMP 0                        50
     C   50      P5NKMM    COMP 0                        50
     C   50      P5NKDD    COMP 0                        50
     C  N50                MOVE '*'       ERSW
     C  N50                MOVELER,4      MSG
     C  N50                MOVE '1'       *IN,I
     C  N50                SETON                     90
     C                     ENDSR
     C****************************************************************
     C* CL.6.1.3.1 iﾞ]mb ﾓbﾈg ﾎabﾓ & Zﾌﾞ]kuﾇj- ﾃcﾆ]                  *
     C****************************************************************
