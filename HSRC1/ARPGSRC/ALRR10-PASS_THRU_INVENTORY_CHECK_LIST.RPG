     C           ACALL     PLIST
     C                     PARM           ASTLR   2        SETON LR ﾍｭcﾆg
     C                     PARM           L5TKR1           nﾃﾜﾌﾞ]k 1
     C                     PARM           L5TKR2                   2
     C                     PARM           L5TKR3                   3
     C                     PARM           L5TKR4                   4
     C                     PARM           WKTSU   90       fhmbﾈｮmbﾇc
     C                     PARM           L5SYOS           ﾆｬcﾑcﾇc
     C                     PARM           WLTM1            ﾆbﾛﾅgL.T
     C                     PARM           WLTM2            a]ﾈﾞ]L.T
     C                     PARM           L5BMON           ﾃcpｬc ﾎﾞy]
     C                     PARM           L5SKCD           ﾈbgｬcﾅg
     C                     PARM           WHITO   3        ﾍgnﾒﾇc
     C                     PARM           ZHITO   3        ﾍgnﾒﾜｮn
     C                     PARM           L5KCD1           f]ﾌﾞ] jﾞb
     C                     PARM           L5KCD2                 ﾆｭc
     C                     PARM           L5UZAR           a]ﾈﾞ]ubﾇc
     C                     PARM           WMAIS   50       f]ﾌﾞ]ubﾇc
     C                     PARM           PYM     6        ﾆｭﾒﾍﾇﾞi
     C                     PARM           L5HKSU           ﾌﾃﾇc
      *
     C           BCALL     PLIST
     C                     PARM           BSTLR            SETON LR ﾍｭcﾆg
     C                     PARM           WMAIS2  50       f]ﾌﾞ]ubﾇc
     C                     PARM           L1KTSU           fhmbﾍajﾒﾇc
     C                     PARM           L1SYOS           ﾆｬcﾑcﾇc
     C                     PARM           L1LTIM           ﾒｰnﾞjbw
     C                     PARM           L1ROTO           ﾜｮn
     C                     PARM           L1KISU           ﾌﾞ[lgibﾇc
     C                     PARM           L1UZAR           kｭcﾈbubﾇc
     C                     PARM           L1HITO           anﾃcmbﾍgnﾒ
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
      *------------------                                              *********
     C                     TIME           WSDT
     C                     MOVEL*BLANK    W1PRTA 20
      *------------------                                              *********
     C* PASS THRU
      *------------------                                              *********
     C                     READ AAPPP01                  80
     C           *IN80     DOWEQ'0'
     C           L5SKJY    IFEQ *BLANK
     C           L5STHZ    ANDGT*DATE
     C           L5BMON    ANDEQ8990
     C           L5SYOS    ANDNE0
     C                     CLEARALRWP101
     C                     MOVEL'0'       W1TYPE
     C                     MOVELL5SHN1    W1PRT1
     C                     MOVELL5SHN2    W1PRT2
     C                     MOVELL5SHN3    W1PRT3
     C                     MOVELL5TKR2    W1LOC2
     C                     MOVELL5TKR3    W1LOC3
     C**  RE-CALCULATE # OF KANBAN
|    C                     EXSR #SB810
     C***        L5KTSU    MULT 20        WKTSU
     C           L5KSSU    MULT 20        WKTSU
     C                     Z-ADD0         WMAIS
     C                     MOVE L5HITO    WHITO
     C                     MOVE L5HITO    ZHITO
     C                     MOVE WSYM6     PYM
     C                     CALL 'ABCR09'  ACALL
     C**
     C***                  Z-ADDL5KMAX    W1KMAX
     C                     Z-ADDWMAIS     W1KMAX
     C**
     C***                  Z-ADDL5KTSU    W1STPD
     C                     Z-ADDL5KSSU    W1STPD
     C                     Z-ADDL5SYOS    W1QPC
     C                     Z-ADD1         W1LOT
     C           W1STPD    DIV  W1QPC     W1BXPD  72H
     C*
     C           KEY01     KLIST
     C                     KFLD           W1PRT1
     C                     KFLD           W1PRT2
     C                     KFLD           W1PRT3
     C**
     C           KEY01     CHAINFCEPL01              81
     C           *IN81     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     MOVELA2STRT    W1FLC2
     C                     MOVELA2STRR    W1FLC3
     C           A2TRHZ    IFGT *DATE
     C           A2KTRT    ANDNE*BLANK
     C                     MOVELA2KTRT    W1FLC2
     C                     MOVELA2KTRR    W1FLC3
     C                     ENDIF
     C                     ENDIF
     C**
     C                     EXSR #SB820
     C                     EXSR #SB830
     C                     EXSR #SB840
     C                     EXSR #SB850
     C**
     C                     WRITEALRWP101
     C                     ENDIF
     C                     READ AAPPP01                  80
     C                     ENDDO
      *------------------                                              *********
     C* BLANK PASS THRU
      *------------------                                              *********
     C                     READ AANPP01                  80
     C           *IN80     DOWEQ'0'
     C           L7SKJY    IFEQ *BLANK
     C           L7STHZ    ANDGT*DATE
     C           L7BMON    ANDEQ8990
     C                     CLEARALRWP101
     C                     MOVEL'6'       W1TYPE
     C                     MOVELL7SHN1    W1PRT1
     C                     MOVELL7SHN2    W1PRT2
     C                     MOVELL7SHN3    W1PRT3
     C                     MOVELL7TKR2    W1LOC2
     C                     MOVELL7TKR3    W1LOC3
     C                     Z-ADDL7KMAX    W1KMAX
     C**                   Z-ADDL7KTSU    W1STPD
     C                     Z-ADDL7KSSU    W1STPD
     C                     Z-ADDL7SYOS    W1QPC
     C                     Z-ADDL7HKSU    W1LOT
     C           W1STPD    DIV  W1QPC     W1BXPD  72H
     C**
     C                     EXSR #SB820
     C                     EXSR #SB830
     C                     EXSR #SB840
     C                     EXSR #SB850
     C**
     C                     WRITEALRWP101
     C                     ENDIF
     C                     READ AANPP01                  80
     C                     ENDDO
      *------------------                                              *********
     C* WASHER
      *------------------                                              *********
     C                     READ AKBPP01                  80
     C           *IN80     DOWEQ'0'
     C           L1SKJY    IFEQ *BLANK
     C           L1STHZ    ANDGT*DATE
     C           L1BMON    ANDEQ8990
     C           L1SYOS    ANDNE0
     C                     CLEARALRWP101
     C                     MOVEL'3'       W1TYPE
     C                     MOVELL1SHN1    W1PRT1
     C                     MOVELL1SHN2    W1PRT2
     C                     MOVELL1SHN3    W1PRT3
     C                     MOVELL1TKR2    W1LOC2
     C                     MOVELL1TKR3    W1LOC3
     C**
     C                     MOVE *BLANK    BSTLR   2
     C                     Z-ADD0         WMAIS2  50
     C                     CALL 'ABCR161' BCALL
     C***                  Z-ADDL1KMAX    W1KMAX
     C                     Z-ADDWMAIS2    W1KMAX
     C**
     C****                 Z-ADDL1KTSU    W1STPD
     C                     Z-ADDL1KSSU    W1STPD
     C                     Z-ADDL1SYOS    W1QPC
     C                     Z-ADD1         W1LOT
     C           W1STPD    DIV  W1QPC     W1BXPD  72H
     C**
     C                     EXSR #SB820
     C                     EXSR #SB830
     C                     EXSR #SB840
     C                     EXSR #SB850
     C**
     C                     WRITEALRWP101
     C                     ENDIF
     C                     READ AKBPP01                  80
     C                     ENDDO
      *------------------                                              *********
     C                     MOVE 'LR'      ASTLR   2
     C                     CALL 'ABCR09'  ACALL
     C                     MOVE 'LR'      BSTLR   2
     C                     CALL 'ABCR161' BCALL
      *------------------                                              *********
     C                     SETON                     LR
     C                     RETRN
      ****************************************************
      *---------------------------*
      *ＬＴ                     *
      *---------------------------*
     CSR         #SB810    BEGSR
      *
     C           KEY2      KLIST
     C                     KFLD           L5BMON
     C                     KFLD           L5TAIP
      *
     C                     Z-ADD0         WLTM1   31
     C                     Z-ADD0         WLTM2   31
     C           KEY2      CHAINGCKPL211             30
     C           *IN30     IFEQ '0'
     C           T2SKJY    IFEQ 'D'
     C           T2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDT2LTM1    WLTM1
     C                     Z-ADDT2LTM2    WLTM2
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB810    ENDSR
      ****************************************************
      * SB820 GET PT PLAN
      ****************************************************
     CSR         #SB820    BEGSR
      *
     C           KEY02     KLIST
     C                     KFLD           W1PRT1  5
     C                     KFLD           W1PRT2  5
     C                     KFLD           W1PRT3  2
     C                     KFLD           K#KEYM  60
      *
     C                     Z-ADDWSYM6     K#KEYM
      *
     C           KEY02     SETLLBTAPL051
     C                     DO   *HIVAL
     C           KEY01     READEBTAPL051                 30
     C   30                LEAVE
      *
     C           BTSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           1         DO   31        AA      20
     C           #ZM,AA    IFEQ *BLANK
     C           #PH,AA    IFNE *ZERO
     C                     ADD  #PH,AA    W1BPLS
     C                     ENDIF
     C           #MH,AA    IFNE *ZERO
     C                     ADD  #MH,AA    W1BMIN
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     CSR         ESB820    ENDSR
      ****************************************************
      * SB830 GET PT ADJUST
      ****************************************************
     CSR         #SB830    BEGSR
      *
     C           KEY01     CHAINBTAPP411             30
     C           *IN30     IFEQ '0'
     C           B4SKJY    ANDEQ*BLANK
     C                     Z-SUBB4MAIS    W1ADJU
     C                     ENDIF
      *
     CSR         ESB830    ENDSR
      ****************************************************
      * SB840 GET PT ORDER STOP STATUS
      ****************************************************
     CSR         #SB840    BEGSR
      *
     C                     MOVE *BLANK    W1STDT
      *
     C           W1PRTA    SETGTGDKPL02
     C           W1PRTA    REDPEGDKPL02                  30
     C           *IN30     IFEQ *OFF
     C*
     C           ISSKJY    IFEQ *BLANK
     C           ISENHZ    IFNE 99999999
     C                     MOVE ISENHZ    W1STDT
     C                     ENDIF
     C                     ELSE
     C                     MOVE ISSKHZ    W1STDT
     C                     ENDIF
      *
     C                     ELSE
     C                     MOVEL'NO DATA' W1STDT
     C                     ENDIF
      *
     CSR         ESB840    ENDSR
      ****************************************************
      * SB850 GET  # OF BOXES WAIT TO BE ORDERED
      ****************************************************
     CSR         #SB850    BEGSR
      *
     C           KEY01     SETLLGDGPL07
     C                     DO   *HIVAL
     C           KEY01     READEGDGPL07                  30
     C   30                LEAVE
     C*
     C           IASKJY    IFEQ *BLANK
     C                     ADD  1         W1WOBX
     C                     ENDIF
      *
     C                     ENDDO
      *--------------
      *
     C                     SETOF                     30
     C           KEY01     SETLLGDGPL01
     C                     DO   *HIVAL
     C           KEY01     READEGDGPL01                  30
     C   30                LEAVE
     C*
     C           IASKJY    IFEQ *BLANK
     C                     ADD  1         W1WOBX
     C                     ENDIF
      *
     C                     ENDDO
      *
     CSR         ESB850    ENDSR
