     C           CLKEY     KLIST
     C                     KFLD           YYY
     C                     KFLD           MMM
     C                     KFLD           DDD
      *
     C           *ENTRY    PLIST
     C                     PARM           A04     4
     C                     PARM           PB0111  4
     C                     PARM           PI0111  2
     C                     PARM           PB9431  4
     C                     PARM           PI9431  2
     C                     PARM           C06     8
      *
     C                     MOVELA04       HHMM1
     C                     MOVE *BLANK    PB0111
     C                     MOVE *BLANK    PI0111
     C                     MOVE *BLANK    PB9431
     C                     MOVE *BLANK    PI9431
     C                     MOVE *BLANK    C06
      *
     C                     SETOF                     10
     C                     MOVE *BLANK    ZZFILE
     C                     MOVEL'AAIPP11' ZZFILE
     C           ZZFILE    CHAINAZZPPDF1             10
     C           *IN10     IFEQ '1'
     C                     MOVEL'AFAR11'  ZZPROG
     C                     Z-ADD0         ZZHORS
     C                     Z-ADD0         ZZMINS
     C                     Z-ADD0         ZZSECS
     C                     WRITEAZZPPDF1
     C           ZZFILE    CHAINAZZPPDF1             10
     C                     END
      *
     C           *LOVAL    SETLLAAIPL111
     C                     SETOF                     10
     C                     READ AAIPL111                 10
     C           *IN10     IFEQ '1'
     C                     Z-ADD0         CDSTHZ
     C                     Z-ADD0         CDZNHZ
     C                     Z-ADD0         CDTOHZ
     C                     Z-ADD0         CDYOHZ
     C                     END
      *
     C*  PARM (1) fﾞ 2400 ﾉ ng
     C*      OR <*DATE *EQ zg] fbﾆﾍﾞ> ﾉ ngﾌ  PARM(1) fﾞ 2000 ﾉ ng
      *
     C           CDSTHZ    IFNE *DATE
     C           HHMM1     ANDEQ2400
     C           CDSTHZ    OREQ *DATE
     C           HHMM1     ANDEQ2000
      *
     C                     MOVE *BLANK    C06
     C                     Z-ADDCDYOHZ    YMD
     C                     TIME           HHMMSS
     C           CLKEY     SETGTAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     13
     C                     READ AGDPL121                 13
     C           *IN13     IFEQ '0'
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    OREQ *BLANK
     C                     SETON                     13
     C                     Z-ADDCLYMD     YMD              ﾑhﾆﾞlﾉ ﾍlﾞi
     C                     END
     C                     END
     C  N13                END
      *
     C*  ﾑhﾆﾞl --> ncﾆﾞl
      *
     C           *LOVAL    SETLLAAIPL111
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AAIPL111                 10
     C           *IN10     IFEQ '0'
     C                     Z-ADDCDTOYY    CDZNYY
     C                     Z-ADDCDTOMM    CDZNMM
     C                     Z-ADDCDTODD    CDZNDD
     C                     Z-ADDCDYOYY    CDTOYY
     C                     Z-ADDCDYOMM    CDTOMM
     C                     Z-ADDCDYODD    CDTODD
     C                     Z-ADDYYY       CDYOYY
     C                     Z-ADDMMM       CDYOMM
     C                     Z-ADDDDD       CDYODD
     C                     Z-ADDCDBN      CDBI
     C                     MOVELCDDN      CDDT
     C                     MOVELCDON      CDOK
     C                     MOVE *BLANK    CDDN
     C                     MOVE *BLANK    CDON
     C                     UPDATAAIPL111
     C                     END
     C  N10                END
      *
     C                     END
      *
     C*  ﾎﾞy] & ﾌｮcﾍﾞ] ﾉ ﾈｮn
      *
     C           *LOVAL    SETLLAAIPL111
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AAIPL111                 10
     C           *IN10     IFEQ '0'
     C           CDBI,HH1  IFNE 0
      *
     C           CDBMON    IFEQ 0111
     C                     MOVE CDBMON    PB0111
     C                     MOVE CDBI,HH1  PI0111
     C                     END
      *
     C           CDBMON    IFEQ 9431
     C                     MOVE CDBMON    PB9431
     C                     MOVE CDBI,HH1  PI9431
     C                     END
      *
     C                     END
     C                     END
     C  N10                END
      *
     C                     MOVELCDTOHZ    C06
      *
     C                     MOVEL'AFAR11'  ZZPROG
     C                     TIME           TIME
     C                     Z-ADDTIMEA     ZZHORS
     C                     Z-ADDTIMEB     ZZMINS
     C                     Z-ADDTIMEC     ZZSECS
     C                     UPDATAZZPPDF1
      *
     C           PB0111    IFEQ *BLANK
     C           PB9431    ANDEQ*BLANK
     C                     SETON                     U2U3U4
     C                     SETON                     U5
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
