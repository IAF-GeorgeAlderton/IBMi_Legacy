     C** MOVE                            **
     C*************************************
     C           MADOKA    BEGSR
     C                     MOVE @KOSN     KOSN
     C                     MOVE '-'       BOU
     C                     MOVE @RGCD     MRGCD
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @RGCD
     C                     SETOF                     99
     C                     ENDSR
