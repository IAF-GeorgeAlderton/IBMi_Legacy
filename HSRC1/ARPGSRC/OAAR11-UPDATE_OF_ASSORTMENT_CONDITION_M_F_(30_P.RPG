     C** WRITE&UPDAT                     **
     C*************************************
     C                     Z-ADD0         H       20
     C                     Z-ADD1         YUI     30
     C           KEY       KLIST
     C                     KFLD           @RGCD
     C                     KFLD           YUI
     C           1         DO   30
     C                     ADD  1         H
     C           KEY       CHAINOAAPL111             95
     C                     MOVE *BLANK    R3SKJY
     C                     Z-ADD0         R3SKHZ
     C                     Z-ADD*DATE     R3KOHZ
     C                     TIME           WTIME
     C*                    MOVELUS        R3KOME
     C                     MOVE @RGCD     R3RGCD
     C                     Z-ADDPKNO,H    R3PKET
     C                     MOVEASIYO,H    R3SKBN
     C           @KOSN     IFEQ '0'
     C                     MOVEL'D'       R3SKJY
     C                     Z-ADD*DATE     R3SKHZ
     C                     END
     C           *IN,95    IFEQ '0'
     C                     UPDATOAAPL111
     C                     ELSE
     C                     WRITEOAAPL111
     C                     END
     C                     ADD  1         YUI
     C                     END
     C                     EXSR MADOKA
     C                     GOTO @DISP1
