     C* s]ﾃc&nﾒiﾆﾉng
     C           @KOSN     IFNE '2'
     C           @RGCD     SETLLOAAPL111
     C                     Z-ADD0         X       20
     C                     DO   *HIVAL
     C           @RGCD     READEOAAPL111                 91
     C           *IN91     IFEQ '0'
     C           R3SKJY    IFEQ 'D'
     C           R3SKHZ    ANDLE*DATE
     C                     GOTO @EXIT
     C                     END
     C                     ADD  1         X
     C                     MOVE R3SKBN    SIYO,X
     C           X         COMP 30                   91
     C                     END
     C           @EXIT     TAG
     C  N91                END
     C                     END
     C                     MOVEA*BLANK    YOTO
     C                     DO   30        X
     C           SIYO,X    IFNE *BLANK
     C           SIYO,X    CHAINOAAPL311             92
