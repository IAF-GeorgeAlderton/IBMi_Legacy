     C           SIYO,B    IFEQ '01'
     C           SIYO,B    OREQ '99'
     C                     GOTO @CHK
     C                     END
     C           30        SUB  B         BB
     C           B         ADD  1         @B      20
     C           @B        DO   30
     C           SIYO,B    IFEQ SIYO,@B
     C                     SETON                     99
     C           LUM       ADD  @B        D       20
     C                     MOVE '1'       *IN,D
     C                     MOVE ER,10     @ERR2
     C                     GOTO @DISP2
     C                     END
     C                     ADD  1         @B
     C                     ENDDO
