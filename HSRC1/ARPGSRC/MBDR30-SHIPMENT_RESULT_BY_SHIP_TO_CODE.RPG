     H            Y/
     F***************************************************
     F*  SHIP RESULT BY SHIP TO CODE                    *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FMBDPW30 CF  E                    WORKSTN
     FAAMPL11 IF  E           K        DISK
     FMBDPL01 IF  E           K        DISK
     FMBDTL03 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FMBDWP30 O   E                    DISK
      *------------------------------------------------------------
     E                    DY          6  2 0
     E                    QY          6  9 0
     E                    BX          6  7 2
      *------------------------------------------------------------
     I            DS
     I                                        1  54 QY
     I                                        1   90MWQTY1
     I                                       10  180MWQTY2
     I                                       19  270MWQTY3
     I                                       28  360MWQTY4
     I                                       37  450MWQTY5
     I                                       46  540MWQTY6
     I            DS
     I                                        1  42 BX
     I                                        1   72MWBOX1
     I                                        8  142MWBOX2
     I                                       15  212MWBOX3
     I                                       22  282MWBOX4
     I                                       29  352MWBOX5
     I                                       36  422MWBOX6
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@ID    1
     C           K#AGD     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C           K#MBD1    KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     KFLD           K@NONY  40
     C           K#MBD3    KLIST
     C                     KFLD           K@NONY
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C           K#AAM     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
      *
     C                     MOVEL'01'      W@ID    2
     C                     MOVE *BLANK    P@ID
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #DAT
     C                     EXSR #WRT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     MOVE D@NONY    @@NONY  40
     C                     MOVE D@NONY    K@NONY  40
     C           K@NONY    CHAINMBDTL03              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DATE
      *------------------------------------------------------
     C           #DAT      BEGSR
      *
     C                     Z-ADD*ZERO     DY
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C           1         DO   6         X       20
     C                     SUB  1         K@MM
     C           K@MM      IFEQ *ZERO
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
     C                     ENDIF
      *
     C           K#AGD     SETLLAGDPL12
     C           *IN80     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  80
     C           *IN80     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         DY,X
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE RECORD
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C           @@NONY    SETLLMBDTL03
     C           *IN80     DOUEQ*ON
     C           @@NONY    READEMBDTL03                  80
     C           *IN80     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
      *
     C                     MOVE F3MHN1    K@MHN1
     C                     MOVE F3MHN2    K@MHN2
     C                     MOVE F3MHN3    K@MHN3
     C                     MOVE F3SHN1    K@SHN1
     C                     MOVE F3SHN2    K@SHN2
     C                     MOVE F3SHN3    K@SHN3
     C                     CLEARMBDWP301
     C                     MOVE F3SHN1    MWPRT1
     C                     MOVE F3SHN2    MWPRT2
     C                     MOVE F3SHN3    MWPRT3
     C           K#AAM     CHAINAAMPL11              90
     C           K#AAM     CHAINFCEPL01              90
      *
     C                     EXSR #QTY
     C           K#MBD3    SETGTMBDTL03
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   QTY
      *------------------------------------------------------
     C           #QTY      BEGSR
      *
     C                     MOVE *OFF      *IN85
     C                     Z-ADD*ZERO     W@NONY  40
     C           K#AAM     SETLLMBDPL01
     C           *IN81     DOUEQ*ON
     C           K#AAM     READEMBDPL01                  81
     C           *IN81     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
      *
     C           W@NONY    IFNE *ZERO
     C           W@NONY    ANDNEF3NONY
     C                     EXSR #OUT
     C                     ENDIF
      *
     C                     Z-ADDF3NONY    W@NONY
     C                     ADD  F3TNSU    MWQTY1
     C                     ADD  F3ANSU    MWQTY2
     C                     ADD  F3BNSU    MWQTY3
     C                     ADD  F3CNSU    MWQTY4
     C                     ADD  F3DNSU    MWQTY5
     C                     ADD  F3ENSU    MWQTY6
     C                     ENDIF
     C                     ENDDO
      *
     C           W@NONY    IFNE *ZERO
     C                     EXSR #OUT
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #OUT      BEGSR
      *------------------------------------------------------
     C                     MOVE W@NONY    MWNONY
     C           1         DO   6         X
     C           QY,X      DIV  DY,X      @@QTY   90
     C           @@QTY     DIV  A2SSYS    BX,X
     C                     ENDDO
     C                     WRITEMBDWP301
     C                     CLEARMBDWP301
      *
     C                     MOVE '1'       P@ID
      *
     C                     ENDSR
