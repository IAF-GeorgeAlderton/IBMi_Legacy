     H            Y.
      ** UEXR45D ***************************************************
      *  GET TOYOTA ACTUAL SHIP DATE BY PP10                       *
      *  JW     2022.01.06                                         *
      **************************************************************
      *  CALLING SEQ.                                              *
      *                    CALL 'UEXR45D'
      *                    PARM           $NONY   4
      *                    PARM           $NUKE   4
      *                    PARM           $NOHZ   8
      *                    PARM           $MAN#  12
      *                    PARM           $SHPDT  8
      *   IN  $NONY   4A  DELIVERY#                                *
      *   "   $NUKE   4A  DOCK CODE                                *
      *   "   $NOHZ   8A  SHIP DATE                                *
      *   "   $MAN#  12A  MANIFEST# (PP10:BAINVN)                  *
      *   OUT $SHPDT  8A  ACTUAL SHIP DATE                         *
      **************************************************************
     FAB#PL65BIF  E           K        DISK
      ***********************************************************
     I            DS
     I                                        1   8 A6DEHZ
     I                                        1   40A6DEYY
     I                                        5   60A6DEMM
     I                                        7   80A6DEDD
     I            DS
     I                                        1   8 @NOHZ
     I                                        1   40@NOYY
     I                                        5   60@NOMM
     I                                        7   80@NODD
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      *
      * READ AB#PL65B
JW1  C           K#PL65    SETLLAB#PL65B
 .   C                     DO   *HIVAL
JW1  C           K#PL65    READEAB#PL65B                 98
     C   98                LEAVE
      *
     C           A6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA6DEHZ    $SHPDT
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4        IN
     C                     PARM           $NUKE   4        "
     C                     PARM           $NOHZ   8        "
     C                     PARM           $MAN#  12        "
     C                     PARM           $SHPDT  8        OUT
      *
     C           K#PL65    KLIST
     C                     KFLD           KYNONY  4
     C                     KFLD           KYNOYY  40
     C                     KFLD           KYNOMM  20
     C                     KFLD           KYNODD  20
     C                     KFLD           KYNUKE  4
     C                     KFLD           KYORNO 12
      *
     C                     MOVEL'00000000'$SHPDT
     C                     MOVEL$NONY     KYNONY
     C                     MOVEL$NOHZ     @NOHZ
     C                     MOVEL@NOYY     KYNOYY
     C                     MOVEL@NOMM     KYNOMM
     C                     MOVEL@NODD     KYNODD
     C                     MOVEL$NUKE     KYNUKE
     C                     MOVEL$MAN#     KYORNO
      *
     C                     ENDSR
