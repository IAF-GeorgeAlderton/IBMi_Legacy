     H            Y.
     F** VVVR94A **********************************************************
     F*  UPDATE XXCATG IN VVVPP50A                                        *
     F*  J.WATANABE   2026.01.16                                          *
     F*********************************************************************
     FVVVPP50AUF  E           K        DISK
      *****************************************************
     I            DS
     I                                        1  10 WKFILE
     I                                        2   5 @CAT
      *****************************************************
      *
     C                     DO   *HIVAL
     C                     READ VVVPP50A                 98
     C   98                LEAVE
      *
     C                     EXSR #EDIT
     C                     UPDATQWHFDML
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************
     C* EDIT
     C*****************************************************
     C           #EDIT     BEGSR
     C                     MOVELMLFILE    WKFILE
      *
     C                     SELEC
     C           @CAT      WHEQ 'RPGS'
     C                     MOVEL'RPG  '   XXCATG
     C           @CAT      WHEQ 'CLSR'
     C                     MOVEL'CLP  '   XXCATG
     C           @CAT      WHEQ 'DSPS'
     C                     MOVEL'DSPF '   XXCATG
     C           @CAT      WHEQ 'CMDS'
     C                     MOVEL'CMD  '   XXCATG
     C           @CAT      WHEQ 'DDSS'
     C                     MOVEL'DDS  '   XXCATG
     C           @CAT      WHEQ 'PRTS'
     C                     MOVEL'PRTF '   XXCATG
     C           @CAT      WHEQ 'RPGL'
     C                     MOVEL'RPGL '   XXCATG
     C           @CAT      WHEQ '#CLS'
     C                     MOVEL'CLP  '   XXCATG
     C           @CAT      WHEQ '#DDS'
     C                     MOVEL'DDS  '   XXCATG
     C           @CAT      WHEQ '#DSP'
     C                     MOVEL'DSPF '   XXCATG
     C           @CAT      WHEQ '#PRT'
     C                     MOVEL'PRTF '   XXCATG
     C           @CAT      WHEQ '#RPG'
     C                     MOVEL'RPG  '   XXCATG
     C                     ENDSL
      *
     C                     ENDSR
