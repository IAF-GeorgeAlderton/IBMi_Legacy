     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ALDWP6E                  98
     C   98                LEAVE
      * FIRST
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELAWLOC     SVLOC   5
     C                     MOVELAWNUKE    SVNUKE  4
     C                     MOVELAWPALT    SVPALT  2
     C                     ENDIF
      * BREAK
     C           AWLOC     IFNE SVLOC
     C                     EXSR #BRK2
     C                     EXSR #BRK1
     C                     ELSE
     C           AWNUKE    IFNE SVNUKE
     C           AWPALT    ORNE SVPALT
     C                     EXSR #BRK2
     C                     ENDIF
     C                     ENDIF
      * DETAIL PROCESS
     C                     ADD  1         W@TTLN
     C                     ADD  1         W@TTLP
     C                     ADD  1         W@TTL
     C                     EXSR #SVDTL
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK2
     C                     EXSR #BRK1
     C                     ENDIF
      * GRAND TOTAL
     C                     EXSR #HED
     C                     EXCPT@TTL
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C* BREAK 1 TOTAL
     C**************************************************************************
     C           #BRK1     BEGSR
      * PRINT PART TOTAL
     C                     EXSR #HED
     C                     EXCPT@TTLP
     C                     ADD  1         PLINE
     C                     ADD  1         W@PCNT
      * PREPARE CHANGE PAGE
     C           PLINE     IFGE 60
     C                     Z-ADD80        PLINE
     C                     ENDIF
      * RESET
     C                     Z-ADD0         W@TTLP
     C                     Z-ADD0         B2CNT
      *
     C                     MOVELAWLOC     SVLOC
      *
     C                     ENDSR
     C**************************************************************************
     C* BREAK 2 SUB
     C**************************************************************************
     C           #BRK2     BEGSR
      *
     C                     ADD  1         B2CNT   20
      *
     C           B2CNT     IFEQ 1
     C                     EXSR #ADJ
     C                     MOVELS1SRT     P@SRT   7
     C                     EXSR #HED
     C                     EXCPT@DTL
     C                     EXSR #BOX
     C                     EXCPT@DTL2
     C                     ADD  3         PLINE
     C                     ELSE
     C                     EXSR #HED
     C                     EXCPT@DTL3
     C                     ADD  1         PLINE
     C                     ENDIF
      *
     C                     Z-ADD0         W@TTLN
     C                     MOVELAWNUKE    SVNUKE
     C                     MOVELAWPALT    SVPALT
      *
     C                     ENDSR
     C**************************************************************************
     C* CALCULATE BOX
     C**************************************************************************
     C           #BOX      BEGSR
      *
     C                     Z-ADD0         P#SRT   30
     C                     Z-ADD0         P@BOX1  30
     C                     Z-ADD0         P@BOX2  30
     C                     Z-ADD0         P@BOX3  30
     C                     Z-ADD0         P@BOX4  30
      *
     C                     MOVELP@PRO1    W@PRO   3
     C                     Z-ADD0         P@BOX   30
     C                     Z-ADD0         P@SRTB 110
     C                     EXSR #SB445
     C                     Z-ADDP@BOX     P@BOX1
     C           P#SRT     IFEQ 0
     C                     Z-ADDP@SRTB    P#SRT
     C                     ENDIF
      *
     C                     MOVELP@PRO2    W@PRO
     C                     Z-ADD0         P@BOX
     C                     Z-ADD0         P@SRTB
     C                     EXSR #SB445
     C                     Z-ADDP@BOX     P@BOX2
     C           P#SRT     IFEQ 0
     C                     Z-ADDP@SRTB    P#SRT
     C                     ENDIF
      *
     C                     MOVELP@PRO3    W@PRO
     C                     Z-ADD0         P@BOX
     C                     Z-ADD0         P@SRTB
     C                     EXSR #SB445
     C                     Z-ADDP@BOX     P@BOX3
     C           P#SRT     IFEQ 0
     C                     Z-ADDP@SRTB    P#SRT
     C                     ENDIF
      *
     C                     MOVELP@PRO4    W@PRO
     C                     Z-ADD0         P@BOX
     C                     Z-ADD0         P@SRTB
     C                     EXSR #SB445
     C                     Z-ADDP@BOX     P@BOX4
     C           P#SRT     IFEQ 0
     C                     Z-ADDP@SRTB    P#SRT
     C                     ENDIF
      *
     C           P@PRO1    IFEQ 'TSL'
     C                     Z-ADDP#SRT     P@BOX1
     C                     ENDIF
      *
     C           P@PRO2    IFEQ 'TSL'
     C                     Z-ADDP#SRT     P@BOX2
     C                     ENDIF
      *
     C           P@PRO3    IFEQ 'TSL'
     C                     Z-ADDP#SRT     P@BOX3
     C                     ENDIF
      *
     C           P@PRO4    IFEQ 'TSL'
     C                     Z-ADDP#SRT     P@BOX4
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************
      *
      **************************************************
     C           #SB445    BEGSR
      *
     C                     MOVELS1SHIN    WKSHIN
      *
     C                     SELEC
     C           W@PRO     WHEQ 'BZ '
     C                     Z-ADD0         P@BOXS
     C                     CALL 'AJSRS2'                   INPROCESS
     C                     PARM           WKSHN1  5
     C                     PARM           WKSHN2  5
     C                     PARM           WKSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
     C                     CALL 'ALOR19'                   PRELOAD
     C                     PARM           WKSHN1  5
     C                     PARM           WKSHN2  5
     C                     PARM           WKSHN3  2
     C                     PARM           P@PRE  110
     C                     PARM           P@SRTB 110
     C                     ADD  P@PRE     P@BOX
     C           W@PRO     WHEQ 'DS '
     C           W@PRO     OREQ 'DSM'
     C                     Z-ADD0         P@BOXS
     C                     CALL 'AJSRS3'                   INPROCESS
     C                     PARM           WKSHN1  5
     C                     PARM           WKSHN2  5
     C                     PARM           WKSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
     C                     CALL 'ALOR19'                   PRELOAD
     C                     PARM           WKSHN1  5
     C                     PARM           WKSHN2  5
     C                     PARM           WKSHN3  2
     C                     PARM           P@PRE  110
     C                     PARM           P@SRTB 110
     C                     ADD  P@PRE     P@BOX
     C           W@PRO     WHEQ 'OQ '
     C                     Z-ADD0         P@BOXS
     C                     CALL 'ALGRS1'                   INPROCESS
     C                     PARM           WKSHN1  5
     C                     PARM           WKSHN2  5
     C                     PARM           WKSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
     C           W@PRO     WHEQ 'LOQ'
     C                     Z-ADD0         P@BOXS
     C                     CALL 'ALHRS1'                   INPROCESS
     C                     PARM           WKSHN1  5
     C                     PARM           WKSHN2  5
     C                     PARM           WKSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C* PRINT
     C**************************************************************************
     C           #HED      BEGSR
      *
     C           PLINE     IFGE 64
     C                     EXCPT@HED
     C                     Z-ADD5         PLINE
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************
      * GET BOX
      **************************************************
     C           #GETBX    BEGSR
      *
      *
     C                     ENDSR
      **************************************************
      *  GET BOX2
      **************************************************
     C           #GETB2    BEGSR
      *
      *
     C                     ENDSR
     C**************************************************************************
     C* SAVE DETAIL DATA
     C**************************************************************************
     C           #SVDTL    BEGSR
      *
     C                     MOVELAWDDAT    S1DDAT  80
     C                     MOVELAWSHFT    S1SHFT  1
     C                     MOVELAWUSRC    S1USRC 10
     C                     MOVELAWUSRN    S1USRN 20
      *
     C                     MOVELAWLOC     S1LOC   5
     C                     MOVELAWSHIN    S1SHIN 14
     C                     MOVELAWPROC    S1PROC  3
     C                     MOVELAWSMEI    S1SMEI 30
     C                     MOVELAWNBRS    S1NBRS  30
      *
     C                     MOVELAWNONY    S1NONY  40
     C                     MOVELAWNONM    S1NONM 15
     C                     MOVELAWNUKE    S1NUKE  4
     C                     MOVELAWPALT    S1PALT  2
      *
     C                     MOVELAWNODT    S1NODT 10
     C                     MOVELAWNOBN    S1NOBN  2
     C                     MOVELAWDETM    S1DETM  5
      *
     C                     MOVELAWLOCX    S1LOCX  5
     C                     MOVELAWSRT     S1SRT  10
      *
     C                     MOVELAWMC01    S1MC01  3
     C                     MOVELAWMC02    S1MC02  3
     C                     MOVELAWMC03    S1MC03  3
     C                     MOVELAWMC04    S1MC04  3
     C                     MOVELAWMC05    S1MC05  3
     C                     MOVELAWMC06    S1MC06  3
     C                     MOVELAWMC07    S1MC07  3
     C                     MOVELAWMC08    S1MC08  3
     C                     MOVELAWMC09    S1MC09  3
     C                     MOVELAWMC10    S1MC10  3
     C                     MOVELAWMC11    S1MC11  3
     C                     MOVELAWMC12    S1MC12  3
     C                     MOVELAWMC13    S1MC13  3
     C                     MOVELAWMC14    S1MC14  3
     C                     MOVELAWMC15    S1MC15  3
      *
     C                     MOVELAWPR01    S1PR01  3
     C                     MOVELAWPR02    S1PR02  3
     C                     MOVELAWPR03    S1PR03  3
     C                     MOVELAWPR04    S1PR04  3
     C                     MOVELAWPR05    S1PR05  3
     C                     MOVELAWPR06    S1PR06  3
     C                     MOVELAWPR07    S1PR07  3
     C                     MOVELAWPR08    S1PR08  3
     C                     MOVELAWPR09    S1PR09  3
     C                     MOVELAWPR10    S1PR10  3
     C                     MOVELAWPR11    S1PR11  3
     C                     MOVELAWPR12    S1PR12  3
     C                     MOVELAWPR13    S1PR13  3
     C                     MOVELAWPR14    S1PR14  3
     C                     MOVELAWPR15    S1PR15  3
      *
     C                     ENDSR
     C**************************************************************************
     C* ADJUST
     C**************************************************************************
     C           #ADJ      BEGSR
      * GET PROCESS
     C                     MOVE *BLANK    P@PRO1  3
     C                     MOVE *BLANK    P@PRO2  3
     C                     MOVE *BLANK    P@PRO3  3
     C                     MOVE *BLANK    P@PRO4  3
     C                     Z-ADD0         IM      20
     C           1         DO   15        IX      20
     C           PRC,IX    IFNE *BLANK
     C           P@PRO1    ANDEQ*BLANK
     C                     MOVELPRC,IX    P@PRO1
     C                     Z-ADDIX        IM
     C                     ITER
     C                     ENDIF
     C           PRC,IX    IFNE *BLANK
     C           P@PRO2    ANDEQ*BLANK
     C                     MOVELPRC,IX    P@PRO2
     C                     ITER
     C                     ENDIF
     C           PRC,IX    IFNE *BLANK
     C           P@PRO3    ANDEQ*BLANK
     C                     MOVELPRC,IX    P@PRO3
     C                     ITER
     C                     ENDIF
     C           PRC,IX    IFNE *BLANK
     C           P@PRO4    ANDEQ*BLANK
     C                     MOVELPRC,IX    P@PRO4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * GET MACHINE
     C                     MOVE *BLANK    P@MCN1  3
     C                     MOVE *BLANK    P@MCN2  3
     C                     MOVE *BLANK    P@MCN3  3
     C                     MOVE *BLANK    P@MCN4  3
     C                     Z-ADD0         IY      20
     C           IM        DO   15        IX      20
     C                     ADD  1         IY
     C           IY        IFGE 5
     C                     LEAVE
     C                     ENDIF
      *
     C                     SELEC
     C           IY        WHEQ 1
     C                     MOVELMCN,IX    P@MCN1
     C                     ITER
     C           IY        WHEQ 2
     C                     MOVELMCN,IX    P@MCN2
     C                     ITER
     C           IY        WHEQ 3
     C                     MOVELMCN,IX    P@MCN3
     C                     ITER
     C           IY        WHEQ 4
     C                     MOVELMCN,IX    P@MCN4
     C                     ITER
     C                     ENDSL
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C* INITIAL SETTING
     C**************************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P$DATE  8
     C                     PARM           P$SFT   1
      *
     C                     MOVELP$DATE    P#DATE  80
     C                     TIME           WSDT
     C                     Z-ADD80        PLINE   30
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         W@PCNT  50
     C                     Z-ADD0         W@TTL   50
     C                     Z-ADD0         W@TTLP  50
     C                     Z-ADD0         W@TTLN  50
      *
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                                   35 '<< SHIPPING # OF SHO'
     O                                   55 'RTAGE SCAN RESULT LI'
     O                                   75 'ST >>  (BY LOCATION)'
     O                                   95 ')                   '
     O                                   97 'DATE'
     O                         TODAY Y  108
     O                                  114 'PAGE'
     O                         PAGE  Z  118
     O        E   02           @HED
     O                                   97 'TIME'
     O                         NOW      108 '0 :  :  '
     O        E   03           @HED
     O                                   15 'SCANNED DATE AT'
     O                         P#DATEY   26
     O                                   36 'SHIFT#:'
     O                         P$SFT     38
     O                         S1USRN    63
     O        E   05           @HED
     O                                    5 'F-LOC'
     O                                   11 'P-LOC'
     O                                   18 'PART#'
     O                                   32 'SRT '
     O                                   40 'PROC'
     O                                   49 '/MACHINE'
     O                                   76 '#OF SHORT'
     O                                   86 'DELIVERY'
     O                                  104 'DOCK'
     O                                  109 'PALT'
     O                                  120 'SHIP DATE'
     O                                  125 'BIN'
     O                                  130 'TIME'
     O        E 1              @DTL
     O                         S1LOC      5
     O                         S1LOCX    11
     O                         S1SHIN    27
     O                         P@SRT     35
     O                         P@PRO1    39
     O                         P@PRO2    43
     O                         P@PRO3    47
     O                         P@PRO4    51
     O                         W@TTLN1   73
     O                         S1NONY    81
     O                         S1NONM    98
     O                         S1NUKE   104
     O                         S1PALT   108
     O                         S1NODT   121
     O                         S1NOBN   124
     O                         S1DETM   131
      *
     O        E 1              @DTL2
     O                         P@MCN1    39
     O                         P@MCN2    43
     O                         P@MCN3    47
     O                         P@MCN4    51
      *
     O        E 1              @DTL2
     O                         P#SRT     33 ' 0 '
     O                         P@BOX1    39 ' 0 '
     O                         P@BOX2    43 ' 0 '
     O                         P@BOX3    47 ' 0 '
     O                         P@BOX4    51 ' 0 '
      *
     O        E 1              @DTL3
     O                         W@TTLN1   73
     O                         S1NONY    81
