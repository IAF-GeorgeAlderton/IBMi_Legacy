     C**********************************************************
     C**初期化　　　　　　　                                 *
     C**********************************************************
     C                     MOVEL*BLANK    ZHK
     C                     MOVEL*BLANK    XHK
     C                     MOVEL*BLANK    ROT
     C                     MOVEL*BLANK    SET
     C                     MOVEL*BLANK    MAI
     C**********************************************************
     C**ＫＥＹ　　　　　　　                                 *
     C**********************************************************
     C*品番
     C           KEY1      KLIST
     C                     KFLD           IHIN1            品番１
     C                     KFLD           IHIN2            品番２
     C                     KFLD           IHIN3            品番３
     C**********************************************************
     C**項目の印字                                           *
     C**********************************************************
     C           *IN10     IFEQ '0'
     C                     EXCPTHD
     C                     SETON                     10
     C                     ENDIF
     C**********************************************************
     C**各種かんばんマスター読取　ーーー＞　ＣＳＶ出力　　   *
     C**********************************************************
     C*
     C**部品マスターからの読出し（首下・Ｓ単重・Ｋ単重など）
     C                     SETOF                     2223
     C*
     C           KEY1      CHAINFCEPL011             22    ﾎﾞﾍ]UﾇJｰ
     C           *IN22     IFEQ '0'
     C           A2GSKD    IFEQ 'D'                        ﾅHﾆﾞﾑ U-H
TCHK1C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     23
     C                     ENDIF
     C                     ENDIF
      *整数部／小数部
     C           *IN23     IFEQ '1'
     C*
     C                     MOVELA2SOZI    STAN1   5
     C                     MOVE A2SOZI    STAN2   2
     C                     MOVELA2KASI    KTAN1   5
     C                     MOVE A2KASI    KTAN2   2
     C                     MOVELA2KAZI    KZKEI1  3
     C                     MOVE A2KAZI    KZKEI2  2
     C*Ｓ単重
     C                     SETOF                     25
     C           A2SOZI    IFEQ *ZERO
     C                     SETON                     25
     C                     MOVEL'0'       STAN2
     C                     ENDIF
     C*Ｋ単重
     C                     SETOF                     26
     C           A2KASI    IFEQ *ZERO
     C                     SETON                     26
     C                     MOVEL'0'       KTAN2
     C                     ENDIF
     C*Ｋ材径
     C                     SETOF                     27
     C           A2KAZI    IFEQ *ZERO
     C                     SETON                     27
     C                     MOVEL'0'       KZKEI2
     C                     ENDIF
     C*データ移行
     C                     MOVELDHIN      DAIHIN 12        ﾍ]ﾌﾞ]
     C                     MOVELA2KUBI    KUBI    3        HﾍﾞﾆJ
     C                     MOVELA2TUSZ    NEJIS   2        RﾆﾞﾅBﾇﾞ
     C                     MOVELA2KIKI    KYOUD   2        GｭCNﾞ
     C                     MOVELA2ZANM    ZAIR   15        ﾅﾞBﾒｭCXB
     C                     MOVELA21HIN    KHIN1  12        ﾃCﾈBﾍ]ﾌﾞ]1
     C                     MOVELA22HIN    KHIN2  12        ﾃCﾈBﾍ]ﾌﾞ]2
     C                     MOVELA23HIN    KHIN3  12        ﾃCﾈBﾍ]ﾌﾞ]3
     C                     MOVELA24HIN    KHIN4  12        ﾃCﾈBﾍ]ﾌﾞ]4
TCHK1C                     MOVE A2SSYS    SYUU    5        ﾆｬCﾑCﾇC
     C                     MOVELA2SSYT    HKSYU   1        ﾌﾃﾆｬ
     C*
     C                     ENDIF
     C*
     C**月間設定数（２０日）の計算
     C                     SETOF                     28
     C*
     C           KEY1      CHAINFCEPL111             28
     C           *IN28     IFEQ '0'
     C           FCSKJY    ANDEQ'D'
TCHK1C           FCSKHZ    ANDLE*DATE
     C                     SETON                     28
     C                     ENDIF
     C*
     C           *IN28     IFEQ '0'
     C           FCCD01    IFNE 0
     C           FCGK01    DIV  FCCD01    HYOU    90
     C                     MVR            HYOU1   90
     C*
     C           HYOU1     IFNE 0
     C                     ADD  1         HYOU
     C                     ENDIF
     C*
     C           HYOU      IFEQ 0
     C                     Z-ADD1         HYOU
     C                     ENDIF
     C*
     C           HYOU      MULT 20        GHYOU   90
     C                     ENDIF
     C                     ENDIF
     C*
     C**各工程内品番・工程・機番・部門・番地・親の引当(AAMPL11)
     C                     Z-ADD1         I       20
     C*
     C                     SETOF                     2021
     C           KEY1      CHAINAAMPL111             20    F]ﾌﾞ]GﾒFDM
     C           *IN20     IFEQ '0'
     C           CKSKJY    IFEQ 'D'                        ﾅHﾆﾞﾑ U-H
TCHK1C           CKSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     21
     C                     ENDIF
     C                     ENDIF
      *
      *各項目
     C           *IN21     IFEQ '1'
     C           1         DO   15        I
     C                     MOVELKHN,I     OHN,I
     C                     MOVELKOT,I     OKT,I
     C                     MOVELKBN,I     OKB,I
     C                     MOVELBMN,I     OBM,I
     C                     MOVELBAN,I     OBN,I
      *
     C           BMN,I     IFEQ *ZERO
     C                     MOVEL*BLANK    OBM,I
     C                     ENDIF
      *
     C                     EXSR $CSV
      *
      *代表品番項目（＊）セット
     C                     MOVEL' '       OOY,I
     C           KHN,I     IFEQ DHIN
     C                     MOVEL'*'       OOY,I
     C                     ENDIF
      *
     C                     ENDDO
      *
     C**番地が'------'の時のロット数・セット数・箱／日・枚数
     C**収容数の再セット
     C                     Z-ADD1         XX      20
      *
     C           1         DO   14        XX
     C                     Z-ADD1         AA      20
     C           1         DO   15        AA
     C           AA        ADD  1         BB      20
     C           OBN,AA    IFEQ '------'
     C           MAI,BB    IFNE '0'
     C                     MOVELROT,BB    ROT,AA
     C                     MOVELSET,BB    SET,AA
     C                     MOVELMAI,BB    MAI,AA
     C                     MOVELZHK,BB    ZHK,AA
     C                     MOVELXHK,BB    XHK,AA
     C                     MOVELSYU,BB    SYU,AA
      *
     C           SYU,AA    IFEQ *BLANK
     C                     MOVEL'0'       SYU,AA
     C                     ENDIF
     C           ROT,AA    IFEQ *BLANK
     C                     MOVEL'0'       ROT,AA
     C                     ENDIF
     C           SET,AA    IFEQ *BLANK
     C                     MOVEL'0'       SET,AA
     C                     ENDIF
     C           MAI,AA    IFEQ *BLANK
     C                     MOVEL'0'       MAI,AA
     C                     ENDIF
      *
     C           ZHK,AA    IFEQ *BLANK
     C           XHK,AA    ANDEQ*BLANK
     C                     MOVEL*BLANK    TEN,AA
     C                     ELSE
     C                     MOVEL'.'       TEN,AA
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDDO
      *
     C                     EXCPTDT
     C                     ENDIF
      *
     C**ロット数・セット数・箱数／日・かんばん枚数引当
     C           $CSV      BEGSR
     C                     MOVELKSU,I     KSYUR   1
     C*
      *かんばん種類判別
     C           KSYUR     CABEQ'0'       $KANH            F]ﾈBﾌ]ﾈBﾍ]
