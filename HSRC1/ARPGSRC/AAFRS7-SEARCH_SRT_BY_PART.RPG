     H            Y.
     F******************************************************
     F*品番でSRTを調べる
     F******************************************************
     FAAFTL06 IF  E           K        DISK
     FAAHTL06 IF  E           K        DISK
      *
     I            DS
     I                                        1  16 A3JOKA
     I                                        1   2 A3JOK1
     I                                        3   4 A3JOK2
     I                                        5   6 A3JOK3
     I                                        7   8 A3JOK4
     I                                        9  10 A3JOK5
     I                                       11  12 A3JOK6
     I                                       13  14 A3JOK7
     I                                       15  16 A3JOK8
     I            DS
     I                                        1  16 L6JOKA
     I                                        1   2 L6JOK1
     I                                        3   4 L6JOK2
     I                                        5   6 L6JOK3
     I                                        7   8 L6JOK4
     I                                        9  10 L6JOK5
     I                                       11  12 L6JOK6
     I                                       13  14 L6JOK7
     I                                       15  16 L6JOK8
      *
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@SRTN 20
     C                     PARM           P@SRT# 20
      *
     C                     MOVE P@HIN1    K@HIN1
     C                     MOVE P@HIN2    K@HIN2
     C                     MOVE P@HIN3    K@HIN3
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C                     EXSR #AAF
     C           P#SNAM    IFNE *BLANK
     C                     EXSR #END
     C                     END
      *
     C                     EXSR #AAH
     C           P#SNAM    IFNE *BLANK
     C                     EXSR #END
     C                     END
      *
     C                     EXSR #END
      *
     C           #END      BEGSR
     C                     MOVE P#SNAM    P@SRTN
     C                     MOVE P#SRT#    P@SRT#
     C                     SETON                     LR
     C                     RETRN
     C           EEND      ENDSR
      *
      *-----------------------------------------------------
     C           #AAF      BEGSR
      *
     C           HINKEY    SETLLAAFTL06
     C                     DO   *HIVAL
     C           HINKEY    READEAAFTL06                  88
     C   88                LEAVE
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           *DATE     IFGE A3UKHZ
     C           *DATE     ANDLTA3STHZ
     C                     ELSE
     C                     ITER
     C                     END
      *
     C           P@BAN1    IFNE *BLANK
     C           P@BAN1    IFNE A3ATK1
     C           P@BAN2    ORNE A3ATK2
     C           P@BAN3    ORNE A3ATK3
     C           P@BAN4    ORNE A3ATK4
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVE A3KCD1    P#KANB
     C                     MOVELA3JOKA    P#KOJA
     C                     MOVE *BLANK    P#NAMA
     C                     MOVE *BLANK    P#SNAM
     C                     MOVE *BLANK    P#SRT#
     C                     CALL 'AAARS3'
     C                     PARM           P#KANB  1
     C                     PARM           P#KOJA 20
     C                     PARM           P#NAMA200
     C                     PARM           P#SNAM 20
     C                     PARM           P#SRT# 20
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #AAH      BEGSR
      *
     C           HINKEY    SETLLAAHTL06
     C                     DO   *HIVAL
     C           HINKEY    READEAAHTL06                  88
     C   88                LEAVE
     C           L6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           *DATE     IFGE L6UKHZ
     C           *DATE     ANDLTL6STHZ
     C                     ELSE
     C                     ITER
     C                     END
      *
     C           P@BAN1    IFNE *BLANK
     C           P@BAN1    IFNE L6ATK1
     C           P@BAN2    ORNE L6ATK2
     C           P@BAN3    ORNE L6ATK3
     C           P@BAN4    ORNE L6ATK4
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVE L6KCD1    P#KANB
     C                     MOVELL6JOKA    P#KOJA
     C                     MOVE *BLANK    P#NAMA
     C                     MOVE *BLANK    P#SNAM
     C                     MOVE *BLANK    P#SRT#
     C                     CALL 'AAARS3'
     C                     PARM           P#KANB  1
     C                     PARM           P#KOJA 20
     C                     PARM           P#NAMA200
     C                     PARM           P#SNAM 20
     C                     PARM           P#SRT# 20
      *
     C                     ENDDO
      *
     C                     ENDSR
