     H            Y.
     F** MRHR13 *********************************************
     F* PILOT LOCATION LIST                                 *
     F*             ITS.           2014.05.08               *
     F*******************************************************
     FMRHPW13 CF  E                    WORKSTN
     E                    ER      1  10 60
      *
     I            DS
     I                                        1   60WKYM
     I                                        1   40WKYY
     I                                        5   60WKMM
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C           *ENTRY    PLIST
     C                     PARM           P1DVKB  1
     C                     PARM           PCMD    2
     C                     PARM           @OUTQ   8
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    D1DVKB
     C                     MOVEL*BLANK    P1DVKB
     C                     MOVEL*BLANK    PCMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTMRHPW131
     C                     SETOF                     414599
     C                     MOVEL*BLANK    D1EMSG
      *
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DVKB    IFEQ ' '
     C           D1DVKB    OREQ '1'
     C           D1DVKB    OREQ '2'
     C           D1DVKB    OREQ '3'
     C           D1DVKB    OREQ '4'
     C           D1DVKB    OREQ '5'
     C                     ELSE
     C                     MOVELER,1      D1EMSG
     C                     SETON                     4199
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVEL*BLANK    @OUTQ
      * CHECK PRINTER SELECTION
     C           D@PRT     IFLE '7'
     C                     SELEC
     C           D@PRT     WHEQ *BLANK
     C                     MOVEL'QPRINTC' @OUTQ   8
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT02'@OUTQ
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT07'@OUTQ
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT03'@OUTQ
     C           D@PRT     WHEQ '4'
     C*                    MOVEL'LANPRT01'@OUTQ
     C                     MOVEL'LANPRT04'@OUTQ
     C           D@PRT     WHEQ '5'
     C                     MOVEL'QPRINTB '@OUTQ
     C           D@PRT     WHEQ '6'
     C                     MOVEL'QPRINT  '@OUTQ
     C           D@PRT     WHEQ '7'
     C                     MOVEL'QDKT    '@OUTQ
     C                     OTHER
     C                     MOVEL'QPRINTC' @OUTQ   8
     C                     ENDSL
     C                     ELSE
     C                     SETON                     4599
     C                     MOVE ER,2      D1EMSG
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     MOVELD1DVKB    P1DVKB
     C                     MOVEL'05'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
** ER
E-01 DEPARTMENT ERR.
E-02 SELECT PRINTER
E-03
E-04
