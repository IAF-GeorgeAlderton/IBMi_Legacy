     H            Y.
     F****************************************************************
     F*PROGRAM NAME. : TEMPORARY UPDATE
     F*    OCT/10/02
     F*
     F*
     F****************************************************************
     FAAMPP11 UP  E                    DISK
     FGHCPL21 UF  E           K        DISK
     C****************************************************************
     E                    KO         15  3               PROCESS
     E                    KB         15  3               MACHINE
     I            DS
     I                                        1  45 KO
     I                                        1   3 CKKO01
     I                                        4   6 CKKO02
     I                                        7   9 CKKO03
     I                                       10  12 CKKO04
     I                                       13  15 CKKO05
     I                                       16  18 CKKO06
     I                                       19  21 CKKO07
     I                                       22  24 CKKO08
     I                                       25  27 CKKO09
     I                                       28  30 CKKO10
     I                                       31  33 CKKO11
     I                                       34  36 CKKO12
     I                                       37  39 CKKO13
     I                                       40  42 CKKO14
     I                                       43  45 CKKO15
     I            DS
     I                                        1  45 KB
     I                                        1   3 CKKB01
     I                                        4   6 CKKB02
     I                                        7   9 CKKB03
     I                                       10  12 CKKB04
     I                                       13  15 CKKB05
     I                                       16  18 CKKB06
     I                                       19  21 CKKB07
     I                                       22  24 CKKB08
     I                                       25  27 CKKB09
     I                                       28  30 CKKB10
     I                                       31  33 CKKB11
     I                                       34  36 CKKB12
     I                                       37  39 CKKB13
     I                                       40  42 CKKB14
     I                                       43  45 CKKB15
     I            DS
     I                                        1   7 CKHN
     I                                        1   5 CKHIN2
     I                                        6   7 CKHIN3
     I                                        3   6 CCC
     C****************************************************************
     C           K#KEY     KLIST
     C                     KFLD           CKHIN1
     C                     KFLD           CKHIN2
     C                     KFLD           CKHIN3
      *
     C           CKSKJY    IFEQ *BLANK
      *
     C                     Z-ADD1         Z       20
     C           'JC '     LOKUPKO,Z                     10
     C           *IN10     IFEQ *ON
     C           KB,Z      ANDNE'A10'
     C                     MOVE 'A10'     @MCN    3
     C                     MOVE 'JC '     @PRC    3
     C                     EXSR #UPD
     C                     MOVE 'A10'     KB,Z
     C                     ENDIF
      *
     C                     Z-ADD1         Z
     C           'SB '     LOKUPKO,Z                     10
     C           *IN10     IFEQ *ON
     C           KB,Z      IFNE 'A21'
     C                     MOVE 'A21'     @MCN    3
     C                     MOVE 'SB '     @PRC    3
     C                     EXSR #UPD
     C                     MOVE 'A21'     KB,Z
     C                     ENDIF
      *
     C                     ADD  1         Z
     C           KO,Z      IFEQ 'KRO'
     C           KB,Z      ANDNE'A22'
     C                     MOVE 'A22'     KB,Z
     C                     MOVE 'A22'     @MCN    3
     C                     MOVE 'KRO'     @PRC    3
     C                     EXSR #UPD
     C                     ENDIF
      *
     C                     ELSE
     C                     Z-ADD1         Z
     C           'KRO'     LOKUPKO,Z                     10
     C           *IN10     IFEQ *ON
     C           KB,Z      ANDNE'A12'
     C                     MOVE 'A12'     @MCN    3
     C                     MOVE 'KRO'     @PRC    3
     C                     EXSR #UPD
     C                     MOVE 'A12'     KB,Z
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADD1         Z
     C           'VNL'     LOKUPKO,Z                     10
     C           *IN10     IFEQ *ON
     C           KB,Z      ANDNE*BLANK
     C                     MOVE *BLANK    @MCN    3
     C                     MOVE 'VNL'     @PRC    3
     C                     EXSR #UPD
     C                     MOVE *BLANK    KB,Z
     C                     ENDIF
      *
     C                     Z-ADD1         Z
     C           'TC '     LOKUPKO,Z                     10
     C           *IN10     IFEQ *ON
     C           CCC       ANDNE'S301'
     C           KB,Z      ANDNE'T01'
     C                     MOVE 'T01'     @MCN    3
     C                     MOVE 'TC '     @PRC    3
     C                     EXSR #UPD
     C                     MOVE 'T01'     KB,Z
     C                     ENDIF
      *
     C                     UPDATAAMPP111
      *
     C                     ENDIF
      *---------------------------------------------
     C           #UPD      BEGSR
      *
     C           K#KEY     SETLLGHCPL21
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEGHCPL21                  90
     C           *IN90     IFEQ *OFF
     C           M7MKTE    ANDEQ@PRC
     C                     MOVE @MCN      M7MSNO
     C                     UPDATGHCPL211
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
