     C**************************************************************************
     C           #CHEK     BEGSR
     C**************************************************************************
     C* A9ERR1:部品マスター完成単重０
     C* A9ERR2:部品マスターにデータなし
     C* A9ERR3:平準化確定ファイルにデータなし
     C* A9ERR4:かんばん種類が違う
     C* A9ERR5:かんばんマスターの部門と一致しない
     C* A9ERR6:かんばんマスターになし
      *
     C* A9ERR1: U/W=0 IN PART M FILE (FCEPP01)
     C* A9ERR2: NOT FOUND IN PART M FILE (FCEPP01)
     C* A9ERR3: NOT FOUND IN LEVEL FIX ORDER FILE (AGAPP31)
     C* A9ERR4: INCORRECT KANBAN TYPE
     C* A9ERR5: INVALID SUPP CODE  WITH KANBAN M FILE
     C* A9ERR6: NOT FOUND IN PLATING KANBAN FILE (AAFPP01)
     C*****************************************************************
     C                     MOVEL*BLANK    A9ERR
     C                     SETOF                     30
     C           KEY2      CHAINFCEPL011             30
     C           *IN30     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C*
     C           *IN30     IFEQ '0'
     C* UNIT WGT = 0
     C           A2KASI    IFEQ 0
     C                     MOVEL'*'       A9ERR1
     C                     END
     C                     Z-ADDA2KASI    A9WEIT
     C                     ELSE
     C* NOT EXIST IN PART M/F
     C                     MOVEL'*'       A9ERR2
     C                     END
     C*
     C           A8KANR    IFNE 'I'
     C                     SETOF                     30
     C           KEY3      CHAINAH#PL111             30
     C           *IN30     IFEQ '0'
     C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     ELSE
     C                     MOVELCFKDAI    WWKDAI  1
     C                     MOVELCFHTHZ    WWHTHZ  80
     C                     END
     C                     END
     C*
     C* NOT EXIST IN LEVEL FIXED ORDER FILE
     C           *IN30     IFEQ '1'
     C*
     C                     SETOF                     30
     C           KEY2      CHAINAGAPL311             30
     C           *IN30     IFEQ '0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVELCBKDAI    WWKDAI  1
     C                     MOVEL*DATE     WWHTHZ  80
     C                     ELSE
     C* NOT EXIST IN LEVEL FIXED ORDER FILE
     C                     MOVEL'*'       A9ERR3
     C                     GOTO ECHEK
     C                     END
     C                     END
     C* INCORRECT KANBAN TYPE
     C           WWKDAI    IFEQ 'C'
     C           WWKDAI    OREQ 'E'
     C                     ELSE
     C                     MOVEL'*'       A9ERR4
     C                     GOTO ECHEK
     C                     END
     C*
     C                     MOVE A8SUPP    KSUPP   40
      * READ PLATING KANBAN
     C*          WWKDAI    IFEQ 'C'
     C*                    SETOF                     31
     C*          KEY2      SETLLAAFTL061
     C*                    DO   *HIVAL
     C*          KEY2      READEAAFTL061                 31
     C*          *IN31     IFEQ '0'
     C*          A3SKJY    IFEQ 'D'
     C*          A3SKHZ    ANDNE*DATE
     C*                    ELSE
     C*          WWHTHZ    IFGE A3UKHZ
     C*          WWHTHZ    ANDLEA3STHZ
     C*          A3ATOB    IFNE KSUPP
      * INCORRECT SUPPILIER CODE
     C*                    MOVEL'*'       A9ERR5
     C*                    END
     C*                    GOTO ECHEK
     C*                    END
     C*                    END
     C*                    END
     C* N31                ENDDO
     C*メッキかんばんマスターなし。
     C*                    MOVEL'*'       A9ERR6
     C*                    GOTO ECHEK
     C***********          END
