     C                     MOVELA2BHB3    A7BHB3
     C                     MOVELW@ATOB    A7ATOB
     C                     MOVELBARC2     A7LTNO
     C                     WRITEAFAPP871
     C                     CLEARAFAPP871
      *
     C                     ENDSR
