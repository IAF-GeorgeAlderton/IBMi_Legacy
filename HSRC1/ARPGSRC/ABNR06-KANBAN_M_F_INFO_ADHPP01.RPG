     H            Y.
     F** ABNR06 *********************************************
     F* KANBAN M/F INFO ADHPP01
     F*    SAKAKI.         2019.04.09                       *
     F*******************************************************
     FADHPL03 IF  E                    DISK
     FABNPP01 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     READ ADHPL03                  21
     C           *IN21     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLESDATE
     C                     ELSE
     C           J6STHZ    IFEQ 99999999
     C                     EXSR #SB200
     C                     ENDIF
     C                     ENDIF
     C                     READ ADHPL03                  21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *焼入れかんばん検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYA31    KLIST
     C                     KFLD           K6CRDT  80
     C                     KFLD           K6KCD1  1
     C                     KFLD           K6KCD2  1
     C                     KFLD           K6LOTK  30
     C                     Z-ADDSDATE     K6CRDT
     C                     MOVELJ6KCD1    K6KCD1
     C                     MOVELJ6KCD2    K6KCD2
     C                     Z-ADDJ6LOTO    K6LOTK
      *
     C           KEYA31    CHAINABNPP01              82
     C           *IN82     IFEQ '0'
     C                     ADD  J6KMAX    S6KMAX
     C                     ADD  J6CMAI    S6CMAI
     C                     ADD  J6DAND    S6DAND
     C                     ADD  J6KYOT    S6KYOT
     C                     ADD  J6FRYO    S6FRYO
     C                     ADD  J6SENY    S6SENY
     C                     ADD  J61NAI    S61NAI
     C                     ADD  J62NAI    S62NAI
     C                     ADD  J6JISK    S6JISK
     C                     ADD  J6AUAJ    S6AUAJ
     C                     ADD  J6OTHH    S6OTHH
     C                     UPDATABNPP011
     C                     ELSE
     C                     CLEARABNPP011
     C                     Z-ADDSDATE     S6CRDT
     C                     MOVELJ6KCD1    S6KCD1
     C                     MOVELJ6KCD2    S6KCD2
     C                     Z-ADDJ6LOTO    S6LOTK
     C                     Z-ADDJ6KMAX    S6KMAX
     C                     Z-ADDJ6CMAI    S6CMAI
     C                     Z-ADDJ6DAND    S6DAND
     C                     Z-ADDJ6KYOT    S6KYOT
     C                     Z-ADDJ6FRYO    S6FRYO
     C                     Z-ADDJ6SENY    S6SENY
     C                     Z-ADDJ61NAI    S61NAI
     C                     Z-ADDJ62NAI    S62NAI
     C                     Z-ADDJ6JISK    S6JISK
     C                     Z-ADDJ6AUAJ    S6AUAJ
     C                     Z-ADDJ6OTHH    S6OTHH
     C                     WRITEABNPP011
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
