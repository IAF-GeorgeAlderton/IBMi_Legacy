     H** AB#RN2 *******************************************************
     H* INQUIRY FOR AWNC : STORE ADDRESS , KANBAN
     H*
     H*  KIRI 15.08.07
     H*****************************************************************
     H            Y/                                    1
     FAB#PWN2 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFREC1
      *
     FAB#PPAW IF  E           K        DISK
      *================================================================
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@MHN  20
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C                     MOVELP@MHN     K@MHN  20
     C                     MOVEL*BLANK    P@MHN
      *
     C           K@MHN     SETLLAB#PPAW
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AB#PPAW                  90
     C   90                LEAVE
     C*
     C           AWSKJY    IFEQ 'D'                        DELETE CODE
     C           AWSKDT    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELAWMHIN    S1MHIN           USER PARTS NO
     C                     MOVELAWADDR    S1ADDR           STORE ADDRESS
     C                     MOVELAWSBAN    S1SBAN           KANBAN
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < F3 > 終了
     C           *INKC     WHEQ *ON
     C   KC                MOVE '#END    '@STEP
     C* < PAGE UP/DOWN >
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* <    >
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFREC1               95
     C           *IN95     IFEQ *OFF
     C                     MOVELS1MHIN    P@MHN            USER PARTS NO
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C                     ENDSR
      *===============================================================
      *===============================================================
