     H            Y.
     F** AB#R6G **********************************
     F*     CONVERT AB#PP6D TO AB#PP6A           *
     F*                                          *
     F*  JW1  CHG 0TTMI TO TMMI                  *
     F********************************** AB#R6G **
     FAB#PP6D IP  E                    DISK
     FAB#PP6A O   E                    DISK
      **********************************************************
     E                    ARY1       20  1
     E                    ARY2       20  1
      **********************************************************
     I            DS
     I                                        1  12 WPART
     I                                        1   5 APPAR1
     I                                        6  10 APPAR2
     I                                       11  12 APCLRC
     I            DS
     I                                        1   80WYMD
     I                                        1   40APRCYY
     I                                        5   60APRCMM
     I                                        7   80APRCDD
     C****************************************************
     C                     MOVEAAPPART    ARY1
     C                     MOVE *BLANK    ARY2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   20        X       20
     C           ARY1,X    IFNE '-'
     C                     ADD  1         Y
     C                     MOVE ARY1,X    ARY2,Y
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAARY2      W20    20
     C                     MOVELW20       WPART
      *
     C                     Z-ADDAPRCDT    WYMD
     C                     Z-ADD*DATE     APPRDT
     C                     Z-ADD@@TIME    APPRTM
      *
JW1  C           APCNAM    IFEQ '0TMMI'
 |   C                     MOVEL'TMMI '   APCNAM
JW1  C                     ENDIF
      *
JW1  C           APCNAM    IFEQ 'TMMNK'
 |   C                     MOVEL'MTMUS'   APCNAM
JW1  C                     ENDIF
      *
     C                     WRITEAB#PP6A1
      *------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@TIM   6
      *
     C                     TIME           @@TIME  60
     C                     MOVE @@TIME    P@TIM
      *
     C                     ENDSR
