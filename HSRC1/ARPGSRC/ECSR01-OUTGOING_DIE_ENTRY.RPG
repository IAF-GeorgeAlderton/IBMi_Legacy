     C                     MOVE '1'       *IN,C
     C                     MOVE '1'       *IN,D
     C                     MOVE '1'       *IN,E
     C                     MOVE '1'       *IN,F
     C                     MOVE '1'       *IN,G
     C   70                MOVE '1'       *IN,H
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STP4
E4   C                     END
E3   C                     END
E2   C                     END
