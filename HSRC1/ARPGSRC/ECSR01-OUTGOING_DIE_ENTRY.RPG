     C           HK2,A     ANDEQ*BLANK
     C           HK3,A     ANDEQ*BLANK
     C           HKS,A     ANDEQ0
     C           HKN,A     ANDEQ*BLANK
     C           HED,A     ANDEQ*BLANK
     C           HHS,A     ANDEQ*BLANK
     C           HHY,A     ANDEQ*BLANK
     C           HKA,A     ANDEQ*BLANK
     C           HRI,A     ANDEQ*BLANK
