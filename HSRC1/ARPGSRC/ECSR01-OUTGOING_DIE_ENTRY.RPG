     C           HHS,A     ANDNE'3'
     C           HHS,A     ANDNE'4'
     C           HHS,A     ANDNE'5'
     C           HHS,A     ANDNE'6'
     C           HHS,A     ANDNE'7'
     C           HHS,A     ANDNE'8'
     C           HHS,A     ANDNE'9'
     C           HHS,A     ANDNE'S'
