 B4  C           HKO,A     IFNE '0'
     C           HKO,A     ANDNE'1'
     C                     MOVE '1'       *IN,B
     C                     SETON                     99
     C                     MOVE ER,8      MSG
     C                     GOTO STP4
 E4  C                     END
