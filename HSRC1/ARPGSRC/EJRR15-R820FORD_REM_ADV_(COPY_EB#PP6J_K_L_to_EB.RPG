     H            Y.
     F** EJRR15 **********************************************
     F*  R820FORD REM ADV (COPY EB#PP6J/K/L TO EB#PP6P/Q/R)  *
     F*  J.WATANABE 2017.07.12                               *
     F********************************************************
     FEB#PP6J IF  E                    DISK
     FEB#PP6K IF  E                    DISK
     FEB#PP6L IF  E                    DISK
     FEB#PP6P O   E                    DISK
     FEB#PP6Q O   E                    DISK
     FEB#PP6R O   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      **********************************************************
     C                     MOVE *OFF      *IN90
     C           *IN90     DOUEQ*ON
     C                     READ EB#PP6J                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDTODAY     APPRDT
     C                     Z-ADDNOW       APPRTM
     C                     WRITEEB#PP6P1
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *OFF      *IN90
     C           *IN90     DOUEQ*ON
     C                     READ EB#PP6K                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDTODAY     APPRDT
     C                     Z-ADDNOW       APPRTM
     C                     WRITEEB#PP6Q1
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *OFF      *IN90
     C           *IN90     DOUEQ*ON
     C                     READ EB#PP6L                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDTODAY     ALPRDT
     C                     Z-ADDNOW       ALPRTM
     C                     WRITEEB#PP6R1
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------
      *
     C                     TIME           D#TIME
      *
     C                     ENDSR
