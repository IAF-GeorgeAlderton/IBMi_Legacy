     H            Y.                                    1
      ** ALER01 ****************************************************************
      *  BPT SCAN                                                              *
      *
      * TCHK  02/05/10 CREATE                                          *********
      * TCHK1 06/01/12 BUG FIX                                         *********
      * TCHK2 06/05/12 ADD ERROR SCREEN                                *********
      * TCHK3 02/28/13 ADD ALEPP10(ASJ KANBAN:ORDER#,LOT#)             *********
      * SAKAKI 11/25/2019 ADD UEXR16 TO CHECK STORE IN/OUT STATUS      *********
      * LEC    10/06/2020 ADD PGM LOCK FOR WRONG KANBAN ERROR          *********
      * LEC    02/12/2025 CHG ORDER KBN LOGIC TO MATERIAL HANDLING KBN,*********
      *        ADD KANBAN COUNT AND VERIFY ALL ARE SCANNED
      **************************************************************************
     FALEPW01 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCEPL07 IF  E           K        DISK
     F            FCEPP011                          KRENAMEFCEPL071
     FFCEPL40 IF  E           K        DISK
     FAANPL04 IF  E           K        DISK
      *
     FALEPP01 IF  E           K        DISK                      A
      ***FALEPL013IF  E           K        DISK
      ***F            ALEPP011                          KRENAMEALEPL@13
     FALEPP10 IF  E           K        DISK                      A
      *
     E                    ERR     1  20 17
     E                    LOT         4  8
     E                    BPT        16 17
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      * IAF BPT KANBAN
      * KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
     I            DS
     I                                        1  17 WHNF
     I                                        1   1 WHKANS
     I                                        2   5 WHZETI
     I                                        6  14 WHETC
     I                                       15  15 WHCHKD
      *
     I            DS
     I                                        1  12 WHPART
     I                                        1   5 WHPAR1
     I                                        6  10 WHPAR2
     I                                       11  12 WHPAR3
      *
     I            DS
     I                                        1  12 WHSHIN
     I                                        1   5 WHSHI1
     I                                        6  10 WHSHI2
     I                                       11  12 WHSHI3
      * ASJ BPT KANBAN
      * KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
     I            DS
     I                                        1  17 WASJ
     I                                        1   1 WAKANS
     I                                        2   5 WAZETI
     I                                        6  11 WAORDR
     I                                       12  12 WASEHI
     I                                       13  160WALOTN
     I                                       17  17 WACHKD
      *
     I            DS
     I                                        1  12 WAPART
     I                                        1   5 WAPAR1
     I                                        6  10 WAPAR2
     I                                       11  12 WAPAR3
      * COMMON
     I            DS
     I                                        1  12 W@PART
     I                                        1   5 W@PAR1
     I                                        6  10 W@PAR2
     I                                       11  12 W@PAR3
      **
     I            DS
     I                                        1  17 A8HN01
     I                                        1   1 K1KSKB
     I                                        2   5 K1ZETI
     I                                        6   7 K1MBCD
     I                                        9  11 K1KTEI
     IQRCD        DS
     I                                        1 256 QR1
     I                                      257 400 QR2
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'10'      #FMT10
     C           W@ID      CASEQ'20'      #FMT20
     C           W@ID      CASEQ'30'      #FMT30
     C           W@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *  INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
      *
     C           *ENTRY    PLIST
     C                     PARM           WKCD    6
     C                     PARM           WKNM   20
      *
     C                     TIME           WSDT
     C                     MOVE '10'      W@ID    2
     C                     MOVEL*BLANK    D@TMCD
      * DUMMY READ
     C                     READ ALEPP01             N    90
      *
     C                     EXSR #CLEAR
      *
     C                     ENDSR
      **************************************************************************
      *  WORK CLEAR
      **************************************************************************
     C           #CLEAR    BEGSR
      *
     C                     CLEARLOT
     C                     CLEARBPT
     C                     MOVEL*BLANK    F1EMSG
     C                     MOVEL*BLANK    BRCD20
     C                     MOVEL*BLANK    QRCD
     C                     MOVEL*BLANK    F2EMSG
     C                     MOVEL*BLANK    BRCD30
     C                     MOVEL*BLANK    F3EMSG
     C                     MOVEL*BLANK    BRCD40
     C                     MOVEL*BLANK    F4EMSG
     C                     SETOF                     616263
     C                     SETOF                     64
     C                     Z-ADD*ZERO     TLOTS   10
     C                     Z-ADD*ZERO     TKANB   20
      *
     C                     ENDSR
      **************************************************************************
     C* TM ID CODE
     C           #FMT10    BEGSR
      **************************************************************************
      *
      * if worker code wasn't passed as parm, then display screen 10
     C           WKCD      IFEQ *BLANK
     C                     EXFMTFMT010
     C                     ELSE
     C                     MOVELWKCD      D@TMCD
     C                     ENDIF
      *
     C                     MOVEL*BLANK    F1EMSG
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'20'      W@ID
     C                     MOVEL*BLANK    BRCD20
     C                     MOVEL*BLANK    QRCD
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *  CHECK--TM CODE
      **************************************************************************
     C           #CHK1     BEGSR
      *
     C                     SETOF                     6199
      *
     C                     MOVEL*BLANK    W1WKNM 20
      *
     C                     MOVELD@TMCD    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     MOVELALWKNM    W1WKNM
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C           ALSKJY    OREQ 'D'
     C                     SETON                     6199
     C                     MOVELERR,1     F1EMSG
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      * MATERIAL HANDLING KANBAN
     C           #FMT20    BEGSR
      **************************************************************************
     C                     EXFMTFMT020
     C                     MOVEL*BLANK    F2EMSG
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     MOVEL'40'      W@ID
     C                     MOVEL*BLANK    BRCD30
     C                     ELSE
     C                     MOVELF2EMSG    F99ER1
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
     C           #CHK2     BEGSR
      **************************************************************************
     C                     SETOF                     6299
     C                     MOVEL*BLANK    WHPART
     C                     MOVEL*BLANK    WHSHIN
     C                     MOVELBRCD20    WHNF
      *
     C                     DO
      *
      * convert QR code to 1D barcode....
     C                     MOVELBRCD20    KTYPE   3
      *
     C           KTYPE     IFEQ 'B01'
     C                     MOVELBRCD20    QRCD
     C                     MOVELQR1       P1QR1 256
     C                     MOVELQR2       P1QR2 256
     C                     MOVEL*BLANK    P9BAR  20
     C                     CALL 'UEXR13'
     C                     PARM           P1QR1
     C                     PARM           P1QR2
     C                     PARM           P9BAR
      *
     C                     MOVELP9BAR     BRCD20
     C                     MOVELBRCD20    WHNF
     C                     MOVEL*BLANK    P9BAR
     C                     ENDIF
      *
     C           BRCD20    IFEQ *BLANK
     C                     SETON                     6299
     C                     MOVELERR,2     F2EMSG
     C                     LEAVE
     C                     END
     C           WHKANS    IFGE '0'
     C           WHKANS    ANDLE'9'
     C                     ELSE
     C                     SETON                     6299
     C                     MOVELERR,9     F2EMSG
     C                     LEAVE
     C                     END
      * CHECK DIGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
     C                     MOVELWHNF      PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     MOVELERR,7     F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     END
     C           WHCHKD    IFNE PMCHK
     C                     MOVELERR,7     F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     END
      *
     C           WHZETI    CHAINFCEPL07              90
     C           *IN90     IFEQ *ON
     C                     MOVELERR,6     F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     END
     C           *IN90     IFEQ *OFF
     C           A2GSKD    ANDNE*BLANK
     C                     MOVELERR,14    F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     END
      * EXIST TABLE CHECK
     C           K#PL40    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#PL40    SETLLFCEPL40
     C                     DO   *HIVAL
     C           K#PL40    READEFCEPL40                  90
     C   90                LEAVE
     C           F4GSKD    IFEQ *BLANK
     C                     LEAVE
     C                     END
     C                     ENDDO
     C           *IN90     IFEQ *ON
     C                     MOVELERR,11    F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     END
      * DUPLICATE SCAN CHECK
     C           K#L013    KLIST
     C                     KFLD           WSSDAT
     C                     KFLD           WHNF
      ******     K#L013    CHAINALEPL013             90
      ******     *IN90     IFEQ *OFF
      ******               MOVELERR,12    F2EMSG
      ******               SETON                     6299
      ******               LEAVE
      ******               END
      *
     C                     MOVELF4HPR1    WHPAR1
     C                     MOVELF4HPR2    WHPAR2
     C                     MOVELF4HPR3    WHPAR3
      *
     C                     MOVELA2BHB1    WHSHI1
     C                     MOVELA2BHB2    WHSHI2
     C                     MOVELA2BHB3    WHSHI3
      *
      **   get asj part# zeti...
     C           K#PL01    KLIST
     C                     KFLD           F4HPR1
     C                     KFLD           F4HPR2
     C                     KFLD           F4HPR3
      *
     C           K#PL01    CHAINFCEPL01              90
     C           *IN90     IFEQ *ON
     C                     MOVELERR,15    F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C           A2GSKD    ANDNE*BLANK
     C                     MOVELERR,16    F2EMSG
     C                     SETON                     6299
     C                     LEAVE
     C                     ELSE
     C                     MOVELA2ZETI    AJZETI  4
     C                     ENDIF
      *
     C                     EXSR #CHKAN
     C                     ENDDO
      *
     C                     ENDSR
      **************************************************************************
      * LOT ID TAG
     C           #FMT30    BEGSR
      **************************************************************************
     C                     EXFMTFMT030
     C                     MOVEL*BLANK    F3EMSG
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C                     MOVELBRCD30    LOT,X
     C                     ADD  1         TLOTS
     C                     MOVEL*BLANK    BRCD30
     C           TLOTS     IFEQ #LOTS
     C                     EXSR #WRT
     C                     EXSR #CHKAN
     C                     EXSR #SUB17
     C                     EXSR #SBSTA
     C                     EXSR #CLEAR
     C                     MOVEL'20'      W@ID
     C                     MOVEL*OFF      *IN64
     C                     MOVEL*BLANK    BRCD20
     C                     ENDIF
      *
     C                     ELSE
     C                     MOVELF3EMSG    F99ER1
     C                     EXFMTFMT999
     C                     END
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
     C* CHECK LOT-ID
     C           #CHK3     BEGSR
      **************************************************************************
     C                     SETOF                     6399
      *
     C                     DO
      *
     C           BRCD30    IFEQ *BLANK
     C                     SETON                     6399
     C                     MOVELERR,2     F3EMSG
     C                     LEAVE
     C                     ENDIF
      *
     C           BRCD30    LOKUPLOT                      90
     C           *IN90     IFEQ *ON
     C                     SETON                     6399
     C                     MOVELERR,3     F3EMSG
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
     C           *BLANK    LOKUPLOT,X                    90
     C           *IN90     IFEQ *OFF
     C                     SETON                     6399
     C                     MOVELERR,4     F3EMSG
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      **************************************************************************
      * ASJ KANBANS
     C           #FMT40    BEGSR
      **************************************************************************
     C                     EXFMTFMT040
     C                     MOVEL*BLANK    F4EMSG
      *
     C                     SELEC
      * F3 = BACK
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK4
     C           *IN99     IFEQ *OFF
     C           *INKE     IFEQ *OFF
     C                     MOVELBRCD40    BPT,X
     C                     MOVEL*BLANK    BRCD40
     C                     ADD  1         TKANB
     C                     MOVEL*BLANK    BRCD40
     C                     ENDIF
      *
      * if total kanbans scanned = total kanbans needed
      * OR F5 was pressed, continue and output data...
     C           TKANB     IFEQ #KANBS
     C           *INKE     OREQ *ON
     C                     MOVEL'30'      W@ID
     C                     MOVEL*OFF      *IN62
     C                     MOVEL*BLANK    BRCD30
     C                     EXSR #CHKAN
     C                     ENDIF
      *
     C                     ELSE
      *
      * LOCK PGM IF WRONG KANBAN ERROR, OTHERWISE DISPLAY ERROR...
     C           F4EMSG    IFEQ ERR,10
     C                     EXSR LOCKPG
     C                     ELSE
     C                     MOVELF4EMSG    F99ER1
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      * CHECK ASJ KANBAN
     C           #CHK4     BEGSR
      **************************************************************************
     C                     SETOF                     6499
     C                     MOVEL*BLANK    WAPART
     C                     MOVELBRCD40    WASJ
      *
     C                     DO
      *
     C                     SELEC
     C           BRCD40    WHEQ *BLANK
     C           *INKE     ANDEQ*ON
     C           TKANB     ANDEQ*ZERO
     C                     SETON                     6499
     C                     MOVELERR,2     F4EMSG
     C                     LEAVE
     C           BRCD40    WHEQ *BLANK
     C           *INKE     ANDEQ*ON
     C           TKANB     ANDGT*ZERO
     C                     LEAVE
     C           BRCD40    WHEQ *BLANK
     C                     SETON                     6499
     C                     MOVELERR,2     F4EMSG
     C                     LEAVE
     C                     ENDSL
      *
      *
      *
     C           WAKANS    IFNE 'I'
     C                     SETON                     6499
     C                     MOVELERR,9     F4EMSG
     C                     LEAVE
     C                     ENDIF
      * CHECK DIGIT
     C                     MOVELWASJ      PMAREA    P
     C                     MOVE '016'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     MOVELERR,7     F4EMSG
     C                     SETON                     6499
     C                     LEAVE
     C                     ENDIF
     C           WACHKD    IFNE PMCHK
     C                     MOVELERR,7     F4EMSG
     C                     SETON                     6499
     C                     LEAVE
     C                     ENDIF
      *
     C           WAZETI    IFNE AJZETI
     C                     MOVELERR,10    F4EMSG
     C                     SETON                     6499
     C                     LEAVE
     C                     ENDIF
      *
     C           BRCD40    LOKUPBPT                      90
     C           *IN90     IFEQ *ON
     C                     SETON                     6499
     C                     MOVELERR,13    F4EMSG
     C                     LEAVE
     C                     ENDIF
      *
     C           K#EP10    KLIST
     C                     KFLD           WAZETI
     C                     KFLD           WAORDR
     C                     KFLD           K@LOTN  4
     C                     MOVELWALOTN    K@LOTN
     C           K#EP10    CHAINALEPP10              90
     C           *IN90     IFEQ *OFF
     C                     SETON                     6499
     C                     MOVELERR,13    F4EMSG
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
     C           *BLANK    LOKUPBPT,X                    90
     C           *IN90     IFEQ *OFF
     C                     SETON                     6499
     C                     MOVELERR,5     F4EMSG
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      **************************************************************************
     C           #WRT      BEGSR
      **************************************************************************
     C                     CLEARALEPP011
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A8DATE
     C                     Z-ADDWSSTM6    A8TIME
     C                     MOVEL#PGM      A8PGID
     C                     MOVEL#WSID     A8WSID
     C                     MOVEL#USER     A8USER
     C                     MOVELD@TMCD    A8TMCD
      * IAF BPT KANBAN
     C                     MOVELWHNF      A8HN01
     C                     MOVELWHPART    A8HNPT
     C                     MOVELWHSHIN    A8SHIN
      * SCANNED LOT ID TAG
     C                     MOVELLOT,1     A8LT01
     C                     MOVELLOT,2     A8LT02
     C                     MOVELLOT,3     A8LT03
     C                     MOVELLOT,4     A8LT04
      * LOT ID TAG
     C                     MOVELLOT,1     A8L#01
     C                     MOVELLOT,2     A8L#02
     C                     MOVELLOT,3     A8L#03
     C                     MOVELLOT,4     A8L#04
      * BPT KANBAN
     C                     MOVELBPT,01    A8BP01
     C                     MOVELBPT,02    A8BP02
     C                     MOVELBPT,03    A8BP03
     C                     MOVELBPT,04    A8BP04
     C                     MOVELBPT,05    A8BP05
     C                     MOVELBPT,06    A8BP06
     C                     MOVELBPT,07    A8BP07
     C                     MOVELBPT,08    A8BP08
     C                     MOVELBPT,09    A8BP09
     C                     MOVELBPT,10    A8BP10
     C                     MOVELBPT,11    A8BP11
     C                     MOVELBPT,12    A8BP12
     C                     MOVELBPT,13    A8BP13
     C                     MOVELBPT,14    A8BP14
     C                     MOVELBPT,15    A8BP15
     C                     MOVELBPT,16    A8BP16
      *
     C                     WRITEALEPP011
      *
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
      *
     C                     ADD  1         Y
     C           Y         IFGT 16
     C                     LEAVE
     C                     END
     C           BPT,Y     IFEQ *BLANK
     C                     LEAVE
     C                     END
      *
     C                     CLEARALEPP101
      *
     C                     Z-ADDWSSDAT    A0DATE
     C                     Z-ADDWSSTM6    A0TIME
     C                     MOVEL#PGM      A0PGID
     C                     MOVEL#WSID     A0WSID
     C                     MOVEL#USER     A0USER
     C                     MOVELD@TMCD    A0TMCD
      *
     C                     MOVELWHNF      A0HNKN
     C                     MOVELWHPAR1    A0HNP1
     C                     MOVELWHPAR2    A0HNP2
     C                     MOVELWHPAR3    A0HNP3
     C                     MOVELWHSHI1    A0SHN1
     C                     MOVELWHSHI2    A0SHN2
     C                     MOVELWHSHI3    A0SHN3
      *
     C                     MOVELBPT,Y     WASJ
     C                     MOVELWAKANS    A0KANS
     C                     MOVELWAZETI    A0ZETI
     C                     MOVELWAORDR    A0ORDR
     C                     MOVELWASEHI    A0SEHI
     C                     MOVELWALOTN    A0LOTN
     C                     MOVELWACHKD    A0CHKD
      *
     C                     WRITEALEPP101
      *
     C                     ENDDO
      *
     C                     ENDSR
      **************************************************************************
     C           #CHKAN    BEGSR
      **************************************************************************
     C                     MOVEL*BLANK    P1TKR1  1
     C                     MOVEL*BLANK    P1TKR2  2
     C                     MOVEL*BLANK    P1TKR3  2
     C                     MOVEL*BLANK    P1TKR4  1
     C                     MOVE K1KSKB    K2KSKB  10
     C                     Z-ADD*ZERO     #LOTS   10
     C                     Z-ADD*ZERO     #KANBS  20
      *
     C           K#KEY     KLIST
     C                     KFLD           AJZETI
      *
     C           K#KEY     SETGTAANPL04
      *-------------------------
     C                     DO   *HIVAL
     C           K#KEY     REDPEAANPL04                  97
     C   97                LEAVE
      *
     C           L7SKJY    IFEQ *BLANK
     C           L7STHZ    ANDEQ99999999
     C                     MOVELL7TKR1    P1TKR1
     C                     MOVELL7TKR2    P1TKR2
     C                     MOVELL7TKR3    P1TKR3
     C                     MOVELL7TKR4    P1TKR4
      * get number of asj kanbans needed for scanning...
     C                     Z-ADDL7HKSU    #KANBS
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *-------------------------
      * get number of lot ids needed for scanning...
     C           TKANB     DIV  4         #LOTS
     C                     MVR            REM     20
     C           REM       IFGT *ZERO
     C                     ADD  1         #LOTS
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
     C           #SUB17    BEGSR
      **************************************************************************
      *
     C                     Z-ADD*ZERO     Y       20
      *-------
D1   C                     DO   *HIVAL
 |   C*-------
 |   C                     ADD  1         Y
 |   C*
 |2  C           Y         IFGT 16
 ||  C                     LEAVE
 |2  C                     ENDIF
 |   C*
 |2  C           BPT,Y     IFNE *BLANK
 ||  C                     MOVEL*BLANK    WASJ20 20
 ||  C                     MOVELBPT,Y     WASJ20
 ||  C*
 ||  C                     MOVEL*BLANK    @@BARA256
 ||  C                     MOVEL*BLANK    @@BARB256
 ||  C                     MOVEL*BLANK    WORK10 10
 ||  C                     MOVELD@TMCD    WORK10
 ||  C                     MOVEL*BLANK    TANT20 20
 ||  C                     MOVELW1WKNM    TANT20
 ||  C*
 ||  C                     CALL 'UEXR16'
 ||  C                     PARM           WASJ20
 ||  C                     PARM           @@BARA
 ||  C                     PARM           @@BARB
 ||  C*
 ||  C                     PARM           P1TKR1
 ||  C                     PARM           P1TKR2
 ||  C                     PARM           P1TKR3
 ||  C                     PARM           P1TKR4
 ||  C                     PARM           WHPAR1
 ||  C                     PARM           WHPAR2
 ||  C                     PARM           WHPAR3
 ||  C*
 ||  C                     PARM           WORK10
 ||  C                     PARM           TANT20
 ||  C                     PARM           #PGM
 ||  C                     PARM '2'       P9TYPE  1
 ||  C                     PARM ' '       P9RTN   1
 ||   *
 |2  C                     ELSE
 ||  C                     LEAVE
 |2  C                     ENDIF
 |   C*-------
 1   C                     ENDDO
     C*-------
      *
     C                     ENDSR
      *================================================================
      * INTRA STOCK UPDATE SUB ROUTINE               *
      *================================================================
     C           #SBSTA    BEGSR
      *
     C                     Z-ADD1         P#HKSU  50
      *
     C                     MOVEL*BLANK    P#QR11
     C                     MOVEL*BLANK    P#QR12
     C                     MOVEL*BLANK    P#QR21
     C                     MOVEL*BLANK    P#QR22
      * PULLING KANBAN
     C                     MOVELWHNF      P#BAR1    P
     C*
     C                     Z-ADD*ZERO     Y       20
     C*-------
D1   C                     DO   *HIVAL
 |   C*
 |   C                     ADD  1         Y
 |   C*
 |2  C           Y         IFGT 16
 ||  C                     LEAVE
 |2  C                     ENDIF
 |   C*
 |2  C           BPT,Y     IFNE *BLANK
 ||  C                     MOVEL*BLANK    P#BAR2
 ||  C                     MOVELBPT,Y     P#BAR2    P
 ||   *
 ||  C                     CALL 'STAR00'
 ||  C                     PARM WSSDAT    P#TIHZ  80
 ||  C                     PARM WSSTM6    P#TITI  60
 ||  C                     PARM '0111'    P#BMON  4
 ||  C                     PARM WHPAR1    P#SHN1  5
 ||  C                     PARM WHPAR2    P#SHN2  5
 ||  C                     PARM WHPAR3    P#SHN3  2
 ||  C                     PARM P1TKR1    P#ATK1  1
 ||  C                     PARM P1TKR2    P#ATK2  2
 ||  C                     PARM P1TKR3    P#ATK3  2
 ||  C                     PARM P1TKR4    P#ATK4  1
 ||  C                     PARM '2'       P#SYOR  1
 ||  C                     PARM '2'       P#ZAIK  1        在庫減
 ||  C                     PARM           P#HKSU  50
 ||  C                     PARM WORK10    P#TMCD 10
 ||  C                     PARM TANT20    P#TMNM 20
 ||  C                     PARM #PGM      P#PGM  10
 ||  C                     PARM           P#BAR1 20
 ||  C                     PARM           P#QR11256
 ||  C                     PARM           P#QR12256
 ||  C                     PARM           P#BAR2 20
 ||  C                     PARM           P#QR21256
 ||  C                     PARM           P#QR22256
 ||   *
 |2  C                     ELSE
 ||  C                     LEAVE
 |2  C                     ENDIF
 |   C*-------
 1   C                     ENDDO
      *
     C                     ENDSR
      *================================================================*********
      * LOCK THE PROGRAM DUE TO ERROR FOR TL TO UNLOCK
      *================================================================
     C           LOCKPG    BEGSR
      *
     C                     Z-ADD2         P1PGM
     C                     MOVELF4EMSG    P1ERR     P
     C                     MOVEL#PGM      P1PID
     C                     MOVELD@TMCD    P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
      *
     C                     ENDSR
      *================================================================*********
** ERR(17A).....>      ##
TM ID CODE ERROR       01
BLANK SCANNED          02
LOT-ID  DUPLICATE      03
LOT-ID MAX 4           04
KANBAN MAX 16          05
UNKNOWN IAF PART#      06
CHECK DIGIT ERROR      07
NOT YET SCAN           08
KANBAN KIND ERROR      09
WRONG KANBAN           10
KANBAN BPT ?           11
IAF BPT KAN DUP        12
ASJ BPT KAN DUP        13
PART DELETED           14
UNKNOWN ASJ PART#      15
ASJ PART DELETED       16
#17                    17
#18                    18
#19                    19
#20                    20
