     FFCEPW39 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAGDPL12 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FFCEWP39 IF  E           K        DISK                      A
     FAAFPL03 IF  E           K        DISK
     FAAGPL03 IF  E           K        DISK
     FAAHPL03 IF  E           K        DISK
     FAAPPL03 IF  E           K        DISK
     FADHPL03 IF  E           K        DISK
     FABHPL03 IF  E           K        DISK
     FCADPL03 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    CMD     1   1 78
     E                    ERR     1   2 78
     E                    TTL     1   1 32
     E                    LOC        15  6               LOCATION
     E                    MCN        15  3               MACHINE
     E                    KAN        15  1                KANABA TYPE
     E                    @M        100  3               MACHINE
