     C                     END
      *
     C                     ENDSR
      *
      *
     C*****************************************************************
     C*         マイナス箱数チェック
     C*****************************************************************
     C           $SYUKA    BEGSR
      *
     C                     SETOF                     83
     C           @YYMM     IFEQ @TEYM
     C           @TEDD     DO   31        B
     C           @KON,B    IFNE 0
     C                     SETON                     83
     C                     MOVE '1'       *IN,B
     C                     END
     C                     END
     C                     END
      *
     C                     ENDSR
      *
      *
     C*****************************************************************
     C*         マイナス箱数チェック
     C*****************************************************************
     C           $MAI      BEGSR
      *
     C                     SETOF                     83
     C                     Z-ADD0         B
     C           1         DO   31        B
     C           @KON,B    IFLT 0
     C                     SETON                     83
     C                     END
     C                     END
      *
     C                     ENDSR
      *
      *
     C*****************************************************************
     C*         バレルチェック・バレル端数計算
     C*****************************************************************
     C           $BARE     BEGSR
      *
     C*箱数はバレルの倍数
     C                     SETOF                     838490
     C                     Z-ADD0         B
     C           1         DO   31        B
     C           @KON,B    IFNE 0
      *
     C           @KON,B    DIV  CBBARL    WMUSHI  30
     C                     MVR            WAMARI  30
     C           WAMARI    IFNE 0
     C                     MOVE '1'       *IN,B
     C                     SETON                     83
     C                     END
     C                     END
     C                     END
      *
     C           *IN83     IFEQ '1'
     C                     GOTO ERA
     C                     END
      *
     C*割振済受注数が総受注数を超えたらエラー
     C                     EXSR $ZUMI
      *
     C           WZUMIH    MULT @SYUSU    WZUMIS  70       割振済受注数
     C           @JYUSU    IFLT WZUMIS
     C                     SETON                     84
     C                     GOTO ERA
     C                     END
      *
     C*割振無受注数
     C           @JYUSU    SUB  WZUMIS    @NJYU
      *
     C*バレル端数
     C                     EXSR $KON
      *
     C           WKHAKO    MULT @SYUSU    WKONS   70
      *
     C           @WARI     IFEQ 'Y'
     C           @NJYU     IFLT WKONS
     C                     SETON                     90
     C                     GOTO ERA
     C                     END
     C                     END
      *
     C           @NJYU     SUB  WKONS     @HASU
      *
     C           ERA       TAG
      *
     C                     ENDSR
      *
      *
     C*****************************************************************
     C*                   今回箱数
     C*****************************************************************
     C           $KON      BEGSR
      *
     C                     Z-ADD0         @SHKSU
     C                     Z-ADD0         WSHKHK  50
     C                     Z-ADD0         WKHAKO  50
     C                     Z-ADD1         B
     C           1         DO   31        B
     C                     ADD  @KON,B    WSHKHK
     C           @BUN,B    IFEQ 0
     C                     ADD  @KON,B    WKHAKO
     C                     END
     C                     END
      *
     C           WSHKHK    MULT @SYUSU    @SHKSU
      *
     C                     ENDSR
      *
      *
     C*****************************************************************
     C*                   割振済箱数
     C*****************************************************************
     C           $ZUMI     BEGSR
      *
     C                     Z-ADD0         WZUMIH  50
     C                     Z-ADD1         B
     C           1         DO   31        B
     C           @BUN,B    IFNE 0
     C                     ADD  @KON,B    WZUMIH
     C                     END
     C                     END
      *
     C                     ENDSR
      *
