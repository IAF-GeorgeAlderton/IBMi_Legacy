      *
     C           STP1      TAG
     C                     TIME           WTIME
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00000000'*IN,09
     C                     MOVEA'00000000'*IN,17
     C                     MOVEA'0000000' *IN,25
     C                     MOVE *BLANK    @KOSIN
     C                     Z-ADD0         @TOKU
     C                     Z-ADD0         @NONY
     C                     MOVE *BLANK    @KOJY
     C                     MOVE *BLANK    @UKEI
     C                     MOVE *BLANK    @HIN1
     C                     MOVE *BLANK    @HIN2
     C                     MOVE *BLANK    @HIN3
     C                     Z-ADD0         @YY
     C                     Z-ADD0         @MM
     C                     MOVE *BLANK    @HIN
     C                     MOVE *BLANK    @YM
     C                     MOVE 'YEAR'    WNEN
     C                     MOVE 'MONT'    WTSUKI
     C                     Z-ADD0         BTNJYU
     C                     Z-ADD0         BTQWA1
     C                     Z-ADD0         BTQWA2
     C                     Z-ADD0         BTSYHZ
     C                     Z-ADD0         @NJYU
     C                     Z-ADD0         @TEHZ
     C                     MOVE *BLANK    @@TEHZ
     C                     Z-ADD0         @NOHZ
     C                     MOVE *BLANK    @@NOHZ
     C                     Z-ADD0         @JYUSU
     C                     Z-ADD0         @INPSU
     C                     Z-ADD0         @@INSU
     C                     Z-ADD0         @THSU
     C                     Z-ADD0         @SYUSU
     C                     Z-ADD0         @@SYSU
     C                     Z-ADD0         @BARE
     C                     Z-ADD0         @HASU
     C                     Z-ADD0         @@HASU
     C                     MOVE *BLANK    @WARI
     C                     Z-ADD0         @HOKI
     C                     Z-ADD0         @AUT1
     C                     Z-ADD0         @AUT2
     C                     Z-ADD0         @SHKSU
