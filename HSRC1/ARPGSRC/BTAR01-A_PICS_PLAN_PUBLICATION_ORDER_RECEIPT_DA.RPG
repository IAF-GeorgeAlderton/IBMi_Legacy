      *
     C           STP2      TAG
     C                     EXFMTBTAPW011
     C                     MOVEA'00000000'*IN,01
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*更新*
     C           @KOSIN    IFNE '0'
     C           @KOSIN    ANDNE'1'
     C           @KOSIN    ANDNE'2'
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     SETOF                     86
     C                     Z-ADD1         F       20
     C           @KOSIN    LOKUPWKJ1,F                   86
     C           *IN86     IFEQ '1'
     C                     MOVE WKJ2,F    WKSNM
     C                     END
      *
     C*得意先*
     C           @TOKU     IFEQ 0
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     SETOF                     86
     C           @TOKU     CHAINFGBPL011             86
     C           *IN86     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     86
     C                     END
     C           *IN86     IFEQ '1'
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     MOVE '-'       WH1
     C                     MOVELB2SMEI    WTOKU
      *
     C*納入先*
     C           @NONY     IFEQ 0
     C                     SETON                     0399
     C                     MOVELER,4      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     SETOF                     86
     C           @NONY     CHAINFGBPL011             86
     C           *IN86     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     86
     C                     END
     C           *IN86     IFEQ '1'
     C                     SETON                     0399
     C                     MOVELER,5      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     MOVE '-'       WH2
     C                     MOVELB2SMEI    WNONY
      *
     C*工場*
     C           @KOJY     IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVELER,6      MSG
     C                     GOTO STP2
     C                     END
      *
     C*受入*
     C           @UKEI     IFEQ *BLANK
     C                     SETON                     0599
     C                     MOVELER,7      MSG
     C                     GOTO STP2
     C                     END
      *
     C*出荷マスター
     C                     SETOF                     86
     C           KEY4      CHAINGADPL111             86
     C           *IN86     IFEQ '0'
     C           B5SKJY    ANDEQ'D'
     C           B5SKHZ    ANDLE*DATE
     C                     SETON                     86
     C                     END
     C           *IN86     IFEQ '1'
     C                     SETON                     020304
     C                     SETON                     0599
     C                     MOVELER,44     MSG
     C                     GOTO STP2
     C                     END
      *
     C*品番*
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     SETON                     0699
     C                     MOVELER,8      MSG
     C                     GOTO STP2
     C                     END
      *
     C*平準化ファイル
     C                     SETOF                     86
     C           KEY2      CHAINAGAPL311             86
     C           *IN86     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     86
     C                     END
     C           *IN86     IFEQ '1'
     C                     SETON                     0699
     C                     MOVELER,9      MSG
     C                     GOTO STP2
     C                     END
      * 95.09.15にプログラム修正してあるが
      *下記のルーチンがあると、１０進数エラーになるため
      *止めてあります。
     C*          @KOSIN    IFNE '0'
     C*Ａ－ＰＩＣＳ計画発行管理マスター*
     C                     SETOF                     86
     C           KEY5      CHAINBTAPL111             86
     C           *IN86     IFEQ '0'
     C           BUSKJY    ANDEQ'D'
     C           BUSKHZ    ANDLE*DATE
     C                     SETON                     86
     C                     END
     C           *IN86     IFEQ '1'
     C                     SETON                     020304
     C                     SETON                     050699
     C                     MOVELER,18     MSG
     C                     GOTO STP2
     C                     END
     C*                    END
      *
     C                     MOVE '-'       WH3
     C                     MOVE '-'       WH4
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WH4
     C                     END
      *
     C*計画予定日*
     C           @YY       IFEQ 0
     C                     SETON                     0799
     C                     MOVELER,10     MSG
     C                     GOTO STP2
     C                     END
      *
     C           @YY       IFLT 1994
     C                     SETON                     0799
     C                     MOVELER,11     MSG
     C                     GOTO STP2
     C                     END
      *
     C           @MM       IFEQ 0
     C                     SETON                     0899
     C                     MOVELER,12     MSG
     C                     GOTO STP2
     C                     END
      *
     C           @MM       IFLT 1
     C           @MM       ORGT 12
