     H            Y.                                    1
     H***INVR10*****************************************************************
     H* YELLOW FLAG LOADING LOT#/QTY                                           *
     H* TCH 04/29/05
TCHK H* TCH 08/09/05
TCHK1H* TCH 06/21/06 CHG GET ADDRESS
     H**************************************************************************
     FINVPW40 CF  E                    WORKSTN
     FINVPP40 UF  E           K        DISK                      A
     FFCETL11 IF  E           K        DISK
      **************************************************************************
     E                    ERR     1   3 15
      **************************************************************************
     I* KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
     I            DS
     I                                        1  15 D@APCS
     I*                                       1   1 WWKANS
     I*                                       2   5 WWZETI
     I*                                       6   8 WWORDR
     I*                                       8   8 WWID
     I*                                       9  11 WWPROC
     I*                                      15  15 WWCHK
     I                                       01  04 WWIDX
     I            DS
     I                                        1  17 D@ASJ
     I                                        1   1 BARKBN
     I                                        2   5 IDNO7
     I                                        6   8 POS
     I                                       15  15 CHKD8
     I                                       17  17 CHKD7
     I                                       16  17 NODGT
     I            DS
     I                                        1   6 TLOC
     I                                        1   1 LOC1
     I                                        2   3 LOC2
     I                                        4   5 LOC3
     I                                        6   6 LOC4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
TCHK I            DS
   | I                                        1  140DTTM
   | I                                        1   60DTIM
TCHK I                                        7  140DDAT
TCHK1I            DS
TCHK1I                                        1   80A2TRHZ
TCHK1I                                        1   40A2TRYY
TCHK1I                                        5   60A2TRMM
TCHK1I                                        7   80A2TRDD
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C*          @@ID      CASEQ'00'      #SCRN0           USER ID
     C           @@ID      CASEQ'01'      #SCRN1           LOCATION
     C*          @@ID      CASEQ'02'      #SCRN2           ASJ
     C           @@ID      CASEQ'03'      #SCRN3           QTY
     C*          @@ID      CASEQ'04'      #SCRN4           CANCEL APCS
     C*          @@ID      CASEQ'05'      #SCRN5           CANCEL ASJ
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
     C           K#INV     KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@BAR  17
      *
     C                     Z-ADD*DATE     K@DATE
      *
     C                     MOVE '01'      @@ID    2
     C*
     C                     ENDSR
     C*************************************************************************
     C*          USER ID ENTRY
     C*************************************************************************
     C           #SCRN0    BEGSR
      *
     C                     EXFMTDSP00
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C           D@USER    IFNE *BLANK
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*  LOCATION
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
TCH72C*          *INKD     WHEQ *ON
TCH72C*                    MOVE '02'      @@ID
     C           *INKG     WHEQ *ON
     C                     MOVE '04'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVE *OFF      *IN61                        F5
     C                     MOVE *BLANK    D@ERR                        F5
      *
     C           D@APCS    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     D@ERR
     C                     ENDIF
      *
     C                     MOVELD@APCS    K@BAR     P
     C*          K#INV     SETLLINVPP10
     C*          *IN90     DOUEQ*ON
     C*          K#INV     READEINVPP10                  90
     C*          *IN90     IFEQ *OFF
     C*          IVSKJY    ANDEQ*BLANK
     C*                    LEAVE
     C*                    ENDIF
     C*                    ENDDO
      *
      *
     C                     MOVE '-'       LOC1    1
     C                     MOVE '--'      LOC2    2
     C                     MOVE '--'      LOC3    2
     C                     MOVE '-'       LOC4    1
     C           WWIDX     CHAINFCETL111             34
     C           *IN34     IFEQ '0'
TCHK1C           *DATE     IFGE A2TRHZ
     C                     MOVE A2STRK    LOC1
     C                     MOVE A2STRT    LOC2
     C                     MOVE A2STRR    LOC3
     C                     MOVE A2STRD    LOC4
TCHK1C                     ELSE
TCHK1C                     MOVE A2KTRK    LOC1
TCHK1C                     MOVE A2KTRT    LOC2
TCHK1C                     MOVE A2KTRR    LOC3
TCHK1C                     MOVE A2KTRD    LOC4
TCHK1C                     ENDIF
     C                     ENDIF
     C*                    MOVELD@APCS    D@BAR     P
     C                     MOVE @@ID      ZZID    2
      *
     C           TLOC      CHAININVPP401            N66
     C           *IN66     IFEQ '0'
     C                     Z-ADDI2QTY     D@KANS
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------
     C*     QTY
      *----------------------------------------------
     C           #SCRN3    BEGSR
      *----------------------------------------------
     C                     EXFMTDSP03
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C           *IN66     IFEQ '1'
     C                     EXSR #WRT
     C                     ELSE
     C                     EXSR #UPD
     C                     ENDIF
      *
TCH72C                     EXFMTDSP97
      *
     C                     MOVE ZZID      @@ID
     C                     MOVE *BLANK    D@APCS
     C                     MOVE *BLANK    D@ASJ
     C                     Z-ADD*ZERO     D@KANS
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------
     C           #CHK3     BEGSR
      *----------------------------------------------
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVE *OFF      *IN61                        F5
     C                     MOVE *BLANK    D@ERR                        F5
     C*          D@KANS    IFEQ *ZERO
     C*                    SETON                     6199
     C*                    ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK2     BEGSR
     C*
     C           D@ASJ     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     D@ERR
     C                     ENDIF
      *
     C                     MOVELD@ASJ     K@BAR     P
     C*          K#INV     SETLLINVPP10
     C*          *IN90     DOUEQ*ON
     C*          K#INV     READEINVPP10                  90
     C*          *IN90     IFEQ *OFF
     C*          IVSKJY    ANDEQ*BLANK
     C*                    LEAVE
     C*                    ENDIF
     C*                    ENDDO
      *
     C*****                MOVELD@ASJ     D@BAR     P
     C                     MOVE @@ID      ZZID    2
      *
     C                     ENDSR
     C**************************************************************************
     C*     WRITE
     C**************************************************************************
     C           #WRT      BEGSR
      *
     C                     CLEARINVPP401
      *
     C                     MOVELTLOC      I2LOC
     C                     Z-ADDD@KANS    I2QTY
TCHK C                     TIME           DTTM
TCHK C                     Z-ADDDDAT      I2DATE
TCHK C                     Z-ADDDTIM      I2TIME
TCHK  *
     C                     WRITEINVPP401
      *
     C                     ENDSR
     C**************************************************************************
     C*     UPDTE
     C**************************************************************************
     C           #UPD      BEGSR
      *
      *
     C                     Z-ADDD@KANS    I2QTY
     C           TLOC      CHAININVPP401             66
     C           *IN66     IFEQ '0'
     C                     Z-ADDD@KANS    I2QTY
TCHK C                     TIME           DTTM
TCHK C                     Z-ADDDDAT      I2DATE
TCHK C                     Z-ADDDTIM      I2TIME
TCHK  *
     C                     UPDATINVPP401
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK4     BEGSR
     C*
     C                     MOVE *BLANK    D@ERR                        F5
     C                     SETOF                     996162
      *
     C           D@APCS    IFEQ *BLANK
     C                     SETON                     9961
     C                     ELSE
     C                     MOVELD@APCS    K@BAR     P
     C*          K#INV     CHAININVPP10              90
     C*          *IN90     IFEQ *ON
     C* N99                MOVELERR,3     D@ERR
     C*                    SETON                     9961
     C*                    ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK5     BEGSR
     C*
     C                     MOVE *BLANK    D@ERR                        F5
     C                     SETOF                     996162
      *
      *
     C                     ENDSR
     C**************************************************************************
