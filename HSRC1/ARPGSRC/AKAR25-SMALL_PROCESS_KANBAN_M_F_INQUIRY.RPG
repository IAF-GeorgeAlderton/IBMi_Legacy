     C                     MOVE '-'       R2
     C                     MOVE '-'       R3
     C                     MOVE '-'       M1
     C                     MOVE '-'       M2
     C                     MOVE '-'       K1
      *
     C                     Z-ADDT1KSKB    KSKBN
      *
     C                     MOVE *BLANK    SETNM
     C           T1STI1    CHAINAABPL011             20
     C           *IN,20    IFEQ '0'
     C           A4SKJY    ANDEQ'D'
     C           A4SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,20
     C                     END
      *
     C           *IN,20    IFEQ '0'
     C                     MOVELA4SETN    SETNM
     C                     END
      *
     C                     MOVE *BLANK    KCDNM
      *
     C           KEYB      CHAINGCMPL311             20
     C           *IN,20    IFEQ '0'
     C           T3SKJY    ANDEQ'D'
     C           T3SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,20
     C                     END
      *
     C           *IN,20    IFEQ '0'
     C                     MOVELT3NAMN    KCDNM
     C                     END
      *
     C                     MOVEA'00'      *IN,20
     C                     MOVE *BLANK    ANM
     C                     Z-ADD0         ALT
     C                     MOVE *BLANK    WYOB
     C                     Z-ADD0         WSKRU
     C                     Z-ADD0         TTM
     C                     Z-ADD0         WLTM1   31
     C                     Z-ADD0         WLTM2   31
     C           KEYC      CHAINGCKPL211             20
     C           *IN,20    IFEQ '0'
     C           T2SKJY    ANDEQ'D'
     C           T2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,20
     C                     END
      *
     C           *IN,20    IFEQ '0'
     C                     Z-ADDT2LTM1    WLTM1
     C                     Z-ADDT2LTM2    WLTM2
      *
     C                     MOVELT2NAMN    ANM
     C           T2LTM1    ADD  T2LTM2    ALT
     C                     Z-ADD1         A       10
     C                     Z-ADD0         B       10
     C           1         DO   5         A
     C           TYB,A     IFEQ '1'
     C                     ADD  1         B
     C                     MOVE TYM,A     WYOB,B
     C                     END
     C                     END
     C                     Z-ADDT2SKRU    WSKRU
     C           WSKRU     COMP 0                    2121
     C                     Z-ADDTTI       TTM
     C                     END
      *
     C                     SETOF                     20
     C                     MOVE *BLANK    BNM
     C                     Z-ADD0         BLT
     C           KEYD      CHAINGCKPL211             20
     C           *IN20     IFEQ '0'
     C           T2SKJY    ANDEQ'D'
     C           T2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,20
     C                     END
     C                     MOVELT2NAMN    BNM
     C           T2LTM1    ADD  T2LTM2    BLT
