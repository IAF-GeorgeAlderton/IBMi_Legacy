     C                     MOVE *BLANK    WDTKB   1
     C           KEYA      SETGTAAOPL031
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEYA      REDPEAAOPL031                 10
     C           *IN10     IFEQ '0'
     C           T1SKJY    IFEQ 'D'
     C           T1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     10
     C                     MOVE '*'       WDTKB
     C                     END
     C                     END
     C  N10                END
      *
     C           WDTKB     IFEQ *BLANK
     C                     MOVE '9'       ERCD
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     MOVE T1SHN1    SHIN1
     C                     MOVE '-'       SHIN2
     C                     MOVE T1SHN2    SHIN3
     C                     MOVE '-'       SHIN4
     C                     MOVE T1SHN3    SHIN5
