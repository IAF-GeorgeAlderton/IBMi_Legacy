     C                     EXCPTHD
     C           *LOVAL    SETLLECSWP951
     C                     READ ECSWP951                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #EDIT
     C                     EXCPTDT
     C                     READ ECSWP951                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * EDIT ITEM                                          *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1IOJK  5
     C           S1IOJK    CAT  W0IOJH:0  S1IOJK
     C           S1IOJK    CAT  ':':0     S1IOJK
     C           S1IOJK    CAT  W0IOJM:0  S1IOJK
     C                     MOVEL*BLANK    S1KAT
     C                     MOVELW0KAT1    S1KAT1
     C                     MOVEL'-'       S1KAF1
     C                     MOVELW0KAT2    S1KAT2
     C                     MOVEL'-'       S1KAF2
     C                     MOVELW0KAT3    S1KAT3
     C                     MOVEL'-'       S1KAF3
     C                     MOVELW0KAT4    S1KAT4
     C                     MOVEL*BLANK    S1RESN 24
     C           W0RIYU    CHAINECSPP701             23
     C           *IN23     IFEQ '0'
     C           S1RESN    CAT  E7RSNM:1  S1RESN
     C                     ENDIF
      *
     C                     MOVEL*BLANK    S1GSKB  6
     C                     SELEC
     C           W0GSKB    WHEQ ' '
     C                     MOVEL'      '  S1GSKB
     C           W0GSKB    WHEQ 'H'
     C                     MOVEL'HANDY '  S1GSKB
     C           W0GSKB    WHEQ 'A'
     C                     MOVEL'ADJUST'  S1GSKB
     C                     ENDSL
      *
     C                     MOVEL*BLANK    D2TKR
     C                     MOVELW0TKR1    D2TKR1
     C                     MOVEL'-'       D2TKF1
     C                     MOVELW0TKR2    D2TKR2
     C                     MOVEL'-'       D2TKF2
     C                     MOVELW0TKR3    D2TKR3
     C                     MOVEL'-'       D2TKF3
     C                     MOVELW0TKR4    D2TKR4
     C                     MOVEL'-'       D2TKF4
     C                     MOVELW0TKR5    D2TKR5
      *
     C                     MOVEL*BLANK    S1IOKB  3
     C           W0IOKB    IFEQ 'I'
     C                     MOVEL'IN'      S1IOKB
     C                     ELSE
     C                     MOVEL'OUT'     S1IOKB
     C                     END
      *
     CSR         EEDIT     ENDSR
     OECSWP97 EADD             HD
