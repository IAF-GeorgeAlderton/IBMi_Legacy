     H            Y.
     F*** GKBR17 **************************************
     F* MATERIAL  ORDER CHECK M/F ACCOUNT BOOK BY COMPLETION MATERIAL *
     F*         H.ITO              88.11.03           *
     F************************************** GKBR17 ***
     FGKBPL01 IP  E           K        DISK
     FRGAPL11 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1   80X3SKHZ
     I                                        1   40X3SKYY
     I                                        5   60X3SKMM
     I                                        7   80X3SKDD
     I            DS
     I                                        1   60@TIME
     I                                        1   20@HH
     I                                        3   40@SS
     C****************************************************************
     C*  START PROGRAM  <GKBR17>                                     *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C                     MOVEA'00'      *IN,01
     C           *IN,90    IFEQ '0'
     C                     TIME           @TIME
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,90
     C                     MOVEA'0'       *IN,30
     C                     MOVE *BLANK    @USER   7
     C           USER      CHAINRGAPL111             30
     C           *IN,30    IFEQ '0'
     C                     MOVELJ8NAME    @USER
     C                     ELSE
     C                     MOVEL'EDP    ' @USER
     C                     END
     C                     END
     C           X3SKJY    IFEQ 'D'
     C           X3SKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
     C                     MOVEA'1'       *IN,01
     C           @END      TAG
     OQPRINT  H  102   02
     O       OR        OF
     O                                  131 '+-------------------+'
     O        H  1     02
     O       OR        OF
     O                                  131 '|GOVERNOR | CHARGE  |'
     O        H  1     02
     O       OR        OF
     O                                   89 'TIME'
     O                         @TIME   +  1 '  :  :  '
     O                                  111 '|'
     O                                  121 '|'
     O                         @USER    129
     O                                  131 '|'
     O        H  2     02
     O       OR        OF
     O                                   10 'GKBR17-1'
     O                                   29 'COMPLET MAT ORDER'
     O                                   52 '**  MATERIAL ORDER'
     O                                   62 'CHECK M/F'
     O                                   79 'ACCOUNT BOOK  **'
     O                                   89 'DATE'
     O                         UDATE   +  1 '  .  .  '
     O                                  104 'PAGE'
     O                         PAGE  Z +  0
     O                                  131 '+-------------------+'
     O        H  2     02
     O       OR        OF
     O                                   13 'CMPLET MAT'
     O                                   32 'CMPLET WIRE DIAM'
     O                                   44 'CMPLET RCV'
     O                                   61 'CMPLET SUPPLIER'
     O                                   74 'MAT QUALITY'
     O                                   86 'WIRE DIAM'
     O                                   95 'MAT RCV'
     O                                  109 'MAT SUPPLIER'
     O                                  119 'PROD ODR'
     O                                  130 'STEEL KIND'
     O        D 1      01
     O                         X3KAZN    16
     O                         X3KAZI4   27
     O                         X3KAUK    41
     O                         X3KASI    55
     O                         X3BOZN    76
     O                         X3BOZI4   85
     O                         X3BOUK    94
     O                         X3BOSI   105
     O                         X3TEHI   116
     O                         X3KUBN   125
