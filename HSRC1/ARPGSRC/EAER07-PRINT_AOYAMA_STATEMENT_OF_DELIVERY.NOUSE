     C  N01                GOTO END
      *
     C           IITKCD    IFEQ 2011
     C                     SETON                       02
     C                     GOTO STEP@
     C                     ELSE
     C                     Z-ADDIITKCD    WTOKU   40
     C                     END
      *
     C           KEY1      CHAINKAAPP101             03
     C  N03      CCSKJY    COMP 'D'                      03
     C  N03      CCAONO    COMP '1'                      04
      *
     C           STEP@     TAG
      *
     C   02      IITKKJ    CABEQ'2'       END
      *
     C           IITKCD    IFEQ 8567
     C           IINOBN    ANDNE*BLANK
     C                     GOTO END
     C                     END
      *
     C                     MOVEL*BLANK    WWTKNM 16
     C           IITKCD    CHAINFGBPL011             05
     C  N05                MOVELB2SMEI    WWTKNM
      *
      *-------------------------------------*
      *     ﾎﾞﾍ]uﾇj-  f[  ﾆﾏcﾑcﾇc           *
      *-------------------------------------*
     C           *IN04     IFEQ '1'
     C                     Z-ADD0         @@SYUY  50
     C                     SETOF                     06
     C           KEY2      CHAINFCEPL011             06
     C           *IN06     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     06
     C                     END
     C                     END
     C           *IN06     IFEQ '0'
     C           A2SYHZ    IFGT IISUHZ
     C                     Z-ADDA2KSYS    @@SYUY
     C                     ELSE
     C                     Z-ADDA2SSYS    @@SYUY
     C                     END
     C                     END
      *-------------------------------------*
      *     ﾌﾃﾇc  ﾌﾇc  ･  ibﾅ]  mﾞ  ynxﾓ    *
      *-------------------------------------*
     C                     Z-ADD0         WHASU   60
     C                     Z-ADD0         WHAKO   30
      *
     C           @@SYUY    IFEQ 0
     C                     Z-ADD0         WHAKO
     C                     GOTO STEPX
     C                     END
      *
     C           IINOSU    IFLT @@SYUY
     C                     Z-ADD1         WHAKO
     C                     ELSE
     C           IINOSU    DIV  @@SYUY    WHAKO
     C                     MVR            WHASU
     C           WHASU     IFNE 0
     C                     ADD  1         WHAKO
     C                     END
     C                     END
      *
     C                     END
     C           STEPX     TAG
      *
     C                     MOVEL*BLANK    WWKJNM
     C                     MOVELIIKJNM    WWKJNM
      *
      *
     C                     MOVEL*BLANK    WWHNNM
     C                     MOVELIIHNNM    WWHNNM
     C                     MOVE HM5       WWHNNM
