     C           KEY1      KLIST
     C                     KFLD           YY
     C                     KFLD           MM
      *
     C           KEY2      KLIST
     C                     KFLD           DAYYY
     C                     KFLD           DAYMM
     C                     KFLD           DAYDD
      *
     C           KEY3      KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           @DD
      *
     C           KEY4      KLIST
     C                     KFLD           C7SHN1
     C                     KFLD           C7SHN2
     C                     KFLD           C7SHN3
     C                     KFLD           FRYY
     C                     KFLD           FRMM
     C                     KFLD           FRDD
      *
     C           KEY5      KLIST
     C                     KFLD           C7SHN1
     C                     KFLD           C7SHN2
     C                     KFLD           C7SHN3
      *
     C           KEY6      KLIST
     C                     KFLD           C7SHN1
     C                     KFLD           C7SHN2
     C                     KFLD           C7SHN3
     C                     KFLD           FROM
      *
     C           *ENTRY    PLIST
     C                     PARM           @YMJ    7
     C                     PARM           @HIZ    8
      *
     C           *IN90     IFEQ '0'
     C                     MOVE *BLANK    @TKR    6
     C                     MOVEL@YMJ      YMJ     70
     C                     MOVEL@HIZ      HIZ     80
     C                     Z-ADDYY        DAYYY
     C                     Z-ADDMM        DAYMM
      *
     C           MM        IFEQ 08
     C           JUN       ANDEQ2
     C                     Z-ADD3         JUN
     C                     END
      *
     C           JUN       IFEQ 1
     C                     Z-ADD1         DAYDD
     C                     Z-ADD10        DDL
     C                     END
      *
     C           JUN       IFEQ 2
     C                     Z-ADD11        DAYDD
     C                     Z-ADD20        DDL
     C                     END
      *
     C           JUN       IFEQ 3
     C                     Z-ADD21        DAYDD
     C                     Z-ADD31        DDL
     C                     END
      *
     C*  fnﾞcﾍﾞ 1.2
     C                     Z-ADD0         @DD1    31
     C                     Z-ADD0         @DD2    31
     C           KEY1      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAGDPL121                 10
     C           *IN10     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @DD1
     C                     ELSE
     C                     ADD  0.5       @DD1
     C                     END
      *
     C                     END
     C                     END
     C  N10                END
      *
     C                     Z-ADDDAYYY     YYL
     C                     Z-ADDDAYMM     MML
     C           KEY2      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     20
     C                     READ AGDPL121                 20
     C           *IN20     IFEQ '0'
      *
     C           F8KAHZ    IFGT DAYL
     C                     SETON                     20
     C                     ELSE
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @DD2
     C                     ELSE
     C                     ADD  0.5       @DD2
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N20                END
      *
     C                     TIME           WTIME   60
     C                     MOVEA'1'       *IN,90
     C                     MOVEL'1'       *INOF
      *
     C                     Z-ADD0         FROM    80
     C                     Z-ADD0         TO      80
     C                     Z-ADD0         X       50
     C           KEY3      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     READPAGDPL121                 30
     C           *IN30     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C                     ADD  1         X
     C           X         IFEQ 5
     C                     Z-ADDF8KAHZ    FROM
     C                     Z-ADDHIZ       TO
     C                     MOVEA'1'       *IN,30
     C                     END
      *
     C                     END
     C                     END
     C  N30                END
     C                     END
      *
     C******************************************************
     C*  LET'S  PRINT-OUT                                  *
     C******************************************************
     C           *INL2     IFEQ '1'
     C                     SETOF                     05
     C                     Z-ADD1         A       10
     C                     MOVE *BLANK    WKJNM  12
     C           $KUBN     LOKUPTB1,A                    05
     C           *IN05     IFEQ '1'
     C                     MOVE TB2,A     WKJNM
     C                     END
     C                     END
      *
     C           *INL2     IFEQ '1'
     C           *INOF     OREQ '1'
     C                     MOVE *BLANK    @TKR
     C                     EXCPTHED
     C                     MOVEL'0'       *INOF
     C                     END
      *
     C                     Z-ADD0         USR     40
     C           KEY4      SETLLDAGPL021
     C                     DO   *HIVAL
     C           KEY5      READEDAGPL021                 40
     C           *IN40     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLEUDATE
     C                     GOTO $EXIT1
     C                     END
      *
     C           E4MIHZ    IFGE FROM
     C           E4MIHZ    ANDLETO
     C                     ADD  1         USR
     C                     END
     C           E4MIHZ    IFGT TO
     C                     MOVEA'1'       *IN,40
     C                     END
     C                     END
     C           $EXIT1    TAG
     C  N40                END
      *
     C                     Z-ADD0         BMON    40
     C           KEY6      SETLLAH#TL201
     C                     DO   *HIVAL
     C           KEY5      READEAH#TL201                 60
     C           *IN60     IFEQ '0'
     C           CFMNHZ    IFGE FROM
     C           CFMNHZ    ANDLETO
     C                     ADD  1         BMON
     C                     END
     C           CFMNHZ    IFGT TO
     C                     MOVEA'1'       *IN,60
     C                     END
     C                     END
     C  N60                END
      *
     C                     MOVE *BLANK    AST     2
     C           C7PAST    IFGE 75.0
     C           C7PAST    ANDLE125.0
     C                     ELSE
     C                     MOVEL'**'      AST
     C                     END
      *
     C                     MOVE *BLANK    TKR
     C                     MOVELC7TKR1    TKR1
     C                     MOVELC7TKR2    TKR2
     C                     MOVELC7TKR3    TKR3
     C                     MOVELC7TKR4    TKR4
     C           TKR2      IFNE *BLANK
     C                     MOVEL'-'       TKRA
     C                     END
      *
     C           TKR3      IFNE *BLANK
     C                     MOVEL'-'       TKRB
     C                     END
      *
     C           TKR4      IFNE *BLANK
     C                     MOVEL'-'       TKRC
     C                     END
      *
     C                     MOVE *BLANK    HIN
     C                     MOVELC7SHN1    HIN1
     C                     MOVELC7SHN2    HIN2
     C                     MOVELC7SHN3    HIN3
     C           HIN2      IFNE *BLANK
     C                     MOVEL'-'       HINA
     C                     END
      *
     C           HIN3      IFNE *BLANK
     C                     MOVEL'-'       HINB
     C                     END
      *
     C           C7SRYO    DIV  C7SYOS    WHHAK   52H
      *
     C           C7HKSU    IFLT 0
     C                     ADD  C7HKSU    MINS    60
     C                     ADD  WHHAK     TMINS   82
     C                     ELSE
     C                     ADD  C7HKSU    PLS     60
     C                     ADD  WHHAK     TPLS    82
     C                     END
      *
     C           $TKR      COMP @TKR                     22
     C                     EXCPTDET
     C                     MOVEL$TKR      @TKR
      *
     C           @EXIT     TAG
      *
     CL1                   EXCPTDMY
      *
     CL2         PLS       ADD  MINS      GKEI    60
     CL2         TPLS      ADD  TMINS     TGKEI   82
     CL2                   EXCPTKEI
