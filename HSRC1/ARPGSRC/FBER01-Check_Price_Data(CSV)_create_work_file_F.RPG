     H            Y.
     F****************************************************************
     F*  PROGRAM    : FBER01                                         *
     F*  WRITTEN    : 10/9/2015                                      *
     F*  WRITTEN BY : JW (SRA)                                       *
     F*  FUNCTION   : READ FBEWP01(CSV) AND VALIDATE FIELDS          *
     F*             : IF ERROR, CREATE ERROR REPORT                  *
     F****************************************************************
     FFBEWP01 IF  E                    DISK
     FFCEPL01 IF  E           K        DISK
     FGHCPL21 IF  E           K        DISK
     FFBEWP02 O   E                    DISK
     FFBEWP03 O   E                    DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------------------
     E                    CSV        50  1
     E                    FLD        20  1
     E                    TBL     1   4 80
      *---------------------------------------------------------------
     I              '0123456789'          C         WKCKSU
      *
     I            DS
     I                                        1  15 W@SHN
     I                                        1   5 W@SHN1
     I                                        7  11 W@SHN2
     I                                       13  14 W@SHN3
     I            DS
     I                                        1   6 W@A006
     I                                        1   65W@PRC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      *                    MAIN PROCESS
      ******************************************************
      * Initial Process
     C                     EXSR @INIT
      * Validate Price Data
     C                     EXSR @CHECK
      * Print Footer (ERROR REPORT TOTAL)
     C           NOM#      ADD  ERR#      TTL#
     C           ERR#      IFEQ 0
      * If No Error, set MSG
     C                     MOVE *OFF      #ERFLG
     C                     MOVELTBL,3     FLD33  33
     C                     MOVE TBL,3     FLD47  47
     C                     MOVE TTL#      FLD33
     C                     MOVELTBL,3     #MSG1
     C                     MOVELFLD33     #MSG1
     C                     ELSE
     C                     MOVE *ON       #ERFLG
     C                     EXCPTFOT1
     C                     MOVELTBL,4     FLD46  46
     C                     MOVE TBL,4     FLD34  34
     C                     MOVELFLD46     FLD32  32
     C                     MOVE FLD46     FLD14  14
     C                     MOVE TTL#      FLD32
     C                     MOVE ERR#      FLD14
     C                     MOVELFLD32     FLD46
     C                     MOVE FLD14     FLD46
     C                     MOVELFLD46     #MSG2
     C                     MOVE FLD34     #MSG2
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      *          @CHECK: Validate Price Data
      ******************************************************
     C           @CHECK    BEGSR
     C                     MOVE *OFF      *IN80
      *
     C           *IN80     DOUEQ*ON
     C                     READ FBEWP01                  80
     C           *IN80     IFEQ *OFF
     C                     ADD  1         LINE#
     C                     MOVE *OFF      #ERFLG
     C                     EXSR @GET
      * If Header, Skip
     C           #HDFLG    IFEQ *ON
     C                     GOTO @SKIP
     C                     ENDIF
      * Check Part -------------------------------
     C                     MOVE *OFF      *IN99
     C           K#PART    CHAINFCEPL01              99
     C           *IN99     IFEQ *ON
      * Print Error Report
     C                     MOVELTBL,1     XMSG   35
     C                     EXSR @PRINT
     C                     ENDIF
      * Check Process Code -----------------------
     C                     MOVE *OFF      *IN99
     C                     MOVE *ON       OKFLG   1
     C           K#PART    SETLLGHCPL21
      *
     C           *IN99     DOWEQ*OFF
     C           K#PART    READEGHCPL21                  99
     C           *IN99     IFEQ *OFF
     C           M7MKTE    ANDEQT4PROC
     C                     MOVE *OFF      OKFLG
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * Pint Error Report
     C           OKFLG     IFEQ *ON
     C                     MOVELTBL,2     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *----------------------
     C           #ERFLG    IFEQ *OFF
     C                     ADD  1         NOM#
     C                     MOVEL@VLDAT    T4EDAT
     C                     Z-ADDLINE#     T4LINE
     C                     Z-ADD@DATE     T4CDAT
     C                     Z-ADD@TIME     T4CTIM
     C                     MOVEL#USER     T4CUSR
     C                     MOVEL#PGM      T4CPGM
     C                     WRITEFBEWP021
     C                     ELSE
     C                     ADD  1         ERR#
     C                     ENDIF
      * ------------------------------------------
     C           @SKIP     TAG
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      *          @GET: GET INPUT FIELDS
      ******************************************************
     C           @GET      BEGSR
     C                     MOVE *BLANK    W@SHN
     C                     MOVE *BLANK    T4MCN#  3
     C                     MOVE *BLANK    T4PROC  3
     C                     MOVE *BLANK    T4SHN  12
     C                     Z-ADD0         T4COST  85
     C                     MOVE *OFF      #HDFLG  1
     C                     CLEARCSV
     C                     Z-ADD0         IX      50
     C                     Z-ADD0         IY      50
      * MCN# ------------------------------------------
     C                     MOVELFLD1      T4MCN#
      * PROC -----------------------------------------
     C                     MOVELFLD2      W@A002  2
     C           W@A002    IFEQ 'SB'
     C                     MOVELW@A002    T4PROC  3
     C                     ELSE
     C                     MOVELFLD2      T4PROC
     C                     ENDIF
      * PART# ---------------------------------------
     C                     MOVELFLD3      W@SHN
     C                     MOVELW@SHN1    T4SHN1  5
     C                     MOVELW@SHN2    T4SHN2  5
     C                     MOVELW@SHN3    T4SHN3  2
      *
     C* COST  -----------------------------------------
     C                     Z-ADD0         IX
     C                     Z-ADD0         IY
     C                     MOVEL*ALL'0'   FLD
     C                     CLEARCSV
     C                     MOVEAFLD4      CSV
     C                     DO   *HIVAL
     C                     ADD  1         IX
     C           CSV,IX    IFEQ ' '
     C                     LEAVE
     C                     ENDIF
     C           CSV,IX    IFEQ '.'
     C                     ITER
     C                     ENDIF
     C                     ADD  1         IY
     C                     MOVELCSV,IX    FLD,IY
     C                     ENDDO
      *
     C                     MOVEAFLD       W@A006
      * CHECK NUMERIC
     C           WKCKSU    CHECKW@A006                   99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDW@PRC     #UP     65
     C                     Z-ADD#UP       T4COST
     C                     ELSE
     C                     MOVE *ON       #HDFLG
     C                     ENDIF
      *
     C                     ENDSR
      ******************************************************
      *          @PRINT: PRINT ERROR REPORT
      ******************************************************
     C           @PRINT    BEGSR
     C                     MOVE *ON       #ERFLG
      *
      * DO NOT PRINT OVER 5 PAGES
     C           SEQ       IFGE 301
     C                     GOTO XPRINT
     C                     ENDIF
      *
     C           DTL#      IFGE 60
     C                     EXCPTHDR1
     C                     Z-ADD0         DTL#
     C                     ENDIF
      *
     C                     ADD  1         SEQ
     C                     EXCPTDTL1
     C                     ADD  1         DTL#
      *
     C           SEQ       IFEQ 300
     C                     EXCPTMAX1
     C                     ENDIF
      * WRITE FBEWP03
     C                     WRITEFBEWP031
      *
     C           XPRINT    ENDSR
      ******************************************************
      *                  INITIAL ROUTINE
      ******************************************************
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           @VLDAT  8
     C                     PARM           #ERFLG  1
     C                     PARM           #MSG1  80
     C                     PARM           #MSG2  80
      *
     C           K#PART    KLIST
     C                     KFLD           T4SHN1
     C                     KFLD           T4SHN2
     C                     KFLD           T4SHN3
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     MOVEL@VLDAT    K@VLDT  80
     C                     MOVE *ON       *INOF
     C                     MOVE *OFF      #ERFLG
     C                     MOVE *BLANK    #MSG1
     C                     MOVE *BLANK    #MSG2
     C                     Z-ADD0         SEQ     50
     C                     Z-ADD0         ERR#    50
     C                     Z-ADD0         NOM#    50
     C                     Z-ADD0         TTL#    50
     C                     Z-ADD0         LINE#   50
     C                     Z-ADD99        DTL#    50
      *
     C                     ENDSR
      *************************************************************
      *                    OUTPUT                                 *
      *************************************************************
     OQPRINT  E  102           HDR1
     O                                    8 'PROGRAM:'
     O                                   15 'FBER01'
     O                                   37 '(UPLOAD PROCESS COST)'
     O                                   60 '<< ERROR REPORT >>'
     O                                   73 '(VALID DATE='
     O                         @VLDAT    81
     O                                   82 ')'
     O                                  100 'DATE'
     O                         @DATE    111 '    .  .  '
     O                         @TIME    120 '  :  :  '
     O                         PAGE  Z  130
     O                                  126 'PAGE'
     O        E  1             HDR1
     O                                    5 'SEQ'
     O                                   11 'LINE'
     O                                   19 'MACHINE'
     O                                   27 'PROCESS'
     O                                   39 'PART NUMBER'
     O                                   52 'COST'
     O                                   64 'ERROR MSG'
     O        E  1             HDR1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
      *
     O        E  1             DTL1
     O                         SEQ   3    5
     O                         LINE# 3   11
     O                         T4MCN#    17
     O                         T4PROC    25
     O                         T4SHN1    33
     O                         T4SHN2    39
     O                         T4SHN3    42
     O                         T4COSTJ   53
     O                         XMSG      90
      *
     O        E  1             FOT1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
      *
     O        E  1             MAX1
     O                                   20 '** ERROR REPORT DOES'
     O                                   40 ' NOT PRINT OVER 5 PA'
     O                                   60 'GES ! **            '
      *
     O        E  1             FOT1
     O                                   18 '** TOTAL RECORDS:'
     O                         TTL#  3   23
     O                                   31 '(ERROR:'
     O                         SEQ   3   36
     O                                   40 ') **'
** TBL(80)  .......2.........3.........4.........5.........6.........7.........8
INVALID PART!
PART NOT FOUND IN PROCESS MASTER!
Error Does not Exist. Total xxxxx Rec. Enter G:Update or C:Cancel.
Error Found! Total Record: xxxxx, Error: xxxxx. Enter G:GO, C:Stop or D:Display
