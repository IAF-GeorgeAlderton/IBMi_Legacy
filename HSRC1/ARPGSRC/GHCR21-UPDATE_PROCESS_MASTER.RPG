      *-------------------------------*
      * SURFACE CHANGE                *
      *-------------------------------*
     CSR         #SB797    BEGSR
      *
     C                     Z-ADD1         #A      30
     C                     MOVEL'0'       #ERR    1
      *
     C           P9MECH    IFEQ '1'
      *
     C           #A        DOWLE15
     C           #ERR      ANDEQ'0'
     C           TP,#A     IFEQ '7'
     C           TP,#A     OREQ 'C'
     C           TP,#A     OREQ 'D'
     C           TP,#A     OREQ 'F'
     C           TP,#A     OREQ 'P'
     C           TP,#A     OREQ 'Q'
     C           HZ,#A     IFEQ #HZ,#A
     C                     MOVEL'1'       #ERR    1
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         #A
     C                     ENDDO
      *
     C                     ENDIF
      *
     C           #ERR      IFEQ '1'
     C                     SETON                     99
     C                     ENDIF
