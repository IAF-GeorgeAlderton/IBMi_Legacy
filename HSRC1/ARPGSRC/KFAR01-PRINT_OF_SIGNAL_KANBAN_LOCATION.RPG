     H            Y.
     F** KFAR01 **********************************
     F* PRINT OF SIGNAL KANBAN LOCATION  *
     F* PROGRAM ID. : KFAR01. <RPG> *
     F* CREATE DATE. : APR.04,'88.               *
     F* AUTHOR.         : G.B.C.                 *
     F********************************** KFAR01 **
     FKFAPW01 CF  E                    WORKSTN
     F                                              KNUM        1
     F                                              KINFDS FEEDBK
     FAAJTL16 IF  E           K        DISK
     FABHTL05 IF  E           K        DISK
     FKFAWP01 IF  E           K        DISK                      A
     E                    MSG     1   8 60               d[ｰxｮﾈｰﾆﾞ
     IFEEDBK      DS
     I                                     *STATUS  @STTS
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
     C                     MOVE *BLANK    BAN1X
     C                     MOVE *BLANK    BAN2X
     C                     MOVE *BLANK    BAN3X
     C                     MOVE *BLANK    BAN4X
      *
     C           STP0      TAG
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    BAN1
     C                     MOVE *BLANK    BAN2
     C                     MOVE *BLANK    BAN3
     C                     MOVE *BLANK    BAN4
     C                     MOVE *BLANK    ERR
      *
     C****************************************************************
     C*  EXFMT  <fﾞx] 1>                                             *
     C****************************************************************
     C           STP1      TAG
     C                     WRITEKFAPW011
     C                     READ KFAPW01                9999<TIME eｰﾌﾞｰ>
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
      *
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVE *BLANK    ERR
     C           *IN,99    IFEQ '1'
     C           @STTS     ANDEQ1331
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
      *
     C*  fﾞx] 1 ﾉ kｩｮh
     C*
     C           BAN1      IFEQ *BLANK
     C           BAN2      ANDEQ*BLANK
     C           BAN3      ANDEQ*BLANK
     C           BAN4      ANDEQ*BLANK
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     GOTO STP1
     C                     END
      *
     C                     Z-ADD0         CJBMON
     C                     MOVE *BLANK    CJCOCR
     C                     Z-ADD0         CJBRYO
     C                     Z-ADD9999      X9999   40
     C                     Z-ADD99        X99     20
     C           KEY1      KLIST
     C                     KFLD           BAN1
     C                     KFLD           BAN2
     C                     KFLD           BAN3
     C                     KFLD           BAN4
     C                     KFLD           X9999
     C                     KFLD           X99
     C                     KFLD           X99
     C           KEY1      CHAINAAJTL161             10
     C           *IN,10    IFEQ '1'
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERR
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE *BLANK    M6HIN1
     C                     MOVE *BLANK    M6HIN2
     C                     MOVE *BLANK    M6HIN3
     C                     MOVE *BLANK    M6KBN1
     C                     MOVE *BLANK    M6KBN2
     C                     MOVE *BLANK    M6KBN3
     C                     Z-ADD9999      X9999
     C                     Z-ADD99        X99
     C           KEY1      SETLLABHTL051
     C           XP1       TAG
     C                     SETOF                     10
     C           KEY1      READEABHTL051                 10
     C           *IN,10    IFEQ '0'
     C           M6SKJY    ANDEQ'D'
     C           M6SKHZ    ANDLE*DATE
     C                     GOTO XP1
     C                     END
     C           *IN,10    IFEQ '1'
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP1
     C                     END
      *
     C           M6DTKO    DOWEQ'2'
     C           KEY2      KLIST
     C                     KFLD           BAN1
     C                     KFLD           BAN2
     C                     KFLD           BAN3
     C                     KFLD           BAN4
     C           KEY2      READEABHTL051                 10
     C           *IN,10    IFEQ '0'
     C           M6SKJY    IFNE *BLANK
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6DTKO    CABNE'2'       STP2
     C                     END
     C                     END
     C  N10                END
      *
     C           STP2      TAG
     C           *IN,10    IFEQ '1'
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C           M6STHZ    IFLT *DATE
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERR
     C                     GOTO STP1
     C                     END
     C           M6STHZ    IFNE 99999999
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,7     ERR
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KEY2      SETLLKFAWP011                 10
     C           *IN,10    IFEQ '1'
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,8     ERR
     C                     GOTO STP1
     C                     END
      *
     C  NKE                GOTO STP1
      *
     C*  DATA OUTPUT  (jbﾎﾟ A)
     C*
     C                     MOVEL'1'       *INU1
     C                     Z-ADDCJBMON    KFBMON
     C                     MOVELBAN1      KFBAN1
     C                     MOVELBAN2      KFBAN2
     C                     MOVELBAN3      KFBAN3
     C                     MOVELBAN4      KFBAN4
     C                     MOVELCJCOCR    KFHICR
     C                     MOVELM6HIN1    KFHIN1
     C                     MOVELM6HIN2    KFHIN2
     C                     MOVELM6HIN3    KFHIN3
     C                     MOVELM6KBN1    KFKIB1
     C                     MOVELM6KBN2    KFKIB2
     C                     MOVELM6KBN3    KFKIB3
     C                     MOVEL'A'       KFYOTP
     C                     Z-ADD2         KFHIMS
     C                     WRITEKFAWP011
      *
     C*               (jbﾎﾟ B & C)
     C*
     C           CJBRYO    IFGT 1
     C                     MOVEL'1'       *INU2
     C                     MOVEL'B'       KFYOTP
     C           CJBRYO    SUB  1         KFHIMS
     C                     WRITEKFAWP011
     C                     WRITEKFAWP011
     C                     END
      *
     C                     MOVELBAN1      BAN1X
     C                     MOVELBAN2      BAN2X
     C                     MOVELBAN3      BAN3X
     C                     MOVELBAN4      BAN4X
     C                     GOTO STP0
**  MSG (ERROR MESSAGE )
E-01 WHEN IT DOESN'T USE LONG TIME SIGN OFF.
E-02 INPUT LOCATION
E-03 APPLICABLE DATA IS NOT IN LOCATION M/F
E-04 APPLICABLE DATA IS NOT IN INTRA-PROCESS KANBAN M/F
E-05 NO DATA EXCEPT UPD METHOD 2 IN INTRA-PROC KANBAN M/F
E-06 LAPSE OF INTRA-PROC KANBAN M/F IS SMALLER THAN SYS DATE
E-07 LAPSE DAY OF INTRA-PROCESS KANBAN M/F IS NOT 999999.
E-08 THIS LOCATION IS ALREADY INPUT
