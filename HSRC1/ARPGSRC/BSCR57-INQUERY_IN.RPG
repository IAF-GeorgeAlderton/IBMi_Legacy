     C           *ENTRY    PLIST
     C                     PARM           P1MTK1  1
     C                     PARM           P1MTK2  2
     C                     PARM           P1MTK3  2
     C                     PARM           P1MTK4  1
     C                     PARM           P1MT21  1
     C                     PARM           P1MT22  2
     C                     PARM           P1MT23  2
     C                     PARM           P1MT24  1
     C                     PARM           P1COH1  8
     C                     PARM           P1COH2  8
     C                     PARM           P1COUS 10
     C                     PARM           P1HNTE  1
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     MOVEL*BLANK    WKMTK
     C                     MOVELP1MTK1    WKMTK1
     C                     MOVELP1MTK2    WKMTK2
     C                     MOVELP1MTK3    WKMTK3
     C                     MOVELP1MTK4    WKMTK4
     C                     MOVEL*BLANK    C1MTK
     C           WKMTK     IFEQ *BLANK
     C                     ELSE
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELWKMTK1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELWKMTK2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELWKMTK3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELWKMTK4    WWMTK4
     C                     MOVELWWMTK     C1MTK
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKMTK
     C                     MOVELP1MT21    WKMTK1
     C                     MOVELP1MT22    WKMTK2
     C                     MOVELP1MT23    WKMTK3
     C                     MOVELP1MT24    WKMTK4
     C                     MOVEL*BLANK    C1MT2
     C           WKMTK     IFEQ *BLANK
     C                     ELSE
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELWKMTK1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELWKMTK2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELWKMTK3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELWKMTK4    WWMTK4
     C                     MOVELWWMTK     C1MT2
     C                     ENDIF
      *
     C                     MOVE P1COH1    C1COH1
     C                     MOVE P1COH2    C1COH2
      *
     C                     MOVEL*BLANK    C1COUS
     C           P1COUS    IFEQ *BLANK
     C                     MOVEL'ALL'     C1COUS
     C                     ELSE
     C                     MOVELP1COUS    C1COUS
     C                     ENDIF
      *
     C                     MOVEL*BLANK    C1HNTE
     C                     SELEC
     C           P1HNTE    WHEQ *BLANK
     C                     MOVEL'ALL'     C1HNTE
     C           P1HNTE    WHEQ '1'
     C                     MOVEL'OK '     C1HNTE
     C           P1HNTE    WHEQ '2'
     C                     MOVEL'NG '     C1HNTE
     C                     ENDSL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *データ検索                                        *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           1         SETLLBSCWP551
     C                     READ BSCWP551                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ BSCWP551                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *   第二画面処理                                   *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEBSCPW579
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '03'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F10 CSV
     C           *IN10     IFEQ '1'
     C                     CALL 'BSCC58'
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTBSCWP551
     C                     READPBSCWP551                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  12        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPBSCWP551                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           1         SETLLBSCWP551
     C                     READ BSCWP551                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ BSCWP551                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ BSCWP551                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      * CHECK
     C                     SETOF                     3199
     C                     Z-ADD1         X       20
     C                     Z-ADD0         WKSEL   20
     C           X         DOWLE12
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C           *IN99     ANDEQ'0'
     C                     SETOF                     31
     C                     EXSR #SB221
     C                     MOVELH139      *IN,39
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK SFL                                          *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'M'
     C                     MOVELH1RDHZ    D2RDHZ
     C                     MOVELH1RDTI    D2RDTI
     C                     MOVELH1JUDG    D2JUDG
     C                     MOVELH1BAR1    D2BAR1
     C                     MOVELH1AT1     D2AT1
     C                     MOVELH1BAR2    D2BAR2
     C                     MOVELH1AT2     D2AT2
     C                     MOVELH1SHN     D2SHN
     C                     MOVELH1KO      D2KO
     C                     EXFMTBSCPW572
     C                     MOVEL*BLANK    S1SEL
     C                     OTHER
     C                     MOVELER,2      D9ERR
     C                     SETON                     3199
     C                     ENDSL
      *
     CSR         ESB221    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 12
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      *   検索ファイル逆読み                             *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      *   検索条件判定                                   *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      *   表示項目＆サブファイルクリアー                 *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      *   編集処理                                       *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVELW5RD      S1COHZ
     C                     MOVEL*BLANK    S1MTK
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELW5TBN1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELW5TBN2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELW5TBN3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELW5TBN4    WWMTK4
     C                     MOVELWWMTK     S1MTK
     C                     MOVEL*BLANK    S1SHN
     C                     MOVEL*BLANK    WWSHN
     C                     MOVELW5LHN1    WWSHN1
     C                     MOVEL'-'       WWSF1
     C                     MOVELW5LHN2    WWSHN2
     C                     MOVEL'-'       WWSF2
     C                     MOVELW5LHN3    WWSHN3
     C                     MOVELWWSHN     S1SHN
     C                     MOVEL*BLANK    S1KO
     C           W5WOKR    CHAINRGAPL111             28
     C           *IN28     IFEQ '0'
     C                     MOVELJ8NAME    S1KO
     C                     ENDIF
      *
     C                     SETOF                     39
     C                     MOVEL'0'       H139
     C           W5OKNG    IFEQ 'NG'
     C                     SETON                     39
     C                     MOVEL'1'       H139
     C                     ENDIF
     C                     MOVELW5CODT    H1RDHZ
     C                     MOVELW5COTM    H1RDTI
     C                     MOVELW5OKNG    H1JUDG
     C                     MOVELW5LBAR    H1BAR1
     C                     MOVELS1MTK     H1AT1
     C                     MOVELW5ABAR    H1BAR2
     C                     MOVELW5AZET    H1ZET2
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELW5ABN1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELW5ABN2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELW5ABN3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELW5ABN4    WWMTK4
     C                     MOVELWWMTK     H1AT2
     C                     MOVELS1SHN     H1SHN
     C                     MOVELS1KO      H1KO
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      *   次データ                                       *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ BSCWP551                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      *   前データ                                       *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
