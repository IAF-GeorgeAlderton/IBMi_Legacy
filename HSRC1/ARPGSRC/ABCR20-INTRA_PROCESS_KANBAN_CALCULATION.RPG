     C           *ENTRY    PLIST
     C                     PARM           PBMN    4        部門
     C                     PARM           PHN1    5        品番・１
     C                     PARM           PHN2    5        　　・２
     C                     PARM           PHN3    2        　　・３
     C                     PARM           PKS1    1        計算区分１
     C                     PARM           PKS2    1        　　　　２
     C                     PARM           PKTS    9        確定設定数
     C                     PARM           PSYU    7        自工程収容数
     C                     PARM           PGLT    4        合計Ｌ・Ｔ
     C                     PARM           PANZ    3        安全率
     C                     PARM           PBRA    3        バラツキ箱数
     C                     PARM           PSET    3        セット数
     C                     PARM           PALT    2        後工程ロット
     C                     PARM           PBN1    1        所番地・１
     C                     PARM           PBN2    2        　　　・２
     C                     PARM           PBN3    2        　　　・３
     C                     PARM           PBN4    1        　　　・４
     C                     PARM           PUYY    4        有効日　年
     C                     PARM           PUMM    2        有効日　月
     C                     PARM           PUDD    2        有効日　日
     C                     PARM           PUBN    2        有効日　便
     C                     PARM           PKJY    3        基準値
     C                     PARM           PLOT    3        生産ロット
     C                     PARM           PMIS    5        かんばん枚数
     C                     PARM           PERR    1        エラー
      *
     C                     MOVELPBMN      WBMN    40
     C                     MOVELPHN1      WHN1    5
     C                     MOVELPHN2      WHN2    5
     C                     MOVELPHN3      WHN3    2
     C                     MOVELPKS1      WKS1    1
     C                     MOVELPKS2      WKS2    1
     C                     MOVELPKTS      WKTS    90
     C                     MOVELPSYU      WSYU    70
     C                     MOVELPGLT      WGLT    42
     C                     MOVELPANZ      WANZ    32
     C                     MOVELPBRA      WBRA    30
     C                     MOVELPSET      WSET    30
     C                     MOVELPALT      WALT    20
     C                     MOVELPBN1      WBN1    1
     C                     MOVELPBN2      WBN2    2
     C                     MOVELPBN3      WBN3    2
     C                     MOVELPBN4      WBN4    1
     C                     MOVELPUYY      WUYY    40
     C                     MOVELPUMM      WUMM    20
     C                     MOVELPUDD      WUDD    20
     C                     MOVELPUBN      WUBN    20
     C                     MOVELPKJY      WKJY    30
     C                     MOVELPLOT      WLOT    30
     C                     MOVELPMIS      WMIS    50
     C                     MOVELPERR      WERR    1
      ****************************************************************
      *  KEY                                                 MAIN    *
      ****************************************************************
     C           KEY1      KLIST
     C                     KFLD           WBN1
     C                     KFLD           WBN2
     C                     KFLD           WBN3
     C                     KFLD           WBN4
      *
     C           KEY2      KLIST
     C                     KFLD           WBMN
     C                     KFLD           WKS2
      *
     C           KEY3      KLIST
     C                     KFLD           WHN1
     C                     KFLD           WHN2
     C                     KFLD           WHN3
      *
     C           KEY4      KLIST
     C                     KFLD           @BNT1
     C                     KFLD           @BNT2
     C                     KFLD           @BNT3
     C                     KFLD           @BNT4
      ****************************************************************
      * 計算式の振り分け MAIN
      ****************************************************************
      *
     C                     EXSR ESUB
      ****************************************************************
      * （セット枚数ー１）を足す
      ****************************************************************
     C                     Z-ADD0         XSET    50
     C           WSET      IFGE 1
     C           WSET      SUB  1         XSET
     C                     ENDIF
     C           WMIS      ADD  XSET      WMIS
      ****************************************************************
      * MOVE *
     C                     MOVELWBMN      PBMN
     C                     MOVELWHN1      PHN1
     C                     MOVELWHN2      PHN2
     C                     MOVELWHN3      PHN3
     C                     MOVELWKS1      PKS1
     C                     MOVELWKS2      PKS2
     C                     MOVELWKTS      PKTS
     C                     MOVELWSYU      PSYU
     C                     MOVELWGLT      PGLT
     C                     MOVELWANZ      PANZ
     C                     MOVELWBRA      PBRA
     C                     MOVELWSET      PSET
     C                     MOVELWALT      PALT
     C                     MOVELWBN1      PBN1
     C                     MOVELWBN2      PBN2
     C                     MOVELWBN3      PBN3
     C                     MOVELWBN4      PBN4
     C                     MOVELWUYY      PUYY
     C                     MOVELWUMM      PUMM
     C                     MOVELWUDD      PUDD
     C                     MOVELWUBN      PUBN
     C                     MOVELWKJY      PKJY
     C                     MOVELWLOT      PLOT
     C                     MOVELWMIS      PMIS
     C                     MOVELWERR      PERR
      *
     C                     SETON                     LR
     C                     RETRN
      *==============================================================*
      *                                                              *
      *==============================================================*
     C           ESUB      BEGSR
      *日当り箱数*
     C                     Z-ADD0         WRK1   103
     C                     Z-ADD0         @D      73
     C           WKTS      DIV  20        WRK1
     C           WSYU      IFNE 0
     C           WRK1      DIV  WSYU      @D        H
     C                     END
      *引取単位*
     C                     Z-ADDWALT      @H      50
      *仮ロット*
     C                     Z-ADD0         @KLOT   30
     C           WKS2      IFNE 'Z'
     C                     SETOF                     30
     C           KEY2      CHAINBAHPL011             30
     C           *IN30     IFEQ '0'
     C           BASKJY    ANDEQ'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C           1         DO   8         A
     C           HIU,A     IFNE 0
     C           HIS,A     ANDEQ0
     C                     Z-ADD99.99     HIS,A
     C                     END
     C                     END
      *
     C                     SETOF                     30
     C                     Z-ADD1         A       20
     C           1         DO   8         A
     C           HIU,A     IFLE @D
     C           HIS,A     IFGT @D
     C           HIS,A     OREQ 99.99
     C                     Z-ADDLOT,A     @KLOT
     C                     SETON                     30
     C                     END
     C                     END
     C  N30                END
      *
     C                     END
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｓ＂     NOT USED                        *
      ****************************************************************
     C           WKS1      IFEQ 'S'
      **********
      *基準値*
      **********
     C           WKS2      IFNE 'Z'
     C                     Z-ADD0         WKJY
     C                     Z-ADD0         WRK3    93
     C                     Z-ADD0         WRK3A   70
      *
     C           @D        MULT WGLT      WRK3
     C                     MULT WANZ      WRK3
      *
     C           @H        IFNE 0
     C                     DIV  @H        WRK3
     C                     END
     C           WRK3      ADD  .999      WRK3A
     C                     MULT @H        WRK3A
     C           WRK3A     ADD  WBRA      WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADD0         WLOT
     C                     Z-ADD0         WRK4    41
     C                     Z-ADD0         WRK5    30
      *
     C           @H        IFNE 0
     C           @KLOT     DIV  @H        WRK4
     C           WRK4      IFLT 1
     C                     Z-ADD1         WRK5
     C                     ELSE
     C                     Z-ADDWRK4      WRK5
     C                     END
     C           WRK5      MULT @H        WLOT
     C                     END
      *
     C           WLOT      IFLT WKJY
     C                     Z-ADDWKJY      WLOT
     C                     END
      *
     C                     END
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADD1         WMIS
     C                     GOTO SEND1
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｒ＂    ALMOST USING                     *
      ****************************************************************
1    C           WKS1      IFEQ 'R'
|     **********
|     *基準値*
|     **********
|    C                     Z-ADD0         WKJY
|     **************
|     *生産ロット*
|     **************
|2   C           WKS2      IFNE 'Z'
||   C                     Z-ADD0         WLOT
||   C                     Z-ADD0         WRK4    41
||   C                     Z-ADD0         WRK5    30
||    *
||3  C           @H        IFNE 0
|||  C           @KLOT     DIV  @H        WRK4
|||4 C           WRK4      IFLT 1
|||| C                     Z-ADD1         WRK5
|||4 C                     ELSE
|||| C                     Z-ADDWRK4      WRK5
|||4 C                     END
|||  C           WRK5      MULT @H        WLOT
|||  C                     ADD  WBRA      WLOT
||3  C                     END
||    *
|2   C                     END
|     ****************
|     *かんばん枚数*
|     ****************
|    C                     Z-ADD0         WMIS
|    C                     Z-ADD0         WRK6    30
|    C                     Z-ADD0         WRK7    30
|    C                     Z-ADD0         WRK8    83
|     *
|    C           WLOT      SUB  4         WRK6
|     *
|    C           @D        MULT WGLT      WRK8
|    C                     MULT WANZ      WRK8
|    C                     ADD  WRK6      WRK8
|     *
|2   C           WLOT      IFEQ 0
||   C                     Z-ADD0         WRK8
|2   C                     ELSE
||   C                     DIV  WLOT      WRK8
|2   C                     END
|     *
|    C           WRK8      ADD  0.999     WMIS
|     *
|    C                     GOTO SEND1
1    C                     END
      ****************************************************************
      * 後工程ロット　＆　かんばん枚数     NOT USED                *
      ****************************************************************
     C           WKS1      IFEQ 'E'
     C           WKS1      OREQ 'F'
     C           WKS1      OREQ 'Y'
      *社内かんばん切替マスター*
     C                     MOVE *BLANK    TKR
     C                     MOVE *BLANK    @BNTC
     C                     Z-ADD0         WRK9    30
     C                     Z-ADD0         WRK10   50
      *
     C                     SETOF                     30
     C           KEY3      CHAINAAMPL111             30
      *
     C           *IN30     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD1         X       20
     C                     Z-ADD0         L       20
     C           1         DO   15        X
     C                     MOVELNUKH,X    WUKH    80
     C           WUKH      IFGT @UHZ
     C           OTKR,X    IFNE *BLANK
     C           OTKR,X    ANDNE'------'
     C           OTKR,X    ANDNE'++++++'
     C                     ADD  1         L
     C                     MOVE OTKR,X    TKR,L
     C                     END
     C                     ELSE
     C           NTKR,X    IFNE *BLANK
     C           NTKR,X    ANDNE'------'
     C           NTKR,X    ANDNE'++++++'
     C                     ADD  1         L
     C                     MOVE NTKR,X    TKR,L
     C                     END
     C                     END
     C                     END
      *
     C                     END
     C                     END
      *
     C           L         IFEQ 0
     C                     MOVE '1'       WERR
     C                     GOTO SEND1
     C                     END
      *後工程番地*
     C                     Z-ADD1         X
     C                     SETOF                     30
     C           WBNTC     LOKUPTKR,X                    30
     C           *IN30     IFEQ '1'
     C                     ADD  1         X
     C                     MOVELTKR,X     @BNTC
     C                     END
      *
     C           @BNTC     IFEQ *BLANK
     C                     MOVE '1'       WERR
     C                     GOTO SEND1
     C                     END
      *焼入かんばんマスター*
     C           KEY4      SETLLADHPL031
     C                     SETOF                     30
     C                     DO   *HIVAL
     C           KEY4      READEADHPL031                 30
     C           *IN30     IFEQ '0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           @UHZ      IFLE J6STHZ
     C                     Z-ADDJ6LOTO    WRK9
     C                     Z-ADDJ6KMAX    WRK10
     C                     END
     C                     END
     C                     END
     C  N30                END
      *
     C                     END
      ** ERR-1 **
     C           WRK9      IFEQ 0
     C                     MOVE '1'       WERR
     C                     GOTO SEND1
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｅ＂OR”Ｙ”    NOT USED               *
      ****************************************************************
     C           WKS1      IFEQ 'E'
     C           WKS1      OREQ 'Y'
      **********
      *基準値*
      **********
     C                     Z-ADD0         WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADDWRK9      WLOT
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADDWRK10     WMIS
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｆ＂                                     *
      ****************************************************************
     C           WKS1      IFEQ 'F'
      **********
      *基準値*
      **********
     C                     Z-ADD0         WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADDWRK9      WLOT
      ****************
      *かんばん枚数*
      ****************
     C           WRK10     DIV  WRK9      WMIS
     C                     END
      *
      ****************************************************************
     C           SEND1     ENDSR
