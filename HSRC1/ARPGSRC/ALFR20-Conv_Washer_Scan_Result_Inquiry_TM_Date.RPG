     H            Y.                                    1
     H***ALFR20*****************************************************************
     H*  CONVEYANCE WASHER PULLING RESILT INQUIRY TM,DATE                      *
     H*
     H* TCHK1 10/21/10 CREATE(COPY FROM ALCR20)
     H* TCHK2 09/25/12 ADD RK-METAL
     H**************************************************************************
     FALFPW20 CF  E                    WORKSTN
     F                                        RRN2  KSFILE SFL020
     F                                        RRN3  KSFILE SFL030
     F                                              KINFDS @INFDS
     FALFPP01 IF  E           K        DISK
     FALFPL02 IF  E           K        DISK
     F            ALFPP011                          KRENAMEALFPL02R
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FALFWP20 UF  E           K        DISK                      A
      **************************************************************************
     E                    ERR     1  10 70
     E                    CMD     1   1 70
      **************************************************************************
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I* SCANNED FROM DATE
     I            DS
     I                                        1   80F1SCFH
     I                                        1   40F1SCFY
     I                                        5   60F1SCFM
     I                                        7   80F1SCFD
     I            DS
     I                                        1   80W1SCFH
     I                                        1   40W1SCFY
     I                                        5   60W1SCFM
     I                                        7   80W1SCFD
     I*         FROM DATE -1 DAYS
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I* SCANNED TO DATE
     I            DS
     I                                        1   80F1SCTH
     I                                        1   40F1SCTY
     I                                        5   60F1SCTM
     I                                        7   80F1SCTD
     I            DS
     I                                        1   80W1SCTH
     I                                        1   40W1SCTY
     I                                        5   60W1SCTM
     I                                        7   80W1SCTD
     I* SCANNED RESULT DATE
     I            DS
     I                                        1   80A8DATE
     I                                        1   40A8DTYY
     I                                        5   80A8DTMD
     I* SCANNED RESULT TIME
     I            DS
     I                                        1   60A8TIME
     I                                        1   20A8TIHH
     I                                        3   40A8TIMM
     I                                        5   60A8TISS
     I            DS
     I                                        1   5 W8TIME
     I                                        1   2 W8TIHH
     I                                        3   3 W8@DY1
     I                                        4   5 W8TIMM
     I* PART#
     I            DS
     I                                        1  15 W@PART
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     I* LOCATION
     I            DS
     I                                        1   9 W@LOC
     I                                        1   1 W@LOC1
     I I            '-'                       2   2 W@LOCA
     I                                        3   4 W@LOC2
     I I            '-'                       5   5 W@LOCB
     I                                        6   7 W@LOC3
     I I            '-'                       8   8 W@LOCC
     I                                        9   9 W@LOC4
     I*
     I            DS
     I                                        1  15 W@BAR
     I                                        2  15 W@BARA
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
     C*
     C                     Z-ADD*ZERO     F1SCFY
     C                     Z-ADD*ZERO     F1SCFM
     C                     Z-ADD*ZERO     F1SCFD
     C                     Z-ADD*ZERO     F1SCTY
     C                     Z-ADD*ZERO     F1SCTM
     C                     Z-ADD*ZERO     F1SCTD
     C                     MOVEL*BLANK    MSG
     C*
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL*OFF      *IN49
     C*
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN(SCAN DATE)
     C**************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     4748
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN49     IFEQ *OFF
     C                     EXSR #SET20
     C                     END
     C           *IN49     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     ELSE
     C                     MOVEL'20'      @@ID
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN CHECK
     C**************************************************************************
     C           #CHK10    BEGSR
     C*
     C                     SETOF                     313249
     C                     TIME           WSDT
     C*
     C           F1SCFH    IFEQ *ZERO
     C           F1SCFH    ORGT WSSDAT
     C                     SETON                     3149
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,1     MSG
     C                     END
     C                     END
     C                     Z-ADDF1SCFH    W1SCFH
     C*
     C           F1SCTH    IFEQ *ZERO
     C                     Z-ADDW1SCFH    W1SCTH
     C                     ELSE
     C                     Z-ADDF1SCTH    W1SCTH
     C                     END
     C*
     C           W1SCFD    IFEQ *ZERO
     C                     Z-ADD01        W1SCFD
     C                     END
     C           W1SCTD    IFEQ *ZERO
     C           K#AGDA    KLIST
     C                     KFLD           W1SCTY
     C                     KFLD           W1SCTM
     C           K#AGDA    SETGTAGDPL12
     C           K#AGDA    REDPEAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KADD    W1SCTD
     C                     ELSE
     C                     Z-ADD31        W1SCTD
     C                     END
     C                     END
     C*
     C           W1SCFH    IFGT W1SCTH
     C                     SETON                     313249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C*
     C*
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN SET
     C**************************************************************************
     C           #SET20    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     Z-ADD*ZERO     C2ACNT
     C                     Z-ADD*ZERO     C2FCNT
     C                     Z-ADD*ZERO     C2RCNT
     C*
     C                     CLOSEALFWP20
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN ALFWP20
     C*
     C                     DO
     C*
     C           K#AGDP    KLIST
     C                     KFLD           W1SCFY
     C                     KFLD           W1SCFM
     C                     KFLD           W1SCFD
     C           K#AGDP    SETLLAGDPL12
     C                     READPAGDPL12                  98
     C   98                LEAVE
     C*
     C                     Z-ADDF8KAHZ    W1SCFH
     C*
     C           K#P01A    KLIST
     C                     KFLD           F8KAHZ
     C                     KFLD           K@TIME  60
     C                     Z-ADD230000    K@TIME
     C           K#P01A    SETLLALFPP01
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALFPP01                  97
     C   97                LEAVE
     C           A8ERR     IFNE *BLANK
     C                     ITER
     C                     END
     C           A8DATE    IFEQ W1SCTH
     C           A8TIME    ANDGE230000
     C                     LEAVE
     C                     END
     C           A8DATE    IFGT W1SCTH
     C                     LEAVE
     C                     END
     C*
     C           A8TMCD    CHAINALFWP20              96
     C           *IN96     IFEQ *ON
     C                     CLEARALFWP201
     C                     MOVELA8TMCD    W20TMC
     C                     MOVELA8TMCD    W@@06N  60
     C           W@@06N    CHAINALBPL30              95
     C           *IN95     IFEQ *OFF
     C                     MOVELALWKNM    W20TMN
     C                     END
     C                     END
     C*
     C           A8BRC2    IFNE *BLANK
     C                     ADD  1         W20ABX
     C                     END
     C           A8BRC3    IFNE *BLANK
     C                     ADD  1         W20FBX
     C                     END
     C           A8BRC5    IFNE *BLANK
     C                     ADD  1         W20RBX
     C                     END
     C*
     C  N96                UPDATALFWP201
     C   96                WRITEALFWP201
     C*
     C                     ENDDO
     C*
     C           *LOVAL    SETLLALFWP20
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALFWP20                  94
     C   94                LEAVE
     C*
     C                     CLEARSFL020
     C                     MOVELW20TMN    S2TMNM
     C                     Z-ADDW20ABX    S2ACNT
     C                     Z-ADDW20FBX    S2FCNT
     C                     Z-ADDW20RBX    S2RCNT
     C                     MOVELW20TMC    H2TMCD
     C*
     C                     ADD  W20ABX    C2ACNT
     C                     ADD  W20FBX    C2FCNT
     C                     ADD  W20RBX    C2RCNT
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL020
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     SETON                     313249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,3     MSG
     C                     END
     C                     END
     C*
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN
     C**************************************************************************
     C           #FMT20    BEGSR
      *
     C                     Z-ADD1         W#RNP2  40
      *
     C                     DO   *HIVAL
     C*
     C                     MOVEL*OFF      *IN47
     C                     MOVEL*ON       *IN48
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKL     WHEQ *ON
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     OTHER
     C                     EXSR #CHK20
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C                     END
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*     2ND SCREEN CHECK
     C**************************************************************************
     C           #CHK20    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN2
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL020               93
     C   93                LEAVE
     C*
     C           S2SEL     IFNE *BLANK
     C                     MOVEL*ON       *IN52
     C                     MOVEL*BLANK    S2SEL
     C                     UPDATSFL020
     C                     MOVEL*OFF      *IN52
     C                     EXSR #SET30
     C                     EXSR #FMT30
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C                     END
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     MOVEL*BLANK    S2SEL
     C                     UPDATSFL020
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*************************************************************************
     C*     3RD SCREEN SET
     C**************************************************************************
     C           #SET30    BEGSR
     C*
     C                     MOVEL*ON       *IN61
     C                     WRITECTL030
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN3    40
     C*
     C                     MOVEL*ON       *IN63
     C                     MOVEL*OFF      *IN71
     C*
     C                     MOVELS2TMNM    C3TMNM
     C                     Z-ADDS2ACNT    C3ACNT
     C                     Z-ADDS2FCNT    C3FCNT
     C                     Z-ADDS2RCNT    C3RCNT
     C*
     C           K#L02A    KLIST
     C                     KFLD           H2TMCD
     C                     KFLD           W1SCFH
     C                     KFLD           K@TIME
     C                     Z-ADD230000    K@TIME
     C           K#L02A    SETLLALFPL02
     C*
     C                     DO   *HIVAL
     C*
     C           H2TMCD    READEALFPL02                  97
     C   97                LEAVE
     C           A8ERR     IFNE *BLANK
     C                     ITER
     C                     END
     C           A8DATE    IFEQ W1SCTH
     C           A8TIME    ANDGE230000
     C                     LEAVE
     C                     END
     C           A8DATE    IFGT W1SCTH
     C                     LEAVE
     C                     END
     C*
     C                     CLEARSFL030
     C*
     C                     Z-ADDA8DTMD    S3DATE
     C                     MOVELA8TIHH    W8TIHH
     C                     MOVEL':'       W8@DY1
     C                     MOVELA8TIMM    W8TIMM
     C                     MOVELW8TIME    S3TIME
     C*
     C                     MOVELA8B1L1    W@LOC1
     C                     MOVELA8B1L2    W@LOC2
     C                     MOVELA8B1L3    W@LOC3
     C                     MOVELA8B1L4    W@LOC4
     C                     MOVELW@LOC     S3LOC
     C           A8DKND    IFEQ 'A'
     C                     MOVEL'ASJ '    S3KIND
     C                     MOVEL*OFF      *IN71
     C                     ELSE
TCHK2C           A8DKND    IFEQ 'F'
     C                     MOVEL'FRWY'    S3KIND
TCHK2C                     ELSE
TCHK2C           A8DKND    IFEQ 'R'
TCHK2C                     MOVEL'RKMT'    S3KIND
TCHK2C                     END
TCHK2C                     END
     C                     MOVEL*ON       *IN71
     C                     END
     C*
     C                     MOVEL*BLANK    W@PART
     C                     MOVELA8PRT1    W@PRT1
     C           A8PRT2    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C                     MOVELA8PRT2    W@PRT2
     C           A8PRT3    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELA8PRT3    W@PRT3
     C                     MOVELW@PART    S3SHIN
     C*
     C                     MOVELA8BRC1    S3BAR1
     C           A8BRC2    IFNE *BLANK
     C                     MOVELA8BRC2    S3BAR2
     C                     ELSE
     C                     MOVELA8BRC3    S3BAR2
     C                     END
     C*
     C                     MOVELA8BRC4    W@BAR
     C                     MOVELW@BARA    S3HIN3
     C                     MOVELA8BRC4    S3BAR3
     C                     MOVELA8BRC5    S3BAR4
     C*
     C                     ADD  1         RRN3
     C                     WRITESFL030
     C*
     C                     ENDDO
     C*
     C                     MOVEL*OFF      *IN71
     C*
     C                     ENDSR
     C*************************************************************************
     C*     3RD SCREEN(TM,DATE DETAIL)
     C**************************************************************************
     C           #FMT30    BEGSR
     C*
     C                     Z-ADD1         W#RNP3  40
     C                     MOVEL*OFF      *IN49
     C*
     C                     DO   *HIVAL
     C*
     C                     SETON                     4748
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL030
     C   KA
     COR KL                LEAVE
     C*
     C  NKJ                MOVELN#MOD3    *IN63
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP3
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
** ERR
DATE ERROR
FROM DATE  >  TO DATE
NO DATA FOUND!







** CMD
CLRPFM QTEMP/ALFWP20
