      *
     O        E  1             DT
     O                 15      IZAIS     17
     O                 15      IZAIK     26 ' 0 .  '
     O                 15                35 'IAF-'
     O                 15      IODR1     37
     O                 15                38 '-'
     O                 15      IODR2     40
     O                 15                41 '-'
     O                 15      IODR3     43
     O                 15      IITEM     51
     O                 15      IODHZ     64 '    /  /  '
     O                 15      IMAIS     70 ' 0 '
     O                N20      IVOS1     75
     O                N20                76 '-'
     O                N20      IVOS2     80
