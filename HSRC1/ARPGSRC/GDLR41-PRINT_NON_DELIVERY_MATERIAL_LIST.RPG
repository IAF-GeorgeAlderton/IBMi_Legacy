     H            Y.                                    1
      ** GDLR41 ****************************
      *  PRINT NON-DELIVERY MATERIAL LIST  *
      *              K.YASUDA  2000.11.21  *
      **************************** GDLR41 **
     FGDLWP4B IP  F     128            DISK
     FGDLPL32 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     IGDLWP4B AA  01
     I                                        1   40ISIRE L2
     I                                        5  19 IZAIS L1
     I                                       20  242IZAIK L1
     I                                       25  300IODER L1
     I                                       25  260IODR1
     I                                       27  280IODR2
     I                                       29  300IODR3
     I                                       31  350IITEM L1
     I                                       36  380IMAIS
     I                                       39  460IODHZ
     I*                                      47  490ISYMA
     I*                                      50  520IMIMA
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I            DS
     I                                        1   80LESKHZ
     I                                        1   40LESKYY
     I                                        5   60LESKMM
     I                                        7   80LESKDD
      *
     I            DS
     I                                        1   80LESYHZ
     I                                        1   40LESKOY
     I                                        5   60LESKOM
     I                                        7   80LESKOD
      *
     I            DS
     I                                        1   80LEINHZ
     I                                        1   40LEINSY
     I                                        5   60LEINSM
     I                                        7   80LEINSD
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C                     MOVE *BLANK    WUSER   9
     C                     MOVE *BLANK    WUSME  15
     C                     CALL 'APLR00'
     C                     PARM           US
     C                     PARM           WUSME
     C                     MOVELWUSME     WUSER
      *------*
      * KEY1 *
      *------*
     C           KEY1      KLIST
     C                     KFLD           ISIRE
     C                     KFLD           IZAIS
     C                     KFLD           IZAIK
     C                     KFLD           IODR1
     C                     KFLD           IODR2
     C                     KFLD           IODR3
     C                     KFLD           IITEM
      *-----*
      * INZ *
      *-----*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     TIME           WTIME   60
     C                     MOVE *BLANK    IVOS1   2
     C                     Z-ADD0         IVOS2   40
     C                     MOVE *BLANK    IPTCD   1
     C                     Z-ADD0         ICASE   50
     C                     Z-ADD0         IJRYO   40
     C                     Z-ADD0         ISPHZ   80
     C                     Z-ADD0         IINHZ   80
     C                     Z-ADD0         IREMA   30
     C                     Z-ADD0         ISYMA   30
     C                     END
      *
     C           *INL2     IFEQ '1'
     C                     MOVE *BLANK    WSIRE  16
     C                     SETOF                     10
     C           ISIRE     CHAINFGBPL011             10
      *
     C           *IN10     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELB2SMEI    WSIRE
     C                     END
     C                     END
     C                     EXCPTHD
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     SETOF                     OF
     C                     SETON                     15
     C                     EXCPTHD
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     SETON                     15
     C                     END
      *
     C                     SETOF                     30
     C           KEY1      SETLLGDLPL321
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEGDLPL32                  20
      *
     C           *IN30     IFEQ '0'
     C           *IN20     IFEQ '1'
     C                     SETON                     30
     C                     EXCPTDT
     C                     END
     C                     END
      *
     C           *IN20     IFEQ '0'
     C           LESKJY    IFEQ 'D'
     C           LESKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     30
     C                     MOVELLEINV1    IVOS1
     C                     MOVELLEINV2    IVOS2
     C                     MOVELLEPTCD    IPTCD
     C                     MOVELLECASE    ICASE
     C                     MOVELLEJURY    IJRYO
     C                     MOVELLESYHZ    ISPHZ
     C                     MOVELLEINHZ    IINHZ
     C                     ADD  1         ISYMA
     C           LEINHZ    IFNE 0
     C                     ADD  1         IREMA
     C                     END
     C           *INOF     IFEQ '1'
     C                     SETOF                     OF
     C                     SETON                     15
     C                     EXCPTHD
     C                     END
     C                     EXCPTDT
     C                     SETOF                     15
     C                     END
     C                     END
     C  N20                ENDDO
      *
     CL1                   Z-ADD0         IMIMA   30
     CL1         IMAIS     SUB  ISYMA     IMIMA
     CL1                   EXCPTTL
     CL1                   MOVE *BLANK    IVOS1
     CL1                   Z-ADD0         IVOS2
     CL1                   MOVE *BLANK    IPTCD
     CL1                   Z-ADD0         ICASE
     CL1                   Z-ADD0         IJRYO
     CL1                   Z-ADD0         ISPHZ
     CL1                   Z-ADD0         IINHZ
     CL1                   Z-ADD0         IREMA
     CL1                   Z-ADD0         ISYMA
     OQPRINT  E  103           HD
     O                                  131 '､､､､､､､､､､､､､､､､､､､､､'
      *
     O        E  1             HD
     O                                  131 '､         ､         ､'
      *
      *
     O        E  1             HD
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  111 '､'
     O                                  121 '､'
     O                         WUSER    130
     O                                  131 '､'
      *
     O        E  2             HD
     O                         ISIRE      5
     O                                    7 '-'
     O                         WSIRE     24
     O                                   46 '** MATERIAL'
     O                                   67 'NON-DELIVERY LIST **'
     O                                   89 'DATE'
     O                         UDATE     98 '  .  .  '
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '､､､､､､､､､､､､､､､､､､､､､'
      *
     O        E  1             HD
     O                                   19 'ORDER INFORMATION'
