     O                                  132 'RECEIVIMG INFO--'
      *
     O        E  1             HD
     O                                    6 'WIRE'
     O                                   24 'WIRE'
     O                                   38 'ORDER #'
     O                                   52 'ITEM #'
     O                                   64 'ORDER DATE'
     O                                   71 'ORDER'
     O                                   81 'INVOICE#'
     O                                   89 'CASE #'
     O                                   98 'WEIGHT'
     O                                  110 'SHIPPING'
     O                                  125 'RECEIVING'
      *
     O        E  1             HD
     O                                   28 'DIAMETER'
     O                                   70 'COIL'
     O                                  106 'DATE'
     O                                  120 'DATE'
      *
     O        E  1             HD
     O                                   19 '-----------------'
