     F********************************** MFAR05 *********
     FMFAWP05 IP  F     128            DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     IMFAWP05 NS  01
     I                                        1   40@KOJO L2
     I                                        5   5 SKBN
     I                                        6   6 BUKA  L1
     I                                        7   7 KAKA  L1
     I                                        8  10 KBN1
     I                                       11  11 KBN2
     I                                       14  190HIZU
     I                                       20  22 OKB1
     I                                       23  23 OKB2
     I                                       24  26 KGUN
     I                                       27  29 KOTE
     I                                       30  33 SYS1
     I                                       34  37 SYS2
     I                                       38  39 COS1
     I                                       40  41 COS2
     I                                       42  43 COS3
     I                                       44  53 KEIS
     I                                       54  590RPMH
     I                                       60  642YOKW
     I                                       65  691YOLL
     I                                       70  71 YOCD
     I                                       72  762GASM
     I                                       77  78 GACD
     I                                       79  88 KEIS
     I                                       89  920MEKA
     I                                       93  93 JTKB
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C******************************************************
     C*  START PROGRAM  <MFAR05>                           *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PKJ     4
     C                     PARM           PKBN    1
     C                     PARM           PLST    1
     C                     MOVELPKJ       KOJO    40
     C*
     C  N01                GOTO @END
     C*
B001 C           *IN90     IFEQ '0'
     C                     MOVEL'1'       *INOF
     C                     MOVEA'1'       *IN,90
     C                     Z-ADD0         CNT     40
     C                     Z-ADD0         DAIS    30
     C                     Z-ADD0         GYOKW   72
     C                     Z-ADD0         GYOLL   71
     C                     Z-ADD0         GGASM   52
E001 C                     END
     C******************************************************
     C*  LET'S  PRINT-OUT                                  *
     C******************************************************
B001 C           *INOF     IFEQ '1'
     C                     EXSR #OF
E001 C                     END
     C*
     C                     ADD  1         DAIS
     C                     ADD  YOKW      GYOKW
     C                     ADD  YOLL      GYOLL
     C                     ADD  GASM      GGASM
     C*
     C                     MOVE *BLANK    AA01    1
     C                     MOVE *BLANK    AA02    1
     C                     MOVE *BLANK    AA03    1
     C                     MOVE *BLANK    AA04    1
     C                     MOVE *BLANK    AA06    1
     C                     MOVE *BLANK    AA07    1
B001 C           KAKA      IFNE *BLANK
     C                     MOVEL'-'       AA01
E001 C                     END
     C*
B001 C           KBN2      IFNE *BLANK
     C                     MOVEL'-'       AA02
E001 C                     END
     C*
B001 C           OKB2      IFNE *BLANK
     C                     MOVEL'-'       AA03
E001 C                     END
     C*
B001 C           SYS2      IFNE *BLANK
     C                     MOVEL'-'       AA04
E001 C                     END
     C*
B001 C           COS2      IFNE *BLANK
     C                     MOVEL'-'       AA06
E001 C                     END
     C*
B001 C           COS3      IFNE *BLANK
     C                     MOVEL'-'       AA07
E001 C                     END
     C*
     C                     MOVE *BLANK    BB01    3
     C                     MOVE *BLANK    BB02    2
     C                     MOVE *BLANK    BB03    1
     C                     MOVE *BLANK    BB04    4
B001 C           RPMH      IFNE 0
     C                     MOVEL'RPH'     BB01
E001 C                     END
     C*
B001 C           YOKW      IFNE 0
     C                     MOVEL'KW'      BB02
E001 C                     END
     C*
B001 C           YOLL      IFNE 0
     C                     MOVEL'L'       BB03
E001 C                     END
     C*
B001 C           GASM      IFNE 0
     C                     MOVEL'M3/H'    BB04
E001 C                     END
     C*
     C                     EXCPTDET
     C*
     C           @END      TAG
     C*
     CL1                   MOVE *BLANK    CC01    5
     CL1                   MOVE *BLANK    CC02    4
B001 CL1         DAIS      IFNE 0
     CL1                   MOVEL'BOARD'   CC01
E001 CL1                   END
     C*
B001 CL1         GGASM     IFNE 0
     CL1                   MOVEL'M3/H'    CC02
E001 CL1                   END
     C*
     CL1         *INOF     IFEQ '1'
     CL1                   EXSR #OF
     CL1                   END
     C*
     CL1                   EXCPTKEI
     CL1                   MOVEL'1'       *INOF
     C*
     CL2                   MOVEL'1'       *INOF
     C******************************************************
     C           #OF       BEGSR                           *
     C******************************************************
     C                     MOVE *BLANK    KJNM   16
     C           @KOJO     CHAINFGBPL011             10
     C           *IN,10    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,10
     C                     END
     C*
     C  N10                MOVELB2SMEI    KJNM
     C*
     C                     MOVE *BLANK    SNM     8
B002 C           PKBN      IFEQ '1'
     C                     MOVEL'LUMP-SUM'SNM
X002 C                     ELSE
B003 C           PKBN      IFEQ '2'
     C                     MOVEL'ALLOCATE'SNM
E003 C                     END
E002 C                     END
     C*
     C                     TIME           TIME    60
     C                     Z-ADDUDATE     DAY     60
     C                     ADD  1         CNT
     C                     EXCPTHED
     C                     MOVEL'0'       *INOF
     C*
     C                     ENDSR
     C*
     C*
     C*
     OQPRINT  E   02           HED
     O                         #PGM       8
