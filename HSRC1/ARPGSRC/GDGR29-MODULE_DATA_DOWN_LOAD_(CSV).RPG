     H            Y.
     F** GDGR29 ******************************************************
     F*  MODULE DATA DOWN LOAD (CSV)                                 *
     F*       SEEK                      2023.02.21                   *
     F****************************************************** GDGR29 **
     FGDGPW29 CF  E                    WORKSTN
     FGDGPL2H IF  E           K        DISK
     FGDGPL2A IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAAPTL01 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
     FGDGWP29 O   F     256            DISK
      ****************************************************************
      * 使用標識                                                   *
      *        KC(F3)   : 終了                                     *
      *        KE(F5)   : ＣＳＶ出力                               *
      *        31-32    : 入力値エラー（反転表示）                 *
      *        90       : 汎用標識                                 *
      *        99       : 画面エラー代表標識                       *
      ****************************************************************
     E                    MSG     1   6 70               エラーＭＳＧ
     I*
     I            DS
     I                                        1   6 IEINVO
     I                                        1   2 IEINV1
     I                                        3   6 IEINV2
     I            DS
     I                                        1   60IEODER
     I                                        1   2 IEODE1
     I                                        3   4 IEODE2
     I                                        5   6 IEODE3
     I            DS
     I                                        1   6 W0LOC
     I                                        1   1 W0LOC1
     I                                        2   3 W0LOC2
     I                                        4   5 W0LOC3
     I                                        6   6 W0LOC4
     I            DS
     I                                        1   80IESKDT
     I                                        1   40IESKYY
     I                                        5   60IESKMM
     I                                        7   80IESKDD
     I            DS
     I                                        1   7 A07
     I                                        1   2 A07A
     I                                        3   3 A07B
     I                                        4   7 A07C
     I            DS
     I                                        1   9 A09
     I                                        1   1 A09A
     I                                        2   2 A09B
     I                                        3   4 A09C
     I                                        5   5 A09D
     I                                        6   7 A09E
     I                                        8   8 A09F
     I                                        9   9 A09G
     I            DS
     I                                        1  12 A12
     I                                        1   3 A12A
     I                                        4   4 A12B
     I                                        5   6 A12C
     I                                        7   7 A12D
     I                                        8   9 A12E
     I                                       10  10 A12F
     I                                       11  12 A12G
     I            DS
     I                                        1  14 A14
     I                                        1   5 A14A
     I                                        6   6 A14B
     I                                        7  11 A14C
     I                                       12  12 A14D
     I                                       13  14 A14E
     I            DS
     I                                        1  140W0TIME
     I                                        1   40W0TITM
     I                                        7  140W0TIDT
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
     I            DS
     I                                        1   80L7UKHZ
     I                                        1   40L7UKYY
     I                                        5   60L7UKMM
     I                                        7   80L7UKDD
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
     I*
     I           SDS
     I                                     *PROGRAM DSPGM
     I                                      254 263 DSUSER
      ****************************************************************
      * パラメータ                                                 *
      ****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           P0CSV   1        ＣＳＶ出力
     C*  DATR10
     C           PLIST1    PLIST
     C                     PARM           P1DATE  8        日付
     C                     PARM           P1RTN   1        戻りコード
      ****************************************************************
      * キーリスト                                                 *
      ****************************************************************
     C*  KANBAN MASTER
     C           KEYA2     KLIST
     C                     KFLD           K@BHB1  5         INTRAL COMPANY PART1
     C                     KFLD           K@BHB2  5         INTRAL COMPANY PART2
     C                     KFLD           K@BHB3  2         INTRAL COMPANY PART3
     C*  GDGPL2A
     C           KEYIE     KLIST
     C                     KFLD           IEPARE            PALLETE
     C                     KFLD           IECAHK            CASE# ISSUE DATE
      ****************************************************************
      * メイン                                                     *
      ****************************************************************
     C* 初期処理
     C                     EXSR #INIT
     C* 処理
B01  C                     DO   *HIVAL
B02  C                     SELEC
     C           W0CTL     WHEQ '*END'
     C                     LEAVE
     C           W0CTL     WHEQ '*DSP1'
     C                     EXSR #DSP1
E02  C                     ENDSL
E01  C                     ENDDO
     C* 終了
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************************
      * 初期処理                                                   *
      ****************************************************************
     C           #INIT     BEGSR
     C*
     C                     TIME           W0TIME
     C                     MOVEL'*DSP1'   W0CTL   5        処理制御
     C*
     C                     ENDSR
      ****************************************************************
      * 画面１                                                     *
      ****************************************************************
     C           #DSP1     BEGSR
     C* 画面１＿セット
     C                     EXSR #SET1
     C* 画面１＿表示
B01  C                     DO   *HIVAL
     C                     EXFMTDSP1
     C* 終了
B02  C           *INKC     IFEQ *ON
     C                     MOVEL'*END '   W0CTL
     C                     LEAVE
E02  C                     ENDIF
     C*
     C                     MOVEA'00'      *IN,31            *IN31-*IN32
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    DXERR            エラーＭＳＧ
     C* 画面１＿チェック
     C                     EXSR #CHK1
     C   99                ITER
     C* ＣＳＶ出力
B02  C           *INKE     IFEQ *ON
     C                     EXSR #CSV
     C   99                ITER
     C*
     C                     MOVEL'*'       P0CSV            ＣＳＶ出力
     C                     MOVEL'*END '   W0CTL
     C                     LEAVE
E02  C                     ENDIF
     C*
E01  C                     ENDDO
     C*
     C                     ENDSR
     C****************************************************************
     C* 画面１のセット                                             *
     C****************************************************************
     C           #SET1     BEGSR
     C*
     C                     Z-ADD*ZERO     D1FRDT            START DATE
     C                     Z-ADD*HIVAL    D1TODT            END DATE
     C*
     C                     MOVEA'00'      *IN,31            *IN31-*IN32
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    DXERR            エラーＭＳＧ
     C*
     C                     ENDSR
     C****************************************************************
     C* 画面１のチェック                                           *
     C****************************************************************
     C           #CHK1     BEGSR
     C*  START DATE
B01  C           D1FRDT    IFEQ *ZERO
     C                     MOVE *ON       *IN31
B02  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,1     DXERR
     C                     MOVE *ON       *IN99
E02  C                     ENDIF
X01  C                     ELSE
     C* ＿実在日？
     C                     MOVELD1FRDT    P1DATE           日付
     C                     MOVE *BLANK    P1RTN            戻りコード
     C                     CALL 'DATR10'  PLIST1
B02  C           P1RTN     IFEQ '1'
     C                     MOVE *ON       *IN31
B03  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,2     DXERR
     C                     MOVE *ON       *IN99
E03  C                     ENDIF
E02  C                     ENDIF
E01  C                     ENDIF
     C*  END DATE
B01  C           D1TODT    IFEQ *ZERO
     C*****                MOVE *ON       *IN32
B02  C*****      *IN99     IFEQ *OFF
     C*****                MOVELMSG,3     DXERR
     C*****                MOVE *ON       *IN99
E02  C*****                ENDIF
     C                     Z-ADD*HIVAL    D1TODT
X01  C                     ELSE
     C* ＿実在日？
B02  C           D1TODT    IFNE *HIVAL
     C                     MOVELD1TODT    P1DATE           日付
     C                     MOVE *BLANK    P1RTN            戻りコード
     C                     CALL 'DATR10'  PLIST1
B03  C           P1RTN     IFEQ '1'
     C                     MOVE *ON       *IN32
B04  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,4     DXERR
     C                     MOVE *ON       *IN99
E04  C                     ENDIF
E03  C                     ENDIF
E02  C                     ENDIF
E01  C                     ENDIF
     C*  START DATE > END DATE
B01  C           *IN31     IFEQ *OFF
     C           *IN32     ANDEQ*OFF
B02  C           D1FRDT    IFGT D1TODT
     C                     MOVEA'11'      *IN,31
B03  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,5     DXERR
     C                     MOVE *ON       *IN99
E03  C                     ENDIF
E02  C                     ENDIF
E01  C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
     C* ＣＳＶ出力＿実行                                           *
     C****************************************************************
     C           #CSV      BEGSR
     C*
     C                     MOVE *BLANK    W0FST   1        初回ＳＷ
     C*  READ GDGPL2H
     C           D1FRDT    SETLLGDGPP281
B01  C                     DO   *HIVAL
     C                     READ GDGPP281                 90
     C   90                LEAVE
B02  C           G8SCDT    IFGT D1TODT
     C                     LEAVE
E02  C                     ENDIF
     C*
     C                     MOVELG8PARE    IEPARE            PALLETE
     C                     Z-ADDG8CAHK    IECAHK            CASE# ISSUE DATE
     C                     Z-ADD0         @CNT    40
     C           KEYIE     SETLLGDGPP251
B02  C                     DO   *HIVAL
     C           KEYIE     READEGDGPP251                 90
     C   90                LEAVE
     C* 選択
B03  C           IESKJY    IFEQ 'D'
     C           IESKDT    ANDLEW0TIDT
     C                     ITER
E03  C                     ENDIF
     C* 見出し＿出力
B03  C           W0FST     IFEQ *BLANK
     C                     EXCPTHED
     C                     MOVEL'*'       W0FST
E03  C                     ENDIF
     C* 編集
     C                     MOVE *BLANK    A07
     C                     MOVELIEINV1    A07A
     C                     MOVEL'-'       A07B
     C                     MOVELIEINV2    A07C
     C                     MOVELA07       W0INVO  7         INVOICE NO
     C                     MOVE *BLANK    A12
     C                     MOVEL'IAF'     A12A
     C                     MOVEL'-'       A12B
     C                     MOVELIEODE1    A12C
     C                     MOVEL'-'       A12D
     C                     MOVELIEODE2    A12E
     C                     MOVEL'-'       A12F
     C                     MOVELIEODE3    A12G
     C                     MOVELA12       W0ODER 12         ORDER NO
     C                     MOVE *BLANK    A14
     C                     MOVELIEHIN1    A14A
B03  C           IEHIN2    IFNE *BLANK
     C                     MOVEL'-'       A14B
     C                     MOVELIEHIN2    A14C
B04  C           IEHIN3    IFNE *BLANK
     C                     MOVEL'-'       A14D
     C                     MOVELIEHIN3    A14E
E04  C                     ENDIF
E03  C                     ENDIF
     C                     MOVELA14       W0HIN  14         PART NO
     C* 所番地＿取得
     C                     EXSR #LOC
     C* 明細＿出力
     C                     EXCPTDET
     C                     ADD  1         @CNT
     C*
E02  C                     ENDDO
     C*
     C           @CNT      IFEQ 0
     C                     EXCPTDET2
     C                     ENDIF
     C*
E01  C                     ENDDO
     C* 対象データ＿有り？
B01  C           W0FST     IFEQ *BLANK
     C                     MOVEA'11'      *IN,31
B02  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,6     DXERR
     C                     MOVE *ON       *IN99
E02  C                     ENDIF
E01  C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
     C* 所番地＿取得                                               *
     C****************************************************************
     C           #LOC      BEGSR
     C*
     C                     MOVE *BLANK    W0LOCX  9         LOCATION
     C*
     C                     MOVELIEHIN1    K@BHB1            INTRAL COMPANY PART1
     C                     MOVELIEHIN2    K@BHB2            INTRAL COMPANY PART2
     C                     MOVELIEHIN3    K@BHB3            INTRAL COMPANY PART3
      * PT
     C           KEYA2     SETGTAAPTL011
     C           KEYA2     REDPEAAPTL011                 90
     C           *IN90     DOWEQ'0'
     C           L5SKJY    IFEQ *BLANK
     C           L5SKHZ    ANDLEW0TIDT
      *
     C           L5UKHZ    IFLE W0TIDT
     C           L5STHZ    ANDGTW0TIDT
     C                     MOVE *BLANK    A09
     C                     MOVELL5TKR1    A09A
     C                     MOVEL'-'       A09B
     C                     MOVELL5TKR2    A09C
     C                     MOVEL'-'       A09D
     C                     MOVELL5TKR3    A09E
     C                     MOVEL'-'       A09F
     C                     MOVELL5TKR4    A09G
     C                     MOVELA09       W0LOCX
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C           KEYA2     REDPEAAPTL011                 90
     C                     ENDDO
      * BPT
     C           W0LOCX    IFEQ *BLANK
     C           KEYA2     SETGTAANPL061
     C           KEYA2     REDPEAANPL061                 90
     C           *IN90     DOWEQ'0'
     C           L7SKJY    IFEQ *BLANK
     C           L7SKHZ    ANDLEW0TIDT
      *
     C           L7UKHZ    IFLE W0TIDT
     C           L7STHZ    ANDGTW0TIDT
     C                     MOVE *BLANK    A09
     C                     MOVELL7TKR1    A09A
     C                     MOVEL'-'       A09B
     C                     MOVELL7TKR2    A09C
     C                     MOVEL'-'       A09D
     C                     MOVELL7TKR3    A09E
     C                     MOVEL'-'       A09F
     C                     MOVELL7TKR4    A09G
     C                     MOVELA09       W0LOCX
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C           KEYA2     REDPEAANPL061                 90
     C                     ENDDO
     C                     ENDIF
      *
      * WASHER
     C           W0LOCX    IFEQ *BLANK
     C           KEYA2     SETGTAKBPL041
     C           KEYA2     REDPEAKBPL041                 90
     C           *IN90     DOWEQ'0'
     C           L1SKJY    IFEQ *BLANK
     C           L1SKHZ    ANDLEW0TIDT
      *
     C           L1UKHZ    IFLE W0TIDT
     C           L1STHZ    ANDGTW0TIDT
     C                     MOVE *BLANK    A09
     C                     MOVELL1TKR1    A09A
     C                     MOVEL'-'       A09B
     C                     MOVELL1TKR2    A09C
     C                     MOVEL'-'       A09D
     C                     MOVELL1TKR3    A09E
     C                     MOVEL'-'       A09F
     C                     MOVELL1TKR4    A09G
     C                     MOVELA09       W0LOCX
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C           KEYA2     REDPEAKBPL041                 90
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
     O****************************************************************
