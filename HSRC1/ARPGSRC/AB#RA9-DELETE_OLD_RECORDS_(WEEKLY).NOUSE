#01   * AB#PP70 (W@YMD: 1 YEAR)
     C           *LOVAL    SETLLAB#PL73
     C           *IN90     DOUEQ*ON
     C                     READ AB#PL73                  90
     C           *IN90     IFEQ *OFF
     C           EKYMD     IFGE K@YMD
     C                     LEAVE
     C                     ENDIF
      *
     C           EKSRYO    IFEQ *ZERO
     C           EKDAT     ORLT W@YMD
     C           EKDAT     ANDNE*ZERO
     C                     DELETAB#PP701
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
