      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@RUNS  1
     C                     MOVEL*OFF      P@RUNS
     C*
     C                     Z-ADD*DATE     K@YMD
     C           K#AGDP    KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#AGDP    CHAINAGDPL12              98
     C           *IN98     IFEQ *OFF
     C           F8YOBI    IFEQ 7
     C                     MOVEL*ON       P@RUNS
     C                     ELSE
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     END
     C                     END
     C                     SUB  1         K@MM
     C           K@MM      IFLE *ZERO
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
     C                     ENDIF
      * ONE YEAR BEFORE
     C                     Z-ADD*DATE     W@YMD
     C                     SUB  1         W@YY
 JW1  * 2   YEAR BEFORE
  |  C                     Z-ADD*DATE     Y2@YMD
  |  C                     SUB  2         Y2@YY
  |   * 5   YEAR BEFORE
  |  C                     Z-ADD*DATE     Y5@YMD
 JW1 C                     SUB  5         Y5@YY
      * 6 MONTHS BEFORE
     C                     Z-ADD*DATE     @@YMD
     C                     SUB  6         @@MM
     C           @@MM      IFLE *ZERO
     C                     ADD  12        @@MM
     C                     SUB  1         @@YY
     C                     ENDIF
      * 3 MONTHS BEFORE
     C                     Z-ADD*DATE     ZZYMD
     C                     SUB  3         ZZMM
     C           ZZMM      IFLE *ZERO
     C                     ADD  12        ZZMM
     C                     SUB  1         ZZYY
     C                     ENDIF
      * ZMLOG1P DATE (1Y)
     C                     Z-ADD@@YY      ZMYY
     C                     Z-ADD@@MM      ZMMM
     C                     Z-ADD@@DD      ZMDD
     C                     Z-ADD1         ZMID
      *
     C                     ENDSR
