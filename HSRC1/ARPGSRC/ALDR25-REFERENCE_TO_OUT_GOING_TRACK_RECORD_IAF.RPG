     C           MM        IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           MM        IFGT 12
     C                     SETON                     0399
     C                     MOVE ER,10     MSG
     C                     GOTO STP1
     C                     ENDIF
     C           DD        IFEQ 0
     C                     SETON                     0499
