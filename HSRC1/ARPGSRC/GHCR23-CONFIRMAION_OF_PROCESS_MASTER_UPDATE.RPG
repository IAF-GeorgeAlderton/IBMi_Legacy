      * 処理内容      :                                            *
      *--------------------------------------------------------------*
      * 【変更履歴】                                               *
      ****************************************************************
     FGHCPW23 CF  E                    WORKSTN
      ****************************************************************
      * 使用標識                                                   *
      *        KA(F1)   : 終了                                     *
      *        90       : 汎用標識                                 *
      *        99       : 画面エラー代表標識                       *
      ****************************************************************
     E                    MSG     1  26 70                ERROR MESSAGE
     E                    PSWD    1   1  8                PASSWORD
     I*
     I            DS
     I                                        1  140W0TIME
     I                                        1   60W0TITM
     I                                        7  140W0TIDT
     I*
     IINFDS       DS
     I                                    B 378 3790$POS
     I           SDS
     I                                     *PROGRAM DSPGM
     I                                      254 263 DSUSER
      ****************************************************************
      * パラメータ                                                 *
      ****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           P0FKY   3         FUNC-KEY
      ****************************************************************
      * キーリスト                                                 *
      ****************************************************************
     C*
      ****************************************************************
      * メイン                                                     *
      ****************************************************************
     C* 初期処理
     C                     EXSR #INIT
     C* 処理
B01  C                     DO   *HIVAL
B02  C                     SELEC
     C           W0CTL     WHEQ '*END'
     C                     LEAVE
     C           W0CTL     WHEQ '*DSP1'
     C                     EXSR #DSP1
E02  C                     ENDSL
E01  C                     ENDDO
     C* 終了
B01  C           *INKA     IFEQ *ON
     C                     MOVEL'F01'     P0FKY
E01  C                     ENDIF
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************************
      * 初期処理                                                   *
      ****************************************************************
     C           #INIT     BEGSR
     C* 画面１＿セット
     C                     EXSR #SET1
     C*
     C                     MOVEL'*DSP1'   W0CTL   5         PROCESS CONTROL
     C*
     C                     ENDSR
      ****************************************************************
      * 画面１                                                     *
      ****************************************************************
     C           #DSP1     BEGSR
     C* 画面１＿表示
B01  C                     DO   *HIVAL
     C                     EXFMTDSP1
     C* 終了
B02  C           *INKA     IFEQ *ON
     C                     MOVEL'*END '   W0CTL
     C                     LEAVE
E02  C                     ENDIF
     C*
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    $ERR              ERROR MESSAGE
     C* 画面１＿チェック
     C                     EXSR #CHK1
     C   99                ITER
     C*
     C                     MOVEL'*END '   W0CTL
     C                     LEAVE
     C*
E01  C                     ENDDO
     C*
     C                     ENDSR
     C****************************************************************
     C* 画面１のセット                                             *
     C****************************************************************
     C           #SET1     BEGSR
     C* 画面項目＿消去
     C                     MOVE *BLANK    D1PSWD            PASSWORD
     C*
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    $ERR              ERROR MESSAGE
     C*
     C                     ENDSR
     C****************************************************************
     C* 画面１のチェック                                           *
     C****************************************************************
     C           #CHK1     BEGSR
     C*  PASSWORD
B01  C           D1PSWD    IFEQ *BLANK
B02  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,1     $ERR
     C                     MOVE *ON       *IN99
E02  C                     ENDIF
X01  C                     ELSE
     C*  __ VALID VALUE ?
B02  C           D1PSWD    IFNE PSWD,1
B03  C           *IN99     IFEQ *OFF
     C                     MOVELMSG,2     $ERR
     C                     MOVE *ON       *IN99
E03  C                     ENDIF
E02  C                     ENDIF
E01  C                     ENDIF
     C*
     C                     ENDSR
**  MSG (エラーＭＳＧ)
INPUT PASSWORD.                                                           1
PASSWORD ERROR, PLEASE TRY AGAIN.                                         2
**  PSWD (PASSWORD)
IAFI1300
