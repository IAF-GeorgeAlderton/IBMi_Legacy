     H            Y.
     F** EDSR60 ********************************************
     F*  PROGRAM: UTILITY - SAVE AB#EP60 TO AB#EP60S       *
     F*  WRITTEN: JW (SRA)                                 *
     F*           02/19/2016                               *
     F*----------------------------------------------------*
     FAB#EP60 IF  E                    DISK
     FAB#EP61 IF  E           K        DISK
     FAB#EP62 IF  E           K        DISK
     FAB#EP75 IF  E           K        DISK
     FAB#EP76 IF  E           K        DISK
     FAB#EP77 IF  E           K        DISK
     FAB#EP60SIF  E           K        DISK                      A
     FAB#EP61SO   E                    DISK
     FAB#EP62SO   E                    DISK
     FAB#EP75SO   E                    DISK
     FAB#EP76SO   E                    DISK
     FAB#EP77SO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *--------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
      * SAVE AB#EP60 TO EP60S -----------------------------
     C                     MOVE *OFF      *IN91
     C           *IN91     DOWEQ*OFF
     C                     READ AB#EP60                  91
     C           *IN91     IFEQ *OFF
     C                     MOVELE1SHID    #SHID  10
     C                     EXSR #SAVE
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     EXSR #BACK
     C                     Z-ADDTODAY     ECRDT
     C                     Z-ADDNOW       ECRTM
     C                     MOVEL#PGM      ECRPG
     C                     MOVEL#WSID     ECRWS
     C                     MOVEL#USER     ECRUS
     C                     WRITEAB#E60S1
      *DTL
     C                     EXSR #DTL
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------
      * CHECK EP60S
      *----------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *ON       *IN85
      *
     C           #SHID     SETLLAB#EP60S
     C                     DO   *HIVAL
     C           #SHID     READEAB#EP60S                 98
     C   98                LEAVE
      *
     C           SVTIME    IFEQ E1TIME
     C                     MOVE *OFF      *IN85
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
      * SAVE DETAIL
      *----------------------------------------------------
     C           #DTL      BEGSR
      * SAVE AB#EP61 --------------------------------------
     C                     MOVE *OFF      *IN92
     C           *LOVAL    SETLLAB#EP61
     C           *IN92     DOWEQ*OFF
     C                     READ AB#EP61                  92
     C           *IN92     IFEQ *OFF
     C           E2SHID    ANDEQ#SHID
     C                     Z-ADDTODAY     E2CRDT
     C                     Z-ADDNOW       E2CRTM
     C                     MOVEL#PGM      E2CRPG
     C                     WRITEAB#E61S1
     C                     ENDIF
     C                     ENDDO
      *
      * SAVE AB#EP62 --------------------------------------
     C                     MOVE *OFF      *IN93
     C           *LOVAL    SETLLAB#EP62
     C           *IN93     DOWEQ*OFF
     C                     READ AB#EP62                  93
     C           *IN93     IFEQ *OFF
     C           E3SHID    ANDEQ#SHID
     C                     Z-ADDTODAY     E3CRDT
     C                     Z-ADDNOW       E3CRTM
     C                     MOVEL#PGM      E3CRPG
     C                     WRITEAB#E62S1
     C                     ENDIF
     C                     ENDDO
      *
      * SAVE AB#EP75 --------------------------------------
     C                     MOVE *OFF      *IN94
     C           *LOVAL    SETLLAB#EP75
     C           *IN94     DOWEQ*OFF
     C                     READ AB#EP75                  94
     C           *IN94     IFEQ *OFF
     C           E2SHID    ANDEQ#SHID
     C                     Z-ADDTODAY     E2CRDT
     C                     Z-ADDNOW       E2CRTM
     C                     MOVEL#PGM      E2CRPG
     C                     WRITEAB#E75S1
     C                     ENDIF
     C                     ENDDO
      *
      * SAVE AB#EP76 --------------------------------------
     C                     MOVE *OFF      *IN94
     C           *LOVAL    SETLLAB#EP76
     C           *IN94     DOWEQ*OFF
     C                     READ AB#EP76                  94
     C           *IN94     IFEQ *OFF
     C           E3SHID    ANDEQ#SHID
     C                     Z-ADDTODAY     E3CRDT
     C                     Z-ADDNOW       E3CRTM
     C                     MOVEL#PGM      E3CRPG
     C                     WRITEAB#E76S1
     C                     ENDIF
     C                     ENDDO
      *
      * SAVE AB#EP77 --------------------------------------
     C                     MOVE *OFF      *IN95
     C           *LOVAL    SETLLAB#EP77
     C           *IN95     DOWEQ*OFF
     C                     READ AB#EP77                  95
     C           *IN95     IFEQ *OFF
     C           E7SHID    ANDEQ#SHID
     C                     Z-ADDTODAY     E7CRDT
     C                     Z-ADDNOW       E7CRTM
     C                     MOVEL#PGM      E7CRPG
     C                     WRITEAB#E77S1
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
      * SAVE AB#EP60
      *----------------------------------------------------
     C           #SAVE     BEGSR
      *
     C                     MOVELE1SHID    SVSHID
     C                     MOVELE1PRTN    SVPRTN
     C                     Z-ADDE1DATE    SVDATE
     C                     Z-ADDE1TIME    SVTIME
     C                     Z-ADDE1TOKU    SVTOKU
     C                     Z-ADDE1NONY    SVNONY
     C                     MOVELE1NKOJ    SVNKOJ
     C                     MOVELE1NUKE    SVNUKE
     C                     Z-ADDE1NOHZ    SVNOHZ
     C                     Z-ADDE1NBIN    SVNBIN
     C                     Z-ADDE1NOTM    SVNOTM
     C                     MOVELE1INVN    SVINVN
     C                     MOVELE1ORDN    SVORDN
     C                     MOVELE1TRCK    SVTRCK
     C                     Z-ADDETPLT     SVPLT
     C                     Z-ADDETBOX     SVBOX
     C                     MOVELETRMD     SVRMD
     C                     Z-ADDETWHT     SVWHT
     C                     MOVELESIRE     SVIRE
     C                     MOVELESIRK     SVIRK
     C                     MOVELESCAC     SVCAC
     C                     Z-ADDETNET     SVNET
      *
     C                     MOVELE1REL#    SVREL#
     C                     MOVELE1FIL1    SVFIL1
      *
     C                     Z-ADDETGRS     SVGRS
     C                     MOVELESCNAM    SVCNAM
     C                     MOVELESCTEL    SVCTEL
     C                     MOVELEFOB      SVOB
     C                     MOVELESNAM     SVNAM
     C                     MOVELESLOC     SVLOC
      *
     C                     ENDSR
      *----------------------------------------------------
      * BACK AB#EP60
      *----------------------------------------------------
     C           #BACK     BEGSR
      *
     C                     MOVELSVSHID    E1SHID
     C                     MOVELSVPRTN    E1PRTN
     C                     Z-ADDSVDATE    E1DATE
     C                     Z-ADDSVTIME    E1TIME
     C                     Z-ADDSVTOKU    E1TOKU
     C                     Z-ADDSVNONY    E1NONY
     C                     MOVELSVNKOJ    E1NKOJ
     C                     MOVELSVNUKE    E1NUKE
     C                     Z-ADDSVNOHZ    E1NOHZ
     C                     Z-ADDSVNBIN    E1NBIN
     C                     Z-ADDSVNOTM    E1NOTM
     C                     MOVELSVINVN    E1INVN
     C                     MOVELSVORDN    E1ORDN
     C                     MOVELSVTRCK    E1TRCK
     C                     Z-ADDSVPLT     ETPLT
     C                     Z-ADDSVBOX     ETBOX
     C                     MOVELSVRMD     ETRMD
     C                     Z-ADDSVWHT     ETWHT
     C                     MOVELSVIRE     ESIRE
     C                     MOVELSVIRK     ESIRK
     C                     MOVELSVCAC     ESCAC
     C                     Z-ADDSVNET     ETNET
      *
     C                     MOVELSVREL#    E1REL#
     C                     MOVELSVFIL1    E1FIL1
      *
     C                     Z-ADDSVGRS     ETGRS
     C                     MOVELSVCNAM    ESCNAM
     C                     MOVELSVCTEL    ESCTEL
     C                     MOVELSVOB      EFOB
     C                     MOVELSVNAM     ESNAM
     C                     MOVELSVLOC     ESLOC
      *
     C                     ENDSR
      *----------------------------------------------------
      * INITIAL SET
      *----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *LIKE     DEFN E1SHID    SVSHID
     C           *LIKE     DEFN E1PRTN    SVPRTN
     C           *LIKE     DEFN E1DATE    SVDATE
     C           *LIKE     DEFN E1TIME    SVTIME
     C           *LIKE     DEFN E1TOKU    SVTOKU
     C           *LIKE     DEFN E1NONY    SVNONY
     C           *LIKE     DEFN E1NKOJ    SVNKOJ
     C           *LIKE     DEFN E1NUKE    SVNUKE
     C           *LIKE     DEFN E1NOHZ    SVNOHZ
     C           *LIKE     DEFN E1NBIN    SVNBIN
     C           *LIKE     DEFN E1NOTM    SVNOTM
     C           *LIKE     DEFN E1INVN    SVINVN
     C           *LIKE     DEFN E1ORDN    SVORDN
     C           *LIKE     DEFN E1TRCK    SVTRCK
     C           *LIKE     DEFN ETPLT     SVPLT
     C           *LIKE     DEFN ETBOX     SVBOX
     C           *LIKE     DEFN ETRMD     SVRMD
     C           *LIKE     DEFN ETWHT     SVWHT
     C           *LIKE     DEFN ESIRE     SVIRE
     C           *LIKE     DEFN ESIRK     SVIRK
     C           *LIKE     DEFN ESCAC     SVCAC
     C           *LIKE     DEFN ETNET     SVNET
      *
     C           *LIKE     DEFN E1REL#    SVREL#
     C           *LIKE     DEFN E1FIL1    SVFIL1
      *
     C           *LIKE     DEFN ETGRS     SVGRS
     C           *LIKE     DEFN ESCNAM    SVCNAM
     C           *LIKE     DEFN ESCTEL    SVCTEL
     C           *LIKE     DEFN EFOB      SVOB
     C           *LIKE     DEFN ESNAM     SVNAM
     C           *LIKE     DEFN ESLOC     SVLOC
      *
     C                     TIME           D#TIME
      *
     C                     ENDSR
