     C                     MOVELKS2,I     K@KKT2           構成型番　型番２
     C           K@KEY1    SETLLWK400L1
     C                     EXSR $4002
     C           *IN91     DOWEQ'0'
     C           S@RRN1    ANDLT26
     C           IX        IFGE 999
     C                     Z-ADD*ZERO     IX               添え字
     C                     ENDIF
     C                     ADD  1         IX               添え字
     C                     Z-ADDIX        D#1NO            №
     C                     MOVEL*BLANK    D#1KKT           型番
     C                     MOVEL*BLANK    D#1KKN           型番名称
     C                     MOVELK4KKT1    D#@KK1
     C                     MOVEL'-'       D#@HIF
     C                     MOVELK4KKT2    D#@KK2
     C                     MOVELD#@KKT    D#1KKT           型番
     C                     MOVELD#@KK1    K@KKT1           型番１
     C                     MOVELD#@KK2    K@KKT2           型番２
     C                     EXSR $CQ21                       FCQPL21 READ
     C                     MOVELO9KANM    D#1KKN           組型番名称
     C           K@KKT@    SETLLFCQPL31
     C                     EXSR $CQ31
     C           *IN93     IFEQ '1'
