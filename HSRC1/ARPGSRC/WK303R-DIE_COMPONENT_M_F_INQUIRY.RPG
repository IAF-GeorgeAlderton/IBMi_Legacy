     C*****************************************************
     C*         パラメーター ＬＩＳＴ                 *
     C*****************************************************
     C*==<受取・受渡>==*
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@KAT1  2
     C                     PARM           P@KAT2  4
     C                     PARM           P@KOJO  4
     C*****************************************************
     C*         キー　ＬＩＳＴ                          *
     C*****************************************************
     C*
     C           K@KAT@    KLIST
     C                     KFLD           K@KAT1  2        組型番　型番１
     C                     KFLD           K@KAT2  4        組型番　型番２
     C           K@KKT@    KLIST
     C                     KFLD           K@KKT1  2        構成型番・型番１
     C                     KFLD           K@KKT2  4        構成型番・型番２
     C           K@KEY1    KLIST
     C                     KFLD           K@KAT1           組型番　型番１
     C                     KFLD           K@KAT2           組型番　型番２
     C                     KFLD           K@KKT1           構成型番・型番１
     C                     KFLD           K@KKT2           構成型番・型番２
     C*
     C           KEY1      KLIST
     C                     KFLD           HIN1    5
     C                     KFLD           HIN2    5
     C                     KFLD           HIN3    2
     C*
     C           T6KEY1    KLIST
     C                     KFLD           K@KTX1  2
     C                     KFLD           K@KTX2  4
     C*
     C           DFKEY1    KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C*****************************************************
     C*         内部ＷＯＲＫ項目                        *
     C*****************************************************
     C                     MOVEL'EDT1'    S@PROC  4        処理制御
     C                     Z-ADD*ZERO     W@ENDL  50
     C                     MOVEL'0'       F@READ  1
     C                     Z-ADD*ZERO     #RRN1   40        RRN
     C                     Z-ADD*ZERO     S@RRN1  40        SFL表示RRN
     C                     MOVEL*BLANK    W@KOJ   1
     C*
     C                     SETOF                     50
     C                     Z-ADD1         M       20
     C           P@KOJO    LOKUPKOJY,M                   50
     C           *IN50     IFEQ '1'
     C                     MOVELKOJ,M     W@KOJ
     C                     ENDIF
     C                     SETOF                     41
     C           W@KOJ     IFNE '6'
     C           W@KOJ     ANDNE'7'
     C                     SETON                     41
     C                     ENDIF
     C*
     C*****************************************************
     C*         メインルーチン                          *
     C*****************************************************
     C*==<主処理>==*
     C           S@PROC    DOWNE'EXIT'
     C                     SELEC
     C           S@PROC    WHEQ 'EDT1'
     C                     EXSR $EDT1                      照会画面初期
     C           S@PROC    WHEQ 'DSP1'
     C                     EXSR $DSP1                      照会画面表示
     C           S@PROC    WHEQ 'EDT2'
     C                     EXSR $EDT2                      照会画面編集
     C                     ENDSL
     C                     ENDDO
     C*==<終了処理>==*
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************
     C*  $EDT1  照会画面初期設定                        *
     C*****************************************************
     C           $EDT1     BEGSR
     C*==<画面項目初期値>==*
     C                     MOVEL*BLANK    D#KAT1           組型番１
     C                     MOVEL*BLANK    D#KAT2           組型番２
     C                     MOVEL*BLANK    D#KKNM           組型番名称
     C                     MOVEL*BLANK    D#TKRO           所番地
     C                     MOVEL*BLANK    D#EMSG            xｮﾈｰﾆﾞ
     C                     MOVEL*ALL'*'   D$KAT1           組型番１
     C                     MOVEL*ALL'*'   D$KAT2           組型番２
     C                     SETOF                     3199
     C*==<次処理>==*
     C                     Z-ADD*ZERO     S@RRN1            SFL表示RRN
     C                     SETOF                     7071   ﾅﾎﾞﾎｦbﾓ非表示
     C           P@KAT1    IFNE *BLANK
     C                     MOVELP@KAT1    D#KAT1
     C                     MOVELP@KAT2    D#KAT2
     C                     MOVELD#KAT1    D$KAT1           組型番１
     C                     MOVELD#KAT2    D$KAT2           組型番２
     C                     EXSR $CHK1
     C                     ELSE
     C                     MOVEL'DSP1'    S@PROC
     C                     ENDIF
     C*
     C           $EDT1E    ENDSR
     C*****************************************************
     C*  $DSP1  照会画面表示                            *
     C*****************************************************
     C           $DSP1     BEGSR
     C*==<画面表示>==*
     C                     Z-ADDS@RRN1    #RRN1
     C                     WRITEWK303D09
     C                     EXFMTWK303D0C
     C                     SETOF                     3199
     C                     Z-ADD$$RRN     S@RRN1            SFL表示RRN
     C                     MOVEL*BLANK    D#EMSG            xｮﾈｰﾆﾞ
     C*
     C           *IN02     IFEQ '0'
     C           D#KAT1    IFNE D$KAT1
     C           D#KAT2    ORNE D$KAT2
     C                     EXSR $CHK1
     C                     MOVELD#KAT1    D$KAT1           組型番１
     C                     MOVELD#KAT2    D$KAT2           組型番２
     C                     ENDIF
     C                     ENDIF
     C*==<次処理>==*
     C                     SELEC
     C           *IN02     WHEQ '1'                        < F2押下>
     C                     MOVEL'EXIT'    S@PROC            ﾎﾟﾜhﾞ[w終了
     C*
     C           *IN25     WHEQ '1'
     C           *IN99     IFEQ '0'
     C           *IN91     IFEQ '1'
     C                     SETON                     99
     C                     MOVEL@MSG,4    D#EMSG            xｮﾈｰﾆﾞ
     C                     MOVEL'DSP1'    S@PROC           照会画面編集
     C                     ELSE
     C                     EXSR $ROLU                      * ROLL-UP
     C                     ENDIF
     C                     ENDIF
     C*
     C           *IN26     WHEQ '1'
     C           *IN99     IFEQ '0'
     C           I         IFEQ 1
     C                     SETON                     99
     C                     MOVEL@MSG,4    D#EMSG            xｮﾈｰﾆﾞ
     C                     MOVEL'DSP1'    S@PROC           照会画面編集
     C                     ELSE
     C                     EXSR $ROLD                      * ROLL-DOWN
     C                     ENDIF
     C                     ENDIF
     C*
     C                     OTHER                           <実行gｰ押下>
     C                     ENDSL
     C*
     C           $DSP1E    ENDSR
     C*****************************************************
     C*  $CHK1  構成型番入力チェック                    *
     C*****************************************************
     C           $CHK1     BEGSR
     C*==<初期hﾒa >==*
     C                     SETOF                     7071   ﾅﾎﾞﾎｦbﾓ非表示
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D#EMSG            xｮﾈｰﾆﾞ
     C                     Z-ADD1         X       40
     C                     MOVEL*BLANK    D#TKRO           所番地
     C                     MOVEL*BLANK    D#KKNM           構成型番名称
     C*==<構成型番>==*
     C*        (入力チェック)
     C           D#KAT1    IFEQ *BLANK
     C           D#KAT2    ANDEQ*BLANK
     C                     MOVEL@MSG,1    D#EMSG            xｮﾈｰﾆﾞ
     C                     SETON                     3199
     C                     MOVEL'DSP1'    S@PROC           画面表示へ
     C                     GOTO $CHK1E
     C                     ENDIF
     C*        (存在チェック)
     C                     MOVELD#KAT1    K@KAT1           組型番・型番１
     C                     MOVELD#KAT2    K@KAT2           組型番・型番２
     C           K@KAT@    SETLLWK400L1
     C                     EXSR $4002
     C           *IN91     IFEQ '1'
     C                     MOVEL@MSG,2    D#EMSG            xｮﾈｰﾆﾞ
     C                     SETON                     3199
     C                     MOVEL'DSP1'    S@PROC           画面表示へ
     C                     GOTO $CHK1E
     C                     ENDIF
     C*        (名称取得)
     C                     MOVELD#KAT1    K@KKT1           型番１
     C                     EXSR $CQ21                       FCQPL21 READ
     C                     MOVELO9KANM    D#KKNM           構成型番名称
     C*        (型仕様マスター確認)
     C                     MOVELD#KAT1    K@KKT1           構成型番・型番１
     C                     MOVELD#KAT2    K@KKT2           構成型番・型番２
     C           K@KKT@    SETLLFCQPL31
     C                     EXSR $CQ31
     C           *IN93     IFEQ '1'
     C                     MOVEL@MSG,3    D#EMSG            xｮﾈｰﾆﾞ
     C                     SETON                     31
     C                     ENDIF
      *
     C                     MOVELD#KAT1    K@KTX1           型番１
     C                     MOVELD#KAT2    K@KTX2           型番２
     C                     EXSR $TKRS
     C                     MOVEL#BANX     D#TKRO           所番地
     C*==<次処理>==*
     C                     MOVEL'DSP1'    S@PROC           照会画面表示
     C           *IN99     IFEQ '0'
     C                     MOVEL'EDT2'    S@PROC           照会画面編集
     C                     ENDIF
     C*
     C           $CHK1E    ENDSR
     C*===================================================*
     C*  $4002   WK400L1 READ                             *
     C*===================================================*
     C           $4002     BEGSR
     C*
     C           $40021    TAG
     C           K@KAT@    READEWK400L1                  91
     C           *IN91     CABEQ'1'       $4002E
     C*==< SKIP >==*
     C           K4SKJY    IFEQ 'D'
     C           K4SKHZ    ANDLE*DATE
     C                     GOTO $40021
     C                     ENDIF
     C*
     C           K4OYAK    IFEQ 'O'
     C                     GOTO $40021
     C                     ENDIF
     C*
     C           $4002E    ENDSR
     C*===================================================*
     C*  $CQ21   FCQPL21 READ                             *
     C*===================================================*
     C           $CQ21     BEGSR
     C*
     C                     MOVEL'0'       F@READ
     C*
     C           K@KKT1    SETLLFCQPL21
     C           K@KKT1    READEFCQPL21                  92
     C           *IN93     DOWEQ'0'
     C           F@READ    ANDEQ'0'
     C           O9SKJY    IFEQ 'D'
     C           O9SKHZ    ANDLE*DATE
     C           K@KKT1    READEFCQPL21                  92
     C                     ELSE
     C                     MOVEL'1'       F@READ
     C                     ENDIF
     C                     ENDDO
     C*
     C           *IN92     IFEQ '1'
     C                     MOVEL*BLANK    O9KANM           型番名称
     C                     ENDIF
     C*
     C           $CQ21E    ENDSR
     C*===================================================*
     C*  $CQ31   FCQPL31 READ                             *
     C*===================================================*
     C           $CQ31     BEGSR
     C*
     C           $CQ311    TAG
     C           K@KKT@    READEFCQPL31                  93
     C           *IN93     CABEQ'1'       $CQ31E
     C*==< SKIP >==*
     C           Q4SKJY    IFEQ 'D'
     C           Q4SKHZ    ANDLE*DATE
     C                     GOTO $CQ311
     C                     ENDIF
     C*
     C           $CQ31E    ENDSR
     C*****************************************************
     C*  $EDT2                                            *
     C*****************************************************
     C           $EDT2     BEGSR
     C*==< ﾅﾎﾞﾎｦbﾓ初期化>==*
     C                     SETON                     70     SFLCLR
     C                     WRITEWK303D0C                    ﾅﾎﾞﾎｦbﾓ hﾒa
     C                     SETOF                     70     SFLDSPCTL
     C                     Z-ADD*ZERO     #RRN1             RRN ﾒﾈｮn
     C                     Z-ADD*ZERO     S@RRN1            SFL表示RRN
     C                     MOVEL*BLANK    KS1              型番１STR
     C                     MOVEL*BLANK    KS2              型番２STR
     C                     MOVEL*BLANK    KE1              型番１END
     C                     MOVEL*BLANK    KE2              型番２END
     C                     Z-ADD*ZERO     NOS              №STR
     C                     Z-ADD*ZERO     NOE              №END
     C                     Z-ADD1         I       50       添え字
     C                     Z-ADD*ZERO     IX      50       添え字
     C*<<明細表示>>
     C                     MOVELD#KAT1    K@KAT1           構成型番・型番１
     C                     MOVELD#KAT2    K@KAT2           構成型番・型番２
     C           K@KAT@    SETLLWK400L1
     C                     EXSR $4002
     C           *IN91     DOWEQ'0'
     C           S@RRN1    ANDLT26
     C                     ADD  1         IX               添え字
     C                     Z-ADDIX        D#1NO            №
     C                     MOVEL*BLANK    D#1KKT           組型番
     C                     MOVEL*BLANK    D#1KKN           組型番名称
     C                     MOVELK4KKT1    D#@KK1
     C                     MOVEL'-'       D#@HIF
     C                     MOVELK4KKT2    D#@KK2
     C                     MOVELD#@KKT    D#1KKT           組型番
     C*
     C                     MOVELK4KKT1    K@KKT1           構成型番・型番１
     C                     MOVELK4KKT2    K@KKT2           構成型番・型番２
     C*        (名称取得)
     C                     EXSR $CQ21                       FCQPL21 READ
     C                     MOVELO9KANM    D#1KKN           組型番名称
     C*        (型仕様マスター確認)
     C                     SETOF                     32
     C           K@KKT@    SETLLFCQPL31
     C                     EXSR $CQ31
     C           *IN93     IFEQ '1'
     C                     SETON                     32
     C                     ENDIF
     C                     Z-ADDK4KOSU    D#1SU
     C*        (所番地セット)
     C                     MOVELK4KKT1    K@KTX1           型番１
     C                     MOVELK4KKT2    K@KTX2           型番２
     C                     EXSR $TKRS
     C                     MOVEL#BANX     D#1TKR           所番地
     C*
     C           S@RRN1    IFEQ *ZERO
     C                     MOVELD#@KK1    KS1,I            型番１STR
     C                     MOVELD#@KK2    KS2,I            型番２STR
     C                     Z-ADDD#1NO     NOS,I            №STR
     C                     ENDIF
     C                     MOVELD#@KK1    KE1,I            型番１END
     C                     MOVELD#@KK2    KE2,I            型番２END
     C                     Z-ADDD#1NO     NOE,I            №END
     C                     ADD  1         #RRN1             RRN + 1
     C                     ADD  1         S@RRN1            SFL表示RRN
     C                     WRITEWK303D0S
     C*
     C                     EXSR $4002
     C                     ENDDO
     C*==<次処理>==*
     C                     Z-ADD1         S@RRN1            SFL表示RRN
     C                     SETON                     71     ﾅﾎﾞﾎｦbﾓ表示
     C                     MOVEL'DSP1'    S@PROC            KEY入力画面表示
     C*
     C           $EDT2E    ENDSR
     C*****************************************************
     C*  $ROLU                                            *
     C*****************************************************
     C           $ROLU     BEGSR
     C*<<画面初期処理>>
     C                     SETON                     70     SFLCLR
     C                     WRITEWK303D0C                    ﾅﾎﾞﾎｦbﾓ hﾒa
     C                     SETOF                     70     SFLDSPCTL
     C*
     C                     Z-ADD*ZERO     #RRN1             RRN ﾒﾈｮn
     C                     Z-ADD*ZERO     S@RRN1           SFL表示RRN
     C                     ADD  1         I                添え字
     C           I         SUB  1         L       40
     C                     Z-ADDNOE,L     IX               添え字
     C*<<明細部>>
     C                     MOVELD#KAT1    K@KAT1           組型番　型番１
     C                     MOVELD#KAT2    K@KAT2           組型番　型番２
     C                     MOVELKE1,L     K@KKT1           構成型番　型番１
     C                     MOVELKE2,L     K@KKT2           構成型番　型番２
     C           K@KEY1    SETGTWK400L1
     C                     EXSR $4002
     C           *IN91     DOWEQ'0'
     C           S@RRN1    ANDLT26
     C           IX        IFGE 999
     C                     Z-ADD*ZERO     IX               添え字
     C                     ENDIF
     C                     ADD  1         IX               添え字
     C                     Z-ADDIX        D#1NO            №
     C                     MOVEL*BLANK    D#1KKT           型番
     C                     MOVEL*BLANK    D#1KKN           型番名称
     C                     SETOF                     32
     C                     MOVELK4KKT1    D#@KK1
     C                     MOVEL'-'       D#@HIF
     C                     MOVELK4KKT2    D#@KK2
     C                     MOVELD#@KKT    D#1KKT           型番
     C                     MOVELD#@KK1    K@KKT1           型番１
     C                     MOVELD#@KK2    K@KKT2           型番２
     C                     EXSR $CQ21                       FCQPL21 READ
     C                     MOVELO9KANM    D#1KKN           組型番名称
     C           K@KKT@    SETLLFCQPL31
     C                     EXSR $CQ31
     C           *IN93     IFEQ '1'
     C                     SETON                     32
     C                     ENDIF
     C                     Z-ADDK4KOSU    D#1SU
     C*        (所番地セット)
     C                     MOVELK4KKT1    K@KTX1           型番１
     C                     MOVELK4KKT2    K@KTX2           型番２
     C                     EXSR $TKRS
     C                     MOVEL#BANX     D#1TKR           所番地
     C           S@RRN1    IFEQ *ZERO
     C                     MOVELD#@KK1    KS1,I            型番１STR
     C                     MOVELD#@KK2    KS2,I            型番２STR
     C                     Z-ADDD#1NO     NOS,I            №STR
