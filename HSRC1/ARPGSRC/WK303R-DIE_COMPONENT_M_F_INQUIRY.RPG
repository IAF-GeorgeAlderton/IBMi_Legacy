     C                     MOVELDFSHN2    HIN2
     C                     MOVELDFSHN3    HIN3
     C           KEY1      CHAINAAMPL111             98
     C           *IN98     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     GOTO $TKRS1
     C                     ENDIF
     C                     ELSE
     C                     GOTO $TKRS1
     C                     ENDIF
     C*
