     C                     ENDIF
     C                     Z-ADDK4KOSU    D#1SU
     C*        (所番地セット)
     C                     MOVELK4KKT1    K@KTX1           型番１
     C                     MOVELK4KKT2    K@KTX2           型番２
     C                     EXSR $TKRS
     C                     MOVEL#BANX     D#1TKR           所番地
     C           S@RRN1    IFEQ *ZERO
     C                     MOVELD#@KK1    KS1,I            型番１STR
     C                     MOVELD#@KK2    KS2,I            型番２STR
