     C                     MOVELQKO,A     KOT,B
     C                     Z-ADDQBM,A     KBM,B
     C                     ENDIF
     C                     ELSE
     C           NKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVELNKO,A     KOT,B
     C                     Z-ADDNBM,A     KBM,B
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
