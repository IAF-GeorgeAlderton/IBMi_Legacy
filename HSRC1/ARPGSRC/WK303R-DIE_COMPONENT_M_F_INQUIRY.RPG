     C*===================================================*
     C*  $TKRS  所番地の取得                            *
     C*===================================================*
     C           $TKRS     BEGSR
     C*
     C                     MOVEL*BLANK    #BAN
     C*
     C           T6KEY1    SETLLGCQTL131
     C           T6KEY1    READEGCQTL131                 98
     C           *IN98     DOWEQ'0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           T6TKR1    IFEQ W@KOJ
     C                     MOVELT6TKR1    #BAN1
     C                     MOVELT6TKR2    #BAN2
     C                     MOVELT6TKR3    #BAN3
     C                     MOVELT6TKR4    #BAN4
     C                     MOVELT6TKR5    #BAN5
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C           T6KEY1    READEGCQTL131                 98
     C                     ENDDO
     C           *IN98     CABEQ'1'       $TKRS1
     C*
     C                     MOVELP@HIN1    K@SHN1
     C                     MOVELP@HIN2    K@SHN2
     C                     MOVELP@HIN3    K@SHN3
     C           DFKEY1    SETLLGCQPL311
     C           DFKEY1    READEGCQPL311                 98
     C           *IN98     DOWEQ'0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C           DFKEY1    READEGCQPL311                 98
     C                     ENDDO
     C           *IN98     CABEQ'1'       $TKRS1
     C*
