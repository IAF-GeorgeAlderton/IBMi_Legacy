     C                     MOVE *BLANK    PNKOJ
     C                     MOVE *BLANK    PNUKE
     C                     Z-ADD*ZERO     PNOHZ
     C                     MOVE *BLANK    PORD#
     C                     Z-ADD*ZERO     W@MXPL  30
     C*
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
      *
     C                     MOVE *OFF      *IN22
JW   C                     Z-ADD0         SVKODT  80
 .   C                     Z-ADD0         SVKOTM  60
     C*
     C                     ENDSR
     C***********************************************************
     C* @MAIN:CONTROL DISPLAY
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C           *INKC     DOWEQ'0'
     C*
     C                     SELEC
     C           WKDSP     WHEQ '0'
     C                     EXFMTABVPW2C0
      *
     C           WKDSP     WHEQ '1'
     C                     EXFMTABVPW2C2
     C*
     C                     OTHER
     C                     WRITEABVPW2C1
     C                     SETON                     70
     C                     EXFMTCTL01
     C                     SETOF                     70
     C                     ENDSL
     C* CLEAR MSG
     C                     MOVEAWKBLAK    *IN,30
     C                     SETOF                     87
     C*
     C           *INKC     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C*
     C                     SELEC
      * BARCODE
     C           WKDSP     WHEQ '0'
     C           *INKI     IFEQ *ON
     C                     CLEARABVPW2C2
     C                     MOVE '1'       WKDSP
     C                     ELSE
      *
     C                     EXSR @CHK0
     C           *IN30     IFEQ *OFF
     C           RRN2      ANDNE*ZERO
      *
     C                     DO   *HIVAL
     C                     MOVE CFK,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE *ON       *INLR
     C                     RETRN
     C           *INKK     WHEQ *ON
     C                     LEAVE
     C                     ENDSL
     C                     ENDDO
     C                     ENDIF
      *
     C           *IN30     IFEQ *OFF
     C                     EXSR @WRT1
     C           @@CNT     IFEQ *ZERO
     C                     MOVELER,12     MSG
     C                     MOVE *ON       *IN30
     C                     MOVE *OFF      *IN87
     C                     ELSE
     C                     EXSR @CLR0
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MANUAL ENTRY
     C           WKDSP     WHEQ '1'
      *
     C           *INKL     IFEQ *ON
     C                     MOVE '0'       WKDSP
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR @CHK1
     C           *IN30     IFEQ *OFF
     C           *INKG     ANDEQ*OFF
     C           RRN2      ANDNE*ZERO
     C                     DO   *HIVAL
     C                     MOVE CFK,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE *ON       *INLR
     C                     RETRN
     C           *INKK     WHEQ *ON
     C                     LEAVE
     C                     ENDSL
     C                     ENDDO
     C                     ENDIF
      *
     C                     SELEC
     C           *INKE     WHEQ '1'
     C           *INKK     OREQ '1'
     C* CHECK OK?
     C           *IN30     IFEQ '0'
     C                     EXSR @WRT1
     C           @@CNT     IFEQ *ZERO
     C                     MOVELER,12     MSG
     C                     MOVE *ON       *IN30
     C                     MOVE *OFF      *IN87
     C                     ENDIF
     C                     END
      *
     C           *INKG     WHEQ '1'
     C           *IN30     IFEQ '0'
     C                     EXSR @SFL
     C                     END
     C*
     C           *INKL     WHEQ '1'
     C                     MOVE '0'       WKDSP
      *
     C                     ENDSL
     C*
     C* 2ND. SCREEN
     C                     OTHER
      *
     C                     SELEC
     C           *INKE     WHEQ '1'
     C           *INKG     OREQ '1'
     C                     EXSR @CHK2
     C* CHECK OK?
     C           *IN30     IFEQ '0'
     C                     EXSR @WRT2
     C                     EXSR @CLRS
     C                     END
     C           *INKL     WHEQ '1'
     C                     EXSR @CLRS
     C                     OTHER
     C                     EXSR @CHK2
     C                     ENDSL
     C*
     C                     ENDSL
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* @CHK0:CHECK BARCODE
     C***********************************************************
     C           @CHK0     BEGSR
     C*
     C                     DO
     C*
     C           D@PCKC    IFEQ '1'
     C           D@PCKC    OREQ '2'
     C                     ELSE
     C                     SETON                     3032
     C                     MOVELER,18     MSG
     C                     LEAVE
     C                     END
     C*
     C           D@BARC    CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     SETON                     3031
     C                     MOVELER,15     MSG
     C                     LEAVE
     C                     END
      *
     C           PUNONY    IFNE 8450
     C                     SETON                     3031
     C                     MOVELER,17     MSG
     C                     LEAVE
     C                     END
      *
     C           PULPDT    IFNE 0
     C**JW1                SETON                     3031
     C**                   MOVELER,19     MSG
     C**                   MOVE PULPDT    MSG
     C**                   LEAVE
JW1  C                     DO   *HIVAL
 |   C                     MOVEL*OFF      *INKJ
 |   C                     MOVEL*OFF      *INKL
 |   C                     Z-ADDPULPDT    WINDT
 |   C                     EXFMTWIN01
 |   C           *INKL     IFEQ *ON
 |   C                     SETON                     3031
 |   C                     MOVELER,19     MSG
 |   C                     MOVE PULPDT    MSG
 |   C                     LEAVE
 |   C                     ENDIF
 |   C           *INKJ     IFEQ *ON
 |   C                     Z-ADD0         PULPDT
 |   C                     LEAVE
 |   C                     ENDIF
JW1  C                     ENDDO
     C                     ENDIF
     C*
     C                     MOVELPUNONY    PNONY
     C                     MOVELPUNKOJ    PNKOJ
     C                     MOVELPUNUKE    PNUKE
     C                     Z-ADDPUBINN    BIN
     C                     Z-ADDPUDAT     PNOHZ
     C                     MOVELPUODRN    PORD#
     C                     MOVE PNONY     WNONY   40
     C                     EXSR #SYSCH
     C*
     C                     MOVELD@PCKC    PPCKC
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* QTY/BOX CHECK
     C***********************************************************
     C           #SYSCH    BEGSR
      *
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
      *
     C                     Z-ADD*ZERO     @ITM    30
      *
     C           KEY1      SETLLAB#PL13
     C           *IN93     DOUEQ*ON
     C           KEY1      READEAB#PL131                 93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C           BIN       IFNE *ZERO
     C           BANOBN    ANDNEBIN
     C                     ITER
     C                     ENDIF
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         @ITM
      *
     C           BASYOS    IFEQ *ZERO
     C                     MOVE BATOKU    PTOKU
     C                     MOVE BANONY    PNONY
     C                     MOVE *BLANK    @SHIN
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           BANKOJ
     C                     PARM           BANUKE  4
     C                     PARM           WMHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG    1
     C                     MOVE @SHN1     BASHN1
     C                     MOVE @SHN2     BASHN2
     C                     MOVE @SHN3     BASHN3
     C           KEY2      CHAINFCEPL011             91
     C           *IN91     IFEQ *OFF
     C                     Z-ADDA2SSYS    BASYOS
     C                     ENDIF
     C                     ENDIF
      *
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@BOX   50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVE INF,2     S@MSG
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDIF
      *
     C           BAUSYS    IFNE BASYOS
     C           BAUSYS    ANDNE*ZERO
     C           BASYOS    ANDNE*ZERO
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVE INF,1     S@MSG
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* @CLR :CLR SCREEN
     C***********************************************************
     C           @CLR0     BEGSR
     C*
     C                     MOVEL*BLANK    D@BARC
     C                     MOVEL*BLANK    D@PCKC
      *
