     C***********************************************************
     C* @CHK1:CHECK ITEMS ON 1ST. SCREEN
     C***********************************************************
     C           @CHK1     BEGSR
     C*
     C* DELIVERY CODE BLANK ?
     C           PNONY     IFEQ *BLANK
     C                     SETON                     3031
     C                     MOVELER,1      MSG
     C                     GOTO #CHK1
     C                     END
     C           PNONY     IFNE '8450'
     C                     SETON                     3031
     C                     MOVELER,17     MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* FACTORY CODE BLANK ?
     C           PNKOJ     IFEQ *BLANK
     C                     SETON                     3032
     C                     MOVELER,2      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* DOCK CODE BLANK ?
     C           PNUKE     IFEQ *BLANK
     C           *INKG     ANDEQ*ON
     C                     SETON                     3033
     C                     MOVELER,3      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* SHIPPING DATE
     C           PNOHZ     IFEQ 0
     C                     SETON                     3034
     C                     MOVELER,4      MSG
     C                     GOTO #CHK1
     C                     END
      *
     C           PNOMM     IFLT 1
     C           PNOMM     ORGT 12
     C                     SETON                     3034
     C                     MOVELER,5      MSG
     C                     GOTO #CHK1
     C                     END
      *
     C           PNODD     IFLT 1
     C           PNODD     ORGT 31
     C                     SETON                     3034
     C                     MOVELER,5      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C*
     C           PPCKC     IFEQ '1'
     C           PPCKC     OREQ '2'
     C                     ELSE
     C                     SETON                     3037
     C                     MOVELER,18     MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* BIN       *
     C           BIN       IFEQ 0
     C                     SETON                     3035
     C                     MOVELER,6      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C                     MOVE PNONY     WNONY   40
     C                     EXSR #SYSCH
     C*
     C           #CHK1     ENDSR
     C***********************************************************
     C* @CHK2:CHECK SFL
     C***********************************************************
     C           @CHK2     BEGSR
     C*
     C                     SETOF                     89
     C                     SETOF                     31
     C                     Z-ADD1         RRN
     C                     DO   W1RRN
     C           RRN       CHAINSFL01                94
     C*
     C           *IN94     IFEQ '0'
     C           @FLAG     IFNE *BLANK
     C           @#LAB     ORNE *ZERO
     C                     SETON                     89
     C                     END
     C           @USYS     IFNE @SYOS
     C                     MOVE *ON       *IN61
     C                     MOVELER,16     MSG
     C                     MOVE *ON       *IN31
     C                     ELSE
     C                     MOVE *OFF      *IN61
     C                     ENDIF
     C                     UPDATSFL01
     C                     END
     C*
     C* NOT USE # OF LABELS
     C                     ADD  1         RRN
     C                     ENDDO
     C*
     C           *IN89     IFEQ '0'
     C                     SETON                     30
     C                     MOVELER,8      MSG
     C                     END
     C*
     C                     Z-ADD1         RRN
     C*
     C                     ENDSR
     C***********************************************************
     C* @DSPATR(CS) LABEL DATA
     C***********************************************************
     C           @WRT1     BEGSR
     C*
     C                     Z-ADD*ZERO     @@CNT   50
     C                     MOVE PNONY     WNONY   40
