     C***********************************************************
     C           @NMBR     BEGSR
      *
     C                     MOVE *ALL'9'   @@14   140
     C           WNONY     CHAINAB#NP30              97
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    N3UDAT
     C                     Z-ADDWSSTM6    N3UTIM
     C                     MOVEL#PGM      N3UPGM
     C                     MOVEL#USER     N3UUSR
     C                     MOVEL#WSID     N3UWIS
     C                     Z-ADDWNONY     N3NONY
