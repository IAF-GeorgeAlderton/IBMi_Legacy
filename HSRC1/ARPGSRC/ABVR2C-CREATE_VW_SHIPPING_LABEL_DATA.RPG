     C                     MOVE X'1E'     @HX4    1
     C                     MOVE '0'       @HX5    1
     C                     MOVE '6'       @HX6    1
     C                     MOVE X'1D'     @HX7    1
     C                     MOVE X'37'     @HX8    1
     C                     MOVE @HX1      @DX1
     C                     MOVE @HX2      @DX2
     C                     MOVE @HX3      @DX3
