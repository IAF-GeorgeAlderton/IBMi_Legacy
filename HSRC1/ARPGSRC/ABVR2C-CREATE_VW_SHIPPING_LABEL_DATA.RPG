     C           @DX7      CAT  '7Q':0    @DX7      P
     C           @DX7      CAT  W@GWHT:0  @DX7      P
     C           @DX7      CAT  'KG':0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  'B':0     @DX7      P
     C           @DX7      CAT  F2PAC1    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '6D':0    @DX7      P
     C           @DX7      CAT  W@DPHZ:0  @DX7      P
     C           @DX7      CAT  '002':0   @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '10Y':0   @DX7      P
     C           @DX7      CAT  F2PLAN:0  @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  'F02':0   @DX7      P
     C           @DX7      CAT  '010I':0  @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  'P':0     @DX7      P
     C           @DX7      CAT  AEMHIN:0  @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '4LUS':0  @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '2P':0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  'IT':0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '14D':0   @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '7Q':0    @DX7      P
     C           @DX7      CAT  F2PQY1:0  @DX7      P
     C           @DX7      CAT  'PC':0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '7Q':0    @DX7      P
     C           @DX7      CAT  W@NWHT:0  @DX7      P
     C           @DX7      CAT  '58':0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C           @DX7      CAT  '11Y':0   @DX7      P
     C           @DX7      CAT  AEMAN#:0  @DX7      P
     C           @DX7      CAT  @HX4:0    @DX7      P
     C           @DX7      CAT  @HX8:0    @DX7      P
     C                     MOVEL@DX       F22DBR
JW5   * PACKAGE TYPE
 |   C           PPCKC     IFEQ '1'
 |   C                     MOVEL'RE'      F2PTYP           RETURNABLE
 |   C                     ELSE
 |   C                     MOVEL'EX'      F2PTYP           EXPENDABLE
JW5  C                     ENDIF
     C*
     C                     DO   W#LAB
     C                     WRITEABVWP2F1
     C                     ENDDO
     C*
     C                     MOVEL*OFF      W@MSTR  1
     C                     EXSR #PP70
     C*
     C                     ENDSR
     C***********************************************************
     C* @SFL:CREATE SUB FILE
     C***********************************************************
     C           @SFL      BEGSR
     C*
     C                     Z-ADD*ZERO     RRN
     C                     MOVE PNONY     WNONY
     C                     MOVE *OFF      *IN31
     C*
     C           KEY1      SETLLAB#PL131
     C           KEY1      READEAB#PL131                 93
     C           *IN93     DOWEQ'0'
     C                     MOVE *OFF      *IN61
     C*
     C* DELETED  ?
     C           BASKJY    IFNE ' '
     C                     GOTO #READ
     C                     END
     C*
     C* SAME BIN ?
     C           BIN       IFNE 0
     C           BIN       ANDNEBANOBN
     C                     GOTO #READ
     C                     END
      *
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     GOTO #READ
     C                     ENDIF
     C*
     C* IF SELECTED ORDER#, SAME ORDER# ?
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     GOTO #READ
     C                     END
     C*
     C* SET DATA TO SUB FILE
     C                     ADD  1         RRN
     C           RRN       CHAINSFL01                94
     C                     MOVE *BLANK    @FLAG
     C                     Z-ADD*ZERO     @#LAB
     C*
     C           BAMHN4    IFEQ *BLANK
     C                     MOVE *BLANK    @P3
     C                     MOVE *BLANK    WAMHN4
     C                     ELSE
     C                     MOVE BAMHN4    WAMHN4
     C                     MOVE '-'       @P3
     C                     END
     C*
     C           BAMHN3    IFEQ *BLANK
     C                     MOVE *BLANK    @P2
     C                     MOVE *BLANK    WAMHN3
     C                     ELSE
     C                     MOVE BAMHN3    WAMHN3
     C                     MOVE '-'       @P2
     C                     END
     C*
     C           BAMHN2    IFEQ *BLANK
     C                     MOVE *BLANK    @P1
     C                     MOVE *BLANK    WAMHN2
     C                     ELSE
     C                     MOVE BAMHN2    WAMHN2
     C                     MOVE '-'       @P1
     C                     END
     C*
     C                     MOVE BAMHN1    WAMHN1
     C*
     C                     MOVE BASBAN    @SBAN
     C                     MOVE BAODRN    @ODER
     C                     Z-ADDBASRYO    @RQTY
     C                     Z-ADDBASYOS    @SYOS
     C                     Z-ADDBAUSYS    @USYS
     C           BASYOS    IFNE BAUSYS
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN31
     C                     MOVELER,16     MSG
     C                     ENDIF
     C   94                WRITESFL01
     C  N94                UPDATSFL01
     C*
     C           #READ     TAG
     C           KEY1      READEAB#PL131                 93
     C                     END
     C*
     C           RRN       IFEQ *ZERO
     C                     SETON                     30
     C                     MOVELER,12     MSG
     C*
     C                     ELSE
     C                     MOVE '2'       WKDSP
     C                     Z-ADDRRN       W1RRN
     C                     Z-ADD1         RRN
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* @WRT2:WRITE LABEL DATA(SELECTED PART NUMBER)
     C***********************************************************
     C           @WRT2     BEGSR
     C*
     C                     SETON                     8887
     C* GET THE NUMBER OF LABEL
     C           PNONY     CHAINAB#PL90              96
     C           *IN96     IFEQ '0'
     C                     Z-ADDYA#LAB    W#LAB
     C                     Z-ADDYAMXPL    W@MXPL
     C                     ELSE
     C                     Z-ADD1         W#LAB
     C                     END
     C*
     C                     Z-ADD1         RRN
     C                     DO   W1RRN
     C           RRN       CHAINSFL01                94
     C           *IN94     IFEQ '0'
     C           @FLAG     IFNE *BLANK
     C           @#LAB     ORNE 0
     C*
     C                     MOVE PNONY     WNONY   40
     C                     MOVEL@ODER     WORDN  10
     C*
     C                     EXSR @8450
     C*
     C                     END
     C                     END
     C*
     C           #WRT2     TAG
     C                     ADD  1         RRN
     C*
     C                     ENDDO
     C*
     C                     SETOF                     88
     C*
     C                     ENDSR
     C***********************************************************
      *  SET FIELDS FOR AB#PP70
     C***********************************************************
     C           #PP70     BEGSR
      *
     C                     Z-ADD*YEAR     EKKOYY
     C                     Z-ADD*MONTH    EKKOMM
     C                     Z-ADD*DAY      EKKODD
     C                     TIME           @@TIM
     C                     MOVE @@HH      EKKOHH
     C                     MOVE @@MM      EKKOMN
     C                     MOVEL#USER     EKKOME
     C                     MOVE BANONY    EKNONY
     C                     MOVE BANKOJ    EKNKOJ
     C                     MOVE BANUKE    EKNUKE
     C                     MOVE A2ZETI    EKZETI
     C           W@MSTR    IFEQ *ON
     C                     MOVEL'99999'   EKSYOS
     C                     ELSE
     C                     MOVE W@SYOS    EKSYOS
     C                     END
     C                     MOVE BAODRN    EKODRN
     C                     MOVE BASHN1    EKSHN1
     C                     MOVE BASHN2    EKSHN2
     C                     MOVE BASHN3    EKSHN3
     C                     MOVE BANOYY    EKNOYY
     C                     MOVE BANOMM    EKNOMM
     C                     MOVE BANODD    EKNODD
     C                     Z-ADDBATOKU    EKTOKU
     C                     MOVELBAMHN1    EKMHN1
     C                     MOVELBAMHN2    EKMHN2
     C                     MOVELBAMHN3    EKMHN3
     C                     MOVELBAMHN4    EKMHN4
     C                     MOVE BANOBN    EKNOBN
     C                     MOVE N3NMBR    EKSERL
     C                     MOVELPNONY     EKSERL
     C                     Z-ADDBADEYY    EKRLYY
     C                     Z-ADDBADEMM    EKRLMM
     C                     Z-ADDBADEDD    EKRLDD
     C*
     C                     EXSR #PP758
JW5   * PACKAGE TYPE
 |   C           EKNONY    IFEQ '8450'
 |   C           D@PCKC    IFEQ '1'
 |   C                     Z-ADD11        EKSKDD
 |   C                     ELSE
 |   C                     Z-ADD22        EKSKDD
 |   C                     ENDIF
JW5  C                     ENDIF
     C*
     C                     WRITEAB#PP701
     C*
     C                     ENDSR
     C***********************************************************
      *  UPDATE AB#PL75 & AB#PL78
     C***********************************************************
     C           #PP758    BEGSR
     C*
     C           K#PL7#    KLIST
     C                     KFLD           EKNOYY
     C                     KFLD           EKNOMM
     C                     KFLD           EKNODD
     C                     KFLD           EKTOKU
     C                     KFLD           K#NONY  40
     C                     KFLD           EKNKOJ
     C                     KFLD           EKNUKE
     C                     KFLD           K#NOBN  20
     C                     KFLD           K#RLYY  40
     C                     KFLD           K#RLMM  20
     C                     KFLD           K#RLDD  20
     C                     KFLD           K#ODRN 10
     C                     MOVELEKNONY    K#NONY
     C                     MOVELEKNOBN    K#NOBN
     C                     MOVELEKODRN    K#ODRN
     C                     Z-ADDEKRLYY    K#RLYY
     C                     Z-ADDEKRLMM    K#RLMM
     C                     Z-ADDEKRLDD    K#RLDD
     C           K#PL7#    CHAINAB#PL75R             81
     C           *IN81     IFEQ *ON
JW   C           *IN81     OREQ *OFF
.    C           PUSKJY    ANDEQ'D'
     C                     MOVEL*BLANK    K#ODRN
     C           K#PL7#    CHAINAB#PL75R             81
     C                     END
     C*
     C           *IN81     IFEQ *OFF
JW   C           PUSKJY    ANDNE'D'
     C*
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    PULPDT
     C                     Z-ADDWSSDAT    PUKODT
     C                     Z-ADDWSSTM6    PUKOTN
     C                     MOVEL#USER     PUKOME
     C                     UPDATAB#PL75R
     C*
     C           K#PL7#    CHAINAB#PL78              82
     C           *IN82     IFEQ *OFF
     C           P8SKJY    ANDEQ*BLANK
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    P8KODT
     C                     Z-ADDWSSTM6    P8KOTM
     C                     MOVEL#USER     P8KONM
     C           P8LPDT    IFEQ *ZERO
     C                     Z-ADDWSSDAT    P8LPDT
     C                     Z-ADDWSSTM6    P8LPTM
     C                     MOVEL#USER     P8LPNM
     C                     END
JW4   * PACKAGE TYPE
 |   C           PPCKC     IFEQ '1'
 |   C                     MOVEL'1 RETURN'P8FLD3    P      RETURNABLE
 |   C                     ELSE
 |   C                     MOVEL'2 EXPEND'P8FLD3    P      EXPENDABLE
JW4  C                     ENDIF
      *
     C                     UPDATAB#PP781
JW    * LOG
 .   C           P8KODT    IFNE SVKODT
 .   C           P8KOTM    ORNE SVKOTM
 .   C                     MOVEL#PGM      P8LPPG
 .   C                     MOVEL'ABVR2C'  P8KOPG    P
 .   C                     WRITEAB#PP78R
 .   C                     Z-ADDP8KODT    SVKODT
 .   C                     Z-ADDP8KOTM    SVKOTM
JW   C                     ENDIF
      *
     C                     END
     C*
     C                     END
     C*
      *
     C                     ENDSR
     C***********************************************************
