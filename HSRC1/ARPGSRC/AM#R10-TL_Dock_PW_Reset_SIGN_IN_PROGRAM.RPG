     C                     ENDIF
      *
     C                     MOVE R3WKCD    POPR             SET WORKER ID
     C                     MOVE 'Y'       VALID            VALID ID Y/N
     C                     LEAVE
      *
      * not found in worker code master file
     C                     ELSE
     C                     SETON                     3031
     C                     MOVEAERR,1     MSG
     C           POPR      IFNE *BLANKS
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
