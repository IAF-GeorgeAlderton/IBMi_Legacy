     H            Y.
     F** EDSR72 ***********************************************
     F*  PROGRAM: UTILITY - SAVE ABWEP70/71 TO ABWEP70S/71S
     F*  WRITTEN: JW (SRA)  2021.07.08
     F*--------------------------------------------------------
     FABWEP70 UF  E                    DISK
     FABWEP71 UF  E                    DISK
     FABWEP70SO   E                    DISK
     FABWEP71SO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * INITIAL SETTING
     C                     TIME           D#TIME
      * SAVE ABWEP70 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ ABWEP70                  99
     C           *IN99     IFEQ *OFF
     C           E7FLG0    ANDEQ*BLANK
     C                     Z-ADDTODAY     E7CRDT
     C                     Z-ADDNOW       E7CRTM
     C                     MOVEL#USER     E7CRUS
     C                     MOVEL#WSID     E7CRWS
     C                     MOVEL#PGM      E7CRPG
     C                     WRITEABWE70S1
      *
     C                     MOVE '*'       E7FLG0
     C                     UPDATABWEP701
     C                     ENDIF
     C                     ENDDO
      * SAVE ABWEP71 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ ABWEP71                  99
     C           *IN99     IFEQ *OFF
     C           E7FLG1    ANDEQ*BLANK
     C                     Z-ADDTODAY     E7CRDT
     C                     Z-ADDNOW       E7CRTM
     C                     MOVEL#USER     E7CRUS
     C                     MOVEL#WSID     E7CRWS
     C                     MOVEL#PGM      E7CRPG
     C                     WRITEABWE71S1
      *
     C                     MOVE '*'       E7FLG1
     C                     UPDATABWEP711
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
