     H            Y.
     F** GDLR1G ****************************************************************
     F*  PROGRAM    : CREATE MATERIAL ORDER IFS.CSV                            *
     F*  WRITTEN    : 10/31/2018                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FGDOKP01 IF  E           K        DISK
     FGDOKP02 IF  E           K        DISK
     FGDLWP04 O   E           K        DISK
     F**************************************************************************
     E                    TTL     1   4 20
     I            DS
     I                                        1  140SDATE
     I                                        1   60STIME
     I                                        7  140TODAY
     I                                        9  100TODYY
     I                                       11  120TODMM
     I                                       13  140TODDD
     I            DS
     I                                        1   9 @@ORD#
     I                                        1   20@@OMM
     I                                        3   40@@ODD
     I                                        5   60@@OYY
     I                                        7   9 @@SEQ
     I            DS
     I                                        1  10 PODATE
     I                                        1   20OKREDM
     I                                        3   3 DASH1
     I                                        4   50OKREDD
     I                                        6   6 DASH2
     I                                        7  100OKREDY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
      *
     C                     SELEC
     C           $SIRE     WHEQ '4511'
     C                     READ GDOKP01                  98
     C           $SIRE     WHEQ '4530'
     C                     READ GDOKP02                  98
     C                     OTHER
     C                     MOVE *ON       *IN98
     C                     ENDSL
      *
     C   98                LEAVE
      *
     C                     EXSR #WRT1
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  WRITE                                             *
      *----------------------------------------------------*
     C           #WRT1     BEGSR
      * HEADER
     C           HEADER    IFEQ 'Y'
     C                     MOVE 'N'       HEADER
     C                     EXSR #HEAD
     C                     ENDIF
      * DETAIL
     C                     CLEARGDLWP041
     C                     MOVELOKSIRE    GKSIRE           SUPPLIER
     C                     MOVEL@@ORD#    GKORD#           PO#
     C                     MOVELPODATE    GKODDT           PO DATE
     C                     MOVELOKZAIS    GKZAIS           ITEM#
     C                     EXSR #DESC
     C                     MOVEL@@DESC    GKZAID           ITEM DESCRIPTION
      *
     C                     MOVE *BLANK    @@VEND  6
     C                     SELEC
     C           OKSIRE    WHEQ 4511
     C                     MOVEL'OKA01'   @@VEND
     C           OKSIRE    WHEQ 4530
     C                     MOVEL'NSC01'   @@VEND
     C           OKSIRE    WHEQ 8990
     C                     MOVEL'ASJ01'   @@VEND
     C                     OTHER
     C                     MOVEL'IAF01'   @@VEND
     C                     ENDSL
      *
     C                     MOVEL@@VEND    GKVEND           VENDOR ID
     C                     MOVELOKMAIS    GKMAIS           # COILS
     C                     MOVELOKTKJR    GKTKJR           U/W
      *
     C                     WRITEGDLWP041
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  DESCRIPTION                                       *
      *----------------------------------------------------*
     C           #DESC     BEGSR
      *
     C                     MOVE *BLANK    @@DESC 30
      *
     C                     Z-ADDOKZAIK    $IN
     C                     CALL 'UTLR64'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     @ZAIK   6
     C                     MOVELOKZAIS    @@DESC
     C                     MOVE @ZAIK     @@DESC
      *
     C                     MOVEL@@DESC    $IN2
     C                     CALL 'UTLR65'
     C                     PARM           $IN2  100
     C                     PARM           $OUT2 100
     C                     PARM           $RTN2   1
     C                     MOVEL$OUT2     @@DESC
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  WRITE HEADER                                      *
      *----------------------------------------------------*
     C           #HEAD     BEGSR
      *
     C                     CLEARGDLWP041
     C                     MOVEL'Supplier'GKSIRE           SUPPLIER
     C                     MOVEL'PO#'     GKORD#           PO#
     C                     MOVEL'PO Date' GKODDT           PO DATE
     C                     MOVELTTL,1     GKZAIS           ITEM#
     C                     MOVELTTL,2     GKZAID           ITEM DESCRIPTION
     C                     MOVELTTL,3     GKVEND           VENDOR ID
     C                     MOVELTTL,4     GKMAIS           # COILS
     C                     MOVEL'U/W'     GKTKJR           U/W
     C                     WRITEGDLWP041
      * OUT SIRE
     C**                   MOVELOKSIRE    $SIRE
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SIRE   4
      *
     C**                   MOVE *BLANK    $SIRE
     C                     MOVE 'Y'       HEADER  1
     C                     TIME           SDATE
     C                     Z-ADDTODYY     @@OYY
     C                     Z-ADDTODMM     @@OMM
     C                     Z-ADDTODDD     @@ODD
     C                     MOVEL'ALH'     @@SEQ
     C                     MOVE '/'       DASH1
     C                     MOVE '/'       DASH2
      *
     C                     ENDSR
** TTL
Item Number
Item Description
Vendor ID
# Of Coils
