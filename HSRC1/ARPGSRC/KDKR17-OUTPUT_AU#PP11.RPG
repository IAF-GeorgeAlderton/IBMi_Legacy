     H            Y.
     F*    KATOGI.         2015.12.21            *
     FKDKWP12 IF  E                    DISK
     FFCEPL01 IF  E           K        DISK
     FAU#PP11 O   E                    DISK                      A
     FAU#NP11 UF  F       9            DISK                      A
      *
     IAU#NP11 AA  70
     I                                        1   20AHZMM
     I                                        3   90ARECD
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1  14 W2SHN
     I                                        1   5 W2SHN1
     I                                        6  10 W2SHN2
     I                                       11  12 W2SHN3
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        1   20STIHH
     I                                        3   40STIMM
     I                                        5   60STISS
     I                                        7  140SDATE
     I                                        7  100SDAYY
     I                                       11  120SDAMM
     I                                       13  140SDADD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WDATE
      *
     C                     READ KDKWP121                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ KDKWP121                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAU#PP111
     C                     Z-ADDSDAYY     CQKOYY
     C                     Z-ADDSDAMM     CQKOMM
     C                     Z-ADDSDADD     CQKODD
     C                     Z-ADDSTIHH     CQKOHH
     C                     Z-ADDSTIMM     CQKOSS
     C                     MOVELW#PGM     CQKOME
      *
     C                     MOVELW2SHN1    CQSHN1
     C                     MOVELW2SHN2    CQSHN2
     C                     MOVELW2SHN3    CQSHN3
     C                     MOVEL'C'       CQTANI
     C                     MOVEL'C'       CQNSYK
     C                     Z-ADD*YEAR     CQNOYY
     C                     Z-ADDUMONTH    CQNOMM
     C                     Z-ADDUDAY      CQNODD
     C                     Z-ADD0         CQNOBB
      *
     C                     Z-ADD*YEAR     CQTHYY
     C                     Z-ADDUMONTH    CQTHMM
     C                     Z-ADDUDAY      CQTHDD
     C                     Z-ADD0         CQCIC1
     C                     Z-ADD0         CQCIC2
     C                     Z-ADD0         CQCIC3
     C                     Z-ADDSTIHH     CQTHJI
     C                     Z-ADDSTIMM     CQTHPN
     C                     Z-ADDSTIHH     CQURJI
     C                     Z-ADDSTIMM     CQURPN
      *
     C           BKEY      KLIST
     C                     KFLD           CQSHN1
     C                     KFLD           CQSHN2
     C                     KFLD           CQSHN3
     C           BKEY      CHAINFCEPL011             96
     C           *IN96     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     96
     C                     ENDIF
     C           *IN96     IFEQ '1'
     C                     MOVE 'S'       CQTHAI
     C                     ELSE
     C                     MOVE A2TEHI    CQTHAI
     C           A2TRHZ    IFGT *DATE
     C                     MOVE A2KTRK    CQSBKJ
     C                     MOVE A2KTRT    CQSBRO
     C                     MOVE A2KTRR    CQSBRT
     C                     MOVE A2KTRD    CQSBDN
     C                     ELSE
     C                     MOVE A2STRK    CQSBKJ
     C                     MOVE A2STRT    CQSBRO
     C                     MOVE A2STRR    CQSBRT
     C                     MOVE A2STRD    CQSBDN
     C                     ENDIF
     C                     Z-ADDA2SSYS    CQSYUY
     C                     ENDIF
     C           W2HAKO    MULT CQSYUY    CQSRYO
     C                     Z-ADDW2HAKO    CQHAKO
      *
     C                     MOVEL'K'       CQSKKB
     C                     Z-ADD*YEAR     CQURYY
     C                     Z-ADDUMONTH    CQURMM
     C                     Z-ADDUDAY      CQURDD
      *
     C                     MOVEL' '       CQDTSY
     C                     MOVEL'4'       CQDTSO
     C                     MOVEL'20'      CQGYOM
      *
     C                     SETOF                     96
     C           1         CHAINAU#NP11              96
     C           *IN96     IFEQ '0'
     C           AHZMM     IFNE UMONTH
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     ELSE
     C                     ADD  1         ARECD
     C                     ENDIF
     C                     EXCPTUP
     C                     ELSE
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     EXCPTWT
     C                     ENDIF
      *
     C                     Z-ADDARECD     CQJTNO
     C                     MOVEL'B'       CQBNKA
      *
     C                     WRITEAU#PP111
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
     OAU#NP11 E                UP
     O                         AHZMM      2
     O                         ARECD      9
     O        EADD             WT
     O                         AHZMM      2
     O                         ARECD      9
