     C                     Z-ADD*ZERO     V
     C           Z         DO   B         X
     C           ARY,X     IFEQ ','
     C                     LEAVE
     C                     ENDIF
     C           ARY,X     IFNE *BLANK
     C           ARY,X     ANDNE'-'
