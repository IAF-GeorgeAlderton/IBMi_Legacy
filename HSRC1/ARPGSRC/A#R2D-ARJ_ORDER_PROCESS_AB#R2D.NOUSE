     C                     ENDDO
      *
     C                     MOVEAA15       AWMHIN
      *
     C                     Z-ADD*ZERO     QTY
      * QTY
     C           B         ADD  1         X
     C           ','       LOKUPARY,X                    10
     C                     ADD  1         X
     C           ','       LOKUPARY,X                    10
     C*                    ADD  1         X
     C*          ','       LOKUPARY,X                    10
     C*                    ADD  1         X
     C*          ','       LOKUPARY,X                    10
      *
     C           X         ADD  1         Z
     C                     Z-ADD*ZERO     QTY
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     T       30
     C                     MOVE *BLANK    A9
     C           Z         DO   2304      X
     C           ARY,X     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C           ARY,X     IFEQ ','
