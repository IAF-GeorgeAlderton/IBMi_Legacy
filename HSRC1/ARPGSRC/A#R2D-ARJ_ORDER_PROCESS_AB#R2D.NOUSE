     C                     ADD  1         X
     C           ','       LOKUPARY,X                    10
     C                     ADD  1         X
     C           ','       LOKUPARY,X                    10
     C                     ADD  1         X
     C                     Z-ADDX         Z       50
     C           ','       LOKUPARY,X                    10
     C                     Z-ADDX         B       50
     C                     MOVE *BLANK    A9
     C                     Z-ADD*ZERO     V
     C           Z         DO   B         X
     C           ARY,X     IFNE *BLANK
     C           ARY,X     ANDNE','
     C                     ADD  1         V
     C                     MOVE ARY,X     A9,V
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD9         W
     C                     Z-ADD9         V       30
     C                     DO   9
     C           A9,W      IFNE *BLANK
     C                     MOVE A9,W      A9X,V
     C                     SUB  1         V
     C                     ENDIF
     C                     SUB  1         W
     C           W         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSYOS
      *
     C           1         DO   249       X
