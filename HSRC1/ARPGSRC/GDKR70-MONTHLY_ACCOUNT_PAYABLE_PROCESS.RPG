     C           #CHG      PLIST
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C*
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
     C                     PARM           PVEND   4
     C                     PARM           PSIHZ   60
     C*
     C                     MOVELPVEND     WVEND   4
     C                     Z-ADDPSIHZ     WSIHZ   60
     C*
     C           KEY1      KLIST
     C                     KFLD           WSIYY
     C                     KFLD           WSIMM
     C                     KFLD           WVEND
     C           KEY2      KLIST
     C                     KFLD           ITODER
     C                     KFLD           ITITEM
     C*
     C                     SETOF                     90
     C           KEY1      SETLLGDKPL0C1
     C                     DO   *HIVAL
     C           KEY1      READEGDKPL0C1                 90
     C           *IN90     IFEQ '0'
     C           ITSKJY    IFEQ 'D'
     C           ITSKHZ    ANDLE*DATE
     C                     ELSE
     C*
     C           ITMMHZ    IFEQ 0
     C*
     C                     Z-ADD5         PLEN
     C                     Z-ADDITTAN     PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      ITTAN1
     C*
     C                     Z-ADD5         PLEN
     C                     Z-ADDITRATE    PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      ITRAT1
     C*
     C*
     C                     Z-ADD5         PLEN
     C                     Z-ADDITDOLL    PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      ITDOL1
     C*
     C                     WRITEGDKWP701
     C                     Z-ADD*DATE     ITKOHZ
     C                     TIME           ITKOTM
     C                     MOVELPUSER     ITKOME
     C                     Z-ADD*DATE     ITMMHZ
     C                     UPDATGDKPL0C1
     C* DIE
     C                     SETOF                     80
     C           ITTYPE    IFEQ 'K'
     C           KEY2      CHAINGDIPL161             80
     C           *IN80     IFEQ '0'
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADD*DATE     IIKOHZ
     C                     TIME           IIKOTM
     C                     MOVELPUSER     IIKOME
     C                     Z-ADD*DATE     IIMJHZ
     C                     UPDATGDIPL161
     C                     END
     C                     END
     C* FINISHED : WASHER : HALF-FINISHED
     C                     ELSE
     C           KEY2      CHAINGDGPL161             80
     C           *IN80     IFEQ '0'
     C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADD*DATE     ICKOHZ
     C                     TIME           ICKOTM
     C                     MOVELPUSER     ICKOME
     C                     Z-ADD*DATE     ICMJHZ
     C                     UPDATGDGPL161
     C                     END
     C                     END
     C                     END
     C*
     C                     END
     C*
     C                     END
     C                     END
     C  N90                ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
