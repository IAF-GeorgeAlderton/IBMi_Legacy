     H            Y.
     F** ABNR03 *********************************************
     F* KANBAN M/F INFO AAPPP01
     F*    SAKAKI.         2019.04.09                       *
     F*******************************************************
     FAAPPL03 IF  E                    DISK
     FABNPP01 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     READ AAPPL03                  21
     C           *IN21     DOWEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLESDATE
     C                     ELSE
     C           L5STHZ    IFEQ 99999999
     C                     EXSR #SB200
     C                     ENDIF
     C                     ENDIF
     C                     READ AAPPL03                  21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *完成かんばん検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYA31    KLIST
     C                     KFLD           K6CRDT  80
     C                     KFLD           K6KCD1  1
     C                     KFLD           K6KCD2  1
     C                     KFLD           K6LOTK  30
     C                     Z-ADDSDATE     K6CRDT
     C                     MOVELL5KCD1    K6KCD1
     C                     MOVELL5KCD2    K6KCD2
     C                     Z-ADD1         K6LOTK
      *
     C           KEYA31    CHAINABNPP01              82
     C           *IN82     IFEQ '0'
     C                     ADD  L5KMAX    S6KMAX
     C                     ADD  L5UZAR    S6CMAI
     C                     ADD  L5AUAJ    S6AUAJ
     C                     ADD  L5KAIH    S6KAIH
     C                     ADD  L5SINH    S6SINH
     C                     ADD  L5DUPH    S6DUPH
     C                     ADD  L5HRH1    S6HRH1
     C                     ADD  L5HRH2    S6HRH2
     C                     ADD  L5HRH3    S6HRH3
     C                     ADD  L5HRH4    S6HRH4
     C                     ADD  L5MNDS    S6MNDS
     C                     ADD  L5HRYO    S6HRYO
     C                     ADD  L5HLTS    S6HLTS
     C                     ADD  L5JTEI    S6JTEI
     C                     ADD  L5SKJI    S6SKJI
     C                     ADD  L5PADJ    S6PADJ
     C                     ADD  L5OTHH    S6OTHH
     C                     UPDATABNPP011
     C                     ELSE
     C                     CLEARABNPP011
     C                     Z-ADDSDATE     S6CRDT
     C                     MOVELL5KCD1    S6KCD1
     C                     MOVELL5KCD2    S6KCD2
     C                     Z-ADD1         S6LOTK
     C                     Z-ADDL5KMAX    S6KMAX
     C                     Z-ADDL5UZAR    S6CMAI
     C                     Z-ADDL5AUAJ    S6AUAJ
     C                     Z-ADDL5KAIH    S6KAIH
     C                     Z-ADDL5SINH    S6SINH
     C                     Z-ADDL5DUPH    S6DUPH
     C                     Z-ADDL5HRH1    S6HRH1
     C                     Z-ADDL5HRH2    S6HRH2
     C                     Z-ADDL5HRH3    S6HRH3
     C                     Z-ADDL5HRH4    S6HRH4
     C                     Z-ADDL5MNDS    S6MNDS
     C                     Z-ADDL5HRYO    S6HRYO
     C                     Z-ADDL5HLTS    S6HLTS
     C                     Z-ADDL5JTEI    S6JTEI
     C                     Z-ADDL5SKJI    S6SKJI
     C                     Z-ADDL5PADJ    S6PADJ
     C                     Z-ADDL5OTHH    S6OTHH
     C                     WRITEABNPP011
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
