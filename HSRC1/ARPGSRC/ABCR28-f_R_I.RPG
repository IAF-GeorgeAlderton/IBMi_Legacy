     H            Y.
     F*** ABCR13 ********************************
     F*     指示かんばん枚数　の　計算        *
     F*       H.ITO         1991.06.27          *
     F*=========================================*
     F*このＰＧＭを修正したら下記ＰＧＭも修正 *
     F*ＰＧＭ：ＡＢＣＲ１３                   *
     F******************************** ABCR13 ***
     C           *ENTRY    PLIST
     C                     PARM           PARM01  2        LRﾆﾍｭc
     C                     PARM           PARM02  90       ﾍajﾒﾇcﾒｭc
     C                     PARM           PARM03  50       ﾆｬcﾑcﾇc
     C                     PARM           PARM04  41       TOTAL L.T
     C                     PARM           PARM05  20       xｮgﾌﾞﾛﾓA
     C                     PARM           PARM06  32       ﾌﾞ[lgibﾇc
     C                     PARM           PARM07  20       zgbﾛﾜｮn
    >C                     PARM           PARM08  50       MAXﾌﾃﾇc
     C                     PARM           PARM09  1        ﾆ]ﾆｫhﾎﾞ]
     C                     PARM           PARM10  20       ﾏｰﾅﾞｰjoﾌﾞ]ﾇc
C0001C                     PARM           PARM11  50       f]ﾌﾞ]ubﾇc
      *
     C           PARM01    IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           PARM03    CABEQ0         @END
      *
     C*  DDDDD = ﾍajﾒﾇcﾒｭc MULT ﾌﾞ[lgibﾇc DIV ﾆｬcﾑcﾇc
     C*
     C           PARM02    MULT PARM04    AAAAA   90
     C           AAAAA     MULT PARM06    BBBBB   91
     C           BBBBB     ADD  0.9       CCCCC   90
     C           CCCCC     DIV  PARM03    DDDDD   90
     C                     MVR            EEEEE   90
     C           EEEEE     IFNE 0
     C                     ADD  1         DDDDD
     C                     END
      *
     C           PARM05    SUB  1         FFFFF   20
      *
     C* HHHHH<ﾆ]ﾆｫgﾒfd ﾆﾞｭcﾇc> = ﾆ]ﾆｫhﾎﾞ]-A ﾉng
     C*                              ﾍajﾒﾇcﾒｭc DIV ﾆｬcﾑcﾇc < 1 = 2
     C*                          ﾆ]ﾆｫhﾎﾞ]-B ﾉng
     C*                              ﾍajﾒﾇcﾒｭc DIV ﾆｬcﾑcﾇc < 2 = 1
     C*
     C           PARM09    IFEQ 'A'
     C           PARM02    DIV  PARM03    HHHHH   90
     C           HHHHH     IFLT 1
     C                     Z-ADD2         IIIII   10
     C                     END
     C                     END
     C           PARM09    IFEQ 'B'
     C           PARM02    DIV  PARM03    HHHHH
     C           HHHHH     IFLT 2
     C                     Z-ADD1         IIIII
     C                     END
     C                     END
      *
     C*    MMMMM = DDDDD + FFFFF + IIIII + joﾌﾞ]ﾇc
     C* <f]ﾌﾞ]ubﾇc >
     C*
     C           DDDDD     ADD  FFFFF     JJJJJ   90
     C           JJJJJ     ADD  IIIII     LLLLL   90
     C           LLLLL     ADD  PARM10    MMMMM   90
     C                     Z-ADDMMMMM     PARM11
      *
     C           PARM11    IFLT 2
     C                     Z-ADD2         PARM11
     C                     END
     C*
     C* ubﾇc = ﾌﾞﾛﾓ
     C*
     C           PARM11    IFLE PARM05
     C           PARM05    ADD  1         PARM11
     C                     END
     C*
     C* f]ﾌﾞ]ubﾇc + MAX
     C*
     C                     ADD  PARM08    PARM11
      *
     C           @END      TAG
      *
     C                     RETRN
