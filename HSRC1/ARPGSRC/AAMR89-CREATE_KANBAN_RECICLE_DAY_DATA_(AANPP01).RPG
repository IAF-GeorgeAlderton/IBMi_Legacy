     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I            DS
     I                                        1   40@@YM
     I                                        1   20@YY
     I                                        3   40@MM
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
     C* f]ﾌﾞ]ubﾇc ibﾅ]PGM s ﾌﾟ[xｰjｰﾒﾇn
     C           ACALL     PLIST
     C                     PARM           ASTLR            SETON LR ﾍｭcﾆg
     C                     PARM           L7TKR1           nﾃﾜﾌﾞ]k 1
     C                     PARM           L7TKR2                   2
     C                     PARM           L7TKR3                   3
     C                     PARM           L7TKR4                   4
     C                     PARM           WKTSU            fhmbﾈｮmbﾇc
     C                     PARM           L7SYOS           ﾆｬcﾑcﾇc
     C                     PARM           WLTM1            ﾆbﾛﾅgL.T
     C                     PARM           WLTM2            a]ﾈﾞ]L.T
     C                     PARM           L7BMON           ﾃcpｬc ﾎﾞy]
     C                     PARM           L7SKCD           ﾈbgｬcﾅg
     C                     PARM           WHITO            ﾍgnﾒﾇc
     C                     PARM           ZHITO            ﾍgnﾒﾜｮn
     C                     PARM           L7KCD1           f]ﾌﾞ] jﾞb
     C                     PARM           L7KCD2                 ﾆｭc
     C                     PARM           L7UZAR           a]ﾈﾞ]ubﾇc
     C                     PARM           WMAIS            f]ﾌﾞ]ubﾇc
     C                     PARM           L7HKSU           ﾌﾃﾇc
     C                     PARM           PYM              ﾆｭﾒﾍﾇﾞi
     C*
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
     C           CKEY      KLIST
     C                     KFLD           L7TKR1
     C                     KFLD           L7TKR2
     C                     KFLD           L7TKR3
     C                     KFLD           L7TKR4
      *
     C           KEY2      KLIST
     C                     KFLD           L7BMON
     C                     KFLD           L7TAIP
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKT1T
     C                     ENDIF
     C                     Z-ADDUYEAR     @YY
     C                     Z-ADDUMONTH    @MM
     C                     MOVE @@YM      PYM     4
      *
     C                     READ AANPP011                 81
     C           *IN81     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AANPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           L7BMON    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
     C           PKOTE     IFNE *BLANK
     C           L7KTEI    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           L7JBN     IFLT WKF
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C           L7JBN     IFGT WKT
     C                     MOVEL'0'       WKOK
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELL7BMON    W0BMON
     C                     MOVELL7SHN1    W0SHN1
     C                     MOVELL7SHN2    W0SHN2
     C                     MOVELL7SHN3    W0SHN3
     C                     MOVELL7KTEI    W0KOTE
     C                     MOVELL7TKR1    W0TKR1
     C                     MOVELL7TKR2    W0TKR2
     C                     MOVELL7TKR3    W0TKR3
     C                     MOVELL7TKR4    W0TKR4
     C           L7KTSU    MULT 20        W0KTSU
     C           L7KSSU    MULT 20        W0KSSU
     C           L7SYOS    IFNE 0
     C           L7KSSU    DIV  L7SYOS    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDL7SYOS    W0SYUY
     C           L7HKSU    IFEQ 0
     C                     Z-ADD1         W0LOTK
     C                     ELSE
     C                     Z-ADDL7HKSU    W0LOTK
     C                     ENDIF
     C                     Z-ADD0         W0KJNK
     C                     Z-ADD0         W0SETO
     C                     Z-ADDL7KMAX    W0KMAX
     C                     MOVELL7KCD1    W0KCD1
     C                     MOVELL7KCD2    W0KCD2
      *
     C                     MOVE *BLANK    W0KSN1
     C                     MOVE *BLANK    W0KSN3
     C                     MOVE *BLANK    W0KSN2
     C                     Z-ADDL7HITO    W0HITO
     C                     Z-ADD0         W0TYLT
     C                     Z-ADDL7LTIM    W0LTIM
     C                     Z-ADD0         W0KEIS
     C                     Z-ADDL7UZAR    W0MAXS
     C                     MOVE *BLANK    W0KKEY
     C                     Z-ADD0         W0CYOU
     C*
     C* anﾃcmb ﾍgnﾒﾇc
     C*
     C                     Z-ADD0         XHITO   90
   #@C*
   #@C           L7UKH8    COMP WTIHZ                25
     C           *IN25     IFEQ '1'
     C                     Z-ADDL7UKYY    L7UYY
     C                     Z-ADDL7UKMM    L7UMM
     C                     Z-ADDL7UKDD    L7UDD
     C                     Z-ADDL7UBIN    L7UBN
     C                     ELSE
     C                     Z-ADDWTIYY     L7UYY
     C                     Z-ADDWTIMM     L7UMM
     C                     Z-ADDWTIDD     L7UDD
     C                     Z-ADD01        L7UBN
     C                     END
     C           CKEY      SETLLAAJTL141
     C                     DO   *HIVAL
     C           CKEY      READEAAJTL141                 30
     C           *IN30     IFEQ '0'
     C           CJAKHZ    IFNE 0
   #@C           CJAKHZ    CABLEWTIHZ     @001
     C                     END
     C           CJHZBN    IFGT L7HZBN
     C           CJSLOT    IFGT XHITO
     C                     Z-ADDCJSLOT    XHITO
     C                     END
     C                     END
     C                     END
     C           @001      TAG
     C  N30                END
     C*
     C*
     C           L7SYOS    IFNE 0
     C           XHITO     DIV  L7SYOS    XXHITO  30
     C                     MVR            XHI     30
     C                     END
     C*
     C           XHI       IFNE 0
     C                     ADD  1         XXHITO
     C                     END
     C                     MOVE XXHITO    ZHITO   3
     C                     MOVE *BLANK    ASTLR   2        SETON LR ﾍｭcﾆg
     C                     MOVE L7HITO    WHITO   3
     C                     EXSR #SB600
     C           L7KSSU    MULT 20        WKTSU   90
     C                     Z-ADD0         WMAIS   50
     C           L7SYOS    IFNE 0
     C                     CALL 'ABCR10'  ACALL
     C                     END
     C*
     C                     MOVE WMAIS     W0SMAX
     C                     MOVE L7HKSU    W0SLOT
     C                     MOVE *BLANK    W0SJNK
      *
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
      *-----------------------------*
      *ＬＴ取得　                 *
      *-----------------------------*
     CSR         #SB600    BEGSR
      *
     C                     Z-ADD0         WLTM1   31
     C                     Z-ADD0         WLTM2   31
     C                     SETOF                     30
     C           KEY2      CHAINGCKPL211             30
     C           *IN30     IFEQ '0'
     C           T2SKJY    ANDEQ' '
     C                     Z-ADDT2LTM1    WLTM1
     C                     Z-ADDT2LTM2    WLTM2
     C                     END
     CSR         ESB600    ENDSR
