     C           *ENTRY    PLIST
     C                     PARM           PARM1   1
     C                     PARM           PARM2   1
     C                     MOVE UDATE     @DATE
     C                     TIME           @TIME
     C* ﾆﾞｭci] ﾆmb *
     C           $100S     TAG
     C                     EXFMTGAEPW181
     C                     SETOF                       99
     C                     SETOF                     101197
     C                     MOVE *BLANK    @ERR
     C                     MOVE *BLANK    ESW
     C           *IN01     IFEQ '1'
     C                     MOVE '9'       PARM1
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C           *IN02     IFEQ '1'
     C                     MOVE 'M'       PARM1
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C                     MOVE @LIST     PARM1
     C           @LIST     IFNE *BLANK
     C           @LIST     IFGE '1'
     C           @LIST     ANDLE'5'
     C                     ELSE
     C                     MOVEL$EMSG,1   @ERR
     C                     SETON                     1099
     C                     GOTO $100S
     C                     END
     C                     END
     C*
     C           @YN       IFEQ 'Y'
     C           @YN       OREQ 'N'
     C                     ELSE
     C                     MOVEL$EMSG,2   @ERR
     C                     SETON                     1199
     C                     GOTO $100S
     C                     END
     C*
     C           @YN       IFEQ 'Y'
     C           @LIST     IFEQ *BLANK
     C                     MOVEL$EMSG,1   @ERR
     C                     SETON                     9910
     C                     GOTO $100S
     C                     END
     C                     END
     C*
     C           @YN       IFEQ 'Y'
     C           @ZRY1     IFEQ *BLANK
     C           @ZRY2     ANDEQ*BLANK
     C           @ZRY3     ANDEQ*BLANK
     C           @JKN1     ANDEQ*BLANK
     C           @JKN2     ANDEQ*BLANK
     C           @JKN3     ANDEQ*BLANK
     C           @JKN4     ANDEQ*BLANK
     C           @JKN5     ANDEQ*BLANK
