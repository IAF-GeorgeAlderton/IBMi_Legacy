     C                     MOVE '*'       ESW     1
     C                     END
     C           @BAN1     IFEQ *BLANK
     C           @BAN2     ANDEQ*BLANK
     C           @BAN3     ANDEQ*BLANK
     C           @BAN4     ANDEQ*BLANK
     C           @BAN5     ANDEQ*BLANK
     C           @ONDO1    ANDEQ*ZERO
     C           @ONDO2    ANDEQ*ZERO
     C           @KT1      ANDEQ*ZERO
     C                     ELSE
     C                     MOVE '*'       ESW
     C                     END
     C           @KT2      IFEQ *ZERO
     C           @MKOTE    ANDEQ*BLANK
     C           @BMN1     ANDEQ*ZERO
     C           @JKOTE    ANDEQ*BLANK
     C           @BMN2     ANDEQ*ZERO
     C                     ELSE
     C                     MOVE '*'       ESW
     C                     END
     C           ESW       IFEQ ' '
