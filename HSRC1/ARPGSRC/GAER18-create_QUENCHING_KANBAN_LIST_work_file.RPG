     C                     ELSE
     C           @JKOTE    IFEQ J6ATOK
     C           @BMN2     OREQ J6ATOB
     C                     ELSE
     C                     MOVE '*'       JSW
     C                     END
     C                     END
     C*
     C           JSW       IFEQ *BLANK
     C           J6RONO    IFNE *BLANK
     C                     EXSR SB200
     C                     END
     C                     END
     C                     END
     C                     END
     C  N80                END
     C                     END
     C*
     C           @YN       IFEQ 'N'
     C                     MOVE 'N'       PARM2
     C           PARM1     IFNE '5'
