     CSR         $FILE     BEGSR
     C                     MOVE *YEAR     WYEAR
     C                     MOVE UMONTH    WMONTH
     C                     MOVE UDAY      WDAY
     C                     Z-ADD01        BIN
     C           @YN       IFEQ 'Y'
     C                     MOVE @LIST     PARM1
     C                     DO   *HIVAL
     C                     READ ADHPP011                 80
     C                     MOVE *BLANK    JSW     1
     C           *IN80     IFEQ '0'
     C           J6SKJY    IFEQ 'D'
     C           WKDATE    ORLE WKDAY
     C                     ELSE
     C*
     C           @ZRY1     IFEQ *BLANK
     C           @ZRY2     ANDEQ*BLANK
     C           @ZRY3     ANDEQ*BLANK
     C                     ELSE
     C           @ZRY1     IFEQ J6ZACD
     C           @ZRY2     OREQ J6ZACD
     C           @ZRY3     OREQ J6ZACD
     C                     ELSE
     C                     MOVE '*'       JSW
     C                     END
     C                     END
     C*
     C           @JKN1     IFEQ *BLANK
     C           @JKN2     ANDEQ*BLANK
     C           @JKN3     ANDEQ*BLANK
     C           @JKN4     ANDEQ*BLANK
     C           @JKN5     ANDEQ*BLANK
     C                     ELSE
     C           @JKN1     IFNE *BLANK
     C                     MOVE @JKN1     WKJKN   2
     C                     EXSR SB100
     C   20                GOTO $210S
     C                     END
     C           @JKN2     IFNE *BLANK
     C                     MOVE @JKN2     WKJKN
     C                     EXSR SB100
     C   20                GOTO $210S
     C                     END
     C           @JKN3     IFNE *BLANK
     C                     MOVE @JKN3     WKJKN
     C                     EXSR SB100
     C   20                GOTO $210S
     C                     END
     C           @JKN4     IFNE *BLANK
     C                     MOVE @JKN4     WKJKN
     C                     EXSR SB100
     C   20                GOTO $210S
     C                     END
     C           @JKN5     IFNE *BLANK
     C                     MOVE @JKN5     WKJKN
     C                     EXSR SB100
     C   20                GOTO $210S
     C                     END
     C                     MOVE '*'       JSW
     C                     END
     C*
     C           $210S     TAG
     C           @BAN1     IFEQ *BLANK
     C           @BAN2     ANDEQ*BLANK
     C           @BAN3     ANDEQ*BLANK
     C           @BAN4     ANDEQ*BLANK
     C           @BAN5     ANDEQ*BLANK
     C                     ELSE
     C           @BAN1     IFEQ J6RONO
     C           @BAN2     OREQ J6RONO
     C           @BAN3     OREQ J6RONO
     C           @BAN4     OREQ J6RONO
     C           @BAN5     OREQ J6RONO
     C                     ELSE
     C                     MOVE '*'       JSW
     C                     END
     C                     END
     C*
     C           @ONDO1    IFEQ *ZERO
     C           @ONDO2    ANDEQ*ZERO
     C                     ELSE
     C           J6ONDO    IFGE @ONDO1
     C           J6ONDO    ANDLE@ONDO2
     C                     ELSE
     C                     MOVE '*'       JSW
     C                     END
     C                     END
     C*
     C           @KT1      IFEQ *ZERO
     C           @KT2      ANDEQ*ZERO
     C                     ELSE
     C           @KT1      IFEQ J6KIK1
     C           @KT2      ANDEQJ6KIK2
     C                     ELSE
     C                     MOVE '*'       JSW
     C                     END
     C                     END
     C*
     C           @MKOTE    IFEQ *BLANK
     C           @BMN1     ANDEQ*ZERO
     C                     ELSE
     C           @MKOTE    IFEQ J6MAEK
     C           @BMN1     OREQ J6MAKB
     C                     ELSE
     C                     MOVE '*'       JSW
     C                     END
     C                     END
     C*
     C           @JKOTE    IFEQ *BLANK
