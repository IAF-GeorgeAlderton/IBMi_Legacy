TCHK1I                                        7  100@@YY
TCHK1I                                       11  120@@MM
TCHK1I                                       13  140@@DD
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'00'      #SCRN0
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
      *
     C           KEY       KLIST
     C                     KFLD           D@KT1
     C                     KFLD           D@KT2
     C                     KFLD           D@KT3
     C           KEY1      KLIST
     C                     KFLD           S@DIE1
     C                     KFLD           S@DIE2
     C                     KFLD           S@DIE3
     C*************        KFLD           S@DIE4
      *
     C           KEY2      KLIST
     C                     KFLD           S@DIE1
     C                     KFLD           S@DIE2
     C                     KFLD           S@DIE3
     C           KEY3      KLIST
     C                     KFLD           S@DIE1
     C                     KFLD           S@DIE2
     C                     KFLD           S@DIE3
     C                     KFLD           K@DATE  80
     C                     KFLD           H@ISNO
     C                     KFLD           S@DIE4
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
      *
TCHK1C*                    Z-ADD*DATE     D@DATE
TCHK1C                     TIME           WWTIME
TCHK1C                     Z-ADD@@YMD     D@DATE
      *
     C                     MOVE '00'      W@ID    2
     C                     MOVE *BLANK    @@FRST  1
     C                     MOVEL'DIEINVTY'K@KWD1
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDCTNBR1    D@CLDT  80
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN0    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
      *
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C           *INKA     IFEQ *ON
     C                     MOVE '99'      W@ID
     C                     ELSE
     C                     EXSR #CHK0
     C           *IN99     IFEQ *OFF
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD1         RRN1    40
     C                     CLEARSFL01
     C                     WRITESFL01
     C                     MOVE *OFF      *IN01
     C                     Z-ADD1         #RCNO
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVE '01'      W@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK0     BEGSR
      *-----------------------------------------------------
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
     C           D@DATE    IFEQ *ZERO
     C                     SETON                     9961
     C                     MOVE MSG,3     D@MSG
     C                     ELSE
     C           D@DATE    IFLE D@CLDT
     C                     SETON                     9961
     C                     MOVE MSG,3     D@MSG
     C                     ENDIF
     C                     ENDIF
     C           D@DATE    IFGT *DATE
     C                     SETON                     9961
     C                     MOVE MSG,3     D@MSG
     C                     ENDIF
      *
     C                     Z-ADDD@DATE    K@DATE
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     SELEC
     C           @@FRST    WHEQ *BLANK
     C                     MOVELCMD,1     D@CMD
     C           *IN01     WHEQ *OFF
     C                     MOVELCMD,2     D@CMD
     C           *IN01     WHEQ *ON
     C                     MOVELCMD,3     D@CMD
     C                     ENDSL
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           @@FRST    IFNE *BLANK
     C                     EXSR #RST
     C           @@CHG     IFNE *BLANK
     C                     EXFMTWIN01
     C           *INKE     IFEQ *ON
     C                     EXSR #UPD
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           @@FRST    WHNE *BLANK
     C           *INKI     ANDEQ*ON
     C                     MOVE *ON       *IN01
     C                     EXSR #RST
      *
     C           *IN01     WHEQ *ON
     C           *INKL     ANDEQ*ON
     C                     MOVE *OFF      *IN01
     C                     EXSR #RST
     C           @@CHG     IFNE *BLANK
     C                     EXFMTWIN01
     C           *INKE     IFEQ *ON
     C                     EXSR #UPD
     C                     ELSE
     C                     EXSR #RVS
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN01     WHEQ *ON
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE *OFF      *IN01
     C                     EXSR #RST
      *
     C                     OTHER
      *
     C           *IN01     IFEQ *OFF
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C                     EXSR #RST
     C                     MOVE *BLANK    D@BRCD
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
      *
     C           D@BRCD    IFEQ *BLANK
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C           KEY       CHAINGCQPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET      BEGSR
      *-----------------------------------------------------
     C           @@FRST    IFEQ *BLANK
     C                     MOVE '1'       @@FRST
     C                     ENDIF
      *
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C                     Z-ADD@@RRN     S@NBR
     C                     MOVE D@KT1     S@DIE1
     C                     MOVE D@KT2     S@DIE2
     C                     MOVE D@KT3     S@DIE3
     C                     MOVE D@KT4     S@DIE4
     C                     MOVE D@ISNO    H@ISNO
     C           KEY2      SETGTGCQPL12
     C           *IN95     DOUEQ*ON
     C           KEY2      REDPEGCQPL12                  95
     C           *IN95     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
     C                     Z-ADDT6SYOS    S@QTY
     C                     Z-ADDT6SYOS    H@QTY
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *OFF
     C                     UPDATSFL01
     C                     ELSE
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C           KEY1      CHAINECSPL10              91
     C           *IN91     IFEQ *ON
     C                     CLEARECSPP101
     C                     MOVE T6TKR1    E1LOC1
     C                     MOVE T6TKR2    E1LOC2
     C                     MOVE T6TKR3    E1LOC3
     C                     MOVE T6TKR4    E1LOC4
     C                     MOVE S@DIE1    E1KAT1
     C                     MOVE S@DIE2    E1KAT2
     C                     MOVE S@DIE3    E1KAT3
     C*********            MOVE S@DIE4    E1KAT4
     C                     ENDIF
      *
     C                     ADD  S@QTY     E1SQTY
TCHK1C*                    Z-ADDD@DATE    E1KDAT
TCHK1C*                    TIME           E1KTIM
TCHK1C                     TIME           WWTIME
TCHK1C                     Z-ADD@@YMD     E1KDAT
TCHK1C                     Z-ADDWTIME     E1KTIM
     C                     MOVEL#USER     E1KOME
     C                     MOVEL#PGM      E1KPGM
     C                     Z-ADDD@DATE    E1INDT
     C   91                WRITEECSPP101
     C  N91                UPDATECSPP101
      *
     C                     CLEARECSPP201
TCHK1C*                    Z-ADDD@DATE    E2KDAT
TCHK1C*                    TIME           E2KTIM
TCHK1C                     TIME           WWTIME
TCHK1C                     Z-ADD@@YMD     E2KDAT
TCHK1C                     Z-ADDWTIME     E2KTIM
     C                     MOVEL#USER     E2KOME
     C                     MOVEL#PGM      E2KPGM
     C                     Z-ADDD@DATE    E2DATE
     C                     MOVE S@DIE1    E2KAT1
     C                     MOVE S@DIE2    E2KAT2
     C                     MOVE S@DIE3    E2KAT3
     C                     MOVE S@DIE4    E2KAT4
     C                     MOVE '1'       E2WHID
     C                     Z-ADDS@QTY     E2WQTY
     C                     MOVE D@ISNO    E2ISNO
     C                     WRITEECSPP201
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #RST      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     W@RRN   40
     C                     MOVE *BLANK    @@CHG   1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           W@RRN     IFNE @@RRN
     C                     MOVE *OFF      *IN30
     C                     ELSE
     C                     MOVE *ON       *IN30
     C                     ENDIF
     C           S@QTY     IFNE H@QTY
     C                     MOVE '1'       @@CHG
     C                     ENDIF
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@@RRN     #RCNO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #RVS      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           W@RRN     IFNE @@RRN
     C                     MOVE *OFF      *IN30
     C                     ELSE
     C                     MOVE *ON       *IN30
     C                     ENDIF
     C           S@QTY     IFNE H@QTY
     C                     Z-ADDH@QTY     S@QTY
     C                     ENDIF
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@@RRN     #RCNO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #UPD      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           W@RRN     IFNE @@RRN
     C                     MOVE *OFF      *IN30
     C                     ELSE
     C                     MOVE *ON       *IN30
     C                     ENDIF
      *
     C           S@QTY     IFNE H@QTY
     C                     EXSR #UPD2
     C                     Z-ADDS@QTY     H@QTY
     C                     ENDIF
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #UPD2     BEGSR
      *-----------------------------------------------------
     C           S@QTY     SUB  H@QTY     @@QTY   20
      *
     C           KEY1      CHAINECSPL10              91
     C           *IN91     IFEQ *OFF
     C                     ADD  @@QTY     E1SQTY
     C                     UPDATECSPP101
     C                     ENDIF
      *
     C           KEY3      CHAINECSPL20              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADDS@QTY     E2WQTY
     C                     UPDATECSPP201
     C                     ENDIF
      *
     C                     ENDSR
