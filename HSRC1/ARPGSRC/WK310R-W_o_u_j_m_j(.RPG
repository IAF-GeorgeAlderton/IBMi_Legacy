     H            Y.
     F** WK310R **********************************
     F* 型構成マスター対象データ抽出　　　　　 *
     F*                        2020.11.09        *
     F**********************COPY FROM    GCQR33 **
     FCCQWP02 IF  F     512            DISK
     FWK400L1 IF  E           K        DISK
     FWK420L3 IF  E           K        DISK
     FWK350W0 UF  E           K        DISK                      A
     ICCQWP02 AA  01
     I                                        1   5 ISHN1
     I                                        6  10 ISHN2
     I                                       11  12 ISHN3
     I                                       13  15 IKOTI
     I                                       16  17 IKSEI
     I                                       18  32 IMKAT
     I                                       18  19 IKAT1
     I                                       21  24 IKAT2
     I                                       33  340IKOSU
     I                                       35  35 IKUBN
     I                                       36  36 IKSKB
     I                                       37  46 IKANM
     I                                       47  61 IKATA
     I                                      350 350 IPKOJ
      *----------------------------------------------------------------
      *  PARAMETER TRANCFER
      *----------------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C                     PARM           KBN     1
      *----------------------------------------------------------------
      *  KEY LIST
      *----------------------------------------------------------------
     C           KEY01     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     KFLD           K@OKT1  2
     C                     KFLD           K@OKT2  4
     C           KEY02     KLIST
     C                     KFLD           K@OKT1  2
     C                     KFLD           K@OKT2  4
     C           KEY03     KLIST
     C                     KFLD           K@OKT1
     C                     KFLD           K@OKT2
     C                     KFLD           K@KOJY  4
     C*
     C                     READ CCQWP02                  90
     C           *IN90     DOWEQ'0'
     C*
     C                     EXSR $KOJO
     C*
     C                     MOVELISHN1     K@SHN1
     C                     MOVELISHN2     K@SHN2
     C                     MOVELISHN3     K@SHN3
     C                     MOVELIKAT1     K@OKT1
     C                     MOVELIKAT2     K@OKT2
     C*
     C           KEY02     SETLLWK400L11
     C                     EXSR $RED2
     C           REDFLG    DOWEQ'0'
     C*
     C                     MOVEL'0'       REDFG2  1
     C           KEY03     SETLLWK420L31
     C                     EXSR $RED42
     C*
     C           KEY01     CHAINWK350W01             92
     C           *IN92     IFEQ '0'
     C                     ELSE
     C                     EXSR $WRT1
     C                     ENDIF
     C*
     C                     EXSR $RED2
     C                     ENDDO
     C*
     C                     READ CCQWP02                  90
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  $RED2  READ WK400L1                            *
     C*****************************************************
     C           $RED2     BEGSR
     C*
     C                     MOVEL'0'       REDFLG  1
     C           REDFLG    DOWEQ'0'
     C*
     C           KEY02     READEWK400L11                 91
     C           *IN91     IFEQ '1'
     C                     MOVEL'1'       REDFLG
     C                     ELSE
     C           K4SKJY    IFEQ 'D'
     C           K4SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C           $RED2E    ENDSR
     C*****************************************************
     C*  $RED42 READ WK420L3                            *
     C*****************************************************
     C           $RED42    BEGSR
     C*
     C           REDFG2    DOWEQ'0'
     C*
     C           KEY03     READEWK420L31                 93
     C           *IN93     IFEQ '1'
     C                     MOVEL'1'       REDFG2
     C                     ELSE
     C           K2SKJY    IFEQ 'D'
     C           K2SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C           $RED4E    ENDSR
     C*****************************************************
     C*  $WRT1  WRITE WK350W0                           *
     C*****************************************************
     C           $WRT1     BEGSR
     C*
     C                     CLEARWK350W01
     C*
     C                     MOVELK@SHN1    W3SHN1
     C                     MOVELK@SHN2    W3SHN2
     C                     MOVELK@SHN3    W3SHN3
     C                     MOVELK@OKT1    W3OKT1
     C                     MOVELK@OKT2    W3OKT2
     C*
     C                     WRITEWK350W01
     C*
     C           $WRT1E    ENDSR
     C*****************************************************
     C*  $KOJO    工場コード変換                        *
     C*****************************************************
     C           $KOJO     BEGSR
     C*
     C                     SELEC
     C           IPKOJ     WHEQ '1'                        恵那
     C                     MOVEL'8974'    K@KOJY
     C           IPKOJ     WHEQ '2'                        岐阜
     C                     MOVEL'8982'    K@KOJY
