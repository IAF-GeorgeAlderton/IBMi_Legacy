     C                     MOVEL'0170'    K@KOJY
     C           IPKOJ     WHEQ 'C'                         AFS
     C                     MOVEL'0755'    K@KOJY
     C           IPKOJ     WHEQ 'D'                         AFD
     C                     MOVEL'0831'    K@KOJY
     C**         IPKOJ     WHEQ 'E'                         大口Ｆ７工場
     C**                   MOVEL'    '    K@KOJY
     C           IPKOJ     WHEQ 'I'                         茨城工場
