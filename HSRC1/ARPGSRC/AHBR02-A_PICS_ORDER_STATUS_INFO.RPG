JWA  C           @SYSHZ    IFGE $CHKDT
     C                     MOVELKKO,A     @KT,A            製造工程
     C                     MOVELKBM,A     @BM,A            製造部門
     C                     MOVELKHB,A     @HN,A            工程内品番
     C                     MOVELKKB,A     @KB,A            引当機番
     C                     MOVELKNB,A     @BN,A            所番地
     C                     MOVELKTY,A     @KS,A            かんばん種類
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
