     C**JW9      @BN,C1    IFNE '------'                   番地
JW9  C           C1        IFNE 0                          番地
"    C           @BN,C1    ANDNE'------'                   番地
     C                     MOVE @BM,C     @@GAI            外注= *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C** %0001
     C           B         ADD  20        K
     C           WCHK      IFEQ *BLANK
     C           SSU,C     IFNE 0
     C           A2GEKN    ANDNESSU,C
     C                     MOVE '1'       *IN,K
     C                     MOVEL'1'       WCHK    1
