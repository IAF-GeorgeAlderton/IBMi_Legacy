 |   C                     PARM           P@STIM  6
 |   C                     PARM           P@STK   1
JW5  C                     PARM           P@RTN   1
      * CHECK ISSUE DATE
JW5B C           P@RTN     IFEQ *BLANK
 |   C                     MOVELP@SDAT    SRT80   80
 |   C           SRT80     IFLT CFHTHZ
 |   C                     GOTO ##SRTX
 |   C                     ENDIF
JW5B C                     ENDIF
      *
JW5  C           P@RTN     IFEQ *BLANK
 |   C                     MOVE P@SDAT    LTR4    4
 |   C                     MOVELLTR4      WDAT1
 |   C                     MOVE LTR4      WDAT2
 |   C                     MOVE '.'       PD1
 |   C                     MOVELWDAT      S1SDAY
 |    * EDIT
 |   C                     MOVELP@STIM    LTR4    4
