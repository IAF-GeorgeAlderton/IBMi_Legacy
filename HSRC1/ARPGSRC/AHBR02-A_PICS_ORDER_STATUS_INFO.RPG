     C                     PARM           P$EDT   8
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C*
     C                     MOVE '#DSP2   '@STEP
     C*
     C* F17 *
     C           *INKR     WHEQ *ON
     C                     CALL 'ANYC23'
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           GGBAN1  1
     C                     PARM           GGBAN2  2
     C                     PARM           GGBAN3  2
     C                     PARM           GGBAN4  1
     C                     PARM           GGBAN1
     C                     PARM           GGBAN2
     C                     PARM           GGBAN3
     C                     PARM           GGBAN1
     C*
     C                     MOVE '#DSP2   '@STEP
     C*
     C* F18 *
     C           *INKS     WHEQ *ON
     C                     MOVE D1DATE    PPDATE
     C                     CALL 'AJZR60'
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           PPDATE
     C*
     C                     MOVE '#DSP2   '@STEP
     C*
     C* F19 *
     C           *INKT     WHEQ *ON
JWA  C                     MOVE @SYSHZ    P#DATE  8
     C                     MOVE '-'       P#PORM  1        + OR -
     C                     MOVE '0003'    P#DAYS  4
     C                     MOVE *BLANK    P#RDAT  8
     C                     MOVE *BLANK    P#RTN   1
     C                     CALL 'DATR1A'
     C                     PARM           P#DATE
     C                     PARM           P#PORM  1        + OR -
     C                     PARM           P#DAYS  4
     C                     PARM           P#RDAT  8
     C                     PARM           P#RTN   1
     C*
%02  C                     MOVEL'BZ '     PQKOTE
     C                     EXSR #ST
     C                     MOVE D1DATE    P#RDAT
     C*
     C           W@ST      IFEQ 'BZ '
     C                     MOVE '1'       PQMODE
     C                     CALL 'AJSR31'
     C                     PARM           PQMODE  1
     C                     PARM           PQKHN1
     C                     PARM           PQKHN2
     C                     PARM           PQKHN3
     C                     PARM           P#RDAT  8
     C                     END
     C*
%02  C                     MOVEL'DS '     PQKOTE
     C                     EXSR #ST
     C*
     C           W@ST      IFEQ 'DS '
     C                     MOVE '1'       PQMODE
     C                     CALL 'AJSR36'
     C                     PARM           PQMODE  1
     C                     PARM           PQKHN1
     C                     PARM           PQKHN2
     C                     PARM           PQKHN3
     C                     PARM           P#RDAT  8
     C                     END
     C*
     C* F20 *
     C           *INKU     WHEQ *ON
JWA  C                     MOVE @SYSHZ    P#DATE  8
     C                     MOVE '-'       P#PORM  1        + OR -
     C                     MOVE '0003'    P#DAYS  4
     C                     MOVE *BLANK    P#RDAT  8
     C                     MOVE *BLANK    P#RTN   1
     C                     CALL 'DATR1A'
     C                     PARM           P#DATE
     C                     PARM           P#PORM  1        + OR -
     C                     PARM           P#DAYS  4
     C                     PARM           P#RDAT  8
     C                     PARM           P#RTN   1
     C*
     C                     MOVE '1'       PQMODE
     C                     MOVE D1DATE    P#RDAT
     C                     CALL 'AJHR26'
     C                     PARM           PQMODE  1
     C                     PARM D1HIN1    PQKHN1
     C                     PARM D1HIN2    PQKHN2
     C                     PARM D1HIN3    PQKHN3
     C                     PARM           P#RDAT  8
     C*
     C* F21 *
     C           *INKV     WHEQ *ON
JWA  C                     MOVEL@SYSHZ    PDATE
     C                     MOVEL'-'       PPORM
     C                     MOVEL'0090'    PDAYS
     C                     MOVEL*BLANK    PRDAT
     C                     MOVEL*BLANK    PRTN
     C*
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C*
     C                     MOVE PRDAT     ##FRM   6
     C                     MOVE '01'      ##FRM
     C                     MOVEL'999999'  ##TO    6
     C*
     C                     MOVEL*BLANK    P1HIN  15
     C                     MOVELD1HIN     P1HIN
     C                     CALL 'GDGC8Z'
     C                     PARM           P1HIN
     C                     PARM           ##FRM
     C                     PARM           ##TO
     C*
JW1  C* F22 * WIP SATTUS INQUIRY (INV)
JW1  C           *INKW     WHEQ *ON
JW1  C                     MOVELD1HIN1    $HIN1
JW1  C                     MOVELD1HIN2    $HIN2
JW1  C                     MOVELD1HIN3    $HIN3
JW1  C                     MOVELD1DD      $HADD
JW1  C                     MOVELD1BIN     $HABB
     C* SET START DATE
JW3  C                     Z-ADDD1YY      WYY1    40
JW3  C                     Z-ADDD1MM      WMM1    20
JW3  C*
JW3  C                     SELEC
JW3  C           HAKO      WHGE 4
JW3  C           WMM1      SUB  0         WMM2
JW3  C           HAKO      WHGE 0.5
JW3  C           WMM1      SUB  2         WMM2
JW3  C                     OTHER
JW3  C           WMM1      SUB  11        WMM2
JW3  C                     ENDSL
JW3  C*
JW3  C           WMM2      IFLE 0
JW3  C           WMM2      ADD  12        WMM2
JW3  C           WYY1      SUB  1         WYY2    40
JW3  C                     ELSE
JW3  C                     Z-ADDWYY1      WYY2
JW3  C                     ENDIF
JW3  C                     MOVELWYY2      $HAYY   4
JW3  C                     MOVELWMM2      $HAMM   2
     C*
JW1  C                     CALL 'NYUR20'
JW1  C                     PARM           $HIN1   5
JW1  C                     PARM           $HIN2   5
JW1  C                     PARM           $HIN3   2
JW1  C                     PARM           $HAYY   4
JW1  C                     PARM           $HAMM   2
JW1  C                     PARM           $HADD   2
JW1  C                     PARM           $HABB   2
     C*
     C* F23 * ST ONEWAY
     C           *INKX     WHEQ *ON
     C                     Z-ADDD1DATE    P@DATE
     C                     Z-ADDD1BIN     P@BIN
     C                     CALL 'AHBR10'
     C                     PARM           P@MODE
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           P@DATE  80
     C                     PARM           P@BIN   20
     C                     PARM           P@STS   1
     C*
     C           P@STS     IFEQ '*'
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
     C                     END
     C*
     C* F24 * STOCK (INY)
     C           *INKY     WHEQ *ON
     C                     CALL 'STAC40'
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C*
     C* 73 *(ROLL UP)
     C           *IN73     WHEQ *ON
     C  N90                EXSR #SFSET
     C                     MOVE '#DSP2   '@STEP
     C*
     C* 77 *(ROLL DOWN)
     C           *IN74     WHEQ *ON
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     OTHER
     C                     MOVE '#CHK2   '@STEP
     C                     ENDSL
     C*
     C                     ENDSR
      *===============================================================
      * CHECK SCREEN 2
      *===============================================================
     C           #CHK2     BEGSR
     C                     MOVE '#DSP2   '@STEP
     C*-------------------------
S1   C                     DO   ENDRRN    RRN
     C           RRN       CHAINSFREC1               91
     C   91                LEAVE
     C                     MOVE *BLANK    P$FLG   1        1=F1,3=F3
     C           S1SEL     IFEQ '1'
     C                     CALL 'AHBR03'
     C                     PARM           S1ZENO
     C                     PARM           S1THNO
     C                     PARM           P$FLG            1=F1,3=F3
     C                     ENDIF
     C                     MOVE ' '       S1SEL
     C           S1CHYU    COMP 'R'                      41
     C                     SETOF                     9293
     C           S1IN92    IFEQ '1'
     C                     SETON                     92
     C                     END
     C           S1IN93    IFEQ '1'
     C                     SETON                     93
     C                     END
     C           S1IN94    IFEQ '1'
     C                     SETON                     94
     C                     END
      * PICKUP DATE
JW7  C           S1PCK     IFEQ 'R'
 |   C                     MOVE *ON       *IN50
 |   C                     ELSE
 |   C                     MOVE *OFF      *IN50
JW7  C                     ENDIF
      * SRT/SHIPPING DATE
JW6  C           S1SRT     IFEQ 'R'
 |   C                     MOVE *ON       *IN49
 |   C                     ELSE
 |   C                     MOVE *OFF      *IN49
JW6  C                     ENDIF
      *
     C           S1IN51    COMP '1'                      51
     C           S1IN52    COMP '1'                      52
      *
     C                     UPDATSFREC1
     C           P$FLG     IFEQ '1'                        1=F1,3=F3
     C                     MOVE '#END    '@STEP
     C                     LEAVE
     C                     ENDIF
E1   C  N99                ENDDO
     C*-------------------------
     C                     ENDSR
      *===============================================================
      * EDIT DATE AND TIME
      *===============================================================
     C           ##EDIT    BEGSR
     C                     MOVEL*BLANK    $$DAY   5
     C                     MOVEL*BLANK    $$TIME  5
     C*
     C           W$DATE    IFNE 0
     C                     Z-ADDW$MM      $$HBMM
     C                     MOVE '.'       $$HB1
     C                     Z-ADDW$DD      $$HBDD
     C                     MOVEL$$HB      $$DAY
     C                     Z-ADDW$JJ      $$HBMM
     C                     MOVE ':'       $$HB1
     C                     Z-ADDW$FF      $$HBDD
     C                     MOVEL$$HB      $$TIME
     C                     ENDIF
     C*
     C                     MOVE '.'       $$HB1
     C                     ENDSR
      *===============================================================
      * INQUIRE PRODUCTION PROCESS INFORMATION
      *===============================================================
     C           ##AKAR    BEGSR
      *
     C                     MOVE 'X'       P$SNO   1
     C                     MOVE *BLANK    P$F3    1
     C                     MOVE *BLANK    P$ERR   1
      *-------------------------
     C                     DO   *HIVAL
     C                     MOVE P$SNO     P$NO
     C                     CALL 'AKAR27'
     C                     PARM           P$F3    1
     C                     PARM           P$ERR   1
     C                     PARM D1HIN     P$HIN  12
     C                     PARM           P$NO    1
     C*
     C           P$F3      IFEQ '1'
     C           P$ERR     ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     CALL 'AKAR28'
     C                     PARM           P$F3
     C                     PARM           P$SNO   1
     C                     PARM           P$ERR   1
     C                     PARM D1HIN1    P$SHN1  5
     C                     PARM D1HIN2    P$SHN2  5
     C                     PARM D1HIN3    P$SHN3  2
     C*
     C           P$F3      IFEQ '1'
     C           P$ERR     ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *-------------------------
      *
     C           P$ERR     IFEQ 'E'
     C                     SETON                       99
     C                     MOVELER,8      D2ERR
     C                     ENDIF
      *
     C           P$ERR     IFEQ '9'
     C                     SETON                       99
     C                     MOVELER,9      D2ERR
     C                     ENDIF
     C*
     C                     ENDSR
      *-----------------------------------------------------
     C           #OQ       BEGSR
      *
     C                     MOVE *BLANK    W@OQ    3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'OQ '     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           AAMRS9    PLIST
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           PQBAN1  1
     C                     PARM           PQBAN2  2
     C                     PARM           PQBAN3  2
     C                     PARM           PQBAN4  1
     C                     PARM           PQBMON  4
     C                     PARM           PQKOTE  3
     C                     PARM           PQKIBN  3
     C                     PARM           PQKHIN 12
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'OQ '     W@OQ
     C                     GOTO EOQ
     C                     END
      *
     C                     MOVEL'LOQ'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'LOQ'     W@OQ
     C                     GOTO EOQ
     C                     END
      *
     C           EOQ       ENDSR
      *-----------------------------------------------------
     C           #LAN      BEGSR
      *
     C                     MOVE *BLANK    W@LAN   3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'LAN'     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'LAN'     W@LAN
     C                     GOTO ELAN
     C                     END
      *
     C                     MOVEL'AOQ'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'AOQ'     W@LAN
     C                     GOTO ELAN
     C                     END
      *
     C           ELAN      ENDSR
      *-----------------------------------------------------
     C           #SB       BEGSR
      *
     C                     MOVE *BLANK    W@SB    3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'SB '     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'SB '     W@SB
     C                     GOTO ESB
     C                     END
      *
     C                     MOVEL'KRO'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'KRO'     W@SB
     C                     GOTO ESB
     C                     END
      *
     C           ESB       ENDSR
      *===============================================================
     C           #ST       BEGSR
      *
     C                     MOVE *BLANK    W@ST    3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
%02  C*         *          MOVEL'BZ '     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
%02  C*         *          MOVEL'BZ '     W@ST
%02  C                     MOVELPQKOTE    W@ST
     C                     GOTO EST
     C                     END
      *
%02  C*         *          MOVEL'DS '     PQKOTE  3
%02  C*         *          CALL 'AAMRS9'  AAMRS9
%02  C*         *PQKHIN    IFNE *BLANK
%02  C*         *          MOVEL'DS '     W@ST
%02  C*         *          GOTO EST
%02  C*         *          END
      *
%02  C           PQKOTE    IFEQ 'DS '
     C                     MOVEL'DSM'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'DS '     W@ST
     C                     GOTO EST
     C                     END
%02  C                     ENDIF
      *
     C           EST       ENDSR
      *===============================================================
**  ERR
ENTER IAF PART#
IAF PART# IS INVALID
DATE FROM IS INVALID
BIN IS INVALID
E-05 IAF PART# IS NOT IN KANBAN EXCHANGE MASTER
DATA NOT FOUND
STORE IS INVALID
E-08 IAF PART# IS NOT IN KANBAN EXCHANGE MASTER
E-09 IAF PART# DOES NOT HAVE DATA TO DISPLAY
