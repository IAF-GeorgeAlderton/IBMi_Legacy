 |   C                     MOVE LTR4      WTIM2
 |   C                     MOVE ':'       PC1
 |   C                     MOVELWTIM      S1STIM
 |   C                     ENDIF
 |    * COLOR GREEN/RED FOR SRT/SHIPPING FIELD
 |   C           P@STK     IFEQ 'Y'
