     C           *ENTRY    PLIST
     C                     PARM           P@MODE  1
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
      *================================================================
     C           KEY01     KLIST
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#D2SET  '#D2SET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CALL2  '#CALL2
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * INITIALIZATION
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C           P@MODE    IFEQ '1'
     C                     SETON                     35
     C                     END
      *
     C                     CLEARDSP01
JW8  C                     MOVELP@HIN1    D1HIN1
 |   C                     MOVELP@HIN2    D1HIN2
JW8  C                     MOVELP@HIN3    D1HIN3
      *
     C                     TIME           @TIME
     C                     Z-ADD@SYSHZ    $$YMD
     C**JW8                Z-ADD1         $$DD
     C                     Z-ADD$$YMD     D1DATE
     C                     Z-ADD1         D1BIN
     C*
     C                     MOVE D1DATE    QQDATE  8
     C                     MOVE '-'       QQPORM  1        + OR -
     C                     MOVE '0010'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR1A'
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C*
     C                     SETON                     44
     C                     SETOF                     454647
     C                     SETOF                     484943
     C*
     C                     MOVE QQRDAT    D1DATE
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      * SCREEN 1
     C*===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'000'     *IN,01
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C******
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
     C*===============================================================
      * CHECK SCREEN 1
     C*===============================================================
     C           #CHK1     BEGSR
     C**
     C           D1HIN1    IFEQ *BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C           D1TKR2    ANDNE*BLANK
     C           D1TKR3    ORNE *BLANK
     C                     MOVEL'0'       P@TKR1  1        LOCATION 1
     C                     MOVELD1TKR2    P@TKR2  2        LOCATION 2
     C                     MOVELD1TKR3    P@TKR3  2        LOCATION 3
     C                     MOVEL'0'       P@TKR4  1        LOCATION 4
     C                     CALL 'FCERS2'
     C                     PARM           P@TKR1  1        LOCATION 1
     C                     PARM           P@TKR2  2        LOCATION 2
     C                     PARM           P@TKR3  2        LOCATION 3
     C                     PARM           P@TKR4  1        LOCATION 4
     C                     PARM           P@HIN1  5        PART NO. 1
     C                     PARM           P@HIN2  5        PART NO. 2
     C                     PARM           P@HIN3  2        PART NO. 3
     C                     PARM           P@RTN   1        9:該当なし
     C           P@HIN1    IFNE *BLANK                     PART NO. 1
     C                     MOVELP@HIN1    D1HIN1           PART NO. 1
     C                     MOVELP@HIN2    D1HIN2           PART NO. 2
     C                     MOVELP@HIN3    D1HIN3           PART NO. 3
     C                     ENDIF
     C                     ENDIF
     C**
      * IAF PARTS#
     C           D1HIN1    IFEQ *BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C           D1TKR2    IFNE *BLANK
     C           D1TKR3    ORNE *BLANK
     C                     SETON                     0399
     C                     MOVELER,7      D1ERR
     C                     GOTO @CHK1
     C                     ELSE
     C                     SETON                     0199
     C                     MOVELER,1      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C                     ENDIF
