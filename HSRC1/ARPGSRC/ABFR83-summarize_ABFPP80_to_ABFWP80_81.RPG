     H            Y/
     F** ABFR83 **********************************************
     F*  SUMMARIZE ABFPP80 TO ABFWP80                        *
     F*  J.WATANABE 2018.07.13                               *
     F********************************************************
     FABFPP80 IF  E           K        DISK
     FAB#PL0M IF  E           K        DISK
      **DAY BASE**
     FABFWP80 UF  E           K        DISK                      A
      **WEEK BASE**
     F**ABFWP81 UF  E           K        DISK                      A
      *------------------------------------------------------------
     I            DS
     I                                        1   60TGTYM
     I                                        1   40TGTYY
     I                                        5   60TGTMM
     I            DS
     I                                        1   80LSTYMD
     I                                        1   60LSTYM
     I                                        1   40LSTYY
     I                                        5   60LSTMM
     I                                        7   80LSTDD
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80B8SDTO
     I                                        1   60B8SDYM
     I                                        7   80B8SDDD
     I            DS
     I                                        1  20 B8SHIN
     I                                        1   5 B8SHN1
     I                                        6  10 B8SHN2
     I                                       11  12 B8SHN3
     I                                       13  20 B8SHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *==================================================
   L  * MAIN ROUTINE
      *==================================================
     C                     EXSR #INT
      * SUM FORECAST
     C                     EXSR #FC
      * SUM SALES
     C                     EXSR #SALES
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*=====================================================
     C* SET FORECAST DATA
     C*=====================================================
     C           #FC       BEGSR
      *
     C           LSTYM     SETLLABFPP80
     C                     DO   *HIVAL
     C                     READ ABFPP80                  91
     C   91                LEAVE
      *
     C                     MOVELB8SDTS    SPLTYM  60
     C           SPLTYM    IFEQ @TGTYM
      * GET QTY/BOX (@SYOS)
     C                     MOVELB8TOKU    $TOKU
     C                     MOVELB8NONY    $NONY
     C                     MOVELB8SHIN    $MHIN
     C                     MOVEL'IAF'     $HTYP
     C                     MOVELTODAY     $DATE
     C                     CALL 'UTLR35'
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $HTYP   3
     C                     PARM           $DATE   8
     C                     PARM           $SYOS   6
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$SYOS     @SYOS   60
     C                     ELSE
     C                     Z-ADD1         @SYOS
     C                     ENDIF
      *
     C                     EXSR #80F
     C***                  EXSR #81F
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C*=====================================================
     C* SET FORECAST DATA IN ABFWP80
     C*=====================================================
     C           #80F      BEGSR
      *
     C                     MOVELB8FCYM    K8FCYM
     C                     MOVELB8NONY    K8NONY
     C                     MOVELB8NKOJ    K8NKOJ
     C                     MOVELB8NUKE    K8NUKE
     C                     MOVELB8MHN1    K8MHN1
     C                     MOVELB8MHN2    K8MHN2
     C                     MOVELB8MHN3    K8MHN3
     C                     MOVELB8MHN4    K8MHN4
      *
     C           K#80      CHAINABFWP80              99
     C           *IN99     IFEQ *OFF
     C                     ADD  B8SQTS    C8FQTY
      *
     C           B8SQTS    IFEQ 0
     C                     Z-ADD0         @BOX
     C                     ELSE
     C           @SYOS     IFEQ 0
     C                     Z-ADD1         @BOX
     C                     ELSE
     C           B8SQTS    DIV  @SYOS     @BOX
     C                     MVR            REM    103
     C**         REM       IFNE 0
     C**                   ADD  1         @BOX
     C**                   ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ADD  @BOX      C8FBOX
      *
     C                     UPDATABFWP801
     C                     ELSE
      *
     C                     MOVELB8NONY    C8NONY
     C                     MOVELB8NKOJ    C8NKOJ
     C                     MOVELB8NUKE    C8NUKE
     C                     MOVELB8FCYM    C8FCYM
     C                     MOVELB8MHN1    C8MHN1
     C                     MOVELB8MHN2    C8MHN2
     C                     MOVELB8MHN3    C8MHN3
     C                     MOVELB8MHN4    C8MHN4
     C                     MOVELB8SHN1    C8SHN1
     C                     MOVELB8SHN2    C8SHN2
     C                     MOVELB8SHN3    C8SHN3
     C                     Z-ADD0         C8SQTY
     C                     Z-ADDB8SQTS    C8FQTY
      *
     C           B8SQTS    IFEQ 0
     C                     Z-ADD0         @BOX
     C                     ELSE
     C           @SYOS     IFEQ 0
     C                     Z-ADD1         @BOX
     C                     ELSE
     C           B8SQTS    DIV  @SYOS     @BOX
     C                     MVR            REM
     C**         REM       IFNE 0
     C**                   ADD  1         @BOX
     C**                   ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADD@BOX      C8FBOX
     C                     Z-ADD@SYOS     C8SYOS
      *
     C                     Z-ADD0         C8RATE
     C                     MOVELB8TOKU    C8TOKU
     C                     MOVELTODAY     C8CRDT
     C                     MOVELNOW       C8CRTM
     C                     MOVEL#USER     C8CRUS
     C                     MOVEL#PGM      C8CRPG
     C                     WRITEABFWP801
     C                     ENDIF
      *
     C                     ENDSR
     C*=====================================================
     C* SET FORECAST DATA IN ABFWP81
     C*=====================================================
     C***        #81F      BEGSR
      *
     C***                  MOVELB8FCYM    K8FCYM
     C***                  MOVELB8NONY    K8NONY
      *
     C***        K#81      CHAINABFWP81              98
     C***        *IN98     IFEQ *OFF
     C***                  ADD  B8SQTO    C8FQTY
      *
     C***        B8SQTO    IFEQ 0
     C***                  Z-ADD0         @BOX
     C***                  ELSE
     C***        @SYOS     IFEQ 0
     C***                  Z-ADD1         @BOX
     C***                  ELSE
     C***        B8SQTO    DIV  @SYOS     @BOX
     C***                  MVR            REM
     C***        REM       IFNE 0
     C***                  ADD  1         @BOX
     C***                  ENDIF
     C***                  ENDIF
     C***                  ENDIF
     C***                  ADD  @BOX      C8FBOX
      *
     C***                  UPDATABFWP811
     C***                  ELSE
     C***                  MOVELB8NONY    C8NONY
     C***                  MOVELB8FCYM    C8FCYM
     C***                  Z-ADD0         C8SQTY
     C***                  Z-ADDB8SQTO    C8FQTY
      *
     C***        B8SQTO    IFEQ 0
     C***                  Z-ADD0         @BOX
     C***                  ELSE
     C***        @SYOS     IFEQ 0
     C***                  Z-ADD1         @BOX
     C***                  ELSE
     C***        B8SQTO    DIV  @SYOS     @BOX
     C***                  MVR            REM
     C***        REM       IFNE 0
     C***                  ADD  1         @BOX
     C***                  ENDIF
     C***                  ENDIF
     C***                  ENDIF
     C***                  Z-ADD@BOX      C8FBOX
      *
     C***                  Z-ADD0         C8RATE
     C***                  MOVELB8TOKU    C8TOKU
     C***                  MOVELTODAY     C8CRDT
     C***                  MOVELNOW       C8CRTM
     C***                  MOVEL#USER     C8CRUS
     C***                  MOVEL#PGM      C8CRPG
     C***                  WRITEABFWP811
     C***                  ENDIF
      *
     C***                  ENDSR
     C*=====================================================
     C* SET SALES DATA
     C*=====================================================
     C           #SALES    BEGSR
      *
     C           K#0D      SETLLAB#PL0M
     C                     DO   *HIVAL
     C           K#0D      READEAB#PL0M                  92
     C   92                LEAVE
      *
     C                     EXSR #80S
     C**                   EXSR #81S
      *
     C                     ENDDO
     C                     ENDSR
     C*=====================================================
     C* SET SALES DATA IN ABFWP80
     C*=====================================================
     C           #80S      BEGSR
      *
     C                     MOVELB1URYY    K8FCYM
     C                     MOVE B1GEMM    K8FCYM
     C                     MOVELB1NONY    K8NONY
     C                     MOVELB1NKOJ    K8NKOJ
     C                     MOVELB1NUKE    K8NUKE
     C                     MOVELB1MHN1    K8MHN1
     C                     MOVELB1MHN2    K8MHN2
     C                     MOVELB1MHN3    K8MHN3
     C                     MOVELB1MHN4    K8MHN4
      *
     C           K#80      CHAINABFWP80              97
     C           *IN97     IFEQ *OFF
     C                     ADD  B1SRYO    C8SQTY
     C                     ADD  B1HAKO    C8SBOX
      *
     C           C8FBOX    IFNE 0
     C           C8SBOX    MULT 100       NUM11  110
     C           NUM11     DIV  C8FBOX    C8RATE    H
     C                     ENDIF
      *
     C                     UPDATABFWP801
     C                     ELSE
     C                     MOVELB1NONY    C8NONY
     C                     MOVELB1NKOJ    C8NKOJ
     C                     MOVELB1NUKE    C8NUKE
     C                     MOVELB1URYY    C8FCYM
     C                     MOVE B1GEMM    C8FCYM
     C***                  MOVE B1URMM    C8FCYM
     C                     MOVELB1MHN1    C8MHN1
     C                     MOVELB1MHN2    C8MHN2
     C                     MOVELB1MHN3    C8MHN3
     C                     MOVELB1MHN4    C8MHN4
     C                     MOVELB1SHN1    C8SHN1
     C                     MOVELB1SHN2    C8SHN2
     C                     MOVELB1SHN3    C8SHN3
     C                     Z-ADDB1SRYO    C8SQTY
     C                     Z-ADDB1HAKO    C8SBOX
     C                     Z-ADD0         C8FQTY
     C                     Z-ADD0         C8FBOX
     C                     Z-ADD0         C8RATE
     C                     Z-ADDB1SYUY    C8SYOS
     C                     MOVELB1TOKU    C8TOKU
     C                     MOVELTODAY     C8CRDT
     C                     MOVELNOW       C8CRTM
     C                     MOVEL#USER     C8CRUS
     C                     MOVEL#PGM      C8CRPG
     C                     WRITEABFWP801
     C                     ENDIF
      *
     C                     ENDSR
     C*=====================================================
     C* SET SALES DATA IN ABFWP81
     C*=====================================================
     C***        #81S      BEGSR
      *
     C***                  MOVELB1URYY    K8FCYM
     C***                  MOVE B1GEMM    K8FCYM
     C***                  MOVELB1NONY    K8NONY
      *
     C***        K#81      CHAINABFWP81              96
     C***        *IN96     IFEQ *OFF
     C***                  ADD  B1SRYO    C8SQTY
     C***                  ADD  B1HAKO    C8SBOX
      *
     C***        C8FBOX    IFNE 0
     C***        C8SBOX    MULT 100       NUM11  110
     C***        NUM11     DIV  C8FBOX    C8RATE    H
     C***                  ENDIF
      *
     C***                  UPDATABFWP811
     C***                  ELSE
     C***                  MOVELB1NONY    C8NONY
     C***                  MOVELB1URYY    C8FCYM
     C***                  MOVE B1GEMM    C8FCYM
     C***                  Z-ADDB1SRYO    C8SQTY
     C***                  Z-ADDB1HAKO    C8SBOX
     C***                  Z-ADD0         C8FQTY
     C***                  Z-ADD0         C8RATE
     C***                  MOVELB1TOKU    C8TOKU
     C***                  MOVELTODAY     C8CRDT
     C***                  MOVELNOW       C8CRTM
     C***                  MOVEL#USER     C8CRUS
     C***                  MOVEL#PGM      C8CRPG
     C***                  WRITEABFWP811
     C***                  ENDIF
      *
     C***                  ENDSR
     C*=====================================================
     C* Initial SET
     C*=====================================================
     C           #INT      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TGTYM  6
      *
     C           K#0D      KLIST
     C                     KFLD           K0FCY   40
     C                     KFLD           K0FCM   20
      *
     C           K#80      KLIST
     C                     KFLD           K8FCYM  60
     C                     KFLD           K8NONY  40
     C                     KFLD           K8NKOJ  1
     C                     KFLD           K8NUKE  4
     C                     KFLD           K8MHN1  5
     C                     KFLD           K8MHN2  5
     C                     KFLD           K8MHN3  5
     C                     KFLD           K8MHN4  5
      *
     C           K#81      KLIST
     C                     KFLD           K8FCYM  60
     C                     KFLD           K8NONY  40
      *
     C                     MOVEL$TGTYM    K0FCY
     C                     MOVE $TGTYM    K0FCM
      *
     C                     TIME           SDATE
     C                     MOVEL$TGTYM    @TGTYM  60
     C                     Z-ADD0         @BOX   102
     C                     MOVE *BLANK    B8SHN4
      * GET LAST YM
     C                     MOVEL$TGTYM    TGTYM
     C           TGTMM     IFEQ 01
     C           TGTYY     SUB  1         LSTYM
     C                     Z-ADD12        LSTMM
     C                     ELSE
     C                     Z-ADDTGTYY     LSTYY
     C           TGTMM     SUB  1         LSTMM
     C                     ENDIF
     C*
     C                     ENDSR
