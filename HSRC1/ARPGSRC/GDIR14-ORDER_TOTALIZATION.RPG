      ** GDIR14 ******************************************************
      *    ORDER TOTALIZATION
      *     G.B.C                        98/01/12
      ****************************************************************
     H            Y/                                    1
     FGDIPL10 IF  E           K        DISK
     FFCQPL31 IF  E           K        DISK
     FGDIWP10 UF  E           K        DISK                      A
     I            DS
     I                                        1   8 IHKATA
     I                                        1   2 IHKAT1
     I                                        3   6 IHKAT2
     I                                        7   7 IHKAT3
     I                                        8   8 IHKAT4
     C*****************************************************************
     C* START                                                         *
     C*****************************************************************
     C                     DO   *HIVAL
     C                     READ GDIPL101                 10
     C   10                LEAVE
     C           IHSKJY    IFEQ 'D'
     C           IHSKHZ    ANDLE*DATE                                  )
     C                     ITER
     C                     ENDIF
     C*  FCQPL31 KEY
     C           FCQKEY    KLIST
     C                     KFLD           IHKAT1
     C                     KFLD           IHKAT2
     C           FCQKEY    CHAINFCQPL311             10
     C  N10                MOVE Q4SPKB    IHKAT4
     C*
     C*
     C           IHKATA    CHAINGDIWP101             20
     C           *IN20     IFEQ '1'
     C                     MOVE *BLANK    WHSKJY
     C                     Z-ADD0         WHSKYY           DELETE DUE DATE YEAR
     C                     Z-ADD0         WHSKMM           MONTH
     C                     Z-ADD0         WHSKDD           DAY
     C                     Z-ADD0         WHKOYY           UPDATE WORK DATE
     C                     Z-ADD0         WHKOMM           MONTH
     C                     Z-ADD0         WHKODD           DAY
     C                     Z-ADD0         WHKOHH           UPDATE WORK TIME
     C                     Z-ADD0         WHKOSS           MINUTES)')
     C                     MOVE *BLANK    WHKOME           NAME OF TEAM MEMBER'
     C                     MOVE IHKATA    WHKATA           DIE CODE
     C                     Z-ADDIHSYOS    WHSYOS           QTY/BOX
     C                     Z-ADD0         WHMAIS           BOX
     C                     Z-ADD0         WHSURY           QTY
     C                     END
     C                     ADD  IHMAIS    WHMAIS           BOX
     C           WHMAIS    MULT WHSYOS    WHSURY           QTY
     C   20                WRITEGDIWP101
     C  N20                UPDATGDIWP101
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
