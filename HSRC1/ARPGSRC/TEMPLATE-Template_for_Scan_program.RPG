      *
     I              'NｱﾃｵｴCﾅﾄﾍﾎ'          C         NAMCON
      *
     C           *ENTRY    PLIST
     C                     PARM           PLOCN  20
     C                     PARM           PWKCD   6
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #FMT30
     C           @@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
      * ｶﾅﾈ ﾁｱﾄｲｱﾄ ｳｸｵｳﾁ ｴｹｷｹﾎ...
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C                     TIME           WSDT
      *
     C                     CLEARFMT100
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
      *
     C                     MOVEL'10'      @@ID    2
      *
      *
      * DUMMY READ
     C                     READ OUT1                     98
      *
     C                     ENDSR
      *************************************************************************
      *    FIRST SCREEN
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C                     MOVEL'20'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *    FIRST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     6199
      *
     C                     DO
      *
     C           F1BAR     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,X     F1ERR
     C                     MOVELERR,X     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * ｳｸｵｳﾁ XXXX ｹﾄ M/F...
     C           F1BAR     CHAINFILE1                51
     C           *IN51     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,X     F1ERR
     C                     ELSE
     C           BNSKJY    IFEQ 'D'
     C                     MOVELERR,X     F1ERR
     C                     SETON                     9961
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *    SECOND SCREEN
      **************************************************************************
     C           #FMT20    BEGSR
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     OTHER
     C                     EXSR #CHK20
     C           *IN99     IFEQ *OFF
     C                     MOVEL'30'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *    SECOND SCREEN CHECK
      **************************************************************************
     C           #CHK20    BEGSR
      *
     C                     SETOF                     6199
      *
     C                     DO
      *
     C           F2BAR     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,X     F2ERR
     C                     MOVELERR,X     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * ｳｸｵｳﾁ XXXX ｹﾄ M/F...
     C           F2BAR     CHAINFILE2                51
     C           *IN51     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,X     F2ERR
     C                     ELSE
     C           BNSKJY    IFEQ 'D'
     C                     MOVELERR,X     F2ERR
     C                     SETON                     9961
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     THIRD SCREEN
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     EXFMTFMT300
     C                     MOVEL*BLANK    F3ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'20'      @@ID
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     OTHER
     C                     EXSR #CHK30
     C           *IN99     IFEQ *OFF
     C                     MOVEL'40'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     THIRD SCREEN CHECK
      **************************************************************************
     C           #CHK30    BEGSR
      *
     C                     SETOF                     6199
      *
     C                     MOVELF3BAR     QR
     C           BCTYPE    IFEQ 'B01'
      *
      * ｳﾈｵｱﾎｵ ｳﾅｴｵ39 ｶﾈﾅﾃ QR....
     C                     MOVEL*BLANK    P9BAR  20
     C                     CALL 'UEXR13'
     C                     PARM           QR1
     C                     PARM           QR2
     C                     PARM           P9BAR
     C                     MOVELP9BAR     W3BAR
     C                     ELSE
     C                     MOVELF3BAR     W3BAR
     C                     ENDIF
      *
     C                     DO
      *
     C           W3BAR     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,X     F3ERR
     C                     MOVELERR,X     F99ER1
     C                     LEAVE
     C                     ENDIF
      * ｳｸｵｳﾁ ｴｹｷｹﾎ...
     C                     MOVELW3BAR     PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,X     F3ERR
     C                     MOVELERR,X     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C           PMCHK     IFNE W3CHKD
     C                     SETON                     9961
     C                     MOVELERR,3     F3ERR
     C                     MOVELERR,3     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * ｳｸｵｳﾁ ﾆｱﾈﾎ ｹｴ ﾃｱﾎｳｸｵﾍ...
     C           W3ZETI    IFNE LZETI
     C           PLOCN     ANDNE'OSOV'
     C                     SETON                     9961
     C                     MOVELERR,X     F3ERR
     C                     MOVELERR,X     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * ｳｸｵｳﾁ ﾎﾅ ﾍｵｵ ｹｶ ﾆﾂｱﾍﾎｹｳ ﾁｱﾄｲｱﾄ ｸｱﾍ ｱﾂﾈｵｱｴﾓ ｲｵｵﾄ ﾍｳｱﾄﾄｵｴ.
     C           W3BAR     IFNE *BLANK
     C                     EXSR CHKDUP
     C           *IN99     IFEQ *ON
     C                     MOVELERR,X     F3ERR
     C                     MOVELERR,X     F99ER1
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     FOURTH SCREEN
      **************************************************************************
     C           #FMT40    BEGSR
      *
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'30'      @@ID
     C                     CLEARFMT400
      *
     C                     OTHER
     C                     EXSR #CHK40
      *
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR DLTDUP
     C                     EXSR #WRTOK
     C                     EXFMTFMT900
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL'99'      @@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     LOT ID SCREEN CHECK
      **************************************************************************
     C           #CHK40    BEGSR
      *
     C                     MOVELF4LOT     W4LOT
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           F4LOT     IFEQ *BLANK
     C           F4LT01    ANDEQ*BLANK
     C           F4LT02    ANDEQ*BLANK
     C           F4LT03    ANDEQ*BLANK
     C           F4LT04    ANDEQ*BLANK
     C           F4LT05    ANDEQ*BLANK
     C           F4LT06    ANDEQ*BLANK
     C           F4LT07    ANDEQ*BLANK
     C           F4LT08    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F4ERR
     C                     MOVELERR,4     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C           F4LOT     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      * ｳｸｵｳﾁ ｴｹｷｹﾎ...
     C                     MOVELW4LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F4ERR
     C                     MOVELERR,4     F99ER1
     C                     ENDIF
      *
     C           PMCHK     IFNE W4CHKD
     C                     SETON                     9961
     C                     MOVELERR,3     F4ERR
     C                     MOVELERR,3     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C   99                LEAVE
      *
     C           F4LOT     IFEQ F4LT01
     C           F4LOT     OREQ F4LT02
     C           F4LOT     OREQ F4LT03
     C           F4LOT     OREQ F4LT04
     C           F4LOT     OREQ F4LT05
     C           F4LOT     OREQ F4LT06
     C           F4LOT     OREQ F4LT07
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,8     F4ERR
     C                     MOVELERR,8     F99ER1
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           F4LT01    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT01
     C                     MOVEL*BLANK    F4LOT
     C           F4LT02    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT02
     C                     MOVEL*BLANK    F4LOT
     C           F4LT03    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT03
     C                     MOVEL*BLANK    F4LOT
     C           F4LT04    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT04
     C                     MOVEL*BLANK    F4LOT
     C           F4LT05    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT05
     C                     MOVEL*BLANK    F4LOT
     C           F4LT06    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT06
     C                     MOVEL*BLANK    F4LOT
     C           F4LT07    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT07
     C                     MOVEL*BLANK    F4LOT
     C           F4LT08    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT08
     C                     MOVEL*BLANK    F4LOT
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *       WRITE RECORD TO OUT1
      **************************************************************************
     C           #WRTOK    BEGSR
      *
     C                     CLEAROUT11
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    AFCODT
     C                     Z-ADDWSSTM6    AFCOTM
     C                     MOVELPWKCD     AFCOWK
     C                     MOVEL#PGM      AFCOPG
      *
     C                     MOVELF2BAR     AFBIN#
     C                     MOVELPLOCN     AFLBAR
     C           XXXFLG    IFEQ *ON
     C                     MOVELW3ZETI    AFLZET
     C                     ELSE
     C                     MOVELLZETI     AFLZET
     C                     MOVELLLOCN4    AFLOCN
     C                     ENDIF
     C                     MOVELW3BAR     AFPBAR
     C                     MOVELF3BAR     AFPBQR
     C                     MOVELW3ZETI    AFPZET
      *
     C           W3ZETI    CHAINFILE3                51
     C           *IN51     IFEQ *OFF
     C                     MOVELA2BHB1    AFPHN1
     C                     MOVELA2BHB2    AFPHN2
     C                     MOVELA2BHB3    AFPHN3
     C                     ENDIF
      *
     C                     WRITEAOUT11
      *
     C                     ENDSR
     C* ****************************************************
      * ｹｶ ｱﾂﾈｵｱｴﾓ ﾎｸｵﾈｵ ｲﾏﾎ ｴｹｶｶｵﾈｵﾄﾎ, ｴｵﾂｵﾎｵ
      * ****************************************************
     C           DLTDUP    BEGSR
      *
     C                     MOVELW3BAR     KYBAR  20 P
     C                     MOVEL#PGM      PPGM   10 P
     C                     CALL 'DELPGM'
     C                     PARM           PWKCD
     C                     PARM           PPGM
     C                     PARM           KYBAR
      *
     C                     ENDSR
      * ****************************************************
      * ﾐｵﾈｹｶﾓ ﾁｱﾄｲｱﾄ ｲｳ ｸｱﾍﾄ'ﾎ ｲｵｵﾄ ﾍｳｱﾄﾄｵｴ ﾓｵﾎ
      * ****************************************************
     C           CHKDUP    BEGSR
      *
     C                     MOVELW3BAR     KYBAR
     C           KYBAR     CHAINOUT1                 91
      *
     C           *IN91     DOWEQ*OFF
      *
     C           XXSKJY    IFEQ *BLANK
     C           XXXBAR    ANDEQPLOCN
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           KYBAR     READEOUT1                     91
     C                     ENDDO
      *
     C                     ENDSR
