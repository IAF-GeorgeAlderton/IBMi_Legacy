     H            Y.
     F** AB#R2R *******************************
     F*  ATS ORDER PROCESSING              *
     F*                                       *
     F*           JUN/08/04                   *
     F*
     F* TCHK1 06/07/07 CHG FORMATTE
     F* TCHK2 11/28/07 CHG SKIP '?'
     F******************************* AB#R2E **
     FATS     IP  F     256            DISK
     FAB#PP86 UF  E           K        DISK                      A
     FAB#WATS O   E                    DISK
      *--------------------------------------------------------
     E                    AY        244  1
     E                    A10        10  1
     E                    A15        15  1
     E                    A20        20  1
     E                    A25        25  1
     E                    A4          4  1
     E                    A9          9  1
     E                    A9X         9  1
      *--------------------------------------------------------
     IATS     AA  01
     I                                        1  12 SEQ
     I                                       13 256 DAT1
     I            DS
     I                                        1   80YMD
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   80DAY
     I            DS
     I                                        1   80SHDT
     I                                        1   40SHYY
     I                                        5   60SHMM
     I                                        7   80SHDD
     I            DS
     I                                        1  15 WMHIN
     I                                        1   5 MHIN1
     I                                        6  10 MHIN2
     I                                       11  15 MHIN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
     C           K#AGD     KLIST
     C                     KFLD           YEAR
     C                     KFLD           MONTH
     C                     KFLD           DAY
     C           K#86      KLIST
     C                     KFLD           AWTOKU
     C                     KFLD           AWMHN1
     C                     KFLD           AWMHN2
     C                     KFLD           AWMHN3
      * SHIP DATE
     C                     MOVEADAT1      AY
     C           *IN99     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'Due Date'SCAN DAT1      X              10
     C           *IN10     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'DUE DATE'SCAN DAT1      X              10
     C                     ENDIF
     C           *IN10     CABEQ*OFF      @END
      *
     C                     MOVE *BLANK    A4
     C                     Z-ADD*ZERO     Y       30
     C                     Z-ADD*ZERO     Z       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ '/'
     C           AY,X      OREQ ','
     C                     ADD  1         Z
      *
     C           Z         IFLT 3
     C           Y         ANDEQ1
     C                     MOVE A4,1      A4,2
     C                     MOVE '0'       A4,1
     C                     ENDIF
     C           Z         IFEQ 3
     C           Y         ANDEQ2
     C                     MOVE A4,1      A4,3
     C                     MOVE A4,2      A4,4
     C                     MOVEA'00'      A4,1
     C                     ENDIF
     C                     MOVEAA4        @A4     4
     C                     SELEC
     C           Z         WHEQ 1
     C                     MOVEL@A4       MONTH
     C           Z         WHEQ 2
     C                     MOVEL@A4       DAY
     C           Z         WHEQ 3
     C                     MOVE @A4       YEAR
     C                     ENDSL
      *
     C           Z         IFEQ 3
     C                     LEAVE
     C                     ELSE
     C                     MOVE *BLANK    A4
     C                     Z-ADD*ZERO     Y
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVE AY,X      A4,Y
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     Z-ADDYEAR      SHYY
     C                     Z-ADDMONTH     SHMM
     C                     Z-ADDDAY       SHDD
      *
     C                     MOVE *ON       *IN99
     C                     GOTO @END
     C                     ENDIF
      * MANIFEST
     C           *IN99     IFEQ *ON
     C           *IN98     ANDEQ*OFF
     C                     Z-ADD1         X       30
     C           'MANIFEST'SCAN DAT1      X              10
     C           *IN10     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'Manifest'SCAN DAT1      X              10
     C                     ENDIF
     C  N10                GOTO @END
      *
     C           '#'       SCAN DAT1      X              10
     C  N10                GOTO @END
      *
     C                     MOVE *BLANK    A10
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
TCHK2C           AY,X      IFEQ '?'
TCHK2C                     ITER
TCHK2C                     END
     C           AY,X      IFEQ *BLANK
     C           Y         ANDGT*ZERO
     C           AY,X      OREQ ','
     C           Y         ANDGT*ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVE AY,X      A10,Y
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEAA10       WORDR  10
     C                     MOVE *ON       *IN98
     C                     GOTO @END
     C                     ENDIF
      *
     C           *IN98     IFEQ *ON
     C           *IN99     ANDEQ*ON
     C           *IN97     ANDEQ*OFF
      * PART #
     C                     Z-ADD1         X       30
     C           '-'       SCAN DAT1      X              10
     C  N10                GOTO @END
      *
     C                     MOVE *ON       *IN97
     C                     Z-ADD*ZERO     X
     C                     MOVE *BLANK    A15
     C                     MOVE *BLANK    A20
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     W       30
      *
     C           1         DO   30        X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         W
     C                     MOVE AY,X      A20,W
     C           AY,X      IFNE '-'
     C           AY,X      ANDNE*BLANK
     C                     ADD  1         Y
     C                     MOVE AY,X      A15,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA15       WMHIN
     C                     MOVEAA20       @@MHN  20
      * KANBAN
     C                     MOVE *BLANK    A10
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           Y         IFGT *ZERO
     C                     LEAVE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVE AY,X      A10,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA10       @10    10
     C                     MOVEL@10       AWSBAN
      *
TCHK C*                    DO   9
TCHK C                     DO   2
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     ITER
     C                     ELSE
     C           ','       LOKUPAY,X                     10
     C                     ENDIF
     C                     ENDDO
      * QTY/BOX
     C                     MOVE *BLANK    A9
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         Y
     C                     MOVE AY,X      A9,Y
     C                     ENDDO
      *
     C                     MOVE *ALL'0'   A9X
     C                     Z-ADD9         Y
     C                     Z-ADD9         W       30
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVE A9,Y      A9X,W
     C                     SUB  1         W
     C                     ENDIF
     C                     SUB  1         Y
     C           Y         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA9X       @9      9
     C                     MOVE @9        AWSYOS
      * SHIP QTY
TCHK1C*                    ADD  1         X
TCHK1C*          AY,X      IFNE ','
TCHK1C*          ','       LOKUPAY,X                     10
TCHK1C*                    ENDIF
      * SHIP QTY
     C                     MOVE *BLANK    A9
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
TCHK1C           AY,X      OREQ ' '
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         Y
     C                     MOVE AY,X      A9,Y
     C                     ENDDO
      *
     C                     MOVE *ALL'0'   A9X
     C                     Z-ADD9         Y
     C                     Z-ADD9         W       30
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVE A9,Y      A9X,W
     C                     SUB  1         W
     C                     ENDIF
     C                     SUB  1         Y
     C           Y         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA9X       @9      9
     C                     MOVE @9        AWSRYO
      *
     C                     GOTO @END
     C                     ENDIF
      *
     C           *IN98     IFEQ *ON
     C           *IN99     ANDEQ*ON
     C           *IN97     ANDEQ*ON
     C                     MOVE *OFF      *IN97
      * PART DESCRIPTION
     C                     Z-ADD*ZERO     Y
     C                     MOVE *OFF      *IN90
     C                     MOVE *BLANK    A25
     C           1         DO   25        X
     C           *IN90     IFEQ *OFF
     C           AY,X      ANDEQ'"'
     C                     MOVE *ON       *IN90
     C                     ITER
     C                     ENDIF
     C           *IN90     IFEQ *ON
     C           AY,X      ANDEQ'"'
     C                     LEAVE
     C                     ENDIF
     C           *IN90     IFEQ *OFF
     C           AY,X      ANDEQ','
     C                     LEAVE
     C                     ENDIF
     C                     ADD  1         Y
     C                     MOVE AY,X      A25,Y
     C                     ENDDO
      *
     C                     MOVEAA25       @@DESC 25
      *
     C                     Z-ADD3530      AWTOKU
     C                     Z-ADD3530      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
      *
     C                     MOVE MHIN1     AWMHN1
     C                     MOVE MHIN2     AWMHN2
     C                     MOVE MHIN3     AWMHN3
     C                     Z-ADDSHDT      AWSHDT
     C                     MOVELWORDR     AWORDN
     C                     WRITEAB#WATS1
     C                     MOVE '1'       PID
      *
     C           K#86      CHAINAB#PP86              90
     C           *IN90     IFEQ *OFF
     C                     MOVEL@@DESC    A6DSCP
     C                     UPDATAB#PP861
     C                     ELSE
     C                     MOVE AWTOKU    A6TOKU
     C                     MOVE AWMHN1    A6MHN1
     C                     MOVE AWMHN2    A6MHN2
     C                     MOVE AWMHN3    A6MHN3
     C                     MOVEL@@DESC    A6DSCP
     C                     MOVEL@@MHN     A6MHIN
     C                     WRITEAB#PP861
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           @END      TAG
