     C****************************************************************
     C*           KEY LIST                                           *
     C****************************************************************
     C***
     C           IUKEY1    KLIST
     C                     KFLD           D1YY
     C                     KFLD           K@VEND
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C           @START    TAG
     C                     CLEARDSP01
     C                     MOVE *ON       *IN40            FIRST
     C*** DSP01 ***
     C           @DSP01    TAG
     C                     WRITEDSP02
     C                     EXFMTDSP01
     C*
     C                     MOVEA'00'      *IN,11
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #D1CHK
     C           *IN99     CABEQ'1'       @DSP01
     C*
     C           *INKE     CABEQ'0'       @DSP01
     C**
     C                     EXSR #LIST
     C**
     C           *IN40     IFEQ *ON
     C  N99                MOVELMSG,2     D#MSG
     C                     SETON                     991112
     C                     GOTO @DSP01
     C                     ENDIF
     C***
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*          #D1CHK    DSP01 CHECK                               *
     C****************************************************************
     C           #D1CHK    BEGSR                                     *
     C           D1YY      IFEQ 0
     C                     MOVEA'1'       *IN,11
     C           *IN99     IFEQ '0'
     C                     MOVELMSG,1     D#MSG
     C                     MOVEA'1'       *IN,99
     C                     END
     C                     END
     C                     ENDSR
     C****************************************************************
     C*          #LIST     LIST                                      *
     C****************************************************************
     C           #LIST     BEGSR
     C                     EXSR #KYSET
     C*
     C                     DO   *HIVAL
     C           D1YY      READEGDKPL101                 90
     C   90                LEAVE
     C**
     C           IUVEND    IFGT E@VEND
     C                     LEAVE
     C                     ENDIF
     C** FIRST **
     C           *IN40     IFEQ *ON
     C                     MOVELIUVEND    W@VEND  4
     C                     MOVE *OFF      *IN40
     C                     MOVE *ON       *INOF
     C                     ENDIF
     C** VENDOR OR PART TYPE BREAK? **
     C           IUVEND    IFNE W@VEND
     C                     XFOOTAM3       A3TOT  100
     C                     EXCPT@TOTL
     C                     Z-ADD0         AM3
     C                     EXSR #HEAD
     C                     MOVELIUVEND    W@VEND
     C                     ENDIF
     C** OVERFLOW ? **
     C           *INOF     CASEQ*ON       #HEAD
     C                     END
     C**
     C                     MOVEL*BLANK    TYPENM 26
     C                     Z-ADD1         A       20
     C           IUTYPE    LOKUPPT,A                     50
     C   50                MOVELPTN,A     TYPENM
     C**
     C                     Z-ADD1         A       20
     C           1         DO   12        A
     C                     Z-ADDAM,A      AM2,A
     C                     END
     C                     XFOOTAM        A2TOT  100
     C                     ADD  AM        AM3
     C**
     C                     EXCPT@DETL
     C                     ENDDO
     C                     XFOOTAM3       A3TOT  100
     C           A3TOT     IFNE 0
     C                     EXCPT@TOTL
     C                     END
     C**
     C                     ENDSR
     C****************************************************************
     C*          #KYSET    KEY SET                                   *
     C****************************************************************
     C           #KYSET    BEGSR
     C** KEY SET **
     C           D1VEND    IFEQ *BLANK
     C                     MOVE *BLANK    K@VEND  4
     C                     MOVEL*HIVAL    E@VEND  4
     C                     ELSE
     C                     MOVELD1VEND    K@VEND
     C                     MOVELD1VEND    E@VEND
     C                     ENDIF
     C*
     C           IUKEY1    SETLLGDKPL101
     C                     ENDSR
     C****************************************************************
     C*          #HEAD     HEAD PRINT                                *
     C****************************************************************
     C           #HEAD     BEGSR
     C*
     C                     Z-ADD*DATE     W@YMD
     C                     Z-ADDW@YY      W@YY1
     C                     Z-ADDW@MM      W@MM1
     C                     Z-ADDW@DD      W@DD1
     C                     MOVEL*BLANK    W@VNNM 30
     C**
     C                     EXCPT@HEAD
     C**
     C                     MOVE *OFF      *INOF
     C                     ENDSR
     C****************************************************************
     O****************************************************************
     OQPRINT  E   01           @HEAD
     O                                    7 'GDKR06'
