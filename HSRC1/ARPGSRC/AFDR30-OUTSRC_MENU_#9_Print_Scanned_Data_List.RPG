      *-----------------------------------------------------
      *  MAIN ROUTINE
     C*-----------------------------------------------------
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KA                LEAVE
     C*
     C                     MOVEL*BLANK    D@MSG
     C                     MOVEL*OFF      W@ERR   1
     C                     EXSR @CHK
     C           W@ERR     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @PRNT
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* INITIAL SET
     C*-----------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           SUPLY   4
     C                     PARM           SUPX    1
     C*
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C*
     C                     TIME           WSDT
     C*
     C                     Z-ADDWSSDAT    D@DATE
     C                     MOVEL'1'       D@PRT
     C                     MOVEL*BLANK    D@MSG
     C*
     C                     MOVELSUPLY     D@SUPP
     C                     MOVELSUPX      D@SUPX
     C                     MOVELSUPLY     W@SPCD  5
     C                     MOVE SUPX      W@SPCD
     C           W@SPCD    LOKUPTAB1      TAB2           90
     C           *IN90     IFEQ *ON
     C                     MOVELTAB2      D@SUPN  8
     C                     ELSE
     C                     MOVEL*BLANK    D@SUPN
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  CHECK
     C******************************************************
     C           @CHK      BEGSR
     C*
     C                     SETOF                     4142
     C*
     C           K#AGDP    KLIST
     C                     KFLD           D@DTYY
     C                     KFLD           D@DTMM
     C                     KFLD           D@DTDD
     C           K#AGDP    CHAINAGDPL12              98
     C           *IN98     IFEQ *ON
     C                     MOVEL*ON       *IN41
     C                     MOVEL*ON       W@ERR
     C                     MOVELERR,1     D@MSG
     C                     END
     C*
     C           D@PRT     IFEQ '1'
     C           D@PRT     OREQ '2'
     C           D@PRT     OREQ '3'
     C           D@PRT     OREQ '4'
     C           D@PRT     OREQ '5'
     C           D@PRT     OREQ '6'
     C           D@PRT     OREQ '9'
     C                     ELSE
     C                     MOVEL*ON       *IN42
     C           W@ERR     IFEQ *OFF
     C                     MOVELERR,2     D@MSG
     C                     MOVEL*ON       W@ERR
     C                     END
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  PRINT
     C******************************************************
     C           @PRNT     BEGSR
     C*
     C                     SELEC
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT10'@OUTQ   8
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT02'@OUTQ
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT09'@OUTQ
     C           D@PRT     WHEQ '4'
     C                     MOVEL'LANPRT03'@OUTQ
     C           D@PRT     WHEQ '5'
     C                     MOVEL'LANPRT04'@OUTQ
     C           D@PRT     WHEQ '6'
     C                     MOVEL'LANPRT05'@OUTQ
     C                     OTHER
     C                     MOVEL'QDKT    '@OUTQ
     C                     ENDSL
      *
     C                     MOVEACMD,1     ARX
     C                     MOVEA@OUTQ     ARX,50
     C                     MOVEAARX       P@CMD     P
     C           P@CMD     CAT  CMD,2:1   P@CMD     P
     C                     Z-ADD105       P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C*
     C                     OPEN QPRINT
     C*
     C                     MOVEL*OFF      W@1ST   1
     C           D@DATE    SETLLAFDPL30
     C*
     C                     DO   *HIVAL
     C*
     C           D@DATE    READEAFDPL30                  97
     C   97                LEAVE
     C*
     C           SUPLY     IFEQ ADSUPP
     C           SUPX      ANDEQW@SUPX
     C                     ELSE
     C                     ITER
     C                     END
     C*
     C           *INOF     IFEQ *ON
     C           W@1ST     OREQ *OFF
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     MOVEL*ON       W@1ST
     C                     END
     C*
     C                     MOVEL*BLANK    P@PARA
     C                     MOVEL*BLANK    P@PARB
     C           ADPAR2    IFNE *BLANK
     C                     MOVEL'-'       P@PARA
     C                     END
     C           ADPAR3    IFNE *BLANK
     C                     MOVEL'-'       P@PARB
     C                     END
     C*
     C                     MOVELADSUPP    P@SPCD  5
     C                     MOVE W@SUPX    P@SPCD
     C           P@SPCD    LOKUPTAB1      TAB2           90
     C           *IN90     IFEQ *ON
     C                     MOVELTAB2      P@SPNM  8
     C                     ELSE
     C                     MOVEL*BLANK    P@SPNM
     C                     END
     C*
     C                     EXCPT@DTL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------
