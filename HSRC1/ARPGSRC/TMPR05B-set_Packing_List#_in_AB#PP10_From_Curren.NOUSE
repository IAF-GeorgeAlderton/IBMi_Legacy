     H            Y.
     F** TMPR05B ***************************************************************
     F*  PROGRAM    : SET PACKING LIST# IN AB#PP10 FROM CURRENT MONTH          *
     F*             : COPIED TO UEXR90A                                        *
     F*  WRITTEN    : JW (SRA) 2022.11.18                                      *
     F**************************************************************************
     FAB#PL79 IF  E           K        DISK
     FAB#PL08 UF  E           K        DISK
     FAB#PPCT UF  E           K        DISK
      **************************************************************************
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @LAST#    SETLLAB#PL79
     C                     DO   *HIVAL
     C                     READ AB#PL79                  98
     C   98                LEAVE
      *
     C           P8SKJY    IFNE ' '
     C                     ITER
     C                     ENDIF
      * UPDATE AB#PP10
     C                     EXSR #PP10
     C                     ENDDO
      *
      * SET LAST P/L#
     C           #CTKEY    CHAINAB#PPCT              99
     C           *IN99     IFEQ *OFF
     C                     MOVELP8SERL    @SERL
     C                     Z-ADD@SERL     CTNBR1
     C                     Z-ADDUPCNT     CTNBR2
     C                     MOVELTODAY     CTCHR1
     C                     MOVELNOW       CTCHR2
     C                     UPDATAB#PPCT1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * UPDATE AB#PP10                                     *
      *----------------------------------------------------*
     C           #PP10     BEGSR
      *
     C                     Z-ADDP8NONY    K#NONY
     C                     MOVELP8NKOJ    K#NKOJ
     C                     MOVELP8NUKE    K#NUKE
     C                     Z-ADDP8NOYY    K#NOYY
     C                     Z-ADDP8NOMM    K#NOMM
     C                     Z-ADDP8NODD    K#NODD
     C                     Z-ADDP8BINN    K#NOBN
     C           K#PL08    SETLLAB#PL08
     C                     DO   *HIVAL
     C           K#PL08    READEAB#PL08                  97
     C   97                LEAVE
      *
     C           P8ODRN    IFNE *BLANK
     C           P8ODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      *
     C           ¥UPD      IFEQ 'Y'
     C                     MOVELP8SERL    BASERL
     C                     MOVEL'TMPR05'  BAFLD1
     C                     UPDATAB#PP101
     C                     ADD  1         UPCNT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           ¥UPD    1
      *
     C           K#PL08    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#NOYY  40
     C                     KFLD           K#NOMM  20
     C                     KFLD           K#NODD  20
     C                     KFLD           K#NOBN  20
      *
     C                     TIME           @SDATE
     C                     Z-ADD0         UPCNT  100
     C                     MOVEL'BASERL  '#CTKEY  8
      *
     C           ¥UPD      IFNE 'Y'
     C                     MOVE 'N'       ¥UPD
     C                     ENDIF
      * GET LAST P/L#
     C           #CTKEY    CHAINAB#PPCT              99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDCTNBR1    @SERL   90
     C                     MOVEL@SERL     @LAST#  9
     C                     ELSE
     C                     MOVE *BLANK    @LAST#
     C                     ENDIF
      *
     C                     ENDSR
