     H            Y.
     F** UEXR20G ********************************************
     F*  PROGRAM: GET FNG DATA FROM AB#EP40S                *
     F*  WRITTEN: JW (SRA) 2025.08.11                       *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR20G'
     F*                    PARM           $NONY   4
     F*                    PARM           $NOHZ   8
     F*                    PARM           $MHIN  20
     F*                    PARM           $PO#   15
     F*                    PARM           $SLOC  20
     F*                    PARM           $KBAN   6
     F*  IN  $NONY   4A  DELIVERY#
     F*      $NOHZ   8A  SHIP DATE
     F*      $MHIN  20A  USER PART
     F*      $PO#   15A  ORDER#  (IF $PO# NOT FOUND, THE SEARCH WILL BE
     F*                           PERFORMED ASSUMING THAT $PO# IS BLANK)
     F*  OUT $SLOC  20A  STORE ADDRESS
     F*      $KBAN   6A  KANBAN#
     F******************************************************
     FAB#EL4S9IF  E           K        DISK
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
      * 1ST TRY (USE ORIGINAL PARAMETER)
     C           KEY1      SETLLAB#EL4S9
     C                     DO   *HIVAL
     C           KEY1      READEAB#EL4S9                 98
     C   98                LEAVE
     C                     MOVELESLOC     $SLOC
     C                     MOVELESUB#     $KBAN
     C                     ENDDO
      *
     C           $SLOC     IFNE *BLANK
     C                     GOTO ENDP
     C                     ENDIF
      *
      * 2ND TRY (USE BLANK $PO#)
     C                     MOVE *BLANK    K#PO#
     C           KEY1      SETLLAB#EL4S9
     C                     DO   *HIVAL
     C           KEY2      READEAB#EL4S9                 98
     C   98                LEAVE
     C                     MOVELESLOC     $SLOC
     C                     MOVELESUB#     $KBAN
     C                     ENDDO
      *
     C           $SLOC     IFNE *BLANK
     C                     GOTO ENDP
     C                     ENDIF
      *
      * GET ORIGINAL USER PART
     C                     CALL 'UTLR75B'
     C                     PARM           $MHIN
     C                     PARM           $NONY
     C                     PARM           $OPART 20
     C                     PARM           $RTN    1
      *
      * 3RD TRY (USE USER PART)
     C                     MOVEL$OPART    K#MHIN
     C                     MOVEL$PO#      K#PO#
     C           KEY1      SETLLAB#EL4S9
     C                     DO   *HIVAL
     C           KEY1      READEAB#EL4S9                 98
     C   98                LEAVE
     C                     MOVELESLOC     $SLOC
     C                     MOVELESUB#     $KBAN
     C                     ENDDO
      *
     C           $SLOC     IFNE *BLANK
     C                     GOTO ENDP
     C                     ENDIF
      *
      * 4TH TRY (USE BLANK $PO#)
     C                     MOVE *BLANK    K#PO#
     C           KEY1      SETLLAB#EL4S9
     C                     DO   *HIVAL
     C           KEY2      READEAB#EL4S9                 98
     C   98                LEAVE
     C                     MOVELESLOC     $SLOC
     C                     MOVELESUB#     $KBAN
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $NOHZ   8
     C                     PARM           $MHIN  20
     C                     PARM           $PO#   15
     C                     PARM           $SLOC  20
     C                     PARM           $KBAN   6
      *
     C           KEY1      KLIST
     C                     KFLD           K#NONY  4
     C                     KFLD           K#NOHZ  80
     C                     KFLD           K#MHIN 30
     C                     KFLD           K#PO#  20
      *
     C           KEY2      KLIST
     C                     KFLD           K#NONY
     C                     KFLD           K#NOHZ
     C                     KFLD           K#MHIN
      *
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$NOHZ     K#NOHZ
     C                     MOVEL$MHIN     K#MHIN
     C                     MOVEL$PO#      K#PO#
     C                     MOVE *BLANK    $SLOC
     C                     MOVE *BLANK    $KBAN
      *
     C                     ENDSR
