      *------------------------------------------------------------
      *   MAIN ROUTINE
      *------------------------------------------------------------
     C                     EXSR #INIT
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C           @@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* DSPLAY 1ST SCREEN
     C*-----------------------------------------------------
     C           #DSP01    BEGSR
      *
     C** 77                GOTO @JUMP
      *
     C                     EXFMTDSP01
      *
     C           @JUMP     TAG
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     EXSR #SET1
      *
     C           RRN1      IFGT 0
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE MSG,4     XMSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
      * CHECK PARAMETER
      *-----------------------------------------------------
     C           #CHK1     BEGSR
     C                     SETOF                     414243
     C                     SETOF                     44  85
     C                     MOVE *BLANK    XMSG
     C* CHEKC DATE FROM
     C           D1FROM    IFEQ 0
     C                     MOVE MSG,1     XMSG
     C                     SETON                     41  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     Z-ADD1         D1STR   80
     C                     MOVELD1FROM    D1STR
     C                     MOVELD1STR     $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ '1'
     C                     MOVE MSG,2     XMSG
     C                     SETON                     41  85
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$TRUE1    D1STR
     C* CHECK NONY
     C           D1NONY    IFNE 0
     C                     MOVELD1NONY    PMNONY
     C                     MOVE 'D'       PMOPT
     C                     CALL 'UTLR16A'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C           PMNAME    IFEQ ' '
     C                     MOVE MSG,6     XMSG
     C                     SETON                     43  85
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * CHECK PART#
     C**         D1SHN1    IFEQ ' '
     C**         D1SHN2    ANDEQ' '
     C**         D1SHN3    ANDEQ' '
     C**                   MOVELMSG,3     XMSG
     C**                   SETON                     44  85
     C**                   GOTO XCHK1
     C**                   ENDIF
      * IF NO ERROR...
     C                     MOVE D1STR     W@YMD
     C                     Z-ADD99999999  D1END   80
     C                     MOVELD1FROM    D1END
      *
     C           XCHK1     ENDSR
     C*-----------------------------------------------------
      * SET SFL01
     C*-----------------------------------------------------
     C           #SET1     BEGSR
     C                     Z-ADD1         W@SCNT  20
     C*
     C                     CLEARSDT
     C                     CLEARAWC
     C                     CLEAR#DT
     C                     Z-ADD0         JX      20
     C*
     C                     MOVE *ON       *IN57
     C                     WRITECTL01
     C                     MOVE *OFF      *IN57
     C                     Z-ADD0         RRN1    40
     C* # OF CONT SET
     C                     EXSR #SET11
     C*
     C           *LOVAL    SETLLAB#WPC1
     C                     DO   *HIVAL
     C                     READ AB#WPC1                  94
     C   94                LEAVE
     C*
     C                     CLEARSFL01
     C                     MOVELAWSHIN    $SHIN1
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN1 12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    S1SHIN
      *
     C                     DO   6         JX
     C                     Z-ADDAWC,JX    #A,JX
     C                     ADD  AWC,JX    #DT,JX
     C                     ENDDO
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
     C*
     C           RRN1      IFGT 0
     C                     DO   6         JX
     C                     MOVELSDT,JX    #SD,JX
     C                     ENDDO
     C                     END
     C*
     C                     Z-ADD1         #RCNO2
      *
     C                     ENDSR
     C*-----------------------------------------------------
      * SET DATA IN AB#WPC1
     C*-----------------------------------------------------
     C           #SET11    BEGSR
      *
     C                     CLOSEAB#WPC1
     C                     MOVELCLS,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WPC1
     C*
     C           K#06A     SETLLAB#PL06
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#PL06                  92
     C   92                LEAVE
      * END
     C           B1NOHZ    IFGT D1END
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           B1SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           D1NONY    IFNE 0
     C           D1NONY    ANDNEB1NONY
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           D1SHIN    IFNE *BLANK
     C           D1SHIN    ANDNEB1SHIN
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADD1         IX      20
     C           B1NOHZ    LOKUPSDT,IX                   89
     C           *IN89     IFEQ *OFF
     C                     Z-ADD1         IX
     C           00000000  LOKUPSDT,IX                   88
     C           *IN88     IFEQ *OFF
     C                     LEAVE
     C                     END
     C                     END
     C                     Z-ADDB1NOHZ    SDT,IX
     C*
     C           K#WPC1    KLIST
     C                     KFLD           B1SHIN
     C                     KFLD           D1NONY
     C           K#WPC1    CHAINAB#WPC1              93
     C           *IN93     IFEQ *ON
     C                     CLEARAB#WPC11
     C                     MOVELB1SHIN    AWSHIN
     C                     Z-ADDD1NONY    AWNONY
     C                     END
     C*
     C**                   ADD  B1HAKO    AWC,IX
     C           B1SYUY    IFEQ 0
     C                     Z-ADD1         BOX     62
     C                     ELSE
     C           B1SRYO    DIV  B1SYUY    BOX
     C                     ENDIF
      * ROUND UP
     C                     ADD  0.09      BOX
     C                     ADD  BOX       AWC,IX
     C*
     C  N93                UPDATAB#WPC11
     C   93                WRITEAB#WPC11
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C* DISPLAY 2ND SCREEN
     C*-----------------------------------------------------
     C           #DSP02    BEGSR
     C                     MOVE CMD,1     D2CMD
      *
     C                     MOVE *ON       *IN56
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN56                       C
      *
     C           @@REC     IFNE 0
     C                     Z-ADD@@REC     #RCNO2
     C                     END
      *
     C                     SELEC
      * F3: BACK
     C           *INKC     WHEQ *ON
     C                     MOVE '01'      @@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
      * F5: DOWNLOAD
     C           *INKE     WHEQ *ON
     C                     EXSR #DOWN
     C                     MOVE '01'      @@ID
      * F8: BACK
     C           *INKH     WHEQ *ON
     C           W@SCNT    IFGT 1
     C                     SUB  1         W@SCNT
     C                     EXSR #SET3
     C                     END
      * F9: NEXT
     C           *INKI     WHEQ *ON
     C           W@SCNT    IFLT 5
     C                     ADD  1         W@SCNT
     C                     EXSR #SET3
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C*-----------------------------------------------------
     C* PAGE BACK/NEXT
     C*-----------------------------------------------------
     C           #SET3     BEGSR
     C                     MOVE *ON       *IN57
     C                     WRITECTL01
     C                     MOVE *OFF      *IN57
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         JX      20
     C                     Z-ADD0         KX      20
     C                     Z-ADD0         LX      20
     C                     CLEAR#DT
     C*
     C                     SELEC
     C           W@SCNT    WHEQ 1
     C                     Z-ADD1         JX
     C           W@SCNT    WHEQ 2
     C                     Z-ADD7         JX
     C           W@SCNT    WHEQ 3
     C                     Z-ADD13        JX
     C           W@SCNT    WHEQ 4
     C                     Z-ADD19        JX
     C           W@SCNT    WHEQ 5
     C                     Z-ADD25        JX
     C                     ENDSL
      *
     C           *LOVAL    SETLLAB#WPC1
      *
     C                     DO   *HIVAL
      *
     C                     READ AB#WPC1                  94
     C   94                LEAVE
      *
     C                     CLEARSFL01
     C                     MOVELAWSHIN    S1SHIN
     C*
     C                     Z-ADDJX        KX
     C                     DO   6         LX
     C                     Z-ADDAWC,KX    #A,LX
     C                     ADD  AWC,KX    #DT,LX
     C                     ADD  1         KX
     C                     ENDDO
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
     C*
     C                     Z-ADDJX        KX
     C                     Z-ADD0         LX
     C                     DO   *HIVAL
     C                     ADD  1         LX
     C           LX        IFGT 6
     C                     LEAVE
     C                     END
     C                     MOVELSDT,KX    #SD,LX
     C                     ADD  1         KX
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------
      *  DOWNLOAD AB#WPC2
      *-----------------------------------------------------
     C           #DOWN     BEGSR
      *
      * CLEAR AB#WPC1T
     C                     CLOSEAB#WPC1T
     C                     MOVELCLS,2     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WPC1T
      * SET HEADER
     C                     EXSR #HEAD
      * SET DETAIL
     C           *LOVAL    SETLLAB#WPC1
     C                     DO   *HIVAL
     C                     READ AB#WPC1                  96
     C   96                LEAVE
      *
     C                     CLEARAB#WC1T1
     C                     MOVELAWSHIN    $SHIN1
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN1 12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    A1SHIN
      *
     C           AWNONY    IFNE 0
     C                     MOVELAWNONY    A1NONY
     C                     ENDIF
      *
     C           1         DO   30        IX      20
     C           AWC,IX    IFNE 0
      * EDIT DECIMAL
     C                     Z-ADDAWC,IX    $IN
     C                     CALL 'EDTR05A'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     A1C,IX
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     WRITEAB#WC1T1
     C                     ENDDO
      * DOWNLOAD
     C                     CLOSEAB#WPC1T
     C                     CALL 'AB#CC1C'
     C                     OPEN AB#WPC1T
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  SET HEADER VALUES
      *-----------------------------------------------------
     C           #HEAD     BEGSR
      *
     C                     CLEARAB#WC1T1
     C                     MOVEL'IAF_PART'A1SHIN
     C                     MOVEL'DELIV#  'A1NONY
     C                     MOVELMSG,9     A1MEMO
     C                     MOVE TODAY     A1MEMO
      *
     C           1         DO   30        IX      20
     C           SDT,IX    IFEQ 0
     C                     MOVE *BLANK    A1C,IX
     C                     ELSE
     C                     MOVELSDT,IX    $DATE1
     C                     MOVE 'YMD'     $YMD
     C                     MOVE '/'       $SEP
     C                     CALL 'EDTR01A'
     C                     PARM           $DATE1  8
     C                     PARM           $YMD    3
     C                     PARM           $SEP    1
     C                     PARM           $DATE2 10
     C                     MOVEL$DATE2    A1C,IX
     C                     ENDIF
     C                     ENDDO
      *
     C                     WRITEAB#WC1T1
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  INITIAL SETTINGS
      *-----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           K#06A     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
     C                     KFLD           D1SHN1
     C                     KFLD           D1SHN2
     C                     KFLD           D1SHN3
      *
     C                     Z-ADD70        P@LEN
     C                     MOVE '01'      @@ID    2
      *
     C                     TIME           SDATE
     C                     MOVELTODAY     D1FROM
     C                     MOVELCLS,1     P@CMD
      *
     C                     ENDSR
      *-----------------------------------------------------
** CMD
 F3:BACK   F5:Download    F8:Left(<--)    F9:Right(-->)    F12:Back
** MSG(60A) .......2.........3.........4.........5.........6
ENTER DATE FROM !                                              01
DATE FROM IS INVALID !                                         02      .
ENTER PART# !                                                  03
NO DATA                                                        04
                                                               05
DELIVERY CODE IS INVALID !                                     06
                                                               07
                                                               08
AB#RC1B                                                        09
SHIPPED CONTAINER BY PART#                                     10
** CLS
CLRPFM QTEMP/AB#WPC1
CLRPFM QTEMP/AB#WPC1T
