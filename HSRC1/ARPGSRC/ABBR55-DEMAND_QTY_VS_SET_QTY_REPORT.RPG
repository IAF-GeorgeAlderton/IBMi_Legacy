     C                     ADD  Q51NNM    WWQT2
     C                     ELSE
     C                     ADD  Q51NNM    WWQT1
     C                     ADD  Q52NNM    WWQT2
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
