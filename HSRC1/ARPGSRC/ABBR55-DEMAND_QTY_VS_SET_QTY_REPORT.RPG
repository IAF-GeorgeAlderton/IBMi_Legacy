     C                     Z-ADDWPCN1     WPCNT   50
     C                     ELSE
     C                     Z-ADDWWQT2     WWQTY   90
     C                     Z-ADDWPCN2     WPCNT   50
     C                     ENDIF
     C                     ENDIF
      *
     C           D@PCNX    IFGT *ZERO
     C           WPCN1     ANDLED@PCNX
     C           WPCN2     ANDLED@PCNX
     C           WWQT1     IFGT WWQT2
