     C           *LIKE     DEFN Q5SHN1    K@SHN1
     C           *LIKE     DEFN Q5SHN2    K@SHN2
     C           *LIKE     DEFN Q5SHN3    K@SHN3
     C           *LIKE     DEFN Q5SHN1    Z@SHN1
     C           *LIKE     DEFN Q5SHN2    Z@SHN2
     C           *LIKE     DEFN Q5SHN3    Z@SHN3
      *
     C                     MOVEL'01'      W@ID    2
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     Z-ADD130       D@PCNT
      *
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD*ZERO     MON
     C                     Z-ADD*ZERO     DAY
      *
     C           1         DO   2         X       20
     C                     Z-ADD*ZERO     @DAY    20
     C                     ADD  1         K@MM
     C           K@MM      IFGT 12
     C                     SUB  12        K@MM
     C                     ADD  1         K@YY
     C                     ENDIF
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @DAY
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDK@YM      MON,X
     C                     Z-ADD@DAY      DAY,X
      *
      *
     C                     ENDDO
      *
     C                     ENDSR
