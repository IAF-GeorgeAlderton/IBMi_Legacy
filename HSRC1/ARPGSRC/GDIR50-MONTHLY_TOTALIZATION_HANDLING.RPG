     H            Y/                                    1
      *** GDIR50 *****************************************************
      *  MONTHLY TOTALIZATION HANDLING
      *      G.B.C                         97/03/06
      ****************************************************************
     FGDIPL15 UF  E           K        DISK
     FGDIPP20 UF  E                    DISK                      A
     F*
     I****************************************************************
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
     I            DS
     I                                        1   8 IIKATA
     I                                        1   2 IIKAT1
     I                                        3   6 IIKAT2
     I                                        7   7 IIKAT3
     I                                        8   8 IIKAT4
     I            DS
     I                                        1   80IIKOHZ
     I                                        1   40IIKOYY
     I                                        5   60IIKOMM
     I                                        7   80IIKODD
     I            DS
     I                                        1   40IIKOTM
     I                                        1   20IIKOHH
     I                                        3   40IIKOSS
     I* DELETE DUE DATE
     I            DS
     I                                        1   80IJSKHZ
     I                                        1   40IJSKYY
     I                                        5   60IJSKMM
     I                                        7   80IJSKDD
     I            DS
     I                                        1   80IJKOHZ
     I                                        1   40IJKOYY
     I                                        5   60IJKOMM
     I                                        7   80IJKODD
     I            DS
     I                                        1   40IJKOTM
     I                                        1   20IJKOHH
     I                                        3   40IJKOSS
     I*発注実績
     I            DS
     I                                        1   40IJJSYY
     I                                        5   60IJJSMM
     I                                        1   6 IJJSHZ
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C                     PARM           PPDATE  6
     C                     MOVE *BLANK    MMKATA  8
     C                     Z-ADD0         WKSURY  90       数量
     C*
     C* <更新処理>
     C*--------------------
B1   C                     DO   *HIVAL
     C                     READ GDIPL15                  90
     C   90                LEAVE
     C*
     C           IIMJHZ    IFNE 0                                      )
     C                     ITER
     C                     ENDIF
     C*
     C           IIIFMK    IFNE 'C'
     C           IIKATA    IFEQ MMKATA
     C                     ADD  IISURY    WKSURY           数量
     C                     ELSE
     C           MMKATA    IFNE *BLANK
     C                     EXSR #WRITE
     C                     ENDIF
     C                     MOVE IIKATA    MMKATA
     C                     Z-ADDIISURY    WKSURY           数量
     C                     ENDIF
     C                     ENDIF
     C*
     C                     TIME           @@TIME
     C                     Z-ADD*DATE     IIKOHZ
     C                     Z-ADD@TIME     IIKOTM
     C                     MOVELPPUSER    IIKOME
     C                     Z-ADD*DATE     IIMJHZ                       )
     C                     UPDATGDIPL151
E1   C                     ENDDO
     C*--------------------
     C           WKSURY    IFNE 0
     C                     EXSR #WRITE
     C                     ENDIF
     C* <終　了>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C* DUMMY READ
     C                     READ GDIPP20                  90
     C****************************************************************
     C*月次発注データ
     C****************************************************************
     C           #WRITE    BEGSR
     C                     TIME           @@TIME
     C                     MOVE *BLANK    IJSKJY
     C                     Z-ADD0         IJSKHZ
     C                     Z-ADD*DATE     IJKOHZ
     C                     Z-ADD@TIME     IJKOTM
     C                     MOVELPPUSER    IJKOME
     C                     MOVE PPDATE    IJJSHZ
     C                     MOVE MMKATA    IJKATA           型番
     C                     Z-ADDWKSURY    IJSURY           発注数量
     C                     Z-ADD0         IJYJYY
     C                     Z-ADD0         IJYJMM
     C                     Z-ADD0         IJYJDD
     C                     WRITEGDIPP201
     C                     ENDSR
     C****************************************************************
