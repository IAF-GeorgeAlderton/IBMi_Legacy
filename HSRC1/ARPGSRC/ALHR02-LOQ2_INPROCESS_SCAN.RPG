     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #FMT30
     C           @@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      * FOR KANBAN CHECK DEGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
TCHK3C*          P#CMD     PLIST
TCHK3C*                    PARM           P@CMD 256
TCHK3C*                    PARM           P@LEN  155
      *
     C                     TIME           WSDT
     C*
     C                     CLEARFMT100
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C*
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL'A'       W@KKND  1
     C* DUMMY READ
     C                     READ ALHPP01                  98
     C                     READ ALHPP11                  98
     C*
      * get label name and outq name for lot id tags...
     C                     MOVEL'LOQ2'    K@WD1     P
     C                     MOVEL'LOTTAG'  K@WD2     P
     C           K#PCT1    CHAINAB#PPCT              72
     C           *IN72     IFEQ *OFF
     C                     MOVELCTCHR1    ##LBLN  8
     C                     MOVELCTCHR1    DFLBLN  8
     C                     MOVELCTCHR2    ##OUTQ 10
     C                     ENDIF
      *
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN(TM-CODE ENTRY)
     C**************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C                     MOVEL'20'      @@ID
     C                     MOVEL'A'       W@KKND
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN CHECK
     C**************************************************************************
     C           #CHK10    BEGSR
     C*
     C                     SETOF                     6162
     C                     SETOF                     9964
     C* TM-CODE CHECK
     C           F1USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     6199
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,1     F1ERR
     C                     END
     C                     END
     C* SHIFT CODE CHECK
     C           F1SHFT    IFEQ '1'
     C           F1SHFT    OREQ '2'
     C           F1SHFT    OREQ '3'
     C                     ELSE
     C                     SETON                     6299
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,2     F1ERR
     C                     END
     C                     END
     C*
TCHK3C*          *IN99     IFEQ *OFF
TCHK3C*                    MOVEACMD,1     P@CMD
TCHK3C*                    Z-ADD75        P@LEN
TCHK3C*                    CALL 'QCMDEXC' P#CMD
TCHK3C*                    END
     C*
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN(APICS KANBAN)
     C**************************************************************************
     C           #FMT20    BEGSR
     C*
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2ERR
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C           *INKH     WHEQ *ON
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL'P'       W@KKND
     C                     MOVEL'30'      @@ID
     C                     OTHER
     C                     EXSR #CHK20
     C           *IN99     IFEQ *OFF
     C                     MOVEL'40'      @@ID
     C           X         IFLT 6
     C                     ADD  1         X       10
     C                     ELSE
     C                     Z-ADD1         X
     C                     ENDIF
     C                     MOVELOQKAN     KAN,X
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*     2ND SCREEN CHECK
     C**************************************************************************
     C           #CHK20    BEGSR
     C*
     C                     MOVELF2KAN     W2KAN
     C                     SETOF                     616263
     C                     SETOF                     99
     C*
     C                     DO
     C*
     C           W2KAN     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,5     F99ER2
     C                     LEAVE
     C                     END
     C* CHECK DIGIT
     C                     MOVELW2KAN     PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE W2CHKD
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C   99                LEAVE
     C*
     C           W2ZETI    CHAINFCEPL07              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,7     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           K#AAH     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#AAH     SETGTAAHTL06
     C                     DO   *HIVAL
     C           K#AAH     REDPEAAHTL06                  90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     LEAVE
     C                     END
     C           L6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
TCHK1C*          L6STYY    IFNE 9999
TCHK1C*                    ITER
TCHK1C*                    END
TCHK1C           WSSDAT    IFGE L6UKHZ
TCHK1C           WSSDAT    ANDLTL6STHZ
TCHK1C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ENDDO
     C* OQ#
     C           F2OQNO    IFEQ '21'
     C                     ELSE
     C                     SETON                     9962
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,12    F2ERR
     C                     MOVELERR,12    F99ER1
     C                     MOVEL*BLANK    F99ER2
     C                     END
     C                     END
     C* CHARGE#
     C           F2CHG#    IFEQ *ZERO
     C                     SETON                     9963
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,13    F2ERR
     C                     MOVELERR,13    F99ER1
     C                     MOVEL*BLANK    F99ER2
     C                     END
     C                     END
     C*
      *
      * make sure this LOQ#/KANBAN hasn't already been scanned...
     C           F2OQNO    CAT  F2KAN     OQKAN  17
     C           OQKAN     LOKUPKAN                      10
     C           *IN10     IFEQ *ON
     C                     SETON                     996162
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,11    F99ER2
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
     C*
     C                     ENDSR
