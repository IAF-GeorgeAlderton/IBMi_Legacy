     C                     ENDSR
     C*************************************************************************
     C*     4TH SCREEN(LOTID)
     C**************************************************************************
     C           #FMT40    BEGSR
      *
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C           *INKI     WHEQ *ON
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C           W@KKND    IFEQ 'A'
     C                     MOVEL'20'      @@ID
     C                     ELSE
     C                     MOVEL'30'      @@ID
     C                     END
     C                     OTHER
     C                     EXSR #CHK40
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRTOK
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C           W@KKND    IFEQ 'A'
     C                     MOVEL'20'      @@ID
     C                     ELSE
     C                     MOVEL'30'      @@ID
     C                     END
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     4TH SCREEN CHECK
     C**************************************************************************
     C           #CHK40    BEGSR
     C*
     C                     MOVELF4LOT     W4LOT
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           F4LOT     IFEQ *BLANK
     C           F4LOT1    ANDEQ*BLANK
     C           F4LOT2    ANDEQ*BLANK
     C           F4LOT3    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,10    F99ER2
     C                     LEAVE
     C                     END
     C           F4LOT     IFEQ *BLANK
     C                     LEAVE
     C                     END
     C* CHECK DIGIT
     C           #USER     IFNE 'TEST'
     C           #USER     ANDNE'I0777'
     C           #USER     ANDNE'I0778'
     C                     MOVELW4LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE W4CHKD
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C                     END
     C   99                LEAVE
     C*
     C           F4LOT     IFEQ F4LOT1
     C           F4LOT     OREQ F4LOT2
     C           F4LOT     OREQ F4LOT3
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,11    F99ER2
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           F4LOT1    WHEQ *BLANK
     C                     MOVELF4LOT     F4LOT1
     C                     MOVEL*BLANK    F4LOT
     C           F4LOT2    WHEQ *BLANK
     C                     MOVELF4LOT     F4LOT2
     C                     MOVEL*BLANK    F4LOT
     C           F4LOT3    WHEQ *BLANK
