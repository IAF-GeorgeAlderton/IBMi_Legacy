     C                     MOVELW3KAN     PMAREA    P
     C                     MOVE '010'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,4     F3ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE W3CHKD
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,4     F3ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C   99                LEAVE
     C*
     C           W3ZETI    CHAINFCEPL07              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F3ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,7     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           K#ADH     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#ADH     SETGTADHTL05
     C                     DO   *HIVAL
     C           K#ADH     REDPEADHTL05                  90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,4     F3ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     LEAVE
     C                     END
     C           J6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
TCHK1C*          J6STYY    IFNE 9999
TCHK1C*                    ITER
TCHK1C*                    END
TCHK1C           J6ONDO    IFEQ W3ONDO
TCHK1C           J6CO2P    ANDEQW3CO2P
TCHK1C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ENDDO
     C* OQ#
     C           F3OQNO    IFEQ '21'
     C                     ELSE
     C                     SETON                     9962
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,12    F3ERR
     C                     MOVELERR,12    F99ER1
     C                     MOVEL*BLANK    F99ER2
