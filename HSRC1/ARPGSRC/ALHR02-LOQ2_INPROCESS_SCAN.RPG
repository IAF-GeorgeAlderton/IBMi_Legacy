     C                     END
     C                     Z-ADDCTNBR1    W@YYMM
     C                     Z-ADDW@YYYY    A1TSQY
     C                     Z-ADDW@MMMM    A1TSQM
     C                     ADD  1         CTNBR2
     C                     Z-ADDCTNBR2    A1TSQ#
     C   97                WRITEAB#PPCT1
     C  N97                UPDATAB#PPCT1
     C*
     C                     MOVELF1USRC    A1TMCD
     C                     MOVELF1SHFT    A1SHFT
     C*
     C                     MOVELA2BHB1    A1SHN1
     C                     MOVELA2BHB2    A1SHN2
     C                     MOVELA2BHB3    A1SHN3
TCHK2C*TCHK1               MOVELA2ZAIC    A1ZACD
