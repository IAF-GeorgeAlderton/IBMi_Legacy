TCHK2C                     MOVELA2ZAIC    A1ZACD
TCHK2C                     ELSE
TCHK1C                     MOVELJ6ZACD    A1ZACD
TCHK2C                     END
TCHK1C*TCHK2     J6ZACD    CHAINFCETL06              97
TCHK2C           A1ZACD    CHAINFCETL06              97
TCHK1C           *IN97     IFEQ *OFF
     C                     MOVELA2ZANM    A1ZANM
TCHK1C                     END
     C*
     C           W@KKND    IFEQ 'A'
