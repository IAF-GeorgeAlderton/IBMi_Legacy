     C           W@A020    IFNE *BLANK
     C                     MOVELW@HOJI    A1HOJI
     C                     MOVELW@ONDO    A1ONDO
     C                     END
     C                     MOVELF2KAN     A1KAN
     C                     ELSE
     C                     Z-ADDJ6HOJI    A1HOJI
     C                     Z-ADDJ6ONDO    A1ONDO
     C                     MOVELF3KAN     A1KAN
     C                     END
     C*
     C                     MOVELW@KKND    A1KKND
     C                     MOVELW@OQNO    A1OQNO
     C                     Z-ADDW@CHG#    A1CHG#
     C*
      * ------------------------------------------------------------
      * THIS SECTION OF CODE WAS MOVED FROM BOTTOM OF THIS SUBR ****
      *  SO THAT SERIAL BARCODE COULD BE STORED IN DATA FILES ALSO.  ****
      *
     C           'ALHR022 'CHAINAB#PPCT              97
     C           *IN97     IFEQ *ON
     C                     CLEARAB#PPCT1
     C                     MOVEL'ALHR022 'CTKEY1
     C                     Z-ADDWSSYMD    CTNBR1
     C                     END
     C           WSSYMD    IFNE CTNBR1
     C                     Z-ADDWSSYMD    CTNBR1
     C                     Z-ADD*ZERO     CTNBR2
     C                     END
     C                     Z-ADDCTNBR1    W@BAR1
     C                     ADD  1         CTNBR2
     C                     Z-ADDCTNBR2    W@BAR2
     C   97                WRITEAB#PPCT1
     C  N97                UPDATAB#PPCT1
     C*
     C* CHECK DIGIT
     C                     MOVELW@BAR@    PMAREA    P
     C                     MOVE '011'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C                     MOVELPMCHK     W@BAR3
      *
     C                     MOVELW@BARC    A1SERL
      *
      * ------------------------------------------------------------
      *
     C                     WRITEALHPP011
     C*
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Y
     C           Y         IFGT 4
     C                     LEAVE
     C                     END
     C           LOT,Y     IFEQ *BLANK
     C                     LEAVE
     C                     END
     C*
     C                     CLEARALHPP111
     C*
     C                     Z-ADDA1KOYY    ABKOYY
     C                     Z-ADDA1KOMM    ABKOMM
     C                     Z-ADDA1KODD    ABKODD
     C                     Z-ADDA1KOTM    ABKOTM
     C                     MOVELA1USER    ABUSER
     C                     MOVELA1WSID    ABWSID
     C                     MOVELA1PGID    ABPGID
     C*
     C                     MOVELA1OQNO    ABOQNO
     C                     Z-ADDA1TSQY    ABTSQY
     C                     Z-ADDA1TSQM    ABTSQM
     C                     Z-ADDA1TSQ#    ABTSQ#
     C                     Z-ADDA1SCYY    ABSCYY
     C                     Z-ADDA1SCMM    ABSCMM
     C                     Z-ADDA1SCDD    ABSCDD
     C                     Z-ADDA1SCTM    ABSCTM
     C*
     C                     MOVELLOT,Y     ABLOT0
     C                     MOVELLOT,Y     W4LOT
     C                     MOVELW4LOT1    ABLOT1
     C                     MOVELW4CHKD    ABLOT2
     C*
     C                     MOVELW@BARC    ABSERL
     C*
     C                     WRITEALHPP111
     C*
     C                     ENDDO
     C*
     C                     OPEN ALHPR02
     C*
     C                     SORTALOT
     C                     DO   4
     C           LOT,1     IFEQ *BLANK
     C                     MOVELLOT,2     LOT,1
     C                     MOVELLOT,3     LOT,2
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     END
     C           LOT,2     IFEQ *BLANK
     C                     MOVELLOT,3     LOT,2
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     END
     C           LOT,3     IFEQ *BLANK
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     END
     C                     ENDDO
     C*
     C                     Z-ADDWSSMMM    P@MM
     C                     Z-ADDWSSDDD    P@DD
     C                     Z-ADDWSSYYY    P@YY
     C                     MOVELF1SHFT    P@SHFT
     C           LOT,1     IFNE *BLANK
     C                     MOVELLOT,1     W4LOT
     C                     MOVELW4LOT1    P@LOT1    P
     C                     MOVELLOT,2     W4LOT
     C                     MOVELW4LOT1    P@LOT2    P
     C                     MOVELLOT,3     W4LOT
     C                     MOVELW4LOT1    P@LOT3    P
     C                     MOVELLOT,4     W4LOT
     C                     MOVELW4LOT1    P@LOT4    P
     C                     END
     C                     MOVELA1OQNO    P@OQNO
     C                     Z-ADDA1CHG#    P@CHG#
     C                     Z-ADDA1TSQ#    P@TSQ#
     C                     CLEARW@SHIN
     C                     MOVELA2BHB1    W@SHN1
     C           A2BHB2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELA2BHB2    W@SHN2
     C           A2BHB3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELA2BHB3    W@SHN3
     C                     MOVELW@SHIN    P@SHIN
     C                     MOVELA2ZANM    P@ZANM
     C*
     C                     Z-ADDA1HOJI    P@HOJI
     C                     Z-ADDA1ONDO    P@ONDO
     C*
     C                     MOVELW@BARC    P@BARC
     C                     MOVELW@BARC    P@BAR2
     C                     WRITEP@REC1
     C                     WRITEP@REC2
     C                     WRITEP@REC3
     C*
     C                     CLOSEALHPR02
     C*
      *
      * call program to print extra lot id tag for partials...
     C                     DO   4         IX      40
      *
     C           LOT,IX    IFNE *BLANKS
     C                     MOVELLOT,IX    ##LOTN  8
     C                     MOVELF1USRC    ##WKCD  6
     C                     MOVELA1ZANM    ##MATL 15
     C                     MOVELA2BHB     ##SHIN 12
     C                     MOVELW@BARC    ##SERL 12
      *
      * if first char of Lot# = 'R', then it's ASJ BPT so use ASJ LOT tag...
      *    else use default Lot Id Tag label name....
     C                     MOVEL##LOTN    FIRST   1
     C           FIRST     IFEQ 'R'
     C                     MOVEL'ASJLOT'  ##LBLN
     C                     ELSE
     C                     MOVELDFLBLN    ##LBLN
     C                     ENDIF
      *
     C                     CALL 'ALHR111'
     C                     PARM           ##WKCD
     C                     PARM           ##LOTN
     C                     PARM           ##MATL
     C                     PARM           ##SHIN
     C                     PARM           ##SERL
     C                     PARM           ##LBLN
     C                     PARM           ##OUTQ
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C* ****************************************************
     C           @GET@     BEGSR
      *
     C                     MOVEL*BLANK    W@A020
     C                     MOVEL*BLANK    W@A002  2
     C                     MOVELL6JOK1    W@A001  1
     C           W@A001    IFEQ '#'
     C                     MOVELL6JOK1    W@A002
     C                     END
     C           W@A002    IFEQ *BLANK
     C                     MOVELL6JOK2    W@A001
     C           W@A001    IFEQ '#'
     C                     MOVELL6JOK2    W@A002
     C                     END
     C                     END
     C           W@A002    IFEQ *BLANK
     C                     MOVELL6JOK3    W@A001
     C           W@A001    IFEQ '#'
     C                     MOVELL6JOK3    W@A002
     C                     END
     C                     END
     C*
     C           W@A002    IFNE *BLANK
     C           W@A002    CHAINAAAPL01              94
     C           *IN94     IFEQ *OFF
     C           A5SKJY    ANDEQ*BLANK
     C                     MOVELA5JOKM    W@A020
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
******* CMD
*******OVRPRTF FILE(ALHPR01) OUTQ(LANPRT27) SAVE(*YES)
