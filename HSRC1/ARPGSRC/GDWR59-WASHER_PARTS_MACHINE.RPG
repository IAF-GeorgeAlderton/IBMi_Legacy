     OQPRINT  E   02           @HED
     O                         #PGM      10
     O                         UDATE Y   60
     O                         @@TIME    69 '  :  :  '
     O                                   72 'P.'
     O                         PAGE  Z   76
     O        E   03           @HED
     O                                   50 'WASHER LIST BY MACHINE#'
