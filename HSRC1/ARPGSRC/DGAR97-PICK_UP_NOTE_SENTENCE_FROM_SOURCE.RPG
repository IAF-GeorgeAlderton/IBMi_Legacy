     H            Y.                                                      FEAR03
     F** DGAR97 *********************************
     F* .. PICK UP  NOTE SENTENCE FROM  SOURCE..*
     F* .. RPG 3  CLSORT..*
     F* .. WORK PHYSICAL FILE / LOGICAL FILE..*
     F* I-HASADA                    96.07.10    *
     F********************************* DGAR97 **
     FSRCFILE IF  F      92            DISK
     E                    HDT        50  1
     ISRCFILE AA  01
      *
     I*------------------*
     I*  ..RPG . SORT..  *
     I*------------------*
     I                                       18  18 RCYO
     I                                       19  19 RC1
     I                                       19  20 RC2
     I                                       20  69 RTXT
      *
     I*-----------*
     I*  ..CL ..  *
     I*-----------*
     I                                       26  27 LDT1
     I                                       26  28 LDT2
     I                                       28  77 LTXT
      *
     I*--------------------*
     I*  ..rｮnﾝｰh.ﾆﾞｭﾎﾞ..  *
     I*--------------------*
     I                                       13  14 TDT1
     I                                       13  15 TDT2
     I                                       15  64 TTXT
      *
     I*------------------------------------*
     I*  ..物理ファイル・論理ファイル..  *
     I*------------------------------------*
     I                                       19  19 FC1
     I                                       19  20 FC2
     I                                       20  69 FTXT
     I            DS
     I                                        1   2 W0EF
     I                                        1   1 W0E
     I                                        2   2 W0F
      *
     C           *ENTRY    PLIST
     C                     PARM           PCMT   50
      *
     C*------------*
     C*  ..RPG ..  *
     C*------------*
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ SRCFILE                  02
     C           *IN02     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           RCYO      IFNE 'A'
     C           RC2       IFNE '**'
     C           RC1       IFEQ '*'
      *
     C                     MOVE RTXT      PCMT
     C                     EXSR SUBR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     END
     C                     END
     C                     END
      *
     C*-------------*
     C*  ..SORT ..  *
     C*-------------*
     C           PTYPE     IFEQ 'TXT  '
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ SRCFILE                  02
     C           *IN02     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           RC2       IFNE '**'
     C           RC1       IFEQ '*'
      *
     C                     MOVE RTXT      PCMT
     C                     EXSR SUBR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*-----------*
     C*  ..CL ..  *
     C*-----------*
     C           PTYPE     IFEQ 'CLP  '
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ SRCFILE                  02
     C           *IN02     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           LDT2      IFNE '/**'
     C           LDT1      IFEQ '/*'
      *
     C                     MOVE LTXT      PCMT
     C                     EXSR SUBR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*--------------------*
     C*  ..rｮnﾝｰh.ﾆﾞｭﾎﾞ..  *
     C*--------------------*
     C           PTYPE     IFEQ 'CL   '
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ SRCFILE                  02
     C           *IN02     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           TDT2      IFNE '/**'
     C           TDT1      IFEQ '/*'
      *
     C                     MOVE TTXT      PCMT
     C                     EXSR SUBR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*------------------------------------*
     C*  ..物理ファイル・論理ファイル..  *
     C*------------------------------------*
     C           PTYPE     IFEQ 'PF   '
     C           PTYPE     OREQ 'LF   '
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ SRCFILE                  02
     C           *IN02     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           FC2       IFNE '**'
     C           FC1       IFEQ '*'
      *
     C                     MOVE FTXT      PCMT
     C                     EXSR SUBR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     END
     C                     END
     C                     END
     C                     END
      *
      *
     C*------------------------------------------*
     C*  ..サブルーチン                        *
     C*  ..テキスト　＇０Ｅ・０Ｆ＇チェック..  *
     C*------------------------------------------*
     C           SUBR      BEGSR
      *
     C                     MOVEAPCMT      HDT
      *
     C                     SETOF                     11
     C           W0E       LOKUPHDT                      11
     C           *IN11     IFEQ '1'
      *
     C                     SETOF                     12
     C                     Z-ADD1         A       20
     C                     Z-ADD51        B       20
     C           1         DO   50        A
     C                     SUB  1         B
      *
     C           HDT,B     IFEQ W0F
     C                     SETON                     12
     C                     ELSE
      *
     C           HDT,B     IFEQ W0E
     C                     SETON                     12
      *
     C           B         DIV  2         WKT1    20
     C                     MVR            WAM1    20
      *
     C           WAM1      IFEQ 0
     C                     MOVE W0F       HDT,49
     C                     MOVE *BLANK    HDT,50
     C                     ELSE
     C                     MOVE W0F       HDT,50
     C                     END
      *
     C                     MOVEAHDT       PCMT
     C                     END
      *
     C                     END
     C  N12                END
     C                     END
      *
     C                     ENDSR
