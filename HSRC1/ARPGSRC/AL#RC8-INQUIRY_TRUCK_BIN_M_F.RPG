     H            Y.
     F** AL#RC8 **************************************
     F* INQUIRY TRUCK BIN M/F                        *
     F*        KIRI         2016.08.12               *
     F************************************************
     FAL#PWC8 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFREC1
     FAL#PPC1 IF  E           K        DISK
      *================================================================
     E                    ER      1  10 65
      *================================================================
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
      * PLIST                                              *
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@KIHZ  80       CHANGE DATE
     C                     PARM           P@SURT  9        SUB ROUTE
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      * INIT                                               *
      *================================================================
     C           #INIT     BEGSR
      *
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
     C                     MOVE *BLANK    P@SURT           SUB ROUTE
     C                     Z-ADDP@KIHZ    K$KIHZ  80
      *
     C           K$KIHZ    SETGTAL#PPC1
     C                     READPAL#PPC1                  90
     C  N90                Z-ADDC5KIHZ    K$KIHZ
     C                     Z-ADDK$KIHZ    D1KIHZ
     C           K$KIHZ    SETLLAL#PPC1
     C                     Z-ADD15        @PAGE   40
     C                     SETON                     89
      *
     C                     EXSR #SFSET
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *================================================================
     C           #SFSET    BEGSR
      *
     C                     SETON                     73
     C                     WRITESFCTL1
     C                     SETOF                     73
     C                     Z-ADD0         RRN     40
      *-------------------------
     C                     DO   *HIVAL
     C           K$KIHZ    READEAL#PPC1                  90
     C   90                LEAVE
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C                     MOVELC5TRKB    S1TRKB           IAF TRUCK BIN#
     C                     MOVELC5SURT    S1SURT           SUB ROUTE
     C                     Z-ADDC5STTN    S1STTN           START TIME
     C                     Z-ADDC5EDTN    S1EDTN           END TIME
     C                     ADD  1         RRN
     C                     WRITESFREC1
     C           RRN       IFGE @PAGE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *-------------------------
     C                     Z-ADDRRN       ENDRRN  40
      *
     C                     ENDSR
      *================================================================
     C           #BACK     BEGSR
      *
     C           ENDRRN    ADD  @PAGE     $BACK   40
     C   90      K$KIHZ    SETGTAL#PPC1
     C   90                ADD  1         $BACK
      *-------------------------
     C                     DO   *HIVAL
     C           K$KIHZ    REDPEAL#PPC1                  89
     C   89                LEAVE
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C                     SUB  1         $BACK
     C           $BACK     IFLE 0
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *-------------------------
     C   89      K$KIHZ    SETLLAL#PPC1
      *
     C                     EXSR #SFSET
     C                     ENDSR
      *================================================================
      *
      *================================================================
     C           #DSP1     BEGSR
     C                     SETON                     7172
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     717299
      *--------------------
     C                     SELEC
     C**
     C           *INKC     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C**
     C           *IN75     WHEQ *ON
     C           *IN90     IFEQ *OFF
     C                     SETOF                     89
     C                     EXSR #SFSET
     C           ENDRRN    IFEQ 0
     C                     EXSR #BACK
     C                     ENDIF
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,2      D1ERR
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C**
     C           *IN76     WHEQ *ON
     C           *IN89     IFEQ *OFF
     C                     EXSR #BACK
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,3      D1ERR
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C**
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFREC1               91
     C           *IN91     IFEQ *OFF
     C                     MOVELS1SURT    P@SURT           SUB ROUTE
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *================================================================
**
ER-1 THERE ARE NO DATA.
ER-2 LAST DATA
ER-3 FIRST DATA
ER-4 INPUT IAF TRUCK BIN#.
ER-5 INPUT CHANGE DATE.
ER-6 THIS CHANGE DATE IS ALREADY EXIST.
ER-7 DUPLICATE ERR.
ER-8
