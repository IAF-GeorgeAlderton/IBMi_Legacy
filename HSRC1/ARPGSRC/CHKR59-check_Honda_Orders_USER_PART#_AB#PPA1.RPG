     H            Y.
     F***CHKR59*****************************************************************
     F*  PROGRAM    : CHECK HONDA ORDERS USER PART# IN AB#PPA1                 *
     F*             : READ AB#PLA2                                             *
     F*  WRITTEN    : 2019.07.08                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLA2 UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80K#YMD
     I                                        1   40K#YY
     I                                        5   60K#MM
     I                                        7   80K#DD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @DATE     SETLLAB#PLA2
     C                     DO   *HIVAL
     C                     READ AB#PLA2                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
      * SELECT HONDA
     C           BATOKU    IFNE 0294
     C           BATOKU    ANDNE0295
     C           BATOKU    ANDNE0296
     C           BATOKU    ANDNE0390
     C           BATOKU    ANDNE0391
     C           BATOKU    ANDNE0400
     C           BATOKU    ANDNE1602
     C           BATOKU    ANDNE3135
     C                     ITER
     C                     ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           BAFLD2    IFEQ *BLANK
     C                     EXSR #MHIN
     C                     EXSR #PRINT
      * SET BLANK FLAG
     C           $MHINO    IFEQ *BLANK
     C                     MOVE 'Y'       BFLG
     C                     ENDIF
      * UPDATE
     C           $UPD      IFEQ 'Y'
     C                     MOVEL$MHINO    BAFLD2
     C                     UPDATAB#PLA21
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           BFLG      IFEQ 'Y'
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  GET USER PART                                     *
      *----------------------------------------------------*
     C           #MHIN     BEGSR
      *
     C                     MOVELBANONY    $NONY
     C                     MOVELBAODRN    $ODRN
     C                     MOVELBAMHIN    $MHINI
     C                     MOVELTODAY     $NOHZ
     C                     CALL 'UEXR10'
     C                     PARM           $NONY   4
     C                     PARM           $ODRN  10
     C                     PARM           $MHINI 20
     C                     PARM           $NOHZ   8
     C                     PARM           $PLNT   3
     C                     PARM           $SHCD  10
     C                     PARM           $PLSH   8
     C                     PARM           $QTY    9
     C                     PARM           $MHINO 20
     C                     PARM           $RTN    1
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1        UPDATE FLAG
     C                     PARM           $DATE   8        CREATE DATE
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE 'N'       BFLG    1        BLANK FLAG
      * SET DATE
     C           $DATE     IFEQ *BLANK
     C           $DATE     OREQ '00000000'
     C                     Z-ADDTODAY     @DATE   80
     C                     ELSE
     C                     MOVEL$DATE     @DATE
     C                     ENDIF
     C           @DATE     IFGT TODAY
     C                     Z-ADDTODAY     @DATE
     C                     ENDIF
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK HONDA ORDER'
     O                                   60 'S USER_PART=BLANK **'
     O                                   80 ' (EDIPP45 VS PPA1)  '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'TYPE'
     O                                   15 'CUST'
     O                                   20 'DELV'
     O                                   36 'SHP_DATE'
     O                                   43 'BIN#'
     O                                   50 'ORDER#'
     O                                   65 'USER_PART'
     O                                   71 'USER_PART (555)'
     O                                   88 'ORIGINAL (S/B)'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         BAEDIK  +002
     O                         BATOKU  +003
     O                         BANONY  +001
     O                         BANKOJ  +001
     O                         BANUKE  +001
     O                         BANOHZ  +001 '    /  /  '
     O                         BANOBN  +002
     O                         BAODRN  +002
     O                         BAMHN1  +002
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         $MHINO  +001
