     H            Y.
      ** ALCR53  *******************************************
      *  CONVEYANCE PULL SCAN ERROR LOG LIST               *
      *                                                    *
      * LEC  2018/12/11   COPY FROM ALCR03                 *
      ******************************************************
     FALCPW53 CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
      *
     E                    ERR     1  10 70
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80W@SCDT
     I                                        1   40W@SCYY
     I                                        5   60W@SCMM
     I                                        7   80W@SCDD
     I            DS
     I                                        1  14 W@PRT
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     I            DS
     I                                        1  120D@FROM
     I                                        1   80D@FRDT
     I                                        9  120D@FRTM
      *
     I            DS
     I                                        1  120D@TO
     I                                        1   80D@TODT
     I                                        9  120D@TOTM
      *
     C           K#AGDP    KLIST
     C                     KFLD           W@SCYY
     C                     KFLD           W@SCMM
     C                     KFLD           W@SCDD
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    D@FRDT
     C                     Z-ADDWSSDAT    D@TODT
     C                     Z-ADD2400      D@TOTM
     C                     MOVE '1'       D@PRTR
     C                     SETOF                     616263
     C                     SETOF                     646566
     C                     SETOF                     69
     C                     MOVEL*BLANK    MSG
     C                     CLEARDSP01
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTDSP01
     C   KA                LEAVE
     C                     SETOF                     616263
     C                     SETOF                     646566
     C                     SETOF                     69
     C                     MOVEL*BLANK    MSG
      *
     C                     EXSR @CHK
     C           *IN69     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C           *INKE     IFEQ *ON
     C                     MOVELD@FROM    P@FRDT 12
     C                     MOVELD@TO      P@TODT 12
     C                     MOVEL*OFF      P@RFLG  1
     C                     MOVELD@PRTR    P@PRTR  1
     C                     CALL 'ALCC52'
     C                     PARM           P@FRDT
     C                     PARM           P@TODT
     C                     PARM           P@RFLG
     C                     PARM           P@PRTR
     C           P@RFLG    IFEQ *OFF
     C                     SETON                     616465
     C                     SETON                     6669
     C                     MOVELERR,3     MSG
     C                     ITER
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * CHECK SCREEN 1 ENTRIES.
      *-----------------------------------------------------
     C           @CHK      BEGSR
      *
     C                     DO
      *
      * check from date...
     C                     MOVELD@FRDT    W@SCDT
     C           K#AGDP    CHAINAGDPL12              91
     C           *IN91     IFEQ *ON
     C                     SETON                     6169
     C                     MOVELERR,1     MSG
     C                     LEAVE
     C                     ENDIF
      *
      * check to date...
     C                     MOVELD@TODT    W@SCDT
     C           K#AGDP    CHAINAGDPL12              91
     C           *IN91     IFEQ *ON
     C                     SETON                     6469
     C                     MOVELERR,1     MSG
     C                     LEAVE
     C                     ENDIF
      *
      * check time fields...
     C           D@FRTM    IFLT *ZERO
     C           D@FRTM    ORGT 2400
     C                     SETON                     6569
     C                     MOVELERR,5     MSG
     C                     LEAVE
     C                     ENDIF
      *
     C           D@TOTM    IFLT *ZERO
     C           D@TOTM    ORGT 2400
     C                     SETON                     6669
     C                     MOVELERR,5     MSG
     C                     LEAVE
     C                     ENDIF
      *
      * check date/time range is valid...
     C           D@FROM    IFGT D@TO
     C                     SETON                     616465
     C                     SETON                     6669
     C                     MOVELERR,6     MSG
     C                     LEAVE
     C                     ENDIF
      *
     C           #USER     IFEQ 'QPGMR'
     C                     ELSE
     C           D@PRTR    IFLT '1'
     C           D@PRTR    ORGT '2'
     C                     SETON                     6369
     C                     MOVELERR,4     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
** ERR
DATE IS INVALID!
SHIFT CODE SHOULD BE 1, 2 OR 3!
NO TARGET DATA!
PRINTER SHOULD BE 1 OR 2!
TIME IS INVALID!
INVALID DATE RANGE!
ERROR 7
ERROR 8
ERROR 9
ERROR 10
