     H            Y.
     F** EJRR13 *******************************************************
     F* R856FORD (CONTAINER ASN) CREATE EB#EP41                       *
     F* T.SAKAKI                    2017.02.08                        *
     F*****************************************************************
     FEJRWP13 IF  F     339            DISK
      *
     FEB#EP41 O   E                    DISK
      *
     E                    TB1        10  1
     E                    TB2        10  1
      *
     IEJRWP13 AA  01
     I                                        1 339 A#DATA
     I                                        1   1 @KUBN
     I**  HEADER
     I                                        1   1 @KUBN
     I                                        2   7 H#RCID
     I                                        8  19 H#PTID
     I                                       20  22 H#DKBN
     I                                       32  33 H#SPCD
     I                                       34  44 H#REF#
     I                                       58  63 H#SIDT
     I                                       73  82 H#GWGT
     I                                      102 106 H#PKCD
     I                                      114 115 H#ROSQ
     I                                      116 117 H#ROIQ
     I                                      118 121 H#ROID
     I                                      122 123 H#ROMC
     I                                      124 125 H#ROLQ
     I                                      126 130 H#ROLO
     I                                      137 143 H#EQMT
     I                                      274 303 H#BOLN
     I                                      317 321 H#IDCD
     I                                      324 325 H#STIQ
     I                                      326 330 H#STID
     I**  DETAIL
     I                                        2   7 D#RCID
     I                                       10  39 D#PART
     I                                       40  46 D#QTY3
     I                                       47  48 D#UBM2
     I                                      119 148 D#PKLS
     I**
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
      *   KEY LIST
      *================================================================
      *================================================================
      *  MAIN
      *================================================================
     C                     TIME           WTIME
     C*-------------------------
     C           1         SETLLEJRWP13
     C*-------------------------
     C                     DO   *HIVAL
     C                     READ EJRWP13                  90
     C   90                LEAVE
     C*
     C                     SELEC
     C* HEADER
     C           @KUBN     WHEQ 'H'
     C                     EXSR #HDSET
     C* DETAIL
     C           @KUBN     WHEQ 'D'
     C                     EXSR #DTSET
     C*
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *  GET HEADER
      *================================================================
     CSR         #HDSET    BEGSR
     C*
     C                     CLEAREB#EP411
     C*
     C                     MOVELH#PTID    A5TPCD
     C                     MOVELH#DKBN    A5TSID           '997'
     C                     MOVELH#SPCD    A5SPCD
     C                     MOVELH#REF#    A5REF#
     C*
     C                     MOVELH#SIDT    WKDTA6  6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    A5SIDT
     C*
     C                     MOVELH#STIQ    A5STIQ
     C                     MOVELH#STID    A5STID
     C                     MOVELH#IDCD    A5IDCD
     C                     MOVELH#PKCD    A5PKCD
     C                     MOVELH#EQMT    A5EQMT
      * GROSS WEIGHT
     C                     MOVEAH#GWGT    TB1
     C                     EXSR #CONV
     C                     Z-ADD@NUM      A5GWGT
     C*
     C                     MOVELH#ROSQ    A5ROSQ
     C                     MOVELH#ROIQ    A5ROIQ
     C                     MOVELH#ROID    A5ROID
     C                     MOVELH#ROMC    A5ROMC
     C                     MOVELH#ROLQ    A5ROLQ
     C                     MOVELH#ROLO    A5ROLO
     C                     MOVELH#BOLN    A5BOLN
     C*
     C*
     CSR         EHDSET    ENDSR
      *================================================================
      *  GET DETAIL
      *================================================================
     CSR         #DTSET    BEGSR
      *
     C                     Z-ADDWTIHZ     A5SVDT
     C                     Z-ADDWJFB      A5SVTM
      *
     C                     MOVELD#PART    A5PART
     C                     MOVELD#UBM2    A5UBM2
      *
     C                     MOVELD#PKLS    A5PKLS
      * QTY
     C                     MOVE D#QTY3    W#QTY3 10
     C                     MOVEAW#QTY3    TB1
     C                     EXSR #CONV
     C                     Z-ADD@NUM      A5QTY3
      *
     C* WRITE
     C                     WRITEEB#EP411
      *
     CSR         EDTSET    ENDSR
      *================================================================
      *  DATE 6 TO 8 DIGITS
      *================================================================
     CSR         #DATE8    BEGSR
      *
     C                     MOVEL*BLANK    WKDTA8  8
      *
     C           WKDTA6    IFEQ *BLANK
     C                     ELSE
     C                     CALL 'DATR00'
     C                     PARM           WKDTA6
     C                     PARM           WKDTA8
     C                     ENDIF
      *
     CSR         EDATE8    ENDSR
      *================================================================
      *  NUMERIC
      *================================================================
     CSR         #CONV     BEGSR
      *
     C                     Z-ADD0         @NUM   100
     C                     Z-ADD0         IX      20
     C                     SETOF                     60
     C                     MOVEA*ALL'0'   TB2
      *
     C           1         DO   10        IX
     C                     MOVE TB1,IX    TB2,IX
     C                     SELEC
     C           TB1,IX    WHEQ *BLANK
     C           TB1,IX    OREQ '+'
     C                     MOVE '0'       TB2,IX
     C           TB1,IX    WHEQ '-'
     C                     MOVE '0'       TB2,IX
     C                     SETON                     60
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     MOVEATB2       LTR10  10
     C                     MOVELLTR10     @NUM
     C* NEGATIVE
     C           *IN60     IFEQ *ON
     C           0         SUB  @NUM      @NUM
     C                     ENDIF
     C*
     CSR         ECONV     ENDSR
