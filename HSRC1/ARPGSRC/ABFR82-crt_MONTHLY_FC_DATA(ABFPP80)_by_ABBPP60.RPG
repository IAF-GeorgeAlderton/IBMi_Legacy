     H            Y/
     F** ABFR82 **********************************************
     F*  CREATE MONTHLY FC ORDER DATA(ABFPP80) (MANUAL) )    *
     F*  J.WATANABE 2018.07.10                               *
     F********************************************************
     FABBPL60 IF  E           K        DISK
     FABFPP80 O   E           K        DISK
      *------------------------------------------------------------
     E                    SU         31  7 0
      *
     I            DS
     I                                        1 2170SU
     I                                        1   70ABSU01
     I                                        8  140ABSU02
     I                                       15  210ABSU03
     I                                       22  280ABSU04
     I                                       29  350ABSU05
     I                                       36  420ABSU06
     I                                       43  490ABSU07
     I                                       50  560ABSU08
     I                                       57  630ABSU09
     I                                       64  700ABSU10
     I                                       71  770ABSU11
     I                                       78  840ABSU12
     I                                       85  910ABSU13
     I                                       92  980ABSU14
     I                                       99 1050ABSU15
     I                                      106 1120ABSU16
     I                                      113 1190ABSU17
     I                                      120 1260ABSU18
     I                                      127 1330ABSU19
     I                                      134 1400ABSU20
     I                                      141 1470ABSU21
     I                                      148 1540ABSU22
     I                                      155 1610ABSU23
     I                                      162 1680ABSU24
     I                                      169 1750ABSU25
     I                                      176 1820ABSU26
     I                                      183 1890ABSU27
     I                                      190 1960ABSU28
     I                                      197 2030ABSU29
     I                                      204 2100ABSU30
     I                                      211 2170ABSU31
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80@SHPHZ
     I                                        1   60@TGTYM
     I                                        7   80IX
     I            DS
     I                                        1   80ABKOHZ
     I                                        1   40ABKOYY
     I                                        5   60ABKOMM
     I                                        7   80ABKODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *==================================================
      * MAIN ROUTINE
      *==================================================
     C                     EXSR #INT
      * MAIN LOOP
     C           @TGTYM    SETLLABBPL60
     C                     DO   *HIVAL
     C           @TGTYM    READEABBPL60                  91
     C   91                LEAVE
      *
     C           ABTOKU    IFNE 8450
     C                     EXSR #OUT
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*=====================================================
     C* OUTPUT DATA TO ABFPP80
     C*=====================================================
     C           #OUT      BEGSR
     C                     Z-ADD0         SEQ#    20
      * OUT
     C           1         DO   31        IX      20
      *
     C           SU,IX     IFNE 0
     C                     CLEARABFPP801
     C                     Z-ADDABKOHZ    B8RCDT
     C                     MOVEL@TGTYM    B8FCYM
     C                     Z-ADDABTOKU    B8TOKU
     C                     Z-ADDABNONY    B8NONY
     C                     MOVELABNKOJ    B8NKOJ
     C                     MOVELABNUKE    B8NUKE
     C                     MOVELABMHN1    B8MHN1
     C                     MOVELABMHN2    B8MHN2
     C                     MOVELABMHN3    B8MHN3
     C                     MOVELABMHN4    B8MHN4
     C                     MOVELABSHN1    B8SHN1
     C                     MOVELABSHN2    B8SHN2
     C                     MOVELABSHN3    B8SHN3
     C                     Z-ADD@SHPHZ    B8SDTS
     C                     Z-ADDSU,IX     B8SQTS
     C                     Z-ADD0         B8SDTW
     C                     ADD  1         SEQ#
     C                     Z-ADDSEQ#      B8SDT#
      *
     C           SEQ#      IFEQ 1
     C                     Z-ADD@SHPHZ    B8SDTO
     C                     Z-ADDABGEKN    B8SQTO
     C                     ENDIF
      *
     C                     MOVEL'ABBPP60' B8SFLO
     C                     Z-ADDTODAY     B8CRDT
     C                     Z-ADDNOW       B8CRTM
     C                     MOVEL#USER     B8CRUS
     C                     MOVEL#PGM      B8CRPG
     C                     WRITEABFPP801
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C*=====================================================
     C* Initial SET
     C*=====================================================
     C           #INT      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TGTYM  6
      *
     C                     TIME           SDATE
     C                     MOVEL$TGTYM    @TGTYM  60
     C*
     C                     ENDSR
