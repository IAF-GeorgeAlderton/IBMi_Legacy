     H            Y.
     F** UTLR78B **********************************************
     F*  PROGRAM: UTILITY- MACHINE/SIZE FROM PROC             *
     F*  ABHPP01: INTRA-PROCESS KANBAN M/F (KOTEINAI)         *
     F*  WRITTEN: JW (SRA) 2020.08.04                         *
     F*-------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR78B'
     F*                    PARM           $SHIN  12
     F*                    PARM           $PRC    3
     F*                    PARM           $MCN    3
     F*                    PARM           $SIZE   3
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART
     F*      $PRC  :  3A  PROCESS
     F*  OUT $MCN  :  3A  MACHINE CODE
     F*      $SIZE :  3A  SIZE
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FAAMPL11 IF  E           K        DISK
     FABBPP7G IF  E           K        DISK
      *===================================================
     E                    PRC        15  3
     E                    MCN        15  3
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * TABLE
     I            DS
     I                                        1  45 PRC
     I                                        1   3 CKKO01
     I                                        4   6 CKKO02
     I                                        7   9 CKKO03
     I                                       10  12 CKKO04
     I                                       13  15 CKKO05
     I                                       16  18 CKKO06
     I                                       19  21 CKKO07
     I                                       22  24 CKKO08
     I                                       25  27 CKKO09
     I                                       28  30 CKKO10
     I                                       31  33 CKKO11
     I                                       34  36 CKKO12
     I                                       37  39 CKKO13
     I                                       40  42 CKKO14
     I                                       43  45 CKKO15
     I            DS
     I                                        1  45 MCN
     I                                        1   3 CKKB01
     I                                        4   6 CKKB02
     I                                        7   9 CKKB03
     I                                       10  12 CKKB04
     I                                       13  15 CKKB05
     I                                       16  18 CKKB06
     I                                       19  21 CKKB07
     I                                       22  24 CKKB08
     I                                       25  27 CKKB09
     I                                       28  30 CKKB10
     I                                       31  33 CKKB11
     I                                       34  36 CKKB12
     I                                       37  39 CKKB13
     I                                       40  42 CKKB14
     I                                       43  45 CKKB15
      * KEY FIELDS
     I            DS
     I                                        1  12 K#SHN
     I                                        1   5 K#SHN1
     I                                        6  10 K#SHN2
     I                                       11  12 K#SHN3
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * READ AAMPL11
     C           K#PL01    CHAINAAMPL11              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      * GET MACHINE
     C                     Z-ADD1         IX      20
     C           $PRC      LOKUPPRC,IX                   99
     C           *IN99     IFEQ *OFF
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVELMCN,IX    $MCN
      * GET SIZE
     C           MCN,IX    SETLLABBPP7G
     C                     DO   *HIVAL
     C           MCN,IX    READEABBPP7G                  98
     C   98                LEAVE
      *
     C           A#SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA#SIZE    $SIZE
     C                     LEAVE
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $PRC    3
     C                     PARM           $MCN    3
     C                     PARM           $SIZE   3
     C                     PARM           $RTN    1
      *
     C           K#PL01    KLIST
     C                     KFLD           K#SHN1  5
     C                     KFLD           K#SHN2  5
     C                     KFLD           K#SHN3  2
      * SYSTEM DATE
     C                     MOVE *BLANK    $MCN
     C                     MOVE *BLANK    $SIZE
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     MOVEL$SHIN     K#SHN
      *
     C                     ENDSR
