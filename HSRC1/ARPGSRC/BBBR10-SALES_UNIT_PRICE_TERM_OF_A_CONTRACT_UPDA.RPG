     H            Y.
     F**BBBR10******************************************
     F* SALES UNIT PRICE TERM OF A CONTRACT UPDATE TABLE HANDLING *
     F*         PROGRAM ID. : BBBR10                   *
     F*         CREATE DATE. : OCT.04,'90.             *
     F*         AUTHOR.        : K.NAKAMURA            *
     F******************************************BBBR10**
     FBBBPW10 CF  E                    WORKSTN
     FBBEPL01 IF  E           K        DISK
     FBBEPL11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     E                    TAB1    1   3  1   TAB2   16
     E                    ER      1  16 60
     I            DS
     I                                        1   80@@STHZ
     I                                        1   40@@STYY
     I                                        5   60@@STMM
     I                                        7   80@@STDD
     I            DS
     I                                        1   80@@ENHZ
     I                                        1   40@@ENYY
     I                                        5   60@@ENMM
     I                                        7   80@@ENDD
     C           STEP1     TAG
      *  1fﾞx] ﾉ ﾎｧｰﾓnﾞ hﾒaｰ
     C                     MOVEL*BLANK    @@KUBN
     C                     Z-ADD0         @@CODE
     C                     MOVE '0'       @@RIRN
     C           STEP2     TAG
      *  1fﾞx] ﾆｬlﾒｭh
     C                     EXFMTBBBPW101
     C                     MOVEL*BLANK    MSG
     C                     MOVEA'000'     *IN,01
     C                     MOVEA'0'       *IN,99
      *  CMD-1 kｩｮh
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *  fﾞx]1 ﾉ ﾎｧｰﾓnﾞ kｩｮh
     C           @@KUBN    IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STEP2
     C                     END
      *
     C           @@KUBN    IFNE 'G'
     C           @@KUBN    ANDNE'R'
     C           @@KUBN    ANDNE'S'
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO STEP2
     C                     END
      *
     C           @@CODE    IFEQ 0
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO STEP2
     C                     END
      *
     C           @@CODE    IFNE 1
     C           @@CODE    ANDNE2
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO STEP2
     C                     END
      *
     C           @@RIRN    IFNE '0'
     C           @@RIRN    ANDNE'R'
     C                     SETON                     0399
     C                     MOVELER,15     MSG
     C                     GOTO STEP2
     C                     END
      *
      *
     C           @@CODE    IFEQ 1
     C                     EXSR GAMEN1
     C                     END
     C           @@CODE    IFEQ 2
     C                     EXSR GAMEN2
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *---------------------------------------*
      *   契約期間のみ変更                  *
      *---------------------------------------*
     C           GAMEN1    BEGSR
      * ﾎｧｰﾓnﾞ hﾒaｰ
     C                     MOVE *BLANK    @@TOKU
     C                     Z-ADD0         @@STHZ
     C                     Z-ADD0         @@ENHZ
      *
     C                     SETOF                     10
     C           @@KUBN    LOKUPTAB1      TAB2           10
     C   10                MOVE TAB2      @@KUNM
      *
     C           STEP3     TAG
     C                     EXFMTBBBPW102
     C                     MOVEA'0000'    *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVEL*BLANK    MSG
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *INKB     IFEQ '1'
     C                     GOTO STEP1
     C                     END
      * ﾎｧｰﾓnﾞ kｩｮh
     C                     MOVE @@TOKU    WWTOKU  40
     C           WWTOKU    IFEQ 0
     C                     SETON                     0199
     C                     MOVELER,5      MSG
     C                     GOTO STEP3
     C                     END
      *
     C                     SETOF                     20
     C           WWTOKU    CHAINFGBPL01              20
     C           *IN20     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,6      MSG
     C                     GOTO STEP3
     C                     END
      *
     C           WWTOKU    IFEQ 3166
     C           @@KOJO    ANDEQ*BLANK
     C                     SETON                     0499
     C                     MOVELER,16     MSG
     C                     GOTO STEP3
     C                     END
      *
     C           @@KUBN    IFEQ 'G'
     C           @@KUBN    OREQ 'S'
     C                     SETOF                     212223
     C           WWTOKU    CHAINBBEPL01              21
     C           *IN21     IFEQ '0'
     C           BESKJY    IFEQ 'D'
     C           BESKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C                     END
     C  N21                SETON                     23
     C           WWTOKU    CHAINBBEPL11              22
     C           *IN22     IFEQ '0'
     C           B@SKJY    IFEQ 'D'
     C           B@SKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     END
     C                     END
     C  N22                SETON                     23
     C*          *IN23     IFEQ '1'
     C*                    SETON                     0199
     C*                    MOVELER,7      MSG
     C*                    GOTO STEP3
     C*                    END
     C                     END
      *
     C           @@STYY    IFLE 89
     C                     SETON                     0299
     C                     MOVELER,8      MSG
     C                     GOTO STEP3
     C                     END
     C           @@STMM    IFLT 1
     C           @@STMM    ORGT 12
     C                     SETON                     0299
     C                     MOVELER,8      MSG
     C                     GOTO STEP3
     C                     END
     C           @@STDD    IFLT 1
     C           @@STDD    ORGT 31
     C                     SETON                     0299
     C                     MOVELER,8      MSG
     C                     GOTO STEP3
     C                     END
      *
     C           @@ENHZ    IFNE 99999999
     C           @@ENYY    IFLE 1989
     C                     SETON                     0399
     C                     MOVELER,8      MSG
     C                     GOTO STEP3
     C                     END
     C           @@ENMM    IFLT 1
     C           @@ENMM    ORGT 12
     C                     SETON                     0399
     C                     MOVELER,8      MSG
     C                     GOTO STEP3
     C                     END
     C           @@ENDD    IFLT 1
     C           @@ENDD    ORGT 31
     C                     SETON                     0399
     C                     MOVELER,8      MSG
     C                     GOTO STEP3
     C                     END
     C                     END
      *
     C           @@STHZ    IFGE @@ENHZ
     C                     SETON                     020399
     C                     MOVELER,9      MSG
     C                     GOTO STEP3
     C                     END
      *
     C  NKE                GOTO STEP3
      *
     C                     CALL 'BBBC11'
     C                     PARM           @@KUBN
     C                     PARM           @@TOKU
     C                     PARM           @@KOJO
     C                     PARM           @@STHZ
     C                     PARM           @@ENHZ
     C                     PARM           @@RIRN
      *
     C                     ENDSR
      *---------------------------------------*
      *   終了日付を延期　                  *
      *---------------------------------------*
     C           GAMEN2    BEGSR
      * ﾎｧｰﾓnﾞ hﾒaｰ
     C                     MOVE *BLANK    @@TOKU
     C                     Z-ADD0         @@ENHZ
      *
     C                     SETOF                     10
     C           @@KUBN    LOKUPTAB1      TAB2           10
     C   10                MOVE TAB2      @@KUNM
      *
     C           STEP4     TAG
     C                     EXFMTBBBPW103
     C                     MOVEA'0000'    *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVEL*BLANK    MSG
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *INKB     IFEQ '1'
     C                     GOTO STEP1
     C                     END
      * ﾎｧｰﾓnﾞ kｩｮh
     C                     MOVE @@TOKU    WWTOKU  40
     C           WWTOKU    IFEQ 0
     C                     SETON                     0199
     C                     MOVELER,10     MSG
     C                     GOTO STEP4
     C                     END
      *
     C                     SETOF                     20
     C           WWTOKU    CHAINFGBPL01              20
     C           *IN20     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,11     MSG
     C                     GOTO STEP4
     C                     END
      *
     C           WWTOKU    IFEQ 3166
     C           @@KOJO    ANDEQ*BLANK
     C                     SETON                     0499
     C                     MOVELER,16     MSG
     C                     GOTO STEP4
     C                     END
      *
     C           @@KUBN    IFEQ 'G'
     C           @@KUBN    OREQ 'S'
     C                     SETOF                     212223
     C           WWTOKU    CHAINBBEPL01              21
     C           *IN21     IFEQ '0'
     C           BESKJY    IFEQ 'D'
     C           BESKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C                     END
     C  N21                SETON                     23
     C           WWTOKU    CHAINBBEPL11              22
     C           *IN22     IFEQ '0'
     C           B@SKJY    IFEQ 'D'
     C           B@SKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     END
     C                     END
     C  N22                SETON                     23
     C*          *IN23     IFEQ '1'
     C*                    SETON                     0199
     C*                    MOVELER,12     MSG
     C*                    GOTO STEP4
     C*                    END
     C                     END
      *
     C           @@ENHZ    IFNE 99999999
     C           @@ENYY    IFLE 1989
     C                     SETON                     0299
     C                     MOVELER,13     MSG
     C                     GOTO STEP4
     C                     END
     C           @@ENMM    IFLT 1
     C           @@ENMM    ORGT 12
     C                     SETON                     0299
     C                     MOVELER,14     MSG
     C                     GOTO STEP4
     C                     END
     C           @@ENDD    IFLT 1
     C           @@ENDD    ORGT 31
     C                     SETON                     0299
     C                     MOVELER,14     MSG
     C                     GOTO STEP4
     C                     END
     C                     END
      *
     C  NKE                GOTO STEP4
     C                     CALL 'BBBC12'
     C                     PARM           @@KUBN
     C                     PARM           @@TOKU
     C                     PARM           @@KOJO
     C                     PARM           @@ENHZ
      *
     C                     ENDSR
      *
**  (TAB1/TAB2)
GG->VOL PROD
RR->EXCEPTION
SS->VOL PROD/EXCP
**  MSG
E-01 INPUT VOLUME PRODUCTION EXCEPTION INSTRUCTION
E-02 VOLUME PRODUCTION EXCEPTION INSTRUCTION ISN'T RIGHT
E-03 INPUT UPDATE TABLE HANDLING CODE
E-04 UPDATE TABLE HANDLING CODE ISN'T RIGHT
E-05 INPUT CUSTOMER CODE
E-06 CUSTOMER CODE ISN'T RIGHT
E-07 IT PROCESS WITH COMMUNICATION ABOUT THIS HANDLING
E-08 APPOINTED DATE ISN'T RIGHT
E-09 APPOINTED DATE ISN'T RIGHT
E-10 INPUT CUSTOMER CODE
E-11 CUSTOMER CODE ISN'T RIGHT
E-12 IT PROCESS WITH COMMUNICATION ABOUT THIS HANDLING
E-13 APPOINTED DATE ISN'T RIGHT
E-14 APPOINTED DATE ISN'T RIGHT
E-15 HANDLING INSTRUCTION (0.R)
E-16 IN THE CASE OF CUSTOMER 3166, INPUT FACTORY
