     C*
     C*==< SKIP >==*
I----C           T6SKJY    IFEQ 'D'
|    C           T6SKHZ    ANDLE*DATE
|    C                     GOTO #CQ121
E----C                     ENDIF
      *
     C                     SELEC
     C           D#3KT3    WHEQ 'U'
     C           D#3KT3    OREQ '4'
     C           T6KAT3    IFNE 'U'
     C           T6KAT3    ANDNE'4'
     C                     GOTO #CQ121
     C                     ENDIF
     C                     OTHER
     C           T6KAT3    IFEQ 'U'
     C           T6KAT3    OREQ '4'
     C                     GOTO #CQ121
     C                     ENDIF
     C                     ENDSL
      *
     C*
     C           #CQ12E    ENDSR
     C*****************************************************
     C*  #EDT4   EDIT SCREEN(4)                           *
     C*****************************************************
     C           #EDT4     BEGSR
     C*
     C*==< INITIALIZE ITEMS >==*
     C                     MOVEL*BLANK    W@LOC@
     C                     MOVELD#3TR1    W@LOC1
     C                     MOVELD#3TR2    W@LOC2
     C                     MOVELD#3TR3    W@LOC3
     C                     MOVELD#3TR4    W@LOC4
     C                     MOVELD#3TR5    W@LOC5
I----C           D#3TR2    IFNE *BLANK
|    C                     MOVEL'-'       W@LOH2
E----C                     ENDIF
I----C           D#3TR3    IFNE *BLANK
|    C                     MOVEL'-'       W@LOH3
E----C                     ENDIF
I----C           D#3TR4    IFNE *BLANK
|    C                     MOVEL'-'       W@LOH4
E----C                     ENDIF
I----C           D#3TR5    IFNE *BLANK
|    C                     MOVEL'-'       W@LOH5
E----C                     ENDIF
     C                     MOVELW@LOC@    D#LOC@
     C*
     C                     MOVEL*BLANK    D#BAR4
     C                     MOVEL*BLANK    D#EMSG
     C*
     C*==< NEXT PROCESSING >==*
