      *
I----C           *IN92     IFEQ '1'
|    C                     MOVEL@ER,11    D#EMSG
|    C                     EXSR #DSP9
|    C                     MOVEL'EDT3'    S@PROC
|    C                     GOTO #CHK3E
E----C                     ENDIF
     C*
