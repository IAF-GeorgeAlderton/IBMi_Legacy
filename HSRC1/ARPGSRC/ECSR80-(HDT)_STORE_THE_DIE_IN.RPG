     C*****************************************************
     C*  #DATA   ECSPP80 RECORD OUTPUT                    *
     C*          ECSPP10 RECORD UPDATE                    *
     C*****************************************************
     C           #DATA     BEGSR
     C*
     C*==< ECSPP20 (OK) >==*
     C                     CLEARECSPP201
     C                     Z-ADDS@YMD     E2KDAT
     C                     Z-ADDS@HMS     E2KTIM
     C                     MOVELP@TAC5    E2KOME
     C                     MOVEL'ECSR80'  E2KPGM
     C                     MOVELS@1KT1    E2KAT1
     C                     MOVELS@1KT2    E2KAT2
     C           S@1KT3    IFEQ '4'
     C                     MOVEL'U'       E2KAT3
     C                     ELSE
     C                     MOVELS@1KT3    E2KAT3
     C                     END
     C                     MOVELS@1KT4    E2KAT4
     C                     Z-ADDS@YMD     E2DATE
     C                     MOVEL*BLANK    E2ISNO
     C                     Z-ADDT6SYOS    E2WQTY
     C                     MOVEL'1'       E2WHID
     C*                    _____________
     C                     WRITEECSPP201
     C*                    ~~~~~~~~~~~~~
     C*==< ECSPP80 (OK) >==*
     C                     CLEARECSPL811
     C                     Z-ADD0111      E8BMON            FACTORY CODE
     C                     MOVEL*BLANK    E8KIBN            MACHINE NO
     C                     MOVEL*BLANK    E8RIYU            IN/OUT REASON
     C                     MOVELS@1KT1    E8KAT1            DIE NO.1
     C                     MOVELS@1KT2    E8KAT2            DIE NO.2
     C                     MOVELS@1KT4    E8KAT3            DIE NO.3
     C           S@1KT3    IFEQ 'U'
     C                     MOVEL'4'       E8KAT4            DIE NO.4
     C                     ELSE
     C                     MOVELS@1KT3    E8KAT4            DIE NO.4
     C                     END
     C                     MOVELD#3TR1    E8TKR1            LOCATION (FACTORY)
     C                     MOVELD#3TR2    E8TKR2            LOCATION (PASSAGE)
     C                     MOVELD#3TR4    E8TKR3            LOCATION (LINE)
     C                     MOVELD#3TR3    E8TKR4            LOCATION (STAIR)
     C                     MOVELD#3TR5    E8TKR5            LOCATION (STAIR)
     C                     Z-ADDT6SYOS    E8KOSU            IN/OUT QUANTITY
     C                     MOVEL'I'       E8IOKB            IN/OUT FLG
     C                     MOVEL'H'       E8GSKB            GENERATION SOURCE
     C                     Z-ADDS@YMD     E8IOHZ            IN/OUT DATE
     C                     Z-ADDS@HMS     E8IOJK            IN/OUT TIME
     C                     MOVELP@TAC5    E8IOME            IN/OUT WORKER
     C                     MOVEL*BLANK    E8OREQ            OUT REQUESTER
     C                     MOVEL'OK'      E8HNTE            JUDGMENT
     C                     MOVEL*BLANK    E8EMSG            ERR MSG
     C                     MOVELD#BAR1    E8PBAR            PT BARCODE
     C                     MOVELD#BAR2    E8SBAR            S/OUT LABEL BARCODE
     C                     MOVELD#BAR3    E8LBAR            LOCATION BARCODE
     C                     MOVELD#BAR4    E8DBAR            DIE KANBAN BARCODE
     C*                    _____________
     C                     WRITEECSPL811
     C*                    ~~~~~~~~~~~~~
     C*==< ECSPP10 >==*
     C                     MOVELS@1KT1    K@KAT1            DIE#1
     C                     MOVELS@1KT2    K@KAT2                2
     C           S@1KT3    IFEQ '4'
     C                     MOVEL'U'       K@KAT3                3
     C                     ELSE
     C                     MOVELS@1KT3    K@KAT3                3
     C                     END
     C*                    MOVELS@1KT4    K@KAT4                4
     C                     MOVEL*BLANK    K@KAT4                4
     C*                    ____________
     C           K@CS10    CHAINECSPL10              93
     C*                    ~~~~~~~~~~~~
I----C           *IN93     IFEQ '1'
|    C           *IN93     OREQ '0'
|    C           E1SKJY    ANDEQ'D'
|    C                     CLEARECSPP101
|    C                     MOVELS@1KT1    E1KAT1            DIE#1
|    C                     MOVELS@1KT2    E1KAT2                2
|    C           S@1KT3    IFEQ '4'
|    C                     MOVEL'U'       E1KAT3                3
|    C                     ELSE
|    C                     MOVELS@1KT3    E1KAT3                3
|    C                     END
|    C*--                  MOVELS@1KT4    E1KAT4                4
|    C                     MOVELD#3TR1    E1LOC1            LOCATION 1
|    C                     MOVELD#3TR2    E1LOC2                     2
|    C                     MOVELD#3TR3    E1LOC3                     3
|    C                     MOVELD#3TR4    E1LOC4                     4
E----C                     ENDIF
     C*
     C                     Z-ADDS@YMD     E1KDAT            UPDATE DATE
     C                     Z-ADDS@HMS     E1KTIM            UPDATE TIME
     C                     MOVELP@TAC5    E1KOME            UPDATE USER
     C                     MOVEL@@PGID    E1KPGM            UPDATE PGM
     C                     Z-ADD*DATE     E1INDT            LATEST IN DATE
     C                     ADD  T6SYOS    E1SQTY            CURRENT INVENTORY
     C*                    _____________
     C  N93                UPDATECSPP101
     C   93                WRITEECSPP101
     C*                    ~~~~~~~~~~~~~
     C*==< NEXT PROCESSING >==*
     C                     MOVEL'EDT1'    S@PROC
     C*
     C           #DATAE    ENDSR
