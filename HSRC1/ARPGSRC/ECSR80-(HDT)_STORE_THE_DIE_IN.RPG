     C                     TIME           S@TIME
     C*
     C*==< NEXT PROCESSING >==*
S----C                     SELEC
+----C           *IN01     WHEQ '1'                        < F1 >
|    C                     MOVEL'EDT3'    S@PROC
|    C*
+----C           *IN02     WHEQ '1'                        < F2 >
|    C           *IN03     OREQ '1'                        < F3 >
|    C           *IN04     OREQ '1'                        < F4 >
|    C           *IN05     OREQ '1'                        < F5 >
|    C           *IN06     OREQ '1'                        < F6 >
|    C           *IN07     OREQ '1'                        < F7 >
|    C           *IN08     OREQ '1'                        < F8 >
|    C           *IN09     OREQ '1'                        < F9 >
|    C           *IN10     OREQ '1'                        < F10 >
|    C           *IN11     OREQ '1'                        < F11 >
|    C           *IN12     OREQ '1'                        < F12 >
|    C           *IN13     OREQ '1'                        < F13 >
