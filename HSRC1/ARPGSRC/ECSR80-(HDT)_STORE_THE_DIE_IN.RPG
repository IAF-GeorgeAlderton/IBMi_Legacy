     C*==< SKIP >==*
I----C           T6SKJY    IFEQ 'D'
|    C           T6SKHZ    ANDLE*DATE
|    C                     GOTO #CQ111
E----C                     ENDIF
     C*
I----C*          T6KSHK    IFNE D#4KSH
|    C*                    GOTO #CQ111
E----C*                    ENDIF
     C*
