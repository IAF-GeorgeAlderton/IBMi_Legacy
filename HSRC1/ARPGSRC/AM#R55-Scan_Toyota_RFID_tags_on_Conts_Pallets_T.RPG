     H            Y.
     F** AM#R55 *********************************************
     F* SCAN TOYOTA RFID TAGS ON CONTS, PALLETS, TOP CAPS   *
     F*    LEC.             2020.02.07                      *
     F*******************************************************
     FAM#PW55 CF  E                    WORKSTN
     FAM#PP55 UF  E           K        DISK                      A
     FALBPL30 IF  E           K        DISK
     E                    ER      1   3 65
      *
     I            DS
     I I            'Container'               1  10 CNT
     I I            'Pallet   '              11  20 PAL
     I I            'Top Cap  '              21  30 TOP
      *
     I            DS
     I I            'All 4 Sides'             1  15 SIDES4
     I I            'Both Sides'             16  30 SIDES2
      *
     I            DS
     I                                        1  12 BAR01
     I                                        1   6 LTYPE
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     C           #SB100    BEGSR
      *
     C                     MOVELWORKER    WKCD    60
     C           WKCD      CHAINALBPL30              55
     C           *IN55     IFEQ *OFF
     C                     MOVELALWKNM    RFUSNM
     C                     ELSE
     C                     MOVELWUSRID    RFUSNM
     C                     ENDIF
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVELWORKER    USRCD   6
     C                     CLEARBAR01
      *
     C                     ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C           #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *⒳�痧���瘏�胭ⓓ��灎獐�獐▓�胕�鯐沴�►��
      *----------------------------------------------------*
     C           #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C           *IN03     IFEQ *ON
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           BAR01     IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     CLEARBAR01
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           LTYPE     IFNE 'T11001'
     C           LTYPE     ANDNE'T14001'
     C           LTYPE     ANDNE'T15001'
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     CLEARBAR01
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           BAR01     CHAINAM#PP55              50
     C           *IN50     IFEQ *OFF
     C           RFSKJY    ANDEQ'D'
     C                     MOVE *ON       *IN50
     C                     ENDIF
      *
     C           *IN50     IFEQ *OFF
     C                     SETON                     3199
     C                     MOVELER,3      MSG
     C                     EXSR #SB999
     C                     CLEARBAR01
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     CLEARDSP02
      *
     C                     SELEC
     C           LTYPE     WHEQ 'T11001'
     C                     MOVELCNT       D2LBTY
     C                     MOVELSIDES2    D2LBL#
     C                     Z-ADD2         SIDES   10
     C           LTYPE     WHEQ 'T14001'
     C                     MOVELPAL       D2LBTY
     C                     MOVELSIDES4    D2LBL#
     C                     Z-ADD4         SIDES
     C           LTYPE     WHEQ 'T15001'
     C                     MOVELTOP       D2LBTY
     C                     MOVELSIDES4    D2LBL#
     C                     Z-ADD4         SIDES
     C                     ENDSL
      *
     C                     MOVELBAR01     D2LBID
     C                     Z-ADDSIDES     D2TOTS
     C                     Z-ADD1         D2TLSD
      *
     C                     MOVEL'02'      DSPSW   2
      *
     C           ESB210    ENDSR
      *----------------------------------------------------*
      *獝Ⓡ鯐�⒳�痧���濰��黬胕胕�鯐沴鰪　　　　　�
      *----------------------------------------------------*
     C           #SB220    BEGSR
      *
     C                     CLEARBAR02
     C                     EXFMTDSP02
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C           *IN03     IFEQ *ON
     C                     CLEARBAR01
     C                     MOVEL'01'      DSPSW   2
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           BAR02     IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           BAR02     IFNE BAR01
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     EXSR #SB999
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     ADD  1         D2TLSD
      *
     C           D2TLSD    IFLT SIDES
     C                     GOTO ESB220
     C                     ENDIF
      *
      * OK
     C                     EXSR #SB500
     C                     EXFMTDSP03
      *
     C                     CLEARBAR01
     C                     MOVEL'01'      DSPSW   2
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     C           ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     C           #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     C           ESB300    ENDSR
      *----------------------------------------------------*
      * WRITE TO AM#PP55                                   *
      *----------------------------------------------------*
     C           #SB500    BEGSR
      *
     C                     TIME           WTIME
     C                     CLEARAM#PP551
     C                     Z-ADDSDATE     RFSSHZ
     C                     Z-ADDSTIME     RFSSTI
     C                     MOVELWORKER    RFUSCD
     C                     MOVELBAR01     RFBAR
     C                     MOVELD2LBTY    RFLBTY
     C                     WRITEAM#PP551
      *
     C           ESB500    ENDSR
      *----------------------------------------------------*
      * ERROR                                              *
      *----------------------------------------------------*
     C           #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     C           ESB999    ENDSR
**
INVALID LABEL
LABEL DOESN'T MATCH.
ALREADY SCANNED.
