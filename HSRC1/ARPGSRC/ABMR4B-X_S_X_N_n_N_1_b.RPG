     H            Y.
     F** ABMR4B *********************************************
     F*材料の確定設定数　ＮとＮ＋１の多い方（月当りで返す）
     F*    HOTTA.               2018.10.24                  *
     F*******************************************************
     FIZAPL10 IF  E           K        DISK
     FABMPL21 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80ZBSKHZ
     I                                        1   40ZBSKYY
     I                                        5   60ZBSKMM
     I                                        7   80ZBSKDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@ZAIS 15
     C                     PARM           P@ZAIK  52
     C                     PARM           P@KOJE  40
     C                     PARM           P@KAKE  40
     C                     PARM           P@MSJR 150
     C                     PARM           P@MKJR 150
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     Z-ADDP@DTYM    K@NTYM
     C                     Z-ADD0         P@MSJR
     C                     Z-ADD0         P@MKJR
      *
     C           KEYZB1    KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     KFLD           K@KOJE  40
     C                     KFLD           K@KAKE  40
     C                     MOVELP@ZAIS    K@ZAIS
     C                     Z-ADDP@ZAIK    K@ZAIK
     C                     Z-ADDP@KOJE    K@KOJE
     C                     Z-ADDP@KAKE    K@KAKE
     C                     Z-ADD0         @@MSJR 150
     C                     Z-ADD0         @@MKJR 150
      *
     C           KEYZB1    SETLLIZAPL101
     C           KEYZB1    READEIZAPL101                 75
     C           *IN75     DOWEQ'0'
     C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB100
     C                     ENDIF
     C           KEYZB1    READEIZAPL101                 75
     C                     ENDDO
      *
     C                     Z-ADD@@MSJR    P@MSJR
     C                     Z-ADD@@MKJR    P@MKJR
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      *内示
      *---------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     Z-ADD0         @BGEKN  90
     C                     Z-ADD0         @CGEKN  90
     C           KEYFCE    KLIST
     C                     KFLD           ZBSHN1
     C                     KFLD           ZBSHN2
     C                     KFLD           ZBSHN3
     C           KEYFCE    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     Z-ADDA2GEKN    @BGEKN
     C                     Z-ADDA2GEKN    @CGEKN
     C                     ENDIF
      *
     C           KEYFC1    KLIST
     C                     KFLD           K@NTYM  60
     C                     KFLD           ZBSHN1
     C                     KFLD           ZBSHN2
     C                     KFLD           ZBSHN3
     C           KEYFC1    CHAINABMPL211             25
     C           *IN25     IFEQ '0'
     C           S4SKJY    ANDEQ'D'
     C           S4SKHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C           S4OMIT    IFEQ '0'
     C                     Z-ADD0         @BGEKN  90
     C           S4NSRD    MULT 20        @CGEKN  90
     C           S4NSRD    IFGT S4FSD1
     C           S4NSRD    MULT 20        @BGEKN
     C                     ELSE
     C           S4FSD1    MULT 20        @BGEKN
     C                     ENDIF
     C                     ENDIF
     C           @CGEKN    MULT ZBSOZI    $$MSJR 150
     C           $$MSJR    DIV  1000      @BMSJR  80H
     C                     ADD  @BMSJR    @@MSJR
     C           @BGEKN    MULT ZBSOZI    $$MKJR 150
     C           $$MKJR    DIV  1000      @BMKJR  80H
     C                     ADD  @BMKJR    @@MKJR
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
