     C           *ENTRY    PLIST
     C                     PARM           TVMENT  1
     C                     MOVE TVMENT    MENT    1
     C*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C           MENT      IFEQ '2'
     C                     EXCPTCLR
     C                     END
     C                     END
     C*
     C           J1SKJY    IFEQ 'D'
     C                     GOTO END
     C                     END
     C****************************************
     C*ＦＡの品番がメッキに無い時ＦＡを削除*
     C****************************************
     C           KEY1      KLIST
     C                     KFLD           J1SHN1
     C                     KFLD           J1SHN2
     C                     KFLD           J1SHN3
     C********************************************************
     C*メッキかんばんからＦＡマスターの未使用品番をチェック*
     C********************************************************
     C           KEY1      SETLLAAFTL061
     C                     SETOF                     10
     C           MELOOP    TAG
     C           KEY1      READEAAFTL061                 10
     C           *IN10     IFEQ '1'
     C                     MOVE 'D'       J1SKJY
     C                     Z-ADD*YEAR     J1SKYY
     C                     Z-ADDUMONTH    J1SKMM
     C                     Z-ADDUDAY      J1SKDD
     C                     MOVEL'AJSR17'  J1KOME
     C                     MOVE '0'       J1MENT
     C                     UPDATAJSPL011
     C                     GOTO END
     C                     ELSE
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    IFLE *DATE
     C                     GOTO MELOOP
     C                     END
     C                     END
     C                     END
TCHK1C*
TCHK1C           A3KCD1    IFEQ 'C'
TCHK1C           A3KCD2    ANDEQ'A'
TCHK1C                     ELSE
TCHK1C                     GOTO MELOOP
TCHK1C                     END
     C*有効日・失効日のチェック*
     C           A3UKHZ    IFLE *DATE
     C           A3STHZ    ANDGT*DATE
     C                     ELSE
     C                     GOTO MELOOP
     C                     END
     C*メッキかんばんマスターに有りの時ＯＫ*
     C                     GOTO OK
      *
     C**********************************************************
     C*トンネルかんばんからＦＡマスターの未使用品番をチェック*
     C**********************************************************
     C*          MEEND     TAG
     C*          KEY1      SETLLAAGTL061
     C*                    SETOF                     10
     C*          TOLOOP    TAG
     C*          KEY1      READEAAGTL061                 10
     C*          *IN10     IFEQ '1'
     C*                    GOTO TOEND
     C*                    ELSE
     C*          O4SKJY    IFEQ 'D'
     C*          O4SKHZ    IFLE *DATE
     C*                    GOTO TOLOOP
     C*                    END
     C*                    END
     C*                    END
     C*有効日・失効日のチェック*
     C*          O4UKHZ    IFLE *DATE
     C*          O4STHZ    ANDGT*DATE
     C*                    ELSE
     C*                    GOTO TOLOOP
     C*                    END
     C*トンネルかんばんマスターに有りの時ＯＫ*
     C*                    GOTO OK
     C**********************************************************
     C*ＡＲＲＳマスターからＦＡマスターの未使用品番をチェック*
     C**********************************************************
     C*          TOEND     TAG
     C*          KEY1      SETLLOABPL011
     C*                    SETOF                     10
     C*          ARSLOP    TAG
     C*          KEY1      READEOABPL011                 10
     C*          *IN10     IFEQ '1'
     C*                    GOTO ARSEND
     C*                    ELSE
     C*          OBSKJY    IFEQ 'D'
