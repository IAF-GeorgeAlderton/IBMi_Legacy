      *************************************************************
      *  MAIN
      *************************************************************
      * INITIALIZE
     C                     EXSR #INIT
      * DISPLAY
     C           W@ID      DOWEQ'01'
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN43
     C                     MOVE *OFF      *IN44
      * F1/3 END
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '99'      W@ID
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
      * NO ERROR & F5
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #INQ
     C           RC@CNT    IFEQ 0
     C                     MOVELMSG,8     XMSG
     C                     ENDIF
      * END JOB
     C***        XASN      IFNE *BLANK
     C***                  MOVE '99'      W@ID
     C***                  ENDIF
     C                     ENDIF
      * NO ERROR & NOT F5
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*OFF
     C                     MOVELMSG,5     XMSG
     C                     ENDIF
      *
     C                     ENDDO
      * FOOT
     C           XASN      IFNE *BLANK
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *          CHECK DATA
      *-----------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
      * SHIP DATE OR ASN#
     C           XFROM     IFNE *BLANK
     C           XAFROM    ANDNE0
     C           XFROM     ORNE *BLANK
     C           XATO      ANDNE0
     C           XTO       ORNE *BLANK
     C           XAFROM    ANDNE0
     C           XTO       ORNE *BLANK
     C           XATO      ANDNE0
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN43
     C                     MOVE *ON       *IN44
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,14    XMSG
     C                     GOTO E#CHK1
     C                     ENDIF
      *
     C           XFROM     IFEQ *BLANK
     C           XAFROM    ANDEQ0
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,1     XMSG
     C                     GOTO E#CHK1
     C                     ENDIF
      *
     C           XFROM     IFNE *BLANK
     C                     EXSR #CHK11
     C                     ENDIF
      *
     C           XAFROM    IFNE 0
     C                     EXSR #CHK12
     C                     ENDIF
      *
     C           E#CHK1    ENDSR
      *-----------------------------------------------------------
      * CHECK SHIP DATE
      *-----------------------------------------------------------
     C           #CHK11    BEGSR
      * VALIDATE DATE FROM
     C                     MOVELXFROM     $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE2    XFROM
     C                     MOVEL$TRUE1    #FROM   80
     C                     ELSE
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,2     XMSG
     C                     GOTO XCHK11
     C                     ENDIF
      *
     C           XTO       IFEQ *BLANK
     C                     MOVELXFROM     XTO
     C                     ENDIF
      * VALIDATE DATE TO
     C           XTO       IFEQ '99999999'
     C           XTO       OREQ MSG,13
     C                     MOVELMSG,7     XTO
     C                     ELSE
     C                     MOVELXTO       $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE2    XTO
     C                     MOVEL$TRUE1    #TO     80
     C                     ELSE
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,4     XMSG
     C                     GOTO XCHK11
     C                     ENDIF
     C                     ENDIF
      * COMPARE
     C           XFROM     IFGT XTO
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,6     XMSG
     C                     GOTO XCHK11
     C                     ENDIF
      * IF NO ERROR..
     C                     MOVELMSG,16    XBY
     C                     MOVE *OFF      *IN49
      *
     C           XCHK11    ENDSR
      *-----------------------------------------------------------
      * CHECK ASN#
      *-----------------------------------------------------------
     C           #CHK12    BEGSR
      *
     C           XATO      IFEQ 0
     C                     Z-ADDXAFROM    XATO
     C                     ENDIF
      *
     C           XAFROM    IFGT XATO
     C                     MOVE *ON       *IN43
     C                     MOVE *ON       *IN44
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,15    XMSG
     C                     GOTO XCHK12
     C                     ENDIF
      * IF NO ERROR...
     C                     MOVELXAFROM    #AFROM  8
     C                     MOVELXATO      #ATO    8
     C                     MOVELMSG,17    XBY
     C                     MOVE *ON       *IN49
      *
     C           XCHK12    ENDSR
      *-----------------------------------------------------------
      *                    ASN INQUIRY
      *-----------------------------------------------------------
     C           #INQ      BEGSR
      * SET DATA
     C           XFROM     IFNE *BLANK
     C                     EXSR #SET1
     C                     ELSE
     C                     EXSR #SET2
     C                     ENDIF
      *
     C                     MOVE *OFF      *INKL
     C                     MOVELMSG,9     XMSG
      *
     C           RC@CNT    IFEQ 0
     C                     GOTO EINQ
     C                     ENDIF
      *
     C                     DO   *HIVAL
      * DISPLAY SFL
     C                     WRITEDSP99
     C                     MOVE *ON       *IN70
     C                     EXFMTSFLCTL
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN99
     C                     MOVE *OFF      *IN70
      *
     C                     SELEC
      * F10 PRINT
     C**         *INKJ     WHEQ *ON
     C**                   EXSR #CHK2
     C**         *IN86     IFEQ *ON
     C**                   MOVELMSG,10    XMSG
     C**                   ELSE
     C**                   EXSR #DTL
     C**                   ENDIF
      * F12
     C           *INKA     WHEQ *ON
     C           *INKL     OREQ *ON
     C                     LEAVE
      * ENTR
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN86     IFEQ *ON
     C                     MOVELMSG,10    XMSG
     C                     ENDIF
     C           *IN86     IFEQ *OFF
     C           X@CNT     ANDNE0
     C                     MOVELMSG,12    XMSG
     C                     ENDIF
      *
     C                     ENDSL
     C                     ENDDO
      *
     C           EINQ      ENDSR
      *-----------------------------------------------------------
      *                    SET INQUIRY DATA (BY SHIP DATE)
      *-----------------------------------------------------------
     C           #SET1     BEGSR
      * CLEAR SUBFILE
     C           RRN       IFEQ 0
     C                     Z-ADD1         RRN
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     MOVE *ON       *IN71
     C                     WRITESFLCTL
     C                     MOVE *OFF      *IN71
      * GET DATA
     C                     Z-ADD0         RRN
     C                     Z-ADD1800      MAX#    40
     C                     MOVE *OFF      *IN51   1
     C           #FROM     SETLLJCMPL12
     C           *IN51     DOWEQ*OFF
     C                     READ JCMPL12                  51
     C           *IN51     IFEQ *OFF
      * END?
     C           J1NOHZ    IFGT #TO
     C                     MOVE *ON       *IN51
     C                     LEAVE
     C                     ENDIF
      * END?
     C           RRN       IFGE MAX#
     C                     MOVE *ON       *IN51
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         RRN
     C                     MOVE *OFF      *IN51
     C                     MOVE *BLANK    H@SEL
     C                     MOVE *BLANK    S@SEL
     C                     Z-ADDJ1DATE    S@ISSU
     C                     Z-ADDJ1TIME    S@TIME
     C                     Z-ADDJ1NOHZ    S@SHDT
     C                     MOVELJ1NONY    S@NONY
     C                     MOVELJ1BIN     S@BIN
     C                     MOVELJ1ASN#    S@ASN
     C                     MOVELJ1NKOJ    S@FACT
     C                     MOVELJ1NUKE    S@DOCK
     C                     MOVELJ1PSCC    S@SCAC
     C                     MOVELJ1SMEI    S@NAME
     C                     MOVELJ1SHID    S@SHID
     C                     Z-ADDJ1BOX     S@BOX
      *
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN       RC@CNT  60
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *                    SET INQUIRY DATA (ASN)
      *-----------------------------------------------------------
     C           #SET2     BEGSR
      * CLEAR SUBFILE
     C           RRN       IFEQ 0
     C                     Z-ADD1         RRN
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     MOVE *ON       *IN71
     C                     WRITESFLCTL
     C                     MOVE *OFF      *IN71
      * GET DATA
     C                     Z-ADD0         RRN
     C                     Z-ADD1800      MAX#    40
     C                     MOVE *OFF      *IN51   1
     C           #AFROM    SETLLJCMPL11A
     C           *IN51     DOWEQ*OFF
     C                     READ JCMPL11A                 51
     C           *IN51     IFEQ *OFF
      * END?
     C           J1ASN#    IFGT #ATO
     C                     MOVE *ON       *IN51
     C                     LEAVE
     C                     ENDIF
      * END?
     C           RRN       IFGE MAX#
     C                     MOVE *ON       *IN51
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         RRN
     C                     MOVE *OFF      *IN51
     C                     MOVE *BLANK    H@SEL
     C                     MOVE *BLANK    S@SEL
     C                     Z-ADDJ1DATE    S@ISSU
     C                     Z-ADDJ1TIME    S@TIME
     C                     Z-ADDJ1NOHZ    S@SHDT
     C                     MOVELJ1NONY    S@NONY
     C                     MOVELJ1BIN     S@BIN
     C                     MOVELJ1ASN#    S@ASN
     C                     MOVELJ1NKOJ    S@FACT
     C                     MOVELJ1NUKE    S@DOCK
     C                     MOVELJ1PSCC    S@SCAC
     C                     MOVELJ1SMEI    S@NAME
     C                     MOVELJ1SHID    S@SHID
      *
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN       RC@CNT  60
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *                    SET DETAIL INQUIRY DATA
      *-----------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD0         X@CNT   40
     C                     MOVE *BLANK    XASN    8
     C                     MOVE *OFF      *IN86
      *
     C           1         DO   RC@CNT    RRN
     C           RRN       CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C**         S@SEL     IFNE 'X'
     C           S@SEL     IFEQ *BLANK
     C                     MOVE 'H'       H@SEL
     C                     MOVE *ON       *IN51
     C                     MOVE *ON       *IN86
     C                     ELSE
     C                     MOVE ' '       H@SEL
     C                     MOVE *OFF      *IN51
     C           S@SEL     IFNE ' '
      * DISPLAY DETAIL
     C                     EXSR #DTL
      *
     C                     ADD  1         X@CNT
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE ' '       S@SEL
     C                     UPDATSFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *          PRINT ASN
      *-----------------------------------------------------------
     C           #DTL      BEGSR
      *
     C           K#11A     CHAINJCMPL11A             99
     C   99                GOTO XDTL
      *
     C                     MOVELJ1NONY    X1NONY
     C                     MOVELJ1CTEL    X1CTEL
     C                     MOVELJ1BIN     X1BIN
     C**                   MOVELJ1PICK    X1PICK
     C                     MOVELJ1BLN#    X1BLN#
     C                     Z-ADDJ1BOX     X1BOX
     C                     MOVELJ1CRME    X1CRME
     C                     MOVELJ1CRME    $USER
     C                     CALL 'UTLR31'
     C                     PARM           $USER  10
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     X1CRNM
      * PACKING LIST#
     C                     MOVELJ1NOHZ    $NOHZ
     C                     MOVEL'5149'    $CUST
     C                     MOVELJ1NONY    $NONY
     C                     MOVELJ1NKOJ    $NKOJ
     C                     MOVELJ1NUKE    $NUKE
     C                     MOVELJ1BIN     $BINN
     C                     MOVELJ1REHZ    $RLHZ
     C                     MOVEL'11111'   $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C           $PICK#    IFNE *BLANK
     C                     MOVEL$PICK#    X1PICK
     C                     ELSE
     C                     EXSR #PICK2
     C                     MOVEL$PICK#    X1PICK
     C                     ENDIF
      * PART#
     C           1         DO   12        IX      20
     C                     MOVELMSG,18    MHN,IX
     C                     ENDDO
      *
     C                     MOVE '0'       RFLG
     C                     Z-ADD0         QTY
     C                     Z-ADD0         CUM
     C                     Z-ADD0         BOX
     C                     MOVE *BLANK    XMORE
     C           J1SHID    SETLLJCMPP12
     C           1         DO   13        IX
     C           J1SHID    READEJCMPP12                  97
     C   97                LEAVE
      *
     C           IX        IFEQ 13
     C                     MOVEL'(+MORE)' XMORE
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELJ2MHIN    MHN,IX
     C                     Z-ADDJ2SRYO    QTY,IX
     C                     Z-ADDJ2CUMQ    CUM,IX
     C                     Z-ADDJ2BOX#    BOX,IX
      * CHECK RETURNABLE
     C           RFLG      IFNE 'Y'
     C           'ST8'     SCAN J2MHIN                   10
     C           *IN10     IFEQ *ON
     C                     MOVE 'Y'       RFLG
     C                     ELSE
     C                     MOVE 'N'       RFLG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
JW1  C           LFLG      IFEQ 'Y'
 .   C                     MOVEL@@LID     X1PACK           PLT90
 .   C                     ELSE
 .   C                     MOVEL@@PLT     X1PACK           BOX90
 .   C                     ENDIF
 .    *
     C                     SELEC
 .   C           RFLG      WHEQ 'Y'
 .   C                     MOVEL@@RET     X1CONT           RETURNABLE
 .   C           RFLG      WHEQ 'N'
 .   C                     MOVEL@@BOX     X1CONT           FORD BOX
 .   C                     OTHER
 .   C                     MOVEL@@NOT     X1CONT           NOT FOUND
JW1  C                     ENDSL
      * REVERSE GROSS WGT
     C           J1WHT     IFEQ 0
     C                     MOVE *ON       *IN31
     C                     ELSE
     C                     MOVE *OFF      *IN31
     C                     ENDIF
      * REVERSE CONTAINE
     C           RFLG      IFEQ '0'
     C                     MOVE *ON       *IN32
     C                     ELSE
     C                     MOVE *OFF      *IN32
     C                     ENDIF
      *
     C                     EXFMTDSP02
      *
     C           XDTL      ENDSR
      *-----------------------------------------------------------
      * GET PACKING LIST# (2)
      *-----------------------------------------------------------
     C           #PICK2    BEGSR
      *
     C                     MOVELJ1REHZ    $NOHZ            RELEASE DATE
     C                     MOVEL'5149'    $CUST
     C                     MOVELJ1NONY    $NONY
     C                     MOVELJ1NKOJ    $NKOJ
     C                     MOVELJ1NUKE    $NUKE
     C                     MOVELJ1BIN     $BINN
     C                     MOVELJ1REHZ    $RLHZ
     C                     MOVEL'11111'   $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *          INITIALIZE
      *-----------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K#11A     KLIST
     C                     KFLD           S@ASN
     C                     KFLD           S@SHID
      *
     C                     Z-ADD0         RRN     50
     C                     MOVE '01'      W@ID    2
     C                     TIME           @TIME
      *
     C                     MOVELTODAY     XFROM
     C                     MOVELTODAY     XTO
     C                     MOVE 'N'       RFLG    1        RET FLG
     C                     MOVE 'N'       LFLG    1        LID FLG
      *
     C                     ENDSR
** MSG(50A)........2.........3.........4.........5
ENTER SHIP DATE(FROM)!                              01
SHIP DATE(FROM) NOT FOND IN CALENDAR MASTER!        02
                                                    03
SHIP DATE(TO) NOT FOND IN CALENDAR MASTER!          04
PRESS F5 TO GO TO INQUIRY SCREEN...                 05
SHIP DATE(TO) SHOULD BE GREATER THAN DATE(FROM)!    06
9999/99/99                                          07
NO RECORD!                                          08
ENTER "X" FOR ASN DETAIL...                         09
ENTER "X" FOR ASN DETAIL...                         10
J-COM DATA CREATED...                               11
                                                    12
9999/99/99                                          13
ENTER SHIP DATE OR ASN#!                            14
ASN(TO) SHOULD BE GREATER THAN ASN(FROM)!           15
(BY SHIP DATE)                                      16
  (BY ASN)                                          17
- - - - - - - - - - -                               18
                                                    19
