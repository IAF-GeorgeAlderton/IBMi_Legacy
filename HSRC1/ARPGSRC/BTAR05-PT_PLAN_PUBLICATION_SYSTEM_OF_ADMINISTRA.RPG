TCHK2C                     Z-ADDWSSDAT    BTKOHZ
TCHK2C                     Z-ADDWSSHHH    BTKOHH
TCHK2C                     Z-ADDWSSNNN    BTKOSS
     C                     MOVE PUS       BTKOME
      *
     C           @KOKU     IFEQ '0'
     C                     MOVE 'D'       BTSKJY
TCHK2C*                    Z-ADD*DATE     BTSKHZ
TCHK2C                     Z-ADDWSSDAT    BTSKHZ
     C                     ELSE
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD0         BTSKHZ
     C                     END
      *
     C                     MOVE @HIN1     BTSHN1
     C                     MOVE @HIN2     BTSHN2
     C                     MOVE @HIN3     BTSHN3
     C                     MOVE WKYM      BTKEYM
     C                     Z-ADD@PH       #PH
     C                     Z-ADD@MH       #MH
     C                     MOVE @ZM       #ZM
      *
     C           *IN98     IFEQ '0'
     C                     UPDATBTAPL051
     C                     ELSE
     C                     WRITEBTAPL051
     C                     END
      *
     C*****************************************************************
     C*         青山カレンダーチェック
     C*****************************************************************
     C           $HOLI     BEGSR                                      $
      *
     C*休日'*XX*'
     C                     MOVEA'00000000'*IN,41
     C                     MOVEA'00000000'*IN,49
     C                     MOVEA'00000000'*IN,57
     C                     MOVEA'0000000' *IN,65
     C                     MOVE *BLANK    @HOL
     C                     Z-ADD*ZERO     WDY
     C                     MOVE *BLANK    EXC
      *
     C                     Z-ADD0         N       20
     C                     Z-ADD1         A
     C           KEY3      SETLLAGDPL121
     C           1         DO   31        A
     C                     SETOF                     80
     C           KEY3      READEAGDPL121                 80
     C           *IN80     IFEQ '0'
     C                     Z-ADDF8YOBI    WDY,A
     C           F8YMD     IFEQ 20031223
     C                     MOVE '1'       EXC,A
     C                     ENDIF
      *
     C                     MOVE *BLANK    WHOL
     C                     MOVELA         WHH23
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       WHH1
     C                     MOVE '*'       WHH4
     C                     END
     C           WHH2      IFEQ '0'
     C                     MOVE *BLANK    WHH2
     C                     END
     C                     MOVE WHOL      @HOL,A
     C                     END
     C                     END
      *
     C* 今日以前は入力禁止
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
      *
 %001C***        WDY,A     IFNE 3
     C***        EXC,A     ANDEQ*BLANK
     C***                  MOVE '1'       *IN,N
 %001C***                  ENDIF
      *
     C           WKYM      IFEQ WUKYM
TCHK2C*          A         IFLE UDAY
TCHK2C           A         IFLE WSSDDD
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     MOVE @HOL,A    WHOL
     C           WHH1      IFEQ '*'
     C                     MOVE '1'       *IN,N
     C                     END
     C           WHH23     IFEQ *BLANK
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C           WKYM      IFLT WUKYM
TCHK3C           @KOKU     OREQ '3'
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     ENDSR
