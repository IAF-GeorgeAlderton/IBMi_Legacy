     C                     SETOF                     01
     C                     END
      *------------*
      *計画予定日*
      *------------*
     C           @KYY      IFLT 1994
     C           @KMM      ORLT 1
     C           @KMM      ORGT 12
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     MOVEL@KYY      WKYM    60
     C                     MOVE @KMM      WKYM
TCHK2C*                    MOVEL*YEAR     WUKYM   60
TCHK2C*                    MOVE UMONTH    WUKYM
TCHK2C                     TIME           WSDT
TCHK2C                     MOVELWSSYYY    WUKYM   60
TCHK2C                     MOVE WSSMMM    WUKYM
      *
TCHK3C           @KOKU     IFNE '3'
