      * KANBAN #(SBAN)
     C           ESBAN     IFEQ *BLANK
      *
     C                     MOVE WNOMM     K@MM
     C           K#FC11    SETGTFCCTL12
     C           *IN90     DOUEQ*ON
     C           K#FC11    REDPEFCCTL12                  90
     C           *IN90     IFEQ *OFF
     C           B4SKBN    ANDEQ*BLANK
      *
     C           B4MAYY    IFNE WNOYY
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELB4SBAN    ESBAN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     Z-ADDWNOYY     @@YY    40
     C                     SUB  1         K@MM
     C           K@MM      IFEQ 0
     C                     ADD  12        K@MM
     C                     SUB  1         @@YY
     C                     ENDIF
      *
     C           K#FC11    SETGTFCCTL12
     C           *IN90     DOUEQ*ON
     C           K#FC11    REDPEFCCTL12                  90
     C           *IN90     IFEQ *OFF
     C           B4SKBN    ANDEQ*BLANK
      *
     C           B4MAYY    IFNE @@YY
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELB4SBAN    ESBAN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           ESBAN     IFEQ *BLANK
     C                     MOVE '0000'    ESBAN
     C                     ENDIF
      *
     C                     ENDIF
