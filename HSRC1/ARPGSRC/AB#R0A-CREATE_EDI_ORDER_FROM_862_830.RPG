     C                     PARM           $KEY2   8
     C                     PARM           $SEQ1  110
     C                     PARM           $SEQ2  11
     C                     MOVEL$SEQ2     WINV#     P
     C                     MOVELEPOLN#    WLIN#     P
     C                     ENDIF
      * ADJUST BIN#
JXH  C                     EXSR #ADBIN
      * ADJUST SBAN
