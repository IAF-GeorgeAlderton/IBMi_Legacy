 .   C                     PARM           $SIGN   1
 .   C                     PARM           $DAY    3
 .   C                     PARM           $MAX    1
 .   C                     PARM           $TGT8   8
 .   C                     PARM           $RTN1   1
 .   C                     MOVEL$TGT8     ENDATE
