 .   C                     MOVELENKOJ     $NKOJ
 .   C                     MOVELENUKE     $NUKE
     C                     MOVELWNYMD     $NOHZ
     C                     MOVELWMHIN     $MHIN
     C                     MOVELWODRN     $ODRN
     C                     CALL 'UTLR72C'                  GET NEXT AVAIL BIN#
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $MHIN  20
     C                     PARM           $ODRN  10
     C                     PARM           $BIN1   2
     C                     PARM           $BIN2   2
     C                     PARM           $STT    1
     C           $STT      IFEQ 'P'
     C           $STT      OREQ 'O'
     C           $BIN2     IFNE '00'
     C                     MOVEL$BIN2     WNOBN
 .   C                     ENDIF
 .   C                     ENDIF
      *
 .   C                     ENDIF
      *
JXH  C                     ENDSR
      *--------------------------------------------------------
      *  BIN-A  VERSION 2
      *--------------------------------------------------------
     C           #BINA2    BEGSR
      *
     C                     MOVE *BLANK    MAINYN  1
      *
      *  if Main Route is in our Truck Schedule file, use Main Route
      *     for Bin# Assignment...
     C           ETOKU     IFEQ '3411'
     C           EMANC     ANDNE*BLANK
     C                     Z-ADDWWYMD     INSHDT
     C                     MOVELEMANC     INRTE     P
     C                     CALL 'AB#R8M2'                               TOYOTA
     C                     PARM           INSHDT
     C                     PARM           INRTE
     C                     PARM           MAINYN
     C                     ENDIF
      *
      *  bin assignment program for toyota...(Main Route)
     C           MAINYN    IFEQ 'Y'
     C                     Z-ADDWWYMD     INSHDT
     C                     MOVELEMANC     INRTE     P
     C                     Z-ADD*ZERO     BINRTN
     C                     CALL 'AB#R8M'                   RETRIEVE BIN TOYOTA
     C                     PARM           INSHDT
     C                     PARM           INRTE
     C                     PARM           BINRTN
      *
     C                     Z-ADDBINRTN    WNOBN
      *
     C                     GOTO #ENDB1
     C                     ENDIF
      *
      *  bin assignment program for toyota...(Sub Route)
     C           ETOKU     IFEQ '3411'
     C           ESUB#     ANDNE*BLANK
     C                     Z-ADDWWYMD     INSHDT  80
     C                     MOVELESUB#     INRTE  10 P
     C                     Z-ADD*ZERO     BINRTN  20
     C                     CALL 'AB#R8M'                   RETRIEVE BIN TOYOTA
     C                     PARM           INSHDT
     C                     PARM           INRTE
     C                     PARM           BINRTN
      *
     C                     Z-ADDBINRTN    WNOBN
     C                     ENDIF
      *
     C           #ENDB1    TAG
      *
     C           WNOBN     IFEQ *ZERO
     C                     Z-ADD1         WNOBN
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  BIN-B
      *--------------------------------------------------------
     C           #BINB     BEGSR
      *
     C                     Z-ADD*ZERO     @@BIN   20
      * DUPLICATE CHECK
TCHK3C           K#AB17    SETLLAB#PL17
TCHK3C           *IN90     DOUEQ*ON
TCHK3C           K#AB17    READEAB#PL17                  90
TCHK3C           *IN90     IFEQ *OFF
TCHK3C           BASKJY    ANDEQ*BLANK
TCHK3C           BANOBN    IFGT @@BIN
TCHK3C                     Z-ADDBANOBN    @@BIN
TCHK3C                     ENDIF
TCHK3C           BAMHIN    IFEQ WMHIN
TCHK3C           BAINVN    ANDEQEINVN
TCHK3C                     MOVE 'E'       @ERC
TCHK3C                     Z-ADD*ZERO     @@BIN
TCHK3C                     LEAVE
TCHK3C                     ENDIF
TCHK3C                     ENDIF
TCHK3C                     ENDDO
      *
     C           @ERC      IFEQ *BLANK
      * DUPLICATE CHECK
     C                     MOVE WNYMD     @@YMD
     C           K#4T      CHAINAB#EP4T              90
     C           *IN90     IFEQ *OFF
     C                     MOVE 'E'       @ERC
     C                     ELSE
     C           @@BIN     IFEQ *ZERO
     C           K#4TY     SETLLAB#EP4T
     C           *IN90     DOUEQ*ON
     C           K#4TY     READEAB#EP4T                  90
     C           *IN90     IFEQ *OFF
     C           E@NOBN    ANDGT@@BIN
     C                     Z-ADDE@NOBN    @@BIN
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * BIN CHECK
     C           @ERC      IFEQ *BLANK
     C           K#4TX     CHAINAB#EP4T              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDE@NOBN    WNOBN
     C                     ELSE
TCHK4C           K#4TY     SETLLAB#EP4T
TCHK4C           *IN90     DOUEQ*ON
TCHK4C           K#4TY     READEAB#EP4T                  90
TCHK4C           *IN90     IFEQ *OFF
TCHK4C           E@NOBN    ANDGT@@BIN
TCHK4C                     Z-ADDE@NOBN    @@BIN
TCHK4C                     ENDIF
TCHK4C                     ENDDO
     C           @@BIN     ADD  1         WNOBN
     C                     ENDIF
      *
     C                     MOVE ENONY     E@NONY
     C                     MOVE ENUKE     E@NUKE
     C                     MOVE EMHIN     E@MHIN
     C                     MOVE @@YMD     E@DATE
     C                     MOVE EODRN     E@ODRN
     C                     MOVE EINVN     E@INVN
     C                     Z-ADDWNOBN     E@NOBN
     C                     WRITEAB#EP4T1
      *
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  BIN-C
      *--------------------------------------------------------
     C           #BINC     BEGSR
      *
     C           ' '       CHEKREODRN     A       20     90
     C           A         SUB  1         A
     C           A         IFLE *ZERO
     C                     Z-ADD1         WNOBN
     C                     ELSE
     C           2         SUBSTEODRN:A   @2C     2
     C                     MOVE @2C       WNOBN
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  BIN-D: BIN# BY INVOICE#
      *--------------------------------------------------------
     C           #BIND     BEGSR
      *
     C                     Z-ADD*ZERO     @@BIN   20
      * DUPLICATE CHECK
     C           K#AB17    SETLLAB#PL17
     C           *IN90     DOUEQ*ON
     C           K#AB17    READEAB#PL17                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BAMHIN    ANDEQWMHIN
     C           BAINVN    IFEQ WINV#
     C                     MOVE 'E'       @ERC
     C                     Z-ADDBANOBN    @@BIN
     C                     LEAVE
     C                     ELSE
     C           BANOBN    IFGT @@BIN
     C                     Z-ADDBANOBN    @@BIN
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
      * BIN CHECK
     C           @ERC      IFEQ *BLANK
     C           @@BIN     ADD  1         WNOBN
     C                     ELSE
     C                     Z-ADD@@BIN     WNOBN
     C                     ENDIF
      *
     C                     ENDSR
TCHK7 *--------------------------------------------------------
TCHK7 *  BIN-E: USE TOYOTA WESTERN TIME TABLE (AB#PP81)
TCHK7 *--------------------------------------------------------
TCHK7C           #BINE     BEGSR
TCHK7 *
TCHK7C                     Z-ADD*ZERO     WNOBN
TCHK7 *
TCHK7C           WWYMD     IFNE *ZERO
TCHK7 *
TCHK7C           WWYMD     SETGTAB#PP81
TCHK7C                     READPAB#PP81                  98
TCHK7 *
TCHK7C           *IN98     IFEQ *OFF
TCHK7 *
TCHK7C           @@1       IFEQ 'C'
TCHK7C           WNOTM     ADD  100       @@NTIM  40
TCHK7C                     ELSE
TCHK7C                     Z-ADDWNOTM     @@NTIM
TCHK7C                     END
TCHK7C                     Z-ADD*ZERO     @ENDT   40
TCHK7C                     Z-ADD*ZERO     @E      20
JW1  C**         1         DO   13        X       20
JWA  C           1         DO   30        X       20
TCHK7C           TO,X      IFNE *ZERO
TCHK7C                     Z-ADDTO,X      @ENDT   40
TCHK7C                     Z-ADDX         @E      20
TCHK7C                     END
TCHK7C           @@NTIM    IFLE TO,X
TCHK7C                     Z-ADDX         WNOBN
TCHK7C                     LEAVE
TCHK7C                     END
TCHK7C                     ENDDO
TCHK7 *
TCHK7C                     END
TCHK7 *
TCHK7C           WNOBN     IFEQ *ZERO
TCHK7C           @@NTIM    ANDGT@ENDT
TCHK7C           @E        ANDNE*ZERO
TCHK7C                     Z-ADD@E        WNOBN
TCHK7C                     END
TCHK7 *
TCHK7C           *IN98     IFEQ *ON
TCHK7C           WNOBN     OREQ *ZERO
TCHK7C                     Z-ADD1         WNOBN
TCHK7C                     END
TCHK7 *
TCHK7C                     END
TCHK7 *
TCHK7C                     ENDSR
      *--------------------------------------------------------
      * get bin assignment for napck service parts.
     C           #BINF     BEGSR
      *
     C                     Z-ADD*ZERO     WNOBN
      *
      * call napck bin assignment program ...
     C           ETOKU     IFEQ '3411'
      *
     C                     MOVELHOME      INHOME  1
     C                     Z-ADDWWYMD     INSHDT  80
     C                     Z-ADD*ZERO     BINRTN  20
     C                     CALL 'AB#R8N'                   RETRIEVE BIN NAPCK
     C                     PARM           INHOME
     C                     PARM           INSHDT
     C                     PARM           BINRTN
      *
     C                     Z-ADDBINRTN    WNOBN
     C                     ENDIF
      *
     C           WNOBN     IFEQ *ZERO
     C                     Z-ADD01        WNOBN
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  ADJUST SBAN
      *--------------------------------------------------------
 .   C           #SBAN     BEGSR
 .    *
     C                     MOVELENONY     QNONY
     C                     MOVELENKOJ     QNKOJ
     C                     MOVELENUKE     QNUKE
     C                     MOVELWMHIN     QMHIN
     C                     MOVELWNYMD     QNOHZ
     C                     CALL 'UTLR33C'
     C                     PARM           QNONY   4
     C                     PARM           QNKOJ   1
     C                     PARM           QNUKE   4
     C                     PARM           QMHIN  20
     C                     PARM           QNOHZ   8
     C                     PARM           QSBAN   6
     C                     MOVELQSBAN     ESBAN
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  DUPLICATE CHECK
      *--------------------------------------------------------
     C           #DUP1     BEGSR
      *
     C                     MOVE *BLANK    @ERC
      * DUPLICATE CHECK
     C           WNYMD     IFNE *ZERO
     C                     MOVE WNYMD     @@YMD
     C           K#4T      SETLLAB#EP4T
     C           *IN90     DOUEQ*ON
     C           K#4T      READEAB#EP4T                  90
     C           *IN90     IFEQ *OFF
     C           E@INVN    ANDEQEINVN
     C                     MOVE 'E'       @ERC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * BIN CHECK
     C           @ERC      IFEQ *BLANK
      *
     C                     MOVE ENONY     E@NONY
     C                     MOVE ENUKE     E@NUKE
     C                     MOVE EMHIN     E@MHIN
     C                     MOVE @@YMD     E@DATE
     C                     MOVE WODRN     E@ODRN
     C                     MOVE EINVN     E@INVN
     C                     Z-ADDWNOBN     E@NOBN
     C                     WRITEAB#EP4T1
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
JXD   *--------------------------------------------------------
      *  DUPLICATE CHECK
      *--------------------------------------------------------
     C           #DUP2     BEGSR
      *
     C                     MOVE *BLANK    @RTN
      * DUPLICATE CHECK
     C                     MOVELENONY     $NONY
     C                     MOVELENKOJ     $NKOJ
     C                     MOVELENUKE     $NUKE
     C                     MOVELWNYMD     $NOHZ
     C                     MOVELWMHIN     $MHIN
     C                     MOVELWODRN     $ODRN
     C                     MOVELWINV#     $INVN
     C                     CALL 'UTLR50C'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $MHIN  20
     C                     PARM           $ODRN  10
     C                     PARM           $INVN  16
     C                     PARM           @RTN    1
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SHIP DATE BASED ON CYCLE
      *--------------------------------------------------------
     C           #CYCL     BEGSR
      *
     C                     MOVELENDATE    K@YMD
     C                     MOVELECYCL     CYCLE
     C                     MOVE CYCL3     @@C     20
     C                     Z-ADD*ZERO     @@C1    20
     C           K#AGD     SETGTAGDPL121
      *
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL121                 90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YOBI    ANDNE6
     C           F8YOBI    ANDNE7
      *
     C                     ADD  1         @@C1
     C           @@C1      IFGE @@C
     C                     MOVE F8DATE    WNYMD            SHIPPING DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE WNYMD     K@YMD
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL121                 90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YOBI    ANDNE6
     C           F8YOBI    ANDNE7
      *
     C                     MOVE F8DATE    WNYMD            SHIPPING DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SHIP DATE -> 1 BUSINESS DAY (LEAD TIME)
      *--------------------------------------------------------
     C           #1DAYB    BEGSR
      *
     C                     MOVELENDATE    K@YMD
     C           K#AGD     SETLLAGDPL121
      *
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL121                 90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     MOVE F8DATE    WNYMD            SHIP DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
JWP   *--------------------------------------------------------
 |    *  SHIP DATE -> 2 BUSINESS DAY (LEAD TIME)
 |    *--------------------------------------------------------
 |   C           #2DAYB    BEGSR
 |    *
 |   C                     Z-ADD0         TIMES   20
 |   C                     MOVELENDATE    K@YMD
 |   C           K#AGD     SETLLAGDPL121
 |    *
 |   C           *IN90     DOUEQ*ON
 |   C                     READPAGDPL121                 90
 |   C           *IN90     IFEQ *OFF
 |   C           F8HIRU    ANDEQ*BLANK
 |   C                     ADD  1         TIMES
 |   C           TIMES     IFEQ 2
 |   C                     MOVE F8DATE    WNYMD            SHIPPING DATE
 |   C                     LEAVE
 |   C                     ENDIF
 |   C                     ENDIF
 |   C                     ENDDO
 |    *
JWP  C                     ENDSR
      *-------------------------------------------------------------
TCHKY *  AWNC(SPECIAL) WHEN DATE=MONDAY THEN SET TO LAST FRIDAY
TCHKY *-------------------------------------------------------------
TCHKYC**         #1DAYA    BEGSR
TCHKY *
TCHKYC**                   DO
TCHKY *
TCHKYC**         ENDATE    IFGT 20090430
TCHKYC**                   LEAVE
TCHKYC**                   END
TCHKYC*
TCHKYC**                   MOVELENDATE    K@YMD
TCHKYC**         K#AGD     CHAINAGDPL121             90
TCHKYC** 90                LEAVE
TCHKYC**         F8YOBI    IFNE 1
TCHKYC**                   LEAVE
TCHKYC**                   END
TCHKY *
TCHKYC**                   DO   *HIVAL
TCHKY *
TCHKYC**                   READPAGDPL121                 90
TCHKYC**         *IN90     IFEQ *OFF
TCHKYC**         F8YOBI    ANDEQ5
TCHKYC**                   MOVE F8DATE    WNYMD            SHIPPING DATE
TCHKYC**                   LEAVE
TCHKYC**                   END
TCHKY *
TCHKYC**                   ENDDO
TCHKY *
TCHKYC**                   ENDDO
TCHKY *
TCHKYC**                   ENDSR
      *--------------------------------------------------------
      *  SHIP DATE -> 3 BUSINESS DAYS (LEAD TIME)
      *--------------------------------------------------------
     C           #3DAYB    BEGSR
      *
     C                     MOVELENDATE    K@YMD
     C                     Z-ADD*ZERO     TIMES
     C**         K#AGD     SETGTAGDPL121
JXA  C           K#AGD     SETLLAGDPL121
      *
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL121                 90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YOBI    ANDLT6
     C                     ADD  1         TIMES
     C           TIMES     IFEQ 3
     C                     MOVE F8DATE    WNYMD            SHIPPING DATE
     C           F8DATE    IFGT *DATE
     C                     MOVE '1'       W@PICK
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
JXA   *  SHIP DATE -> 4 BUSINESS DAYS (LEAD TIME)
 .    *--------------------------------------------------------
 .   C           #4DAYB    BEGSR
 .    *
     C                     MOVELENDATE    K@YMD
     C                     Z-ADD*ZERO     TIMES
     C           K#AGD     SETLLAGDPL121
      *
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL121                 90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YOBI    ANDLT6
     C                     ADD  1         TIMES
     C           TIMES     IFEQ 4
     C                     MOVE F8DATE    WNYMD            SHIPPING DATE
     C           F8DATE    IFGT TODAY
     C                     MOVE '1'       W@PICK
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
 .   C                     ENDIF
 .   C                     ENDDO
 .    *
JXA  C                     ENDSR
