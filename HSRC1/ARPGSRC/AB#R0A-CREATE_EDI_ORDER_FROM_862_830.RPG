TCH84 *--------------------------------------------------------
   |  *  SHIP DATE -> NEXT DAY (LEAD TIME)
      *--------------------------------------------------------
     C           #NDAY     BEGSR
      *
     C                     Z-ADD0         CCCC    10
TCHKEC           @VAL2     IFEQ 'N'
TCHKEC                     Z-ADDENDATE    K@YMD
TCHKEC                     ELSE
     C                     Z-ADD*DATE     K@YMD
TCHKEC                     END
     C           K#AGD     SETLLAGDPL121
      *
B0   C           *IN90     DOUEQ*ON
     C                     READ AGDPL121                 90
B1   C           *IN90     IFEQ *OFF
B2   C           F8HIRU    IFEQ *BLANK
     C                     ADD  1         CCCC
E2   C                     ENDIF
B2   C           CCCC      IFGE 2
     C                     MOVE F8DATE    WNYMD            SHIPPING DATE
     C                     LEAVE
E2   C                     ENDIF
E1   C                     ENDIF
E0   C                     ENDDO
   |  *
TCH84C                     ENDSR
TCHLHC*--------------------------------------------------------
TCHLHC*  FLEX-N-GATE SPECIAL SHIP-DATE=THURSDAY
TCHLHC*--------------------------------------------------------
TCHLHC           #THURS    BEGSR
TCHLHC*
TCHLHC                     MOVELENDATE    K@YMD
TCHLHC                     Z-ADD*ZERO     X
TCHLHC           K#AGD     SETLLAGDPL121
TCHLHC*
TCHLHC                     DO   *HIVAL
TCHLHC                     READPAGDPL121                 90
TCHLHC   90                LEAVE
TCHLHC                     ADD  1         X
TCHLHC           X         IFGT 7
TCHLHC                     LEAVE
TCHLHC                     END
TCHLHC           F8YOBI    IFEQ 4
TCHLHC           F8HIRU    ANDEQ*BLANK
TCHLHC                     MOVELF8DATE    WNYMD
TCHLHC                     LEAVE
TCHLHC                     END
TCHLHC           F8YOBI    IFEQ 3
TCHLHC           F8HIRU    ANDEQ*BLANK
TCHLHC                     MOVELF8DATE    WNYMD
TCHLHC                     LEAVE
TCHLHC                     END
TCHLHC                     ENDDO
TCHLHC*
TCHLHC                     ENDSR
TCHLSC*--------------------------------------------------------
TCHLSC*  FLEX-N-GATE SPECIAL SHIP-DATE=TUESDAY
TCHLSC*--------------------------------------------------------
TCHLSC           #TUES     BEGSR
TCHLSC*
TCHLSC                     DO
TCHLSC*
TCHLSC                     MOVEL*BLANK    WNYMD
TCHLSC                     MOVEL*BLANK    WMOND   8
TCHLSC           ENDATE    IFLE *DATE
TCHLSC                     LEAVE
TCHLSC                     END
TCHLSC                     MOVELENDATE    K@YMD
TCHLSC                     Z-ADD*ZERO     X
TCHLSC           K#AGD     SETLLAGDPL121
TCHLSC*
TCHLSC                     DO   *HIVAL
TCHLSC                     READ AGDPL121                 90
TCHLSC   90                LEAVE
TCHLSC                     ADD  1         X
TCHLSC           X         IFGT 7
TCHLSC                     LEAVE
TCHLSC                     END
TCHLSC           F8YOBI    IFEQ 2
TCHLSC           F8HIRU    ANDEQ*BLANK
TCHLSC                     MOVELF8DATE    WNYMD
TCHLSC                     LEAVE
TCHLSC                     END
TCHLSC           F8YOBI    IFEQ 1
TCHLSC           F8HIRU    ANDEQ*BLANK
TCHLSC                     MOVELF8DATE    WMOND
TCHLSC                     END
TCHLSC                     ENDDO
TCHLSC*
TCHLSC           WNYMD     IFEQ *BLANK
TCHLSC           WMOND     IFNE *BLANK
TCHLSC                     MOVELWMOND     WNYMD
TCHLSC                     ELSE
TCHLSC                     MOVELENDATE    WNYMD
TCHLSC                     END
TCHLSC                     END
TCHLSC*
TCHLSC                     ENDDO
TCHLSC*
TCHLSC                     ENDSR
TCHLNC*--------------------------------------------------------
TCHLNC*  NAL SPECIAL SHIP-DATE=TUE-->MON , THU-->WED
TCHLNC*--------------------------------------------------------
TCHLNC           #NAL@     BEGSR
TCHLNC*
TCHLNC                     MOVELWNYMD     K@YMD
TCHLNC*
TCHLNC                     DO
TCHLNC*
TCHLNC           K#AGD     CHAINAGDPL12              90
TCHLNC   90                LEAVE
TCHLNC*
TCHLNC           F8YOBI    IFEQ 1
TCHLNC           F8YOBI    OREQ 3
TCHLNC           F8YOBI    OREQ 5
TCHLNC                     LEAVE
TCHLNC                     END
TCHLNC*
TCHLNC                     DO   *HIVAL
TCHLNC*
TCHLNC                     READPAGDPL12                  90
TCHLNC   90                LEAVE
TCHLNC*
TCHLNC           F8HIRU    IFEQ *BLANK
TCHLNC           F8YOBI    IFEQ 1
TCHLNC           F8YOBI    OREQ 3
TCHLNC           F8YOBI    OREQ 5
TCHLNC                     MOVELF8DATE    WNYMD
TCHLNC                     LEAVE
TCHLNC                     END
TCHLNC                     END
TCHLNC*
TCHLNC                     ENDDO
TCHLNC*
TCHLNC                     ENDDO
TCHLNC*
TCHLNC                     ENDSR
      *--------------------------------------------------------
      *  QTY BASED ON QTY/BOX
      *--------------------------------------------------------
     C           #BOX      BEGSR
      *
     C                     Z-ADD*ZERO     @@BOX   30
     C                     Z-ADD*ZERO     @@BQT   50
     C                     MOVE EBOXQ     @@BOX   30
     C                     MOVE EUSYS     @@BQT   50
     C           @@BOX     MULT @@BQT     WSURY
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  WRITE RECORDS IN AB#PP40
      *--------------------------------------------------------
     C           #P40      BEGSR
      *
     C                     CLEARAB#PP401
      *
     C                     TIME           @@TIM
     C                     Z-ADD@@YY      DAKOYY
     C                     Z-ADD@@MM      DAKOMM
     C                     Z-ADD@@DD      DAKODD
     C                     Z-ADD@@HH      DAKOHH
     C                     Z-ADD@@MN      DAKOSS
     C                     MOVEL#USER     DAKOME
     C                     MOVE ENONY     DANONY
     C                     MOVE ENKOJ     DANKOJ
     C                     MOVE WNOYY     DANOYY
     C                     MOVE WNOMM     DANOMM
     C                     MOVE WNODD     DANODD
     C                     MOVE WNOBN     DANOBN
     C                     MOVE WMHN1     DAMHN1
     C                     MOVE WMHN2     DAMHN2
     C                     MOVE WMHN3     DAMHN3
     C                     MOVELEN1MI     DACUNM
     C                     MOVELEN1SU     DASUNM
     C                     MOVELEEKBN     DAORDC
     C                     MOVE ESTSC     DASTSC
     C                     MOVELENUKE     DANUKE
      *
     C                     MOVELELIAD     DALIAD
     C                     MOVELESTAD     DASTAD
      * AWNC
     C           ENONY     IFEQ '0492'
     C           ENONY     OREQ '0493'
     C                     MOVELEODRN     DASTAD           PO#
     C                     Z-ADDENDATE    DAULDT           DELIVERY DATE
     C                     ENDIF
      *
     C                     MOVELEPANM     DAPANM
     C                     MOVELESUB#     DASUB#
     C                     MOVELEMANI     DAMANI
     C                     MOVELEINVN     DADEL#
     C           EINVN     IFEQ *BLANK
     C           EBSS4     ANDNE*BLANK
     C                     MOVELEBSS4     DADEL#
     C                     ENDIF
TCHKIC           ENONY     IFEQ '1101'
JWT  C           ENONY     OREQ '0492'
JWT  C           ENONY     OREQ '0493'
TCHKIC                     MOVELWODRN     DAORDN
TCHKIC                     ELSE
     C                     MOVELWINV#     DAORDN
TCHKIC                     END
     C                     MOVELEHAKO     DAHAKO
     C                     MOVELECD1C     DACD1C
     C                     MOVELECD1D     DACD1D
     C                     MOVELECD1T     DACD1T
     C                     MOVELECD2C     DACD2C
     C                     MOVELECD2D     DACD2D
     C                     MOVELECD2T     DACD2T
     C                     MOVELEMAN#     DAMAN#
TCHKIC           ENONY     IFEQ '1101'
TCHKIC                     MOVELEFLR1     DAROS#
TCHKIC                     ELSE
     C                     MOVELEROS#     DAROS#
TCHKIC                     END
     C                     MOVELEULDT     DAULDT
     C                     MOVELEULTM     DAULTM
     C                     MOVELEMANC     DAMANC
     C           EMANC     IFEQ *BLANK
     C           EN1ST     ANDNE*BLANK
     C                     MOVELEN1ST     DAMANC
     C                     ENDIF
      * SAVE PARTNER
     C           DACUNM    IFEQ *BLANK
     C                     MOVELEPRTNR    DACUNM
     C                     ENDIF
      *
     C                     WRITEAB#PP401
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  WRITE RECORDS IN AB#PP41
      *--------------------------------------------------------
     C           #P41      BEGSR
      *
     C                     MOVELERETN     K@TRAN
     C                     MOVE WNYMD     K@SPDT
     C           K#41      CHAINAB#PP41              90
     C           *IN90     IFEQ *ON
     C                     CLEARAB#PP411
      *
     C                     TIME           @@TIM
     C                     Z-ADD@@YY      AVKOYY
     C                     Z-ADD@@MM      AVKOMM
     C                     Z-ADD@@DD      AVKODD
     C                     Z-ADD@@HH      AVKOHH
     C                     Z-ADD@@MN      AVKOSS
     C                     MOVEL#USER     AVKOME
     C                     MOVELEBSS1     AVSTDT
     C                     MOVELEBSS2     AVPTDV
     C                     MOVELEBSS3     AVEDDT
     C                     MOVELEBSS4     AVCTDT
     C                     MOVELEN1SU     AVSUNM
     C                     MOVELESIRE     AVSUCD
     C                     MOVELEREFP     AVPDDS
     C                     MOVELEINVN     AVMAN#
     C                     MOVELESUB#     AVTRUC
     C                     MOVELERETN     AVTRAN
     C                     MOVELERESQ     AVKBSQ
     C                     MOVELEPANM     AVCNTP
     C                     MOVELECYCL     CYCLE
     C                     MOVE CYCL1     AVCYC1
     C                     MOVE CYCL2     AVCYC2
     C                     MOVE CYCL3     AVCYC3
     C                     MOVE EPO45     AVWTDV           WEIGHT DIVIS
     C                     MOVEAEPO46     A9
     C                     MOVE *ALL'0'   A9X
     C                     Z-ADD9         @X      20
     C                     Z-ADD9         @Y      20
     C                     DO   9
     C           A9,@X     IFNE *BLANK
     C           A9,@X     IFEQ '.'
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE A9,@X     A9X,@Y
     C                     SUB  1         @Y
     C                     ENDIF
      *
     C                     SUB  1         @X
     C           @X        IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA9X       @@9     9
     C                     TESTN          @@9        10
     C   10                MOVE @@9       AVBXWT
     C                     MOVE EPO47     AVWTUT           WEIGHT UNIT
     C                     MOVE EBOXQ     AVNBKB
     C                     MOVELEPER2     AVCTPS           CONTACT PERS
     C                     MOVELEPER4     AVTEL#           CONTACT TEL#
     C                     MOVE WHIN1     AVSHN1
     C                     MOVE WHIN2     AVSHN2
     C                     MOVE WHIN3     AVSHN3
     C                     MOVE ENONY     AVNONY
     C                     MOVE WNYMD     AVSPDT
     C                     MOVELENDATE    AVRVDT
      *
     C                     WRITEAB#PP411
     C                     ENDIF
      *
     C                     ENDSR
