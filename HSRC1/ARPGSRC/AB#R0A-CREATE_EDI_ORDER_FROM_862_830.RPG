JWI  C                     MOVELEPVAL1    WSUP10 10
     C                     MOVELEPVAL2    WSIRK   1
     C                     ELSE
     C                     MOVELESIRE     WSIRE
JWI  C                     MOVELESIRE     WSUP10
     C                     MOVELESIRK     WSIRK
     C           ESIRK     IFEQ *BLANK
     C           ES2       ANDNE*BLANK
     C                     MOVELES2       WSIRK
