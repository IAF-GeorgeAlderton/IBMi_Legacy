 .   C                     MOVE '-'       $SIGN
 .   C                     MOVEL'WED'     $DAY
 .   C                     MOVEL'7'       $MAX
JXG  C                     CALL 'UTLR37C'                  GET NEAREST DATE
 .   C                     PARM           $DT8    8
 .   C                     PARM           $SIGN   1
 .   C                     PARM           $DAY    3
 .   C                     PARM           $MAX    1
 .   C                     PARM           $TGT8   8
 .   C                     PARM           $RTN1   1
