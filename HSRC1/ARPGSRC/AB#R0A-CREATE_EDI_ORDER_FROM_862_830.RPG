 .   C                     MOVELEN1SU     IPGID            SU
 .   C                     ENDIF
      * FUTABA ================================
JXB  C           ENONY     IFEQ '0567'
 .   C           ENONY     OREQ '0579'
 .   C           ENONY     OREQ '0578'
 .   C           ENONY     OREQ '0556'
 .   C                     MOVELEMKDO     WINV#
 .   C                     MOVELEODRN     IPGID            PO#
 .   C                     MOVELESLOC     WFLD3            SU
 .   C                     MOVELERESQ     WRESE            CTL#
      * USE LAST 10 CHAR
 .   C                     MOVELEMKDO     $IN       P
 .   C                     CALL 'UTLR65A'
 .   C                     PARM           $IN    30
 .   C                     PARM           $OUT   10
 .   C                     MOVEL$OUT      WODRN
      *
 .   C                     MOVELESTAD     WFLD2
 .   C                     Z-ADDEPODT     WNUM1            PO ISSUE DATE
 .   C                     Z-ADDEPOLN#    PIN
 .   C                     CALL 'EDTR04'                   ZERO SUPPRESS
 .   C                     PARM           PIN    300
 .   C                     PARM           POUT   30
 .   C                     MOVELPOUT      WLIN#
JXB  C                     ENDIF
      * ADJUST FUTABA
 .   C           ENONY     IFEQ '0579'
     C                     Z-ADD05        WNOBN
     C                     ENDIF
 .   C**         ENONY     IFEQ '0579'
     C**                   MOVELEMKDO     WODRN
 .    **                   Z-ADD10        WNOBN
 |   C**                   MOVELENONY     $NONY
     C**                   MOVEL'0'       $NKOJ
     C**                   MOVEL'00  '    $NUKE
     C**                   MOVELWNYMD     $NOHZ
     C**                   MOVELWODRN     $ODRN
     C**                   CALL 'UTLR72D'
     C**                   PARM           $NONY   4
     C**                   PARM           $NKOJ   1
     C**                   PARM           $NUKE   4
     C**                   PARM           $NOHZ   8
     C**                   PARM           $ODRN  10
     C**                   PARM           $BIN    2
 .   C**                   MOVEL$BIN      WNOBN
 .   C**                   ENDIF
JW    * ADJUST BOCAR
     C           ENONY     IFEQ '2320'
     C                     MOVEL'BOCAR   '$KEY1
     C                     MOVEL'INVOICE#'$KEY2
