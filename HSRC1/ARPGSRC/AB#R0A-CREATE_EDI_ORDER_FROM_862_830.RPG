      * IAF PART# ---------------------------------
     C                     MOVELETOKU     PTOKU   4
     C                     MOVE ENONY     PNONY   4
     C                     MOVELENKOJ     PNKOJ   1
     C                     MOVELENUKE     PNUKE   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'                   GET IAF PART#
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVEL@SHIN     WSHIN
      *   PP41
     C                     MOVEL'AB#PP41' K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     EXSR #P41
     C                     ENDIF
      * BIN  ------------------------------------------
     C                     MOVE *OFF      *IN98
     C                     MOVEL'BIN   '  K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
      *
     C                     SELEC
     C           *IN90     WHEQ *ON
     C                     Z-ADD1         WNOBN   20
     C           EPVAL1    WHEQ 'A'
     C                     MOVELEPVAL2    @@1     1
     C                     EXSR #BINA
     C                     EXSR #BINA2
      *
     C           EPVAL1    WHEQ 'B'
     C                     MOVE *BLANK    @ERC    1
     C                     EXSR #BINB
     C           @ERC      CABNE*BLANK    @@JUMP
      *
     C           EPVAL1    WHEQ 'C'
     C                     EXSR #BINC
     C           EPVAL1    WHEQ 'D'
     C                     MOVE *BLANK    @ERC    1
     C                     EXSR #BIND
TCHK7C           EPVAL1    WHEQ 'E'
TCHK7C                     MOVELEPVAL2    @@1     1
TCHK7C                     EXSR #BINE
     C           EPVAL1    WHEQ 'F'
     C                     MOVELEPVAL2    @@1
     C                     EXSR #BINF
     C                     ENDSL
TCHK6 * AISIN AWNC ===============================
TCHMGC           ENONY     IFEQ '0492'
TCHMGC           ENUKE     IFEQ '00  '
TCHMGC                     Z-ADD7         WNOBN
TCHMGC                     ELSE
TCHMGC                     CALL 'AB#R9J1'                  GET STORE-ADDRESS
TCHMGC                     PARM           WMHIN
TCHMGC                     PARM           W@STOR 20
TCHMGC                     PARM           W@KNBN 10
      *
TCHMGC           W@KNBN    IFNE *BLANK
TCHMGC                     MOVELW@KNBN    ESBAN
TCHMGC                     MOVELW@KNBN    W@A002  2
TCHMGC                     SELEC
TCHMGC           W@A002    WHEQ 'C2'
TCHMGC                     Z-ADD01        WNOBN
TCHMGC           W@A002    WHEQ 'C7'
TCHMGC                     Z-ADD02        WNOBN
TCHMGC           W@A002    WHEQ 'C8'
TCHMGC                     Z-ADD03        WNOBN
TCHMGC                     ENDSL
TCHMGC                     END
TCHMGC                     END
TCHMGC                     END
