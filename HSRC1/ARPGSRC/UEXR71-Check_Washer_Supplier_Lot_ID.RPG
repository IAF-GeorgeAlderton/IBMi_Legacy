     H            Y.
      ** UEXR71  ***************************************************
      *  CHECK WASHER SUPPLIER LOT ID                              *
      *  LEC   2025.08.21                                          *
      **************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR71 '
      *                    PARM           #SUPP   4
      *                    PARM           #LOTN  25
      *                    PARM           #RTN    1
      *
      *   IN  #SUPP   4A  SUPPLIER CODE
      *   IN  #LOTN  25A  LOT ID
      *   OUT #RTN    1A  Y = GOOD, N = NO GOOD
      ***********************************************************
      *
     C           *ENTRY    PLIST
     C                     PARM           #SUPP   4
     C                     PARM           #LOTN  25
     C                     PARM           #RTN    1
      *
     C                     MOVE 'N'       #RTN
      *
     C                     SELEC
      * freeway
     C           #SUPP     WHEQ '2323'
     C           1         SUBST#LOTN:1   PRE1    1
     C           PRE1      IFEQ 'D'
     C           24        SUBST#LOTN:2   #LOTN     P
     C                     MOVE 'Y'       #RTN
     C                     ENDIF
      * rk metal
     C           #SUPP     WHEQ '2525'
     C           3         SUBST#LOTN:1   PRE3    3
     C           PRE3      IFEQ 'RKF'
     C                     MOVE 'Y'       #RTN
     C                     ENDIF
      * sekido
     C           #SUPP     WHEQ '3111'
     C           1         SUBST#LOTN:1   PRE1    1
     C           PRE1      IFEQ 'S'
     C           24        SUBST#LOTN:2   #LOTN     P
     C                     MOVE 'Y'       #RTN
     C                     ELSE
     C           2         SUBST#LOTN:1   PRE2    2
     C           PRE2      IFEQ '1T'
     C           23        SUBST#LOTN:3   #LOTN     P
     C                     MOVE 'Y'       #RTN
     C                     ENDIF
     C                     ENDIF
      *
      * art metals
     C           #SUPP     WHEQ '2626'
     C           1         SUBST#LOTN:1   PRE1
     C           PRE1      IFEQ 'D'
     C           24        SUBST#LOTN:2   #LOTN     P
     C                     MOVE 'Y'       #RTN
     C                     ENDIF
     C                     OTHER
     C           1         SUBST#LOTN:1   PRE1
     C           PRE1      IFEQ 'I'
     C                     MOVE 'Y'       #RTN
     C                     ENDIF
      *
     C                     ENDSL
      *
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
