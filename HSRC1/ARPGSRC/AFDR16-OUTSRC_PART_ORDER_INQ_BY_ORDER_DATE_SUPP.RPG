      *
     C**         SUPLY     CAT  SUPX:0    SCODE   5 P
     C**         SCODE     LOKUPTAB1      TAB2           90
     C**         *IN90     IFEQ *ON
     C**                   MOVELTAB2      D@SUPN
     C**                   ENDIF
      *
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
     C                     MOVE *ON       *IN43
     C                     Z-ADD0         D@SUPP
     C                     Z-ADDTODAY     D@FROM
     C                     Z-ADD99999999  D@TO
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C**         FIRST     IFEQ 'Y'
     C**                   MOVE 'N'       FIRST
     C**                   MOVE P@HIN1    D@PRT1
     C**                   MOVE P@HIN2    D@PRT2
     C**                   MOVE P@HIN3    D@PRT3
     C**                   ENDIF
      *
     C**                   MOVE P@SDAT    D@FROM
     C**                   Z-ADD999999999 D@TO
      *
     C                     MOVELCMD,1     D@CMD
      *
     C     N88             GOTO @JUMP
      *
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C           @JUMP     TAG
     C                     SETON                     88
      *
     C                     SELEC
      * F3: BACK
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
      * F7: DOWNLOAD
     C           *INKG     WHEQ *ON
     C                     MOVELSUPLY     $SUPP
     C                     MOVEL' '       $SUPX
     C                     MOVELD@FROM    $FROM
     C                     MOVELD@TO      $TO
     C                     MOVELD@PART    $PART
     C                     CALL 'AFDC05D'
     C                     PARM           $SUPP   4
     C                     PARM           $SUPX   1
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
     C                     PARM           $PART  12
     C                     PARM           $RTN1   1
      *
     C           $RTN1     IFEQ '*'
     C                     MOVELERR,3     $TXT1
     C                     MOVE *BLANK    $TXT2
     C                     CALL 'UTLC96 '
     C                     PARM           $TXT1  30
     C                     PARM           $TXT2  30
     C                     ENDIF
     C                     MOVEL'99'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C*
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C                     SELEC
     C           RRN1      WHEQ *ZERO
     C                     MOVE ERR,1     D@MSG
     C           RRN1      WHEQ 9999
     C                     MOVE ERR,2     D@MSG
     C                     OTHER
     C                     MOVEL'02'      @@ID
     C                     ENDSL
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *OFF      *IN99
     C                     MOVE '0'       *IN,60
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *BLANK    D@MSG
      * CHECK SUUP
     C                     MOVELD@SUPP    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C           $RTN      IFEQ '*'
     C                     GOTO XCHK1
     C                     MOVE *ON       *IN60
     C                     MOVE *ON       *IN99
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$NAME1    SUPLY
     C*  CHECK DATE
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FROM    D@TO
     C                     ENDIF
      *
     C           D@TO      IFLT D@FROM
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
     C**************************************************************************
     C*    SET DATA FOR 2ND SCREEN
     C**************************************************************************
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN1  40
     C                     Z-ADDD@FROM    K@YMD
     C                     MOVE *OFF      *IN80
     C*
     C           K#AF24    KLIST
     C                     KFLD           SUPLY
