     C                     ITER
     C                     END
     C**         SUPX      IFNE *BLANK
     C**         AFAKI1    ANDNESUPX
     C**                   ITER
     C**                   END
      *
     C                     MOVELAFODNO    W@ODNO  6
     C           S@PAR1    IFEQ AFPAR1
     C           S@PAR2    ANDEQAFPAR2
     C           S@PAR3    ANDEQAFPAR3
     C           S@BOX     ANDEQAFHAKO
     C           S@ORNO    ANDEQW@ODNO
     C           H@RCVD    ANDEQAFNDAT
     C           H@RBIN    ANDEQAFAKI2
     C           20000000  ADD  S@RCVD    AFNDAT
     C                     MOVELS@RBIN    AFAKI2
     C                     UPDATAFDPP201
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*    CHECK 2ND SCREEN
     C**************************************************************************
     C           #CHK2     BEGSR
     C*
     C                     MOVE '02'      @@ID
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    IFNE *BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     MOVEL*OFF      *IN41
     C                     UPDATSFL01
      *
     C                     EXSR #SET2
     C                     MOVE '03'      @@ID
     C                     LEAVE
     C                     ENDIF
     C                     MOVEL*OFF      *IN41
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*    SET DATA FOR 3RD SCREEN
     C**************************************************************************
     C           #SET2     BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2    40
      *
     C                     MOVE S@BINN    D@BINN
     C                     MOVE S@PAR1    D@PAR1
     C                     MOVE S@PAR2    D@PAR2
     C                     MOVE S@PAR3    D@PAR3
     C                     Z-ADDS@OUT     D@OUT
     C                     Z-ADDS@BOX     D@BOX
     C                     Z-ADDS@ORDT    D@ORDT
     C                     MOVE S@ORNO    D@ORNO
     C                     Z-ADDH@ORDT    W@ORDT
      *
     C           K#AF10    SETLLAFDPL10
