     C           K#15      READEAFDPL15                  95
     C           *IN95     IFEQ *OFF
     C           A5SKJY    ANDEQ*BLANK
     C                     ADD  1         Z
     C                     MOVELA5LTNO    LT,Z
     C                     ENDIF
     C                     ENDDO
      *
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      *
      *
     C                     MOVEL*BLANK    D@SR#1
     C                     MOVEL*BLANK    D@SR#2
     C           SUPLY     IFEQ '3111'
     C           SUPLY     OREQ '3222'
     C           SUPLY     OREQ '4456'
     C           K#15      SETLLAFDPL40
     C           K#15      READEAFDPL40                  95
