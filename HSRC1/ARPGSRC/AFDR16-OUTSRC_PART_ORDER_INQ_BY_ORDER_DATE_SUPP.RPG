     C           A@KODT    IFGT H@ORDT
     C                     MOVEL'R'       S@SHMK
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     Z-ADD*ZERO     Z       30
     C           ADLTNO    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTNO    LT,Z
