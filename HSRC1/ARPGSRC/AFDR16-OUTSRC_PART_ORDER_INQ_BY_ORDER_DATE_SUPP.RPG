     C           K#AF20    SETLLAFDPL20
     C                     END
      *
     C                     MOVEL*BLANK    CKHIN1
     C                     MOVEL*BLANK    CKHIN2
     C                     MOVEL*BLANK    CKHIN3
     C                     Z-ADD*ZERO     W@READ
     C                     Z-ADD*ZERO     WWREAD  31
     C*
     C                     EXSR #SET11
