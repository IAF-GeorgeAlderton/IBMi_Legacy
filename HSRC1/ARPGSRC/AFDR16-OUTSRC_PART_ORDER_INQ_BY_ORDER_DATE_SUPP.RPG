     C                     ELSE
     C           SUPLY     READEAFDPL20             N    80
     C                     END
     C           *IN80     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
      *
     C**         SUPX      IFNE *BLANK
     C**         AFAKI1    ANDNESUPX
     C**                   ITER
     C**                   ENDIF
      *
     C           AFODAT    IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           D@PART    IFNE *BLANK
     C           D@PART    ANDNEAFPART
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL01
     C*
     C                     Z-ADDAFODAT    S@ORDT
     C                     Z-ADDAFODAT    H@ORDT
     C                     MOVE AFBINN    S@BINN
     C                     MOVE AFPAR1    S@PAR1
     C                     MOVE AFPAR2    S@PAR2
     C                     MOVE AFPAR3    S@PAR3
     C                     Z-ADDAFHAKO    S@BOX
     C                     MOVE AFODNO    S@ORNO
     C                     Z-ADDAFNDAT    S@RCVD
     C                     Z-ADDAFNDAT    H@RCVD
     C                     MOVELAFAKI2    S@RBIN
     C                     MOVELAFAKI2    H@RBIN
     C                     Z-ADD*ZERO     W@OUT   50
     C                     EXSR #SET12
     C                     Z-ADDW@OUT     S@OUT
     C                     MOVEL*OFF      *IN41
     C           AFPAR1    IFNE CKHIN1
     C           AFPAR2    ORNE CKHIN2
     C           AFPAR3    ORNE CKHIN3
     C                     Z-ADD*ZERO     WWREAD
     C           K#AAML    KLIST
     C                     KFLD           AFPAR1
     C                     KFLD           AFPAR2
     C                     KFLD           AFPAR3
     C           K#AAML    CHAINAAMPL11              81
     C           *IN81     IFEQ *OFF
     C           CKSKJY    IFNE *BLANK
     C                     MOVEL*ON       *IN81
     C                     ELSE
     C                     Z-ADD*ZERO     I       20
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           I         IFGT 15
     C                     LEAVE
     C                     END
     C           NKBM,I    IFEQ *ZERO
     C           NTKR,I    ANDEQ*BLANK
     C           NCKQ,I    ANDEQ*BLANK
     C                     LEAVE
     C                     END
     C                     MOVELNKBM,I    W@NKBM  4
     C           W@NKBM    IFNE SUPLY
     C                     ITER
     C                     END
     C           NTKR,I    IFEQ *BLANK
     C           NTKR,I    OREQ '------'
     C           NTKR,I    OREQ '++++++'
     C                     ITER
     C                     END
     C           NCKQ,I    IFEQ *BLANK
     C                     ITER
     C                     END
     C           K#TKR     KLIST
     C                     KFLD           @@TK1
     C                     KFLD           @@TK2
     C                     KFLD           @@TK3
     C                     KFLD           @@TK4
     C                     MOVELNTKR,I    @@TKR
     C                     SELEC
     C           NCKQ,I    WHEQ 'C'
     C           K#TKR     SETGTAAFPL03
     C                     DO   *HIVAL
     C           K#TKR     REDPEAAFPL03                  83
     C   83                LEAVE
     C           A3SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     Z-ADDA3READ    WWREAD
     C                     LEAVE
     C                     ENDDO
     C           NCKQ,I    WHEQ 'A'
     C           K#TKR     SETGTABHPL03
     C                     DO   *HIVAL
     C           K#TKR     REDPEABHPL03                  83
     C   83                LEAVE
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     Z-ADDM6LIT1    WWREAD
     C                     ADD  M6LIT2    WWREAD
     C                     ADD  M6LIT3    WWREAD
     C                     ADD  M6LIT4    WWREAD
     C                     LEAVE
     C                     ENDDO
      *
     C           NCKQ,I    WHEQ 'E'
     C           K#TKR     SETGTAAHPL03
     C                     DO   *HIVAL
     C           K#TKR     REDPEAAHPL03                  83
     C   83                LEAVE
     C           L6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     Z-ADDL6LTIM    WWREAD
     C                     ENDDO
      *
     C                     ENDSL
     C                     ENDDO
     C                     END
     C                     END
     C                     END
     C*
     C           *IN81     IFEQ *OFF
     C           WWREAD    ANDNE*ZERO
     C                     Z-ADDWWREAD    S@READ
     C                     Z-ADDWWREAD    W@READ
     C           W@REA2    IFNE *ZERO
     C                     ADD  1         W@REA1
     C                     Z-ADD*ZERO     W@REA2
     C                     END
     C           K#AGD     KLIST
     C                     KFLD           AFODYY
     C                     KFLD           AFODMM
     C                     KFLD           AFODDD
     C                     Z-ADD*ZERO     W@CNT   30
     C           K#AGD     SETGTAGDPL12
     C                     DO   *HIVAL
     C                     READ AGDPL12                  82
     C   82                LEAVE
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  1         W@CNT
     C                     ELSE
     C***        F8YOBI    IFGE 6
     C***                  ADD  1         W@CNT
     C***                  END
     C                     END
     C           W@CNT     IFGE W@READ
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C           *IN82     IFEQ *OFF
     C           WWREAD    ANDNE*ZERO
     C           AFNDAT    IFEQ *ZERO
     C           F8TODT    IFLT WSSDAT
     C                     MOVEL'*'       S@LATE
     C                     END
     C                     ELSE
     C           AFNDAT    IFGT F8TODT
     C                     MOVEL'*'       S@LATE
     C                     END
     C                     END
     C                     END
     C                     END
     C*
     C                     ADD  1         RRN1
     C*
     C                     WRITESFL01
     C           RRN1      IFEQ 9999
     C                     LEAVE
     C                     END
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         @@RRN1
