     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
     C                     MOVEL'A'       K@KSKB
     C           K#ADA     SETLLADAPL01
     C                     DO   *HIVAL
     C           K#ADA     READEADAPL01                  93
     C   93                LEAVE
