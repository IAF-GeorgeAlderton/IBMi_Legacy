      *
     C                     SELEC
      * F3: BACK
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
      * F7: DOWNLOAD
     C           *INKG     WHEQ *ON
     C                     MOVELSUPLY     $SUPP
     C                     MOVEL' '       $SUPX
     C                     MOVELD@FROM    $FROM
     C                     MOVELD@TO      $TO
     C                     MOVELD@PART    $PART
     C                     CALL 'AFDC05D'
     C                     PARM           $SUPP   4
     C                     PARM           $SUPX   1
     C                     PARM           $FROM   8
