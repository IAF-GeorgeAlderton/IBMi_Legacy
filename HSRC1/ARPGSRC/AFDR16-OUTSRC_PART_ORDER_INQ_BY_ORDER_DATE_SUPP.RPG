     C**************************************************************************
     C           #SET11    BEGSR
      *
     C           *IN80     DOWEQ*OFF
     C           D@PART    IFNE *BLANK
     C           K#AF2D    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
