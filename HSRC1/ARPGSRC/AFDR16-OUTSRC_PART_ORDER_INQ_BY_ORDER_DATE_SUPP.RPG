     C           ADLTN2    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTN2    LT,Z
     C                     ENDIF
     C           ADLTN3    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTN3    LT,Z
     C                     ENDIF
     C*
     C                     EXSR GETNAM
     C                     MOVELALWKNM    S@TM
     C*
     C           SUPLY     IFEQ '5555'
