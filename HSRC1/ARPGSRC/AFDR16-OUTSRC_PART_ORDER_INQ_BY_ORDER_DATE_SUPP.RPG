     C                     MOVE ADTAIS    W@TICD
     C                     MOVE ADSYUK    W@YUKO
     C                     MOVE ADHKOS    W@HASY
     C                     MOVE W@LOT#    S@TEHI
     C                     ENDIF
     C*
     C                     MOVE ADPAGE    S@PAGE
     C*
     C                     Z-ADD*ZERO     Z       30
     C           ADLTNO    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTNO    LT,Z
     C                     ENDIF
     C           ADLTN2    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTN2    LT,Z
     C                     ENDIF
     C           ADLTN3    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTN3    LT,Z
     C                     ENDIF
     C                     Z-ADDADSYOS    S@QTY
      *
     C                     MOVEL' '       S@SHMK
     C           K#AL3A    SETLLALDPL30
     C                     DO   *HIVAL
     C           K#AL3A    READEALDPL30                  94
     C   94                LEAVE
     C           A3SYDT    IFGT H@ORDT
     C                     MOVEL'X'       S@SHMK
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C           *IN94     IFEQ *ON
     C                     MOVEL'A'       K@KSKB
     C           K#ADA     SETLLADAPL01
     C                     DO   *HIVAL
     C           K#ADA     READEADAPL01                  93
     C   93                LEAVE
     C           A@DTKB    IFNE 'S'
