     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C**         *ENTRY    PLIST
     C**                   PARM           SUPLY   4
     C**                   PARM           SUPX    1
     C**                   PARM           P@HIN1  5
     C**                   PARM           P@HIN2  5
     C**                   PARM           P@HIN3  2
     C**                   PARM           P@SDAT  8
      *
     C                     TIME           WSDT
      *
     C           K#AF20    KLIST
     C                     KFLD           SUPLY   4
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C           K#AF10    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@ODYY
     C                     KFLD           K@ODMM
     C                     KFLD           K@ODDD
     C                     KFLD           S@BINN
      *
     C           K#15      KLIST
     C                     KFLD           ADKANR
     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
     C                     KFLD           ADPAGE
     C                     KFLD           ADNIJI
     C                     KFLD           ADTAIS
