     FGDIPW11 CF  E                    WORKSTN
     FGDIPL10 UF  E           K        DISK                      A
     FGCQPL12 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    MSG     1   6 59               d[ｰ xｮﾈｰﾆﾞ
     I****************************************************************
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
     I            DS
     I                                        1   40IHKOTM
     I                                        1   20IHKOHH
     I                                        3   40IHKOSS
     I            DS
     I                                        1   80IHSKHZ
     I                                        1   40IHSKYY
     I                                        5   60IHSKMM
     I                                        7   80IHSKDD
     I            DS
     I                                        1   80IHKOHZ
     I                                        1   40IHKOYY
     I                                        5   60IHKOMM
     I                                        7   80IHKODD
     I            DS
     I                                        1   8 D1KATA
     I                                        1   6 D1KAT6
     I                                        1   2 D1KAT1
     I                                        3   6 D1KAT2
     I                                        7   7 D1KAT3
     I                                        8   8 D1KAT4
     I            DS
     I                                        1  11 D2KATA
     I                                        1   2 D2KAT1
     I                                        3   3 D2HIF1
     I                                        4   7 D2KAT2
     I                                        8   8 D2HIF2
     I                                        9   9 D2KAT3
     I                                       10  10 D2HIF3
     I                                       11  11 D2KAT4
     I            DS
     I                                        1   8 WWDIE
     I                                        1   2 WWDIE1
     I                                        3   6 WWDIE2
     I                                        7   7 WWDIE3
     I                                        8   8 WWDIE4
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*
     C           @CLR1     TAG
     C*
     C                     MOVE *BLANK    D1OPT
     C                     MOVE *BLANK    D1KAT1
     C                     MOVE *BLANK    D1KAT2
     C                     MOVE *BLANK    D1KAT3
     C                     MOVE *BLANK    D1KAT4
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA'00'      *IN,11
     C                     MOVEA'0'       *IN,99
     C****************
     C*  第１画面  *
     C****************
     C           @DSP1     TAG
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00'      *IN,11
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABEQ'1'       @DSP1
     C*
     C                     EXSR #SET01
     C****************
     C*  第２画面  *
     C****************
     C           @DSP2     TAG
     C*
     C                     EXFMTDSP02
     C                     MOVEA'0'       *IN,21
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C* < F3=ON >
     C           *INKC     CABEQ'1'       @DSP1
     C*
     C                     EXSR #CHK02
     C           *IN99     CABEQ'1'       @DSP2
     C* < F5=OFF >
     C           *INKE     CABEQ'0'       @DSP2
     C*
     C           *IN30     IFEQ '0'
     C                     SETON                     30
     C                     TIME           @@TIME
     C                     EXCPTHD
     C                     END
     C*
     C                     ADD  1         CHGALL  40
     C*
     C                     EXSR #UPD01
     C                     GOTO @CLR1
     C*
     C**************
     C* 終　　了 *
     C**************
     C           @END      TAG
     C           *IN30     IFEQ '1'
     C                     EXCPTTO
     C                     END
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*           ＳＵＢ　　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           #CHK01    BEGSR                                     *
     C****************************************************************
     C**第１画面チェック**
     C*
     C           D1OPT     IFNE '0'
     C           D1OPT     ANDNE'1'
     C           D1OPT     ANDNE'2'
     C                     MOVEA'1'       *IN,11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C*
     C                     MOVE D1KAT1    D2KAT1
     C                     MOVE D1KAT2    D2KAT2
     C                     MOVE D1KAT3    D2KAT3
     C                     MOVE D1KAT4    D2KAT4
     C                     MOVE '-'       D2HIF1
     C                     MOVE '-'       D2HIF2
     C                     MOVE '-'       D2HIF3
     C*----------
     C           D1KATA    SETLLGDIPL101
     C                     DO   *HIVAL
     C           D1KATA    READEGDIPL101                 10
     C   10                LEAVE
     C           IHSKJY    IFEQ 'D'                        DELETE CODE
     C           IHSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*:
     C                     LEAVE
     C                     ENDDO
     C*----------
     C           *IN10     IFEQ '1'
     C           D1OPT     IFEQ '0'
     C           D1OPT     OREQ '1'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,3     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C                     ELSE
     C           D1OPT     IFEQ '2'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C                     END
     C*
     C*--------------------
     C                     Z-ADD0         WKSYOS  50       収容数
     C*--------------------
     C           KEYA1     KLIST
     C                     KFLD           WWDIE1
     C                     KFLD           WWDIE2
     C                     KFLD           WWDIE3
      *
     C                     MOVE *BLANK    WWDIE
     C                     MOVELD1KAT6    WWDIE
      *
     C           KEYA1     SETGTGCQPL121
     C                     DO   *HIVAL
     C                     SETOF                     1070
     C           KEYA1     REDPEGCQPL121                 10
     C           *IN10     IFEQ '0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           *DATE     IFGE T6KIHZ
     C                     SETON                     1070
     C                     Z-ADDT6SYOS    WKSYOS
     C                     END
     C                     END
     C                     END
     C  N10                END
     C*--------------------
     C           *IN70     IFEQ '0'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,4     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     ENDIF
     C*
     C           @CHK1E    ENDSR
     C****************************************************************
     C           #CHK02    BEGSR                                     *
     C****************************************************************
     C**第２画面チェック**
     C*
     C                     Z-ADDWKSYOS    D2SYOS           収容数
     C           D2MAIS    MULT D2SYOS    D2SURY
     C*
     C           D1OPT     IFNE '0'
     C           D2MAIS    IFEQ 0
     C                     MOVEA'1'       *IN,21
     C  N99                MOVELMSG,5     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C                     END
     C*
     C           @CHK2E    ENDSR
     C****************************************************************
     C           #SET01    BEGSR                                     *
     C****************************************************************
     C**第２画面セット**
     C                     MOVEA'0'       *IN,21
     C                     MOVEA'0'       *IN,29
     C           D1OPT     COMP '0'                      80
     C           D1OPT     COMP '1'                      81
     C           D1OPT     COMP '2'                      82
     C                     Z-ADD0         D2MAIS
     C                     Z-ADD0         D2SYOS
     C   82                Z-ADDWKSYOS    D2SYOS
     C                     Z-ADD0         D2SURY
     C   80                MOVEA'1'       *IN,29
     C*----------
     C           D1KATA    SETLLGDIPL101
     C                     DO   *HIVAL
     C           D1KATA    READEGDIPL101            N    10
     C   10                LEAVE
     C           IHSKJY    IFEQ 'D'                        DELETE CODE
     C           IHSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*:
     C                     LEAVE
     C                     ENDDO
     C*----------
     C  N82      *IN,10    IFEQ '0'
     C                     Z-ADDIHMAIS    D2MAIS
     C                     Z-ADDIHSYOS    D2SYOS
     C           D2MAIS    MULT IHSYOS    D2SURY
     C                     END
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD01    BEGSR                                     *
     C****************************************************************
     C                     MOVELD1KATA    IHKATA
     C                     TIME           @@TIME
     C*
     C           D1KATA    CHAINGDIPL101             10
     C* OLD DATA=>FIELD INPUT
     C                     MOVE IHKATA    ODKATA  8
     C                     Z-ADDIHSYOS    ODSYOS  30
     C                     Z-ADDIHMAIS    ODMAIS  50
     C                     Z-ADDIHSURY    ODSURY  70
     C*
     C                     Z-ADDD2SYOS    IHSYOS
     C                     Z-ADDD2MAIS    IHMAIS
     C                     Z-ADDD2SURY    IHSURY
     C                     Z-ADD*DATE     IHKOHZ
     C                     Z-ADD@TIME     IHKOTM
     C                     MOVELPPUSER    IHKOME
     C*
     C* DELETE MODE
     C*
     C           *IN80     IFEQ '1'
     C                     MOVE 'DEL DATA'OLDMSG  8
     C                     EXCPTOLD
     C                     EXCPTSP
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     MOVE 'D'       IHSKJY           DELETE CODE
     C                     Z-ADD*DATE     IHSKHZ
     C  N10                UPDATGDIPL101
     C                     ENDIF
     C*
     C* CHANGE MODE
     C*
     C           *IN81     IFEQ '1'
     C                     MOVE 'OLD DATA'OLDMSG
     C                     EXCPTOLD
     C                     MOVE 'CHG DATA'NEWMSG  8
     C                     EXCPTNEW
     C                     EXCPTSP
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C  N10                UPDATGDIPL101
     C                     ENDIF
     C*
     C* ADD MODE
     C*
     C           *IN82     IFEQ '1'
     C                     MOVE 'ADD DATA'NEWMSG
     C                     EXCPTNEW
     C                     EXCPTSP
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     MOVE ' '       IHSKJY           DELETE CODE
     C                     Z-ADD0         IHSKHZ
     C  N10                UPDATGDIPL101
     C   10                WRITEGDIPL101
     C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
     OQPRINT  E  102           HD
     O                                  131 '+-------------------+'
     O        E  1             HD
     O                                  131 '|         |         |'
     O        E  1             HD
     O                                   89 'TIME'
     O                         @@TIME    98 '  .  .  '
     O                                  131 '|         |         |'
     O        E  2             HD
     O                                   12 'GDIR11-1 '
     O                                   54 '**  KANBAN INPUT DATA'
     O                                   69 'CHANGE LIST **'
     O                                   81 '(D I E)'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '+-------------------+'
     O        E  2             HD
     O                                   21 'MODE'
     O                                   35 'PART NO.'
     O                                   52 'AMD QTY'
     O                                   63 'BOX'
     O                                   77 'QTY.'
     O        E  1             OLD
     O                         OLDMSG    21
     O                         ODKATA    35
     O                         ODSYOS2   52
     O                         ODMAIS2   63
     O                         ODSURY2   77
     O        E  1             NEW
     O                         NEWMSG    21
     O                         IHKATA    35
     O                         IHSYOS2   52
     O                         IHMAIS2   63
     O                         IHSURY2   77
     O        E  1             SP
     O                                  132 ' '
     O        E 11             TO
     O                                   25 '*** CHANGE OF TOTAL'
     O                         CHGALL2   38
