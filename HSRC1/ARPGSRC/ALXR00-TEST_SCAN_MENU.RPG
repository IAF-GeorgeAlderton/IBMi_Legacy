     FALXPW00 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     E                    ER      1  11 65
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 20
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     MOVELWORKER    USRCD
     C                     Z-ADD0         D1SEL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*BLANK    WPGM    6
     C                     MOVEL*BLANK    P2PGM  10
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           P1        PLIST
     C                     PARM           POPR    6
     C                     PARM           PUSR   20
      *
     C           P3        PLIST
     C                     PARM           POPR    6
     C                     PARM           PUSR   20
     C                     PARM           PSECT   1
      *
     C                     MOVE WORKER    POPR    6        SET WORKER ID
     C                     MOVE WORKER    POPR2   60       SET WORKER ID
     C*
     C                     MOVELW#USER    PUSR             SET WORKER ID
     C                     SETOF                     98
     C           POPR2     SETGTALBPL301
     C                     DO   *HIVAL
     C           POPR2     REDPEALBPL301                 98
     C   98                LEAVE
     C           ALSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C                     MOVEL*BLANK    PUSR
     C                     MOVELALWKNM    PUSR   20
     C                     ENDDO
      *
     C                     MOVEL'1'       PSECT   1
      *
     C                     SELEC
      * LOT TAG SCAN
     C           D1SEL     WHEQ 1
     C                     MOVEL'IZAR60'  WPGM
      * REPLACE SCAN
     C           D1SEL     WHEQ 2
     C                     MOVEL'ALCR70'  WPGM
      * INTRA STORE IN
     C           D1SEL     WHEQ 3
     C                     MOVEL'ALDR99'  WPGM
      * 4 POINT SCAN
     C           D1SEL     WHEQ 4
     C                     MOVEL'ALCR12'  WPGM
      * 5  STOCK CHECK
     C           D1SEL     WHEQ 5
     C                     MOVEL'STAR30'  WPGM
      *
     C                     OTHER
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     GOTO ESB210
     C                     ENDSL
      *
%0001 * CALL PROCESS
     C                     SELEC
     C           D1SEL     WHEQ 1
