     C           D1SEL     WHEQ 2
     C                     CALL WPGM      P1
     C           D1SEL     WHEQ 3
     C                     CALL WPGM      P3
     C           D1SEL     WHEQ 4
     C                     CALL WPGM      P3
     C           D1SEL     WHEQ 5
     C                     CALL WPGM      P1
     C                     ENDSL
      *
     C                     Z-ADD0         D1SEL
      *
     CSR         ESB210    ENDSR
