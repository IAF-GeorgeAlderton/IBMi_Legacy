     C           #SB210    BEGSR
     C                     Z-ADD*ZERO     @ACQY   90
     C*          KEY1      SETLLMBDPL01
     C*          *IN10     DOUEQ*ON
     C*          KEY1      READEMBDPL01                  10
     C*          *IN10     IFEQ *OFF
     C*          F3SKJY    ANDEQ*BLANK
     C*                    ADD  F3TNSU    @ACQY
     C*                    ENDIF
     C*                    ENDDO
      *
     C                     Z-ADD@10DT     K@NODT
     C           K#AB18    SETLLAB#PL18
     C           *IN26     DOUEQ*ON
     C           KEY1      READEAB#PL18                  26
     C           *IN26     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BADAT     IFGT *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  BASRYO    @ACQY
     C                     ENDIF
     C                     ENDDO
      *
     C           WSYS      IFNE 0
     C           @ACQY     DIV  WSYS      @ABOX   70
     C                     MVR            @@MVR   70
     C                     END
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         @ABOX
     C                     ENDIF
     C           @W10      IFNE 0
     C           @ABOX     DIV  @W10      @ACTB   41H      日当り実績
     C                     END
      *
     C           ESB210    ENDSR
      *------------------------------------------------------
     C           #SB300    BEGSR
     C                     Z-ADD0         KNB     40
     C                     Z-ADD0         WKN
     C                     MOVEA*BLANK    @ID
     C                     Z-ADD99999999  WISDT   80
     C                     SETOF                     33
     C                     MOVE *BLANK    KZETI   4
     C                     MOVE *BLANK    KTENO   3
     C           1         SETLLINPUT2
     C                     SETOF                     10
     C                     DO   *HIVAL
     C                     READ INPUT2                   10
     C           *IN10     IFEQ *OFF
     C           I1PRT1    IFEQ I2PRT1
     C           I1PRT2    ANDEQI2PRT2
     C           I1PRT3    ANDEQI2PRT3
      *
     C                     Z-ADD0         WKNB    40
     C                     MOVE I2ZETI    KZETI
     C                     MOVE I2TENO    KTENO
     C**********           EXSR #SB400
     C           I2KNID    IFEQ 'A'
     C                     SETON                     33
     C                     ADD  I2KQTY    KNB
     C           I2ISDT    IFLT WISDT
     C                     Z-ADDI2ISDT    WISDT
      *
     C*********            EXSR #SB400
      *
     C                     END
     C                     ELSE
      *
     C           I2KQTY    MULT I2LOTS    WKNB
     C           WKNB      IFEQ 0
     C                     Z-ADDI2KQTY    WKNB
     C                     END
     C                     ADD  WKNB      KNB
     C                     END
      *
     C                     Z-ADD1         @A
     C                     SETOF                     11
     C           I2LOCT    LOKUPWTK,@A                   11
     C           *IN11     IFEQ '1'
     C                     ADD  KNB       WKN,@A
      *
     C                     SELEC
     C           I2KNID    WHEQ 'Q'
     C                     MOVEL'OQ'      W@KID   3 P
     C           I2KNID    WHEQ 'L'
     C                     MOVEL'LAN'     W@KID
     C           I2KNID    WHEQ 'R'
     C                     MOVEL'RL'      W@KID     P
     C           I2KNID    WHEQ '1'
     C                     MOVEL'AOQ'     W@KID     P
     C           I2KNID    WHEQ '2'
     C                     MOVEL'RRT'     W@KID     P
     C           I2KNID    WHEQ 'S'
     C                     MOVEL'SB '     W@KID     P
     C           I2KNID    WHEQ 'K'
     C                     MOVEL'KRO'     W@KID     P
     C           I2KNID    WHEQ 'F'
     C                     MOVEL'FRL'     W@KID     P
     C           I2KNID    WHEQ 'Z'
     C                     MOVEL'BZ '     W@KID     P
     C           I2KNID    WHEQ 'Y'
     C                     MOVEL'SL '     W@KID     P
     C           I2KNID    WHEQ 'H'
     C                     MOVEL'HN '     W@KID     P
     C                     OTHER
     C                     MOVELI2KNID    W@KID     P
     C                     ENDSL
     C           '('       CAT  W@KID:0   @@KID   4
     C           @@KID     CAT  ')'       @ID,@A
      *
      *
     C                     END
      *
     C                     Z-ADD0         KNB
     C                     END
      *
     C                     ENDIF
     C  N10                ENDDO
     C           WISDT     IFEQ 99999999
     C                     Z-ADD0         WISDT
     C                     END
     C           ESB300    ENDSR
      *------------------------------------------------------
