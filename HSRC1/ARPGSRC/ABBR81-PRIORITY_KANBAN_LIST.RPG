TCHK2C                     EXSR #STEI
     C           WSYS      IFNE 0
     C           WSTEI     DIV  WSYS      HAKO      H      日当り箱数
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXSR #SB210
      *
     C                     END
     C                     END
     C           ESB200    ENDSR
