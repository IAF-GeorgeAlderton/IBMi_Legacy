     C                     ELSE
     C                     Z-ADDA2KSYS    WSYS
     C                     END
      *
     C           @WKD      IFNE 0
     C           A2GEKN    DIV  @WKD      WSTEI     H
     C           A2GEKN    DIV  20        WSTEI     H
     C           WSYS      IFNE 0
     C           WSTEI     DIV  WSYS      HAKO      H      日当り箱数
     C                     ENDIF
     C                     ENDIF
      *
     C           KEY1      CHAINFCEPL111             10
     C           FCCD01    IFNE *ZERO
TCHK2C*          FCGK01    DIV  FCCD01    WSTEI     H
