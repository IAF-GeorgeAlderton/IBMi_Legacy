     H            Y.
     F** CHKR25B  **************************************************************
     F*  PROGRAM    : CHECK & FIX USER PART BY EDIPP45                         *
     F*  WRITTEN    : JW (SRA)    2022.03.21                                   *
     F**************************************************************************
     FAB#PLAA UF  E           K        DISK
     FEDIPP45 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      * -------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **************************************************************************
     C                     EXSR #INIT
      *
     C           @DATE     SETLLAB#PLAA
     C                     DO   *HIVAL
     C                     READ AB#PLAA                  98
     C   98                LEAVE
      * IGNORE
     C           BASKJY    IFEQ 'D'
     C           BAFLD2    OREQ *BLANK
     C                     ITER
     C                     ENDIF
      * CHECK EDIPP45
     C           K#PP45    SETLLEDIPP45
     C                     DO   *HIVAL
     C           K#PP45    READEEDIPP45                  97
     C   97                LEAVE
      *
     C           E5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           E5UPRT    IFNE BAFLD2
     C                     EXSR #PRINT
      * UPDATE
     C           $UPD      IFEQ 'Y'
     C                     MOVELE5UPRT    BAFLD2    P
     C                     UPDATAB#PLAA1
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDDO
      *
     C           SEQ#      IFEQ 0
     C                     EXCPT@FOOT
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
     C                     PARM           $UPD    1
      *
     C           K#PP45    KLIST
     C                     KFLD           BANONY
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
      *
     C           $UPD      IFNE 'Y'
     C                     MOVE 'N'       $UPD
     C                     ENDIF
      *
     C                     TIME           SDATE
     C           $DATE     IFEQ *BLANK
     C                     Z-ADDTODAY     @DATE   80
     C                     ELSE
     C                     MOVEL$DATE     @DATE
     C                     ENDIF
      *
     C                     Z-ADD0         CNT     40
     C                     Z-ADD0         SEQ#    40
      *
     C                     EXCPT@HDR
      *
     C           EINIT     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM       9
     O                                   25 'SHIP DATE FROM:'
     O                         @DATE     36 '    .  .  '
     O                                   70 '** USER PART ERROR R'
     O                                   90 'EPORT (PPA1) **     '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   02           @HDR
     O                                   17 'UPDATE:'
     O                         $UPD      19
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   12 'DELV#'
     O                                   22 'SHP_DATE'
     O                                   32 'BAMHIN'
     O                                   61 'QTY'
     O                                   79 'MASTER PART --->'
     O                                  102 'USER PART IN FLD2'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         BANONY  +003
     O                         BANOHZ  +002 '    /  /  '
     O                         BAMHIN  +002
     O                         BASRYO1 +002
     O                         E5UPRT  +002
     O                         BAFLD2  +002
     O        E 1              @FOOT
     O                                   25 '** ERROR NOT FOUND **'
