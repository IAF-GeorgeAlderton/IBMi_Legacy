     C* NOT READ FCEPL01
     C                     ELSE
     C                     MOVE *BLANK    FCLOC1
     C                     MOVE *BLANK    FCLOC2
     C                     MOVE *BLANK    FCLOC3
     C                     MOVE *BLANK    FCLOC4
     C                     Z-ADD*ZERO     W2KASI
B02  C                     END
     C*
     C* CALUCULATE THE NUMBER OF BOXES
     C           BASRYO    DIV  ISYOS     FC#BOX
     C                     MVR            WHAK1   40
     C           WHAK1     IFNE 0
     C                     ADD  1         FC#BOX
     C                     END
     C*
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* NET WEIGHT + BOX WEIGHT             = GROSS WEIGHT PER BOX(G)
     C* (GROSS WEIGHT PER BOX) * # OF BOX   = TOTAL WEIGHT / PART(G)
     C* (TOTAL WEIGHT PER PART) / 1000      = TOTAL WEIGHT / PART(KG)
      *
JWG  C           D@P6      IFEQ 'Y'
 .   C           BASRYO    MULT W2KASI    WKOT1   92
 .   C                     ELSE
 .   C           ISYOS     MULT W2KASI    WKOT1
JWG  C                     ENDIF
      *
     C           WKOT1     MULT FC#BOX    WKOT1
     C           WKOT1     DIV  1000      FCWEGH  62
     C                     ADD  PWEIG     FCWEGH
     C*
     C                     WRITEABWPP3W1
     C  N89                SETON                     89
     C*
     C                     ENDIF
     C                     ENDDO
E1    *
     C                     CLOSEABWPP3X
      *
      *
     C                     ENDSR
      *---------------------------------------------------
     C           #HINV     BEGSR
      *
     C                     MOVEL'HONDA'   K@KWD1    P
     C                     MOVEL'ASN# '   K@KWD2    P
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C           CTNBR1    IFGT 99999999
     C                     Z-ADD1         CTNBR1
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     ADD  1         CTNBR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE CTNBR1    @@8     8
      *
     C**JW8      '0'       CHECK@@8       X       20     10
     C**         *IN10     IFEQ *ON
JW8  C           '0'       CHECK@@8       X       20     11
"    C           *IN11     IFEQ *ON
      *
     C           8         SUB  X         XX      20
     C                     ADD  1         XX
     C           XX        SUBST@@8:X     W@8     8
     C                     ELSE
     C                     MOVE @@8       W@8
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------
** MSGTBL(70A) ....2.........3.........4.........5.........6.........7
E-01 ENTER DELIVERY CODE!
E-02 ENTER FACTORY CODE!
E-03 DATE IS INVALID!
E-04 CONTAINER WEIGHT SHOULD NOT BE 0!
E-05 ENTER Y OR N!
E-06 NO TARGET DATA!
E-07 DELIVERY CODE DOES NOT EXIST IN PACKING LIST OPTION (AB#C90)!
M-08 FRS LIST WILL BE PRINTED OUT...
E-09 BIN ERROR!
E-10 PRINTER SELECTION ERROR!
E-11
E-12 ORDER NOT FOUND!
E-13 ENTER Y AT LEAST FOR ONE DOCUMENT!
M-14 PRESS F5 TO PROCESS...
** CMD(70) ........2.........3.........4.........5.........6.........7
CLRPFM QTEMP/ABWPP31
** KEY(79) ........2.........3.........4.........5.........6.........7
 F3:END   F5:OK
