     C           WWODRN    IFNE IODRN
     C                     ADD  1         CX
     C                     ENDIF
      *
     C                     MOVELIODRN     WWODRN
      *
     C                     WRITEAB#PP311
     C                     MOVE INUKE     WWDOCK
     C                     ENDIF
     C                     ENDDO
