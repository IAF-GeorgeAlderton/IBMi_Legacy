     C                     MOVELBASHN2    ISHN2
     C                     MOVELBASHN3    ISHN3
     C                     Z-ADDBATOKU    ITOKU
     C                     MOVE BANONY    INONY
     C                     MOVELBANKOJ    INKOJ
     C                     MOVELBAINVN    IINV#
     C*
     C* SET QUANTITY / CONTAINERS
     C           BAUSYS    IFEQ *ZERO
     C           BASYOS    IFEQ *ZERO
     C                     Z-ADD1         ISYOS
     C*
     C                     ELSE
     C                     Z-ADDBASYOS    ISYOS
     C                     END
     C*
     C                     ELSE
     C                     Z-ADDBAUSYS    ISYOS
     C                     END
     C*
     C* SET LOCATION
     C           KEY2      SETLLFCEPL30
     C           *IN91     DOUEQ*ON
     C           KEY2      READEFCEPL30                  91
B02  C           *IN91     IFEQ '0'
     C           F3GSKD    ANDEQ*BLANK
     C*
     C           KDATE     IFGE F3TYMD                     LOCATION
     C                     MOVE F3STRK    FCLOC1           NEW
     C                     MOVE F3STRT    FCLOC2
     C                     MOVE F3STRR    FCLOC3
     C                     MOVE F3STRD    FCLOC4
     C*
     C                     ELSE
     C                     MOVE F3KTRK    FCLOC1           OLD
     C                     MOVE F3KTRT    FCLOC2
     C                     MOVE F3KTRR    FCLOC3
     C                     MOVE F3KTRD    FCLOC4
     C                     END
     C                     Z-ADDF3KASI    W2KASI  72
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C* NOT READ FCEPL01
     C           *IN91     IFEQ *ON
     C           KEY2      SETLLFCEPL011
     C           #PART     TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C*
     C           A2GSKD    IFEQ 'D'
     C                     GOTO #PART
     C                     END
     C*
     C           PNOHZ     IFGE A2DATE                     LOCATION
     C                     MOVE A2STRK    FCLOC1           NEW
     C                     MOVE A2STRT    FCLOC2
     C                     MOVE A2STRR    FCLOC3
     C                     MOVE A2STRD    FCLOC4
     C*
     C                     ELSE
     C                     MOVE A2KTRK    FCLOC1           OLD
     C                     MOVE A2KTRT    FCLOC2
     C                     MOVE A2KTRR    FCLOC3
     C                     MOVE A2KTRD    FCLOC4
     C                     END
     C                     Z-ADDA2KASI    W2KASI  72
     C*
     C* NOT READ FCEPL01
     C                     ELSE
     C                     MOVE *BLANK    FCLOC1
     C                     MOVE *BLANK    FCLOC2
     C                     MOVE *BLANK    FCLOC3
     C                     MOVE *BLANK    FCLOC4
     C                     Z-ADD*ZERO     W2KASI
B02  C                     END
     C                     ENDIF
     C*
     C* CALUCULATE THE NUMBER OF BOXES
     C           BASRYO    DIV  ISYOS     FC#BOX
     C                     MVR            WHAK1   40
     C           WHAK1     IFNE 0
     C                     ADD  1         FC#BOX
     C                     END
     C*
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* NET WEIGHT + BOX WEIGHT             = GROSS WEIGHT PER BOX(G)
     C* (GROSS WEIGHT PER BOX) * # OF BOX   = TOTAL WEIGHT / PART(G)
     C* (TOTAL WEIGHT PER PART) / 1000      = TOTAL WEIGHT / PART(KG)
     C           ISYOS     MULT W2KASI    WKOT1   92
     C           WKOT1     ADD  PWEIG     WKOT1
     C           WKOT1     MULT FC#BOX    WKOT1
     C           WKOT1     DIV  1000      FCWEGH  62
     C*
     C                     WRITEABWPP3W1
     C  N89                SETON                     89
     C*
     C                     ENDIF
     C                     ENDDO
E1    *
     C                     CLOSEABWPP3W
E1    *
     C                     ENDSR
