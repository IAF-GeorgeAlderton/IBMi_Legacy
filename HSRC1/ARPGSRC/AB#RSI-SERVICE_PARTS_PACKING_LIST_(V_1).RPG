     C           *IN62     IFEQ '0'
     C           B4SKJY    IFEQ 'D'
     C                     ELSE
     C*
     C           W@DATE    IFGE B4CHDT
     C                     MOVELB4NSHP    ISHP#            NEW
     C                     ELSE
     C                     MOVELB4OSHP    ISHP#            OLD
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     ENDIF
      *
     C* SET VALUES NOT REQUIRED CALCULATIONS
     C                     Z-ADDBANOHZ    INOHZ
     C                     Z-ADDBANOBN    INOTM
     C                     MOVELBANUKE    INUKE
     C                     MOVELBAODRN    IODRN
     C                     MOVELBASBAN    ISBAN
     C                     MOVELBAMHIN    IMHN
