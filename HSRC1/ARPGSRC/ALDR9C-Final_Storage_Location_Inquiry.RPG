      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVELW5RD      S1COHZ
      *
     C                     MOVEL*BLANK    S1MTK
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELW5TBN1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELW5TBN2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELW5TBN3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELW5TBN4    WWMTK4
     C                     MOVELWWLOCN    S1MTK
      *
     C                     MOVEL*BLANK    S1SHN
     C                     MOVEL*BLANK    WWSHN
     C                     MOVELW5LHN1    WWSHN1
     C                     MOVEL'-'       WWSF1
     C                     MOVELW5LHN2    WWSHN2
     C           W5LHN3    IFNE *BLANK
     C                     MOVEL'-'       WWSF2
     C                     MOVELW5LHN3    WWSHN3
     C                     ENDIF
     C                     MOVELWWSHN     S1SHN
     C                     MOVELW5WOKR    S1KO
      *
     C           W5PAGE    IFEQ *BLANK
     C                     MOVE *BLANK    WWDSH1
     C                     ELSE
     C                     MOVEL'-'       WWDSH1
     C                     ENDIF
      *
     C                     MOVELWWLTPG    S1LTPG
      *
     C           W5PTLT    IFNE *BLANK
     C                     MOVEL*BLANK    S1LTPG
     C                     MOVELW5PTLT    S1LTPG
     C                     ENDIF
      *
     C                     MOVELS1KO      S1KONM  60
     C           S1KONM    CHAINALBPL301             28
     C           *IN28     IFEQ *OFF
     C                     MOVELALWKNM    S1NAME
     C                     ENDIF
      *
     C                     SETOF                     39
     C                     MOVEL'0'       H139
     C           W5OKNG    IFEQ 'NG'
     C                     SETON                     39
     C                     MOVEL'1'       H139
     C                     ENDIF
     C                     MOVELW5CODT    H1RDHZ
     C                     MOVELW5COTM    H1RDTI
     C                     MOVELW5OKNG    H1JUDG
     C                     MOVELW5LBAR    H1BAR1
     C                     MOVELS1MTK     H1AT1
     C                     MOVELW5ABAR    H1BAR2
     C                     MOVELW5AZET    H1ZET2
