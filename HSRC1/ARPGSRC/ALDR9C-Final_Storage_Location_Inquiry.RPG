     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK SFL                                          *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'M'
     C                     MOVELH1RDHZ    D2RDHZ
     C                     MOVELH1RDTI    D2RDTI
     C                     MOVELH1JUDG    D2JUDG
     C                     MOVELH1BAR1    D2BAR1
     C                     MOVELH1AT1     D2AT1
     C                     MOVELH1BAR2    D2BAR2
     C                     MOVELH1AT2     D2AT2
     C                     MOVELH1SHN     D2SHN
     C                     MOVELH1KO      D2KO
     C                     MOVE *BLANKS   D2NAME
     C                     MOVELD2KO      D2KONM  60
     C           D2KONM    CHAINALBPL301             28
     C           *IN28     IFEQ *OFF
     C                     MOVELALWKNM    D2NAME
     C                     ENDIF
      *
      * get issue date for this part/lot#
     C           AH#KEY    KLIST
     C                     KFLD           H1ZET2
     C                     KFLD           H1TEHA
      *
     C           AH#KEY    CHAINAH#PL111             28
     C           *IN28     IFEQ *OFF
     C                     MOVE '.'       POINT1
     C                     MOVE '.'       POINT2
     C                     MOVELISSDAT    D2ISDT
     C                     ELSE
     C                     MOVE *BLANKS   D2ISDT
     C                     ENDIF
      *
      * if error code, get error message to display on screen.
     C                     MOVE *OFF      *IN50
     C                     MOVE *BLANKS   D2EMSG
     C           H1ERCD    IFGT *BLANKS
     C                     MOVE *ON       *IN50
     C                     MOVE H1ERCD    CD      20
     C                     MOVELERR,CD    D2EMSG
     C                     ENDIF
      *
      *
     C                     EXFMTALDPW982
     C                     MOVEL*BLANK    S1SEL
     C                     OTHER
     C                     MOVELER,2      D9ERR
     C                     SETON                     3199
     C                     ENDSL
