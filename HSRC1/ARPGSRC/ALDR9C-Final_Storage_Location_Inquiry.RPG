      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INITIALIZATION                                     *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     MOVEL*BLANK    WKMTK
     C                     MOVELP1MTK1    WKMTK1
     C                     MOVELP1MTK2    WKMTK2
     C                     MOVELP1MTK3    WKMTK3
     C                     MOVELP1MTK4    WKMTK4
     C                     MOVEL*BLANK    C1MTK
     C           WKMTK     IFEQ *BLANK
     C                     ELSE
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELWKMTK1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELWKMTK2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELWKMTK3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELWKMTK4    WWMTK4
     C                     MOVELWWMTK     C1MTK
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKMTK
     C                     MOVELP1MT21    WKMTK1
     C                     MOVELP1MT22    WKMTK2
     C                     MOVELP1MT23    WKMTK3
     C                     MOVELP1MT24    WKMTK4
     C                     MOVEL*BLANK    C1MT2
     C           WKMTK     IFEQ *BLANK
     C                     ELSE
     C                     MOVEL*BLANK    WWMTK
     C                     MOVELWKMTK1    WWMTK1
     C                     MOVEL'-'       WWTF1
     C                     MOVELWKMTK2    WWMTK2
     C                     MOVEL'-'       WWTF2
     C                     MOVELWKMTK3    WWMTK3
     C                     MOVEL'-'       WWTF3
     C                     MOVELWKMTK4    WWMTK4
     C                     MOVELWWMTK     C1MT2
     C                     ENDIF
      *
     C                     MOVE P1COH1    C1COH1
     C                     MOVE P1COH2    C1COH2
     C                     MOVE P1DET1    C1DET1
     C                     MOVE P1DET2    C1DET2
      *
     C                     MOVEL*BLANK    C1COUS
     C           P1COUS    IFEQ *BLANK
     C                     MOVEL'ALL'     C1COUS
     C                     ELSE
     C                     MOVELP1COUS    C1COUS
     C                     ENDIF
      *
     C                     MOVEL*BLANK    C1HNTE
     C                     SELEC
     C           P1HNTE    WHEQ *BLANK
     C                     MOVEL'ALL'     C1HNTE
     C           P1HNTE    WHEQ '1'
     C                     MOVEL'OK '     C1HNTE
     C           P1HNTE    WHEQ '2'
     C                     MOVEL'NG '     C1HNTE
     C                     ENDSL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
