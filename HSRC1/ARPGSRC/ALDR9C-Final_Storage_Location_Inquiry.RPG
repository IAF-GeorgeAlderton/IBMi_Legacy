     C                     ENDIF
      * CHECK
     C                     SETOF                     3199
     C                     Z-ADD1         X       20
     C                     Z-ADD0         WKSEL   20
     C           X         DOWLE12
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
