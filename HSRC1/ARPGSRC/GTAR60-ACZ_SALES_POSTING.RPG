     H            Y.                                                      EMD050
     F** AB#R32 **************************************************
     *
     *  THIS PROGRAM COPY FROM AB#R32 ONLY WORK FOR ACZ
     *
     F*  ..RECORDING OF EDI FRS SALES & EDI(810) INVOICE DATA    *
     F*  ..ISSURANCE OF CANADA CUSTOM SHEET                      *
     F*    I-HASADA                             97.06.26         *
     F*    ADDING %0001 A.MAMIYA 2000.10.23                      *
     F*    ADD RELEASE DATE FOR FORD
     F*            2001/11/05
     F*    QTY/BOX -> IF BASYOS IS ZERO, RETRIEVE FROM BAUSYS
     F*
     F*      CHANGE BIN FROM 1 BITES TO 2 BITES
     F*
     F* TCHK1 01/26/07 ADD AB#PL75,AB#PL78 UPDATE(POSTING DATE)
     F* TCHK2 07/23/07 ADD AB#PL75,AB#PL78 UPDATE FOR FORD VAN BORN
     F* TCHK3 01/15/13 CHG READ SKIP NOT ACZ
     F************************************************** AB#R32 **
     FAB#PL11 IF  E           K        DISK
TCHK1FAB#PL75 UF  E           K        DISK
TCHK1FAB#PL78 UF  E           K        DISK
     FAB#WP32 O   E                    DISK                      A
     I* ----------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     I            DS
     I                                        1   80WNOHZ
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80WREHZ
     I                                        1   40WREYY
     I                                        5   60WREMM
     I                                        7   80WREDD
     I            DS
     I                                        1   80BAEHZ
     I                                        1   40BADEYY
     I                                        5   60BADEMM
     I                                        7   80BADEDD
      *
     C           KEY1      KLIST
     C                     KFLD           WNONY   40
     C                     KFLD           WNOYY
     C                     KFLD           WNOMM
     C                     KFLD           WNODD
      *
     C           *ENTRY    PLIST
     C                     PARM           PSIRE   4
     C                     PARM           PSIRK   1
     C                     PARM           PNOHZ   8
     C                     PARM           PNOBI   20
     C                     PARM           PRLDT   8
     C                     MOVE PNOHZ     WNOHZ
     C                     MOVE PSIRE     WNONY
      *
%0001C                     Z-ADDPNOBI     WNOBN   20
B0   C           PRLDT     IFNE *BLANK
     C                     MOVE PRLDT     WREHZ
E0   C                     ENDIF
      *
     C           KEY1      SETLLAB#PL111
      *
B0   C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAB#PL111                 10
B1   C           *IN10     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
E1   C                     END
TCHK3C*
TCHK3C           BANONY    IFNE 0170
TCHK3C                     ITER
TCHK3C                     END
      *
B1   C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
      *
B2   C           PRLDT     IFEQ *BLANK
     C           PRLDT     ORNE *BLANK
     C           BAEHZ     ANDEQWREHZ
      *
B3   C           BACARD    IFNE 'MA02'
     C                     SETON                     U1
      *
B4   C           BAURHZ    IFEQ 0
      *
     C****       BANONY    IFEQ 3347
%0001C           BANOBN    IFNE WNOBN
     C                     GOTO JUMP
     C                     END
     C****                 END
      *
B5   C           BATOKU    IFEQ BANONY
     C                     MOVE BANKOJ    W1TKOJ
     C                     MOVE BANUKE    W1TUKE
     C                     ELSE
     C                     MOVE *BLANK    W1TKOJ
     C                     MOVE *BLANK    W1TUKE
E5   C                     END
      *
     C                     MOVE BASIRE    W1SIRE
     C                     MOVE BASIRK    W1SIRK
     C                     MOVE BAMHN1    W1THN1
     C                     MOVE BAMHN2    W1THN2
     C                     MOVE BAMHN3    W1THN3
     C                     MOVE BAMHN4    W1THN4
     C                     MOVE 'U'       W1USRI
     C                     MOVE 'K'       W1ODKE
     C                     MOVE *BLANK    W1TEIS
     C                     Z-ADDBATOKU    W1TOKU
     C                     Z-ADDBANONY    W1NONY
     C                     MOVE BANKOJ    W1NKOJ
     C                     MOVE BANUKE    W1NUKE
     C                     MOVE BAMHN1    W1UHN1
     C                     MOVE BAMHN2    W1UHN2
     C                     MOVE BAMHN3    W1UHN3
     C                     MOVE BAMHN4    W1UHN4
     C                     MOVE BASHN1    W1SHN1
     C                     MOVE BASHN2    W1SHN2
     C                     MOVE BASHN3    W1SHN3
     C                     MOVE *BLANK    W1KANR
     C                     MOVELBAODRN    W1ODNO
     C                     MOVELBAINVN    W1NOBN
     C                     Z-ADD0         W1ODED
     C                     MOVE 'C'       W1NOKB
     C                     Z-ADDBANOYY    W1NOYY
     C                     Z-ADDBANOMM    W1NOMM
     C                     Z-ADDBANODD    W1NODD
     C****       BANONY    IFEQ 3347
%0001C                     Z-ADDBANOBN    W1NOBI
     C****                 ELSE
     C****                 Z-ADD0         W1NOBI
     C****                 END
     C                     Z-ADDBANOTM    W1NOTM
     C                     MOVE *BLANK    W1SENO
     C                     Z-ADDBATANK    W1TANK
     C                     MOVE *BLANK    W1TAKB
     C                     MOVE 'C'       W1SUTN
     C                     Z-ADD0         W1KING
     C                     Z-ADDBANOYY    W1JYRY
     C                     Z-ADDBANOMM    W1JYRM
     C                     Z-ADDBANODD    W1JYRD
     C                     MOVE '9'       W1JKKB
     C                     MOVE *BLANK    W1KENS
     C                     Z-ADD0         W1SEIY
     C                     Z-ADD0         W1SEIM
     C                     Z-ADD0         W1SEID
     C                     Z-ADD0         W1SIMY
     C                     Z-ADD0         W1SIMM
     C                     Z-ADD0         W1SIMD
     C                     MOVE *BLANK    W1JUNJ
     C                     MOVE *BLANK    W1MACH
     C                     Z-ADD0         W1MACY
     C                     Z-ADD0         W1MACM
     C                     Z-ADD0         W1MACD
     C                     Z-ADD0         W1GETU
     C                     MOVE *BLANK    W1KURK
     C                     MOVE BASBAN    W1SEBN
     C                     MOVELBAMHIN    W1UHIN
     C                     Z-ADD0         W1LTNO
     C                     Z-ADD0         W1PANO
     C                     MOVE *BLANK    W1MIKB
     C                     Z-ADD0         W1MIHK
     C                     Z-ADD0         W1MISU
     C                     MOVE *BLANK    W1STKB
     C                     Z-ADD0         W1RECN
     C                     Z-ADD*YEAR     W1URIY
     C                     Z-ADD*MONTH    W1URIM
     C                     Z-ADD*DAY      W1URID
     C                     MOVE *BLANK    W1TKKB
     C                     MOVE *BLANK    W1TUKA
     C                     Z-ADD0         W1RATE
     C                     MOVE *BLANK    W1BANK
     C                     MOVE *BLANK    W1KOZN
     C                     Z-ADD0         W1PAYY
     C                     Z-ADD0         W1PAYM
     C                     Z-ADD0         W1PAYD
     C                     Z-ADD0         W1PKIN
     C                     Z-ADD0         W1SAGK
     C                     MOVE 'S'       W1SYBT
     C                     MOVE '4'       W1SOBT
     C                     MOVE '04'      W1GYOM
     C                     MOVE BACARD    W1CARD
     C                     Z-ADDBASRYO    W1NOSU
     C                     Z-ADDBASYOS    W1SYUY
B5   C           BASYOS    IFEQ *ZERO
     C                     Z-ADDBAUSYS    W1SYUY
E5   C                     ENDIF
      *
     C                     Z-ADD0         W1HAKO
B5   C           BASYOS    IFNE 0
     C           BASRYO    DIV  BASYOS    W1HAKO
     C                     MVR            WHAK1   30
     C           WHAK1     IFNE 0
     C                     ADD  1         W1HAKO
     C                     END
E5   C                     END
      *
     C                     SETON                     U2
     C                     WRITEAB#WP321
TCHK1C*
TCHK1C           K#L7A     KLIST
TCHK1C                     KFLD           BANOYY
TCHK1C                     KFLD           BANOMM
TCHK1C                     KFLD           BANODD
TCHK1C                     KFLD           BATOKU
TCHK1C                     KFLD           BANONY
TCHK1C                     KFLD           BANKOJ
TCHK1C                     KFLD           BANUKE
TCHK1C                     KFLD           BANOBN
TCHK1C                     KFLD           BADEYY
TCHK1C                     KFLD           BADEMM
TCHK1C                     KFLD           BADEDD
TCHK2C           K#L7A@    KLIST
TCHK2C                     KFLD           BANOYY
TCHK2C                     KFLD           BANOMM
TCHK2C                     KFLD           BANODD
TCHK2C                     KFLD           BATOKU
TCHK2C                     KFLD           BANONY
TCHK2C                     KFLD           BANKOJ
TCHK2C                     KFLD           BANUKE
TCHK2C                     KFLD           BANOBN
TCHK2C           BANONY    IFEQ 5125
TCHK2C           K#L7A@    SETLLAB#PL75
TCHK2C                     ELSE
TCHK1C           K#L7A     SETLLAB#PL75
TCHK2C                     END
TCHK1C*
TCHK1C                     DO   *HIVAL
TCHK2C           BANONY    IFEQ 5125
TCHK2C           K#L7A@    READEAB#PL75                  91
TCHK2C                     ELSE
TCHK1C           K#L7A     READEAB#PL75                  91
TCHK2C                     END
TCHK1C   91                LEAVE
TCHK1C           PUSKJY    IFNE *BLANK
TCHK1C                     ITER
TCHK1C                     END
TCHK1C*
TCHK1C           PUODRN    IFNE *BLANK
TCHK1C           PUODRN    IFNE BAODRN
TCHK1C                     ITER
TCHK1C                     END
TCHK1C                     END
TCHK1C*
TCHK1C                     TIME           WWTIME
TCHK1C                     Z-ADD@@YMD     PUKODT
TCHK1C                     Z-ADDWTIME     PUKOTN
TCHK1C                     MOVEL#USER     PUKOME
TCHK1C                     Z-ADD@@YMD     PUSPDT
TCHK1C                     UPDATAB#PP751
TCHK1C*
TCHK1C           K#L7B     KLIST
TCHK1C                     KFLD           PUNOYY
TCHK1C                     KFLD           PUNOMM
TCHK1C                     KFLD           PUNODD
TCHK1C                     KFLD           PUCUST
TCHK1C                     KFLD           PUNONY
TCHK1C                     KFLD           PUNKOJ
TCHK1C                     KFLD           PUNUKE
TCHK1C                     KFLD           PUBINN
TCHK1C                     KFLD           PURLYY
TCHK1C                     KFLD           PURLMM
TCHK1C                     KFLD           PURLDD
TCHK1C                     KFLD           PUODRN
TCHK1C           K#L7B     CHAINAB#PL78              92
TCHK1C           *IN92     IFEQ *OFF
TCHK1C           P8SKJY    ANDEQ*BLANK
TCHK1C           P8SPDT    IFEQ *ZERO
TCHK1C                     TIME           WWTIME
TCHK1C                     Z-ADD@@YMD     P8KODT
TCHK1C                     Z-ADDWTIME     P8KOTM
TCHK1C                     MOVEL#USER     P8KONM
TCHK1C                     Z-ADD@@YMD     P8SPDT
TCHK1C                     Z-ADDWTIME     P8SPTM
TCHK1C                     MOVEL#USER     P8SPNM
TCHK1C                     UPDATAB#PP781
TCHK1C                     END
TCHK1C                     END
TCHK1C*
TCHK1C                     LEAVE
TCHK1C*
TCHK1C                     ENDDO
TCHK1C*
     C           JUMP      TAG
      *
E4   C                     END
E3   C                     END
E2   C                     END
E1   C                     END
E0   C  N10                END
