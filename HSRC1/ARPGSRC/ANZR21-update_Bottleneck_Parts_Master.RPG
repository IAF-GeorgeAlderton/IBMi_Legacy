     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #CTL30
     C                     ENDCS
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
     C*
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL*OFF      *IN89
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT010
     C******************************************************
     C           #FMT10    BEGSR
     C*
     C                     EXSR @F1INT
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN89
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKJ     WHEQ *ON
     C                     MOVEL'30'      @@ID
     C                     LEAVE
     C                     OTHER
     C                     EXSR @F1CHK
     C           *IN89     IFEQ *ON
     C                     ITER
     C                     END
     C                     MOVEL'20'      @@ID
     C                     LEAVE
     C                     ENDSL
      *
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  1ST SCREEN INITIALIZE
     C*----------------------------------------------------*
     C           @F1INT    BEGSR
     C*
     C                     MOVEL*BLANK    F1SHN1
     C                     MOVEL*BLANK    F1SHN2
     C                     MOVEL*BLANK    F1SHN3
     C                     MOVEL*BLANK    MSG
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHECK FMT010
     C*----------------------------------------------------*
     C           @F1CHK    BEGSR
     C*
     C                     SETOF                     3189
     C                     MOVEL*BLANK    MSG
     C*
     C                     DO
     C*
     C           F1SHN1    IFEQ *BLANK
     C                     SETON                     3189
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     END
     C*
     C           K#FCE1    KLIST
     C                     KFLD           F1SHN1
     C                     KFLD           F1SHN2
     C                     KFLD           F1SHN3
     C           K#FCE1    CHAINFCEPL01              91
     C           *IN91     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     3189
     C                     MOVELERR,3     MSG
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT020
     C******************************************************
     C           #FMT20    BEGSR
     C*
     C                     EXSR @F2INT
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT020
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN89
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKL     WHEQ *ON
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     OTHER
     C                     EXSR @F2CHK
     C           *IN89     IFEQ *ON
     C                     ITER
     C                     END
     C           *INKE     IFEQ *ON
     C                     EXSR @OUTF
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     END
     C           *INKH     IFEQ *ON
     C                     EXSR @DLTF
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     END
     C                     ENDSL
      *
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  2ND SCREEN INITIALIZE
     C*----------------------------------------------------*
     C           @F2INT    BEGSR
     C*
     C           K#FCE1    CHAINANZPP21              91
     C                     SELEC
     C           *IN91     WHEQ *ON
     C                     MOVEL*OFF      W@EXST  1
     C                     Z-ADD*ZERO     F2LOT#
     C                     MOVEL*BLANK    F2CMT1
     C                     MOVEL*BLANK    F2CMT2
     C           Z2SKJY    WHNE *BLANK
     C                     MOVEL*ON       W@EXST
     C                     Z-ADD*ZERO     F2LOT#
     C                     MOVEL*BLANK    F2CMT1
     C                     MOVEL*BLANK    F2CMT2
     C           Z2SKJY    WHEQ *BLANK
     C                     MOVEL*ON       W@EXST
     C                     Z-ADDZ2LOT#    F2LOT#
     C                     MOVELZ2CMT1    F2CMT1
     C                     MOVELZ2CMT2    F2CMT2
     C                     ENDSL
     C*
     C                     MOVEL*BLANK    MSG
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHECK FMT020
     C*----------------------------------------------------*
     C           @F2CHK    BEGSR
     C*
     C                     SETOF                     414289
     C                     MOVEL*BLANK    MSG
     C*
     C                     DO
     C*
     C           F2LOT#    IFEQ *ZERO
     C                     SETON                     4189
     C                     MOVELERR,4     MSG
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  OUTPUT
     C*----------------------------------------------------*
     C           @OUTF     BEGSR
     C*
     C                     CLEARANZPP211
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    Z2KOYY
     C                     Z-ADDWSSMMM    Z2KOMM
     C                     Z-ADDWSSDDD    Z2KODD
     C                     Z-ADDWSSHHH    Z2KOHH
     C                     Z-ADDWSSNNN    Z2KOSS
     C                     MOVEL#USER     Z2KOME
     C                     MOVEL#PGM      Z2KOPG
     C*
     C                     MOVELF1SHN1    Z2SHN1
     C                     MOVELF1SHN2    Z2SHN2
     C                     MOVELF1SHN3    Z2SHN3
     C                     Z-ADDF2LOT#    Z2LOT#
     C                     MOVELF2CMT1    Z2CMT1
     C                     MOVELF2CMT2    Z2CMT2
     C*
     C           W@EXST    IFEQ *ON
     C                     UPDATANZPP211
     C                     ELSE
     C                     WRITEANZPP211
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  DELETE
     C*----------------------------------------------------*
     C           @DLTF     BEGSR
     C*
     C                     DO
     C*
     C           K#DLTF    KLIST
     C                     KFLD           F1SHN1
     C                     KFLD           F1SHN2
     C                     KFLD           F1SHN3
