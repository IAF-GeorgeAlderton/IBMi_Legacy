     C   93                LEAVE
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    Z2SKYY
     C                     Z-ADDWSSMMM    Z2SKMM
     C                     Z-ADDWSSDDD    Z2SKDD
     C                     MOVEL#USER     Z2KOME
     C                     MOVEL#PGM      Z2KOPG
     C                     MOVEL'D'       Z2SKJY
     C*
     C                     UPDATANZPP211
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  CTL030
     C******************************************************
     C           #CTL30    BEGSR
     C*
     C                     EXSR @C3INT
     C                     Z-ADD1         W#RNP3  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL030
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP3
     C                     END
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKL     WHEQ *ON
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     OTHER
     C                     ENDSL
      *
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  @C3INT
     C*----------------------------------------------------*
     C           @C3INT    BEGSR
     C*
     C                     MOVEL*ON       *IN51
     C                     WRITECTL030
     C                     MOVEL*OFF      *IN51
     C                     MOVEL*OFF      *IN52
     C                     Z-ADD*ZERO     RRN3    40
     C*
     C           *LOVAL    SETLLANZPP21
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ANZPP21                  92
     C   92                LEAVE
     C           Z2SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL030
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELZ2SHN1    W@SHN1
     C           Z2SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELZ2SHN2    W@SHN2
     C           Z2SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELZ2SHN3    W@SHN3
     C                     MOVELW@SHIN    S3PART
     C                     Z-ADDZ2LOT#    S3LOT#
     C                     MOVELZ2CMT1    S3CMT1
     C                     MOVELZ2CMT2    S3CMT2
     C*
     C                     ADD  1         RRN3
     C                     WRITESFL030
     C*
     C                     ENDDO
     C*
     C           RRN3      IFEQ *ZERO
     C                     CLEARSFL030
     C                     Z-ADD1         RRN3
     C                     WRITESFL030
     C                     END
     C*
     C                     ENDSR
