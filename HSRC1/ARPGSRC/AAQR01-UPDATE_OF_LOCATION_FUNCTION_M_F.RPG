     H            Y.
     F** AAQR01 ******************************
     F*    UPDATE OF LOCATION FUNCTION M/F   *
     F*               H.ITO 86.10.07 *
     F****************************** AAQR01 **
     FAAQPW01 CF  E                    WORKSTN
     FAAQPL01 UF  E           K        DISK                      A
     E                    KOCD    1   3  1   KONM    6   更新区分
     E                    ER      1  14 60               エラーＭＳＧ
     I            DS
     I                                        1   80DBSKHZ
     I                                        1   40DBSKYY
     I                                        5   60DBSKMM
     I                                        7   80DBSKDD
     I            DS
     I                                        1   80DBKOHZ
     I                                        1   40DBKOYY
     I                                        5   60DBKOMM
     I                                        7   80DBKODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20DBKOHH
     I                                        3   40DBKOSS
     C           *ENTRY    PLIST
     C                     PARM           USER   10        ﾏｰﾅﾞｰ xb
     C                     Z-ADD0         DBSKHZ
     C*--------------*
     C*  画面－１  *
     C*--------------*
     C           STP1      TAG
     C                     EXFMTAAQPW011
     C                     SETOF                     010203
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*---------------*
     C*  更新区分   *
     C*---------------*
     C                     SETOF                     30
     C                     Z-ADD1         A       10
     C           KOSN      LOKUPKOCD,A                   30
     C           *IN30     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KONM,A    WKOSN
     C*  ﾃcﾆﾞｭchﾎﾞ]  *
     C           DBNKOJ    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
     C*  lcﾜhﾎﾞ]  *
     C           DBNTUR    IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
     C*---------------------*
     C*   追加　の　場合  *
     C*---------------------*
     C           KEY1      KLIST
     C                     KFLD           DBNKOJ
     C                     KFLD           DBNTUR
     C                     SETOF                     30
     C           KEY1      CHAINAAQPL011             30
     C           KOSN      IFEQ '2'
     C           *IN30     IFEQ '0'
     C           DBSKJY    IFEQ 'D'
     C           DBSKHZ    ANDLE*DATE
     C                     GOTO SP1
     C                     END
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*---------------------*
     C*   変更　の　場合  *
     C*---------------------*
     C           KOSN      IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
     C           DBSKJY    IFEQ 'D'
     C           DBSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*---------------------*
     C*   取消　の　場合  *
     C*---------------------*
     C           KOSN      IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
     C           DBSKJY    IFEQ 'D'
     C           DBSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           SP1       TAG
     C*
     C           KOSN      IFEQ '2'
     C                     MOVE *BLANK    WHKOJ
     C                     MOVE *BLANK    WHTUR
     C                     Z-ADD0         DBSHIY
     C                     MOVE *BLANK    DBYOSI
     C                     Z-ADD0         DBHKOJ
     C                     Z-ADD0         DBHTUR
     C                     END
     C                     MOVE DBNKOJ    WNKOJ
     C                     MOVE DBNTUR    WNTUR
     C           KOSN      IFNE '2'
     C                     MOVE DBHKOJ    WHKOJ
     C                     MOVE DBHTUR    WHTUR
     C                     END
     C*--------------*
     C*  画面－２  *
     C*--------------*
     C           STP2      TAG
     C                     EXFMTAAQPW012
     C                     SETOF                     010203
     C                     SETOF                     0499
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    KOSN
     C                     MOVE *BLANK    DBNKOJ
     C                     MOVE *BLANK    DBNTUR
     C                     GOTO STP1
     C                     END
     C*  s]f]nﾃﾜﾌﾞ]k ﾃcﾆﾞｭc  *
     C           WHKOJ     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,9      MSG
     C                     GOTO STP2
     C                     END
     C           WHKOJ     IFLT '0'
     C                     SETON                     0199
     C                     MOVE ER,10     MSG
     C                     GOTO STP2
     C                     END
     C                     MOVE WHKOJ     DBHKOJ
     C*  s]f]nﾃﾜﾌﾞ]k lcﾜ  *
     C           WHTUR     IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,11     MSG
     C                     GOTO STP2
     C                     END
     C           WHTUR     IFLT '00'
     C                     SETON                     0299
     C                     MOVE ER,12     MSG
     C                     GOTO STP2
     C                     END
     C                     MOVE WHTUR     DBHTUR
     C*  ﾆﾝihﾎﾞ]  *
     C           DBSHIY    IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,13     MSG
     C                     GOTO STP2
     C                     END
     C*  ﾑcﾆﾌﾞ]ﾃﾞc  *
     C           DBYOSI    IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,14     MSG
     C                     GOTO STP2
     C                     END
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO STP2
     C                     END
     C                     MOVE WNKOJ     MNKOJ
     C                     MOVE WNTUR     MNTUR
     C                     MOVE WKOSN     MKOSN
     C*
     C           KOSN      IFEQ '0'
     C                     MOVE 'D'       DBSKJY
     C                     Z-ADD*DATE     DBSKHZ
     C                     ELSE
     C                     MOVE *BLANK    DBSKJY
     C                     Z-ADD0         DBSKHZ
     C                     END
     C                     Z-ADD*DATE     DBKOHZ
     C                     TIME           WTIME
     C                     MOVELUSER      DBKOME
     C           *IN30     IFEQ '0'
     C                     UPDATAAQPL011
     C                     ELSE
     C                     WRITEAAQPL011
     C                     END
     C*
     C                     MOVE *BLANK    KOSN
     C                     MOVE *BLANK    DBNKOJ
     C                     MOVE *BLANK    DBNTUR
     C                     GOTO STP1
     C*
**  (KOCD/KONM)
0CANCEL
1CHANGE
2ADD
**  ER
E-01 UPDATE INSTRUCTION <0 1 2>.
E-02 FACTORY INSTRUCTION ISN'T INPUT.
E-03 PASSAGE INSTRUCTION ISN'T INPUT.
E-04 ADD WAS APPOINTED BUT M/F EXIST.
E-05 CHANGE WAS APPOINTED BUT M/F DON'T EXIST.
E-06 CHANGE WAS APPOINTED BUT M/F IS CANCELLED ALREADY.
E-07 CANCEL WAS APPOINTED BUT M/F DON'T EXIST.
E-08 CANCEL WAS APPOINTED BUT M/F IS CANCELLED ALREADY.
E-09 CONVERSION LOCATION(FACTORY) ISN'T INPUT .
E-10 CONVERSION LOCATION(FACTORY) MUST BE NUMBER.
E-11 CONVERSION LOCATION(PASSAGE) ISN'T INPUT .
E-12 CONVERSION LOCATION(PASSAGE) MUST BE NUMBER.
E-13 SORT INSTRUCTION  ISN'T INPUT.
E-14 PAPER NUMBER ISN'T INPUT.
