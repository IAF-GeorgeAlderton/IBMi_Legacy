     H            Y/                                    1
     H** ALBR33 *******************************************************
     H*  WORKER CODE M/F INQUIRY BY NAME                              *
     H*  LEC     2020.02.03                                           *
     H*****************************************************************
     FALBPW33 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFL01
     FALBPP30 IF  E           K        DISK
      *================================================================
     E                    ER      1   2 65
     E                    PGM        10  1
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C*  MAIN ROUTINE
     C*===============================================================
     C                     EXSR #INIT
      *
     C           *IN01     DOUEQ*ON
      *
     C                     EXFMTDSP01
     C           *IN01     IFEQ *ON
     C                     LEAVE
     C                     ELSE
     C                     EXSR CHK1
     C           *IN99     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN98     DOUEQ*ON
      *
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
      *
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     SETOF                     7071
     C                     Z-ADD$$RRN     RRN1
     C*------------------------------------------------------------
     C                     SELEC
     C* <F3> END
     C           *INKC     WHEQ *ON
     C                     MOVE *ON       *IN98
     C* <PAGE UP/DOWN>
     C           *IN73     WHEQ *ON
      * <ENTR>
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFL01                95
     C           *IN95     IFEQ *OFF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
      *
     C                     MOVELW@PGM     D1PGM
     C                     MOVELW@PGM     S1PGM
      *
     C                     Z-ADD0         P1WKCD
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
      * SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      * SET INITIAL DATA
     C           *LOVAL    SETLLAM#PP31
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AM#PP31                  90
     C   90                LEAVE
     C*
     C           R3SKJY    IFEQ 'D'                        DELETE CODE
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELR3WKCD    S1WKCD
      * GET NAME
     C           R3WKCD    CHAINALBPL30              99
     C           *IN99     IFEQ *OFF
     C                     MOVELALWKNM    S1WKNM
     C                     ELSE
     C                     MOVE *BLANK    S1WKNM
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *-----------------------------------------
      * NO DATA *
     C           RRN1      IFEQ 0
     C                     Z-ADD0         S1WKCD
     C                     MOVELER,1      S1WKNM
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *-----------------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1
      *
     C                     ENDSR
** ER,
 ** NO DATA **

