     C           @WRTE2    BEGSR
     C*
     C                     CLEARALDPP301
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    A3KSYY
     C                     Z-ADDWSSMMM    A3KSMM                  MONTH
     C                     Z-ADDWSSDDD    A3KSDD                  DAY
     C                     Z-ADDWSSHHH    A3KSJI                  HOUR
     C                     Z-ADDWSSNNN    A3KSPN                  MINUTE
TCHKGC                     MOVEL'ALDR2Y'  A3UPGM
     C                     MOVE WORKER    A3OPER           WORKER
     C                     MOVELWUSRID    A3OPNM           NAME
     C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
     C                     MOVE EKSHN1    A3SHN1           INTERNAL PART
     C                     MOVE EKSHN2    A3SHN2           INTERNAL PART
     C                     MOVE EKSHN3    A3SHN3           INTERNAL PART
TCHK8C*                    Z-ADDSYY       A3SYYY
TCHK8C*                    Z-ADDSMM       A3SYMM
TCHK8C*                    Z-ADDSDD       A3SYDD
TCHK8C                     Z-ADDWSSYYY    A3SYYY
TCHK8C                     Z-ADDWSSMMM    A3SYMM
TCHK8C                     Z-ADDWSSDDD    A3SYDD
     C                     Z-ADDWSSHHH    A3SYJI           BIN
     C                     Z-ADDWSSNNN    A3SYFN
     C* FINISHED STORAGE(PART MASTER LOCATION)
     C                     MOVE EKLOC1    A3TKR1           NEW
     C                     MOVE EKLOC2    A3TKR2
     C                     MOVE EKLOC3    A3TKR3
     C                     MOVE EKLOC4    A3TKR4
     C*
     C                     MOVE *BLANK    A3MHN1           USER PART
     C                     MOVE *BLANK    A3MHN2
     C                     MOVE *BLANK    A3MHN3
     C                     MOVE *BLANK    A3MHN4
     C                     MOVE EKMHN1    A3MHN1           USER PART
     C                     MOVE EKMHN2    A3MHN2
     C                     MOVE EKMHN3    A3MHN3
     C                     MOVE EKMHN4    A3MHN4
     C                     MOVE EKSYOS    A3SSYS           UNIT QTY
     C                     MOVE EKSYOS    A3USYS           USER UNIT QTY
     C                     MOVE EKNONY    A3NONY           DELIVERY POINY
     C                     MOVE EKNKOJ    A3NKOJ                    FACTORY
     C                     MOVE EKNUKE    A3NUKE                    RECV
     C           EKNONY    CAT  EKNUKE:0  A3TOPX    P      TOPIX CODE
     C                     MOVE *BLANK    A3SALE           EFU/KANBAN
     C                     MOVE @@SERL    A3SERL
     C                     WRITEALDPP301
     *
     * update shipment information in nzupp01.
     C                     EXSR UPDSHP
      *
TCHLHC           B2D       SETLLALDPP65
TCHLHC                     DO   *HIVAL
TCHLHC           B2D       READEALDPP65                  99
TCHLHC   99                LEAVE
TCHLHC           AFRDAT    IFEQ *ZERO
TCHLHC                     Z-ADDWSSDAT    AFDATE
TCHLHC                     Z-ADDWSSTM6    AFTIME
TCHLHC                     MOVEL#USER     AFUSER
TCHLHC                     MOVEL#WSID     AFWSID
TCHLHC                     MOVEL#PGM      AFPGID
TCHLHC                     MOVELWORKER    AFTMCD
TCHLHC*
TCHLHC                     MOVELWAPICS    AFAKAN
TCHLHC                     MOVELA3ZETI    AFAZET
TCHLHC                     MOVELA3TEHI    AFALOT
TCHLHC                     MOVELA3PAGE    AFAPAG
TCHLHC                     Z-ADDWSSDAT    AFRDAT
TCHLHC                     Z-ADDWSSTM6    AFRTIM
TCHLHC                     MOVELWORKER    AFRTMC
TCHLHC*
TCHLHC                     UPDATALDPP651
TCHLHC                     END
TCHLHC                     LEAVE
TCHLHC                     ENDDO
TCHLHC           *IN99     IFEQ *ON
TCHL5C                     EXSR @AU#11
TCHLHC                     END
TCHL5C*
      *
     C                     EXSR #ASJ#2
      *
     C                     ENDSR
