     C                     ENDSR
     C**************************************************************************
     C*      WRITE RECORDS IN ORDER FILE TO ASJ
      **************************************************************************
      *  Check to see if Last Process is not at IAF, if not write to Out-
      *       going file.
      *
     C           @CHKLP    BEGSR
      *
      * key list
     C           K@AAMP    KLIST
     C                     KFLD           EKSHN1
     C                     KFLD           EKSHN2
     C                     KFLD           EKSHN3
      *
      * get process codes for part number...
     C           K@AAMP    CHAINAAMPL11              51
     C           *IN51     IFEQ *OFF
      *
     C                     Z-ADD*ZERO     LASTPR  40
     C                     Z-ADD*ZERO     BX      40
      *
      * find last process code for part number...
     C                     DO   15        BX
      *
     C           BMN,BX    IFNE *ZERO
     C                     Z-ADDBMN,BX    LASTPR
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * if last process is not done at IAF, then write to retrieval outgoing fil
     C           LASTPR    IFNE *ZERO
     C           LASTPR    ANDNE111
     C                     EXSR @WRTRV
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *   Write to Retrieval Out Going File.
      *
     C           @WRTRV    BEGSR
      *
     C                     CLEARALDPP791
      *
     C                     Z-ADDWSSDAT    ARKODT           update date
     C                     Z-ADDWSSTM6    ARKOTM           update time
     C                     MOVELWORKER    ARWKCD           worker code
     C                     MOVELWORKNM    ARWKNM           worker name
     C                     MOVEL#PGM      ARPGID           pgm id
     C                     Z-ADDWSSDAT    ARCODT           scan date
     C                     Z-ADDWSSTM6    ARCOTM           scan time
      *
     C                     MOVE EKSHN1    ARSHN1           internal part1
     C                     MOVE EKSHN2    ARSHN2           internal part2
     C                     MOVE EKSHN3    ARSHN3           internal part3
      *
     C                     MOVE EKMHN1    ARMHN1           user part 1
     C                     MOVE EKMHN2    ARMHN2           user part 2
     C                     MOVE EKMHN3    ARMHN3           user part 3
     C                     MOVE EKMHN4    ARMHN4           user part 4
      *
     C                     MOVE EKLOC1    ARTBN1           final loc 1
     C                     MOVE EKLOC2    ARTBN2           final loc 2
     C                     MOVE EKLOC3    ARTBN3           final loc 3
     C                     MOVE EKLOC4    ARTBN4           final loc 4
      *
     C                     Z-ADDLASTPR    ARCKBM           last process code
      *
     C                     Z-ADDEKTOKU    ARTOKU           customer code
     C                     MOVE EKNONY    ARNONY           delivery code
     C                     MOVE EKNKOJ    ARNKOJ           factory code
     C                     MOVE EKNUKE    ARNUKE           dock code
      *
     C                     Z-ADDEKSRYO    ARSRYO           quantity
     C                     MOVE EKODRN    ARORDN           order number
      *
     C                     WRITEALDPP791
      *
     C                     ENDSR
     C**************************************************************************
     C           #ASJ      BEGSR
      *
     C                     CLEARGDGPP051
TCHK8C*                    Z-ADD*YEAR     IAKOYY
TCHK8C*                    Z-ADD*MONTH    IAKOMM
TCHK8C*                    Z-ADD*DAY      IAKODD
TCHK8C                     TIME           WSDT
TCHK8C                     Z-ADDWSSYYY    IAKOYY
TCHK8C                     Z-ADDWSSMMM    IAKOMM
TCHK8C                     Z-ADDWSSDDD    IAKODD
     C                     MOVELWORKER    IAKOME
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
     C                     MOVE A1ORDR    IAODER
     C                     MOVE A1ZETI    IAZETI
     C                     MOVE A1SEHI    IASEIH
     C                     MOVE A1LOTN    IARENB
     C                     MOVE A1SHN1    IAHIN1
     C                     MOVE A1SHN2    IAHIN2
     C                     MOVE A1SHN3    IAHIN3
     C                     Z-ADDA1SSYS    IASYOS
     C                     ADD  1         IAMAIS
TCHK8C*                    Z-ADD*YEAR     IAHAYY
TCHK8C*                    Z-ADD*MONTH    IAHAMM
TCHK8C*                    Z-ADD*DAY      IAHADD
TCHK8C                     Z-ADDWSSYYY    IAHAYY
TCHK8C                     Z-ADDWSSMMM    IAHAMM
TCHK8C                     Z-ADDWSSDDD    IAHADD
     C                     WRITEGDGPP051
      *
TCHK C                     EXSR #IICSD
TCHK  *
     C                     ENDSR
TCHK C**************************************************************************
TCHK C*      WRITE RECORDS IICSD
TCHK C**************************************************************************
TCHK C           #IICSD    BEGSR
TCHK  *
TCHK C           *HIVAL    SETGTIICSD01
TCHK C                     READPIICSD01                  94
TCHK C           *IN94     IFEQ '0'
TCHK C                     Z-ADDIIIDNO    ID#     60
TCHK C                     ELSE
