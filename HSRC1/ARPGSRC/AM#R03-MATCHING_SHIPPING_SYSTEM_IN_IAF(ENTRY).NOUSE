     C                     Z-ADDSDATE     R1KOHZ
     C                     Z-ADDSTIME     R1KOTI
     C                     MOVELWORKER    R1KOME
     C                     MOVEL#PGM      R1KPGM
     C                     Z-ADDSDATE     R1SSHZ
     C                     Z-ADDSTIME     R1SSTI
     C                     MOVELWORKER    R1USCD
     C                     MOVEL*BLANK    R1USNM
     C                     MOVELWKHNTE    R1HNTE
     C                     MOVELMSG       R1ERR
     C                     MOVELTICKET    R1TICK
     C                     MOVELTISURT    R1SURT
     C                     MOVELTISHID    R1SHID
     C                     MOVELTISHIT    R1SHIT
     C                     MOVELTISMEI    R1SMEI
     C                     MOVELTIDOCK    R1DOCK
     C                     MOVELTIORD#    R1ORD#
     C                     MOVELTIPALT    R1PALT
     C                     MOVELTINONY    R1NONY
     C                     MOVELTINKOJ    R1NKOJ
     C                     MOVELTINUKE    R1NUKE
     C                     MOVELTIIAFB    R1IAFB
     C                     MOVELTIIAFP    R1IAFP
     C                     MOVELTIPPUL    R1PPUL
     C                     MOVELTIEXT     R1EXT
     C                     MOVELTISAT     R1SAT
     C                     MOVELW2D       R12D
     C                     MOVELSUBR      R12URT
     C                     MOVELSHDT      R12HID
     C                     MOVELSHTM      R12HIT
     C                     MOVELDEST      R12AMC
     C                     MOVELDCCOD     R12OCK
     C                     MOVELORNO      R12RD#
