TCHKSC           QRA,XX    IFEQ *BLANK
TCHKSC                     LEAVE
TCHKSC                     END
TCHKSC                     ADD  1         YY
TCHKSC                     MOVELQRA,XX    Q20,YY
TCHKSC                     ENDDO
TCHKSC                     MOVEAQ20       W@SRL# 14
TCHKSC*
TCHKSC                     MOVEL*ON       *IN89
TCHKSC*
TCHKSC                     ENDDO
TCHKSC*
TCHKSC                     DO
TCHKSC*
TCHKSC           *IN89     IFEQ *OFF
TCHKSC                     MOVE ERR,20    MSG
TCHKSC                     MOVEL*ON       *IN30
TCHKSC                     MOVEL'1'       W@ECOD  1
TCHKSC                     EXSR @QSSER
TCHKSC                     LEAVE
TCHKSC                     END
TCHKSC*
TCHKSC                     MOVELEKNOYY    W@A04A  4
TCHKSC                     MOVELEKNOMM    W@A02A  2
TCHKSC                     MOVELEKNODD    W@A02B  2
TCHKSC           W@A04A    IFEQ W@NOYY
TCHKSC           W@A02A    ANDEQW@NOMM
TCHKSC           W@A02B    ANDEQW@NODD
TCHKSC           EKMHN1    ANDEQW@MHN1
TCHKSC           EKMHN2    ANDEQW@MHN2
TCHKSC           EKMHN3    ANDEQW@MHN3
TCHKSC           EKMHN4    ANDEQW@MHN4
TCHKSC                     ELSE
TCHKSC                     MOVE ERR,13    MSG
TCHKSC                     MOVEL*ON       *IN30
TCHKSC                     MOVEL'2'       W@ECOD  1
TCHKSC                     EXSR @QSSER
TCHKSC                     LEAVE
TCHKSC                     END
TCHKSC*
TCHKSC           W@SRL#    SETLLALDPL45
TCHKSC                     DO   *HIVAL
TCHKSC           W@SRL#    READEALDPL45                  96
TCHKSC   96                LEAVE
TCHKSC           AEERR     IFEQ *BLANK
TCHKSC                     MOVE ERR,8     MSG
TCHKSC                     MOVEL*ON       *IN30
TCHKSC                     MOVEL'2'       W@ECOD  1
TCHKSC                     EXSR @QSSER
TCHKSC                     LEAVE
TCHKSC                     END
TCHKSC                     ENDDO
TCHKSC*
TCHKSC                     ENDDO
TCHKSC*
TCHKSC                     ENDSR
     C**************************************************************************
     C*    TOTAL
     C**************************************************************************
     C           #TOT      BEGSR
     C*
     C           120       SUB  TOTAL     EMPTY
     C                     Z-ADD120       GTOTL
     C*
     C                     ENDSR
     C**************************************************************************
     C*     WIRTE
     C**************************************************************************
     C           @OUT      BEGSR
      *
     C           @D        IFEQ '1'
     C                     EXSR @WRT
     C                     ELSE
     C                     EXSR @WRTX
     C                     ENDIF
      *
      * check last process.
     C                     EXSR @CHKLP
      *
     C                     ADD  1         TOTAL
     C                     CLEARDSP01
     C                     CLEARDSP02
     C                     CLEARDSP03
     C                     CLEARDSP04
     C                     CLEARDSP05
TCHKSC                     CLEARDSP06
      *
     C                     EXFMTDSP97
     C                     MOVE '01'      @@ID
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT      BEGSR
     C*
     C                     MOVE *BLANK    @@SERL 18
     C           BARCD0    SETLLAB#PL71
     C           *IN90     DOUEQ*ON
     C           BARCD0    READEAB#PL71                  90
     C           *IN90     IFEQ *OFF
     C           EKDEYY    IFNE *ZERO
     C                     ITER
     C                     ELSE
TCHK8C*                    Z-ADD*YEAR     EKKOYY
TCHK8C*                    Z-ADD*MONTH    EKKOMM
TCHK8C*                    Z-ADD*DAY      EKKODD
     C                     TIME           WSDT
TCHK8C                     Z-ADDWSSYYY    EKKOYY
TCHK8C                     Z-ADDWSSMMM    EKKOMM
TCHK8C                     Z-ADDWSSDDD    EKKODD
     C                     Z-ADDWSSHHH    EKKOHH
     C                     Z-ADDWSSNNN    EKKOMN
     C                     MOVEL#USER     EKKOME
TCHK8C*                    Z-ADD*YEAR     EKDEYY
TCHK8C*                    Z-ADD*MONTH    EKDEMM
TCHK8C*                    Z-ADD*DAY      EKDEDD
TCHK8C*                    TIME           EKDETM
TCHK8C                     Z-ADDWSSYYY    EKDEYY
TCHK8C                     Z-ADDWSSMMM    EKDEMM
TCHK8C                     Z-ADDWSSDDD    EKDEDD
TCHK8C                     Z-ADDWSSTM6    EKDETM
     C                     MOVE EKSYOS    EKSRYO
     C           BARKBN    IFNE 'I'
TCHLSC           BARKBN    ANDNE'S'
     C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
     C                     MOVELA3TEHI    EKLTNO
     C                     MOVELA3PAGE    EKISNO
     C                     ELSE
     C                     MOVE IIAF      WIAF             IAF KANBAN
     C                     MOVE A1LOTN    EKLTNO
     C                     ENDIF
     C                     UPDATAB#PP701
     C                     MOVE EKSERL    @@SERL 18
TCHKSC           EKNONY    IFEQ '4044'
TCHKSC                     EXSR @QSSOT
TCHK2C                     END
TCHLAC           EKNONY    IFEQ '0170'
TCHLAC                     EXSR @ACZ#1
TCHLAC                     END
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           @I        IFEQ '2'
