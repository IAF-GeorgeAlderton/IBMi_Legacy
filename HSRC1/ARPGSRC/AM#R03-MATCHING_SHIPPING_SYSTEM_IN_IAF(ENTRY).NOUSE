     C                     MOVELPART      R12HN
     C                     MOVELBXNBR     R12OX#
     C                     MOVELWKIAFB    R12AFB
     C                     MOVELWKIAFP    R12AFP
     C                     MOVELWKSHME    R1SHME
     C                     WRITEAM#PP011
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * PALLET#                                            *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     TIME           WTIME
      *2Dかんばんよりセット
     C                     MOVELSHDT      KKSHID  8
     C                     MOVELSHTM      KKSHIT  6
     C                     MOVELSUBR      KKSURT  9
     C                     Z-ADD0         KKNONY  40
     C                     MOVEL*BLANK    KKNKOJ  1
     C                     MOVEL*BLANK    KKNUKE  4
     C           DEST      CHAINAL#PP211             49
     C           *IN49     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     49
     C                     ENDIF
     C           *IN49     IFEQ '0'
     C                     MOVELC2NONY    KKNONY
     C                     MOVELC2NKOJ    KKNKOJ
     C                     ENDIF
     C                     MOVELDCCOD     KKNUKE
     C                     MOVELORNO      KKORD# 12
     C                     MOVELPALT      KKPALT  2
     C                     MOVEL'0'       GET     1
     C           KEY01     SETLLAL#PL031
     C           KEY01     READEAL#PL031                 80
     C           *IN80     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAMHN     IFEQ PART
     C           CABOX#    ANDEQBXNBR
     C           CAIAFB    ANDEQTIIAFB
     C           CAIAFP    ANDEQTIIAFP
     C           CAPLDT    ANDEQ0
     C                     MOVEL'1'       GET
     C                     Z-ADDSDATE     CAPLDT
     C                     Z-ADDSTIME     CAPLTI
     C                     UPDATAL#PL031
     C                     ENDIF
     C                     ENDIF
     C           GET       IFEQ '0'
     C           KEY01     READEAL#PL031                 80
     C                     ENDIF
     C                     ENDDO
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      * PALLET#                                            *
      *----------------------------------------------------*
     CSR         #SB901    BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           KKSHID  8
     C                     KFLD           KKSHIT  6
     C                     KFLD           KKSURT  9
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKORD# 12
     C                     KFLD           KKPALT  2
      *
     C                     TIME           WTIME
      *2Dかんばんよりセット
     C                     MOVELSHDT      KKSHID  8
     C                     MOVELSHTM      KKSHIT  6
     C                     MOVELSUBR      KKSURT  9
     C                     Z-ADD0         KKNONY  40
     C                     MOVEL*BLANK    KKNKOJ  1
     C                     MOVEL*BLANK    KKNUKE  4
     C           DEST      CHAINAL#PP211             49
     C           *IN49     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     49
     C                     ENDIF
     C           *IN49     IFEQ '0'
     C                     MOVELC2NONY    KKNONY
     C                     MOVELC2NKOJ    KKNKOJ
     C                     ENDIF
     C                     MOVELDCCOD     KKNUKE
     C                     MOVELORNO      KKORD# 12
     C                     MOVELPALT      KKPALT  2
      * GET : 0 NO DATA
      *     : 1 GET DATA
      *     : 2 SCANNED DATA
      *     : 3 PALLET# ERR
     C                     MOVEL*BLANK    WKIAFB  3
     C                     MOVEL*BLANK    WKIAFP  3
     C                     MOVEL*BLANK    WKSHME 20
     C                     MOVEL'0'       GET     1
     C           KEY01     SETLLAL#PL031
     C           KEY01     READEAL#PL031            N    80
     C           *IN80     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAMHN     IFEQ PART
     C           CABOX#    ANDEQBXNBR
     C                     MOVELCAIAFB    WKIAFB
     C                     MOVELCAIAFP    WKIAFP
     C                     MOVELCASHME    WKSHME
      *品番、ボックス＃が同じときＩＡＦ便＃とパレット＃
     C           CAIAFB    IFEQ TIIAFB
     C           CAIAFP    ANDEQTIIAFP
     C           CAPLDT    IFEQ 0
     C                     MOVEL'1'       GET
     C                     ELSE
     C                     MOVEL'2'       GET
     C                     ENDIF
     C                     ELSE
     C                     MOVEL'3'       GET
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C           KEY01     READEAL#PL031            N    80
     C                     ENDDO
      *
     C                     SELEC
     C           GET       WHEQ '1'
     C           GET       WHEQ '0'
     C                     MOVE ERR,27    MSG
     C                     MOVE '27'      A5ERID
     C                     SETON                     3033
     C           GET       WHEQ '2'
     C                     MOVE ERR,28    MSG
     C                     MOVE '28'      A5ERID
     C                     SETON                     3033
     C           GET       WHEQ '3'
     C                     MOVEL'NG'      WKHNTE  2
     C                     MOVE ERR,29    MSG
     C                     MOVE '29'      A5ERID
     C                     SETON                     3033
     C                     ENDSL
      *
     CSR         ESB901    ENDSR
      *----------------------------------------------------*
