     *----------------------------------------------------*
     * Update NZUPL01 with Shipment Date and Time         *
     *----------------------------------------------------*
     *
    C           UPDSHP    BEGSR
      *
      * update NZUPL01
      *
     C           N2KEY     KLIST
     C                     KFLD           A3ZETI
     C                     KFLD           A3TEHI
     C                     KFLD           A3PAGE
     C*
     C           N2KEY     SETGTNZUPL011
     C           N2KEY     REDPENZUPL011                 51
      *
      * if id/lot/page num is found, update record and leave.
     C           *IN51     IFEQ *OFF
     C                     Z-ADDWSSDAT    N2KOHZ
     C                     Z-ADDWSSTM6    N2KOTI
     C                     MOVELWUSRID    N2KOME
     C                     MOVEL#PGM      N2KOPG
     C                     Z-ADDWSSDAT    N2DEHZ
     C                     Z-ADDWSSTM6    N2DETI
     C                     UPDATNZUPL011
     C                     ENDIF
      *
    C                     ENDSR
     *----------------------------------------------------*
     * update NZUPL11 with passthru kanban ship info
     *----------------------------------------------------*
    C           UPDSHI    BEGSR
     C*
     C           N3KEY     KLIST
     C                     KFLD           A1ZETI
     C                     KFLD           A1ORDR
     C                     KFLD           LOTN    4
      *
     C                     MOVE A1LOTN    LOTN
     C           N3KEY     CHAINNZUPL111             51
      *
      * if id/ord#/lot# is found update record, else add record.
     C           *IN51     IFEQ *OFF
      *
     C                     MOVELWSSDAT    N3KOHZ
     C                     MOVELWSSTM6    N3KOTI
     C                     MOVELWORKER    N3KOME
     C                     MOVEL#PGM      N3KOPG
     C                     MOVE '0'       N3ONOF
     C                     MOVELWSSDAT    N3DEHZ
     C                     MOVELWSSTM6    N3DETI
      *
     C                     MOVELA1SHN1    N3SHN1
     C                     MOVELA1SHN2    N3SHN2
     C                     MOVELA1SHN3    N3SHN3
     C                     MOVELA1TKR1    N3JTK1
     C                     MOVELA1TKR2    N3JTK2
     C                     MOVELA1TKR3    N3JTK3
     C                     MOVELA1TKR4    N3JTK4
      *
     C                     MOVE BARKBN    N3KANR
     C                     MOVELA1ZETI    N3SZET
     C                     MOVELA1ORDR    N3SORD
     C                     MOVE A1SEHI    N3STYP
     C                     MOVELA1LOTN    N3SLOT
     C                     MOVELCHKD7     N3CHKD
      *
     C                     EXSR GETINF
      *
     C                     UPDATNZUPL111
      *
     C                     ELSE
      *
     C                     CLEARNZUPL111
     C                     MOVELA1ZETI    N3ZETI
     C                     MOVELA1ORDR    N3ORDN
     C                     MOVELLOTN      N3LOTN
      *
     C                     MOVELWSSDAT    N3KOHZ
     C                     MOVELWSSTM6    N3KOTI
     C                     MOVELWORKER    N3KOME
     C                     MOVEL#PGM      N3KOPG
     C                     MOVE '0'       N3ONOF
     C                     MOVELWSSDAT    N3DEHZ
     C                     MOVELWSSTM6    N3DETI
      *
     C                     MOVELA1SHN1    N3SHN1
     C                     MOVELA1SHN2    N3SHN2
     C                     MOVELA1SHN3    N3SHN3
     C                     MOVELA1TKR1    N3JTK1
     C                     MOVELA1TKR2    N3JTK2
     C                     MOVELA1TKR3    N3JTK3
     C                     MOVELA1TKR4    N3JTK4
      *
     C                     MOVE BARKBN    N3KANR
     C                     MOVELA1ZETI    N3SZET
     C                     MOVELA1ORDR    N3SORD
     C                     MOVE A1SEHI    N3STYP
     C                     MOVELA1LOTN    N3SLOT
     C                     MOVELCHKD7     N3CHKD
      *
     C                     EXSR GETINF
      *
     C                     WRITENZUPL111
     C                     ENDIF
      *
    C                     ENDSR
      *
     *----------------------------------------------------*
     * get order info from invoice management
     *----------------------------------------------------*
    C           GETINF    BEGSR
     C*
     C           GDKEY     KLIST
     C                     KFLD           A1SHN1
     C                     KFLD           A1SHN2
     C                     KFLD           A1SHN3
     C*
     C           GDKEY     SETGTGDGPP251
     C           GDKEY     REDPEGDGPP251                 51
      *
      * if read until order number is found.
     C           *IN51     DOWEQ*OFF
      *
     C                     MOVE IEODER    IEORCH  6
     C           IEORCH    IFEQ A1ORDR
     C                     Z-ADDIESYOS    N3KSYU           BOX QTY
     C                     MOVE 'C'       N3KSTI           BOX TYPE
     C                     MOVELIEYMD     N3DEJD           DEPART YMD
     C                     LEAVE
     C                     ENDIF
      *
     C           GDKEY     REDPEGDGPP251                 51
     C                     ENDDO
      *
    C                     ENDSR
      *
      **************************************************************************
      *  if first process is KN then write to ASJ order file.
      *
     C           #ASJ#2    BEGSR
      *
      * get part number process information...
     C           K#KEY1    CHAINAAMPL11              51
     C           *IN51     IFEQ *OFF
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLEWSSDAT
     C                     GOTO @ENDA2
     C                     ENDIF
      *
      * if first process is KN,  then an order entry needs to be written to ASJ
     C           *IN51     IFEQ *OFF
      *
     C           WSSDAT    IFGE CKHZ
     C           CKKO01    ANDEQ'KN'
     C           WSSDAT    ORLT CKHZ
     C           CKQK01    ANDEQ'KN'
      *
     C                     CLEARGDGPP051
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    IAKOYY
     C                     Z-ADDWSSMMM    IAKOMM
     C                     Z-ADDWSSDDD    IAKODD
     C                     MOVELWORKER    IAKOME
     C                     MOVE 'T'       IAKOME
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
      *
     C                     MOVE A3ZETI    IAZETI
     C                     MOVE A3SHN1    IAHIN1
     C                     MOVE A3SHN2    IAHIN2
     C                     MOVE A3SHN3    IAHIN3
     C                     Z-ADDA3USYS    IASYOS
     C                     ADD  1         IAMAIS
     C                     Z-ADDWSSYYY    IAHAYY
     C                     Z-ADDWSSMMM    IAHAMM
     C                     Z-ADDWSSDDD    IAHADD
      *
      * get ASJ P/T order info...
     C                     MOVELAKAN      PTABAR
     C           PTABAR    CHAINALRPP051             51
      *
      * if APICS is found, get P/T ord#, product code, lot#
     C           *IN51     IFEQ *OFF
     C                     MOVE PTODER    IAODER
     C                     MOVE PTPRCD    IASEIH
     C                     MOVE PTLOTN    IARENB
     C                     ELSE
     C                     MOVE *BLANKS   IAODER
     C                     MOVE '0'       IASEIH
     C                     MOVE *BLANKS   IARENB
     C                     ENDIF
      *
      * APICS NOT SCANNED, SO WRITE INFO TO ERROR LOG....
     C                     MOVE '30'      A5ERID
     C                     MOVE '03'      A5ERPS
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A5KSDT
     C                     Z-ADDWSSTM6    A5KSTM
     C                     MOVELWORKER    A5OPER
     C           @D        IFEQ '1'
     C                     MOVELWWBRCD    A5SERL
     C                     MOVEL*BLANK    A52DBC
     C                     ELSE
     C                     MOVEL*BLANK    A5SERL
     C                     MOVELW2D       A52DBC
     C                     ENDIF
     C                     MOVEL@9        A5FIL1
     C                     MOVELLAR01     A5FIL2
     C                     MOVELBARKAX    A5FIL3
      *
     C                     WRITEGDGPP051
      *
     C                     EXSR #IICSD
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           @ENDA2    ENDSR
      **************************************************************************
