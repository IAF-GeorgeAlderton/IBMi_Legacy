     C                     ELSE
     C                     EXSR @WRTE2                     APICS FILE
     C                     END
     C*
     C                     ADD  1         TOTAL
     C*
     C                     CLEARDSP01
     C                     CLEARDSP02
     C                     CLEARDSP03
     C                     CLEARDSP04
     C                     CLEARDSP05
TCHKSC                     CLEARDSP06
      *
     C                     ENDSR
     C**************************************************************************
     C*   TOYOTA E-KANBAN  @WRT(IAF KANBAN FILE)
     C**************************************************************************
     C           @WRTE1    BEGSR
     C*
     C                     CLEARALDPP201
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    A1KSYY
     C                     Z-ADDWSSMMM    A1KSMM                  MONTH
     C                     Z-ADDWSSDDD    A1KSDD                  DAY
     C                     Z-ADDWSSHHH    A1KSJI                  HOUR
     C                     Z-ADDWSSNNN    A1KSPN                  MINUTE
     C                     MOVE WUSRID    A1KSNA           AS USER-ID
     C                     MOVE EKSHN1    A1SHN1           INTERNAL PART
     C                     MOVE EKSHN2    A1SHN2           INTERNAL PART
     C                     MOVE EKSHN3    A1SHN3           INTERNAL PART
TCHK8C*                    Z-ADDSYY       A1SYYY
TCHK8C*                    Z-ADDSMM       A1SYMM
TCHK8C*                    Z-ADDSDD       A1SYDD
TCHK8C                     Z-ADDWSSYYY    A1SYYY
TCHK8C                     Z-ADDWSSMMM    A1SYMM
TCHK8C                     Z-ADDWSSDDD    A1SYDD
     C                     Z-ADDWSSHHH    A1SYJI
     C                     Z-ADDWSSNNN    A1SYFN
     C                     MOVE IIAF      WIAF             IAF KANBAN
     C* FINISHED STORAGE(PART MASTER LOCATION)
     C                     MOVE EKLOC1    A1TKR1           NEW
     C                     MOVE EKLOC2    A1TKR2
     C                     MOVE EKLOC3    A1TKR3
     C                     MOVE EKLOC4    A1TKR4
     C*
     C                     MOVE WORKER    A1OPER           WORKER
     C                     MOVE *BLANK    A1MHN1           USER PART
     C                     MOVE *BLANK    A1MHN2
     C                     MOVE *BLANK    A1MHN3
     C                     MOVE *BLANK    A1MHN4
      *
     C                     MOVE EKMHN1    A1MHN1           USER PART
     C                     MOVE EKMHN2    A1MHN2
     C                     MOVE EKMHN3    A1MHN3
     C                     MOVE EKMHN4    A1MHN4
     C                     MOVE EKSYOS    A1SSYS           UNIT QTY
     C                     MOVE EKSYOS    A1USYS           USER UNIT QTY
     C                     MOVE EKNONY    A1NONY           DELIVERY POINY
     C                     MOVE EKNKOJ    A1NKOJ                    FACTORY
     C                     MOVE EKNUKE    A1NUKE                    RECV
     C           EKNONY    CAT  EKNUKE:0  A1TOPX    P      TOPIX CODE
     C                     MOVE *BLANK    A1SALE           EFU/KANBAN
     C                     MOVE *BLANK    A1UPAG           BOTTOM KANBAN ISSU#
     C                     MOVE @@SERL    A1SERL
     C                     WRITEALDPP201
      *
     C                     EXSR #ASJ
     C                     EXSR UPDSHI
     C*
     C                     ENDSR
     C**************************************************************************
     C*   TOYOTA E-KANBAN  @WRT(A-PICS,KOTENAI KANBAN FILE)
