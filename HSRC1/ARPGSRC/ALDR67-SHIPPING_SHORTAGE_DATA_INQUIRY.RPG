     I*             '1: OQ       '        C         $TYP1
     C*===============================================================
     C*
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
      *
     C                     CLEARDSP01
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
      *  指示画面
      *===============================================================
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,11           11-18
     C                     MOVEA'00000000'*IN,19           19-27
     C                     MOVEA'00000000'*IN,27           27-34
     C                     MOVE *BLANK    D1ERR
      *
     C                     SELEC
     C* < F1 >
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* <    >
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *  指示画面チェック
      *===============================================================
     C           #CHK1     BEGSR
      *
      * SHORTAGE DATE (11,12,13,14)
      *
     C           D1ODT1    IFEQ 0
     C                     SETON                     1199
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVE D1ODT1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     1199
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C           D1ODT2    IFEQ 0
     C                     SETON                     1399
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C           D1ODT2    IFNE 99999999
     C                     MOVE D1ODT2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     1399
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1ODT1    IFGT D1ODT2
     C                     SETON                     111399
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
      * RECOVERY DATE (15,16,17,18)
      *
     C           D1RDT1    IFNE 0
     C                     MOVE D1RDT1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     1599
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1RDT2    IFNE 0
     C           D1RDT2    ANDNE99999999
     C                     MOVE D1RDT2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     1799
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1RDT1    IFGT D1RDT2
     C                     SETON                     151799
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
      * INVOICE DATE (19,20,21,22)
      *
     C           D1NOD1    IFNE 0
     C                     MOVE D1NOD1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     1999
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1NOD2    IFNE 0
     C           D1NOD2    ANDNE99999999
     C                     MOVE D1NOD2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     2199
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1NOD1    IFGT D1NOD2
     C                     SETON                     192199
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
      * STATUS (23)
      *
     C           D1STTS    IFNE ' '
     C           D1STTS    ANDNE'1'
     C           D1STTS    ANDNE'2'
     C                     SETON                     2399
     C                     MOVELER,3      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
      * IAF PART # (24)
      * COSTOMER PART # (25)
      *
      * CUSTOMER (26)
      * DELIVERY (27)
      * FACTORY  (28)
      * DOCK     (29)
      *
     C           KEY01     KLIST
     C                     KFLD           D1ODT1
     C                     KFLD           K$OTM1  60
     C           KEY02     KLIST
     C                     KFLD           D1ODT2
     C                     KFLD           K$OTM2  60
     C           D1OTM1    MULT 100       K$OTM1
     C           D1OTM2    MULT 100       K$OTM2
     C                     ADD  59        K$OTM2
      *
      *データ件数カウントのみ
      *
     C           KEY01     SETLLALDPL66
     C                     Z-ADD0         D2KENS
     C                     MOVE '#COUNT  '@STEP
     C                     EXSR #SFSET
      *
      *サブファイル作成
      *
     C           KEY01     SETLLALDPL66
     C                     Z-ADD7         @@MAX   40
     C                     SETON                     91
     C                     MOVE '        '@STEP
     C                     EXSR #SFSET
      *
     C           ENDRRN    IFEQ 0
     C                     MOVEA'1111'    *IN,11           11-14
     C           D1RDT1    COMP 0                    1515
     C           D1RTM1    COMP 0                    1616
     C           D1RDT2    COMP 0                    1717
     C           D1RTM2    COMP 0                    1818
     C           D1NOD1    COMP 0                    1919
     C           D1NOB1    COMP '  '                 2020
     C           D1NOD2    COMP 0                    2121
     C           D1NOB2    COMP '  '                 2222
     C           D1STTS    COMP ' '                  2323
     C           D1LPR1    COMP '     '              2424
     C           D1MHN1    COMP '     '              2525
     C           D1TOKU    COMP 0                    2626
     C           D1NONY    COMP 0                    2727
     C           D1NKOJ    COMP ' '                  2828
     C           D1NUKE    COMP '    '               2929
     C                     SETON                     99
     C                     MOVELER,4      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *-------------------------*
     C           $CHK1Z    TAG
      *-------------------------*
     C           *IN99     IFEQ *OFF
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  照会画面作成(PAGE UP/DOWN)   (F12)CSV DATA作成
      *===============================================================
     C           #SFSET    BEGSR
     C*
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL1
     C                     SETOF                     73
     C*
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C*-------------------------
      * SHIPPING SHORTAGE FILE                         *
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ ALDPL66                  90
     C  N90      AFODTM    IFGT K$MADE
     C                     SETON                     90
     C                     ENDIF
     C   90                LEAVE
     C           AFSKJC    IFEQ 'D'                         DELETE CODE
     C           AFSKHZ    ANDLE@SYSHZ                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     EXSR #SEL
     C           @NG       IFEQ '*'
     C                     ITER
     C                     ENDIF
     C*データ件数カウントのみ
 S2  C           @STEP     IFEQ '#COUNT  '
     C                     ADD  1         D2KENS
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVE *BLANK    S1SEL
     C                     Z-ADDAFNONY    S1NONY
     C                     MOVELAFNKOJ    S1NKOJ
     C                     MOVELAFNUKE    S1NUKE
     C                     MOVEL'-'       $MHF1
     C                     MOVEL'-'       $MHF2
     C                     MOVEL'-'       $MHF3
     C           AFMHN4    IFEQ *BLANK
     C                     MOVEL' '       $MHF3
     C           AFMHN3    IFEQ *BLANK
     C                     MOVEL' '       $MHF2
     C           AFMHN2    IFEQ *BLANK
     C                     MOVEL' '       $MHF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVELAFODRN    S1ODRN           ORDER NO
     C                     Z-ADDAFODT6    S1ODTM           SHRTG DATE
     C                     MOVEL'-'       $SHF1
     C                     MOVEL'-'       $SHF2
     C           AFLPR3    IFEQ *BLANK
     C                     MOVEL' '       $SHF2
     C           AFLPR2    IFEQ *BLANK
     C                     MOVEL' '       $SHF1
     C                     ENDIF
     C                     ENDIF
     C                     MOVEL'-'       $LHF1            LOC
     C                     MOVEL'-'       $LHF2
     C                     MOVEL'-'       $LHF3
     C                     MOVE AFNOYY    S1NOYY
     C                     MOVE AFNOMM    S1NOMM
     C                     MOVE AFNODD    S1NODD
     C                     MOVE '.'       $NHF1
     C                     MOVE '.'       $NHF2
     C                     MOVE '-'       $NHF3
     C                     MOVELAFNOBN    $NOBN
     C                     Z-ADDAFRDTM    S1RDTM           RCVR DATE
      *
     C                     Z-ADDAFODAT    S1ODAT           SHRTG DATE
     C                     Z-ADDAFOTIM    S1OTIM           SHRTG TIME
     C                     MOVELAFOTMC    S1OTMC           INPUT TM
     C                     Z-ADDAFNODT    S1NODT           INVOICE DATE
     C                     MOVELAFNOBN    S1NOBN           INVOICE BIN
     C                     Z-ADDAFRDAT    S1RDAT           RCVR DATE
     C                     Z-ADDAFRTIM    S1RTIM           RCVR TIME
     C                     MOVELAFRTMC    S1RTMC           INPUT TM
     C                     Z-ADDAFTOKU    S1TOKU           CUSTOMER
     C                     MOVELAFUKAN    S1UKAN           USER KANBAN
     C*
     C*---------------
 S2  C           @STEP     IFEQ '#CSV    '
     C                     EXSR #NAME
     C                     EXCPT$DATA
 X2  C                     ELSE
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C           RRN1      IFGE @@MAX
     C                     LEAVE
     C                     ENDIF
 E2  C                     ENDIF
     C*---------------
E1   C                     ENDDO
     C*-------------------------
     C*-------------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C*--------------------
     C                     ENDSR
      *===============================================================
      *選択
      *===============================================================
     C           #SEL      BEGSR
      *
     C                     MOVE ' '       @NG     1
     C* STATUS
     C                     SELEC
     C           D1STTS    WHEQ '1'
     C           AFRDAT    IFNE 0
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C           D1STTS    WHEQ '2'
     C           AFRDAT    IFEQ 0
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C                     ENDSL
      *
      *  RECOVERY DATE-TIME
     C           D1RDT1    IFNE 0
     C           AFRDT4    IFLT D$RDT1
     C           AFRDT4    ORGT D$RDT2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C                     ENDIF
      *  INVOICE DATE-BIN
     C           D1NOD1    IFNE 0
     C           AFNODB    IFLT D$NOD1
     C           AFNODB    ORGT D$NOD2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C                     ENDIF
      *  IAF PART #
     C           D1LPR1    IFNE *BLANK
     C           D1LPR1    ANDNEAFLPR1
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C           D1LPR2    IFNE *BLANK
     C           D1LPR2    ANDNEAFLPR2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C           D1LPR3    IFNE *BLANK
     C           D1LPR3    ANDNEAFLPR3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *  CUSTOMER PART #
     C           D1MHN1    IFNE *BLANK
     C           D1MHN1    ANDNEAFMHN1
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C           D1MHN2    IFNE *BLANK
     C           D1MHN2    ANDNEAFMHN2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C           D1MHN3    IFNE *BLANK
     C           D1MHN3    ANDNEAFMHN3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C           D1MHN4    IFNE *BLANK
     C           D1MHN4    ANDNEAFMHN4
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *  CUSTOMER
     C           D1TOKU    IFNE 0
     C           D1TOKU    ANDNEAFTOKU
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *  DELIVERY
     C           D1NONY    IFNE 0
     C           D1NONY    ANDNEAFNONY
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *  FACTORY
     C           D1NKOJ    IFNE *BLANK
     C           D1NKOJ    ANDNEAFNKOJ
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *  DOCK
     C           D1NUKE    IFNE *BLANK
     C           D1NUKE    ANDNEAFNUKE
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
     C*
     C           $SELZ     ENDSR
