     H            Y/
     F** ABBR33 ***************************************************
     F*  FORECAST BY CUST/DELIV/FACTORY/DOCK (OUT MBDWP02)        *
     F*  READ ABBWP29 AND DROP TO MBDW02                          *
     F*  JW    2019.02.28                                         *
     F*************************************************************
     FABBWP29 IF  E           K        DISK
     FMBDWP02 UF  E           K        DISK                      A
      *------------------------------------------------------------
     I            DS
     I                                        1  20 W9MHIN
     I                                        1   5 W9MHN1
     I                                        6  10 W9MHN2
     I                                       11  15 W9MHN3
     I                                       16  20 W9MHN4
     I            DS
     I                                        1  17 X9MHIN
     I                                        1   5 X9MHN1
     I                                        6   6 X9M1
     I                                        7  11 X9MHN2
     I                                       12  12 X9M2
     I                                       13  17 X9MHN3
     I            DS
     I                                        1  20 W9SHIN
     I                                        1   5 W9SHN1
     I                                        6  10 W9SHN2
     I                                       11  15 W9SHN3
     I                                       16  20 W9SHN4
     I            DS
     I                                        1  17 X9SHIN
     I                                        1   5 X9SHN1
     I                                        6   6 X9S1
     I                                        7  11 X9SHN2
     I                                       12  12 X9S2
     I                                       13  17 X9SHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ABBWP29                  98
     C   98                LEAVE
      *
     C                     MOVELW9TOKU    K#TOKU    P
     C                     MOVELW9NONY    K#NONY    P
     C                     MOVELW9NKOJ    K#NKOJ    P
     C                     MOVELW9NUKE    K#NUKE    P
      * ADJ USER PARTS
     C                     MOVELW9MHN1    X9MHN1
     C                     MOVELW9MHN2    X9MHN2
     C                     MOVELW9MHN3    X9MHN3
     C           X9MHN2    IFEQ *BLANK
     C                     MOVE *BLANK    X9M1
     C                     ELSE
     C                     MOVE '-'       X9M1
     C                     ENDIF
     C           X9MHN3    IFEQ *BLANK
     C                     MOVE *BLANK    X9M2
     C                     ELSE
     C                     MOVE '-'       X9M2
     C                     ENDIF
     C                     MOVELX9MHIN    K#MHIN    P
      *
     C           K#WP02    CHAINMBDWP02              99
     C           *IN99     IFEQ *OFF
     C                     EXSR #UPD
     C                     ELSE
     C                     EXSR #WRT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  UPDATE MBDWP02
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     MOVELW9FQ01    F5FC01
     C                     MOVELW9FQ02    F5FC02
     C                     MOVELW9FQ03    F5FC03
     C                     MOVELW9FQ04    F5FC04
     C                     MOVELW9FQ05    F5FC05
     C                     MOVELW9FQ06    F5FC06
     C                     MOVELW9FQ07    F5FC07
     C                     MOVELW9FQ08    F5FC08
     C                     MOVELW9FQ09    F5FC09
      *
     C           W9FQ01    ADD  W9FQ02    W9FQ99  80
     C                     ADD  W9FQ03    W9FQ99
     C                     ADD  W9FQ04    W9FQ99
     C                     ADD  W9FQ05    W9FQ99
     C                     ADD  W9FQ06    W9FQ99
     C                     ADD  W9FQ07    W9FQ99
     C                     ADD  W9FQ08    W9FQ99
     C                     ADD  W9FQ09    W9FQ99
     C                     MOVELW9FQ99    F5FC99
      *
     C                     UPDATMBDWP021
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE  MBDWP02
      *------------------------------------------------------
     C           #WRT      BEGSR
      * GET GROUP
     C                     MOVELW9NONY    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME2    F5GRP
      * GET CUSTOMER NAME
     C                     MOVEL'D'       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           $DLV    4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           PMRTN   1
     C                     MOVELPMNAME    F5TONM
      * ADJ IAF PARTS
     C                     MOVELW9SHN1    X9SHN1
     C                     MOVELW9SHN2    X9SHN2
     C                     MOVELW9SHN3    X9SHN3
     C           X9SHN2    IFEQ *BLANK
     C                     MOVE *BLANK    X9S1
     C                     ELSE
     C                     MOVE '-'       X9S1
     C                     ENDIF
     C           X9SHN3    IFEQ *BLANK
     C                     MOVE *BLANK    X9S2
     C                     ELSE
     C                     MOVE '-'       X9S2
     C                     ENDIF
      *
     C                     CLEARMBDWP021
     C                     MOVELW9TOKU    F5TOKU
     C                     MOVELW9NONY    F5NONY
     C                     MOVELW9NKOJ    F5NKOJ
     C                     MOVELW9NUKE    F5NUKE
     C                     MOVELX9MHIN    F5MHIN
     C                     MOVELX9SHIN    F5SHIN
     C                     MOVELW9MSET    F5MSET
      *
     C                     MOVELW9FQ01    F5FC01
     C                     MOVELW9FQ02    F5FC02
     C                     MOVELW9FQ03    F5FC03
     C                     MOVELW9FQ04    F5FC04
     C                     MOVELW9FQ05    F5FC05
     C                     MOVELW9FQ06    F5FC06
     C                     MOVELW9FQ07    F5FC07
     C                     MOVELW9FQ08    F5FC08
     C                     MOVELW9FQ09    F5FC09
      *
     C           W9FQ01    ADD  W9FQ02    W9FQ99  80
     C                     ADD  W9FQ03    W9FQ99
     C                     ADD  W9FQ04    W9FQ99
     C                     ADD  W9FQ05    W9FQ99
     C                     ADD  W9FQ06    W9FQ99
     C                     ADD  W9FQ07    W9FQ99
     C                     ADD  W9FQ08    W9FQ99
     C                     ADD  W9FQ09    W9FQ99
     C                     MOVELW9FQ99    F5FC99
      *
     C                     WRITEMBDWP021
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           #INIT     BEGSR
      *
     C**         *ENTRY    PLIST
     C**                   PARM           $CUST   4
     C**                   PARM           $NONY   4
     C**                   PARM           $NKOJ   1
     C**                   PARM           $NUKE   4
      *
     C           K#WP02    KLIST
     C                     KFLD           K#TOKU  5
     C                     KFLD           K#NONY  6
     C                     KFLD           K#NKOJ  7
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#MHIN 20
      *
      *
     C                     ENDSR
