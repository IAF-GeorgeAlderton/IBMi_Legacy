     C                     TIME           WTIME
     C                     READ AKBPL03                  21
     C           *IN21     DOWEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLESDATE
     C                     ELSE
     C           L1STHZ    IFEQ 99999999
     C                     EXSR #SB200
     C                     ENDIF
     C                     ENDIF
     C                     READ AKBPL03                  21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *AAJPP11 検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C                     CLEARABNPP111
     C                     MOVELL1KCD1    S7KCD1
     C                     MOVELL1KCD2    S7KCD2
     C                     Z-ADDL1BMON    S7BMON
     C                     MOVELL1TKR1    S7TKR1
     C                     MOVELL1TKR2    S7TKR2
     C                     MOVELL1TKR3    S7TKR3
     C                     MOVELL1TKR4    S7TKR4
     C                     MOVELL1SHN1    S7SHN1
     C                     MOVELL1SHN2    S7SHN2
     C                     MOVELL1SHN3    S7SHN3
     C                     Z-ADDL1KMAX    S7KMAX
     C           KEYA31    KLIST
     C                     KFLD           L1TKR1
     C                     KFLD           L1TKR2
     C                     KFLD           L1TKR3
     C                     KFLD           L1TKR4
     C                     Z-ADD32        @@SHAK  30
     C           KEYA31    SETGTAAJPL11
     C           KEYA31    REDPEAAJPL11                  82
     C           *IN82     IFEQ '0'
     C                     Z-ADDCJSDAI    S7SDAI
     C                     MOVELCJSSYO    S7SSYO
     C                     MOVELCJHAKO    S7HAKO
     C                     Z-ADDCJBRYO    S7BRYO
     C                     Z-ADDCJSHAK    S7SHAK
     C           CJSDSS    LOKUPTAB5      TAB6           20
     C   20                Z-ADDTAB6      @@SHAK
     C                     ENDIF
     C                     EXSR #SB670
     C                     WRITEABNPP111
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      *間口数　構成品3
      *---------------------------*
     CSR         #SB670    BEGSR
      *
     C                     Z-ADD0         WKMAX   70
     C                     Z-ADD0         MAGS    30
     C           L1BMON    IFEQ 0111
     C           L1BMON    OREQ 8990
     C           L1KMAX    MULT 12        WKMAX
     C                     ELSE
     C           L1KMAX    MULT 0.7       WKMAX
     C                     ENDIF
     C           WKMAX     DIV  @@SHAK    S7NSIZ
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S7NSIZ
     C                     ENDIF
      *
     CSR         ESB670    ENDSR
