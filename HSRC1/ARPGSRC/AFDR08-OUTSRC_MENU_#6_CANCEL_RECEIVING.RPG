     H            Y.                                    1
     H** AFDR08 *******************************************************
     H* OUT SOURCE ORDER(CURTIS)                                      *
     H*     CANCEL RECEIVING                                          *
     H* TCH DEC/17/01
     H**************************************************************************
     FAFDPW08 CF  E                    WORKSTN
     FAFDPL22 UF  E           K        DISK
      *--------------------------------------------------------------
     E                    CMD     1   1 78
     E                    ER      1   4 78
     I**************************************************************************
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           SUPLY   4
     C                     PARM           SUPX    1
      *
     C           K#AFD     KLIST
     C                     KFLD           SUPLY
     C                     KFLD           W@BIN  30
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C           P#99      PLIST
     C                     PARM           YMD8    80
     C                     PARM           YY      40
     C                     PARM           MM      20
     C                     PARM           DD      20
     C                     PARM           WD      1
     C                     PARM           ERR     1
      *
     C                     MOVE SUPLY     @SUPP   40
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN (SCAN APICS KANBAN)
     C**************************************************************************
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
B02  C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR #CHK1
     C*
B04  C           *IN99     IFEQ *OFF
B04  C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *BLANK    D@UPD
     C                     SETOF                     996162
     C* CHECK BIN
     C           D@BINN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
      * CHECK DATE
     C                     Z-ADDD@RCVD    YMD8
     C                     CALL 'AFDR99'  P#99
     C           ERR       IFNE *BLANK
     C           *IN99     IFEQ *OFF
     C                     MOVE ER,2      D@MSG
     C                     ENDIF
     C                     SETON                     9962
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     Z-ADDD@RCVD    K@YMD
     C                     MOVELD@BINN    W@BIN     P
     C           K#AFD     CHAINAFDPL22             N90
     C           *IN90     IFEQ *ON
     C           *IN99     IFEQ *OFF
     C                     MOVE ER,3      D@MSG
     C                     ENDIF
     C                     SETON                     996162
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*        UPDATE
     C**************************************************************************
     C           #UPD      BEGSR
     C*
     C           K#AFD     SETLLAFDPL22
     C           *IN90     DOUEQ*ON
     C           K#AFD     READEAFDPL22                  90
     C           *IN90     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
      *
     C           SUPX      IFNE *BLANK
     C           SUPX      ANDNEAFAKI1
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD*DATE     AFKODT
     C                     TIME           AFKHMS
     C                     MOVEL#USER     AFKOME
     C                     MOVEL#PGM      AFKOPG
     C                     Z-ADD*ZERO     AFNOYY
     C                     Z-ADD*ZERO     AFNOMM
     C                     Z-ADD*ZERO     AFNODD
     C                     Z-ADD*ZERO     AFNODD
     C                     Z-ADD*ZERO     AFNOSU
     C                     MOVE *BLANK    AFAKI2
     C                     UPDATAFDPP201
     C                     ENDIF
     C*
     C                     ENDDO
      *
     C                     MOVELER,4      D@UPD
     C                     MOVE *BLANK    D@BINN
     C                     Z-ADD*ZERO     D@RCVD
     C*
     C                     ENDSR
      *---------------------------------------------------------
** CMD
F3:END     F5:UPDATE
** ERROR MESSAGE
BIN ERROR
DATE ERROR
NO DATA
CENCELLED !!
