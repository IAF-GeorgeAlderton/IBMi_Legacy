     H            Y.
     F** MBDR65 **************************************
     F*納入統計ファイルのデータ分析ツールコンバート*
     F*   C:N.HAYAKAWA         2000.5.16             *
     F************************************************
     FMBDPP01 IP  E                    DISK
     FMBDWP66 O   F     256            DISK
     I            DS
     I                                        1   80W@SKHZ
     I                                        1   40W@SKY4
     I                                        5   60W@SKMM
     I                                        7   80W@SKDD
     C* パラメーターリスト
     C           *ENTRY    PLIST
     C                     PARM           PTOK1   4
     C                     PARM           PTOK2   4
     C                     PARM           PTOK3   4
     C                     PARM           PTOK4   4
     C                     PARM           PTOK5   4
     C                     PARM           PCRTHZ  8
     C* １回のみの処理
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     Z-ADD01        WDD     20
     C                     EXCPTHD
     C* 1
     C           PTOK1     IFEQ *BLANK
     C                     MOVE '0000'    PTOK1X  40
     C                     ELSE
     C                     MOVE PTOK1     PTOK1X
     C                     END
     C* 2
     C           PTOK2     IFEQ *BLANK
     C                     MOVE '0000'    PTOK2X  40
     C                     ELSE
     C                     MOVE PTOK2     PTOK2X
     C                     END
     C* 3
     C           PTOK3     IFEQ *BLANK
     C                     MOVE '0000'    PTOK3X  40
     C                     ELSE
     C                     MOVE PTOK3     PTOK3X
     C                     END
     C* 4
     C           PTOK4     IFEQ *BLANK
     C                     MOVE '0000'    PTOK4X  40
     C                     ELSE
     C                     MOVE PTOK4     PTOK4X
     C                     END
     C* 5
     C           PTOK5     IFEQ *BLANK
     C                     MOVE '0000'    PTOK5X  40
     C                     ELSE
     C                     MOVE PTOK5     PTOK5X
     C                     END
     C*
     C                     END
     C* 得意先抜き出し
     C* 画面１つ目が９９９９の時は全得意先対象
     C           PTOK1     IFEQ '9999'
     C                     GOTO EXIT1
     C                     END
     C* 画面にある得意先の時はデータ作成
     C           F3TOKU    IFEQ PTOK1X
     C           F3TOKU    OREQ PTOK2X
     C           F3TOKU    OREQ PTOK3X
     C           F3TOKU    OREQ PTOK4X
     C           F3TOKU    OREQ PTOK5X
     C                     ELSE
     C                     GOTO END
     C                     END
     C*
     C           EXIT1     TAG
     C* 単価１円固定
     C***************      Z-ADD1         F3TANK
      *
     C*                    MOVE PCRTHZ    PHIZK
     C*                    MOVE *BLANK    PHIZ8
     C*                    CALL 'DATR00'
     C*                    PARM           PHIZK   6
     C*                    PARM           PHIZ8   8
     C                     MOVE PCRTHZ    W@SKHZ  80
      *
     C* Ｎ月の処理
     C                     Z-ADDF3TNSU    WNSUU   70
     C                     Z-ADDW@SKY4    WYY     40
     C           WNSUU     MULT F3TANK    WKIN   152
     C*
     C           W@SKMM    SUB  0         WMM     20
     C           WMM       IFLE 0
     C           WMM       ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C*
     C*
     C                     EXCPTME
     C* Ｎ－１月の処理
     C                     Z-ADDF3ANSU    WNSUU   70
     C                     Z-ADDW@SKY4    WYY     40
     C           WNSUU     MULT F3TANK    WKIN   152
     C*
     C           W@SKMM    SUB  1         WMM     20
     C           WMM       IFLE 0
     C           WMM       ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C*
     C                     EXCPTME
     C* Ｎ－２月の処理
     C                     Z-ADDF3BNSU    WNSUU   70
     C                     Z-ADDW@SKY4    WYY     40
     C           WNSUU     MULT F3TANK    WKIN   152
     C*
     C           W@SKMM    SUB  2         WMM     20
     C           WMM       IFLE 0
     C           WMM       ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C*
     C                     EXCPTME
     C* Ｎ－３月の処理
     C                     Z-ADDF3CNSU    WNSUU   70
     C                     Z-ADDW@SKY4    WYY     40
     C           WNSUU     MULT F3TANK    WKIN   152
     C*
     C           W@SKMM    SUB  3         WMM     20
     C           WMM       IFLE 0
     C           WMM       ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C*
     C                     EXCPTME
     C* Ｎ－４月の処理
     C                     Z-ADDF3DNSU    WNSUU   70
     C                     Z-ADDW@SKY4    WYY     40
     C           WNSUU     MULT F3TANK    WKIN   152
     C*
     C           W@SKMM    SUB  4         WMM     20
     C           WMM       IFLE 0
     C           WMM       ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C*
     C                     EXCPTME
     C* Ｎ－５月の処理
     C                     Z-ADDF3ENSU    WNSUU   70
     C                     Z-ADDW@SKY4    WYY     40
     C           WNSUU     MULT F3TANK    WKIN   152
     C*
     C           W@SKMM    SUB  5         WMM     20
     C           WMM       IFLE 0
     C           WMM       ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C*
     C                     EXCPTME
     C*
     C           END       TAG
     OMBDWP66 E                HD
     O                                      '得意先'
     O                                      ','
     O                                      '得工場'
     O                                      ','
     O                                      '得受入'
     O                                      ','
     O                                      '納入先'
     O                                      ','
     O                                      '納工場'
     O                                      ','
     O                                      '納受入'
     O                                      ','
     O                                      '社内品番'
     O                                      ','
     O                                      'ユーザ品番'
     O                                      ','
     O                                      'データ年月日'
     O                                      ','
     O                                      '販売数量'
     O                                      ','
     O                                      '販売単価'
     O                                      ','
     O                                      '販売金額'
     O                                      ','
     O                                      '単価区分'
     O                                      ','
     O                                      '単価形態'
     O                                      ','
     O                                      '手配先'
     O                                      ','
     O                                      '手配区分'
     O        E                ME
     O                                      '"'
     O                         F3TOKU
     O                                      '"'
     O                                      ','
     O                                      '"'
