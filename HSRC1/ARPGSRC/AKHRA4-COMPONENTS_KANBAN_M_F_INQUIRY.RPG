     C*--------------------------------*
     C*  ..構成品かんばんマスター..  *
     C*--------------------------------*
     C                     SETOF                     10
     C           AKEY      CHAINAKBPL011             10
     C           *IN10     IFEQ '0'
     C           L1SKJY    ANDEQ'D'
     C           L1SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C                     MOVE '9'       PCMD3
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     Z-ADDL1KMAX    WKMAX
     C                     MOVE '-'       H1
     C                     MOVE '-'       H2
     C                     MOVE '-'       T1
     C                     MOVE '-'       T2
     C                     MOVE '-'       T3
     C                     MOVE '-'       U1
     C                     MOVE ':'       U2
     C                     MOVE '-'       U3
     C                     Z-ADD0         WRD     10
      *
     C                     SETON                     98
     C                     SETOF                     50
      *
     C                     EXSR #SUB1                      f]ﾌﾞ]ﾆｬﾓb
     C                     EXSR #SUB2                      BCD & L.T
     C                     EXSR #SUB3                      ﾈｮmbuﾇjｰ
     C                     EXSR #SUB4                      ﾆﾞｭci]uﾇjｰ
      *
     C                     SETOF                     20
     C                     MOVE *BLANK    @UKNM
     C           L1UKOJ    CHAINFGBPL011             20
     C           *IN20     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELB2SMEI    @UKNM
     C                     END
     C                     END
      *
     C           @SCR1     TAG
     C                     EXFMTAKHPWA41
      *
     C           *INKC     IFEQ '1'
     C                     MOVE '1'       PCMD3
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*------------------------*
     C*  ..引取ロット照会..  *
     C*------------------------*
     C           *INKB     IFEQ '1'
