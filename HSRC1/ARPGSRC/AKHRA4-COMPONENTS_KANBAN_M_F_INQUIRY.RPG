     C                     MOVE L1UKMM    PUMM    2
     C                     MOVE L1UKDD    PUDD    2
     C                     MOVE L1UBIN    PUBN    2
     C                     CALL 'AAJR16'
     C                     PARM           L1TKR1           nﾃﾜﾌﾞ]k 1
     C                     PARM           L1TKR2                   2
     C                     PARM           L1TKR3                   3
     C                     PARM           L1TKR4                   4
     C                     PARM           PUYY             ﾏcﾃcﾍﾞ r]
     C                     PARM           PUMM                    lg
     C                     PARM           PUDD                    ﾍ
     C                     PARM           PUBN                    ﾍﾞ]
     C                     GOTO @SCR1
     C                     END
      *調整分理由
     C           *INKD     IFEQ '1'
     C                     MOVELL1TKR1    P@JBN1
     C                     MOVELL1TKR2    P@JBN2
     C                     MOVELL1TKR3    P@JBN3
     C                     MOVELL1TKR4    P@JBN4
