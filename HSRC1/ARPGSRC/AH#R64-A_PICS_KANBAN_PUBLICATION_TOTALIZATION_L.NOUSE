     H            Y.
     F*** AH#R64 *********************************
     F* A-PICS KANBAN PUBLICATION TOTALIZATION LIST <2> *
     F* PROGRAM ID. : AH#R64. <RPG> *
     F* CREATE DATE. : 1995.07.18.               *
     F* AUTHOR.         : H.ITO                  *
     F********************************** AH#R64 **
     FAH#WP64 IP  F      64            DISK
     FFGBPL01 IF  E           K        DISK
     FRGAPL11 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAH#PR64 O   E             21     PRINTER
     E                    #1MI        4  4 0             ubﾇc 1
     E                    #2MI        4  4 0                  2
     E                    #1HE        4  4 0             ubﾇc平均1
     E                    #2HE        4  4 0                 平均2
     E                    #1GO        4  5 0             ubﾇc合計1
     E                    #2GO        4  5 0                 合計2
     IAH#WP64 NS  01
     I                                        1   80CFHTHZL1
     I                                        1   40@YY
     I                                        5   60@MM
     I                                        7   80@DD
     I                                        9  100CFHTBB
     I                                       11  22 CFHBAN
     I                                       23  250CFMAIS
     I                                       26  28 CFKBAN
     I                                       29  29 CFKKRI
     I                                       30  330CFBMONL2
     I            DS
     I                                        1  160#1MI
     I                                        1   40#1MI01
     I                                        5   80#1MI02
     I                                        9  120#1MI03
     I                                       13  160#1MI04
     I            DS
     I                                        1  160#2MI
     I                                        1   40#2MI01
     I                                        5   80#2MI02
     I                                        9  120#2MI03
     I                                       13  160#2MI04
     I            DS
     I                                        1  160#1HE
     I                                        1   40#1HE01
     I                                        5   80#1HE02
     I                                        9  120#1HE03
     I                                       13  160#1HE04
     I            DS
     I                                        1  160#2HE
     I                                        1   40#2HE01
     I                                        5   80#2HE02
     I                                        9  120#2HE03
     I                                       13  160#2HE04
     I            DS
     I                                        1  200#1GO
     I                                        1   50#1GO01
     I                                        6  100#1GO02
     I                                       11  150#1GO03
     I                                       16  200#1GO04
     I            DS
     I                                        1  200#2GO
     I                                        1   50#2GO01
     I                                        6  100#2GO02
     I                                       11  150#2GO03
     I                                       16  200#2GO04
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C  N01                GOTO @END
      *
     C           *IN90     IFEQ '0'
     C                     MOVEA'1'       *IN,90
     C                     Z-ADD0         #1MI
     C                     Z-ADD0         #2MI
     C                     Z-ADD0         KHIZ    20
     C                     MOVE *ALL'~'   W128  128
     C                     Z-ADD0         #1HE
     C                     Z-ADD0         #2HE
     C                     Z-ADD0         #1GO
     C                     Z-ADD0         #2GO
     C                     Z-ADD0         $MAIS
     C                     Z-ADD0         $HEKIN
     C                     Z-ADD0         $GOKEI
     C                     MOVEL'1'       *INOF
     C                     MOVEA'1'       *IN,21
     C                     Z-ADD0         CNT     30
     C                     END
      *
     C           *IN,21    IFEQ '1'
     C                     MOVE *BLANK    USNM
     C           US        CHAINRGAPL111             11
     C           *IN,11    IFEQ '0'
     C           J8SKJY    ANDEQ'D'
     C                     MOVEA'1'       *IN,11
     C                     END
      *
     C  N11                MOVELJ8NAME    USNM
      *
     C                     MOVE *BLANK    NAME
     C           CFBMON    IFEQ 8907
     C                     MOVEL'PURCHS'  NAME
     C                     ELSE
     C           CFBMON    CHAINFGBPL011             10
     C           *IN,10    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,10
     C                     END
      *
     C  N10                MOVELB2SMEI    NAME
     C                     END
      *
     C           CFBMON    CHAINFGBPL011             20
     C           *IN,20    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,20
     C                     END
      *
     C  N20                MOVELB2SMEI    @NAME
      *
     C                     TIME           TIME    60
     C                     Z-ADD*DATE     DAY
     C                     ADD  1         CNT
     C                     WRITEHED
     C                     MOVEA'0'       *IN,21
     C                     END
      *
     C           CFHTBB    IFLE 4
     C                     Z-ADDCFHTBB    Z       20
     C           CFKKRI    IFEQ '*'
     C                     ADD  CFMAIS    #1MI,Z
     C                     ELSE
     C                     ADD  CFMAIS    #2MI,Z
     C                     END
     C                     END
     C                     ADD  CFMAIS    $GOKEI
      *
     C           @END      TAG
      *
     CL1                   XFOOT#1MI      $1MI
     CL1                   XFOOT#2MI      $2MI
     CL1         $1MI      ADD  $2MI      $MAIS
      *
     CL1                   EXSR SUB1
     CL1                   WRITEDET
     CL1                   Z-ADD0         #1MI
     CL1                   Z-ADD0         #2MI
     CL1                   ADD  $1MI      WGMAI   80
     CL1                   ADD  $2MI      WGTEN   70
     CL1                   Z-ADD0         $1MI
     CL1                   Z-ADD0         $2MI
     CL1                   Z-ADD0         $MAIS
      *
     CL2                   XFOOT#1GO      $1GO
     CL2                   XFOOT#2GO      $2GO
     CL2                   EXSR SUB3
     CL2                   EXSR SUB2
     CL2                   WRITETOT
     CL2                   Z-ADD0         #1HE
     CL2                   Z-ADD0         #2HE
     CL2                   Z-ADD0         #1GO
     CL2                   Z-ADD0         #2GO
     CL2                   Z-ADD0         WGMAI
     CL2                   Z-ADD0         WGTEN
     CL2                   MOVEA'1'       *IN,21
      *
     C******************************************************
     C*              便単位のカウント
     C******************************************************
     C           SUB1      BEGSR
      *
     C                     Z-ADD1         A       20
     C                     DO   4         A
     C                     ADD  #1MI,A    #1GO,A
     C                     ADD  #2MI,A    #2GO,A
     C                     END
      *
     C                     ENDSR
      *
     C******************************************************
     C*                便単位の平均
     C******************************************************
     C           SUB2      BEGSR
      *
     C                     Z-ADD1         B       20
     C                     DO   4         B
     C           #1GO,B    DIV  KHIZ      #1HE,B    H
     C           #2GO,B    DIV  KHIZ      #2HE,B    H
     C                     END
      *
     C           WGMAI     DIV  KHIZ      $1HE      H
     C           WGTEN     DIV  KHIZ      $2HE      H
     C           $1HE      ADD  $2HE      $HEKIN
      *
     C                     ENDSR
      *
     C******************************************************
     C*                 稼働日計算
     C******************************************************
     C           SUB3      BEGSR
      *
     C                     Z-ADD0         KHIZ
     C                     SETOF                     55
     C           WYM       KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
      *
     C           WYM       SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                         55
     C           WYM       READEAGDPL121                 55
     C           *IN55     IFEQ '0'
     C           F8KAHZ    IFLE *DATE
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C                     ADD  1         KHIZ
     C                     END
     C                     ELSE
     C                     SETON                     55
     C                     END
     C                     END
     C  N55                ENDDO
      *
     C                     ENDSR
