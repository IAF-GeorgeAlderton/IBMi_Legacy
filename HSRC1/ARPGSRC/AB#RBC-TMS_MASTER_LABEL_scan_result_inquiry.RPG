     H            Y.
     F** AB#RBC *************************************************************
     F*  TMS MASTER LABEL SCANNED RESULT INQUIRY                            *
     F****************************************** ABBRBC *********************
     FAB#PWBC CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAB#PL66 IF  E           K        DISK
     E*****************************************************************
     E                    ER      1   3 78
     E                    CMD     1   2 78
     I*****************************************************************
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
      *  MAIN
      *---------------------------------------------------------
B01  C           @@DSP     DOWNE'99'
     C           @@DSP     CASEQ'01'      #SCRN1
     C           @@DSP     CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------
      * INITIALIZE
      *-------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#66      KLIST
     C                     KFLD           D@CUST
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C                     KFLD           D@DOCK
     C                     KFLD           D@NYMD
     C           K#66X     KLIST
     C                     KFLD           D@CUST
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C                     KFLD           D@DOCK
     C                     KFLD           D@NYMD
     C                     KFLD           K@NBIN  20
     C                     KFLD           K@MLBL  8
     C*
     C                     MOVE '01'      @@DSP   2
      *
     C                     ENDSR
     C***********************************************************
     C* 1ST SCREEN
     C***********************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@DSP
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ '0'
     C                     EXSR #SET
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@DSP
     C                     ELSE
     C                     MOVE ER,2      D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C***********************************************************
     C* 1ST SCREEN CHECK
     C***********************************************************
     C           #CHK1     BEGSR
      *
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C           K#66      CHAINAB#PL66              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
     C* DATA SET
     C***********************************************************
     C           #SET      BEGSR
      *
     C           K#66      SETLLAB#PL66
     C                     EXSR #SET1
      *
     C                     ENDSR
     C***********************************************************
     C* DATA SET
     C***********************************************************
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN32
     C                     WRITECTL01
     C                     MOVE *OFF      *IN32
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *BLANK    D@CASE
      *
     C           *IN90     DOUEQ*ON
     C           K#66      READEAB#PL66                  90
     C           *IN90     IFEQ *OFF
     C           A6MHN1    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           D@CASE    IFEQ *BLANK
     C                     MOVELA6MLBL    D@CASE
     C                     MOVELA6MLBL    K@MLBL
     C                     ENDIF
     C           A6MLBL    IFNE D@CASE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     MOVE A6MHN1    S@PRT1
     C                     MOVE A6MHN2    S@PRT2
     C                     MOVE A6MHN3    S@PRT3
     C           A6QTYB    IFNE *ZERO
     C           A6SRYO    DIV  A6QTYB    S@BOX
     C                     ELSE
     C                     Z-ADD1         S@BOX
     C                     ENDIF
      *
     C                     WRITESFL01
     C                     Z-ADDA6NBIN    K@NBIN
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* DETAIL INFORMATION
     C***********************************************************
     C           #SCRN2    BEGSR
     C*
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN31
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN31
      *
     C                     SELEC
B02  C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@DSP
      *
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@DSP
      *
     C           *INKI     WHEQ *ON
     C           K#66X     SETGTAB#PL66
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     MOVE '01'      @@DSP
     C                     MOVE ER,3      D@MSG
     C                     ENDIF
      *
     C                     ENDSL
     C*
     C                     ENDSR
      *-------------------------------------------------
** ER
E-01 NO MASTER LABEL DATA.
E-02 NO SCANNED RECORDS.
E-03 NO OTHER MASTER LABELS.
** CMD
 F1=END
 F1=END     F9=NEXT MASTER LABEL     F12=GO BACK
