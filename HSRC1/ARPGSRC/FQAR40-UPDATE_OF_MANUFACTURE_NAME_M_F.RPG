     H            Y.
     F** FQAR40 *********************************
     F* ..UPDATE OF MANUFACTURE NAME M/F..      *
     F*     K.OKACHI               98.04.08     *
     F********************************* FQAR40 **
     FFQAPW40 CF  E                    WORKSTN
     FFQAPL40 UF  E           K        DISK                      A
     E                    ER      1  20 60
      *
     I            DS
     I                                        1   80F4SKHZ
     I                                        1   40F4SKYY
     I                                        5   60F4SKMM
     I                                        7   80F4SKDD
     I            DS
     I                                        1   80F4KOHZ
     I                                        1   40F4KOYY
     I                                        5   60F4KOMM
     I                                        7   80F4KODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20F4KOHH
     I                                        3   40F4KOSS
      *
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
     C           STEP0     TAG
     C                     MOVE *BLANK    IKOS
     C                     MOVE *BLANK    ICODE
     C                     MOVE *BLANK    INAME
     C                     SETOF                     04
      *
     C           STEP1     TAG
     C                     EXFMTFQAPW401
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           IKOS      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           IKOS      IFNE '0'
     C           IKOS      ANDNE'1'
     C           IKOS      ANDNE'2'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           ICODE     IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     END
      *
     C                     SETOF                     10
     C           ICODE     CHAINFQAPL401             10
      *
     C           IKOS      IFEQ '0'
     C           IKOS      OREQ '1'
     C           *IN10     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,4      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           F4SKJY    IFEQ 'D'
     C           F4SKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,4      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C                     MOVE F4NAME    INAME
     C                     END
      *
     C           IKOS      IFEQ '2'
     C           *IN10     ANDEQ'0'
     C           F4SKJY    IFEQ 'D'
     C           F4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     010299
     C                     MOVE ER,5      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C           IKOS      IFEQ '0'
     C                     SETON                     04
     C                     END
      *
     C           STEP2     TAG
     C                     EXFMTFQAPW402
     C                     SETOF                     0399
      *
     C           *INKC     IFEQ '1'
     C                     GOTO STEP0
     C                     ENDIF
      *
     C           INAME     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,6      MSG
     C                     GOTO STEP2
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STEP2
     C                     END
      *
     C           IKOS      IFEQ '0'
     C                     MOVE 'D'       F4SKJY
     C                     Z-ADD*DATE     F4SKHZ
     C                     ELSE
     C                     MOVE ' '       F4SKJY
     C                     Z-ADD0         F4SKHZ
     C                     END
      *
     C           IKOS      IFEQ '1'
     C           IKOS      OREQ '2'
     C                     MOVE ICODE     F4CODE
     C                     MOVE INAME     F4NAME
     C                     END
      *
     C                     Z-ADD*DATE     F4KOHZ
     C                     TIME           WTIME
     C                     MOVELUSER      F4KOME
      *
     C           *IN10     IFEQ '0'
     C                     UPDATFQAPL401
     C                     ELSE
     C                     WRITEFQAPL401
     C                     END
      *
     C                     GOTO STEP0
** ER
