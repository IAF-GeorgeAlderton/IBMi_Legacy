     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2 F5'#CHK2
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *   << INIT >>
      *===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1UPD
     C                     MOVE *BLANK    D1KOTE
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     MOVE *BLANK    D1ERR            エラー
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00000000'*IN,10
     C                     SETOF                         99
     C                     MOVE *BLANK    D1ERR            エラー
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F12 >  INQ.
     C           *INKL     IFEQ *ON
     C                     CALL 'AJSR08'
     C                     PARM D1KOTE    P@KOTE  3
     C                     PARM D1HIN1    P@HIN1  5
     C                     PARM D1HIN2    P@HIN2  5
     C                     PARM D1HIN3    P@HIN3  2
     C           P@KOTE    IFNE *BLANK
     C                     MOVELP@KOTE    D1KOTE
     C                     MOVELP@HIN1    D1HIN1
     C                     MOVELP@HIN2    D1HIN2
     C                     MOVELP@HIN3    D1HIN3
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C*--------------------
     C                     SELEC
     C           D1UPD     WHEQ '0'
     C                     MOVEL'0-CANCEL'D2UPD
     C                     SETON                     20
     C           D1UPD     WHEQ '1'
     C                     MOVEL'1-CHANGE'D2UPD
     C                     SETOF                     20
     C           D1UPD     WHEQ '2'
     C                     MOVEL'2-ADD   'D2UPD
     C                     SETOF                     20
     C                     OTHER
     C                     SETON                     1199
     C                     MOVELMSG,1     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDSL
     C*--------------------
     C* PROC.
     C*--------------------
     C           D1KOTE    IFEQ *BLANK
     C                     SETON                     1299
     C                     MOVELMSG,2     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C*
     C*(FCETL03).. PROCESS NAME M/F ...
     C           D1KOTE    CHAINFCETL03              91
     C  N91      A6GSKD    IFEQ 'D'
     C           A6GSHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C           D1UPD     ANDNE'0'                        <> 0=CANCEL
     C                     SETON                     1299
     C                     MOVELMSG,3     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
      *           A6KTNM        30A         COLHDG('PROCESS NAME KANA')
     C*--------------------
     C* PART NO.
     C*--------------------
     C           D1HIN1    IFEQ *BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C                     SETON                     1399
     C                     MOVELMSG,4     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C*(FCEPL01).. PART INFORMATION M/F ...
     C           KEY01     KLIST
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C           KEY01     CHAINFCEPL01              91
     C  N91      A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C           D1UPD     ANDNE'0'                        <> 0=CANCEL
     C                     SETON                     1399
     C                     MOVELMSG,5     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C*-------------------------
     C*(AJSPP09)
     C*-------------------------
     C           KEY02     KLIST
     C                     KFLD           D1KOTE
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C           KEY02     CHAINAJSPP09             N91
     C  N91      J@SKJY    IFEQ 'D'
     C           J@SKDT    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
      *
     C           *IN91     IFEQ *ON
     C           D1UPD     IFNE '2'                        <> 2=ADD
     C                     SETON                     111213
     C                     SETON                     99
     C                     MOVELMSG,6     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     Z-ADD0         D2TANJ
     C                     ELSE
     C           D1UPD     IFEQ '2'                        =  2=ADD
     C                     SETON                     111213
     C                     SETON                     99
     C                     MOVELMSG,7     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     Z-ADDJ@TANJ    D2TANJ
     C                     ENDIF
     C*
     C                     MOVELD1HIN1    D2HIN1
     C                     MOVELD1HIN2    D2HIN2
     C                     MOVELD1HIN3    D2HIN3
     C                     MOVEL'-'       D2HF1
     C                     MOVEL'-'       D2HF2
     C           D2HIN3    IFEQ *BLANK
     C                     MOVEL*BLANK    D2HF2
     C           D2HIN2    IFEQ *BLANK
     C                     MOVEL*BLANK    D2HF1
     C                     ENDIF
     C                     ENDIF
     C*-------------------------
     C           @CHK1Z    TAG
     C*-------------------------
S1   C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
X1   C                     ELSE
     C                     SETOF                     21
     C                     MOVEL*BLANK    D2ERR
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     EXFMTDSP02
     C                     SETOF                     2199
     C                     MOVE *BLANK    D2ERR
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVEA'00000000'*IN,11
     C                     MOVE *BLANK    D1ERR
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2 F5'@STEP
     C           D1UPD     IFEQ '0'                        0-CANCEL
     C                     MOVE '#UPDAT  '@STEP
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　チェック
      *===============================================================
     C           #CHK2     BEGSR
     C*--------------------
     C           D2TANJ    IFEQ 0
     C                     SETON                     2199
     C                     MOVELMSG,10    D2ERR
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*-------------------------
     C           @CHK2Z    TAG
     C*-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2 F5'
     C                     MOVEL'#UPDAT  '@STEP
     C                     ELSE
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  更新処理
      *===============================================================
     C           #UPDAT    BEGSR
     C*
     C           KEY02     CHAINAJSPP09              91
     C   91                CLEARAJSPP091
     C*
S1   C           D1UPD     IFEQ '0'                        0-CANCEL
     C                     MOVE 'D'       J@SKJY           DELETE CODE
     C                     Z-ADD@SYSHZ    J@SKDT           DELETE DATE
     C  N91                UPDATAJSPP091
X1   C                     ELSE
     C                     MOVE *BLANK    J@SKJY           DELETE CODE
     C                     Z-ADD0         J@SKDT           DELETE DATE
     C                     Z-ADD@SYSHZ    J@KODT           UPDATE DATE
     C                     Z-ADD@SYSTM    J@KOTM           UPDATE TIME
     C                     MOVELW@PGM     J@PGMN           UPDATE PGM
     C                     MOVELW@USER    J@KOME           UPDATE USER
     C                     MOVELD1KOTE    J@KOTE           PROC.
     C                     MOVELD1HIN1    J@HIN1           PART NO.-1
     C                     MOVELD1HIN2    J@HIN2           PART NO.-2
     C                     MOVELD1HIN3    J@HIN3           PART NO.-3
     C                     Z-ADDD2TANJ    J@TANJ           UNIT WEIGHT
     C   91                WRITEAJSPP091
     C  N91                UPDATAJSPP091
E1   C                     ENDIF
      *
     C                     MOVE *BLANK    D1UPD
     C                     MOVE *BLANK    D1KOTE
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     MOVE *BLANK    D1ERR
     C                     MOVEA'00000000'*IN,11
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
