     FGCQPW35 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FGCQPL31 IF  E           K        DISK
     FFCQPL21 IF  E           K        DISK
     FECQPP01 IF  E           K        DISK
     FGCQWP35 O   E                    DISK
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  15 DFKATA
     I                                        1   2 K@KAT1
     I                                        4   7 K@KAT2
     I                                        9   9 K@KAT3
     I                                       11  11 K@KAT4
     I            DS
     I                                        1  14 @PART
     I                                        1   5 DFSHN1
     I I            '-'                       6   6 AA
     I                                        7  11 DFSHN2
     I                                       12  12 BB
     I                                       13  14 DFSHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#ECQ     KLIST
     C                     KFLD           K@KAT1
     C                     KFLD           K@KAT2
     C                     KFLD           K@KAT3
     C                     KFLD           K@KAT4
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C           *INKE     WHEQ *ON
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
     C                     EXSR #WRT
     C                     MOVEL'99'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE DATA
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     Z-ADD*ZERO     @@CNT   30
     C                     MOVE *BLANK    WPART  12
     C           *LOVAL    SETLLGCQPL31
     C           *IN80     DOUEQ*ON
     C                     READ GCQPL31                  80
     C           *IN80     IFEQ *OFF
     C           DFSKJY    ANDEQ*BLANK
      *
     C           DFSHIN    IFNE WPART
     C                     Z-ADD*ZERO     @@CNT
     C                     ENDIF
      *
     C                     CLEARGCQWP351
      *
     C                     MOVE DFSHIN    WPART
     C                     ADD  1         @@CNT
     C                     Z-ADD@@CNT     GWNMBR
     C                     MOVE *BLANK    BB
     C           DFSHN3    IFNE *BLANK
     C                     MOVE '-'       BB
     C                     ENDIF
      *
     C                     MOVE @PART     GWPART
     C                     MOVE DFKATA    GWKATA
     C                     Z-ADDDFKSEI    GWKSEI
     C                     Z-ADDDFKOSU    GWKOSU
     C                     MOVE DFKOTI    GWKOTI
     C                     MOVELDFKATA    @@2     2
     C           @@2       CHAINFCQPL211             90
     C           *IN90     IFEQ *OFF
     C                     MOVELO9KANM    GWNAME
     C                     ENDIF
      *
     C           K#ECQ     SETGTECQPP01
     C           *IN90     DOUEQ*ON
     C           K#ECQ     REDPEECQPP01                  90
     C           *IN90     IFEQ *OFF
     C           ECSKJY    ANDEQ*BLANK
     C           ECVALD    ANDLE*DATE
     C                     Z-ADDECUPRC    GWUPRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           GWUPRC    MULT GWKOSU    GWAMNT
     C                     WRITEGCQWP351
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
