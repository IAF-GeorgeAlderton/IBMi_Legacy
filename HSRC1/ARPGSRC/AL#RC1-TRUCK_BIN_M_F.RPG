     H            Y.
     F** AL#RC1 **************************************
     F* TRUCK BIN M/F                                *
     F*        ITS.         2015.05.20               *
     F************************************************
     FAL#PWC1 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FAL#WPC1 IF  E           K        DISK
     FAL#PPC1 IF  E           K        DISK
      *
     E                    ER      1  11 65
      *
     I            DS
     I                                        1   40W1STTK
     I                                        1   2 W1STKH
     I                                        3   4 W1STKM
      *
     I            DS
     I                                        1   40W1EDTK
     I                                        1   2 W1EDKH
     I                                        3   4 W1EDKM
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KIHZ  8
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
     C                     MOVE P1KIHZ    C1KIHZ
     C                     SETOF                     39
     C           C1KIHZ    IFNE 0
     C                     SETON                     39
     C                     ENDIF
     C*****                MOVE P1KIHZ    C2KIHZ
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLAL#WPC11
     C                     READ AL#WPC11                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AL#WPC11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEAL#PWC19
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     303199
     C                     SETOF                     3233
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
     C           X         DOWLE15
     C           *IN99     ANDEQ'0'
     C           X         CHAINSFL                  21
     C           *IN21     IFEQ '0'
     C                     EXSR #SFCHK
     C           *IN99     IFEQ '0'
     C                     EXSR #SB221
     C                     ENDIF
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     C           *IN99     IFEQ '0'
     C           C1KIHZ    IFEQ 0
     C                     SETON                     3399
     C                     MOVELER,5      D9ERR
     C                     ELSE
     C           *IN39     IFEQ '0'
     C                     EXSR #SB555
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTAL#WPC11
     C                     READPAL#WPC11                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  15        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPAL#WPC11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLAL#WPC11
     C                     READ AL#WPC11                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AL#WPC11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AL#WPC11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      * F5
     C           *IN05     IFEQ '1'
     C                     MOVELC1KIHZ    P1KIHZ
     C                     MOVEL'05'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK                                              *
      *----------------------------------------------------*
     CSR         #SB555    BEGSR
      *
     C                     MOVEL'0'       GET     1
     C           C1KIHZ    SETLLAL#PPC11
     C           C1KIHZ    READEAL#PPC11                 48
     C           *IN48     DOWEQ'0'
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C           C1KIHZ    READEAL#PPC11                 48
     C                     ENDDO
      *
     C           GET       IFEQ '1'
     C                     SETON                     3399
     C                     MOVELER,6      D9ERR
     C                     ENDIF
      *
     CSR         ESB555    ENDSR
      *----------------------------------------------------*
      * CHECK                                              *
      *----------------------------------------------------*
     CSR         #SFCHK    BEGSR
      *
     C           S1SURT    IFEQ *BLANK
     C           S1STTN    ANDEQ0
     C           S1EDTN    ANDEQ0
     C                     ELSE
     C                     EXSR #SFCH2
     C           *IN99     IFEQ '1'
     C                     GOTO ESFCHK
     C                     ENDIF
     C                     ENDIF
      *
      *
     CSR         ESFCHK    ENDSR
      *----------------------------------------------------*
      * CHECK                                              *
      *----------------------------------------------------*
     CSR         #SFCH2    BEGSR
      *
     C           S1SURT    IFEQ *BLANK
     C                     SETON                     3099
     C                     MOVELER,3      D9ERR
     C                     GOTO ESFCH2
     C                     ENDIF
      *
     C                     MOVELS1TRKB    P9TRKB
     C                     MOVELS1SURT    P9SURT
     C                     Z-ADDS1STTN    P9STTN
     C                     Z-ADDS1EDTN    P9EDTN
     C                     MOVELH1SEQ     P9SEQ
     C                     CALL 'AL#RC7'
     C                     PARM           P9TRKB  2
     C                     PARM           P9SURT  9
     C                     PARM           P9STTN  40
     C                     PARM           P9EDTN  40
     C                     PARM           P9SEQ   3
     C                     PARM           P9STS   1
     C           P9STS     IFEQ '1'
     C                     SETON                     3099
     C                     MOVELER,7      D9ERR
     C                     GOTO ESFCH2
     C                     ENDIF
     C           P9STS     IFEQ '2'
     C                     SETON                     3199
     C                     MOVELER,7      D9ERR
     C                     GOTO ESFCH2
     C                     ENDIF
     C           P9STS     IFEQ '3'
     C                     SETON                     3299
     C                     MOVELER,7      D9ERR
     C                     GOTO ESFCH2
     C                     ENDIF
      *
     CSR         ESFCH2    ENDSR
      *----------------------------------------------------*
      * CHECK                                              *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     MOVELS1TRKB    P9TRKB
     C                     MOVELS1SURT    P9SURT
     C                     Z-ADDS1STTN    P9STTN
     C                     Z-ADDS1EDTN    P9EDTN
     C                     MOVELH1SEQ     P9SEQ
     C                     CALL 'AL#RC2'
     C                     PARM           P9TRKB  2
     C                     PARM           P9SURT  9
     C                     PARM           P9STTN  40
     C                     PARM           P9EDTN  40
     C                     PARM           P9SEQ   3
      *
     CSR         ESB221    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 15
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT DATA                                        *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR ITEM                                         *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT ITEM                                          *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVELW1TRKB    S1TRKB
     C                     MOVELW1SURT    S1SURT
     C                     MOVELW1STTN    S1STTN
     C                     MOVELW1EDTN    S1EDTN
     C                     MOVELW1KURT    S1KURT
     C                     MOVEL*BLANK    S1STTK
     C                     MOVEL*BLANK    S1EDTK
     C           W1KURT    IFNE *BLANK
     C           S1STTK    CAT  W1STKH:0  S1STTK
     C           S1STTK    CAT  ':':0     S1STTK
     C           S1STTK    CAT  W1STKM:0  S1STTK
     C           S1EDTK    CAT  W1EDKH:0  S1EDTK
     C           S1EDTK    CAT  ':':0     S1EDTK
     C           S1EDTK    CAT  W1EDKM:0  S1EDTK
     C                     ENDIF
     C                     MOVELW1SEQ     H1SEQ
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * NEXT DATA                                          *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ AL#WPC11                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      * PRV DATA                                           *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPAL#WPC11                 81
      *
     CSR         ENEXTP    ENDSR
     C*----------------------------------------------------------------
**
ER-1 THERE ARE NO DATA.
ER-2 INPUT 1 OR 2.
ER-3 INPUT CUSTOMER TRUCK#.
ER-4 INPUT IAF TRUCK BIN#.
ER-5 INPUT CHANGE DATE.
ER-6 THIS CHANGE DATE IS ALREADY EXIST.
ER-7 DUPLICATE ERR.
ER-8
