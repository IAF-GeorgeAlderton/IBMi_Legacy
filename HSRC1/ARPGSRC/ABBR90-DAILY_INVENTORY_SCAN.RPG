     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *BLANK    ERR1                         F5
     C                     MOVE *BLANK    ERR2                         F5
     C                     SETOF                     996162
      *
     C           D@KNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ELSE
     C**
     C                     MOVE D@KNBN    WBAR
     C           WWBCHK    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,9     ERR1
     C                     ENDIF
      *
     C           WWZETI    CHAINFCETL11              90
B01  C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ENDIF
      *
     C           K#ABB     CHAINABBPL90              90
     C  N99      *IN90     IFEQ *OFF
     C                     SETON                     9961
     C                     MOVELERR,2     ERR1
     C                     MOVELERR,3     ERR2
     C                     ENDIF
      * CHECK DIGIT
#### C           #USER     IFNE 'TEST'
#### C           #USER     ANDNE'I0777'
     C                     MOVELWBAR      PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ELSE
     C           PMCHK     IFNE WWCHK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ENDIF
     C                     ENDIF
#### C                     END
     C                     ENDIF
