|||  C           A32HB5    ANDEQA9PRT2
|||  C           A33HB2    ANDEQA9PRT3
|||  C           A3SKJY    IFEQ 'D'
|||  C           A3STHZ    ORNE 99999999
|||  C                     ITER
|||  C                     ENDIF
|||  C                     Z-ADDA3BARA    @BARL   20
|||  C                     LEAVE
|||  C                     ENDIF
|||  C                     ENDDO
|||   *
|||  C           NCKQ,W    WHEQ 'D'
|||  C           K#LOC     SETLLAAGPL03
|||  C           *IN95     DOUEQ*ON
|||  C           K#LOC     READEAAGPL03                  95
|||  C           *IN95     IFEQ *OFF
|||  C           O4SHN1    ANDEQA9PRT1
|||  C           O4SHN2    ANDEQA9PRT2
|||  C           O4SHN3    ANDEQA9PRT3
|||  C           O4SKJY    IFEQ 'D'
|||  C           O4STHZ    ORNE 99999999
|||  C                     ITER
|||  C                     ENDIF
|||  C                     Z-ADDO4BARA    @BARL
|||  C                     LEAVE
|||  C                     ENDIF
|||  C                     ENDDO
|||   *
|||  C           NCKQ,W    WHEQ 'E'
|||  C           K#LOC     SETLLAAHPL03
|||  C           *IN95     DOUEQ*ON
|||  C           K#LOC     READEAAHPL03                  95
|||  C           *IN95     IFEQ *OFF
|||  C           L6SHN1    ANDEQA9PRT1
|||  C           L6SHN2    ANDEQA9PRT2
|||  C           L6SHN3    ANDEQA9PRT3
|||  C           L6SKJY    IFEQ 'D'
|||  C           L6STHZ    ORNE 99999999
|||  C                     ITER
|||  C                     ENDIF
|||  C                     Z-ADDL6LOTO    @BARL
|||  C                     LEAVE
|||  C                     ENDIF
|||  C                     ENDDO
|||  C*
|||  C           NCKQ,W    WHEQ 'B'
|||   *
|||  C           K#LOC     SETLLADHPL03
|||  C           *IN95     DOUEQ*ON
|||  C           K#LOC     READEADHPL03                  95
|||  C           *IN95     IFEQ *OFF
|||  C           J6SHN1    ANDEQA9PRT1
|||  C           J6SHN2    ANDEQA9PRT2
|||  C           J6SHN3    ANDEQA9PRT3
|||  C           J6SKJY    IFEQ 'D'
|||  C           J6STHZ    ORNE 99999999
