     C**************************************************************************
     C           #CHK0     BEGSR
      *
     C                     SETOF                     6199
      *
TCHK2C           D@LOC     IFEQ 'A'
TCHK3C           D@LOC     OREQ 'B'
TCHK5C           D@LOC     OREQ 'C'
TCHK5C           D@LOC     OREQ 'D'
TCHK5C           D@LOC     OREQ 'E'
     C           D@LOC     OREQ 'F'
JW2  C           D@LOC     OREQ 'G'
"    C           D@LOC     OREQ 'H'
TCHK3C                     ELSE
     C           D@LOC     IFLT '0'
     C           D@LOC     ORGT '9'
     C                     SETON                     6199
     C                     ENDIF
TCHK2C                     END
      *
      *
