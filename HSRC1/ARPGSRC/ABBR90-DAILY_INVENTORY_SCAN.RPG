     C                     ELSE
     C                     MOVE 'A'       @@K              A-PICS
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
      * GO TO 2ND SCREEN TO ENTER # OF CONTAINER
     C           D@LOC     IFEQ 'E'                        QD
     C           D@LOC     OREQ 'C'                        JC-PL
     C           D@LOC     OREQ 'D'                        JC
     C                     EXSR #SCRNB
     C                     ELSE
     C                     EXSR #WRT
     C***                  CLEARDSP01
     C                     MOVEL*BLANK    D@KNBN
     C                     MOVEL*BLANK    D@ERR
     C                     SETOF                     616299
     C***                  CLEARDSP11
     C                     Z-ADD0         D@HAKO
     C                     END
     C                     ELSE
     C                     EXFMTERR01
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
