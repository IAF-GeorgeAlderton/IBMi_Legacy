     C*************************************************************************
     C*          IST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F3:BACK
     C           *INKC     WHEQ *ON
     C                     MOVE '00'      @@ID
     C                     CLEARDSP00
     C                     CLEARDSP01
     C                     CLEARDSP11
     C* F7:CANCEL
     C           *INKG     WHEQ *ON
     C                     MOVE '02'      @@ID
     C                     CLEARDSP02
     C*** F5:CHANGE KANBAN KIND - NO USED
     C***        *INKE     WHEQ *ON
     C***        @@K       IFEQ 'A'
     C***                  MOVE 'P'       @@K
     C***                  ELSE
     C***                  MOVE 'A'       @@K
     C***                  ENDIF
      *
     C                     OTHER
      * CHECK
     C                     EXSR #CHK1
      *
     C           WWKANS    IFGE '0'
     C           WWKANS    ANDLE'9'
