     C                     MOVELA2BHB2    A9PRT2
     C                     MOVELA2BHB3    A9PRT3
      * A-PICS
1    C           @@K       IFEQ 'A'
|     *
|2   C           D@LOC     IFEQ 'E'
||   C           D@LOC     OREQ 'C'
||   C           D@LOC     OREQ 'D'
||   C           A2SSYS    MULT D@HAKO    A9QTY
||   C                     Z-ADDD@HAKO    A9BOX
|2   C                     ELSE
||   C           A2SSYS    MULT 4         A9QTY
||   C                     Z-ADD4         A9BOX
|2   C                     END
|     * IN-PROCESS
1    C                     ELSE
|    C           K#KEY     CHAINAAMPL11              90
|    C                     Z-ADD1         W       20
|    C           WWPROC    LOKUPNPRC,W                   10
|     *
|     * IN CASE OF 3 SPECIAL PARTS, PASS THE PROCESS CHECK
|2   C           A9PRT1    IFEQ 'U1026'
||   C           A9PRT2    ANDEQ'B1082'
||   C           A9PRT1    OREQ 'U1026'
||   C           A9PRT2    ANDEQ'B1083'
||   C           A9PRT1    OREQ 'U1026'
||   C           A9PRT2    ANDEQ'B1084'
||   C                     MOVE *ON       *IN10
|2   C                     ENDIF
|     *
|2   C           *IN10     IFEQ *ON
||   C                     MOVE NTKR,W    W7LOC
||   C                     MOVE PRT,W     W@CPRT 12
||   C                     SELEC
||3  C           NCKQ,W    WHEQ 'C'
|||  C           K#LOC     SETLLAAFPL03
|||  C           *IN95     DOUEQ*ON
|||  C           K#LOC     READEAAFPL03                  95
|||  C           *IN95     IFEQ *OFF
