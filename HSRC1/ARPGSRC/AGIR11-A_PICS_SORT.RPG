     C                     TIME           WTIME
      *
     C                     Z-ADD0         WKTOHZ  80
     C                     Z-ADD0         WKYOHZ  80
     C                     Z-ADD0         WKCIBI  20
     C           0111      CHAINAAIPL111             44
     C           *IN44     IFEQ '0'
     C                     Z-ADDCDTOHZ    WKTOHZ
     C                     Z-ADDCDYOHZ    WKYOHZ
     C                     Z-ADDCDCIBI    WKCIBI
     C                     ENDIF
      *
     C                     MOVEL*DATE     WKDATE
     C                     MOVEL'01'      WKBIN
     C                     READ AGAPL311                 80
     C           *IN80     DOWEQ'0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLESDATE
     C                     ELSE
     C           TRXX      IFEQ *ALL'0'
     C                     EXSR #SB400
     C                     ELSE
     C                     EXSR #SB450
     C                     ENDIF
     C                     ENDIF
     C                     READ AGAPL311                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     CLEARAGIWP301
     C                     MOVELCBSHN1    W0SHN1
     C                     MOVELCBSHN2    W0SHN2
     C                     MOVELCBSHN3    W0SHN3
     C                     Z-ADD0         W0HAKO
     C                     Z-ADD0         WHK     50
     C                     Z-ADD0         WHN     50
     C                     XFOOTHN        WHN
     C                     Z-ADD1         X       30
     C           X         DOWLE24
     C           BI,X      IFEQ 0
     C                     ADD  HK,X      WHK
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           WHK       ADD  WHN       W0HAKO
     C                     Z-ADDCBBARL    W0BARL
     C                     Z-ADDWKCIBI    W0CIBI
      *
     C           KEYW8     KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C           KEYW8     CHAINAGIWP081             20
     C           *IN20     IFEQ '0'
     C                     MOVELW8SORT    W0SORT
     C                     Z-ADDW8GEKN    W0GEKN
     C                     Z-ADDW8SYUY    W0SYUY
     C                     Z-ADDW8HAKO    W0GEKH
     C                     ELSE
     C                     MOVEL'99999'   W0SORT
     C                     Z-ADD0         W0GEKN
     C                     Z-ADDCBSYUY    W0SYUY
     C                     Z-ADD0         W0GEKH
     C                     ENDIF
     C           W0HAKO    IFNE 0
     C                     WRITEAGIWP301
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB450    BEGSR
      *
     C                     Z-ADD1         X       30
     C           X         DOWLE24
     C           BI,X      IFEQ 0
     C           HK,X      IFNE 0
     C                     Z-ADDHK,X      ##HAKO  50
     C                     Z-ADDWKTOHZ    ##APHZ  80
     C                     Z-ADDX         ##APBB  20
     C                     EXSR #SB451
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     C                     Z-ADD1         X       30
     C           X         DOWLE24
     C           HN,X      IFNE 0
     C                     Z-ADDHN,X      ##HAKO  50
     C                     Z-ADDWKYOHZ    ##APHZ  80
     C                     Z-ADDX         ##APBB  20
     C                     EXSR #SB451
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB450    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB451    BEGSR
      *
     C                     CLEARAGIWP311
     C                     MOVELCBSHN1    W#SHN1
     C                     MOVELCBSHN2    W#SHN2
