     H            Y.
     F** ADAR49 ****************************************
     F*..PUBLISH DATA CHECK LIST WHICH PRODUCTION ORDER AGAIN AND OVER MADE<2> *
     F*                S.YAMAGMI 92.03.26              *
     F**************************************************
     FADAWP49 IP  F      50            DISK
     FRGAPL11 IF  E           K        DISK
     FADAPR49 O   E             55     PRINTER
      *
     IADAWP49 AA
     I                                        1  12 IHIN
     I                                        1   5 IHN1
     I                                        6  10 IHN2
     I                                       11  12 IHN3
     I                                       13  18 ITK
     I                                       13  13 ITK1
     I                                       14  15 ITK2
     I                                       16  17 ITK3
     I                                       18  18 ITK4
     I                                       19  19 IDKB
     I                                       20  220IMAIS
     I            DS
     I                                        1   80J8KOHZ
     I                                        1   40J8KOYY
     I                                        5   60J8KOMM
     I                                        7   80J8KODD
      *
     C                     SETOF                     OF
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
     C                     PARM           PNO     1
     C                     PARM           PHIZ    8
     C                     MOVE PHIZ      @HIZ    80
      *
      *
     C           *IN40     IFEQ '0'
     C                     SETON                     4055
     C                     TIME           TIME    60
     C                     Z-ADD0         WNO     30
     C                     Z-ADD0         WWPU    40
     C                     Z-ADD0         WWMA    40
      * ﾆｭﾒﾆｫ
     C                     SETOF                     10
     C           PUSER     CHAINRGAPL111             10
     C           *IN10     IFEQ '0'
     C           J8SKJY    IFEQ 'D'
     C           J8KOHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVE J8NAME    WNAME  15
     C                     END
     C                     END
      * ﾆｭﾒﾍﾞ
     C           PNO       IFEQ '1'
     C                     MOVEL' INPUT'WRIST   8
     C                     ELSE
     C                     MOVEL'LOCATION'WRIST
     C                     END
     C                     END
      *
     C           *IN55     IFEQ '0'
     C                     GOTO STEP1
     C                     END
      *
     C                     WRITEADAPR491
     C                     SETOF                     55
      *
     C           STEP1     TAG
      *
     C                     ADD  1         WNO
      *
     C           IDKB      IFEQ 'S'
     C                     ADD  IMAIS     WWPU
     C                     END
     C           IDKB      IFEQ 'T'
     C                     ADD  IMAIS     WWMA
     C                     END
      *
     C                     WRITEADAPR492
      *
     CLR                   WRITEADAPR493
