      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1SHID  8
     C                     PARM           P9CMD   2
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     Z-ADD0         ##DA
     C                     Z-ADDWTIHZ     ##DATE
     C                     Z-ADDWTITM     ##TIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
     C                     MOVEL'0'       KKTYPE  1
     C                     MOVELP1SHID    C1SHID  80
     C                     MOVEL*BLANK    P9CMD   2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * INQ                                                *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLAM#WP641
     C                     READ AM#WP641                 81
      *開始実績の最新を探す
     C                     Z-ADD0         ##AST  140
     C           *IN81     DOWEQ'0'
     C           W4AST     IFGT ##AST
     C                     Z-ADDW4AST     ##AST  140
     C                     ENDIF
     C                     READ AM#WP641                 81
     C                     ENDDO
      *開始実績の最新まで読む
     C                     MOVEL'0'       ENDSW   1
     C           *LOVAL    SETLLAM#WP641
     C                     READ AM#WP641                 81
     C           *IN81     DOWEQ'0'
     C           ENDSW     ANDEQ'0'
     C           W4AST     IFEQ ##AST
     C                     MOVEL'1'       ENDSW   1
     C                     ENDIF
     C                     READ AM#WP641                 81
     C                     ENDDO
      *６便前まで戻す
     C                     MOVEL*BLANK    ##SHID  8
     C                     Z-ADD0         ##EXTR  30
     C                     MOVEL*BLANK    ##TRKB  2
     C                     MOVEL*BLANK    ##IAFB  3
     C                     Z-ADD0         ##AST  140
     C                     Z-ADD0         D       30
     C           *IN81     DOWEQ'0'
     C           D         ANDLE7
     C           W4IAFB    IFNE *BLANK
     C                     MOVELW4SHD1    ##SHID  8
     C                     Z-ADDW4EXTR    ##EXTR  30
     C                     MOVELW4TRKB    ##TRKB  2
     C                     MOVELW4IAFB    ##IAFB  3
     C                     Z-ADDW4AST     ##AST  140
     C                     ADD  1         D
     C                     ENDIF
     C                     READPAM#WP641                 81
     C                     ENDDO
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLAM#WP641
     C                     READ AM#WP641                 81
     C                     ENDIF
     C                     MOVEL'0'       ENDSW   1
     C           *LOVAL    SETLLAM#WP641
     C                     READ AM#WP641                 81
     C           *IN81     DOWEQ'0'
     C           ENDSW     ANDEQ'0'
     C           W4AST     IFEQ ##AST
     C           W4SHD1    ANDEQ##SHID
     C           W4EXTR    ANDEQ##EXTR
     C           W4TRKB    ANDEQ##TRKB
     C           W4IAFB    ANDEQ##IAFB
     C                     MOVEL'1'       ENDSW   1
     C                     ENDIF
     C           ENDSW     IFEQ '0'
     C                     READ AM#WP641                 81
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AM#WP641                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * SFL                                                *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C*****                EXFMTSFLCTL
     C                     WRITEAM#PW629               92
     C           *IN92     DOWEQ'1'
     C                     READ AM#PW62                9191
      *例外エラー
     C           MJCODE    IFNE '00'
     C                     MOVEL'03'      P9CMD   2
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C           MJCOD4    IFEQ '0300'
     C                     MOVEL'03'      P9CMD   2
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C                     WRITEAM#PW629               92
     C                     ENDDO
     C           *IN92     IFEQ '1'
     C                     READ AM#PW62                9191
     C                     WRITEAM#PW629               92
     C                     WRITESFLCTL                 92
     C                     READ AM#PW62                9191
     C                     GOTO ENT
     C***                  MOVEL'05'      P9CMD   2
     C***                  SETON                     LR
     C***                  RETRN
     C                     ENDIF
      *
     C                     WRITESFLCTL                 92
     C                     READ AM#PW62                9191
     C           MJCODE    IFNE '00'
     C           MJCODE    ANDNE'03'
     C                     EXSR *PSSR
     C                     MOVEL'03'      P9CMD   2
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      ***
     C           ENT       TAG
      ***
     C           *IN91     IFEQ '1'
     C           @STTS     ANDEQ1331
     C                     MOVEL'05'      P9CMD   2
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      P9CMD   2
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C***        WKPAGE    IFEQ 1
     C***                  GOTO ESB220
     C***                  ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTAM#WP641
     C                     READPAM#WP641                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  15        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPAM#WP641                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLAM#WP641
     C                     READ AM#WP641                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AM#WP641                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AM#WP641                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *エラー回避                                        *
      *----------------------------------------------------*
     CSR         *PSSR     BEGSR
      *
     C                     TIME           WTIME
     C                     Z-ADDWTIHZ     R5KOHZ
     C                     Z-ADDWTITM     R5KOTI
     C                     MOVELW#WSID    R5WSID
     C                     MOVELW#PGM     R5PGM
     C                     MOVELMJCOD4    R5MJC4
     C                     MOVEL@STTS     R5STTS
     C                     WRITEAM#PP511
      *
     C                     MOVEL'03'      P9CMD   2
     C                     SETON                     LR
     C                     RETRN
      *
     CSR                   ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 15
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT                                             *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR                                              *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     SETON                     72
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     SETOF                     72
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     SETOF                     3536
     C                     MOVEL*BLANK    S1SHID
     C                     MOVEL*BLANK    S1SHIT
     C                     MOVEL*BLANK    S1SR
     C                     Z-ADD0         S1SUMI
     C                     Z-ADD0         S1BOX
     C           W4IAFB    IFEQ *BLANK
     C                     MOVELW4SHD1    S1SHID
     C                     MOVELW4SHT1    WKTI
     C           S1SHIT    CAT  WKTIHH:0  S1SHIT
     C           S1SHIT    CAT  ':':0     S1SHIT
     C           S1SHIT    CAT  WKTIMM:0  S1SHIT
     C                     SETON                     35
     C                     ELSE
     C                     MOVELW4TRKB    S1TRKB
     C                     MOVELW4IAFB    S1IAFB
     C                     MOVEL'/'       S1SR
     C                     Z-ADDW4COMP    S1SUMI
     C                     Z-ADDW4KPLT    S1BOX
     C                     ENDIF
      *
     C                     Z-ADDW4PSTD    S1PSTD
     C                     MOVEL*BLANK    S1PSTT
     C           S1PSTD    IFNE 0
     C                     MOVELW4PSTT    WKTI
     C           S1PSTT    CAT  WKTIHH:0  S1PSTT
     C           S1PSTT    CAT  ':':0     S1PSTT
     C           S1PSTT    CAT  WKTIMM:0  S1PSTT
     C                     ENDIF
     C           W4PST     IFLE ##DA
     C           W4AST     ANDEQ0
     C                     SETON                     36
     C                     ENDIF
      *
     C                     Z-ADDW4ASTD    S1ASTD
     C                     MOVEL*BLANK    S1ASTT
     C           S1ASTD    IFNE 0
     C                     MOVELW4ASTT    WKTI
     C           S1ASTT    CAT  WKTIHH:0  S1ASTT
     C           S1ASTT    CAT  ':':0     S1ASTT
     C           S1ASTT    CAT  WKTIMM:0  S1ASTT
     C                     ENDIF
      *
     C                     Z-ADDW4PEDD    S1PEDD
     C                     MOVEL*BLANK    S1PEDT
     C           S1PEDD    IFNE 0
     C                     MOVELW4PEDT    WKTI
     C           S1PEDT    CAT  WKTIHH:0  S1PEDT
     C           S1PEDT    CAT  ':':0     S1PEDT
     C           S1PEDT    CAT  WKTIMM:0  S1PEDT
     C                     ENDIF
      *
     C                     Z-ADD0         S1AEDD
     C                     MOVEL*BLANK    S1AEDT
     C           W4KPLT    IFEQ W4COMP
     C                     Z-ADDW4AEDD    S1AEDD
     C                     MOVEL*BLANK    S1AEDT
     C           S1AEDD    IFNE 0
     C                     MOVELW4AEDT    WKTI
     C           S1AEDT    CAT  WKTIHH:0  S1AEDT
     C           S1AEDT    CAT  ':':0     S1AEDT
     C           S1AEDT    CAT  WKTIMM:0  S1AEDT
     C                     ENDIF
     C                     ENDIF
      *
     C           S1AEDD    IFEQ 0
     C                     Z-ADDW4HKHZ    S1AEDD
     C           S1AEDD    IFNE 0
     C                     MOVELW4HKTI    WKTI
     C           S1AEDT    CAT  WKTIHH:0  S1AEDT
     C           S1AEDT    CAT  ':':0     S1AEDT
     C           S1AEDT    CAT  WKTIMM:0  S1AEDT
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETOF                     37
     C           W4EXTR    IFNE 0
     C                     SETON                     37
     C                     ENDIF
      *
     C                     SETOF                     38
     C                     MOVEL'0'       H138
     C           W4AST     IFGT W4PST
     C                     SETON                     38
     C                     MOVEL'1'       H138
     C                     ENDIF
      *
     C                     SETOF                     39
     C                     MOVEL'0'       H139
     C           W4AED     IFGT W4PED
     C                     SETON                     39
     C                     MOVEL'1'       H139
     C                     ENDIF
      *
     C                     MOVEL*BLANK    S1STS
     C           W4IAFB    IFNE *BLANK
     C           W4KPLT    IFEQ W4COMP
     C                     MOVEL'DONE'    S1STS
     C                     ENDIF
     C                     ENDIF
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * NEXT                                               *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ AM#WP641                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      * PRV                                                *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
