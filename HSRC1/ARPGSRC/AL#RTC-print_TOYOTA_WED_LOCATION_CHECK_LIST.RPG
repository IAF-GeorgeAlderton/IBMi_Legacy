     H            Y.
     F** AL#RTC  *******************************************
     F*  CHECK WEB DATA (PRINT)                            *
     F*  JW    2018.08.17                                  *
     F******************************************************
     FAL#WP01 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      *
     I            DS
     I                                        1   8 CASHID
     I                                        1   4 CASHYY
     I                                        5   6 CASHMM
     I                                        7   8 CASHDD
     I            DS
     I                                        1  10 WKSHID
     I                                        1   4 WKSHYY
     I                                        5   5 HP1
     I                                        6   7 WKSHMM
     I                                        8   8 HP2
     I                                        9  10 WKSHDD
      *
     I            DS
     I                                        1   9 IAF
     I                                        1   1 CATKR1
     I                                        2   2 H1
     I                                        3   4 CATKR2
     I                                        5   5 H2
     I                                        6   7 CATKR3
     I                                        8   8 H3
     I                                        9   9 CATKR4
      *
     I            DS
     I                                        1  30 CASUPI
     I                                        7   8 LOC2
     I                                       10  11 LOC3
     I                                       13  13 LOC4
     I                                        5  13 TOYOTA
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AL#WP01                  91
     C   91                LEAVE
      * IGNORE
     C           CASUPI    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      * FIRST
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELCATKR2    SVTKR2
     C                     MOVELCATKR3    SVTKR3
     C                     MOVELCATKR4    SVTKR4
     C                     ENDIF
      * BREAK?
     C           CATKR2    IFNE SVTKR2
     C           CATKR3    ORNE SVTKR3
     C           CATKR4    ORNE SVTKR4
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     ENDDO
      * FINAL BREAK
     C           FIRST     IFEQ 'N'
     C           CASUPI    ANDNE*BLANK
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------
     C           #BRK1     BEGSR
      *---------------------------
     C           LIN#      IFGE 64
     C                     EXCPT@HDR1
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     MOVELCASHYY    WKSHYY
     C                     MOVELCASHMM    WKSHMM
     C                     MOVELCASHDD    WKSHDD
      *
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      * RESET
     C                     MOVELCATKR2    SVTKR2
     C                     MOVELCATKR3    SVTKR3
     C                     MOVELCATKR4    SVTKR4
      *
     C                     ENDSR
      *---------------------------
     C           #INIT     BEGSR
      *---------------------------
     C           *ENTRY    PLIST
     C                     PARM           @SHPDT  8
      *
     C                     TIME           WDATE
     C                     Z-ADD80        LIN#    30
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE *BLANK    SVTKR2  2
     C                     MOVE *BLANK    SVTKR3  2
     C                     MOVE *BLANK    SVTKR4  1
     C                     MOVE '-'       H1
     C                     MOVE '-'       H2
     C                     MOVE '-'       H3
     C                     MOVE '-'       HP1
     C                     MOVE '-'       HP2
      * SET HEADER DATE
     C                     MOVEL@SHPDT    CASHID
     C                     MOVELCASHYY    WKSHYY
     C                     MOVELCASHMM    WKSHMM
     C                     MOVELCASHDD    WKSHDD
     C                     MOVELWKSHID    HDSHID 10
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR1
     O                         #PGM      10
     O                                   35 '** TOYOTA WEB LOCATI'
     O                                   55 'ON CHECK LIST SORTED'
     O                                   75 ' BY LOCATION **     '
     O                                   82 'DATE'
     O                         TODAY     85 '    .  .  '
     O                         NOW       95 '  :  :  '
     O                                   99 'P.'
     O                         PAGE  Z  103
      *
     O        E   02           @HDR1
     O                                   22 'START SHIP DATE FROM :'
     O                         HDSHID    33
      *
     O        E   03           @HDR1
     O                                    9 'SHP_DATE'
     O                                   21 'RCV_DATE'
     O                                   29 'CUS#'
     O                                   35 'DLV#'
     O                                   38 'F'
     O                                   44 'DOCK'
     O                                   54 'IAF_PART'
     O                                   70 ' '
     O                                   71 'LOCATION'
     O                                   85 'TOYOTA_WEB'
     O                                   95 'USER_INF'
     O        E 1              @DTL1
     O                         WKSHID  +001
     O                         CAWBRD  +002 '    /  /  '
     O                         CATOKU  +002
     O                         CANONY  +002
     O                         CANKOJ  +002
     O                         CANUKE  +002
     O                         CASHN1  +002
     O                         CASHN2  +001
     O                         CASHN3  +001
     O                         IAF     +003
     O                         TOYOTA  +003
     O                         CASUPI  +003
