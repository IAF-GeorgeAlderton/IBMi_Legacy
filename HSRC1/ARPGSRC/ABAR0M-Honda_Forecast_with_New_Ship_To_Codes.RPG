     H            Y.
      ** ABAR0M ************************************************
      *  HONDA Forecast with New Ship To Codes WF              *
      *    Listing to be emailed to Honda distr. list          *
      ************************************ ABAR0M **************
     FABAWP2H IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      ****************************************************
      * TIME
     I            DS
     I                                        1  120WTMDT
     I                                        1   60WTIME
     I                                        7  120WDATE
      ***********************************************************
      *
     C                     TIME           WTMDT
     C                     SETON                     OF
      *
     C                     EXSR @MAIN
      *
     C                     SETON                     LR
     C                     RETRN
      *
      ***********************************************************
      *    MAIN SUBROUTINE...                                  **
      *
     C           @MAIN     BEGSR
      *
     C                     READ ABAWP2H                  90
     C           *IN90     DOWEQ*OFF
      *
     C   OF                EXCPT#HED1
     C   OF                EXCPT#HED2
     C   OF                SETOF                     OF
     C                     EXCPT#DTL1
      *
     C                     READ ABAWP2H                  90
     C                     ENDDO
      *
     C                     ENDSR
      ***********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
     O                                    8 'ABAR0M'
     O                                   52 'HONDA FORECAST WITH NEW'
     O                                   66 'SHIP TO CODES'
      *
     O        E 1              #HED1
     O       OR        OF
     O                                  131 '.         .         .'
      *
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
      *
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O        E 1              #HED2
     O       OR        OF
     O                                    8 'Partner'
     O                                   18 'Cust'
     O                                   25 'Delv'
     O                                   35 'Ship To'
     O                                   44 'Name'
     O                                   85 'Address 1'
     O                                  121 'Address 2'
     O                                  152 'City'
     O                                  177 'St'
     O                                  187 'Zip Code'
     O                                  197 'Country'
      *
     O        E 1              #DTL1
     O                         W2PRTR    11
     O                         W2TOKU    18
     O                         W2NONY    25
     O                         W2SHCD    38
     O                         W2SNAM    75
     O                         W2SAD1   111
     O                         W2SAD2   147
     O                         W2CITY   173
     O                         W2STAT   177
     O                         W2ZIPC   189
     O                         W2CNTY   195
