     H            Y.
     F** AC#R2E *********************************************
     F*  HONDA LATE EDI ORDER AFTER 10 REPORT               *
     F*  WRITTEN: JW (SRA) 2019.04.08                       *
     F*  -------------------------------------              *
JW1  F*  JW     2021.08.13 ADD AB#EP92                      *
JW2  F*  JW     2022.01.03 ADD QTY DISCREPANCY              *
     F*******************************************************
     FAB#EL91SIF  E           K        DISK
     FAB#PL1L IF  E           K        DISK
     FAB#EL92SIF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1   80AEPLSH
     I                                        1   40XXNOYY
     I                                        5   60XXNOMM
     I                                        7   80XXNODD
      *
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#90S     SETLLAB#EL91S
     C                     DO   *HIVAL
     C                     READ AB#EL91S                 88
     C   88                LEAVE
      * CHECK QTY=0
     C           AEQNTY    IFEQ 0
     C                     EXSR #EP92
     C           A9QNTY    IFEQ 0
     C                     ITER
     C                     ELSE
     C                     Z-ADDA9QNTY    AEQNTY
     C                     Z-ADDA9PLSH    AEPLSH
     C                     ENDIF
     C                     ENDIF
      * CHECK CREATE DATE
     C           AECRDT    IFNE KECRDT
     C                     ITER
     C                     ENDIF
      * CHECK TIME
     C           AECRTM    IFLT KECRTM
     C                     ITER
     C                     ENDIF
      * CHECK SHIP DATE
     C                     EXSR #GETNX
     C           AEPLSH    IFLE TODAY
     C           AEPLSH    ORGT NEXTD
     C                     ITER
     C                     ENDIF
      * CHECK IF EXIST IN PP10
     C                     EXSR #CHK1
     C           WFLG      IFEQ 'OK '
     C                     ENDIF
      *
     C                     EXSR #PRINT
      *
     C                     ENDDO
      *
     C           SEQ#      IFEQ 0
     C                     MOVE *ON       *IN85
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     ENDIF
      * PRINT FOOT
     C                     EXCPT@FOT1
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * CHECK EP92
      *======================================================
     C           #EP92     BEGSR
      *
     C                     MOVELAECONT    K#ODRN
     C                     Z-ADDAECRDT    K#CRDT
     C                     Z-ADDAECRTM    K#CRTM
     C                     MOVELAEEDID    K#EDID
     C                     MOVELAEPLNT    K#PLNT
     C                     MOVELAESHCD    K#SHCD
     C                     MOVELAEMHIN    K#MHIN
     C           K#92S     CHAINAB#EL92S             99
     C           *IN99     IFEQ *ON
     C                     Z-ADD0         A9QNTY
     C                     ENDIF
      *
     C                     ENDSR
      *======================================================
      * GET NEXT SHIP DATE
      *======================================================
     C           #GETNX    BEGSR
      *
     C                     MOVELTODAY     $DT8
     C                     MOVE '+'       $SIGN
     C                     MOVEL'0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN3   1
      *
     C                     MOVEL$TGT8     NEXTD   80
      *
     C                     ENDSR
      *======================================================
      * DETECT IF ORDER IS IN AB#PP10
      *======================================================
     C           #CHK1     BEGSR
      * GET USER PART
     C                     MOVELAEMHIN    @@MHIN 15
     C                     MOVELAEMHIN    $IN
     C                     CALL 'UTLR73'
     C                     PARM           $IN    30
     C                     PARM           $MHIN  20
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $RTN1   1
      * GET NONY
     C                     MOVELAEPLNT    $$PLNT
     C                     MOVELAESHCD    $$SHCD
     C                     CALL 'UTLR74'
     C                     PARM           $$PLNT  3
     C                     PARM           $$SHCD 10
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $RTN2   1
      * SET KEY
     C                     MOVEL$NONY     KANONY
     C                     Z-ADDXXNOYY    KANOYY
     C                     Z-ADDXXNOMM    KANOMM
     C                     Z-ADDXXNODD    KANODD
     C                     MOVEL'00  '    KANUKE
      *
     C           AEEDID    IFEQ '850'
     C                     MOVELAEODRN    KAODRN
     C                     ELSE
     C                     MOVELAECONT    KAODRN
     C                     ENDIF
      *
     C                     MOVEL$MHN1     KAMHN1
     C                     MOVEL$MHN2     KAMHN2
     C                     MOVEL$MHN3     KAMHN3
     C                     MOVEL$MHN4     KAMHN4
      *
     C                     Z-ADD0         WQTY    70
     C                     Z-ADD0         WSYOS   60
      *
     C           K#PL1L    SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#PL1L    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  BASRYO    WQTY
     C                     Z-ADDBASYOS    WSYOS
      *
     C                     ENDDO
      * CHECK FULL QTY?
     C           WSYOS     IFNE 0
     C           AEQNTY    DIV  WSYOS     SHO     70
     C                     MVR            REM     70
     C           REM       IFNE 0
     C                     ADD  1         SHO
     C           SHO       MULT WSYOS     AEQNTY
     C                     ENDIF
     C                     ENDIF
      *
     C           WQTY      IFEQ AEQNTY
     C                     MOVE 'OK '     WFLG    3
     C                     MOVE '   '     WARW    3
     C                     ELSE
     C                     MOVE '***'     WFLG
     C                     MOVE '-->'     WARW
     C                     ADD  1         CHG#
     C                     ENDIF
      *
     C                     ENDSR
      *======================================================
      * PRINT
      *======================================================
     C           #PRINT    BEGSR
      * HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR1
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * BREAK ?
     C           SVCRTM    IFEQ 0
     C                     Z-ADDAECRTM    SVCRTM
     C                     ENDIF
     C           SVCRTM    IFNE AECRTM
     C                     EXCPT@BRK1
     C                     ADD  1         LIN#
     C                     Z-ADDAECRTM    SVCRTM
     C                     ENDIF
      * ADJUST
     C                     MOVELKAODRN    XXODRN 11
JW2  C           AEQNTY    SUB  WQTY      WDIS    70
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#90S     KLIST
     C                     KFLD           KECRDT  80
     C                     KFLD           KECRTM  60
      *
     C           K#92S     KLIST
     C                     KFLD           K#ODRN 20
     C                     KFLD           K#CRDT  80
     C                     KFLD           K#CRTM  60
     C                     KFLD           K#EDID  3
     C                     KFLD           K#PLNT  3
     C                     KFLD           K#SHCD 10
     C                     KFLD           K#MHIN 30
      *
     C           K#PL1L    KLIST
     C                     KFLD           KANONY  40
     C                     KFLD           KANOYY  40
     C                     KFLD           KANOMM  20
     C                     KFLD           KANODD  20
     C                     KFLD           KANUKE  4
     C                     KFLD           KAODRN 10
     C                     KFLD           KAMHN1  5
     C                     KFLD           KAMHN2  5
     C                     KFLD           KAMHN3  5
     C                     KFLD           KAMHN4  5
      *
     C                     MOVE *BLANK    $RTN
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD0         CHG#    40
     C                     Z-ADD0         SVCRTM  60
     C                     TIME           SDATE
      *
     C                     Z-ADDTODAY     KECRDT
     C                     Z-ADD100400    KECRTM
      * PRINT HEADER
     C                     EXCPT@HDR1
     C                     MOVE *OFF      *IN85
     C                     Z-ADD4         LIN#    30
      *
     C                     ENDSR
      *====================================================
     OQPRINT  E   01           @HDR1
     O                                    1 '.'
     O        E   02           @HDR1
     O                         #PGM      10
     O                                   40 '<< HONDA LATE EDI OR'
     O                                   60 'DER AFTER 10 REPORT '
     O                                   64 '>>  '
     O                                  109 'DATE'
     O                         TODAY    112 '    /  /  '
     O                         NOW      122 '  :  :  '
     O                                  126 'P.'
     O                         PAGE  Z  130
     O        E   03           @HDR1
     O                                    5 'SEQ#'
     O                                   15 'RCV DATE'
     O                                   23 'TIME'
     O                                   33 'DELV#'
     O                                   43 'SHIP DATE'
     O                                   52 'ORDER#'
     O                                   67 'USER PART'
     O                                   79 'PLANT'
     O                                   88 'SHIP TO'
     O                                  100 'CURR QTY'
     O                                  116 'NEW QTY'
     O                                  121 'CHG'
JW2  O                                  131 'DISCRE.'
     O        E   04           @HDR1
     O                                    5 '----'
     O                                   15 '--------'
     O                                   23 '----'
     O                                   33 '-----'
     O                                   43 '---------'
     O                                   52 '------'
     O                                   72 '--------------'
     O                                   79 '-----'
     O                                   88 '-------'
     O                                  100 '--------'
     O                                  116 '-------'
     O                                  121 '---'
JW2  O                                  131 '-------'
      *
     O        E 1              @DTL1
     O                         SEQ#  Z +001
     O                         AECRDT  +002 '    /  /  '
     O                         AECRTM  +001 '0 :  :  '
     O                         $NONY   +002
     O                         AEPLSH  +002 '    /  /  '
     O                         XXODRN  +002
     O                         @@MHIN  +001
     O                         AEPLNT  +002
     O                         AESHCD  +003
     O                         WQTY  1 +000
     O                         WARW    +002
     O                         AEQNTY1 +000
     O                         WFLG    +002
JW2  O                         WDIS  O +000
      *
      *
     O        E 1              @FOT1
     O                                    1 '.'
     O        E 1      85      @FOT1
     O                                 +001 '** THERE IS NO ORDE'
     O                                 +000 'R TO REPORT...     '
     O        E 1              @FOT1
     O                                 +001 '** END OF REPORT **'
     O                                 +005 '(CHANGED ORDER:'
     O                         CHG#  1 +001
     O                                 +001 ')'
      *
     O        E 1              @BRK1
     O                                    1 '.'
