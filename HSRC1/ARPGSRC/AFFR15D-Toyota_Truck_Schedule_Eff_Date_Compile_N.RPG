     H            Y.                                    1
      **************************************************************************
      *  PROGRAM    : AFFR15D                                        *
      *  WRITTEN    : 02/06/2023                                     *
      *  WRITTEN BY : LEC       COPIED FROM AFFR10                   *
      *  FUNCTION   : GET EFFECTIVE DATE                             *
      *               AND VERIFY FILE HEADERS                        *         *
      *
     *** CAUTION !!! COMPILE WITH "ALLOW NULL *YES"
      **************************************************************************
     FAFFPW15 CF  E                    WORKSTN
     FAFFWP15 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
      **************************************************************************
     E                    ERR     1   4 70
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
     I            DS
     I                                        1   80W1NYMD
     I                                        1   40W1NOYY
     I                                        5   60W1NOMM
     I                                        7   80W1NODD
     C           *ENTRY    PLIST
     C                     PARM           EFFDAT  80
     C                     PARM           UPFLG   1
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
      *
     C                     MOVEL*BLANK    MSG
      *
     C                     MOVEL'10'      @@ID    2
     C                     MOVE 'N'       UPFLG
     C                     MOVE *OFF      *IN99
      *
     C                     READ AFFWP15                  50
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(SHIP DATE)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     99
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN99
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'N'       UPFLG
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *INKE     IFEQ *ON
     C           *IN99     ANDEQ*OFF
     C                     MOVEL'Y'       UPFLG
     C                     Z-ADDD1NYMD    EFFDAT
     C                     MOVEL'99'      @@ID
     C                     ENDIF
     C           *IN99     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     3199
     C                     TIME           WSDT
      *
     C           D1NYMD    IFEQ *ZERO
     C                     SETON                     3199
     C                     MOVELERR,1     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C                     Z-ADDD1NYMD    W1NYMD
      *
     C           K#AGDA    KLIST
     C                     KFLD           W1NOYY
     C                     KFLD           W1NOMM
     C                     KFLD           W1NODD
      *
     C           K#AGDA    CHAINAGDPL12              98
     C           *IN98     IFEQ *ON
     C                     SETON                     3199
     C                     MOVELERR,1     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C           *IN50     IFEQ *ON
     C                     MOVE *ON       *IN99
     C                     MOVELERR,3     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C           D1NYMD    IFLE WSSDAT
     C                     MOVE *ON       *IN99
     C                     MOVELERR,4     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C           FLD1      IFNE 'SUPPLIER'
     C           FLD3      ORNE 'DATE'
     C           FLD5      ORNE 'START'
     C           FLD6      ORNE 'END'
     C                     MOVE *ON       *IN99
     C                     MOVELERR,2     MSG
     C                     ENDIF
      *
     C           #EF10     ENDSR
      *************************************************************************
** ERR
EFFECTIVE DATE IS INVALID
FILE HEADER IS INVALID
NO DATA FOUND IN CSV FILE
EFFECTIVE DATE MUST BE AFTER TODAY
