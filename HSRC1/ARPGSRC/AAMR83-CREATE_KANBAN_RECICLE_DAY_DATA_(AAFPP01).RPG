     H            Y.
     F** AAMR83 ********************************************
     F*かんばん回転日数データ作成(AAFPP01)               *
     F*   MSK.                            2011.02.15       *
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.11|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F*****************************************************************
     FAAFPP01 IF  E                    DISK
     FAAMWP80 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80A3SKHZ
     I                                        1   40A3SKYY
     I                                        5   60A3SKMM
     I                                        7   80A3SKDD
      *
     I            DS
     I                                        1   80A3UKHZ
     I                                        1   40A3UKYY
     I                                        5   60A3UKMM
     I                                        7   80A3UKDD
     I            DS
     I                                        1   80A3STHZ
     I                                        1   40A3STYY
     I                                        5   60A3STMM
     I                                        7   80A3STDD
      *
     I            DS
     I                                        1   3 A3JBN
     I                                        1   1 A3ATK1
     I                                        2   3 A3ATK2
      *
     I            DS
     I                                        1   3 WKF
     I                                        1   1 WKK1F
     I                                        2   3 WKT1F
      *
     I            DS
     I                                        1   3 WKT
     I                                        1   1 WKK1T
     I                                        2   3 WKT1T
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I            DS
     I                                        1   6 W@TKR
     I                                        1   1 W@TKR1
     I                                        2   3 W@TKR2
     I                                        4   5 W@TKR3
     I                                        6   6 W@TKR4
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
      *-------------------------------------------------------*
      *  かんばん枚数計算用パラメータ                       *
      *-------------------------------------------------------*
     C           ACALL     PLIST
     C                     PARM           ASTLR            SETON LR ﾍｭcﾆg
     C                     PARM           A3KSSU
     C                     PARM           A3SSYS
     C                     PARM           A3KEIS
     C                     PARM           A3READ
     C                     PARM           A3BARA
     C                     PARM           A3CBKO
     C                     PARM           A3LOTO
     C                     PARM           A3MAXH
     C                     PARM           WMAIS
      *１箱メッキ用
     C           ABCR85    PLIST
     C                     PARM           PIKSSU  90
     C                     PARM           PISYSS  50
     C                     PARM           PISKAI  30
     C                     PARM           PILTKE  50
     C                     PARM           PIURLT  40
     C                     PARM           PIBARA  20
     C                     PARM           PIMXHK  30
     C                     PARM           POMAIS  40
      * AMER81
     C           AMER81    PLIST
     C                     PARM           PIHIN1  5
     C                     PARM           PIHIN2  5
     C                     PARM           PIHIN3  2
     C                     PARM           PICTKR  6
     C                     PARM           PIKCD1  1
     C                     PARM           PIKCD2  1
     C                     PARM           PIMBMN  4
     C                     PARM           PIKOTE  3
     C                     PARM           PIMKER  4
     C                     PARM           PIDATE 10
     C                     PARM           POHNTE  1
     C                     PARM           POLINE  2
     C                     PARM           POURLT  4
     C                     PARM           POKTLT  4
     C                     PARM           POHILT  4
     C                     PARM           POTOLT  4
     C                     PARM           POMELT  4
     C                     PARM           POTRLT  4
     C                     PARM           PONYLT  4
     C                     PARM           POINLT  4
     C                     PARM           POSKLT  4
     C                     PARM           POUNLT  4
     C                     PARM           PONKLT  4
     C                     PARM           POSKAI  3
     C                     PARM           POFRLT  4
     C                     PARM           POANLT  4
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKT1T
     C                     ENDIF
      *
     C                     READ AAFPP011                 81
     C           *IN81     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AAFPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           A3ATOB    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
     C           PKOTE     IFNE *BLANK
     C           A3ATOK    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           A3JBN     IFLT WKF
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C           A3JBN     IFGT WKT
     C                     MOVEL'0'       WKOK
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELA3ATOB    W0BMON
     C                     MOVELA31HB5    W0SHN1
     C                     MOVELA32HB5    W0SHN2
     C                     MOVELA33HB2    W0SHN3
     C                     MOVELA3ATOK    W0KOTE
     C                     MOVELA3ATK1    W0TKR1
     C                     MOVELA3ATK2    W0TKR2
     C                     MOVELA3ATK3    W0TKR3
     C                     MOVELA3ATK4    W0TKR4
     C           A3KTSU    MULT 20        W0KTSU
     C           A3KSSU    MULT 20        W0KSSU
     C           A3SSYS    IFNE 0
     C           A3KSSU    DIV  A3SSYS    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDA3SSYS    W0SYUY
     C                     Z-ADD0         W0LOTK
     C                     Z-ADD0         W0KJNK
     C                     Z-ADD0         W0SETO
     C                     Z-ADDA3KMAX    W0KMAX
     C                     MOVELA3KCD1    W0KCD1
     C                     MOVELA3KCD2    W0KCD2
      *
     C                     MOVE *BLANK    W0KSN1
     C                     MOVE *BLANK    W0KSN3
     C                     MOVE *BLANK    W0KSN2
     C                     Z-ADD0         W0HITO
     C                     Z-ADD0         W0TYLT
     C                     Z-ADDA3READ    W0LTIM
     C                     Z-ADDA3KEIS    W0KEIS
     C                     Z-ADDA3MAXH    W0MAXS
     C                     MOVE *BLANK    W0KKEY
     C                     Z-ADD0         W0CYOU
      *
     C           A3SSYS    IFNE 0
     C                     EXSR $SB600
     C                     END
     C*
     C                     MOVE WMAIS     W0SMAX
     C                     MOVE A3LOTO    W0SLOT
     C                     MOVE *BLANK    W0SJNK
     C*
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
     C****************************************************************
     C           $SB600    BEGSR
     C                     MOVELA3UKHZ    WKDTA6  6
     C                     MOVE *ALL'0'   WKDTA8  8
     C                     CALL 'DATR00'
     C                     PARM           WKDTA6
     C                     PARM           WKDTA8
     C                     MOVE WKDTA8    @CHKDT  80
      *
     C                     MOVE '0'       @1MEKI  1
     C**                   EXSR $SB950
     C**         POHNTE    IFEQ '1'
     C**                   MOVE '1'       @1MEKI
     C**                   END
      *
     C           @1MEKI    IFEQ '0'
     C                     MOVE *BLANK    ASTLR   2        SETON LR ﾍｭcﾆg
     C                     Z-ADD0         WMAIS   50
     C                     CALL 'ABCR05'  ACALL
     C                     ELSE
      *
     C                     EXSR $SB999
     C                     Z-ADDA3KSSU    PIKSSU
     C                     Z-ADDA3SSYS    PISYSS
     C                     Z-ADDA3BARA    PIBARA
     C                     Z-ADDA3MAXH    PIMXHK
     C                     Z-ADD0         POMAIS
     C                     CALL 'ABCR85'  ABCR85
     C                     Z-ADDPOMAIS    WMAIS
     C                     END
     CSR         $S600E    ENDSR
      *--------------------------------------------------------------*
      *　　多回集荷対象品の判定　　　　　　　　　　　　　　　　　  *
      *--------------------------------------------------------------*
     CSR         $SB950    BEGSR
     C                     CLEARW@TKR
     C                     MOVE A3ATK1    W@TKR1
     C                     MOVE A3ATK2    W@TKR2
     C                     MOVE A3ATK3    W@TKR3
     C                     MOVE A3ATK4    W@TKR4
      *
     C                     MOVE A31HB5    PIHIN1
     C                     MOVE A32HB5    PIHIN2
     C                     MOVE A33HB2    PIHIN3
     C                     MOVE W@TKR     PICTKR
     C                     MOVE A3KCD1    PIKCD1
     C                     MOVE A3KCD2    PIKCD2
     C                     MOVE A3MAKB    PIMBMN  4
     C                     MOVE A3ATOK    PIKOTE  3
     C                     MOVE A3ATOB    PIMKER  4
      *
     C                     MOVEL@CHKDT    PIDATE 10
     C                     MOVE A3UBIN    PIDATE
     C*                    MOVEL*DATE     PIDATE 10
     C*                    MOVE '01'      PIDATE
     C                     MOVE *BLANK    POHNTE  1
     C                     MOVE *BLANK    POLINE  2
     C                     CALL 'AMER81'  AMER81
     CSR         $S950E    ENDSR
      *--------------------------------------------------------------*
      *　　１箱メッキ用かんばん枚数計算用パラメータセット          *
      *--------------------------------------------------------------*
     CSR         $SB999    BEGSR
      *パラメータ値セット
     C           POHNTE    IFEQ '1'
      *
     C                     Z-ADD0         PILTKE
     C                     Z-ADD0         PIURLT
      *
     C                     MOVE POURLT    AMURLT  40
     C                     MOVE POKTLT    AMKTLT  40
     C                     MOVE POHILT    AMHILT  40
     C                     MOVE POTOLT    AMTOLT  40
     C                     MOVE POMELT    AMMELT  40
     C                     MOVE POTRLT    AMTRLT  40
     C                     MOVE PONYLT    AMNYLT  40
     C                     MOVE POFRLT    AMFRLT  40
     C                     MOVE POANLT    AMANLT  40
     C                     MOVE POSKAI    AMSKAI  30
      *
     C                     Z-ADDAMSKAI    PISKAI
      *
     C                     ADD  AMURLT    PILTKE
     C                     ADD  AMKTLT    PILTKE
     C                     ADD  AMHILT    PILTKE
     C                     ADD  AMTOLT    PILTKE
     C                     ADD  AMMELT    PILTKE
     C                     ADD  AMTRLT    PILTKE
     C                     ADD  AMNYLT    PILTKE
     C                     ADD  AMFRLT    PILTKE
     C                     ADD  AMANLT    PILTKE
      *
     C                     Z-ADDAMURLT    PIURLT
      * 2007.06
     C**                   Z-ADDAMFRKS    PIFRKS
     C**                   Z-ADDAMAZAI    PIAZAI
     C**                   Z-ADDAMTZAI    PITZAI
     C**                   Z-ADDAMFZAI    PIFZAI
      *
     C                     END
      *
     CSR         $S999E    ENDSR
