      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     Z-ADD0         EISKHZ
      *
     C*------------------*
     C*  ..画面－１..  *
     C*------------------*
     C           STP1      TAG
     C                     EXFMTEIAPW011
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*------------------*
     C*  ..更新区分..  *
     C*------------------*
     C                     SETOF                     50
     C                     Z-ADD1         A       10
     C           IKOSN     LOKUPTB1,A                    50
     C           *IN50     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE TB2,A     WKSNM
      *
     C*--------------------*
     C*  ..プログラム..  *
     C*--------------------*
     C           EIPROG    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     SETOF                     51
     C           EIPROG    SETLLEGBPL141
     C                     DO   *HIVAL
     C                     SETOF                     50
     C           EIPROG    READEEGBPL141                 50
     C           *IN50     IFEQ '0'
     C           MPSKJY    IFEQ *BLANK
     C                     SETON                     5051
     C                     END
     C                     END
     C  N50                END
      *
     C           *IN51     IFEQ '0'
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C*----------------------------------------*
     C*  ..システム体系別メニューマスター..  *
     C*----------------------------------------*
     C                     SETOF                     90
     C           EIPROG    CHAINEIAPL011             90
     C           IKOSN     IFEQ '2'
     C           *IN90     IFEQ '0'
     C           EISKJY    IFEQ 'D'
     C           EISKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
      *
     C                     SETON                     010299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           IKOSN     IFEQ '1'
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           EISKJY    IFEQ 'D'
     C           EISKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           IKOSN     IFEQ '0'
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
      *
     C           EISKJY    IFEQ 'D'
     C           EISKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           STP2      TAG
      *
     C           IKOSN     IFEQ '2'
     C                     MOVE *BLANK    EISKJY
     C                     Z-ADD0         EISKHZ
     C                     Z-ADD0         EISTEM
     C                     Z-ADD0         EIOUT1
     C                     Z-ADD0         EIOUT2
     C                     Z-ADD0         EIBSYO
     C                     END
      *
     C*------------------*
     C*  ..画面－２..  *
     C*------------------*
     C           STP3      TAG
     C                     EXFMTEIAPW012
     C                     SETOF                     030405
     C                     SETOF                     0699
      *
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
     C*----------------------*
     C*  ..システム体系..  *
     C*----------------------*
     C           EISTEM    IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,9      MSG
     C                     GOTO STP3
     C                     END
      *
     C           EISTEM    IFGT 14
     C                     SETON                     0399
     C                     MOVE ER,10     MSG
     C                     GOTO STP3
     C                     END
      *
     C*------------------*
     C*  ..出力方法..  *
     C*------------------*
     C           EIOUT1    IFEQ 0
     C                     SETON                     0499
     C                     MOVE ER,11     MSG
     C                     GOTO STP3
     C                     END
      *
     C           EIOUT1    IFGT 07
     C                     SETON                     0499
     C                     MOVE ER,12     MSG
     C                     GOTO STP3
     C                     END
      *
     C           EIOUT2    IFNE 0
     C           EIOUT2    IFGT 3
     C                     SETON                     0599
     C                     MOVE ER,13     MSG
     C                     GOTO STP3
     C                     END
     C                     END
      *
     C*------------------*
     C*  ..主管部署..  *
     C*------------------*
     C           EIBSYO    IFEQ 0
     C                     SETON                     0699
     C                     MOVE ER,14     MSG
     C                     GOTO STP3
     C                     END
      *
     C           EIBSYO    IFGT 20
     C                     SETON                     0699
     C                     MOVE ER,15     MSG
     C                     GOTO STP3
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP3
     C                     END
      *
     C           IKOSN     IFEQ '0'
     C                     MOVE 'D'       EISKJY
     C                     Z-ADD*DATE     EISKHZ
     C                     END
      *
     C                     Z-ADD*DATE     EIKOHZ
     C                     TIME           WTIME
     C                     MOVELPUS       EIKOME
      *
     C           *IN90     IFEQ '0'
     C                     UPDATEIAPL011
     C                     ELSE
     C                     WRITEEIAPL011
     C                     END
      *
     C                     MOVE IKOSN     @KOSN
     C                     MOVE WKSNM     @KSNM
     C                     MOVE EIPROG    @PROG
      *
     C                     EXSR SUBRTN
     C                     GOTO STP1
      *
      *
     C*----------------------------*
     C*  ..サブルーチン..        *
     C*  ..画面－１　クリアー    *
     C*----------------------------*
     C           SUBRTN    BEGSR
      *
     C                     MOVE *BLANK    IKOSN
     C                     MOVE *BLANK    EIPROG
      *
     C                     ENDSR
