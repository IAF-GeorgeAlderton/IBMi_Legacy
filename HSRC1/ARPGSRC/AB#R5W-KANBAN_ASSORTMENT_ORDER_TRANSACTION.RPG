     H            Y.
     F** AB#R5A *********************************
     F* ..KANBAN ASSORTMENT ORDER TRANSACTION.. *
     F*     K.OKACHI               97.11.05     *
     F********************************* AB#R5A **
     FAB#PW5W CF  E                    WORKSTN
     E                    ER      1   1 78
      *------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@END   1
     C                     MOVE *BLANK    P@END
     C           P#5Y      PLIST
     C                     PARM           D@NONY
     C                     PARM           D@DOCK
     C                     PARM           D@ORNO
     C                     PARM           D@DAT1
     C                     PARM           D@BIN
     C                     PARM           D@DAT2
     C                     PARM           P@ID    1
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *OFF      *IN99
     C           D@NONY    IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
     C           D@DOCK    IFEQ *BLANK
     C                     SETON                     6299
     C                     ENDIF
     C           D@DAT1    IFEQ *ZERO
     C                     SETON                     6399
     C                     ENDIF
     C           D@ORNO    IFEQ *BLANK
     C                     SETON                     6499
     C                     ENDIF
     C           D@BIN     IFEQ *ZERO
     C                     SETON                     6699
     C                     ENDIF
     C           D@DAT2    IFEQ *ZERO
     C                     SETON                     6599
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDAT
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     MOVE *BLANK    P@ID
     C                     CALL 'AB#R5Y'  P#5Y
     C           P@ID      IFEQ *BLANK
     C                     MOVE ER,1      D@MSG
     C                     ELSE
     C                     MOVE *BLANK    D@ORNO
     C                     Z-ADD*ZERO     D@DAT1
     C                     Z-ADD*ZERO     D@BIN
     C                     Z-ADD*ZERO     D@DAT2
     C                     MOVE '1'       P@END
     C                     ENDIF
      *
     C                     ENDSR
** ER
     NO DATA
