     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C           @STP0     TAG
     C                     MOVEL*BLANK    @ODER
     C                     MOVEL*BLANK    @ITEM
TCHK1C*                    MOVEL'0002'    @SIRE
TCHK1C                     MOVEL'8990'    @SIRE
     C                     MOVEL'0111'    @UKEI   4
     C                     MOVE *BLANK    @ERR
     C                     Z-ADD0         KSIRE   40
     C                     MOVE @UKEI     KUKEI   40
     C                     Z-ADD0         KODE1   20
     C                     Z-ADD0         KODE2   20
     C                     Z-ADD0         KODE3   20
     C                     Z-ADD0         KITEM   50
     C                     Z-ADD0         LSIRE
     C                     Z-ADD0         LUKEI
