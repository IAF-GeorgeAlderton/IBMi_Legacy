      *--------*
      *画面１*
      *--------*
     C           @STP1     TAG
     C                     EXFMTGDLPW251
     C                     SETOF                     111213
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *--------------*
      *  ERR CHECK   *
      *--------------*
      * CHAR CHECK
     C           @ODER     IFNE *BLANK
     C                     MOVEL@ODER     PIN    99
     C                     Z-ADD6         PKT     20
     C                     EXSR #CHECK
     C           WFLG      IFEQ '*'
     C                     MOVELER,1      @ERR
     C                     SETON                     1199
     C                     GOTO @STP1
     C                     END
      *
     C           @ORD2     IFGE '01'
     C           @ORD2     ANDLE'12'
     C                     ELSE
     C                     MOVELER,12     @ERR
     C                     SETON                     1199
     C                     GOTO @STP1
     C                     END
      *
     C           @ORD3     IFEQ '00'
     C                     MOVELER,12     @ERR
     C                     SETON                     1199
     C                     GOTO @STP1
     C                     END
      *
     C                     END
      *
     C           @ITEM     IFNE *BLANK
     C           @ODER     IFEQ *BLANK
     C                     MOVELER,2      @ERR
     C                     SETON                     1199
     C                     GOTO @STP1
     C                     END
      *
     C                     MOVEL@ITEM     PIN    99
     C                     Z-ADD5         PKT     20
     C                     EXSR #CHECK
     C           WFLG      IFEQ '*'
     C                     MOVELER,3      @ERR
     C                     SETON                     1299
     C                     GOTO @STP1
     C                     END
     C                     END
      *
     C           @SIRE     IFEQ *BLANK
     C                     MOVELER,4      @ERR
     C                     SETON                     1399
     C                     GOTO @STP1
     C                     END
      *
     C                     MOVE @SIRE     KSIRE
     C                     SETOF                     90
     C           KSIRE     CHAINFGBPL011             90
     C           *IN90     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     END
     C           *IN90     IFEQ '1'
     C                     SETON                     0399
     C                     MOVELER,5      @ERR
     C                     GOTO @STP1
     C                     END
     C                     MOVELB2SMEI    @SINM
      *
     C                     SETOF                     90
     C           KUKEI     CHAINFGBPL011             90
     C           *IN90     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELB2SMEI    @UKNM
     C                     END
      *HAIRETU SET
     C                     EXSR #KEY
     C                     EXSR #SET
      *--------*
      *画面２*
      *--------*
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'00'      *IN,19
     C                     SETOF                     2199
     C           @STP2     TAG
     C                     EXFMTGDLPW252
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'00'      *IN,19
     C                     SETOF                     2199
     C                     MOVEL*BLANK    WKOSN   1
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO @STP0
     C                     END
      *
     C           *IN94     IFEQ '1'
     C                     EXSR #ROLUP
     C           Z         IFEQ 0
     C                     MOVELER,7      @ERR
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
     C           *IN95     IFEQ '1'
     C                     EXSR #ROLDW
     C           Z         IFEQ 11
     C                     MOVELER,8      @ERR
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C           Z         IFNE 1
     C                     EXSR #SET
     C                     GOTO @STP2
     C                     END
     C                     END
      *
     C           PNO       IFNE *BLANK
     C                     Z-ADD0         KK      20
     C                     Z-ADD10        LL      20
     C           1         DO   10
     C                     ADD  1         KK
     C                     ADD  1         LL
     C           #NO,KK    IFEQ *BLANK
     C           #NO,KK    OREQ '0'
     C           #NO,KK    OREQ '1'
     C           #NO,KK    IFEQ '0'
     C           #NO,KK    OREQ '1'
     C           #OD,KK    IFEQ *BLANK
     C                     MOVELER,9      @ERR
     C                     MOVEA'1'       *IN,LL
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
     C                     ELSE
     C                     MOVELER,10     @ERR
     C                     MOVEA'1'       *IN,LL
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     ENDDO
      *
     C                     Z-ADD0         KK      20
     C           1         DO   10
     C                     ADD  1         KK
     C           #NO,KK    IFNE *BLANK
     C           #NO,KK    IFEQ '0'
     C                     MOVEL'0'       WKOSN
     C                     END
     C           #NO,KK    IFEQ '1'
     C                     MOVEL'1'       WKOSN
     C                     END
     C                     MOVE #OD,KK    KODER
     C                     MOVE #IT,KK    KITEM
     C                     MOVE #OD,KK    WODER
     C                     MOVE #IT,KK    WITEM
     C                     MOVEL#TY,KK    WTYPE
     C                     MOVEL#WI,KK    WZAIS
     C                     MOVE #DI,KK    WZAIK
     C                     Z-ADD#KA,KK    WMAIS
      *
     C                     SETOF                     90
TCHK2C           KSIRE     IFEQ 4511
JW1  C           KSIRE     OREQ 4530
JW2  C           KSIRE     OREQ 4540
JW3  C           KSIRE     OREQ 4550
JW3  C           KSIRE     OREQ 4560
TCHK2C           KEY01     SETLLGDLPL131
TCHK2C                     DO   *HIVAL
TCHK2C           KEY01     READEGDLPL131                 90
TCHK2C   90                LEAVE
TCHK2C           LBSKJY    IFEQ 'D'
TCHK2C           LBSKHZ    ANDLE*DATE
TCHK2C                     ITER
TCHK2C                     END
TCHK2C           LBZAIS    IFEQ WZAIS
TCHK2C           LBZAIK    ANDEQWZAIK
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     ENDDO
TCHK2C                     ELSE
      *
     C           KEY01     CHAINGDLPL131             90
     C           *IN90     IFEQ '0'
     C           LBSKJY    IFEQ 'D'
     C           LBSKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     END
     C                     END
TCHK2C                     END
      *
     C           *IN90     IFEQ '1'
     C                     EXSR #SET
     C                     SETON                     99
     C                     MOVELER,6      @ERR
     C                     GOTO @STP2
     C                     END
      *
     C                     Z-ADDLBODHZ    WODHZ
     C                     Z-ADDLBSPHZ    WSHHZ
     C                     Z-ADDLBREHZ    WREHZ
     C                     Z-ADDLBMAIS    WODKA
     C                     Z-ADDLBREMA    WREKA
     C                     Z-ADD0         WSHKA
      *
     C           KEY05     KLIST
     C                     KFLD           KODE1
     C                     KFLD           KODE2
     C                     KFLD           KODE3
     C                     KFLD           KITEM
      *
     C                     SETOF                     90
     C           KEY05     SETLLGDLPL311
     C                     DO   *HIVAL
     C           KEY05     READEGDLPL311                 90
     C           *IN90     IFEQ '0'
     C                     ADD  1         WSHKA
     C                     END
     C  N90                ENDDO
      *
     C                     GOTO @JUMP
     C                     END
     C                     ENDDO
      *
     C                     END
      *
     C           WIADD     IFEQ *BLANK
     C                     GOTO @STP2
     C                     END
      *ADDING
     C                     MOVEL'2'       WKOSN
      *
     C           WIADD     IFNE '2'
     C                     MOVELER,11     @ERR
     C                     SETON                     2199
     C                     END
      *---------------*
      * GET ORDER NO. *
      *---------------*
     C                     MOVE *BLANK    WODER
     C                     SETOF                     90
     C           'ORDER2'  CHAINGDLNP101             90
     C           *IN90     IFEQ '0'
     C           LNSKJY    IFEQ 'D'
     C           LNSKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     END
     C                     END
     C           *IN90     IFEQ '0'
     C           LNYEAR    IFEQ *YEAR
     C           LNMOTH    ANDEQUMONTH
     C                     MOVE LNYEAR    WORD1
     C                     MOVE LNMOTH    WORD2
     C                     MOVE LNIDNO    WORD3
     C                     ELSE
     C                     MOVE UYEAR     WORD1
     C                     MOVE UMONTH    WORD2
     C                     MOVE '50'      WORD3
     C                     END
     C                     END
      *
     C           *IN90     IFEQ '1'
     C                     MOVE UYEAR     WORD1
     C                     MOVE UMONTH    WORD2
     C                     MOVE '50'      WORD3
     C                     END
      *--------------*
      * GET ITEM NO. *
      *--------------*
     C                     MOVE *BLANK    WITEM
     C                     MOVE *BLANK    @KOSN   1
     C                     SETOF                     90
     C           'ITEM2 '  CHAINGDLNP101             90
     C           *IN90     IFEQ '0'
     C                     MOVEL'*'       @KOSN
     C           LNSKJY    IFEQ 'D'
     C           LNSKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     END
     C                     END
     C           *IN90     IFEQ '0'
     C           LNYEAR    IFEQ *YEAR
     C                     ADD  1         LNIDNO
     C                     MOVE LNIDNO    WITEM
     C                     ELSE
     C                     Z-ADD90000     LNIDNO
     C                     ADD  1         LNIDNO
     C                     MOVE LNIDNO    WITEM
     C                     END
     C                     END
      *
     C           *IN90     IFEQ '1'
     C                     Z-ADD90000     LNIDNO
     C                     ADD  1         LNIDNO
     C                     MOVE LNIDNO    WITEM
     C                     END
      *
     C                     MOVEL*BLANK    WTYPE
     C                     MOVEL*BLANK    WZAIS
     C                     Z-ADD0         WZAIK
     C                     Z-ADD0         WMAIS
     C           @JUMP     TAG
      *--------*
      *画面３*
      *--------*
     C                     SETOF                     505152
     C                     SETOF                     98
     C           WKOSN     IFEQ '0'
