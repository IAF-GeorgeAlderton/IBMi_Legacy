      *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
     C                     KFLD           K@KWD2  8
     C           *ENTRY    PLIST
     C                     PARM           P@CUST  5
     C                     PARM           P@YMD   80
TCHK3C                     PARM           P@TIM   60
     C                     PARM           P@SLCT  1
      *
     C           K#KEY     KLIST
     C                     KFLD           K@CUST  5
     C                     KFLD           K@DATE  80
     C***                  KFLD           K@MM
      *
     C***                  Z-ADDP@YYMM    K@YYMM
     C*          P@YYMM    MULT 100       K@DATE
     C*          K@DATE    ADD  99        W@END   80
     C                     Z-ADDP@YMD     K@DATE
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVEA'00'      *IN,97
     C                     MOVE *BLANK    @@MANI 16
     C                     Z-ADD*ZERO     @@TOT
     C           K#KEY     SETLLAB#PL6A
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAB#PL6A                  90
     C           *IN90     IFEQ *OFF
     C*          APPRDT    IFGT W@END
     C*                    LEAVE
     C*                    ENDIF
      *
TCHK3C           APPRTM    IFNE P@TIM
TCHK3C                     ITER
TCHK3C                     END
TCHK3C*
     C           *IN98     IFEQ *OFF
     C           *IN88     ANDEQ*OFF
     C                     MOVE *ON       *IN98
     C                     CLEARAB#PP6B1
      *
TCHK3C                     MOVELP@CUST    A6CNAM    P
      *
TCHK3C*                    MOVELAPCNAM    K@KWD2    P
TCHK3C                     MOVELP@CUST    K@KWD2    P
     C                     MOVEL'AB#PP6B' K@KWD1    P
     C           APRCYY    MULT 100       YM      60
     C                     ADD  APRCMM    YM
     C           K#PCT     CHAINAB#PPCT              91
     C           *IN91     IFEQ *ON
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     Z-ADDYM        CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     WRITEAB#PPCT1
     C                     ELSE
     C           CTNBR1    IFEQ YM
     C                     ADD  1         CTNBR2
     C                     ELSE
     C                     Z-ADDYM        CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     ENDIF
     C                     MOVE CTNBR2    W@1     1
      *
     C                     MOVE APRCYY    YY      2
     C                     MOVE APRCMM    MM      2
     C           YY        CAT  MM        YYMM    4
TCHK3C*          APCNAM    LOKUPTAB1      TAB2           10
TCHK3C           P@CUST    LOKUPTAB1      TAB2           10
     C           TAB2      CAT  YYMM:0    CHK9    9 P
     C           CHK9      CAT  W@1:0     A6CHEK    P
      *
     C                     Z-ADDAPMAMT    A6TOTL
     C                     WRITEAB#PP6B1
     C                     ENDIF
      *
     C*          *IN97     IFEQ *ON
     C*          APMANI    ANDNE@@MANI
     C*                    EXSR #MANI
     C*                    ENDIF
      *
TCHK3C                     MOVELK@CUST    A6CNAM    P
     C                     MOVELAPMANI    A6MANI
     C                     MOVELAPCARD    A6CARD
     C                     MOVELAPPAR1    A6PRT1
     C                     MOVELAPPAR2    A6PRT2
     C                     MOVELAPCLRC    A6COLR
     C                     Z-ADDAPIQTY    A6QTY
     C                     Z-ADDAPUNIT    A6UPRC
     C                     MOVELAPDOCK    A6DOCK
     C                     Z-ADDAPRCDT    A6RCDT
      *
     C                     MOVE APMANI    @@MANI
     C  N97                MOVE *ON       *IN97
B01   *
     C           APUNIT    IFNE *ZERO
     C           APIQTY    MULT APUNIT    APTAMT
     C                     ENDIF
     C                     ADD  APTAMT    @@TOT  112
     C                     Z-ADDAPTAMT    A6MAMT
      *
     C                     WRITEAB#PP6C1
      *
     C                     ENDIF
     C                     ENDDO
      *
     C*          *IN97     IFEQ *ON
     C*                    EXSR #MANI
     C*                    ENDIF
      *
