     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     Z-ADDYM        CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     WRITEAB#PPCT1
