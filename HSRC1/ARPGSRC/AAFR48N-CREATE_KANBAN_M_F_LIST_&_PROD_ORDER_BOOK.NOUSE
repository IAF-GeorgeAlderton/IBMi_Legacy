     C           *ENTRY    PLIST
     C                     PARM           US     10
     C                     PARM           KOSN    1
     C                     PARM           PNO     1
     C  N01                GOTO END
     C   08                GOTO BTP1
     C                     SETON                     08
      *
     C           US        CHAINRGAPL111             09
     C   09                GOTO BTP1
     C           J8SKJY    IFNE 'D'
     C                     MOVELJ8NAME    JNAME  15
     C                     END
      *
     C           BTP1      TAG
     C                     EXSR #LIST
     C           END       TAG
     CLR         PNO       IFEQ '1'
     CLR         *IN99     IFEQ '1'
     CLR                   CLOSEQPRINT
     CLR                   END
     CLR                   END
     CLR         PNO       IFEQ '2'
     CLR         *IN99     IFEQ '1'
     CLR                   CLOSEQPRINTS
     CLR                   END
     CLR                   END
     C**         PNO       IFEQ '9'
JW   CLR         PNO       IFEQ '3'
     CLR         *IN99     IFEQ '1'
     CLR                   CLOSEQPRINT
     CLR                   CLOSEQPRINTS
     CLR                   END
     CLR                   END
      *
      *--------------------------------------------------------------*
      * f]ﾌﾞ] uﾇj- ﾒﾇn ﾅhﾈb                                          *
      *--------------------------------------------------------------*
     C           #LIST     BEGSR
     C                     MOVEA'00000000'*IN,61
     C                     MOVEA'00000000'*IN,69
     C                     MOVEA'00000000'*IN,77
     C                     MOVEA'00000000'*IN,85
     C                     MOVEA'00'      *IN,93
      *
      *--------------------------------------------------------------*
      * ﾍ]ﾌﾞ] ﾆﾞﾑctc & ﾃcmb ﾆﾞﾑctc                                   *
      *--------------------------------------------------------------*
     C                     SETOF                     020304
     C                     SETOF                     0523
      *
     C           INHIN3    IFNE *BLANK
     C                     SETON                     61
     C                     END
      *
     C           HINKEY    KLIST
     C                     KFLD           INHIN1
     C                     KFLD           INHIN2
     C                     KFLD           INHIN3
     C           HINKEY    CHAINFCEPL011             11    ﾎﾞﾍ] ﾆﾞﾑctc
     C  N11      A2GSKD    IFEQ 'D'                        ﾅhﾆﾞﾑ u-h
     C                     SETON                     11
     C                     END
      *
     C                     SETOF                     16
     C                     Z-ADD0         WOGEK   90
     C                     Z-ADD0         WKOSN   10
     C           HINKEY    CHAINAAUPL011             16
     C           *IN16     IFEQ '0'
     C           J1SKJY    ANDEQ'D'
     C           J1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDJ1OGEK    WOGEK
     C                     Z-ADDJ1KOSN    WKOSN
     C                     END
      *
     C           *IN99     IFEQ '0'
     C           PNO       IFEQ '1'
     C                     OPEN QPRINT
     C                     EXCPTMCHK1
     C                     ELSE
     C           PNO       IFEQ '2'
     C                     OPEN QPRINTS
     C                     EXCPTMCHK2
     C                     ELSE
     C                     OPEN QPRINT
     C                     OPEN QPRINTS
     C                     EXCPTMCHK1
     C                     EXCPTMCHK2
     C                     END
     C                     END
     C                     SETON                     99
     C                     END
      *
     C                     MOVE *BLANK    WHI
     C                     MOVE *BLANK    WKT
     C                     Z-ADD0         WBM
     C                     MOVE *BLANK    WTR
     C                     MOVE *BLANK    WMN
     C                     Z-ADD0         BIN
     C                     MOVE *BLANK    KTI
     C                     MOVE *BLANK    WKJ
     C                     MOVE *BLANK    WKI
     C                     MOVE *BLANK    WKB
     C                     MOVE *BLANK    WBA
      *
     C           HINKEY    CHAINAAMPL111             10
     C           *IN10     IFEQ '0'
     C                     Z-ADD0         A       20
     C                     Z-ADD1         I
     C           1         DO   15        I
     C           CKT,I     IFNE *BLANK
