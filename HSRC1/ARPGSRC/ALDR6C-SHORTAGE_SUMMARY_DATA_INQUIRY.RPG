     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@DATE  80
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            еИЭжЬЯеЗ¶зРЖ
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * еИЭжЬЯпЊИпљЃmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
     C                     Z-ADDP@DATE    D1ODAT
      *
     C           KEY01     KLIST
     C                     KFLD           AFLPR1           IAF PART#1
     C                     KFLD           AFLPR2           PART#2
     C                     KFLD           AFLPR3           PART#3
     C                     KFLD           AFLOC1           LOC1
     C                     KFLD           AFLOC2           LOC2
     C                     KFLD           AFLOC3           LOC3
     C                     KFLD           AFLOC4           LOC4
      *
      * .. SHIPPING SHORTAGE FILE                         *
     C           P@DATE    SETLLALDPL66
      **----------------------------------
     C                     DO   *HIVAL
     C           P@DATE    READEALDPL66                  90
     C   90                LEAVE
     C           AFSKJC    IFEQ 'D'
     C           AFDATE    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD0         M$BOX1  60       :TOYOTA
     C                     Z-ADD0         M$BOX2  60       :HONDA
     C                     Z-ADD0         M$BOX3  60       :FORD
     C                     Z-ADD0         M$BOX4  60       :TIER1
     C                     EXSR ##NONY
      *
     C           KEY01     CHAINALDWP6C              91
     C           *IN91     IFEQ *ON
     C                     MOVELAFLPR1    W$LPR1           IAF PART#1
     C                     MOVELAFLPR2    W$LPR2           PART#2
     C                     MOVELAFLPR3    W$LPR3           PART#3
     C                     MOVELAFLOC1    W$LOC1           LOC1
     C                     MOVELAFLOC2    W$LOC2           LOC2
     C                     MOVELAFLOC3    W$LOC3           LOC3
     C                     MOVELAFLOC4    W$LOC4           LOC4
     C                     Z-ADD1         W$BOXS
     C                     Z-ADDM$BOX1    W$BOX1
     C                     Z-ADDM$BOX2    W$BOX2
     C                     Z-ADDM$BOX3    W$BOX3
     C                     Z-ADDM$BOX4    W$BOX4
     C                     WRITEALDWP6C1
     C                     ELSE
     C                     ADD  1         W$BOXS
     C                     ADD  M$BOX1    W$BOX1
     C                     ADD  M$BOX2    W$BOX2
     C                     ADD  M$BOX3    W$BOX3
     C                     ADD  M$BOX4    W$BOX4
     C                     UPDATALDWP6C1
     C                     ENDIF
     C                     ENDDO
      **----------------------------------
      *
     C*
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL1
     C                     SETOF                     73
     C*
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C*
     C*
      **----------------------------------
     C                     DO   *HIVAL
