     C                     PARM           W$LOC2  2
     C                     PARM           W$LOC3  2
     C                     PARM           W$LOC4  1
     C                     PARM           S1LOC   9
     C                     Z-ADDW$BOXS    S1BOXS
     C                     Z-ADDW$BOX1    S1BOX1
     C                     Z-ADDW$BOX2    S1BOX2
     C                     Z-ADDW$BOX3    S1BOX3
     C                     Z-ADDW$BOX4    S1BOX4
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C                     ENDDO
