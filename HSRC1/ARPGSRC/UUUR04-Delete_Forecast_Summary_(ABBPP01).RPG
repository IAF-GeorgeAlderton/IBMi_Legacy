     H            Y.
     F** UUUR04 *********************************************
     F*  DELETE FORECAST SUMMARY (ABBPP01)                  *
     F*  J.WATANABE  2021.05.06                             *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UUUR04'
     F*                    PARM           $TOKU   4
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $MHN1   5
     F*                    PARM           $MHN2   5
     F*                    PARM           $MHN3   5
     F*                    PARM           $MHN4   5
     F*                    PARM           $SBAN   4
     F*                    PARM           $RTN    1
     F*  IN  $TOKU :  4A CUST#
     F*      $NONY :  4A DELIVERY#
     F*      $NKOJ :  1A FACTORY
     F*      $NUKE :  4A DOCK
     F*      $MHN1 :  5S USER PART1
     F*      $MHN2 :  5A USER PART2
     F*      $MHN3 :  5S USER PART3
     F*      $MHN4 :  5A USER PART4
     F*      $SBAN :  4A KANBAN#
     F*  OUT $RTN  :  1A RETURN (BLNAK=NO ERROR)
     F*                  1= RECORD NOT FOUND
     F*                  2= IT IS NOT ZERO BALANCE
     F******************************************************
     FABBPL01 UF  E           K        DISK
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#KEY     CHAINABBPL01              99
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '1'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C           Q5NNNM    IFNE 0
     C           Q51NNM    ORNE 0
     C           Q52NNM    ORNE 0
     C                     MOVE '2'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     DELETABBPL011
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $SBAN   4
     C                     PARM           $RTN    1
      *
     C           K#KEY     KLIST
     C                     KFLD           K5TOKU  40
     C                     KFLD           K5NONY  40
     C                     KFLD           K5GKOJ  1
     C                     KFLD           K5GUKE  4
     C                     KFLD           K5SEBN  4
     C                     KFLD           K5MHN1  5
     C                     KFLD           K5MHN2  5
     C                     KFLD           K5MHN3  5
     C                     KFLD           K5MHN4  5
      *
     C                     MOVE ' '       $RTN
     C                     MOVEL$TOKU     K5TOKU
     C                     MOVEL$NONY     K5NONY
     C                     MOVEL$NKOJ     K5GKOJ
     C                     MOVEL$NUKE     K5GUKE
     C                     MOVEL$SBAN     K5SEBN
     C                     MOVEL$MHN1     K5MHN1
     C                     MOVEL$MHN2     K5MHN2
     C                     MOVEL$MHN3     K5MHN3
     C                     MOVEL$MHN4     K5MHN4
      *
     C                     ENDSR
