     C                     Z-ADD*ZERO     Y
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         Y
     C           Y         IFEQ 2
     C                     Z-ADDF8YMD     AAASHT
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     WRITEAB#PP4A1
      *
     C                     ELSE
TCHK1 *
TCHK1C                     Z-ADDAADLDT    K@YMD
TCHK1C           K#AGD     SETLLAGDPL12
TCHK1C                     READ AGDPL12                  90
TCHK1C  N90                READ AGDPL12                  90
TCHK1C  N90                READ AGDPL12                  90
TCHK1C  N90                READ AGDPL12                  90
TCHK1C  N90                READ AGDPL12                  90
TCHK1C  N90                READ AGDPL12                  90
TCHK1C  N90                READ AGDPL12                  90
TCHK1C                     Z-ADDF8YMD     AAENDT
TCHK1C                     Z-ADDAADLDT    AASTRT
TCHK1 *
     C                     WRITEAB#WDNS1
      *
     C                     ENDIF
      *
     C                     MOVE '1'       P@END
      *
     C           @END      TAG
      *---------------------------------------------------
     C           #DATE     BEGSR
      *
     C                     MOVE *BLANK    A4
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD1         P       20
     C                     Z-ADD*ZERO     W@YMD
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AR,X      IFEQ ','
     C                     SELEC
     C           Y         WHEQ 0
     C                     MOVE *ALL'0'   A4
     C           Y         WHEQ 1
     C                     MOVE A4,1      A4,4
     C                     MOVEA'200'     A4,1
     C           Y         WHEQ 2
     C                     MOVE A4,1      A4,3
     C                     MOVE A4,2      A4,4
     C                     MOVEA'20'      A4,1
     C           Y         WHEQ 3
     C                     MOVE A4,3      A4,4
     C                     MOVE A4,2      A4,3
     C                     MOVE A4,1      A4,2
     C                     MOVEA'2'       A4,1
     C                     ENDSL
     C                     MOVEAA4        @4
     C                     MOVE @4        W@YY
     C                     LEAVE
     C                     ENDIF
      *
     C           AR,X      IFEQ '/'
     C           Y         IFEQ 1
     C                     MOVE A4,1      A4,2
     C                     MOVE '0'       A4,1
     C                     ENDIF
      *
     C                     MOVEAA4        @4      4
     C           P         IFEQ 1
     C                     MOVEL@4        W@MM
     C                     ELSE
     C                     MOVEL@4        W@DD
     C                     ENDIF
     C                     Z-ADD*ZERO     Y
     C                     MOVE *BLANK    A4
     C                     ADD  1         P
     C                     ITER
     C                     ENDIF
      *
     C           AR,X      IFGE '0'
     C           AR,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVE AR,X      A4,Y
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVE X'0A'     W@HEX   1
     C                     MOVE X'25'     W@HEX2  1
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4
     C                     PARM           P@END   1
      *
     C           K#KEY     KLIST
     C                     KFLD           K@ID    1
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     MOVE *BLANK    K@ID
     C                     MOVE P@NONY    K@TOKU
     C                     MOVE P@NONY    K@NONY
     C           K#KEY     SETLLAB#PP4A
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAB#PP4A                  90
     C           *IN90     IFEQ *OFF
     C                     MOVE 'D'       AAFLAG
     C                     UPDATAB#PP4A1
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
