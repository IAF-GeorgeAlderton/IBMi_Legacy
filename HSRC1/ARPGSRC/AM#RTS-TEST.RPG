     H            Y.
     F** AM#R05 *********************************************
     F* DOCK LABEL                                          *
     F*    ITS.             2015.06.01                      *
     F*******************************************************
     FAM#PWTS CF  E                    WORKSTN
     F                                              KNUM        1
     F                                              KINFDS FEEDBK
     FAM#PP11 O   E                    DISK                      A
     E                    ER      1  11 65
      *
     IB2D         DS
     I                                        1  25 BAR01
     I                                       26  50 BAR02
     I                                       51  72 BAR03
     I*****                                  76 100 BAR04
     I*****                                 101 125 BAR05
     I*****                                 126 150 BAR06
     I*****                                 151 175 BAR07
     I*****                                 176 200 BAR08
     I*****                                 201 225 BAR09
     I*****                                 226 250 BAR10
      *
     ID2R         DS
     I                                        1  25 D2R01
     I                                       26  50 D2R02
     I                                       51  75 D2R03
     I                                       76 100 D2R04
     I                                      101 125 D2R05
     I                                      126 150 D2R06
     I                                      151 175 D2R07
     I                                      176 200 D2R08
     I                                      201 225 D2R09
     I                                      226 250 D2R10
      *
     I            DS
     I                                        1  72 TICKET
     I                                        1   9 TISURT
     I                                       10  17 TISHID
     I                                       18  23 TISHIT
     I                                       24  38 TISMEI
     I                                       39  40 TIDOCK
     I                                       41  52 TIORD#
     I                                       53  54 TIPALT
     I                                       55  58 TINONY
     I                                       59  59 TINKOJ
     I                                       60  63 TINUKE
     I                                       64  66 TIIAFB
     I                                       67  69 TIIAFP
     I                                       70  70 TIPPUL
     I                                       71  71 TIEXT
     I                                       72  72 TISAT
      * DOCK LABEL
     I            DS
     I                                        1  40 DOCKLB
     I                                        1   5 DONAMC
     I                                        6  10 DOSUPC
     I                                       11  12 DODOCK
     I                                       13  24 DOORD#
     I                                       25  36 DOMART
     I                                       37  38 DOPALT
     I                                       39  40 DOMROS
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
     IFEEDBK      DS
     I                                     *STATUS  @STTS
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    PCMD    2
     C                     MOVELWORKER    USRCD   6
     C                     CLEARB2D
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *パレットチケット                                  *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      PCMD    2
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           B2D       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     CLEARB2D
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVELB2D       TICKET
      *
     C                     EXSR #SB920
     C                     MOVE 'BIN'     D1BIN
     C                     MOVELTIIAFB    D1IAFB
     C                     MOVEL'PALLET#' D1PLT#
     C                     MOVELTIIAFP    D1IAFP
     C                     MOVELTISURT    D1SURT
     C                     MOVELTIORD#    D1ORD#
     C                     MOVELTISMEI    D1SMEI
     C                     MOVELTIDOCK    D1DOCK
     C                     MOVELTIPALT    D1PALT
     C           P2TOTL    IFEQ 0
     C                     SETON                     3199
     C                     MOVELER,4      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARB2D
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVELTIIAFB    D2IAFB
     C                     MOVELTIIAFP    D2IAFP
     C                     MOVELTISURT    D2SURT
     C                     MOVELTIORD#    D2ORD#
     C                     MOVELTISMEI    D2SMEI
     C                     MOVELTIDOCK    D2DOCK
     C                     MOVELTIPALT    D2PALT
     C                     MOVEL'02'      DSPSW   2
     C                     CLEARD2R
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *ＤＯＣＫ　ＬＡＢＥＬ                              *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTDSP02
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     CLEARB2D
     C                     MOVEL'01'      DSPSW   2
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D2R       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     EXSR #SB999
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKHNTE  2
     C                     MOVELD2R       DOCKLB
     C                     EXSR #SB710
     C                     EXSR #SB500
     C           *IN99     IFEQ '1'
     C                     Z-ADD3         P1PGM
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     ELSE
      * OK
     C                     WRITEDSP03
     C                     READ AM#PWTS                3737
     C                     ENDIF
      *
     C                     CLEARB2D
     C                     MOVEL'01'      DSPSW   2
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * AM#PP11                                            *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     TIME           WTIME
     C                     CLEARAM#PP111
     C                     Z-ADDSDATE     R0KOHZ
     C                     Z-ADDSTIME     R0KOTI
     C                     MOVELWORKER    R0KOME
     C                     Z-ADDSDATE     R0SSHZ
     C                     Z-ADDSTIME     R0SSTI
     C                     MOVELWORKER    R0USCD
     C                     MOVEL*BLANK    R0USNM
     C                     MOVELWKHNTE    R0HNTE
     C                     MOVELTICKET    R0TICK
     C                     MOVELTISURT    R0SURT
     C                     MOVELTISHID    R0SHID
     C                     MOVELTISHIT    R0SHIT
     C                     MOVELTISMEI    R0SMEI
     C                     MOVELTIDOCK    R0DOCK
     C                     MOVELTIORD#    R0ORD#
     C                     MOVELTIPALT    R0PALT
     C                     MOVELTINONY    R0NONY
     C                     MOVELTINKOJ    R0NKOJ
     C                     MOVELTINUKE    R0NUKE
     C                     MOVELTIIAFB    R0IAFB
     C                     MOVELTIIAFP    R0IAFP
     C                     MOVELTIPPUL    R0PPUL
     C                     MOVELTIEXT     R0EXT
     C                     MOVELTISAT     R0SAT
     C                     MOVELDOCKLB    R0DLBL
     C                     MOVELDONAMC    R0NAMC
     C                     MOVELDOSUPC    R0SUPC
     C                     MOVELDODOCK    R0DDCK
     C                     MOVELDOORD#    R0DRD#
     C                     MOVELDOMART    R0MART
     C                     MOVELDOPALT    R0DALT
     C                     MOVELDOMROS    R0MROS
     C                     WRITEAM#PP111
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB710    BEGSR
      *
     C           TIDOCK    IFEQ DODOCK
     C           TIORD#    ANDEQDOORD#
     C           TIPALT    ANDEQDOPALT
     C                     MOVEL'OK'      WKHNTE  2
     C                     ELSE
     C                     SETON                     99
     C                     MOVEL'NG'      WKHNTE  2
     C                     MOVELER,3      MSG
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *----------------------------------------------------*
      * PALLET#                                            *
      *----------------------------------------------------*
     CSR         #SB920    BEGSR
      *
     C                     Z-ADD0         P2TOTL
     C                     Z-ADD0         P2SUMI
     C                     CALL 'AM#R02'
     C                     PARM           TISHID
     C                     PARM           TISHIT
     C                     PARM           TISURT
     C                     PARM           TINONY
     C                     PARM           TINKOJ
     C                     PARM           TINUKE
     C                     PARM           TIORD#
     C                     PARM           TIPALT
     C                     PARM           TIIAFB
     C                     PARM           TIIAFP
     C                     PARM           P2TOTL  30
     C                     PARM           P2SUMI  30
      *
     CSR         ESB920    ENDSR
      *----------------------------------------------------*
      * ERR                                                *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     CSR         ESB999    ENDSR
**
INPUT PALLET TICKET.
INPUT DOCK LABEL.
OTHER DOCK LABEL.
NO PALLET DATA.


