     H            Y.                                    1
     H** UTLR16 ********************************************
     H*  GET CUSTOMER NAME (INCLUDE DETELETED CUST#)       *
     H*  JW   2017.09.14                                   *
     F*  -------------------------------                   *
     F*  * SEE SIMILAR FUNCTION --> UTLR62, UTLR62B        *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR16'
     F*                    PARM           PMNONY  4
     F*                    PARM           PMOPT   1
     F*                    PARM           PMNAME 20
     F*                    PARM           PTOKU   4
     F*                    PARM           PMRTN   1
     F*   IN  PMNONY:  4A DELIVERY/CUSTOMER CODE
     F*       PMOPT :  1A D=INCLUDE DETELETED CUST#
     F*   OUT PMNAME: 20A NAME
     F*       PTOKU :  4A CUSTOMER#
     F*       PMRTN :  1A RETURN FLAG (BLANK=OK, *=ERROR)
     H**************************************************************************
     FGADPL15 IF  E           K        DISK
     FGADTL17 IF  E           K        DISK
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           PMRTN   1
      *
     C                     MOVE *BLANK    PMNAME
     C                     MOVE *BLANK    PTOKU
     C                     MOVE *BLANK    PMRTN
      * IF NONY=0 --> ERROR
     C           PMNONY    IFEQ *BLANK
     C                     MOVE '*'       PMRTN
     C                     GOTO @END
     C                     ENDIF
      * IF OPT<>'D' / BLANK  --> EEROR
     C           PMOPT     IFNE *BLANK
     C           PMOPT     ANDNE'D'
     C                     MOVE '*'       PMRTN
     C                     GOTO @END
     C                     ENDIF
      *
     C                     MOVELPMNONY    NUM4    40
      *
     C           NUM4      CHAINGADPL15              95
     C           *IN95     IFEQ *OFF
     C                     MOVELB5KMEI    PMNAME
     C                     MOVELB5TOKU    PTOKU
     C                     GOTO @END
     C                     ENDIF
      *
     C           *IN95     IFEQ *ON
     C           PMOPT     ANDEQ*BLANK
     C                     MOVE '*'       PMRTN
     C                     GOTO @END
     C                     ENDIF
      *
     C           PMOPT     IFEQ 'D'
     C           NUM4      SETLLGADTL17
     C           *IN96     DOWEQ*OFF
     C           NUM4      READEGADTL17                  96
     C           *IN96     IFEQ *OFF
     C                     MOVELB5KMEI    PMNAME
     C                     MOVELB5TOKU    PTOKU
     C                     GOTO @END
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     MOVE '*'       PMRTN
      *
     C           @END      TAG
     C                     MOVEL*ON       *INLR
     C                     RETRN
