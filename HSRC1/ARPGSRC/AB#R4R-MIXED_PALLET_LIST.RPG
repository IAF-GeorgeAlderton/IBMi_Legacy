     H            Y.
     F** AB#R4R ********************
     F*                            *
     F*  COPIED FROM AB#R44        *
     F*                            *
     F*                            *
     F******************** AB#R4R **
     FABWPL32 IF  E           K        DISK
     FAB#PL7G IF  E           K        DISK
     FALAPL01 IF  E           K        DISK
     FAB#PR4R O   E             70     PRINTER
     E                    WW          4  1
     I            DS
     I                                        1  20 IMHN
     I                                        1   5 IMHN1
     I                                        6  10 IMHN2
     I                                       11  15 IMHN3
     I                                       16  20 IMHN4
     I            DS
     I                                        1   80INOHZ
     I                                        1   40YYYY
     I                                        5   60MM
     I                                        7   80DD
     I            DS
     I                                        1  10 WNOHZ
     I                                        1   2 WNOMM
     I                                        3   3 WNO1
     I                                        4   5 WNODD
     I                                        6   6 WNO2
     I                                        7  10 WNOYY
     I            DS
     I                                        1  17 WMHIN
     I                                        1   5 WMHN1
     I                                        6   6 WMH1
     I                                        7  11 WMHN2
     I                                       12  12 WMH2
     I                                       13  17 WMHN3
     I            DS
     I                                        1   5 WPART1
     I                                        6  10 WPART2
     I                                       11  15 WPART3
     I                                        1   7 IMHN5
     I                                        8  11 IMHN6
     I            DS
     I                                        1   5 WPART4
     I                                        6  10 WPART5
     I                                       11  15 WPART6
     I                                        1   2 IMHN7
     I                                        3   7 IMHN8
     I                                        8  15 IMHN9
     I            DS
     I                                        1  12 WMHIN1
     I                                        1   7 WMHN4
     I                                        8   8 WMH5
     I                                        9  12 WMHN6
      *
     I            DS
     I                                        1  17 WMHIN2
     I                                        1   2 WMHN7
     I                                        3   3 WMH8
     I                                        4   8 WMHN9
     I                                        9   9 WMH10
     I                                       10  17 WMHN11
     I            DS
     I                                        1  17 PARTA
     I                                        1   5 PART1
     I                                        6   6 FLD1
     I                                        7   9 PART2
     I                                       10  10 FLD2
     I                                       11  14 PART3
     I                                       15  17 PART4
     I            DS
     I                                        1  18 PARTB
     I                                        1   5 PART5
     I                                        6   6 FLD3
     I                                        7   9 PART6
     I                                       10  10 FLD5
     I                                       11  11 FLD4
     I                                       12  15 PART7
     I                                       16  18 PART8
     I            DS
     I                                        1   5 NPART1
     I                                        6  10 NPART2
     I                                       11  15 NPART3
     I                                        1   5 NMHN1
     I                                        6   8 NMHN2
     I                                        9  12 NMHN3
     I                                       13  15 NMHN4
     I            DS
     I                                        1   80PHZ8
     I                                        1   40PYY8
     I                                        5   60PMM8
     I                                        7   80PDD8
     I            DS
     I                                        1   60WTIME
     I                                        1   20THH
     I                                        3   40TMM
     I                                        5   60TSS
      *
     C           *ENTRY    PLIST
     C                     PARM           PMXPL   30
      *
     C                     MOVE '===='    BA1     4
     C                     MOVE '===='    BA2     4
      *
     C           P#CMD     PLIST
     C                     PARM           #CHR    1
     C                     PARM           #L1     6
     C                     PARM           #L2     6
     C                     PARM           #L3     6
     C                     PARM           #L4     6
     C                     PARM           #L5     6
     C                     PARM           #L6     6
     C                     PARM           #L7     6
     C                     PARM           #L8     6
      *
     C           KEY1      KLIST
     C                     KFLD           KTOKU   40       CUSTOMER CODE
     C                     KFLD           KNONY   40       DELIVERY CODE
      *
     C           KEY2      KLIST
     C                     KFLD           KTOKU
     C                     KFLD           KNONY
     C                     KFLD           INUKE
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
     C                     KFLD           IMHN3
     C                     KFLD           IMHN4
      *
     C           KEY3      KLIST
     C                     KFLD           KTOKU
     C                     KFLD           CNONY
     C                     KFLD           IODRN
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
     C                     KFLD           IMHN3
     C                     KFLD           IMHN4
      *
      * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *
      *    M  A  I  N  L  I  N  E
      *
     C                     MOVE '-'       FLD1
     C                     MOVE '-'       FLD2
     C                     MOVE '-'       FLD3
     C                     MOVE '-'       FLD4
     C                     MOVE *BLANK    FLD5
      *
     C           *LOVAL    SETLLABWPL32
     C                     READ ABWPL32                  51
     C                     MOVELINUKE     SAVNUK
     C           *IN51     DOWEQ*OFF
      *
     C                     MOVE IMHN1     NPART1
     C                     MOVE IMHN2     NPART2
     C                     MOVE IMHN3     NPART3
     C                     MOVE NMHN1     PART1
     C                     MOVE NMHN2     PART2
     C                     MOVE NMHN3     PART3
     C                     MOVE NMHN4     PART4
     C                     MOVE PARTA     PART   17
      *
     C                     MOVE YYYY      WNOYY
     C                     MOVE MM        WNOMM
     C                     MOVE DD        WNODD
     C                     MOVE '/'       WNO1
     C                     MOVE '/'       WNO2
      *
      * if overflow, write headings...
     C           *IN70     IFEQ *ON
     C                     WRITEAB#PR4R1
     C                     SETOF                     70
     C                     ENDIF
      *
      * if dock has changed, print footer
     C           INUKE     IFNE SAVNUK
     C                     EXSR DOCR
     C                     ENDIF
      *
      * if kanban or cust item# has changed, get detail and print
     C           ISBAN     IFNE SAVBAN
     C           IMHN      ORNE SAVMHN
     C                     EXSR SUBR
     C                     ENDIF
      *
     C                     MOVELINUKE     SAVNUK  4
     C                     MOVELISBAN     SAVBAN  4
     C                     MOVELIMHN      SAVMHN 20
      *
     C                     READ ABWPL32                  51
     C                     ENDDO
      *
      * print footer with totals
     C           THAKO     IFGT *ZERO
     C                     EXSR DOCR
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *************************************************************
      * Purpose: write footer with total for dock
      *
     C           DOCR      BEGSR
      *
     C                     EXSR #LARG
     C                     WRITEAB#PR4R3
     C                     Z-ADD0         PAGE
      *
     C                     Z-ADD0         THAKO   50
     C                     Z-ADD0         SHAKO   50
      *
      *  GET CUSTOMER NAME
      *
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C                     SETOF                     85
     C           KEY1      CHAINALAPL011             85
     C           *IN85     IFEQ '0'
     C                     MOVELTPTPKN    WNAME
     C                     ELSE
     C                     MOVEL*BLANKS   WNAME
     C                     ENDIF
     C                     ENDSR
      *************************************************************
      * Purpose: get and write detail for part #
     C           SUBR      BEGSR
      *
     C           *IN55     IFEQ *OFF
     C           *IN70     OREQ *ON
      *
      *  get customer name
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C                     SETOF                     85
     C           KEY1      CHAINALAPL011             85
     C           *IN85     IFEQ '0'
     C                     MOVELTPTPKN    WNAME
     C                     ELSE
     C                     MOVEL*BLANKS   WNAME
     C                     ENDIF
      *
      *  write headings
     C                     MOVEL*BLANKS   SPART  17        PART#
     C                     MOVEL*BLANKS   SSBAN   4        KANBAN#
     C                     Z-ADD*DATE     PHZ8
     C                     TIME           WTIME
     C                     WRITEAB#PR4R1
     C                     MOVE *ON       *IN55
     C                     MOVE *OFF      *IN70
     C                     ENDIF
      *
     C                     MOVE IMHN1     WMHN1
     C                     MOVE '-'       WMH1
     C                     MOVE IMHN2     WMHN2
     C                     MOVE '-'       WMH2
     C                     MOVE IMHN3     WMHN3
      *
     C                     MOVE IMHN5     WMHN4
     C                     MOVE '-'       WMH5
     C                     MOVE IMHN6     WMHN6
      *
     C                     MOVE IMHN7     WMHN7
     C                     MOVE '-'       WMH8
     C                     MOVE IMHN8     WMHN9
     C                     MOVE '-'       WMH10
     C                     MOVELIMHN9     WMHN11
      *
      *
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C                     MOVELINONY     CNONY   4
     C                     MOVELISBAN     WSBAN     P
      *
      * detail with serial #s
      *
     C           KEY3      CHAINAB#PL7G              50
     C           *IN50     DOWEQ*OFF
     C                     MOVELEKSERL    WSERL
     C                     Z-ADD1         FC#BOX
      *
     C                     Z-ADDFC#BOX    WHAKO
     C                     ADD  WHAKO     THAKO
     C                     WRITEAB#PR4R2
      *
      * if max per pallet is reached, print footer
     C           THAKO     IFEQ PMXPL
     C                     EXSR DOCR
     C                     WRITEAB#PR4R1
     C                     ENDIF
      *
     C           *IN70     IFEQ *ON
     C                     WRITEAB#PR4R1
     C                     MOVE *OFF      *IN70
     C                     ENDIF
      *
     C           KEY3      READEAB#PL7G                  50
     C                     ENDDO
      *
     C                     ENDSR
      *
      *************************************************************
      * Purpose: --- PRINT LARGE CHR ---
      *          Ship Month and Day
      *
     C           #LARG     BEGSR
     C                     MOVELWNOMM     WW,1
     C                     MOVE WNOMM     WW,2
     C                     MOVELWNODD     WW,3
     C                     MOVE WNODD     WW,4
     C           1         DO   4         CC      10
     C                     MOVE *BLANKS   #L1
     C                     MOVE *BLANKS   #L2
     C                     MOVE *BLANKS   #L3
     C                     MOVE *BLANKS   #L4
     C                     MOVE *BLANKS   #L5
     C                     MOVE *BLANKS   #L6
     C                     MOVE *BLANKS   #L7
     C                     MOVE *BLANKS   #L8
     C                     MOVE WW,CC     #CHR
     C                     CALL 'AB#R4P'  P#CMD
     C           CC        IFEQ 1
     C                     MOVE #L1       #11
     C                     MOVE #L2       #12
     C                     MOVE #L3       #13
     C                     MOVE #L4       #14
     C                     MOVE #L5       #15
     C                     MOVE #L6       #16
     C                     MOVE #L7       #17
     C                     MOVE #L8       #18
     C                     ENDIF
     C           CC        IFEQ 2
     C                     MOVE #L1       #21
     C                     MOVE #L2       #22
     C                     MOVE #L3       #23
     C                     MOVE #L4       #24
     C                     MOVE #L5       #25
     C                     MOVE #L6       #26
     C                     MOVE #L7       #27
     C                     MOVE #L8       #28
     C                     ENDIF
     C           CC        IFEQ 3
     C                     MOVE #L1       #31
     C                     MOVE #L2       #32
     C                     MOVE #L3       #33
     C                     MOVE #L4       #34
     C                     MOVE #L5       #35
     C                     MOVE #L6       #36
     C                     MOVE #L7       #37
     C                     MOVE #L8       #38
     C                     ENDIF
     C           CC        IFEQ 4
     C                     MOVE #L1       #41
     C                     MOVE #L2       #42
     C                     MOVE #L3       #43
     C                     MOVE #L4       #44
     C                     MOVE #L5       #45
     C                     MOVE #L6       #46
     C                     MOVE #L7       #47
     C                     MOVE #L8       #48
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
