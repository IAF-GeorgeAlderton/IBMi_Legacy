     I                                      337 3430QTY54
     I                                      344 3500QTY55
     I                                      351 3570QTY56
     I                                      358 3640QTY57
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SSHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
      *
     I            DS
     I                                        1  20 S1PART
     I                                        1   5 S1MHN1
     I                                        6  10 S1MHN2
     I                                       11  15 S1MHN3
     I                                       16  20 S1MHN4
     I            DS
     I                                        1  20 AFMHIN
     I                                        1   5 AFMHN1
     I                                        6  10 AFMHN2
     I                                       11  15 AFMHN3
     I                                       16  20 AFMHN4
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 WSHN1
     I                                        6  10 WSHN2
     I                                       11  12 WSHN3
     I            DS
     I                                        1   80AFSHDT
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80@SHDT
     I                                        1   40@SHYY
     I                                        5   60@SHMM
     I                                        7   80@SHDD
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     SELEC
      * DSP01 -------------------------
     C           @SCRN     WHEQ 'DSP01'
     C                     EXSR #DSP01
      * F1: EXIT
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C                     LEAVE
     C                     ENDIF
      * SFL01 -------------------------
     C           @SCRN     WHEQ 'SFL01'
     C                     EXSR #SFL01
      * F5: EXIT
     C           *INKE     IFEQ *ON
     C           UPFLG     ANDEQ'Y'
     C                     LEAVE
     C                     ENDIF
      * F5:
     C           *INKE     IFEQ *ON
     C           UPFLG     ANDNE'Y'
     C                     MOVELERR,16    D9ERR            THERE IS NO FORECAST
     C                     ENDIF
      * SFL02 -------------------------
     C           @SCRN     WHEQ 'SFL02'
     C                     EXSR #SFL02
      *
     C                     ENDSL
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DISPLAY DSP01 FORECAST ORDER CONFIRMATION          *
      *----------------------------------------------------*
     C           #DSP01    BEGSR
     C                     EXFMTDSP01
     C                     SETOF                     85
     C                     MOVEL*BLANK    XMSG
      * F1:EXIT
     C           *INKA     IFEQ *ON
     C                     GOTO XDSP01
     C                     ENDIF
      *--------------
      * IF NO ERROR,
      *--------------
      * CLEAR SUB FILE **
     C                     SETON                     71
     C                     WRITECTL01
     C                     WRITECTL02
     C                     SETOF                     71
      * SET ORDER DATA **
     C                     CALL 'AFFC71'
     C                     PARM           YN      1
      * CHECK AND SET DATA
     C           YN        IFEQ 'Y'
     C                     EXSR #CHK1
     C                     ENDIF
      *
     C           XDSP01    ENDSR
      *----------------------------------------------------*
      *  CHECK FORECAST DATA                               *
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     MOVE 'N'       EDFLG1  1
     C                     MOVE 'N'       EDFLG2  1
     C                     MOVE *OFF      *IN85
     C                     Z-ADD0         YCNT    30
     C                     Z-ADD0         NCNT    30
     C                     Z-ADD0         OCNT    30
     C                     Z-ADD0         LIN#    30
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
     C                     Z-ADD0         SVNONY  40
     C                     OPEN AFFWP70                    OPEN
      *
     C                     DO   *HIVAL
     C                     READ AFFWP70                  91
     C   91                LEAVE
      * CHECK END FLAG
     C           EDFLG1    IFEQ 'Y'
     C           EDFLG2    OREQ 'Y'
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         LIN#
     C                     EXSR #CHK12
      * COUNT
     C                     SELEC
     C           OKFLG     WHEQ 'Y'
     C                     ADD  1         YCNT
     C           OKFLG     WHEQ 'N'
     C                     ADD  1         NCNT
     C                     OTHER
     C                     ADD  1         OCNT
     C                     ENDSL
     C                     ENDDO
      * IF NO RECORD..
     C           *IN85     IFEQ *OFF
     C           YCNT      ANDEQ0
     C                     MOVELERR,1     XMSG             NO DATA IN
     C                     MOVE '1'       XMSG             IFS.FC.HORIZONTAL.CSV
     C                     ENDIF
      * IF NO ERROR --> SFL01
     C           *IN85     IFEQ *OFF
     C                     MOVEL'SFL01'   @SCRN
     C                     ENDIF
      * IF ERROR EXISTS --> SFL02
     C           *IN85     IFEQ *ON
     C                     MOVEL'SFL02'   @SCRN
     C                     ENDIF
      *
     C           RRN1      IFEQ 0
     C           RRN2      ANDEQ0
     C                     MOVEL'DSP01'   @SCRN
     C                     MOVELERR,1     XMSG             NO DATA IN
     C                     MOVE '2'       XMSG             IFS.FC.HORIZONTAL.CSV
     C                     ENDIF
      *
     C                     CLOSEAFFWP70                    CLOSE
      *
     C           XCHK1     ENDSR
      *----------------------------------------------------*
      *  CHECK 2                                           *
      *----------------------------------------------------*
     C           #CHK12    BEGSR
      *
     C                     MOVE 'N'       HDFLG   1
     C                     MOVE ' '       OKFLG   1
      * LINE IGNORED
     C           FLD5      IFEQ *BLANK
     C                     GOTO XCHK12
     C                     ENDIF
      *===================
      * HEADER PROCESS   *
      *===================
      * HEADER (IF FLD5 CONTAINS "PART" --> HEADER)
     C           'PART'    SCAN FLD5                     98
     C           *IN98     IFEQ *ON
     C                     MOVE 'Y'       HDFLG
     C                     EXSR #HDR1
     C                     GOTO XCHK12
     C                     ENDIF
      *===================
      * DETAIL PROCESS   *
      *===================
      * IF COMMENT LINE --> SKIP
     C           @TYPE     IFEQ '*'
     C                     MOVE ' '       OKFLG
     C                     GOTO XCHK12
     C                     ENDIF
      * 1.(A) CHECK TYPE
     C                     MOVELFLD1      @TYPE   1
     C           @TYPE     IFNE 'M'
     C           @TYPE     ANDNE'W'
     C           @TYPE     ANDNE'D'
     C                     MOVE 'N'       OKFLG
     C                     MOVELERR,24    S2MSG            TYPE SHOULD BE M/W/D
     C                     EXSR #ERRD
     C                     ENDIF
      * 2.(B) CUST#
      *       EDIT CUST#
     C                     MOVELFLD2      $IN4
     C                     CALL 'EDTR04B'
     C                     PARM           $IN4    4
     C                     PARM           $OUT4   4
     C                     MOVEL$OUT4     @TOKU   40
     C           @TOKU     CHAINFGBPL01              99
     C           *IN99     IFEQ *ON
     C                     MOVELERR,25    S2MSG            INVALID CUSTOMER#!
     C                     EXSR #ERRD
     C                     ENDIF
      * 3.(C) DELIVVERY CODE
     C                     MOVELFLD3      $IN4
     C                     CALL 'EDTR04B'
     C                     PARM           $IN4    4
     C                     PARM           $OUT4   4
     C                     MOVEL$OUT4     @NONY   40
     C           @NONY     CHAINFGBPL01              99
     C           *IN99     IFEQ *ON
     C                     MOVELERR,2     S2MSG            INVALID DELIV#
     C                     EXSR #ERRD
     C                     ENDIF
      * SAVE DELIVERY CODE
     C           SVNONY    IFEQ 0
     C                     Z-ADD@NONY     SVNONY
     C                     ENDIF
      * CHECK MULTIPLE DELIVERYV CODE
     C           @NONY     IFNE SVNONY
     C           SVNONY    ANDNE0
     C                     MOVELERR,14    S2MSG            MULTIPLE DELIV#
     C                     EXSR #ERRD
     C                     ENDIF
      * 4.(D) DOCK
     C                     MOVELFLD4      $IN25     P
     C                     CALL 'EDTR02C'
     C                     PARM           $IN25  25
     C                     PARM           $OUT25 25
     C                     MOVEL$OUT25    @NUKE   4
      * 5.(E) PART#
      *   REMOVE "-"
     C                     MOVELFLD5      $IN25     P
     C                     CALL 'EDTR02C'
     C                     PARM           $IN25  25
     C                     PARM           $OUT25 25
      *
     C                     MOVEL@NONY     $NONY
     C                     MOVEL$OUT25    $MHIN
     C                     CALL 'UTLR61A'
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $SHIN  12
      *
     C           $SHIN     IFEQ *BLANK
     C                     MOVELERR,9     S2MSG            COMMON P/M
     C                     EXSR #ERRD
     C                     ENDIF
      *
     C           $SHIN     IFNE *BLANK
     C                     MOVELFLD5      @MHIN  20        ORIGINAL USR PART
     C                     MOVEL$OUT25    @PART  20        NO HIPH USER PART
     C                     ENDIF
JW    * SET TYPE FORECELY
     C           @NONY     IFEQ 0681                       PMO
     C                     MOVEL'D'       @TYPE
     C                     ENDIF
      *
      * 5.(E) CHECK ORDER QTY
     C                     EXSR #QTY1
      *
      * END OF CHECK --------------------------------------
     C           OKFLG     IFEQ 'Y'
     C           OKFLG     OREQ ' '
     C                     Z-ADD0         SVLIN#
     C           1         DO   52        IX
     C           DAT,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      * BREAK
     C           LIN#      IFNE SVLIN#
     C           RRN1      ANDNE0
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     Z-ADDLIN#      S1LIN#
     C                     MOVEL@TYPE     S1TYPE
     C                     MOVEL@TOKU     S1TOKU
     C                     MOVEL@NONY     S1NONY
     C                     MOVEL@NUKE     S1NUKE
     C**                   MOVEL@MHIN     S1MHIN
     C                     MOVEL@PART     S1MHIN
     C                     MOVELDAT,IX    S1NOHZ
     C                     Z-ADDQTY,IX    S1QTY
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     Z-ADDLIN#      SVLIN#
     C                     ENDDO
      *
     C                     MOVE 'Y'       OKFLG
     C                     ENDIF
      *
     C           RRN1      IFGT MAX1
     C                     MOVELERR,4     D9ERR            NO ERROR... PRESS F5
     C                     MOVE 'Y'       EDFLG1
     C                     ENDIF
      *
     C           RRN2      IFGT MAX2
     C                     MOVELERR,5     S2MSG            ERROR REACHED MAX 800
     C                     MOVELERR,5     D9ERR
     C                     SETON                     85
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     MOVE 'Y'       EDFLG2
     C                     ENDIF
      *
     C           XCHK12    ENDSR
      *----------------------------------------------------*
      *  MAKE BREAK LINE                                   *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C                     MOVE *BLANK    S1TYPE
     C                     Z-ADD0         S1LIN#
     C                     MOVE *BLANK    S1TOKU
     C                     MOVE *BLANK    S1NONY
     C                     MOVE *BLANK    S1NUKE
     C                     MOVE *BLANK    S1MHIN
     C                     Z-ADD0         S1NOHZ
     C                     Z-ADD0         S1QTY
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK HEADER                                      *
      *----------------------------------------------------*
     C           #HDR1     BEGSR
      *
     C                     MOVEA*BLANK    DAT
      *
     C           1         DO   52        IX      20
     C           FLD,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      * CHECK DATE
     C                     MOVELFLD,IX    $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
      *
     C           $RTN      IFEQ ' '
     C                     MOVEL$TRUE     DAT,IX
     C                     MOVEL' '       DER,IX
     C                     ELSE
     C                     MOVEL$SRC      DAT,IX
     C                     MOVE '*'       DER,IX
     C                     MOVE 'N'       OKFLG
     C                     EXSR #ERRH
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK QTY                                         *
      *----------------------------------------------------*
     C           #QTY1     BEGSR
      *
     C                     MOVEA*ZERO     QTY
      *
     C           1         DO   52        IX      20
     C           FLD,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      * CHECK QTY
     C                     Z-ADD0         @QTY    70
     C                     MOVELFLD,IX    $CHAR  17
     C                     CALL 'UTLR60'
     C                     PARM           $CHAR  17
     C                     PARM           $T156  156
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     Z-ADD$T156     QTY,IX
     C                     ELSE
     C                     MOVELERR,10    S2MSG            QTY IS INVALID!
     C                     EXSR #ERRD
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  DISPLAY ORDER (SFL01)                             *
      *----------------------------------------------------*
     C           #SFL01    BEGSR
      *
     C           EDFLG1    IFEQ 'Y'
     C                     MOVELERR,21    D9ERR            ORDER REACHED MAX 800
     C                     ELSE
     C                     MOVELERR,6     D9ERR            PRESS F5 FOR NEXT STP
     C                     ENDIF
      *
     C                     WRITEDSP91
     C                     SETON                     72
     C                     EXFMTCTL01
     C                     SETOF                     72
     C                     MOVE *BLANK    D9ERR
      * F3 BACK
     C           *INKC     IFEQ *ON
     C                     MOVEL'DSP01'   @SCRN
     C                     ENDIF
      * CHECK END FLAG
     C           EDFLG1    IFEQ 'Y'
     C                     MOVE *OFF      *INKE
     C                     ENDIF
      * F5: UPLOAD
     C           *INKE     IFEQ *ON
     C                     EXSR #UPL
     C                     MOVEL'DSP01'   @SCRN
     C                     ENDIF
      *
     C           XSFL01    ENDSR
      *----------------------------------------------------*
      *  DISPLAY ERROR (SFL02)                             *
      *----------------------------------------------------*
     C           #SFL02    BEGSR
      *
     C           EDFLG2    IFEQ 'Y'
     C                     MOVELERR,5     D9ERR            ERROR REACHED MAX 300
     C                     ELSE
     C                     MOVELERR,7     D9ERR            FIX ERROR TRY AGAIN
     C                     ENDIF
      *
     C                     WRITEDSP92
     C                     SETON                     72
     C                     EXFMTCTL02
     C                     SETOF                     72
     C                     MOVE *BLANK    D9ERR
      * F3 BACK
     C           *INKC     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'DSP01'   @SCRN
     C                     ENDIF
      *
     C           XSFL02    ENDSR
      *----------------------------------------------------*
      *  WRITE HEADER ERROR SFL                            *
      *----------------------------------------------------*
     C           #ERRH     BEGSR
      *
     C                     Z-ADDLIN#      S2LIN#
     C                     MOVE *BLANK    S2TYPE
     C                     MOVE *BLANK    S2TOKU
     C                     MOVE *BLANK    S2NONY
     C                     MOVE *BLANK    S2NUKE
     C                     MOVEL$SRC      S2MHIN    P
     C                     MOVELERR,12    S2MSG
     C                     MOVEL'WEEK#'   LTR7    7
     C                     MOVE IX        LTR7
     C                     MOVE LTR7      S2MSG
      *
     C                     SETON                     85
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     MOVE 'N'       OKFLG
      *
     C           XERRH     ENDSR
      *----------------------------------------------------*
      *  WRITE DETAIL ERROR SFL                            *
      *----------------------------------------------------*
     C           #ERRD     BEGSR
      *
     C                     Z-ADDLIN#      S2LIN#
     C                     MOVELFLD1      S2TYPE
     C                     MOVEL@TOKU     S2TOKU
     C                     MOVEL@NONY     S2NONY
     C                     MOVELFLD4      S2NUKE
     C                     MOVELFLD5      S2MHIN
      *
     C                     SETON                     85
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     MOVE 'N'       OKFLG
      *
     C           XERRD     ENDSR
      *----------------------------------------------------*
      *  WRITE WORK FILE                                   *
      *----------------------------------------------------*
     C           #UPL      BEGSR
      *
     C                     Z-ADD0         RRN1
      *
     C                     DO   *HIVAL
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                99
     C   99                LEAVE
      * OUT
     C                     CLEARAFFWP711
      *
     C           S1LIN#    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDS1LIN#    AFLIN#
     C                     MOVEL@TYPE     AFTYPE
     C                     Z-ADD@TOKU     AFTOKU
     C                     Z-ADD@NONY     AFNONY
     C                     MOVEL@NUKE     AFNUKE
     C                     Z-ADDS1NOHZ    AFSHDT
     C                     MOVELS1MHIN    AFMHIN
     C                     Z-ADDS1QTY     AFSRYO
      * DEFAULT
     C           AFNUKE    IFEQ *BLANK
     C           AFNUKE    OREQ '0   '
     C                     MOVEL'00  '    AFNUKE
     C                     ENDIF
      *
     C                     WRITEAFFWP711
     C                     MOVE 'Y'       UPFLG
      *
     C                     ENDDO
      *
     C           XUPL      ENDSR
      *----------------------------------------------------*
      * INITIALIZE
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           UPFLG   1
      *
     C           KEY1      KLIST
     C                     KFLD           WSHN1
     C                     KFLD           WSHN2
     C                     KFLD           WSHN3
      *
     C           K#15      KLIST
     C                     KFLD           WNOYY
     C                     KFLD           WNOMM
     C                     KFLD           WTOKU   40
     C                     KFLD           WNONY   40
     C                     KFLD           WNKOJ   1
     C                     KFLD           WNUKE   4
     C                     KFLD           WMHN1
     C                     KFLD           WMHN2
     C                     KFLD           WMHN3
     C                     KFLD           WMHN4
      *
     C           K#17      KLIST
     C                     KFLD           @NONY
     C                     KFLD           @SHYY
     C                     KFLD           @SHMM
     C                     KFLD           @SHDD
      *
     C           K#85      KLIST
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNUKE   4
     C                     KFLD           WMHN1
     C                     KFLD           WMHN2
     C                     KFLD           WMHN3
     C                     KFLD           WMHN4
     C                     KFLD           WDATE   80
      *
     C           K#85X     KLIST
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNUKE   4
     C                     KFLD           WMHN1
     C                     KFLD           WMHN2
     C                     KFLD           WMHN3
     C                     KFLD           WMHN4
      *
      * IF DATA WAS UPLODED, UPFLAG=Y
     C                     MOVE *BLANK    UPFLG
      *
     C                     Z-ADD0         WDATE
     C                     Z-ADD0         @SHDT
     C                     TIME           SDATE
     C                     MOVEL'DSP01'   @SCRN   5
     C                     Z-ADD800       MAX1    40
     C                     Z-ADD800       MAX2    40
     C                     MOVE *OFF      *IN73            MORE
     C                     Z-ADDLIN#      SVLIN#  30
      *
