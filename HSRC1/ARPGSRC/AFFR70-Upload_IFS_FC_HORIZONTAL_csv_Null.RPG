      ** AFFR70 ******************************************************
      *  FUNCTION : UPLOAD IFS.FC.HORIZONTAL.CSV                     *
      *  WRITTEN  : JW (SRA)   2024.04.29                            *
     *** CAUTION !!! COMPLIE WITH "ALLOW NULL *YES"                 *
      ****************************************************************
     FAFFPW70 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FFGBPL01 IF  E           K        DISK
     FAFFWP70 IF  E           K        DISK                           UC
     FAFFWP71 O   E           K        DISK
      *
     E                    ERR     1  25 60
     E                    FLD        52 20
     E                    DAT        52  8
     E                    DER        52  8
     E                    QTY        52  7 0
      *-----------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
      * SYSTEM TIME
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * FLD
     I            DS
     I                                        11040 FLD
