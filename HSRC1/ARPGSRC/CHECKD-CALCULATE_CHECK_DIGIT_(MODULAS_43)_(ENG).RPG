     H            Y.
      ******************************************************************
      *  PROGRAM ID.   :  CHKR12                                       *
      *  PROGRAM　   :  CALCULATE CHECK DIGIT (MODULAS 43)
      *  JW
      ******************************************************************
     FCHKPW12 CF  E                    WORKSTN
     E                    ER      1   3 60
      * CHECK DIGIT
     C           CHKR01    PLIST
     C                     PARM           PMAREA100        * FIELD
     C                     PARM           PMBYTE  3        * LENGTH
     C                     PARM           PMCHK   1        * CHECK DIGIT
     C                     PARM           PMRTCD  1        * RETURN CODE
      *
     C                     SETOF                     010299
     C                     MOVE *BLANK    FIL1
     C                     Z-ADD0         FIL2
     C                     MOVE *BLANK    FIL3
      *
     C           STP1      TAG
     C                     EXFMTDSP01
     C                     SETOF                     010299
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           FIL1      IFEQ *BLANK
     C                     MOVELER,1      MSG
     C                     SETON                     0199
     C                     GOTO STP1
     C                     END
      *
     C           FIL2      IFEQ 0
     C           FIL2      ORGT 100
     C                     MOVELER,2      MSG
     C                     SETON                     0299
     C                     GOTO STP1
     C                     END
      *
     C                     MOVELFIL1      PMAREA100
     C                     MOVELFIL2      PMBYTE  3
     C                     MOVE *BLANK    PMCHK   1
     C                     MOVE *BLANK    PMRTCD  1
     C                     CALL 'CHKR01'  CHKR01
      *
     C           PMRTCD    IFEQ '1'
     C                     MOVELER,3      MSG
     C                     SETON                     010299
     C                     GOTO STP1
     C                     END
      *
     C                     MOVELPMCHK     FIL3
     C                     GOTO STP1
** ER ------------------------------------------------------>
E-01 ENTER VALUES!
E-02 ENTER LENGTH!
E-03 CHECK DIGIT CANNOT CALCULATE!
