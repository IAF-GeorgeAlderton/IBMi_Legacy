     F** AL#R53 **************************************
     F* TRUCK BIN M/F                                *
     F*        ITS.         2015.05.20               *
     F************************************************
     FAL#PP51 IF  E           K        DISK
     FAL#WP51 UF  E                    DISK                      A
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KIHZ  8
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     MOVE *BLANK    P1KIHZ
     C                     Z-ADD1         WKSORT  50
     C           WKSORT    DOWLE999
     C                     MOVE WKSORT    W1SEQ
     C                     WRITEAL#WP511
     C                     ADD  1         WKSORT
     C                     ENDDO
      *
     C                     READ AL#PP511                 80
     C           *IN80     DOWEQ'0'
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVE C5KIHZ    P1KIHZ
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ AL#PP511                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     MOVEL'0'       GET     1
     C           1         SETLLAL#WP511
     C                     READ AL#WP511                 20
     C           *IN20     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           W1SURT    IFEQ *BLANK
     C                     MOVEL'1'       GET     1
     C                     MOVELC5SURT    W1SURT
     C                     MOVELC5TRKB    W1TRKB
     C                     MOVELC5KRKB    W1KRKB
     C                     UPDATAL#WP511
     C                     ENDIF
     C                     READ AL#WP511                 20
     C                     ENDDO
      *
     CSR         ESB500    ENDSR
