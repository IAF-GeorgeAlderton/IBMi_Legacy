     C                     TIME           WTIME
     C                     Z-ADDSTIME     W#TIME  60
      *
      * TODAY FOR WEEKDAY
      * PREVIOUS WORIKING DAY FOR HOLIDAY
     C           KEYF8     KLIST
     C                     KFLD           K@KAYY  40
     C                     KFLD           K@KAMM  20
     C                     KFLD           K@KADD  20
      *
     C                     Z-ADDSYEAR     K@KAYY
     C                     Z-ADDSMONTH    K@KAMM
     C                     Z-ADDSDAY      K@KADD
     C                     Z-ADD0         W#SDAT  80
      * GET PREVIOUS WORKING DAY AND 1 DAY AGO
     C                     Z-ADD0         X       20
     C                     Z-ADD0         Y       20
     C           KEYF8     SETGTAGDPL12
     C                     READPAGDPL12                  20
     C           *IN20     DOWEQ'0'
     C           X         ANDLE1
      *
     C                     ADD  1         Y
     C           Y         IFEQ 2
     C                     Z-ADDF8KAHZ    W#3DAT           1 DAY AGO
     C                     ENDIF
      *
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  1         X
     C           X         IFEQ 1
     C                     Z-ADDF8KAHZ    W#SDAT           PREV W.DAY
     C***                  ELSE
     C***                  Z-ADDF8KAHZ    W#3DAT           1 DAY AGO
     C                     ENDIF
     C                     ENDIF
      *
     C                     READPAGDPL12                  20
     C                     ENDDO
      *
      * 12 HOURS AGO
     C           W#TIME    IFGE 120000
     C                     SUB  120000    W#TIME
     C                     Z-ADDSDATE     W#3DAT
     C                     ELSE
     C                     ADD  120000    W#TIME
     C                     ENDIF
      ********
     C                     READ ALDPL68                  20
     C           *IN20     DOWEQ'0'
     C           AFNODT    IFGE W#SDAT
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ ALDPL68                  20
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
