     H            Y.
      ** KFAR05 *******************************************
      * PRINT ALL ITEM SIGNAL KANBAN LOCATION  ON BARCODE *
      * PROGRAM ID. : KFAR05. <RPG>                       *
      * CREATE DATE. : OCT/06/1997.                       *
      * AUTHOR.         : S.OHTAKE.  ADDING(TAKE)         *
      * UPDATE : OCT/07/1997. K.OKACHI      %0001         *
      ******************************************* KFAR05 **
     FKFAWP04 IP  F      36            DISK
TAKE FFCEPL03 IF  E           K        DISK
     FKFAPR05 O   E             77     PRINTER                        UC
     E                    TAB3    1   6  1   TAB4    6   箱色　名
TAKE E                    CHK1        7  1               * BARCODE
TAKE E                    TABX1  11  43  1   TABY1   2 0 * CHR->NUMERI
TAKE E                    TABX2  11  43  2 0 TABY2   1   * NUMERIC->CH
     IKFAWP04 NS  01
     I                                        1   40KZBMONL1
     I                                        5   5 KZBAN1
     I                                        6   7 KZBAN2
     I                                        8   9 KZBAN3
     I                                       10  10 KZBAN4
     I                                       11  11 KZHICR
     I                                       12  16 KZHIN1
     I                                       17  21 KZHIN2
     I                                       22  23 KZHIN3
     I                                       24  26 KZKIB1
     I                                       27  29 KZKIB2
     I                                       30  32 KZKIB3
     I                                       33  33 KZYOTP
     I                                       34  350KZHIMS
     I                                       36  36 KZHIRO
     I            DS
     I                                        1  14 KZHINB
     I                                        1   5 KZHIN1
     I                                        6   6 KZH1
     I                                        7  11 KZHIN2
     I                                       12  12 KZH2
     I                                       13  14 KZHIN3
     I            DS
     I                                        1   6 KZBAN
     I                                        1   1 KZBAN1
     I                                        2   3 KZBAN2
     I                                        4   5 KZBAN3
     I                                        6   6 KZBAN4
     I                                        2   2 KZBAN5
     I                                        4   4 KZBAN6
     I            DS
     I                                        1   4 NAME
     I                                        1   2 NAME01
     I                                        3   4 NAME02
      *
TAKE I            DS
TAKE I                                        1   8 BR
TAKE I*                                       1   1 W1BAR
TAKE I                                        1   7 BAR
TAKE I                                        1   4 ZETI
TAKE I                                        5   7 BLNK
TAKE I                                        8   8 CHKD
TAKE I*                                      10  10 W2BAR
      *
TAKE I            DS
TAKE I                                        1   80A2GSHZ
TAKE I                                        1   40A2GSYY
TAKE I                                        5   60A2GSMM
TAKE I                                        7   80A2GSDD
      *
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
TAKE C           KEY1      KLIST
TAKE C                     KFLD           KZBAN1
TAKE C                     KFLD           KZBAN2
TAKE C                     KFLD           KZBAN3
TAKE C                     KFLD           KZBAN4
      *
     C  N01                GOTO @END
      *
     C           *IN,90    IFEQ '0'
     C                     Z-ADD0         CNT     10
     C                     MOVE *BLANK    PSW     1
     C                     MOVEL'1'       *IN77
     C                     MOVEA'1'       *IN,90
     C                     END
      *
     C           PSW       IFEQ *BLANK
     C                     OPEN KFAPR05
     C                     MOVEL'*'       PSW
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     MOVE *BLANK    NAME
     C                     MOVEL'XXXX'    NAME
     C                     ADD  1         CNT
      *
     C           CNT       IFEQ 1
     C                     WRITEKFAPR051
     C                     END
      *
     C           CNT       IFEQ 2
     C                     WRITEKFAPR052
     C                     END
      *
     C           CNT       IFEQ 3
     C                     WRITEKFAPR053
     C                     Z-ADD0         CNT
     C                     END
      *
     C                     END
      *
     C                     MOVE '-'       KZH1
     C                     MOVE '-'       KZH2
      *
     C*  ﾌﾃbﾜ ﾈｮn
     C*
     C                     MOVE *BLANK    COL     6
     C           KZHIRO    LOKUPTAB3      TAB4           10
     C   10                MOVELTAB4      COL
      *
     C*          KZBAN5    IFEQ '0'
     C*                    MOVE *BLANK    KZBAN5
     C*                    END
     C*          KZBAN6    IFEQ '0'
     C*                    MOVE *BLANK    KZBAN6
     C*                    END
     C*          KZBAN4    IFEQ '0'
     C*                    MOVE '-'       KZBAN4
     C*                    END
      *
     C                     DO   KZHIMS
TAKE C                     EXSR BUHIN
%0001C           *IN10     IFEQ '0'
TAKE C                     EXSR BARSUB
%0001C                     END
     C                     ADD  1         CNT
     C           CNT       IFEQ 1
     C                     WRITEKFAPR054
     C                     END
      *
     C           CNT       IFEQ 2
     C                     WRITEKFAPR055
     C                     END
      *
     C           CNT       IFEQ 3
     C                     WRITEKFAPR056
     C                     Z-ADD0         CNT
     C                     END
      *
     C                     END
      *
     C           @END      TAG
      *
TAKE  *================================================================
TAKE  ***********
TAKE  *  BUHIN  *
TAKE  ***********
TAKE C           BUHIN     BEGSR
TAKE C                     MOVE *BLANK    ZETI    4
%0002 *
     C           KEY1      SETLLFCEPL031
     C                     SETON                     10
     C                     DO   *HIVAL
     C                     SETOF                     80
     C           KEY1      READEFCEPL031                 80
     C           *IN80     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     GOTO EXIT1
     C                     ELSE
     C                     SETOF                     10
     C                     MOVE A2ZETI    ZETI
     C                     END
     C                     END
     C           EXIT1     TAG
     C  N80                ENDDO
%0002 *
      *
TAKE C*                    SETOF                     8010
TAKE C*          KEY1      CHAINFCEPL03              80
TAKE C*          *IN80     IFEQ '0'
TAKE C*          A2GSKD    IFEQ 'D'
TAKE C*          A2GSHZ    ANDLE*DATE
TAKE C*                    SETON                     80
TAKE C*                    ENDIF
TAKE C*                    ENDIF
TAKE C*          *IN80     IFEQ '1'
TAKE C*                    MOVE *BLANK    ZETI
%0001C*                    SETON                     10
TAKE C*                    ELSE
TAKE C*                    MOVE A2ZETI    ZETI
TAKE C*                    ENDIF
TAKE  *
TAKE C                     ENDSR
TAKE  ****************
TAKE  *  CHECKDIGIT  *
TAKE  ****************
TAKE C           BARSUB    BEGSR
TAKE C                     MOVE '000'     BLNK
TAKE C*                    MOVE '*'       W1BAR
TAKE C*                    MOVE '*'       W2BAR
TAKE C                     MOVEABAR       CHK1
TAKE C                     Z-ADD7         XX      20
TAKE C                     Z-ADD0         I       20
TAKE C                     Z-ADD0         WKKEI   50
TAKE C           1         DO   XX        I
TAKE C                     SETOF                     75
TAKE C           CHK1,I    LOKUPTABX1     TABY1          75
TAKE C           *IN75     IFEQ '1'
TAKE C                     ADD  TABY1     WKKEI
TAKE C                     END
TAKE C                     END
TAKE  *
TAKE C           WKKEI     DIV  43        WKSHO   20
TAKE C                     MVR            WAMARI  20
TAKE  *
TAKE C                     SETOF                     75
TAKE C           WAMARI    LOKUPTABX2     TABY2          75
TAKE C           *IN75     IFEQ '1'
TAKE C                     MOVE TABY2     CHKD    1
TAKE C                     END
TAKE C                     MOVE BR        BARC
TAKE C                     ENDSR
