     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PLKBN   1
     C                     PARM           PTKOJ   1
     C                     PARM           PKOTE   3
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE '***'     KOTE
     C******************************************************
     C* M-NO               ﾒﾇn ﾆﾞﾑci] ﾒﾏcﾒﾑh               *
     C******************************************************
     C           STEP01    TAG
     C                     EXFMTGBFPW761
     C           *INKA     IFEQ '1'
     C                     SETON                     U1
     C                     GOTO END
     C                     END
     C           KOTE      IFEQ *BLANK
     C                     SETON                     99
     C                     MOVE ER,1      MSG
     C                     GOTO STEP01
     C                     END
     C           KOTE      IFNE *BLANK
     C           KOTE      IFNE '***'
     C           KOTE      CHAINFCETL031             99
     C           *IN99     IFEQ '1'
     C                     MOVE ER,2      MSG
     C                     GOTO STEP01
     C                     ELSE
     C           A6GSKD    IFEQ 'D'
     C                     MOVE ER,3      MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C                     END
     C                     END
     C           *INKE     CABEQ'0'       STEP01
     C******************************************************
     C* M-NO               vlyﾒibﾅ]ﾎabﾓ ﾉ ﾑvnﾒ             *
     C******************************************************
     C                     MOVE KOTE      PKOTE
     C           TNKEY     KLIST
     C                     KFLD           UTOKU
     C                     KFLD           PTKOJ
     C                     KFLD           KMHN1
     C                     KFLD           KMHN2
     C                     KFLD           KMHN3
     C                     KFLD           KMHN4
     C                     MOVE *BLANK    KMHN1   5
     C                     MOVE *BLANK    KMHN2   5
     C                     MOVE *BLANK    KMHN3   5
     C                     MOVE *BLANK    KMHN4   5
     C           TNKEY     SETLLGBFPL511
     C                     SETOF                     02
     C           STEP02    TAG
     C                     SETOF                     04
     C                     READ GBFPL51                  02
     C           *IN02     CABEQ'1'       END
     C******************************************************
     C* M-NO               vlyﾒibﾅ]ﾎabﾓ ﾉ ﾆﾞﾑci] ﾈ]jh      *
     C******************************************************
     C           G9TOKU    CABNEUTOKU     END
     C           PTKOJ     IFNE '*'
     C           G9TKOJ    CABNEPTKOJ     END
     C                     END
     C           G9SKJY    IFEQ 'D'
     C           G9SKHZ    ANDLEUDATE
     C                     GOTO STEP02
     C                     END
     C                     Z-ADDG9TOKU    ICTOKU
     C                     MOVE G9TKOJ    ICTKOJ
     C           PLKBN     IFEQ '3'
     C                     MOVE *BLANK    ICKKEY
     C                     ELSE
     C                     MOVE G9TKOJ    ICKKEY
     C                     END
     C                     MOVE G9MHN1    ICMHN1
     C                     MOVE G9MHN2    ICMHN2
     C                     MOVE G9MHN3    ICMHN3
     C                     MOVE G9MHN4    ICMHN4
     C                     MOVE G9MSYO    ICMSYO
     C                     Z-ADDG9TUSZ    ICTUSZ
     C                     Z-ADDG9KUBI    ICKUBI
     C                     MOVE G9ZCOD    ICZCOD
     C                     Z-ADDG9SZIJ    ICSZIJ
     C                     Z-ADDG9SZAJ    ICSZAJ
     C                     Z-ADDG9KANJ    ICKANJ
     C                     Z-ADDG9KAKH    ICKAKH
     C                     Z-ADDG9MTAN    ICMTAN
     C                     Z-ADDG9SRYO    ICSRYO
     C                     Z-ADD1         I       20
     C           1         DO   10        I
     C           KO,I      CABEQ*BLANK    STEP02
     C                     MOVE KO,I      ICKOTE
     C                     Z-ADDKG,I      ICKGEN
     C                     SETOF                     05
     C           KOTE      IFNE '***'
     C           KOTE      IFEQ KO,I
     C                     WRITEGBFWP761
