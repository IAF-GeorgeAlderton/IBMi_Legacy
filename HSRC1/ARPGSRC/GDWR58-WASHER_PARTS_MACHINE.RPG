     C                     EXSR #MAIN
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FCEP    KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           K#MC      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
      *
     C           *LIKE     DEFN MCSHN1    K@SHN1
     C           *LIKE     DEFN MCSHN2    K@SHN2
     C           *LIKE     DEFN MCSHN3    K@SHN3
      *
      *
     C                     ENDSR
      *------------------------------------------------------
      *   MAIN ROUTINE
      *------------------------------------------------------
     C           #MAIN     BEGSR
      *
     C           *LOVAL    SETLLAKBPL04
      *
     C           *IN80     DOWEQ*OFF
     C                     READ AKBPL04                  80
      *
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDNE'D'
     C           L1STYY    ANDEQ9999
      *
     C                     CLEARGDGWP581
      *
     C                     MOVE L1SHN1    WPART1
     C                     MOVE L1SHN2    WPART2
     C                     MOVE L1SHN3    WPART3
      * PCS/BOX
     C           K#FCEP    SETLLMCENP13
     C           *IN97     DOUEQ*ON
     C           K#FCEP    READEMCENP13                  97
B01  C           *IN97     IFEQ *OFF
      *
     C                     MOVE MCSHN1    WSPRT1
     C                     MOVE MCSHN2    WSPRT2
     C                     MOVE MCSHN3    WSPRT3
     C                     MOVE MCSHN1    K@SHN1
     C                     MOVE MCSHN2    K@SHN2
     C                     MOVE MCSHN3    K@SHN3
      *
     C           K#MC      CHAINFCEPL11              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDFCGK01    WMQTY
     C                     ENDIF
      *
     C                     EXSR #MCN
     C           K#MC      CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA2SSYS    WBQTY
     C                     ENDIF
     C                     WRITEGDGWP581
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   MACHINE NUMBER
      *------------------------------------------------------
     C           #MCN      BEGSR
      *
     C           K#MC      SETLLAAMPL11
     C           *IN91     DOUEQ*ON
     C           K#MC      READEAAMPL11                  91
     C           *IN91     IFEQ *OFF
     C           CKSKJY    ANDEQ*BLANK
      *
     C                     Z-ADD1         Y       30
     C           'RL '     LOKUPKO,Y                     10
     C           *IN10     IFEQ *ON
     C                     MOVE KB,Y      WMCHN
     C                     ENDIF
     C                     LEAVE
      *
     C                     ENDIF
     C                     ENDDO
