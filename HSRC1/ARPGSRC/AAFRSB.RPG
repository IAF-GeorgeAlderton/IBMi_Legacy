     H            Y.
     FAAAPL01 IF  E           K        DISK
     E                    JOK         8  2
     E                    TB1     1  12  2
     E                    TB2     1 100  2
      *
     C           *ENTRY    PLIST
     C                     PARM           P@KDAI  1
     C                     PARM           P@JOK1  2
     C                     PARM           P@JOK2  2
     C                     PARM           P@JOK3  2
     C                     PARM           P@JOK4  2
     C                     PARM           P@JOK5  2
     C                     PARM           P@JOK6  2
     C                     PARM           P@JOK7  2
     C                     PARM           P@JOK8  2
     C                     PARM           P@NAME 40
      *
     C                     MOVE *BLANK    P@NAME
      *
     C                     MOVE P@JOK1    JOK,01
     C                     MOVE P@JOK2    JOK,02
     C                     MOVE P@JOK3    JOK,03
     C                     MOVE P@JOK4    JOK,04
     C                     MOVE P@JOK5    JOK,05
     C                     MOVE P@JOK6    JOK,06
     C                     MOVE P@JOK7    JOK,07
     C                     MOVE P@JOK8    JOK,08
      *
     C                     MOVE *BLANK    W@SORT  2
     C                     MOVE *BLANK    W@GOKI  2
      *
     C           1         DO   8         @X      20
      *
     C           JOK,@X    LOKUPTB1                      88
     C           *IN88     IFEQ '1'
     C                     MOVE JOK,@X    W@SORT
     C                     END
      *
     C           *IN88     IFEQ '0'
     C           JOK,@X    LOKUPTB2                      88
     C           *IN88     IFEQ '1'
     C                     MOVE JOK,@X    W@GOKI
     C                     END
     C                     END
      *
     C                     ENDDO
      *
     C           KEY       KLIST
     C                     KFLD           A5JOKN
     C                     KFLD           A5KANB
      *
     C                     MOVE W@SORT    A5JOKN
     C                     MOVE P@KDAI    A5KANB
      *
     C           KEY       CHAINAAAPL01              77
     C           *IN77     IFEQ '0'
     C           A5SKJY    IFEQ 'D'
     C                     SETON                     77
     C                     END
     C                     END
     C           *IN77     IFEQ '0'
     C                     MOVELA5JOKM    P@NAME
     C                     END
      *
     C                     MOVE W@GOKI    A5JOKN
      *
     C           KEY       CHAINAAAPL01              77
     C           *IN77     IFEQ '0'
     C           A5SKJY    IFEQ 'D'
     C                     SETON                     77
     C                     END
     C                     END
     C           *IN77     IFEQ '0'
     C                     CAT  A5JOKM:0  P@NAME
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
