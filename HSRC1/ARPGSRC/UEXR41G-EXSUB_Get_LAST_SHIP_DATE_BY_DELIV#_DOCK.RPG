     H            Y.
     F** UEXR41G ******************************************************
     F*  EXSUB- GET LAST SHIP DATE BY DELIV# AND DOCK CODE            *
     F*  WRITTEN: JW (SRA) 2025.01.06                                 *
     F*---------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR41G'
     F*                    PARM           $NONY   4
     F*                    PARM           $DOCK   4
     F*                    PARM           $STDAT  8
     F*                    PARM           $LSDAT  8
     F*                    PARM           $EDIK   1
     F*  IN: $NONY   4A  DELIVERY CODE
     F*      $DOCK   4A  DOCK CODE  (BLANK=ALL DOCK)
     F*      $STDAT  8A  START DATE (BLANK=00000000)
     F*  OUT:$LSDAT  8A  LAST SHIPPED DATE (YYYYMMDD)
     F*     :$EDIK   1A  LAST SHIPPED ORDER TYPE E OR M
     F******************************************************
     FAB#PL1L IF  E           K        DISK
      *
     I            DS
     I                                        1   80KANOHZ
     I                                        1   40KANOYY
     I                                        5   60KANOMM
     I                                        7   80KANODD
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#L1L     SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#L1LX    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           $DOCK     IFNE ' '
     C           $DOCK     ANDNEBANUKE
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDBANOHZ    @LSDAT
     C                     MOVE BAEDIK    $EDIK
      *
     C                     ENDDO
      *
     C                     MOVEL@LSDAT    $LSDAT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=====================================================
      * INITIAL SETTING
      *=====================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $DOCK   4
     C                     PARM           $STDAT  8
     C                     PARM           $LSDAT  8        LAST SHIP DATE
     C                     PARM           $EDIK   1        ORDER TYPE
      *
     C           K#L1L     KLIST
     C                     KFLD           KANONY  40
     C                     KFLD           KANOYY  40
     C                     KFLD           KANOMM  20
     C                     KFLD           KANODD  20
      *
     C           K#L1LX    KLIST
     C                     KFLD           KANONY
      *
     C           $STDAT    IFEQ *BLANK
     C                     Z-ADD0         @STDAT  80
     C                     ELSE
     C                     MOVEL$STDAT    @STDAT
     C                     ENDIF
      *
     C                     MOVE ' '       $EDIK
     C                     MOVEL$NONY     @NONY   40
     C                     Z-ADD0         @LSDAT  80
      *SET KEY
     C                     MOVEL@NONY     KANONY
     C                     MOVEL@STDAT    KANOHZ
      *
     C                     ENDSR
