     H            Y.
     F** AB#R0170O *****************************************
     F*  ACZ ORDER PROCESSING                              *
     F*                                                    *
     F*                                                    *
     F* TCHK  10/25/12 CREATE                              *
     F******************************************************
     FACZ     IP  F     500            DISK
     FAB#WACZ O   E                    DISK
      *--------------------------------------------------------
     E                    AY        500  1
     E                    A5          5  1
     E                    A5X         5  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    AX         15  1
      *--------------------------------------------------------
     IACZ     AA  01
     I                                        1  12 SEQ
     I                                       13 500 DAT1
     I            DS
     I                                        1   8 YMD
     I                                        1   2 W20
     I                                        3   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1  15 AWPART
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C                     CLEARAB#WACZ1
     C                     Z-ADD0170      AWTOKU
     C                     Z-ADD0170      AWNONY
     C                     MOVEL'0'       AWNKOJ
     C                     MOVEL'00  '    AWNUKE
     C                     MOVEL'000000'  AWSBAN
      *
     C                     MOVEADAT1      AY,1
      * ++++++++++++
      * HEADER
      * ++++++++++++
 B0  C           *IN99     IFEQ *OFF
     C                     Z-ADD1         I       30
     C           'ORDER'   SCAN DAT1      I              10
     C  N10      'Order'   SCAN DAT1      I              10
 B1  C           *IN10     IFEQ *ON
     C                     GOTO @END
 E1  C                     END
 E0  C                     END
      * ++++++++++++
      * DETAIL
      * ++++++++++++
     C                     MOVEL*ON       *IN99
     C                     Z-ADD*ZERO     X       30
      * ------------
      * ORDER DATE
      * ------------
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
     C                     END
     C                     ENDDO
     C                     MOVEAA9        W@9     9
     C                     MOVELW@9       W@8     80
     C                     Z-ADDW@8       AWORDT
      * ------------
      * ORDER#
      * ------------
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
     C                     END
     C                     ENDDO
     C                     MOVEAA9        W@9
     C                     MOVELW@9       AWORDN
      * ------------
      * ITEM#
      * ------------
     C                     MOVEL*BLANK    A5
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELAY,X      A5,Y
     C                     END
     C                     ENDDO
     C                     MOVEL*ZERO     A5X
     C                     Z-ADD5         W       30
     C                     Z-ADD5         V       30
     C                     DO   *HIVAL
     C           W         IFLE *ZERO
     C                     LEAVE
     C                     END
     C           A5,W      IFNE *BLANK
     C                     MOVELA5,W      A5X,V
     C                     SUB  1         V
     C                     END
     C                     SUB  1         W
     C                     ENDDO
     C                     MOVEAA5X       AWITMN
      * ------------
      * PART#
      * ------------
     C                     MOVEL*BLANK    AX
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFEQ ' '
     C                     ITER
     C                     END
     C           AY,X      IFEQ '-'
     C                     ITER
     C                     END
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELAY,X      AX,Y
     C                     END
     C                     ENDDO
     C                     MOVEAAX        AWPART
      * ------------
      * QTY
      * ------------
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Y
B0   C                     DO   *HIVAL
     C                     ADD  1         X
B1   C           AY,X      IFEQ ','
     C                     LEAVE
E1   C                     END
B1   C           AY,X      IFGE '0'
B1   C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
E1   C                     END
E0   C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V
B0   C                     DO   *HIVAL
B1   C           W         IFLE *ZERO
     C                     LEAVE
E1   C                     END
B1   C           A9,W      IFNE *BLANK
     C                     MOVELA9,W      A9X,V
     C                     SUB  1         V
E1   C                     END
     C                     SUB  1         W
E0   C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVEL@9C       @9      90
     C                     Z-ADD@9        AWSRYO
      * ------------
      * QTY/BOX
      * ------------
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Y
B0   C                     DO   *HIVAL
     C                     ADD  1         X
B1   C           AY,X      IFEQ ','
     C                     LEAVE
E1   C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
     C                     END
E0   C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V
B0   C                     DO   *HIVAL
B1   C           W         IFLE *ZERO
     C                     LEAVE
E1   C                     END
B1   C           A9,W      IFNE *BLANK
     C                     MOVELA9,W      A9X,V
     C                     SUB  1         V
E1   C                     END
     C                     SUB  1         W
E0   C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSYOS
      * ------------
      * #OF BOX
      * ------------
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Y
B0   C                     DO   *HIVAL
     C                     ADD  1         X
B1   C           AY,X      IFEQ ','
     C                     LEAVE
E1   C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
     C                     END
E0   C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V
B0   C                     DO   *HIVAL
B1   C           W         IFLE *ZERO
     C                     LEAVE
E1   C                     END
B1   C           A9,W      IFNE *BLANK
     C                     MOVELA9,W      A9X,V
     C                     SUB  1         V
E1   C                     END
     C                     SUB  1         W
E0   C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AW#BOX
      * ------------
      * PART ID#
      * ------------
     C                     MOVEL*BLANK    A5
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELAY,X      A5,Y
     C                     END
     C                     ENDDO
     C                     MOVEL*ZERO     A5X
     C                     Z-ADD5         W       30
     C                     Z-ADD5         V       30
     C                     DO   *HIVAL
     C           W         IFLE *ZERO
     C                     LEAVE
     C                     END
     C           A5,W      IFNE *BLANK
     C                     MOVELA5,W      A5X,V
     C                     SUB  1         V
     C                     END
     C                     SUB  1         W
     C                     ENDDO
     C                     MOVEAA5X       @5C     5
     C                     MOVE @5C       AWZETI
      * ------------
      * LOCATION
      * ------------
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
     C                     END
     C                     ENDDO
     C                     MOVEAA9        @6C     6
     C                     MOVEL@6C       AWLOC
      * ------------
      * WRITE
      * ------------
      *
     C           AWSRYO    IFNE 0
     C                     WRITEAB#WACZ1
     C                     MOVE '1'       PID
     C                     END
      *
      *
     C           @END      TAG
