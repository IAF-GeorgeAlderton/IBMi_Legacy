     C           KEY1      KLIST
     C                     KFLD           M1KHN1
     C                     KFLD           M1KHN2
     C                     KFLD           M1KHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PKBN    1
     C                     PARM           PYM     6
     C                     PARM           PJYM    6
     C                     PARM           PCD     3
     C                     PARM           PCD1    3
     C                     PARM           PCD2    3
     C                     PARM           PCD3    3
     C                     PARM           PCD4    3
     C                     PARM           PLIST   1
     C                     MOVE PCD       WCD     31
     C                     MOVE PCD1      WCD1    31
     C                     MOVE PCD2      WCD2    31
     C                     MOVE PCD3      WCD3    31
     C                     MOVE PCD4      WCD4    31
      *
     C           PCALL     PLIST
     C                     PARM           PKBN
     C                     PARM           PYM
     C                     PARM           PJYM
     C                     PARM           PCD
     C                     PARM           PCD1
     C                     PARM           PCD2
     C                     PARM           PCD3
     C                     PARM           PCD4
     C                     PARM           PLIST
     C                     PARM           @KHIN  12
     C                     PARM           @KOTI   3
     C                     PARM           @KBMN   4
     C                     PARM           @NTKR   6
     C                     PARM           @KBMK   1
     C                     PARM           @KANB   1
      *
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C*------------------------------------------*
     C*  ..構成品かんばん　切り替えマスター..  *
     C*------------------------------------------*
     C                     SETOF                     10
     C           KEY1      CHAINAKEPL011             10
     C           *IN10     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD16        B       20
     C           1         DO   15        A
     C                     SUB  1         B
     C           SKB,B     IFEQ '3'
     C           SKB,B     OREQ 'P'
     C           SKB,B     OREQ 'Q'
      *
     C           B         ADD  1         C       20
      *
     C                     SETOF                     11
     C                     Z-ADD1         D       20
     C                     MOVE *BLANK    @KBMK
      *
     C           C         DO   15        D
     C           SKB,D     IFNE *BLANK
     C                     SETON                     11
     C           SKB,D     IFEQ 'P'
     C           SKB,D     OREQ 'Q'
     C                     MOVE 'P'       @KBMK
     C                     END
     C                     END
     C  N11                END
      *
      *
     C                     MOVE SDH,B     @KHIN
     C                     MOVE SKO,B     @KOTI
     C                     MOVE SBM,B     @KBMN
     C                     MOVE SBN,B     @NTKR
     C                     MOVE SKB,B     @KANB
      *
     C                     CALL 'ABEC05'  PCALL
      *
     C                     END
     C                     END
