     H            Y.
     F** STAR40 *********************************************
     F* INQ INTRA STOCK DATA
     F*   SAKAKI.         2020.02.14                        *
     F*******************************************************
     FSTAPL10 IF  E           K        DISK
     FSTAWP40 O   E                    DISK                      A
     FABHPL03 IF  E           K        DISK
     FADHPL03 IF  E           K        DISK
     FAAFPL03 IF  E           K        DISK
     FAAHPL03 IF  E           K        DISK
     FAAPPL03 IF  E           K        DISK
     FAANPL03 IF  E           K        DISK
     E                    KOT        15  3
     E                    TKR        15  6
     E                    BMN        15  4
     E                    MHN        15 12
     E                    KCD        15  1
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I            DS
     I                                        1  10 W@PHB
     I                                        1   4 W@PHBY
     I                                        5   6 W@PHBM
     I                                        7   8 W@PHBD
     I                                        9  10 W@PHBB
      *
     I            DS
     I                                        1  20 S1BARC
     I                                        1   1 S1IKBN
     I                                        8   8 S1PAGT
     I                                        9  11 S1PROC
     I                                       12  14 S1PAGI
      *
     I            DS
     I                                        1   6 S1ATK
     I                                        1   1 S1ATK1
     I                                        2   3 S1ATK2
     I                                        4   5 S1ATK3
     I                                        6   6 S1ATK4
      *
     I            DS
     I                                        1   6 W0ATK
     I                                        1   1 W0ATK1
     I                                        2   3 W0ATK2
     I                                        4   5 W0ATK3
     I                                        6   6 W0ATK4
      *
     I            DS
     I                                        1  12 W0MHN
     I                                        1   5 W0MHN1
     I                                        6  10 W0MHN2
     I                                       11  12 W0MHN3
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C           KEYTKR    KLIST
     C                     KFLD           W0ATK1
     C                     KFLD           W0ATK2
     C                     KFLD           W0ATK3
     C                     KFLD           W0ATK4
      *
     C           KEYA      KLIST
     C                     KFLD           K1SHN1  5
     C                     KFLD           K1SHN2  5
     C                     KFLD           K1SHN3  2
     C                     MOVEL'1'       OPNCLS
     C                     MOVELP1SHN1    K1SHN1
     C                     MOVELP1SHN2    K1SHN2
     C                     MOVELP1SHN3    K1SHN3
     C                     EXSR #SB390
     C                     Z-ADD1         A       30
     C           A         DOWLE15
     C           KOT,A     IFNE *BLANK
     C                     EXSR #SB500
     C                     ENDIF
     C                     ADD  1         A
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *ワーク
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARSTAWP401
     C                     MOVELP1SHN1    W0SHN1
     C                     MOVELP1SHN2    W0SHN2
     C                     MOVELP1SHN3    W0SHN3
     C                     MOVELTKR,A     W0ATK
     C                     MOVELKOT,A     W0PROC
     C                     MOVELBMN,A     W0MBMN
     C                     MOVELMHN,A     W0MHN
     C*
     C                     MOVELW0MHN1    K1SHN1
     C                     MOVELW0MHN2    K1SHN2
     C                     MOVELW0MHN3    K1SHN3
     C*
     C                     MOVELKCD,A     W0KCD1
     C                     Z-ADDA         W0KSEQ
     C                     EXSR #SB510
     C                     SELEC
     C           W0KCD1    WHEQ 'A'
     C                     EXSR #SBAAA
     C           W0KCD1    WHEQ 'B'
     C                     EXSR #SBBBB
     C           W0KCD1    WHEQ 'C'
     C                     EXSR #SBCCC
     C           W0KCD1    WHEQ 'E'
     C                     EXSR #SBEEE
     C           W0KCD1    WHEQ '0'
     C                     EXSR #SB000
     C           W0KCD1    WHEQ '6'
     C                     EXSR #SB666
     C                     ENDSL
     C                     WRITESTAWP401
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * ABH
      *----------------------------------------------------*
     CSR         #SBAAA    BEGSR
      *
     C           KEYTKR    SETGTABHPL03
     C           KEYTKR    REDPEABHPL03                  45
     C           *IN45     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6STHZ    IFEQ 99999999
     C                     Z-ADDM6KMAX    W0KMAX
     C                     Z-ADDM6LOTK    W0LOT
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEABHPL03                  45
     C                     ENDDO
      *
     CSR         ESBAAA    ENDSR
      *----------------------------------------------------*
      * ADH
      *----------------------------------------------------*
     CSR         #SBBBB    BEGSR
      *
     C           KEYTKR    SETGTADHPL03
     C           KEYTKR    REDPEADHPL03                  45
     C           *IN45     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           J6STHZ    IFEQ 99999999
     C                     Z-ADDJ6KMAX    W0KMAX
     C                     Z-ADDJ6LOTO    W0LOT
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEADHPL03                  45
     C                     ENDDO
      *
     CSR         ESBBBB    ENDSR
      *----------------------------------------------------*
      * AAF
      *----------------------------------------------------*
     CSR         #SBCCC    BEGSR
      *
     C           KEYTKR    SETGTAAFPL03
     C           KEYTKR    REDPEAAFPL03                  45
     C           *IN45     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3STHZ    IFEQ 99999999
     C                     Z-ADDA3KMAX    W0KMAX
     C                     Z-ADD1         W0LOT
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEAAFPL03                  45
     C                     ENDDO
      *
     CSR         ESBCCC    ENDSR
      *----------------------------------------------------*
      * AAH
      *----------------------------------------------------*
     CSR         #SBEEE    BEGSR
      *
     C           KEYTKR    SETGTAAHPL03
     C           KEYTKR    REDPEAAHPL03                  45
     C           *IN45     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6STHZ    IFEQ 99999999
     C                     Z-ADDL6KMAX    W0KMAX
     C                     Z-ADD1         W0LOT
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEAAHPL03                  45
     C                     ENDDO
      *
     CSR         ESBEEE    ENDSR
      *----------------------------------------------------*
      * AAP
      *----------------------------------------------------*
     CSR         #SB000    BEGSR
      *
     C           KEYTKR    SETGTAAPPL03
     C           KEYTKR    REDPEAAPPL03                  45
     C           *IN45     DOWEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ELSE
     C           L5STHZ    IFEQ 99999999
     C                     Z-ADDL5KMAX    W0KMAX
     C                     Z-ADD1         W0LOT
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEAAPPL03                  45
     C                     ENDDO
      *
     CSR         ESB000    ENDSR
      *----------------------------------------------------*
      * AAN
      *----------------------------------------------------*
     CSR         #SB666    BEGSR
      *
     C           KEYTKR    SETGTAANPL03
     C           KEYTKR    REDPEAANPL03                  45
     C           *IN45     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7STHZ    IFEQ 99999999
     C                     Z-ADDL7KMAX    W0KMAX
     C                     Z-ADDL7HKSU    W0LOT
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEAANPL03                  45
     C                     ENDDO
      *
     CSR         ESB666    ENDSR
      *----------------------------------------------------*
      *ワーク
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C           KEYA      SETLLSTAPL10
     C           KEYA      READESTAPL10                  24
     C           *IN24     DOWEQ'0'
     C           S1SKJY    IFEQ 'D'
     C           S1SKHZ    ANDLE*DATE
     C                     ELSE
     C*
     C**         S1PROC    IFEQ KOT,A
     C**         S1IKBN    OREQ 'I'
     C           S1ATK     IFEQ TKR,A
     C* STOCK INCLUDING TEMP
     C                     ADD  S1TUHK    W0TUHK
     C* NORMAL STOCK
     C                     SELEC
     C*   PLASTIC
     C           S1IKBN    WHEQ 'A'
     C           S1IKBN    OREQ 'R'
     C*  A888899X01050C. <- IF X IS DIGIT IT IS NORMAL KANBAN
     C           S1PAGT    IFGE '0'
     C           S1PAGT    ANDLE'9'
     C                     ADD  S1TUHK    W0TUHT
     C                     ENDIF
     C*   INTRA
     C           S1IKBN    WHGE '0'
     C           S1IKBN    ANDLE'9'
     C                     MOVE S1PAGI    W1PAGI  30
     C*  IF PAGE NO IS LESS THAN 300, IT IS NORMAL KANBAN
     C           W1PAGI    IFLT 300
     C                     ADD  S1TUHK    W0TUHT
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ADD  S1FRHK    W0FRHK
     C                     ADD  S1HMHK    W0HMHK
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C           KEYA      READESTAPL10                  24
     C                     ENDDO
      *
     C           NYUR21    PLIST
     C                     PARM           $HIN1   5
     C                     PARM           $HIN2   5
     C                     PARM           $HIN3   2
     C                     PARM           $HAYY   4
     C                     PARM           $HAMM   2
     C                     PARM           $HADD   2
     C                     PARM           $HABB   2
      *OUT
     C                     PARM           $OHKSU  5
     C                     PARM           $OSISU  5
     C                     PARM           $ONYSU  5
     C                     PARM           $OSYSU  5
     C                     PARM           $OKISU  5
     C                     PARM           $OINV   5
      *
     C                     MOVE *DATE     PDATE
     C                     MOVEL'-'       PPORM
     C                     MOVEL'0020'    PDAYS
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C           W0ATK1    IFEQ '0'
     C                     Z-ADD0         W0TUHK
     C                     Z-ADD0         W0TUHT
     C                     MOVELW0SHN1    $HIN1
     C                     MOVELW0SHN2    $HIN2
     C                     MOVELW0SHN3    $HIN3
     C                     MOVELPRDAT     W@PHB
     C                     MOVE W@PHBY    $HAYY
     C                     MOVE W@PHBM    $HAMM
     C                     MOVE W@PHBD    $HADD
     C                     MOVE '01'      $HABB
     C                     CALL 'NYUR21'  NYUR21
     C                     MOVE $OINV     W0TUHK
     C                     MOVE $OINV     W0TUHT
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *-----------------------------------*
      *工程情報                         *
      *-----------------------------------*
     CSR         #SB390    BEGSR
      *
     C                     CLEARKOT
     C                     CLEARTKR
     C                     CLEARBMN
     C                     CLEARMHN
     C                     CLEARKCD
     C                     MOVELP1SHN1    CBSHN1  5
     C                     MOVELP1SHN2    CBSHN2  5
     C                     MOVELP1SHN3    CBSHN3  2
     C                     MOVEL*DATE     INYMDB
     C                     MOVE '01'      INYMDB
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C           STATUS    IFEQ '9'
     C                     GOTO ESB390
     C                     ENDIF
      *
     C                     MOVEAPKOT      KOT
     C                     MOVEAPTKR      TKR
     C                     MOVEAPBMN      BMN
     C                     MOVEAPHBN      MHN
     C                     MOVEAPSHR      KCD
      *
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
      *
     CSR         ESB390    ENDSR
