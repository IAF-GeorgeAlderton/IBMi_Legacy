      *  ﾅﾎﾞﾓｰk]                             *
      * 構成品番から内示数量・実績数量算出 *
      * 構成品番→社内品番→数量算出       *
      *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
     C           SBKHN     BEGSR
      *
      *--------------------*
      * 工程マスター検索 *
      *--------------------*
     C           KEY3      SETLLGHCPL221
     C                     DO   *HIVAL
     C                     SETOF                     31
     C           KEY3      READEGHCPL221                 31
     C           *IN31     IFEQ '0'
      *
      *--------------------------------------*
      * 構成品番から内示数量・実績数量算出 *
      *--------------------------------------*
     C           KEYF      SETLLAEBPL021
     C                     DO   *HIVAL
     C                     SETOF                     32
     C           KEYF      READEAEBPL021                 32
     C           *IN32     IFEQ '0'
     C           AFSKJY    IFEQ 'D'
     C           AFSKHZ    ANDLE*DATE
     C                     ELSE
      *
      *----------------*
      * 内示数量算出 *
      *----------------*
     C                     Z-ADDINJYM     @NJYM
      *
     C                     SETOF                     33
     C           KEYG      CHAINABBPL211             33
     C           *IN33     IFEQ '0'
     C           U1NGKB    IFEQ 'N'
     C           U1NS,1    MULT AFSKSU    ZNJS0   90
     C           U1NS,2    MULT AFSKSU    ZNJS1   90
     C           U1NS,3    MULT AFSKSU    ZNJS2   90
     C                     ADD  ZNJS0     W0NJS0
     C                     ADD  ZNJS1     W0NJS1
     C                     ADD  ZNJS2     W0NJS2
     C                     ELSE
     C           U1SS,1    MULT AFSKSU    ZNJS0
     C           U1SS,2    MULT AFSKSU    ZNJS1
     C           U1SS,3    MULT AFSKSU    ZNJS2
     C                     ADD  ZNJS0     W0NJS0
     C                     ADD  ZNJS1     W0NJS1
     C                     ADD  ZNJS2     W0NJS2
     C                     END
     C                     END
      *
      *----------------*
      * 実績数量算出 *
      *----------------*
     C           KEYH      SETLLMBDPL121
     C                     DO   *HIVAL
     C                     SETOF                     35
     C                     Z-ADDIJIMM     D
     C           KEYH      READEMBDPL121                 35
     C           *IN35     IFEQ '0'
     C           F4SKJY    IFEQ 'D'
     C           F4SKHZ    ANDLE*DATE
     C                     ELSE
     C           F4TS,D    MULT AFSKSU    ZJISU   90
     C                     ADD  ZJISU     W0JISU
     C                     END
     C                     END
     C  N35                END
      *
     C                     END
     C                     END
     C  N32                END
      *
     C                     END
     C  N31                END
      *
     C                     ENDSR
