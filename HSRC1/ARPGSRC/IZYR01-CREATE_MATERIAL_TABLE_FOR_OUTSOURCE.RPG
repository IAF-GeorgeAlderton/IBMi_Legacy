     H            Y.                                    1
     H** IZBR21 *******************************
     H* CREATE MATERIAL TABLE FOR OUTSOURCE   *
     H*     Y.MAEDA           2018.01.16      *
     H*****************************************
     FIZAPL02 IF  E           K        DISK
     FIZBPL02 IF  E           K        DISK
     FIZBPL20 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FIZYWP01 O   F    1024            DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIME1
     I                                        7  140WDATE
      *
     I            DS
     I                                        1   80ZCUKHZ
     I                                        1   40ZCUKYY
     I                                        5   60ZCUKMM
     I                                        7   80ZCUKDD
      *
     I            DS
     I                                        1   80ZCSTHZ
     I                                        1   40ZCSTYY
     I                                        5   60ZCSTMM
     I                                        7   80ZCSTDD
      *
     I            DS
     I                                        1   80ZDUKHZ
     I                                        1   40ZDUKYY
     I                                        5   60ZDUKMM
     I                                        7   80ZDUKDD
      *
     I            DS
     I                                        1   80ZDSTHZ
     I                                        1   40ZDSTYY
     I                                        5   60ZDSTMM
     I                                        7   80ZDSTDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PIKAKE  4
      *
     C                     TIME           WTIME
     C                     MOVE PIKAKE    PPKAKE  40
      *--------------------------------------------------
      *FINISHED MATERIAL KANBAN MASTER
     C                     SETOF                     81
     C           *LOVAL    SETLLIZAPL02
     C                     DO   *HIVAL
     C                     READ IZAPL02                  81
     C   81                LEAVE
     C           ZCSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           WDATE     IFLT ZCUKHZ
     C           WDATE     ORGE ZCSTHZ
     C                     ITER
     C                     END
     C           ZCKAKE    IFNE PPKAKE
     C                     ITER
     C                     END
      * DATA SET
     C                     MOVEL*BLANK    O@SMEI 15
     C                     SETOF                     92
     C           ZCKAKE    CHAINFGBPL01              92
     C           *IN92     IFEQ '0'
     C                     MOVELB2SMEI    O@SMEI
     C                     END
     C                     MOVELZCZAIS    O@ZAIS 15
     C                     Z-ADDZCZAIK    O@ZAIK  52
     C                     MOVEL*BLANK    O@RFTP 10
     C                     MOVEL*BLANK    O@WFTP 10
     C                     MOVEL*BLANK    O@RFCT 15
     C                     SETOF                     92
     C           ZCKOJE    CHAINFGBPL01              92
     C           *IN92     IFEQ '0'
     C                     MOVELB2SMEI    O@RFCT
     C                     END
     C                     MOVELZCUKIR    O@GATE  2
     C                     Z-ADDZCMSSU    O@CYCL  20
     C                     Z-ADDZCSLTM    O@LDTM  20
     C                     MOVELZCKIBN    O@KIBN  5
     C                     MOVEL*BLANK    O@CLCD  1
     C                     SETOF                     92
     C           ZCZAIS    CHAINIZBPL20              92
     C           *IN92     IFEQ '0'
     C                     MOVELZHZRCD    O@CLCD
     C                     END
     C                     MOVELZCZIRO    O@CLOR 20
     C                     MOVEL*BLANK    O@DRC1 16
     C                     MOVEL*BLANK    O@DRC2 16
     C                     Z-ADDWDATE     O@ODDT  80
     C                     MOVELZCKNO2    O@KNO2  1
     C                     MOVELZCKNO3    O@KNO3  4
     C                     MOVELZCADR1    O@ADR1  1
     C                     MOVELZCADR2    O@ADR2  2
     C                     MOVELZCADR3    O@ADR3  2
     C                     MOVELZCADR4    O@ADR4  1
      *
     C                     EXCPT@DT
      *
     C                     ENDDO
      *--------------------------------------------------
      *ROD MATERIAL KANBAN MASTER
     C                     SETOF                     81
     C           *LOVAL    SETLLIZBPL02
     C                     DO   *HIVAL
     C                     READ IZBPL02                  81
     C   81                LEAVE
     C           ZDSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           WDATE     IFLT ZDUKHZ
     C           WDATE     ORGE ZDSTHZ
     C                     ITER
     C                     END
     C           ZDSIRE    IFNE PPKAKE
     C                     ITER
     C                     END
      * DATA SET
     C                     MOVEL*BLANK    O@SMEI 15
     C                     SETOF                     92
     C           ZDSIRE    CHAINFGBPL01              92
     C           *IN92     IFEQ '0'
     C                     MOVELB2SMEI    O@SMEI
     C                     END
     C                     MOVELZDZAIS    O@ZAIS 15
     C                     Z-ADDZDZAIK    O@ZAIK  52
     C                     MOVEL*BLANK    O@RFTP 10
     C                     MOVEL*BLANK    O@WFTP 10
     C                     MOVEL*BLANK    O@RFCT 15
     C                     SETOF                     92
     C           ZDKOJE    CHAINFGBPL01              92
     C           *IN92     IFEQ '0'
     C                     MOVELB2SMEI    O@RFCT
     C                     END
     C                     MOVELZDUKIR    O@GATE  2
     C                     Z-ADD0         O@CYCL  20
     C                     Z-ADDZDSLTM    O@LDTM  20
     C                     MOVEL*BLANK    O@KIBN  5
     C                     MOVEL*BLANK    O@CLCD  1
     C                     SETOF                     92
     C           ZDZAIS    CHAINIZBPL20              92
     C           *IN92     IFEQ '0'
     C                     MOVELZHZRCD    O@CLCD
     C                     END
     C                     MOVELZDZIRO    O@CLOR 20
     C                     MOVEL*BLANK    O@DRC1 16
     C                     MOVEL*BLANK    O@DRC2 16
     C                     Z-ADDWDATE     O@ODDT  80
     C                     MOVELZDKNO2    O@KNO2  1
     C                     MOVELZDKNO3    O@KNO3  4
     C                     MOVELZDADR1    O@ADR1  1
     C                     MOVELZDADR2    O@ADR2  2
     C                     MOVELZDADR3    O@ADR3  2
     C                     MOVELZDADR4    O@ADR4  1
      *
     C                     EXCPT@DT
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OIZYWP01 E                @DT
      *RETRIEVAL LOCATION CODE
     O                         O@SMEI
      *MATERIAL
     O                         O@ZAIS
      *WIRE DIAMETER
     O                         O@ZAIK       '0   .  '
      *ROD FORM TYPE
     O                         O@RFTP
      *WIRE FORM TYPE
     O                         O@WFTP
      *RECEIVING FACTORY
     O                         O@RFCT
      *RECEIVING GATE NO
     O                         O@GATE
      *DELIVERY CYCLE TIME
     O                         O@CYCL
      *PRODUCTION LEAD TIME
     O                         O@LDTM
      *WIRE DRAWING MACHINE NO
     O                         O@KIBN
      *MATERIAL COLOR CODE
     O                         O@CLCD
      *MATERIAL COLOR
     O                         O@CLOR
      *DRAWING CONDITION 1
     O                         O@DRC1
      *DRAWING CONDITION 2
     O                         O@DRC2
      *ORDER DATE
     O                         O@ODDT
      *NUMBER TYPE
     O                         O@KNO2
      *WIRE IDENTIFICATION NUMBER
     O                         O@KNO3
      *LOCATION CODE 1
     O                         O@ADR1
      *LOCATION CODE 2
     O                         O@ADR2
      *LOCATION CODE 3
     O                         O@ADR3
      *LOCATION CODE 4
     O                         O@ADR4
