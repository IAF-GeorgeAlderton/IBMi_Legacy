     C           *ENTRY    PLIST
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1CIBI  20
     C                     PARM           P9ALL   50
     C                     PARM           P9HND   50
     C                     PARM           P9RNJ   50
     C                     PARM           P9SRYO 120
     C                     PARM           P9LIMD 120
     C                     PARM           P9LIMB 120
     C                     PARM           P9RTCD  1
      *
     C                     TIME           WDATE
     C                     MOVEL'1'       OPNCLS
     C                     Z-ADD0         WKAP
     C                     Z-ADDP1APHZ    WKAPHZ
     C                     Z-ADDP1APBN    WKAPBN
     C                     Z-ADD0         P9ALL
     C                     Z-ADD0         P9HND
     C                     Z-ADD0         P9RNJ
     C                     Z-ADD0         P9SRYO
     C                     Z-ADD0         P9LIMD
     C                     Z-ADD0         P9LIMB
     C                     MOVEL'0'       P9RTCD
      *直（３直とする）
     C                     Z-ADD3         TYOKU   30
      *２便あたりの上限を求めるための母数
     C           P1CIBI    DIV  2         WK2BIN  30H
     C           WK2BIN    IFEQ 0
     C                     Z-ADD6         WK2BIN
     C                     ENDIF
      *
     C                     EXSR #SB780
     C                     EXSR #SB790
      *
     C           KEYSHN    KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C           KEYSHN    CHAINAGAPL411             22
     C           *IN22     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     EXSR #SB400
     C                     ENDIF
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *                                   *
      *-----------------------------------*
     CSR         #SB400    BEGSR
      *便数
     C                     Z-ADDP1CIBI    WKBINS  20
     C                     MOVEL'1'       WKFL1   1        今回発行できる
      *直当り便数
     C                     Z-ADD0         WKBINT  20
     C           WKBINS    DIV  TYOKU     WKBINT
      *指定便有無
     C                     Z-ADD1         X
     C                     Z-ADD0         SITEBN  20
     C*
S1   C           X         DOWLE24
     C           CBTR,X    IFNE 0
     C                     ADD  1         SITEBN
     C                     ENDIF
     C                     ADD  1         X
E1   C                     ENDDO
     C*
      *指定便があるときは指定便の数
     C           SITEBN    IFNE 0
     C                     Z-ADDSITEBN    WKBINS
     C                     EXSR #SB401
     C                     ENDIF
      *
     C                     CLEAROKT
     C                     CLEAROTK
     C                     CLEAROSY
     C                     MOVE WKAP      INYMDB
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C           STATUS    IFEQ '9'
     C                     GOTO ESB400
     C                     ENDIF
      *
     C                     MOVEAPKOT      OKT
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSY
      *
     C                     Z-ADD0         IDX1    30
     C                     Z-ADD15        X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWGE1
     C           IDX1      ANDEQ0
     C           OSY,X     IFEQ CBKDAI
     C                     Z-ADDX         IDX1
     C                     ENDIF
     C                     SUB  1         X
     C                     ENDDO
      *ロット
     C                     EXSR #SB410
      *設定数
     C                     Z-ADD0         WKGEKN 120
     C                     Z-ADD0         P9GEKN 120
     C                     CALL 'ADKR96'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P9GEKN 120
     C                     Z-ADDP9GEKN    WKGEKN
      *係数
      *品番別があればそちらを使う
     C           KEYSHN    CHAINADKPP451             22
     C           *IN22     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     MULT CNKSU     WKGEKN
     C                     ELSE
     C                     MULT WKKSU     WKGEKN
     C                     ENDIF
      *
     C           KEYSHN    CHAINFCEPL011             22
     C           *IN22     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C***        *IN22     IFEQ '0'
     C***                  Z-ADDA2GEKN    WKGEKN
     C***                  ENDIF
      *日当り箱数
     C                     Z-ADD0         WKSETD 122
     C           CBSYUY    IFNE 0
     C           WKGEKN    DIV  CBSYUY    WKSETD    H
     C           WKSETD    DIV  20        WKSETD    H
     C                     ENDIF
      *日当り上限（ロットの整数倍）
     C                     Z-ADD0         JOGEND  50
     C           @@LOT     IFNE 0
     C           WKSETD    DIV  @@LOT     WKSYOB  30
     C                     MVR            WKAMRB  52
     C           WKAMRB    IFNE 0
     C                     ADD  1         WKSYOB
     C                     ENDIF
      *最低１ロット分
     C           WKSYOB    IFEQ 0
     C                     Z-ADD1         WKSYOB
     C                     ENDIF
     C           WKSYOB    MULT @@LOT     JOGEND
     C                     ENDIF
      *便当り箱数
     C                     Z-ADD0         WKSETB 122
     C           WKBINS    IFNE 0
     C           WKSETD    DIV  WKBINS    WKSETB    H
     C                     ENDIF
      *便当り上限（ロットの整数倍）
     C                     Z-ADD0         JOGENB  30
     C           @@LOT     IFNE 0
     C           WKSETB    DIV  @@LOT     WKSYOB  30
     C                     MVR            WKAMRB  52
     C           WKAMRB    IFNE 0
     C                     ADD  1         WKSYOB
     C                     ENDIF
      *最低１ロット分
     C           WKSYOB    IFEQ 0
     C                     Z-ADD1         WKSYOB
     C                     ENDIF
     C           WKSYOB    MULT @@LOT     JOGENB
     C                     ENDIF
      *直当り上限（日当り上限÷直数）
      ***************
      *直当り箱数
     C                     Z-ADD0         WKSETT 122
     C           WKSETD    DIV  TYOKU     WKSETT    H
      *直当り上限（ロットの整数倍）
     C                     Z-ADD0         JOGENT  30
     C           @@LOT     IFNE 0
     C           WKSETT    DIV  @@LOT     WKSYOB  30
     C                     MVR            WKAMRB  52
     C           WKAMRB    IFNE 0
     C                     ADD  1         WKSYOB
     C                     ENDIF
      *最低１ロット分
     C           WKSYOB    IFEQ 0
     C                     Z-ADD1         WKSYOB
     C                     ENDIF
     C           WKSYOB    MULT @@LOT     JOGENT
     C                     ENDIF
      ***************
      *２便当り上限
      *２便当り箱数
     C                     Z-ADD0         WKSET2 122
     C           WKSETD    DIV  WK2BIN    WKSET2    H
      *直当り上限（ロットの整数倍）
     C                     Z-ADD0         JOGEN2  30
     C           @@LOT     IFNE 0
     C           WKSET2    DIV  @@LOT     WKSYOB  30
     C                     MVR            WKAMRB  52
     C           WKAMRB    IFNE 0
     C                     ADD  1         WKSYOB
     C                     ENDIF
      *最低１ロット分
     C           WKSYOB    IFEQ 0
     C                     Z-ADD1         WKSYOB
     C                     ENDIF
     C           WKSYOB    MULT @@LOT     JOGEN2
     C                     ENDIF
      ***************
      *過去１日の総発行枚数
     C                     EXSR #SB405
      *----------------------
      * 2020.03.05仕様変更
      *----------------------
     C                     Z-ADD0         Q9MAIS
     C                     CALL 'ADKR62'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1CIBI  20
     C                     PARM           Q9MAIS  50
     C                     Z-ADDQ9MAIS    WKMAIS
     C           WKMAIS    IFGT JOGENB
     C                     Z-ADDJOGENB    WKMAIS
     C                     ENDIF
     C           WKMAIS    IFEQ 0
     C                     MOVEL'1'       P9RTCD
     C                     Z-ADD0         P9SRYO
     C           JOGEND    MULT CBSYUY    P9LIMD
     C           JOGENB    MULT CBSYUY    P9LIMB
     C           WKFL1     IFEQ '0'
     C                     Z-ADD0         P9SRYO
     C                     Z-ADD0         P9LIMB
     C                     ENDIF
     C                     GOTO ESB400
     C                     ENDIF
      *----------------------
      *日当り上限と比較
      *上限以上のとき、上限ゼロを返す
      *上限未満のとき、直当り上限で計算
      *----------------------
     C*****      WKMAIS    IFGE JOGEND
     C*****                MOVEL'1'       P9RTCD
     C*****                Z-ADD0         P9SRYO
     C*****      JOGEND    MULT CBSYUY    P9LIMD
     C*****      JOGENB    MULT CBSYUY    P9LIMB
     C*****      WKFL1     IFEQ '0'
     C*****                Z-ADD0         P9SRYO
     C*****                Z-ADD0         P9LIMB
     C*****                ENDIF
     C*****                GOTO ESB400
     C*****                ENDIF
      ***************
      *２便当り上限で計算
      *過去１便の総発行枚数
     C***********          EXSR #SB406
      *----------------------
      *２便当り上限と比較
      *上限以上のとき、上限ゼロを返す
      *上限未満のとき、便当り上限ロット×収容数を返す
      *ただし、指定便がある場合に今回便が指定便にないときは
      *上限ゼロを返す
      *----------------------
      * 2019.11.25
      *２便当りの上限カットやめる
     C****       WKMAIS    IFGE JOGEN2
     C****                 MOVEL'2'       P9RTCD
     C****                 Z-ADD0         P9SRYO
     C****                 ELSE
     C****       JOGENB    MULT CBSYUY    P9SRYO
     C****                 ENDIF
     C*********  JOGENB    MULT CBSYUY    P9SRYO
     C*******    Q9MAIS    MULT CBSYUY    P9SRYO
      *
     C           WKMAIS    MULT CBSYUY    P9SRYO
      *
     C           JOGEND    MULT CBSYUY    P9LIMD
     C           JOGENB    MULT CBSYUY    P9LIMB
      *
     C           WKFL1     IFEQ '0'
     C                     Z-ADD0         P9SRYO
     C                     Z-ADD0         P9LIMB
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *過去１日の発行
      *----------------------------------------------------*
     CSR         #SB405    BEGSR
      *前日日付と現在の便＋１を渡す
     C                     Z-ADDWKZNHZ    P2APHZ
     C**                   Z-ADDP1APBN    P2APBN
     C           P1APBN    ADD  1         P2APBN
     C           P2APBN    IFGT WKCIBI
     C                     Z-ADDP1APHZ    P2APHZ
     C                     Z-ADD1         P2APBN
     C                     ENDIF
     C                     Z-ADD0         P9MAIS
     C                     CALL 'ADKR9D'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P9MAIS  50
     C                     Z-ADDP9MAIS    P9ALL
      *過去１日の直接入力発行枚数
      *前日日付と現在の便＋１を渡す
     C                     Z-ADDWKZNHZ    P2APHZ
     C**                   Z-ADDP1APBN    P2APBN
     C           P1APBN    ADD  1         P2APBN
     C           P2APBN    IFGT WKCIBI
     C                     Z-ADDP1APHZ    P2APHZ
     C                     Z-ADD1         P2APBN
     C                     ENDIF
     C                     MOVEL'HN'      P1TYPE
     C                     Z-ADD0         P8MAIS
     C                     CALL 'ADKR9C'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1TYPE  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P8MAIS  50
     C                     Z-ADDP8MAIS    P9HND
      *過去１日の臨時分発行枚数
      *前日日付と現在の便＋１を渡す
     C                     MOVEL'RN'      P1TYPE
     C                     Z-ADD0         P8MAIS
     C                     CALL 'ADKR9C'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1TYPE  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P8MAIS  50
     C                     Z-ADDP8MAIS    P9RNJ
      *総発行枚数から直接入力・臨時分を引く
     C                     Z-ADD0         WKMAIS
     C           P9MAIS    SUB  P9HND     WKMAIS  50
     C                     SUB  P9RNJ     WKMAIS  50
     C           WKMAIS    IFLT 0
     C                     Z-ADD0         WKMAIS
     C                     ENDIF
      *
     CSR         ESB405    ENDSR
      *----------------------------------------------------*
      *過去１便の発行
      *----------------------------------------------------*
     CSR         #SB406    BEGSR
      *当日日付と現在の便ー１を渡す
     C                     Z-ADDP1APHZ    P2APHZ
     C**                   Z-ADDP1APBN    P2APBN
     C           P1APBN    SUB  1         P2APBN
     C           P2APBN    IFLE 0
     C                     Z-ADDWKZNHZ    P2APHZ
     C                     ADD  WKCIBI    P2APBN
     C                     ENDIF
     C                     Z-ADD0         P9MAIS
     C                     CALL 'ADKR9D'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P9MAIS  50
     C                     Z-ADDP9MAIS    P7ALL   50
      *過去１便の直接入力発行枚数
      *当日日付と現在の便ー１を渡す
     C                     Z-ADDP1APHZ    P2APHZ
     C**                   Z-ADDP1APBN    P2APBN
     C           P1APBN    SUB  1         P2APBN
     C           P2APBN    IFLE 0
     C                     Z-ADDWKZNHZ    P2APHZ
     C                     ADD  WKCIBI    P2APBN
     C                     ENDIF
     C                     MOVEL'HN'      P1TYPE
     C                     Z-ADD0         P8MAIS
     C                     CALL 'ADKR9C'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1TYPE  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P8MAIS  50
     C                     Z-ADDP8MAIS    P7HND   50
      *過去１便の直接入力発行枚数
      *当日日付と現在の便ー１を渡す
     C                     MOVEL'RN'      P1TYPE
     C                     Z-ADD0         P8MAIS
     C                     CALL 'ADKR9C'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1TYPE  2
     C                     PARM           P2APHZ  80
     C                     PARM           P2APBN  20
     C                     PARM           P8MAIS  50
     C                     Z-ADDP8MAIS    P7RNJ   50
      *総発行枚数から直接入力・臨時分を引く
     C                     Z-ADD0         WKMAIS
     C           P9MAIS    SUB  P7HND     WKMAIS  50
     C                     SUB  P7RNJ     WKMAIS  50
     C           WKMAIS    IFLT 0
     C                     Z-ADD0         WKMAIS
     C                     ENDIF
      *
     CSR         ESB406    ENDSR
      *----------------------------------------------------*
      *指定便が今回発行便か
      *----------------------------------------------------*
     CSR         #SB401    BEGSR
      *
     C                     MOVEL'0'       WKFL1   1
     C           P1APBN    LOKUPCBTR                     79
     C           *IN79     IFEQ '1'
     C                     MOVEL'1'       WKFL1   1
     C                     ENDIF
      *
     CSR         ESB401    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C                     Z-ADD0         WKLOT1  30
     C                     Z-ADD0         WKLOT2  30
      *自工程のロット
     C                     Z-ADDCBBARL    WKLOT1  30
     C           WKLOT1    IFEQ 0
     C                     Z-ADD1         WKLOT1
     C                     ENDIF
      *前工程のロット
     C                     Z-ADD0         IDX2    30
     C                     Z-ADD0         X
     C           IDX1      SUB  1         X
     C           X         DOWGE1
     C           IDX2      ANDEQ0
     C           OTK,X     IFNE '------'
     C           OTK,X     ANDNE'++++++'
     C                     Z-ADDX         IDX2
     C                     MOVELOTK,X     WKTKR
     C                     MOVELOSY,X     WKSY    1
     C                     EXSR #SB490
     C                     Z-ADDWKLOT     WKLOT2  30
     C                     ENDIF
     C                     SUB  1         X
     C                     ENDDO
      *自工程が前工程ロット以上の場合は自工程ロット
      *自工程が前工程より小さい場合は前工程ロット
      *（前工程ロット以上の自工程ロットの整数倍）
     C                     Z-ADD0         @@LOT   30
     C                     Z-ADDWKLOT1    @@LOT
     C*****      WKLOT1    IFGE WKLOT2
     C*****                Z-ADDWKLOT1    @@LOT
     C*****                ELSE
     C*****      WKLOT2    DIV  WKLOT1    WKSYO   30
     C*****                MVR            WKAMR   30
     C*****      WKAMR     IFNE 0
     C*****                ADD  1         WKSYO
     C*****                ENDIF
     C*****      WKLOT1    MULT WKSYO     @@LOT
     C*****                ENDIF
      *
     CSR         ESB410    ENDSR
      *----------------------------------------------------*
      *ロット                                            *
      *----------------------------------------------------*
     CSR         #SB490    BEGSR
      *
     C           KEYT      KLIST
     C                     KFLD           WKTKR1
     C                     KFLD           WKTKR2
     C                     KFLD           WKTKR3
     C                     KFLD           WKTKR4
      *
     C                     Z-ADD0         WKLOT   30
     C                     SELEC
      *工程内
     C           WKSY      WHEQ 'A'
     C           KEYT      SETGTABHPL031
     C           KEYT      REDPEABHPL031                 83
     C           *IN83     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6UK      IFLE WKAP
     C           M6ST      ANDGTWKAP
     C                     Z-ADDM6LOTK    WKLOT
     C                     ENDIF
     C                     ENDIF
     C           KEYT      REDPEABHPL031                 83
     C                     ENDDO
      *焼入れ
     C           WKSY      WHEQ 'B'
     C           KEYT      SETGTADHPL031
     C           KEYT      REDPEADHPL031                 83
     C           *IN83     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           J6UK      IFLE WKAP
     C           J6ST      ANDGTWKAP
     C                     Z-ADDJ6LOTO    WKLOT
     C                     ENDIF
     C                     ENDIF
     C           KEYT      REDPEADHPL031                 83
     C                     ENDDO
      *めっき
     C           WKSY      WHEQ 'C'
     C           KEYT      SETGTAAFPL031
     C           KEYT      REDPEAAFPL031                 83
