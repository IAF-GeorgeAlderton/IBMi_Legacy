     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3UK      IFLE WKAP
     C           A3ST      ANDGTWKAP
     C                     Z-ADDA3BARA    WKLOT
     C                     ENDIF
     C                     ENDIF
     C           KEYT      REDPEAAFPL031                 83
     C                     ENDDO
     C                     ENDSL
      *
     CSR         ESB490    ENDSR
