     H            Y.
     F** EJRR01 *******************************************************
     F* R856 FROM SUPPLIER RECEIVING PROCESS                          *
     F* T.SAKAKI                    2016.10.13                        *
     F*****************************************************************
     FEJRWP01 IF  F     312            DISK
      * B2B PROGRRAM M/F
     FEJKPL13 IF  E           K        DISK
      * DETAIL CODE M/F
     FFGBPL01 IF  E           K        DISK
      *
     FAFDPP60 O   E                    DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TB1        10  1
     E                    TB2        10  1
      *
     IEJRWP01 AA  01
     I                                        1 312 A#DATA
     I**  HEADER
     I                                        1   1 @KUBN
     I                                        2   7 H#RCID
     I                                        8  19 H#PTID
     I                                       20  22 H#DKBN
     I                                       34  44 H#ASNN
     I                                       45  50 H#ASND
     I                                       51  54 H#ASNT
     I                                       55  57 H#DQL1
     I                                       58  63 H#HSDT
     I                                       64  67 H#HSTM
     I                                       87  96 H#GRWG
     I                                       97  98 H#GRME
     I                                      104 113 H#ANWG
     I                                      114 115 H#ANME
     I                                      116 120 H#PCCD
     I                                      121 127 H#LQTY
     I                                      132 135 H#SCAC
     I                                      136 137 H#TPMT
     I                                      138 139 H#LCQ1
     I                                      140 144 H#LQID
     I                                      147 150 H#EQIN
     I                                      151 157 H#EQNO
     I                                      160 189 H#PKNO
     I                                      192 221 H#AWNO
     I                                      224 253 H#FRNO
     I                                      256 285 H#BMNO
     I                                      290 294 H#SFID
     I                                      299 303 H#STID
     I                                      308 312 H#SUID
     I**  DETAIL
     I                                        2   7 D#RCID
     I                                       34  35 D#PSIQ
     I                                       24  53 D#PART
     I                                       54  60 D#SQTY
     I                                       61  62 D#SQTM
     I                                       75  83 D#CQTY
     I                                       99 108 D#PONO
     I                                      109 113 D#NOLD
     I                                      114 120 D#NOUS
     I                                      121 125 D#TOPC
     I                                      126 127 D#RIQL
     I                                      128 157 D#SERN
     I                                      158 160 D#DQL2
     I                                      161 166 D#DSDT
     I                                      167 170 D#DSTM
     I                                      171 172 D#SMOP
     I                                      173 178 D#TTCD
     I                                      179 180 D#LCQL
     I                                      181 182 D#CUQL
     I                                      183 185 D#CUCD
     I                                      211 219 D#CAMT
     I**
      * SYSTEM TIME & DATE
     I            DS
     I                                        1  140WTMDT
     I                                        1   60WTIME
     I                                        1   20WTIHH
     I                                        3   40WTIMM
     I                                        5   60WTISS
     I                                        7  140WDATE
     I                                        9  140WDAT6
     I                                        7  100WDAY4
     I                                        9  100WDAYY
     I                                       11  120WDAMM
     I                                       13  140WDADD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
      *   KEY LIST
      *================================================================
     C           KEY1      KLIST
     C                     KFLD           K1PTID 12
     C                     KFLD           K1RVSN  1
     C                     KFLD           K1DKBN  3
      *================================================================
      *   ENTRY LIST
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           SNM    15
     C                     PARM           PD      1
     C                     MOVE *BLANK    SNM
     C                     MOVE *BLANK    PD
      *================================================================
      *  MAIN
      *================================================================
     C                     TIME           WTMDT
     C                     SETON                     OF
     C                     MOVEL'R'       K1RVSN
     C*-------------------------
     C           1         SETLLEJRWP01
     C*-------------------------
     C                     DO   *HIVAL
     C                     READ EJRWP01                  90
     C   90                LEAVE
     C*
     C                     SELEC
     C* HEADER
     C           @KUBN     WHEQ 'H'
     C                     EXSR #HDSET
     C* DETAIL
     C           @KUBN     WHEQ 'D'
     C                     EXSR #DTSET
     C*
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *  GET HEADER
      *================================================================
     CSR         #HDSET    BEGSR
     C*
     C                     MOVELH#PTID    K1PTID
     C                     MOVELH#DKBN    K1DKBN
     C*
     C                     SETOF                     81
     C           KEY1      CHAINEJKPL131             81
     C           *IN81     IFEQ '0'
     C           DPSKJY    IFEQ 'D'
     C           DPSKHZ    ANDLEWDATE
     C                     ELSE
     C                     MOVELDPNONY    WSUPP   4        SUPPLIER
     C                     ENDIF
     C                     ENDIF
     C* GET SUPPLIER NAME
     C                     MOVE WSUPP     KSUPP   40
     C                     SETOF                     82
     C           KSUPP     CHAINFGBPL011             82
     C           *IN82     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLEWDATE
     C                     ELSE
     C                     MOVELB2SMEI    SNM
     C                     ENDIF
     C                     ENDIF
     C*
     C* CLEAR
     C                     CLEARAFDPP601
     C*
     C                     MOVELW#PGM     A6KOPG
     C                     MOVELWSUPP     A6SUPP
     C*
     C                     MOVELH#ASNN    A6ASNN
     C*
     C                     MOVELH#ASND    WKDTA6  6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    A6ASND
     C*
     C                     MOVELH#ASNT    A6ASNT
     C                     MOVELH#DQL1    A6DQL1
     C*
     C                     MOVELH#HSDT    WKDTA6  6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    A6HSDT
     C*
     C                     MOVELH#HSTM    A6HSTM
     C* GROSS WEIGHT
     C                     MOVEAH#GRWG    TB1
     C                     EXSR #CONL
     C                     Z-ADD@NUM      A6GRWG
     C*
     C                     MOVELH#GRME    A6GRME
     C* ACTUAL NET WEIGHT
     C                     MOVEAH#ANWG    TB1
     C                     EXSR #CONL
     C                     Z-ADD@NUM      A6ANWG
     C*
     C                     MOVELH#ANME    A6ANME
     C                     MOVELH#PCCD    A6PCCD
     C* LADING QTY.
     C                     MOVEAH#LQTY    TB1
     C                     EXSR #CONL
     C                     Z-ADD@NUM      A6LQTY
     C*
     C                     MOVELH#SCAC    A6SCAC
     C                     MOVELH#TPMT    A6TPMT
     C                     MOVELH#LCQ1    A6LCQ1
     C                     MOVELH#LQID    A6LQID
     C*
     C                     MOVELH#EQNO    A6EQNO
     C                     MOVELH#PKNO    A6PKNO
     C                     MOVELH#AWNO    A6AWNO
     C                     MOVELH#FRNO    A6FRNO
     C                     MOVELH#BMNO    A6BMNO
     C                     MOVELH#SFID    A6SFID
     C                     MOVELH#STID    A6STID
     C                     MOVELH#SUID    A6SUID
     C*
     CSR         EHDSET    ENDSR
      *================================================================
      *  GET DETAIL
      *================================================================
     CSR         #DTSET    BEGSR
      *
     C                     Z-ADDWDATE     A6KODT
     C                     Z-ADDWTIME     A6KHMS
      *
     C                     MOVELD#PART    A6PART
     C* SHIPPED QTY
     C                     MOVEAD#SQTY    TB1
     C                     EXSR #CONL
     C                     Z-ADD@NUM      A6SQTY
     C*
     C                     MOVELD#SQTM    A6SQTM
     C* CUMLATIVE QTY
     C                     MOVEAD#CQTY    TB1
     C                     EXSR #CONL
     C                     Z-ADD@NUM      A6CQTY
     C*
     C                     MOVELD#PONO    A6PONO
     C                     MOVELD#NOLD    A6NOLD
     C                     MOVELD#NOUS    A6NOUS
     C                     MOVELD#TOPC    A6TOPC
     C                     MOVELD#RIQL    A6RIQL
     C                     MOVELD#SERN    A6SERN
     C                     MOVELD#DQL2    A6DQL2
     C*
     C                     MOVELD#DSDT    WKDTA6  6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    A6DSDT
     C*
     C                     MOVELD#DSTM    A6DSTM
     C                     MOVELD#SMOP    A6SMOP
     C                     MOVELD#TTCD    A6TTCD
     C                     MOVELD#LCQL    A6LCQL
     C                     MOVELD#CUQL    A6CUQL
     C                     MOVELD#CUCD    A6CUCD
     C                     MOVELD#CAMT    A6CAMT
      *
     C* WRITE
     C                     WRITEAFDPP601
     C* WRITE QPRINT
     C   OF                EXCPT#HED1
     C   OF                EXCPT#HED2
     C   OF                SETOF                     OF
     C                     EXCPT#DTL1
     C                     MOVE '1'       PD
      *
     CSR         EDTSET    ENDSR
      *================================================================
      *  DATE 6 TO 8 DIGITS
      *================================================================
     CSR         #DATE8    BEGSR
      *
     C                     MOVEL*BLANK    WKDTA8  8
      *
     C           WKDTA6    IFEQ *BLANK
     C                     ELSE
     C                     CALL 'DATR00'
     C                     PARM           WKDTA6
     C                     PARM           WKDTA8
     C                     ENDIF
      *
     CSR         EDATE8    ENDSR
      *================================================================
      *  NUMERIC
      *================================================================
     CSR         #CONL     BEGSR
      *
     C                     Z-ADD0         @NUM   100
     C                     Z-ADD10        IX      20
     C                     Z-ADD10        IY      20
     C                     MOVEA*ALL'0'   TB2
      *
     C           IX        DOUEQ0
     C*
     C           TB1,IX    IFNE *BLANK
     C                     MOVE TB1,IX    TB2,IY
     C                     SUB  1         IY
     C                     ENDIF
     C*
     C                     SUB  1         IX
     C*
     C                     ENDDO
     C*
     C                     MOVEATB2       LTR10  10
     C                     MOVELLTR10     @NUM
     C*
     CSR         ECONL     ENDSR
     C********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
     O                                    8 'EJRR01'
     O                                   32 'ASN(856) FROM'
     O                         WSUPP     38
     O                         SNM       55
     O                                   62 'REPORT'
     O                                  104 'TIME'
     O                         WTIME    113 '  :  :  '
     O                                  119 'PAGE'
     O                         PAGE  Z  123
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                  104 'DATE'
     O                         WDAT6 Y  113
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                  132 '*'
     O*
     O        E 1              #HED2
     O       OR        OF
     O                                    5 'ASN #'
     O                                   21 'SHIPPED DATE'
     O                                   37 'SCAC'
     O                                   47 'B.O.L.#'
     O                                   56 'PART #'
     O                                   94 'SHIPPED QTY.'
     O                                  106 'NET WGT.'
     O                                  125 'GROSS WGT.'
     O*
     O        E 1              #DTL1
     O                         A6ASNN    11
     O                         A6HSDT    19 '    /  /  '
     O                                   21 '-'
     O                         A6HSTM    27 '0 :  '
     O                         A6SCAC    37
     O                         A6EQNO    47
     O                         A6PART    80
     O                         A6SQTY2   91
     O                         A6SQTM    94
     O                         A6ANWG2  109
     O                         A6ANME   112
     O                         A6GRWG2  127
     O                         A6GRME   130
**
