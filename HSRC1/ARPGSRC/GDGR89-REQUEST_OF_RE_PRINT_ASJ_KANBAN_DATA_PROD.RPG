     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@SYS   8
     C                     MOVELP@SYS     D1ODKG
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#SFSET  '#SFSET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2U  '#CHK2
     C           @STEP     CASEQ'#ADD    '#ADD
     C           @STEP     CASEQ'#DSP3   '#DSP3
     C           @STEP     CASEQ'#CHK3   '#CHK3
     C           @STEP     CASEQ'#CHK3U  '#CHK3
     C           @STEP     CASEQ'#DELETE '#DEL
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1MSG            エラー
     C*
     C                     Z-ADD1         X       20
     C           P@SYS     LOKUPTBL,X                    90
     C           *IN90     IFEQ *ON
     C                     MOVE TOKU,X    @TOKU
     C                     ELSE
     C                     MOVE TOKU,4    @TOKU
     C                     ENDIF
     C*
     C                     MOVE *BLANK    D1ODR1
     C                     MOVE *BLANK    D1ODR2
     C                     MOVE *BLANK    D1ODR3
     C*
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     Z-ADD0         D1BOXA
     C                     Z-ADD0         D1BOXS
     C                     Z-ADD0         D1MAIA
     C                     Z-ADD0         D1MAIS
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     SETOF                     111299
     C                     MOVE *BLANK    D1MSG
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F3 >  INPUT OK
     C           *INKC     IFEQ *ON
     C                     SETON                     U3
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F12 >  INQUIRY
     C           *INKL     IFEQ *ON
     C                     MOVE '#SFSET  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C                     CLEARGDGWP891
     C*-----------
     C* ORDER NO.
     C*-----------
     C           D1ODR1    IFEQ 0
     C           D1ODR2    ANDEQ0
     C           D1ODR3    ANDEQ0
     C                     SETON                     1199
     C                     MOVELMSG,1     D1MSG
     C                     ENDIF
     C*----------
     C* PART NO.
     C*----------
     C  N99      D1HIN1    IFEQ *BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C                     SETON                     1299
     C                     MOVELMSG,2     D1MSG
     C                     ENDIF
     C*
     C           KEY01     KLIST
     C                     KFLD           K1ODR   60
     C                     KFLD           K1HIN1  5
     C                     KFLD           K1HIN2  5
     C                     KFLD           K1HIN3  2
     C*------------------
     C* ORDER DATA CHECK
     C*------------------
     C                     Z-ADDD1ODR1    K1ODR1
     C                     Z-ADDD1ODR2    K1ODR2
     C                     Z-ADDD1ODR3    K1ODR3
     C                     MOVELD1HIN1    K1HIN1
     C                     MOVELD1HIN2    K1HIN2
     C                     MOVELD1HIN3    K1HIN3
      *
     C           *IN99     IFEQ *OFF
     C           KEY01     SETLLGDGPL181
     C                     DO   *HIVAL
     C           KEY01     READEGDGPL18                  90
     C           *IN90     IFEQ *OFF
     C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     ELSE
     C           ICHANY    IFEQ 'S'
     C                     MOVELICITEM    D1ITMS
     C                     ADD  ICMAIS    D1BOXS
     C                     END
     C           ICHANY    IFEQ 'A'
     C                     MOVELICITEM    D1ITMA
     C                     ADD  ICMAIS    D1BOXA
     C                     END
     C                     END
     C                     END
     C  N90                ENDDO
      *
     C           D1BOXS    IFEQ 0
     C           D1BOXA    ANDEQ0
     C                     SETON                     1299
     C                     MOVELMSG,3     D1MSG
     C                     ENDIF
     C                     ENDIF
     C*----------
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1   '
     C*
     C                     MOVE '-'       D1HIF1
     C                     MOVE '-'       D1HIF2
     C                     MOVE '-'       D1HIF3
     C                     MOVE '-'       D1HIF4
     C                     MOVE '-'       D1HIF5
     C           D1HIN2    IFEQ *BLANK
     C                     MOVE ' '       D1HIF4
     C                     END
     C           D1HIN3    IFEQ *BLANK
     C                     MOVE ' '       D1HIF5
     C                     END
     C                     Z-ADD0         D1MAIA
     C                     Z-ADD0         D1MAIS
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*===============================================================
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     EXFMTDSP02
     C                     SETOF                     111299
     C                     MOVE *BLANK    D1MSG
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  END JOB
     C           *INKC     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  INPUT OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2U  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　チェック
      *===============================================================
     C           #CHK2     BEGSR
     C*------------------
     C* NUMBER OF KANBAN
     C*------------------
     C           D1MAIS    IFEQ 0
     C           D1MAIA    ANDEQ0
     C                     SETON                     111299
     C                     MOVELMSG,5     D2MSG
     C                     ENDIF
      *
     C           D1MAIS    IFGT D1BOXS
     C                     SETON                     1199
     C                     MOVELMSG,6     D2MSG
     C                     ENDIF
     C*
      *
     C           D1MAIA    IFGT D1BOXA
     C                     SETON                     1299
     C                     MOVELMSG,6     D2MSG
     C                     ENDIF
     C*
     C*------------------
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2U  '
     C                     MOVE '#ADD    '@STEP
X1   C                     ELSE
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*===============================================================
     C*===============================================================
     C*   << ADD   >>
     C*===============================================================
     C           #ADD      BEGSR
     C           KEY02     KLIST
     C                     KFLD           K1TOKU  40
     C                     KFLD           K1NONY  40
     C                     KFLD           K1NKOJ  1
     C                     KFLD           K1NUKE  4
     C                     KFLD           K1ODR1  20
     C                     KFLD           K1ODR2  20
     C                     KFLD           K1ODR3  20
     C                     KFLD           K1ITEM  50
     C                     KFLD           K1HIN1  5
     C                     KFLD           K1HIN2  5
     C                     KFLD           K1HIN3  2
     C                     KFLD           K1HANY  1
      *
     C                     Z-ADD@@TOKU    K1TOKU
     C                     Z-ADD@@NONY    K1NONY
     C                     MOVEL@@NKOJ    K1NKOJ
     C                     MOVEL@@NUKE    K1NUKE
     C                     MOVE D1ODR1    K1ODR1
     C                     MOVE D1ODR2    K1ODR2
     C                     MOVE D1ODR3    K1ODR3
     C                     MOVE D1HIN1    K1HIN1
     C                     MOVE D1HIN2    K1HIN2
     C                     MOVE D1HIN3    K1HIN3
      *
     C           D1MAIS    IFGT 0
     C                     MOVE D1ITMS    K1ITEM
     C                     MOVE 'S'       K1HANY
     C                     SETOF                     88
     C           KEY02     CHAINGDGWP891             88
      *
      *
     C                     Z-ADD@@TOKU    G1TOKU
     C                     MOVE @@TKOJ    G1TKOJ
     C                     MOVE @@TUKE    G1TUKE
     C                     Z-ADD@@NONY    G1NONY
     C                     MOVE @@NKOJ    G1NKOJ
     C                     MOVE @@NUKE    G1NUKE
     C                     MOVE D1ODKG    G1ODKG
     C                     MOVE D1ODR1    G1ODR1
     C                     MOVE D1ODR2    G1ODR2
     C                     MOVE D1ODR3    G1ODR3
     C                     MOVE D1ITMS    G1ITEM
     C                     MOVE D1HIN1    G1HIN1
     C                     MOVE D1HIN2    G1HIN2
     C                     MOVE D1HIN3    G1HIN3
     C                     MOVE K1HANY    G1HANY
     C                     MOVE D1MAIS    G1MAIS
     C           *IN88     IFEQ '1'
     C                     WRITEGDGWP891
     C                     ELSE
     C                     UPDATGDGWP891
     C                     END
     C                     END
      *
     C           D1MAIA    IFGT 0
     C                     MOVE D1ITMA    K1ITEM
     C                     MOVE 'A'       K1HANY
     C                     SETOF                     88
     C           KEY02     CHAINGDGWP891             88
      *
      *
     C                     Z-ADD@@TOKU    G1TOKU
     C                     MOVE @@TKOJ    G1TKOJ
     C                     MOVE @@TUKE    G1TUKE
     C                     Z-ADD@@NONY    G1NONY
     C                     MOVE @@NKOJ    G1NKOJ
     C                     MOVE @@NUKE    G1NUKE
     C                     MOVE D1ODKG    G1ODKG
     C                     MOVE D1ODR1    G1ODR1
     C                     MOVE D1ODR2    G1ODR2
     C                     MOVE D1ODR3    G1ODR3
     C                     MOVE D1ITMA    G1ITEM
     C                     MOVE D1HIN1    G1HIN1
     C                     MOVE D1HIN2    G1HIN2
     C                     MOVE D1HIN3    G1HIN3
     C                     MOVE K1HANY    G1HANY
     C                     MOVE D1MAIA    G1MAIS
     C           *IN88     IFEQ '1'
     C                     WRITEGDGWP891
     C                     ELSE
     C                     UPDATGDGWP891
     C                     END
     C                     END
     C*
     C                     MOVE D1ODKG    D2ODKG
     C                     MOVE '-'       D2HIF1
     C                     MOVE D1ODR1    D2ODR1
     C                     MOVE '-'       D2HIF2
     C                     MOVE D1ODR2    D2ODR2
     C                     MOVE '-'       D2HIF3
     C                     MOVE D1ODR3    D2ODR3
     C                     MOVE D1HIN1    D2HIN1
     C                     MOVE '-'       D2HIF4
     C                     MOVE D1HIN2    D2HIN2
     C                     MOVE '-'       D2HIF5
     C                     MOVE D1HIN3    D2HIN3
     C           D2HIN3    IFEQ *BLANK
     C                     MOVE *BLANK    D2HIF5
     C                     END
     C                     MOVE *BLANK    D1ODR1
     C                     MOVE *BLANK    D1ODR2
     C                     MOVE *BLANK    D1ODR3
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     Z-ADDD1MAIA    D2MAIA
     C                     Z-ADDD1MAIS    D2MAIS
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
     C*   << SFSET >>
     C*===============================================================
     C           #SFSET    BEGSR
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
     C*
     C* DAYLY ORDER DATA BEFOR ADDING FILE
     C           *LOVAL    SETLLGDGWP89
     C*--------------------
S1   C                     DO   *HIVAL
     C                     READ GDGWP89                  90
     C   90                LEAVE
     C*
     C                     SETOF                     21
     C                     MOVE *BLANK    S1DEL            DELETE
     C                     MOVE *BLANK    S1HIN            PART NO.
     C                     MOVE *BLANK    S1ODR            ORDER NO.
     C                     MOVE G1ODKG    S1ODKG           ORDER NO.
     C                     MOVE G1ODR1    S1ODR1           ORDER NO1
     C                     MOVE G1ODR2    S1ODR2           ORDER NO2
     C                     MOVE G1ODR3    S1ODR3           ORDER NO3
     C                     MOVE '-'       S1HIF1
     C                     MOVE '-'       S1HIF2
     C                     MOVE '-'       S1HIF3
     C                     MOVE G1HIN1    S1HIN1           PART NO1
     C                     MOVE G1HIN2    S1HIN2           PART NO2
     C                     MOVE G1HIN3    S1HIN3           PART NO3
     C                     MOVE '-'       S1HIF4
     C                     MOVE '-'       S1HIF5
     C           S1HIN3    IFEQ *BLANK                     PART NO3
     C                     MOVE ' '       S1HIF5
     C           S1HIN2    IFEQ *BLANK                     PART NO2
     C                     MOVE ' '       S1HIF4
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDG1MAIS    S1MAIS           QTY
     C                     ADD  1         RRN1
     C                     WRITESFREC1
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C                     Z-ADD1         RRN
     C                     MOVE '#DSP3   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面３　表示
      *===============================================================
     C           #DSP3     BEGSR
     C*
     C                     WRITEDSP03
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     SETON                     72
     C                     EXFMTSFCTL
     C                     SETOF                     717299
     C                     MOVE *BLANK    D2MSG
     C                     Z-ADD$$RRN     TOPRRN  40
     C*
     C                     MOVE '#CHK3   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *BLANK    D1ODR1
     C                     MOVE *BLANK    D1ODR2
     C                     MOVE *BLANK    D1ODR3
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  DELETE OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK3U  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面３　チェック
      *===============================================================
     C           #CHK3     BEGSR
     C*
     C                     Z-ADD0         @SEL    40
     C                     Z-ADD0         ERRRRN  40
     C                     Z-ADD0         CHGRRN  40
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C                     SETOF                     21
     C*
 S2  C           S1DEL     IFNE *BLANK
     C           S1DEL     ANDNE'0'
     C                     MOVELMSG,7     D2MSG
     C                     SETON                     2199
     C                     Z-ADDRRN1      ERRRRN
 E2  C                     ENDIF
     C           S1DEL     IFEQ '0'                        DELETE
     C                     ADD  1         @SEL
     C                     ENDIF
     C*
     C                     UPDATSFREC1
E1   C  N99                ENDDO
     C*--------------------
     C*
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK3U  '
     C                     MOVE '#DELETE '@STEP
X1   C                     ELSE
 S2  C           ERRRRN    IFNE 0
     C                     Z-ADDERRRRN    RRN
 X2  C                     ELSE
     C                     Z-ADDTOPRRN    RRN
 E2  C                     ENDIF
     C                     MOVE '#DSP3   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *   DELETE
      *===============================================================
     C           #DEL      BEGSR
     C*
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C*
     C           S1DEL     IFEQ '0'                        DELETE
     C           KEY02     CHAINGDGWP89              95
     C  N95                DELETGDGWP891
     C                     ENDIF
E1   C                     ENDDO
     C*--------------------
     C                     MOVE '#SFSET  '@STEP
     C*
     C                     ENDSR
