     H            Y.
     F** AL#RA4 **************************************
     F*発行制御ファイル作成AL#PPD1                 *
     F*        ITS.         2015.05.26               *
     F************************************************
     FAL#WPA9 IF  E           K        DISK
     FAL#PLA1 IF  E           K        DISK
     FAL#PPD1 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     READ AL#WPA91                 22
     C           *IN22     DOWEQ'0'
     C           W9SEL     IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ AL#WPA91                 22
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PPD1
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYA      KLIST
     C                     KFLD           W9FIXD
     C                     KFLD           W9FIXT
     C                     KFLD           W9TRKB
     C                     KFLD           W9IAFB
     C           KEYA      SETLLAL#PLA11
     C           KEYA      READEAL#PLA11                 89
     C           *IN89     DOWEQ'0'
     C           CRSKJY    IFEQ 'D'
     C           CRSKHZ    ANDLESDATE
     C                     ELSE
     C                     CLEARAL#PPD11
     C                     Z-ADDSDATE     CDKOHZ
     C                     Z-ADDSTIME     CDKOTI
     C                     MOVELW#USER    CDKOME
     C                     MOVELCRDATA    CDDATA
     C                     Z-ADDCRFIXD    CDFIXD
     C                     Z-ADDCRFIXT    CDFIXT
     C                     Z-ADDCRTIMS    CDTIMS
     C                     MOVELCRTRKB    CDTRKB
     C                     MOVELCRIAFB    CDIAFB
     C                     Z-ADDSDATE     CDCRHZ
     C                     Z-ADDSTIME     CDCRTI
     C                     Z-ADD0         CDNKHZ
     C                     Z-ADD0         CDNKTI
     C                     WRITEAL#PPD11
     C                     ENDIF
     C           KEYA      READEAL#PLA11                 89
     C                     ENDDO
      *
     CSR         ESB500    ENDSR
