%0001FTEST1   IP  F       7            DISK
     FGCQPL13 IF  E           K        DISK
%0001FTEST2   O   F     128            DISK
     C*
     ITEST1   AA  01
     I                                        1   2 @KAT1
     I                                        4   7 @KAT2
     I            DS
     I                                        1   7 @SETA
     I                                        1   5 @SET1
     I                                        6   7 @SET2
      *
     C                     MOVEL*BLANK    @KAT3   1
      *
     C           KATKEY    KLIST
     C                     KFLD           @KAT1   2
     C                     KFLD           @KAT2   4
     C                     KFLD           @KAT3   1
      *
     C*  f]’Šī’Š×] ub’Šćc ’Įż ’Šł’Į«mb’Šćc ’Įż ’Šå’Į¼c’Šæc’Šćc
     C*
     C                     SETOF                     22
     C                     Z-ADD0         $MKOCD  40
     C                     Z-ADD0         WMKCD   40
     C                     MOVE *BLANK    $TKR1   1
     C                     Z-ADD0         MAIS    30
     C                     Z-ADD0         SETS    72
     C                     Z-ADD0         SYUS    30
     C           KATKEY    SETLLGCQPL131
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KATKEY    READEGCQPL131                 20
     C           *IN20     IFEQ '0'
      *
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     GOTO KTP1
