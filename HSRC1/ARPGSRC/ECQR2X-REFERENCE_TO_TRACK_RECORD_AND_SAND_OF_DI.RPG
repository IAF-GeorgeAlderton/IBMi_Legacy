     C                     MOVE T6TKR1    $TKR1
     C                     Z-ADDT6KOCD    WMKCD
     C                     ADD  T6MAIS    MAIS
     C                     ADD  T6SRYO    SETS
     C                     Z-ADDT6SYOS    SYUS
     C           KTP1      TAG
     C                     END
     C                     END
     C  N20                END
      *
     C           MAIS      IFGE 1
