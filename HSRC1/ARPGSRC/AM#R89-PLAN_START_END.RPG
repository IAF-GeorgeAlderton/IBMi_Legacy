     C           *ENTRY    PLIST
     C                     PARM           P1DATE  8
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           P1DATE    SETLLAL#PP311
     C           P1DATE    READEAL#PP311                 81
     C           *IN81     DOWEQ'0'
     C           C3SKJY    IFEQ 'D'
     C           C3SKHZ    ANDLESDATE
     C                     ELSE
     C           C3EXTR    IFEQ 0
     C                     EXSR #SB400
     C                     ENDIF
     C                     ENDIF
     C           P1DATE    READEAL#PP311                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PL32
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           C3FIXD
     C                     KFLD           C3FIXT
      *
     C           KEYC1     SETLLAL#PL321
     C           KEYC1     READEAL#PL321                 82
     C           *IN82     DOWEQ'0'
     C           C3SKJY    IFEQ 'D'
     C           C3SKHZ    ANDLESDATE
     C                     ELSE
     C           C3EXTR    IFEQ 0
