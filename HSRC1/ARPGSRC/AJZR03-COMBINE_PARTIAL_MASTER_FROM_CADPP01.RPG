     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     C           C2SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
      *失効日の拡大
     C                     MOVE C2STHZ    PRDAT
     C           C2STMM    IFNE 99
     C                     MOVE C2STHZ    PDATE   8
     C                     MOVE '+'       PPORM   1        + OR -
     C                     MOVE '0001'    PDAYS   4
     C                     MOVE *BLANK    PRDAT   8
     C                     MOVE *BLANK    PRTN    1
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     END
     C                     MOVE PRDAT     W@STDT  80
      *有効日の拡大
     C                     MOVE C2UKHZ    PDATE   8
     C                     MOVE '-'       PPORM   1        + OR -
     C                     MOVE '0001'    PDAYS   4
     C                     MOVE *BLANK    PRDAT   8
     C                     MOVE *BLANK    PRTN    1
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     W@UKDT  80
      *
     C                     TIME           WTIME
      *
     C           WTIHZ     IFGE W@UKDT
     C           WTIHZ     ANDLEW@STDT
     C                     ELSE
     C                     GOTO @END
     C                     END
      *
     C                     CALL 'AJSRS4'
     C                     PARM           C2SHN1
     C                     PARM           C2SHN2
     C                     PARM           C2SHN3
     C                     PARM           P@TANJ  73
      *
     C           C2KTEI    IFEQ 'PRS'
     C           C2KTEI    OREQ 'INJ'
     C           C2KTEI    OREQ 'HK '
     C                     Z-ADD0         P@TANJ
     C                     END
      *
     C           P@TANJ    IFEQ 0
     C                     CALL 'AJZR5Z'
     C                     PARM           C2SHN1
     C                     PARM           C2SHN2
     C                     PARM           C2SHN3
     C                     PARM           P@TANJ  73
     C                     END
      *
     C                     Z-ADDP@TANJ    J1TANJ  73
      * ZERO
     C                     Z-ADD0         J1OSYU  50
     C                     Z-ADD0         J121CD  40
