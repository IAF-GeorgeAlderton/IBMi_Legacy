     H            Y.
     F** AB#R87 ************************************
     F* ..CHANGE UNIT PRICE                        *
     F*---------------------                       *
JW1  F* JW     2022.02.06 ADD LOG FILE (AB#PP02)   *
JW1  F* JW     2022.02.28 ADD PRICE=0 INQ (F9)     *
     F**********************************************
     FAB#PW87 CF  E                    WORKSTN
     FAB#PL09 UF  E           K        DISK
     FAB#PL05 IF  E           K        DISK
     FAB#PL0A UF  E           K        DISK
JW1  FAB#PP02 O   E                    DISK
      *
JW1  E                    ERR     1  15 60
JW1  I            DS
 .   I                                        1  140SDATE
 .   I                                        1   60NOW
JW1  I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
      *
     C           K#CUT     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@DELV  40
      *
     C           K#A0A     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@DELV  40
     C                     KFLD           D@MPR1
     C                     KFLD           D@MPR2
     C                     KFLD           D@MPR3
     C                     KFLD           D@MPR4
     C                     KFLD           D@YY
     C                     KFLD           D@MM
      *
     C           K#APP     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           D@YY
     C                     KFLD           D@MM
      *
     C                     MOVE '01'      @@ID    2
     C                     MOVE 'N'       D@ZFLG
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------
      *
     C                     EXFMTDSP01
JW1  C                     MOVE *BLANK    XMSG
      * F3: END
     C           *INKA     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
JW1   * F9: PRICE=0 INQ
 .   C           *INKI     IFEQ *ON
 .   C                     CALL 'AB#R8D'
JW1  C                     ELSE
      *
     C                     EXSR #CHK1
      * F5: UPDATE
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE *BLANK    D@PRT1
     C                     MOVE *BLANK    D@PRT2
     C                     MOVE *BLANK    D@PRT3
     C                     MOVE *BLANK    D@MPR1
     C                     MOVE *BLANK    D@MPR2
     C                     MOVE *BLANK    D@MPR3
     C                     MOVE *BLANK    D@MPR4
     C                     Z-ADD*ZERO     D@NWPR
     C                     Z-ADD*ZERO     D@OLPR
JW1  C                     MOVELERR,13    XMSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------
      *
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *OFF      *IN99
     C                     Z-ADD0         D@OLPR
      *
     C           D@CUST    IFEQ *BLANK
     C                     SETON                     6199
JW1  C                     MOVELERR,1     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@DELV    IFEQ *BLANK
     C                     SETON                     6299
JW1  C                     MOVELERR,2     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELD@CUST    K@TOKU  40
     C                     MOVELD@DELV    K@DELV  40
     C           K#CUT     CHAINAB#PL05              90
     C           *IN90     IFEQ *ON
     C                     SETON                     616299
JW1  C                     MOVELERR,10    XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@YY      IFEQ 0
     C                     SETON                     6399
JW1  C                     MOVELERR,3     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@MM      IFEQ 0
     C                     SETON                     6499
JW1  C                     MOVELERR,4     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      * CHECK DATE
     C                     MOVELD@YY      LTR6    6
     C                     MOVE D@MM      LTR6
     C                     MOVELLTR6      LTR8    8
     C                     MOVE '01'      LTR8
     C                     MOVELLTR8      $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN1   1
     C           $RTN1     IFNE *BLANK
     C                     SETON                     636499
JW1  C                     MOVELERR,11    XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@PRT1    IFEQ *BLANK
     C           D@MPR1    ANDEQ*BLANK
     C                     SETON                     6599
JW1  C                     MOVELERR,5     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@PRT1    IFNE *BLANK
     C           D@MPR1    ANDNE*BLANK
     C                     SETON                     6599
JW1  C                     MOVELERR,9     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      * USER PART
     C           D@MPR1    IFNE *BLANK
     C           K#A0A     CHAINAB#PL0A             N90
     C           *IN90     IFEQ *ON
     C                     SETON                     616299
     C                     SETON                     6564
JW1  C                     MOVELERR,7     XMSG
JW1  C                     MOVE '1'       XMSG
 "   C                     GOTO XCHK1
     C                     ELSE
     C                     Z-ADDB1TANK    D@OLPR
     C                     ENDIF
     C                     ENDIF
      * IAF PART
     C           D@PRT1    IFNE *BLANK
     C           K#APP     SETLLAB#PL09
     C           *IN90     DOUEQ*ON
     C           K#APP     READEAB#PL09             N    90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C           B1NONY    ANDEQK@DELV
     C                     Z-ADDB1TANK    D@OLPR
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           D@ZFLG    IFNE 'Y'
     C           D@ZFLG    ANDNE'N'
     C                     SETON                     6799
JW1  C                     MOVELERR,12    XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@NWPR    IFEQ 0
     C           D@ZFLG    ANDEQ'N'
     C                     SETON                     6699
JW1  C                     MOVELERR,6     XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C                     MOVEA'11111'   *IN,61
     C                     SETON                     99
JW1  C                     MOVELERR,7     XMSG
JW1  C                     MOVE '3'       XMSG
 "   C                     GOTO XCHK1
     C                     ENDIF
      * IF NO ERROR...
JW1  C                     MOVELERR,8     XMSG
      *
     C           XCHK1     ENDSR
      *-----------------------------------------------
     C           #UPD      BEGSR
      *-----------------------------------------------
      * BY IAF PART
     C           D@MPR1    IFEQ *BLANK
     C           K#APP     SETLLAB#PL09
     C           *IN90     DOUEQ*ON
     C           K#APP     READEAB#PL09                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C           B1NONY    ANDEQK@DELV
     C           B1TOKU    ANDEQK@TOKU
JW1  C                     EXSR #BFR
     C                     Z-ADDB1TANK    SVTANK 105
     C                     Z-ADDD@NWPR    B1TANK
JW1  C           D@ZFLG    IFEQ 'Y'
 .   C                     MOVE 'Z'       B1TKBN           ZERO PRICE ORDER FLAG
 .   C                     ENDIF
 .   C           D@NWPR    IFNE 0
 .   C                     MOVE ' '       B1TKBN
JW1  C                     ENDIF
     C                     UPDATAB#PL071
JW1  C                     EXSR #AFT
     C                     ENDIF
     C                     ENDDO
      * BY USER PART
     C                     ELSE
     C           K#A0A     SETLLAB#PL0A
     C           *IN90     DOUEQ*ON
     C           K#A0A     READEAB#PL0A                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
JW1  C                     EXSR #BFR
     C                     Z-ADDB1TANK    SVTANK 105
     C                     Z-ADDD@NWPR    B1TANK
JW1  C           D@ZFLG    IFEQ 'Y'
 .   C                     MOVE 'Z'       B1TKBN           ZERO PRICE ORDER FLAG
 .   C                     ENDIF
 .   C           D@NWPR    IFNE 0
 .   C                     MOVE ' '       B1TKBN
JW1  C                     ENDIF
     C                     UPDATAB#PL0A1
JW1  C                     EXSR #AFT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
JW1   ***************************
 .    * SAVE (BEFORE UPDATE)
 .    ***************************
 *   C           #BFR      BEGSR
      *
     C                     TIME           SDATE
     C                     MOVEL'BEFORE'  B2ATTR
     C                     Z-ADDB1TANK    B2TNK1
     C                     Z-ADD0         B2TNK2
     C                     Z-ADDTODAY     B2CRHZ
     C                     Z-ADDNOW       B2CRTM
     C                     MOVEL#USER     B2CRUS
     C                     MOVEL#PGM      B2CRPG
     C                     WRITEAB#PP021
      *
     C                     ENDSR
      ***************************
      * SAVE (AFTER UPDATE)
      ***************************
     C           #AFT      BEGSR
      *
     C                     TIME           SDATE
     C                     MOVEL'AFTER '  B2ATTR
     C                     Z-ADDSVTANK    B2TNK1
     C                     Z-ADDB1TANK    B2TNK2
     C                     Z-ADDTODAY     B2CRHZ
     C                     Z-ADDNOW       B2CRTM
     C                     MOVEL#USER     B2CRUS
 *   C                     MOVEL#PGM      B2CRPG
 .   C                     WRITEAB#PP021
 .    *
JW1  C                     ENDSR
** ERR (60A).......2.........3.........4.........5.........6
ENTER CUSTOMER !                                               1
ENTER DELIVERY !                                               2
ENTER SHIP YEAR !                                              3
ENTER SHIP MONTH !                                             4
ENTER IAF PART# OR USER PART# !                                5
ENTER NEW UNIT PRICE OR ZERO FLAG=Y !                          6
ORDER DATA NOT FOUND !                                         7
PRESS F5 TO UPDATE...                                          8
DO NOT ENTER IAF AND USER PART# BOTH !                         9
NO ORDER DATA WITH CUST AND DELIV CONBINATION !               10
YEAR/MONTH NOT FOUND IN OUR CALENDAR MASTER !                 11
THIS FIELD SHOULD BE Y OR N !                                 12
CONTINUE...                                                   13
