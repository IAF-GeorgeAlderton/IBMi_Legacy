     C           @CHK1     BEGSR
     C*
     C                     MOVE *BLANK    MSG
     C                     SETOF                     306162
      *
TCHK1C                     DO
TCHK1C*
TCHK1C           K#11      SETGTAFDPL11
     C           *IN90     DOUEQ*ON
TCHK1C           K#11      REDPEAFDPL11                  90
     C           *IN90     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
     C           ADSUPP    ANDEQSUPLY
     C                     MOVE ADBINN    K@BIN
     C                     MOVE ADODNO    W@ODNO  60
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     SETON                     3062
     C                     MOVELER,1      MSG
TCHK1C                     LEAVE
     C                     ENDIF
      *
     C           K#AFD     SETLLAFDPL21
     C           *IN90     DOUEQ*ON
     C           K#AFD     READEAFDPL21                  90
     C           *IN90     IFEQ *OFF
     C           AFSKJY    ANDNE*BLANK
     C           AFAKI1    ANDEQ@@3
     C           AFAKI2    ANDNE*BLANK
     C  N30                MOVELER,3      MSG
     C                     SETON                     3061
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
TCHK1C*
TCHK1C           *IN30     IFEQ *ON
TCHK1C                     LEAVE
TCHK1C                     END
      *
TCHK1C           K#AFD     SETLLAFDPL21
TCHK1C           *IN90     DOUEQ*ON
TCHK1C           K#AFD     READEAFDPL21                  90
TCHK1C           *IN90     IFEQ *OFF
TCHK1C           AFSKJY    ANDEQ*BLANK
TCHK1C           AFAKI1    ANDEQ@@3
TCHK1C           AFODNO    ANDEQW@ODNO
TCHK1C                     LEAVE
TCHK1C                     ENDIF
TCHK1C                     ENDDO
TCHK1C*
TCHK1C           *IN90     IFEQ *ON
TCHK1C                     SETON                     3062
JW1  C                     MOVELER,5      MSG
TCHK1C                     ENDIF
TCHK1C*
TCHK1C                     ENDDO
TCHK1C*
