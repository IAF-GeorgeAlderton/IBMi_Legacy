     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C           @@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PWKCD   6
     C                     PARM           SUPLY   4
     C                     PARM           PID     1
      *
     C           K#AFD     KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@BIN   3
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C* AFDPL11
     C           K#11      KLIST
     C                     KFLD           BCOCD            CONTROL CD
     C                     KFLD           BZETI            ABSOLUTE #
     C                     KFLD           WTEHI            TEHAI
     C                     KFLD           BPAGE            PAGE
     C                     KFLD           BNIJI            2ND.TREATEMENT
     C                     KFLD           BTICD            TARGET TYPE
     C                     KFLD           BYUKO            SHIP EFFECTIVE
     C                     KFLD           BHASY            CONTAINER TYPE
     C                     KFLD           BCKDT            CHECK DIGIT
      *
     C                     MOVE SUPLY     @SUPP   40
     C                     MOVELPID       @@3     3
     C                     Z-ADD*ZERO     K@YY
     C                     Z-ADD*ZERO     K@MM
     C                     Z-ADD*ZERO     K@DD
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C           SUPLY     LOKUPTAB1      TAB2           10
     C                     MOVELTAB2      TITL
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN (SCAN APICS KANBAN)
     C**************************************************************************
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@KEY
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
B02  C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR @CHK1
     C*
B04  C           *IN30     IFEQ '0'
     C                     MOVEL'02'      @@ID
TCHK5C                     MOVELK@BIN     BIN
      *
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
