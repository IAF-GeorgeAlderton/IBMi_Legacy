     C*
     C           BIN       IFEQ *BLANK
     C  N30                MOVELER,2      MSG
     C                     SETON                     3061
TCHK5C                     LEAVE
     C                     ENDIF
      *
TCHK5C           BIN       IFNE K@BIN
TCHK5C                     MOVELER,4      MSG
JW1  C                     MOVE '1'       MSG
TCHK5C                     MOVELK@BIN     BIN#1
TCHK5C                     MOVELBIN       BIN#2
TCHK5C                     EXFMTERR98
TCHK5C                     SELEC
TCHK5C           *INKC     WHEQ *ON
TCHK5C                     MOVEL*ON       *INLR
TCHK5C                     RETRN
TCHK5C           *INKE     WHEQ *ON
TCHK5C                     LEAVE
TCHK5C                     OTHER
TCHK5C                     MOVELER,4      MSG
JW1  C                     MOVE '2'       MSG
TCHK5C                     SETON                     3061
TCHK5C                     ENDSL
TCHK5C                     END
TCHK5C*
TCHK5C                     ENDDO
