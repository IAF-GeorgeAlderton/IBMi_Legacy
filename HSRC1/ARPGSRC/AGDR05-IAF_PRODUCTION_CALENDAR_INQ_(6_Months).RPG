      *----------------------------------------------------
      * MAIN ROUTINE
      *----------------------------------------------------
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTDSP01
     C                     MOVE *BLANK    XMSG
      * F1: EXIT
     C           *INKA     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      * ENTER KEY
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C           *INKE     IFEQ *ON
     C                     EXSR #DSP2
     C                     MOVE *BLANK    XMSG
     C                     ELSE
     C                     MOVELMSG,5     XMSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------
      * CHECK YEAR/MONTH
      *----------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN85
      *
     C           XYEAR     IFEQ 0
     C           XMON      OREQ 0
     C                     SETON                     414285
     C                     MOVELMSG,1     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XYEAR     IFLE 1997
     C           XYEAR     ORGE 3000
     C                     SETON                     41  85
     C                     MOVELMSG,2     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XMON      IFLE 0
     C           XMON      ORGE 13
     C                     SETON                     42  85
     C                     MOVELMSG,3     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK CALENDAR
     C                     Z-ADDXYEAR     K#YY
     C                     Z-ADDXMON      K#MM
     C                     Z-ADD01        K#DD
     C           K#AG1A    CHAINAGDPL12              99
     C           *IN99     IFEQ *ON
     C                     SETON                     414285
     C                     MOVELMSG,4     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * IF NO ERROR...
     C                     EXSR #SET1
      *
     C           XCHK1     ENDSR
      *--------------------------------------*
      * SCREEN 2                             *
      *--------------------------------------*
     C           #DSP2     BEGSR
      *
     C                     EXFMTDSP02
      *
     C                     ENDSR
      *--------------------------------------*
      * SET CALENDAR DATA                    *
      *--------------------------------------*
     C           #SET1     BEGSR
      *
     C                     EXSR #CLR1
      *
     C                     Z-ADDXYEAR     @YEAR   40
     C                     Z-ADDXMON      @MONTH  20
     C                     Z-ADD1         @M      20
     C                     MOVE *ON       *IN81
     C                     EXSR #MON1
      *
     C                     Z-ADDXYEAR     @YEAR
     C                     ADD  1         @MONTH
     C           @MONTH    IFGE 13
     C                     SUB  12        @MONTH
     C                     ADD  1         @YEAR
     C                     ENDIF
     C                     ADD  1         @M
     C                     MOVE *ON       *IN82
     C                     EXSR #MON2
      *
     C                     ENDSR
      *--------------------------------------*
      * SET DISPLAY DATA                     *
      *--------------------------------------*
     C           #MON1     BEGSR
      *
     C                     Z-ADD@MONTH    XYM,@M
     C                     MOVEL@YEAR     XYM,@M
     C                     Z-ADD0         XWK,@M
     C**                   MOVEALTR38     *IN,01
      * GET CALENDAR MASTER
     C                     Z-ADD@YEAR     K#YY
     C                     Z-ADD@MONTH    K#MM
     C                     Z-ADD01        K#DD
     C           K#AG1A    SETLLAGDPL12
     C                     DO   *HIVAL
     C           K#AG1B    READEAGDPL12                  98
     C   98                LEAVE
     C           F8KADD    IFEQ 1
     C                     Z-ADDF8YOBI    IX      20
     C                     ENDIF
     C                     ADD  1         IX
     C                     Z-ADDF8KADD    XD1,IX
     C           F8HIRU    IFEQ '*'
     C                     MOVE *ON       *IN,IX
     C                     ELSE
     C                     ADD  1         XWK,@M
     C                     ENDIF
     C                     ENDDO
      *
     C           XDSP1     ENDSR
      *--------------------------------------*
      * SET DISPLAY DATA                     *
      *--------------------------------------*
     C           #MON2     BEGSR
      *
     C                     Z-ADD@MONTH    XYM,@M
     C                     MOVEL@YEAR     XYM,@M
     C                     Z-ADD0         XWK,@M
     C**                   MOVEALTR38     *IN,01
      * GET CALENDAR MASTER
     C                     Z-ADD@YEAR     K#YY
     C                     Z-ADD@MONTH    K#MM
     C                     Z-ADD01        K#DD
     C           K#AG1A    SETLLAGDPL12
     C                     DO   *HIVAL
     C           K#AG1B    READEAGDPL12                  98
     C   98                LEAVE
     C           F8KADD    IFEQ 1
     C                     Z-ADDF8YOBI    IX      20
     C                     ENDIF
     C                     ADD  1         IX
     C                     Z-ADDF8KADD    XD2,IX
     C           F8HIRU    IFEQ '*'
     C                     MOVE *ON       *IN,IX
     C                     ELSE
     C                     ADD  1         XWK,@M
     C                     ENDIF
     C                     ENDDO
      *
     C           XDSP2     ENDSR
      *--------------------------------------*
      * CLEAR VALUES                         *
      *--------------------------------------*
     C           #CLR1     BEGSR
      *
     C                     MOVELMSG,1     LTR38  38
     C                     MOVEALTR38     *IN,01
     C                     SETOF                     818283
     C                     SETOF                     848586
      *
     C                     Z-ADD0         XYM
     C                     Z-ADD0         XWK
     C                     Z-ADD0         XD1
     C                     Z-ADD0         XD2
     C                     Z-ADD0         XD3
     C                     Z-ADD0         XD4
     C                     Z-ADD0         XD5
     C                     Z-ADD0         XD6
      *
     C                     ENDSR
      *-----------------------------------------
      * INITIAL SETTING
      *-----------------------------------------
     C           #INIT     BEGSR
      *
     C           K#AG1A    KLIST
     C                     KFLD           K#YY    40
     C                     KFLD           K#MM    20
     C                     KFLD           K#DD    20
      *
     C           K#AG1B    KLIST
     C                     KFLD           K#YY    40
     C                     KFLD           K#MM    20
      *
     C                     TIME           SDATE
     C                     Z-ADDSYY       XYEAR
     C                     Z-ADDSMM       XMON
      * CLEAR INDICATORS
     C                     EXSR #CLR1
      *
     C                     ENDSR
** MSG(60A) .......2.........3.........4.........5.........6
ENTER YEAR/MONTH!                                            01
YEAR IS INVALID!                                             02
MONTH IS INVALID!                                            03
ENTERED YEAR/MONTH DOES NOT EXIST IN IAF CALENDAR MASTER!    04
PRESS F5 TO RUN...                                           05
