      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------
      *  INITIALIZE
      *-------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVE '01'      W@ID    2
     C           K#KEY     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#ADH     KLIST
     C                     KFLD           K@LOC1
     C                     KFLD           K@LOC2
     C                     KFLD           K@LOC3
     C                     KFLD           K@LOC4
      *
     C           K#APL     KLIST
     C                     KFLD           K@JOKN  2
     C                     KFLD           K@KANB  1
      *
     C                     TIME           @TIME
     C                     MOVE *ALL'-'   @LINE  80
      *
     C                     ENDSR
      *-------------------------------------------------
      *  1ST SCREEN
      *-------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #OUT
     C                     MOVE *BLANK    D@PRT1
     C                     MOVE *BLANK    D@PRT2
     C                     MOVE *BLANK    D@PRT3
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------
      *  CHECK 1ST SCREEN
      *-------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
     C           K#KEY     CHAINAAMPL111             90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------
      *  OUTPUT
      *-------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     EXCPT@HED
      *
     C                     MOVE *BLANK    WME
     C                     MOVE *BLANK    WQN
     C                     Z-ADD*ZERO     WCH
     C                     Z-ADD*ZERO     WMQ
     C                     Z-ADD*ZERO     WCT
     C                     Z-ADD*ZERO     WMC
     C                     Z-ADD*ZERO     WDC
     C                     Z-ADD*ZERO     WDQ
     C           1         DO   15        I       20
     C                     Z-ADDCHG,I     WCH,I
     C                     MOVE SBN,I     K@LOC
      *
     C                     SELEC
     C           SKB,I     WHEQ 'A'
     C                     EXSR #A
      *
     C           SKB,I     WHEQ 'B'
     C                     EXSR #QUEN
      *
     C           SKB,I     WHEQ 'C'
     C                     EXSR #C
      *
     C           SKB,I     WHEQ 'E'
     C                     EXSR #WTHD
      *
     C           SKB,I     WHEQ 'F'
     C                     EXSR #F
      *
     C           SKB,I     WHEQ 'D'
     C                     EXSR #D
      *
     C           SKB,I     WHEQ '0'
     C                     EXSR #0
      *
     C           SKB,I     WHEQ '1'
     C                     EXSR #1
      *
     C           SKB,I     WHEQ '2'
     C                     EXSR #2
      *
     C           SKB,I     WHEQ '4'
     C                     EXSR #4
      *
     C           SKB,I     WHEQ '6'
     C                     EXSR #6
      *
     C           SKB,I     WHEQ '7'
     C                     EXSR #7
      *
     C                     ENDSL
      *
     C           SBM,I     IFNE 0
     C           SBM,I     CHAINFGBPL011             90
     C           *IN90     IFEQ *OFF
     C                     MOVELB2SMEI    WME,I
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           SKO,2     COMP *BLANK                   01
     C           SKO,3     COMP *BLANK                   02
     C           SKO,4     COMP *BLANK                   03
     C           SKO,5     COMP *BLANK                   04
     C                     EXCPT@AAM
     C           SKO,6     IFNE *BLANK
     C           SKO,7     COMP *BLANK                   01
     C           SKO,8     COMP *BLANK                   02
     C           SKO,9     COMP *BLANK                   03
     C           SKO,10    COMP *BLANK                   04
     C                     EXCPT@AAM2
     C                     ENDIF
     C           SKO,11    IFNE *BLANK
     C           SKO,12    COMP *BLANK                   01
     C           SKO,13    COMP *BLANK                   02
     C           SKO,14    COMP *BLANK                   03
     C           SKO,15    COMP *BLANK                   04
     C                     EXCPT@AAM3
     C                     ENDIF
      *
     C                     EXSR #CHLD
     C                     EXCPT@CHLD1
     C                     Z-ADD*ZERO     QQ
     C                     Z-ADD*ZERO     X       30
     C                     MOVE *BLANK    WIT
     C                     DO   *HIVAL
     C                     ADD  1         QQ
     C           ITM,QQ    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ADD  1         X
     C                     MOVE ITM,QQ    @@JHIN
     C                     MOVE @@JHN1    WWJHN1
     C                     MOVE @@JHN2    WWJHN2
     C                     MOVE @@JHN3    WWJHN3
     C                     MOVE WWJHIN    WIT,X
     C           X         IFEQ 4
     C                     EXCPT@CHLD2
     C                     MOVE *BLANK    WIT
     C                     Z-ADD*ZERO     X
     C                     ENDIF
     C                     ENDDO
      *
     C           X         IFNE *ZERO
     C                     EXCPT@CHLD2
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------
     C           #CHLD     BEGSR
      *-------------------------------------------------
     C                     MOVE *BLANK    ITM
     C                     Z-ADD*ZERO     QQ      30
     C           K#KEY     SETLLGHCPL21
     C           *IN95     DOUEQ*ON
     C           K#KEY     READEGHCPL21                  95
     C           *IN95     IFEQ *OFF
     C                     MOVE M7MHN1    @@JHN1
     C                     MOVE M7MHN2    @@JHN2
     C                     MOVE M7MHN3    @@JHN3
     C           @@JHIN    LOKUPITM                      96
     C           *IN96     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ADD  1         QQ
     C                     MOVE @@JHIN    ITM,QQ
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------
     C           #A        BEGSR
      *-------------------------------------------------
     C           K#ADH     SETGTABHPL03
     C           *IN90     DOUEQ*ON
     C           K#ADH     REDPEABHPL03                  90
     C           *IN90     IFEQ *OFF
     C           M6SKJY    ANDEQ*BLANK
     C                     Z-ADDM6SYUY    WCT,I
     C                     Z-ADDM6KTSU    WMQ,I
     C           M6KTSU    DIV  20        WDQ,I
     C           M6SYUY    IFNE 0
     C           WMQ,I     DIV  M6SYUY    WMC,I     H
     C           WDQ,I     DIV  M6SYUY    WDC,I     H
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------
     C           #QUEN     BEGSR
      *-------------------------------------------------
     C           K#ADH     SETGTADHPL03
     C           *IN90     DOUEQ*ON
     C           K#ADH     REDPEADHPL03                  90
     C           *IN90     IFEQ *OFF
     C           J6SKJY    ANDEQ*BLANK
     C                     MOVELJ6CO2P    WJ3
     C                     MOVE J6CO2P    WJ5
     C                     MOVE J6W       WQN,I
     C                     Z-ADDJ6SYOS    WCT,I
     C                     Z-ADDJ6KTSU    WMQ,I
     C           J6KTSU    DIV  20        WDQ,I
     C           J6SYOS    IFNE 0
     C           WMQ,I     DIV  J6SYOS    WMC,I     H
     C           WDQ,I     DIV  J6SYOS    WDC,I     H
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------
     C           #WTHD     BEGSR
      *-------------------------------------------------
     C           K#ADH     SETGTAAHPL03
     C           *IN90     DOUEQ*ON
     C           K#ADH     REDPEAAHPL03                  90
     C           *IN90     IFEQ *OFF
     C           L6SKJY    ANDEQ*BLANK
     C                     MOVELL6JOK1    K@JOKN
     C                     MOVE SKB,I     K@KANB
     C           K#APL     CHAINAAAPL01              26
     C  N26                MOVELA5JOKM    WQN,I
      *
     C                     Z-ADDL6SYOS    WCT,I
     C                     Z-ADDL6KTSU    WDQ,I
     C           L6KTSU    MULT 20        WMQ,I
     C           L6SYOS    IFNE 0
     C           WMQ,I     DIV  L6SYOS    WMC,I     H
     C           WDQ,I     DIV  L6SYOS    WDC,I     H
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
