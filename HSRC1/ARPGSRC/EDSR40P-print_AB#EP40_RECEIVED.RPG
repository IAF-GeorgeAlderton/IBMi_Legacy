     H            Y.
     F** EDSR40P *******************************************
     F*  PROGRAM: PRINT AB#EP40 RECEIVED                   *
     F*  WRITTEN: JW (SRA) 2024.10.23                      *
     F*----------------------------------------------------*
     FAB#EP40 IF  E           K        DISK
     FEDIPP03 O   E                    DISK
     FQPRINT  O   F     132     OF     PRINTER
      *--------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
      *--------------------------------------------------------
     C                     EXSR #INIT
      * READ AB#EP40 --------------------------------------
     C           *LOVAL    SETLLAB#EP40
     C                     DO   *HIVAL
     C                     READ AB#EP40                  98
     C   98                LEAVE
      *
     C           EPRTNR    IFEQ 'ASI'
     C           ENONY     ANDEQ*BLANK
     C                     MOVELEALFL     ENONY
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELEPRTNR    XPRTNR 10
     C                     MOVELETOKU     XTOKU   4
     C                     MOVELENONY     XNONY   4
     C                     MOVELENKOJ     X1NKOJ  1
     C                     MOVELENUKE     X1NUKE  4
     C                     MOVELEMHIN     X1MHIN 20
     C                     MOVELEODRN     X1ODRN 10
     C                     MOVELENDATE    X1DATE  80
     C                     Z-ADDESRYO     X1SRYO  60
     C                     ENDIF
      * BREAK?
     C           EPRTNR    IFNE XPRTNR
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     ADD  1         CNT1
      * GET QPC
     C                     MOVELETOKU     $TOKU
     C                     MOVELENONY     $NONY
     C                     MOVELEMHIN     $MHIN
     C                     MOVEL'USR'     $HTYP
     C                     MOVELTODAY     $DATE
     C                     CALL 'UTLR35D'
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $HTYP   3
     C                     PARM           $DATE   8
     C                     PARM           $SYOS   6
     C                     PARM           $RTN1   1
     C                     MOVEL$SYOS     @SYOS   60
     C           @SYOS     IFEQ 0
     C                     ADD  1         XBOX
     C                     ELSE
     C           ESRYO     DIV  @SYOS     @SHO    60
     C                     MVR            @REM    60
     C           @REM      IFNE 0
     C                     ADD  1         @SHO
     C                     ENDIF
     C                     ADD  @SHO      XBOX
     C                     ENDIF
      *
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      * PRINT
     C**         XNONY     IFEQ '5426'                     TOYOTA TSUSHO
     C           XNONY     IFEQ '5126'                     FORD EMDO
     C                     EXSR #PRINT
     C                     ENDIF
      * LOG
     C                     EXSR #LOG
      * RESET
     C                     MOVELEPRTNR    XPRTNR
     C                     MOVELETOKU     XTOKU
     C                     MOVELENONY     XNONY
     C                     MOVELENKOJ     X1NKOJ
     C                     MOVELENUKE     X1NUKE
     C                     MOVELEMHIN     X1MHIN
     C                     MOVELEODRN     X1ODRN
     C                     MOVELENDATE    X1DATE
     C                     Z-ADDESRYO     X1SRYO
     C                     Z-ADD0         CNT1
     C                     Z-ADD0         XBOX
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  OUTPUT LOG                                        *
      *----------------------------------------------------*
     C           #LOG      BEGSR
      *
     C                     CLEAREDIPP031
     C                     Z-ADDTODAY     E3RCHZ
     C                     Z-ADDNOW       E3RCTM
     C                     MOVEL'862'     E3RCID
     C                     MOVEL'AB#EP40' E3FILE
     C                     MOVEL#PGM      E3PGM
      *
     C                     MOVELXPRTNR    E3PRTN
     C                     MOVELXTOKU     E3TOKU
     C                     MOVELXNONY     E3NONY
     C                     MOVELX1NKOJ    E3NKOJ
     C                     MOVELX1NUKE    E3NUKE
     C                     MOVELX1MHIN    E3MHIN
     C                     Z-ADDX1DATE    E3NOHZ
     C                     Z-ADDX1SRYO    E3SRYO
     C                     MOVELX1ODRN    E3ODRN
     C                     Z-ADDXBOX      E3BOX
     C                     Z-ADDCNT1      E3ORD
      *
     C                     MOVE *BLANK    E3MSG            TEST
      *
     C                     WRITEEDIPP031
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE ' '       $RTN
     C                     TIME           SDATE
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SEQ#    30
     C                     MOVEL'Y'       FIRST   1
     C                     Z-ADD80        LIN#    30
     C                     Z-ADD0         CNT1    50
     C                     Z-ADD0         XBOX    50
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** RECEIVED EDI ORDE'
     O                                   60 'R **                '
     O                         TODAY     70 '    .  .  '
     O                         NOW       80 '  :  :  '
     O                                   83 'P.'
     O                         PAGE  Z   87
     O        E   03           @HDR
     O                                    4 'SEQ#'
     O                                   13 'CUST_ID'
     O                                   22 'CUST'
     O                                   28 'DLV#'
     O                                   31 'F'
     O                                   37 'DOCK'
     O                                   43 'MHIN'
     O                                   67 'ORDER#'
     O                                   82 'SHIP_DATE'
     O                                   93 'QTY'
     O                                  104 'BOX'
     O                                  115 '#_ORDERS'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         XPRTNR  +002
     O                         XTOKU   +002
     O                         XNONY   +002
     O                         X1NKOJ  +002
     O                         X1NUKE  +002
     O                         X1MHIN  +002
     O                         X1ODRN  +002
     O                         X1DATE  +002 '    /  /  '
     O                         X1SRYO1 +003
     O                         XBOX  1 +005
     O                         CNT1  1 +005
