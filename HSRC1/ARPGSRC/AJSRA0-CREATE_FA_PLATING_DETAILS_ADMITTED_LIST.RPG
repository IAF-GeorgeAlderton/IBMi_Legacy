     H            Y.
     F** AJSRA0 ************************************
     F*DATA CREATE  WHICH  FA PLATING DETAILS ADMITTED LIST*
     F* C:N.HAYAKAWA         94.02.24              *
     F**********************************************
     FAJSPWA0 CF  E                    WORKSTN
     FAJSPL15 IF  E           K        DISK
     FAJSPL14 IF  E           K        DISK
     FAJSWPA0 O   F      70            DISK                      A
     E                    GOK        10  2               xｮg gﾌﾞ](fﾞx])
     E                    ERM     1   3 60               d[ｰxｮﾈｰﾆﾞ
     I            DS
     I                                        1  20 GOK
     I                                        1   2 @GOK01
     I                                        3   4 @GOK02
     I                                        5   6 @GOK03
     I                                        7   8 @GOK04
     I                                        9  10 @GOK05
     I                                       11  12 @GOK06
     I                                       13  14 @GOK07
     I                                       15  16 @GOK08
     I                                       17  18 @GOK09
     I                                       19  20 @GOK10
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIMEX
     I                                        7  140WDATEX
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        5   60WBY
     I                                        7  100WYEAR
     I                                       11  120WMONTH
     I                                       13  140WDAY
     I                                        1   2 XJI
     I                                        3   4 XFN
     I                                        5   6 XBY
     I                                        7  10 XYEAR
     I                                       11  12 XMONTH
     I                                       13  14 XDAY
     I            DS
     I                                        1  100EDDAY
     I                                        1   4 @EDYY
     I                                        5   6 @EDMM
     I                                        7   8 @EDDD
     I                                        9  10 @EDHH
     I            DS
     I                                        1  100J1WIN
     I                                        1   40J1WINY
     I                                        5   60J1WINM
     I                                        7   80J1WIND
     I                                        9  100J1WINJ
     C           *ENTRY    PLIST
     C                     PARM           USW1    1
     C**************************
     C*  画面出力とチェック  *
     C**************************
     C           STEP0     TAG
     C                     MOVE '99'      @GOK01
     C                     MOVE *BLANK    @GOK02
     C                     MOVE *BLANK    @GOK03
     C                     MOVE *BLANK    @GOK04
     C                     MOVE *BLANK    @GOK05
     C                     MOVE *BLANK    @GOK06
     C                     MOVE *BLANK    @GOK07
     C                     MOVE *BLANK    @GOK08
     C                     MOVE *BLANK    @GOK09
     C                     MOVE *BLANK    @GOK10
     C                     MOVE *BLANK    @STYY
     C                     MOVE *BLANK    @STMM
     C                     MOVE *BLANK    @STDD
     C                     MOVE *BLANK    @STHH
     C                     TIME           WTIMEX
     C                     Z-ADD*DATE     WDATEX
     C                     MOVE XYEAR     @EDYY
     C                     MOVE XMONTH    @EDMM
     C                     MOVE XDAY      @EDDD
     C                     MOVE XJI       @EDHH
     C*
     C           STEP1     TAG
     C                     EXFMTAJSPWA01
     C                     SETOF                     998081
     C                     SETOF                     82
     C                     MOVE *BLANK    @ERR
     C* CMD-1チェック
     C           *INKA     IFEQ '1'
     C                     MOVE '*'       USW1    1
     C                     GOTO END
     C                     END
     C*号機チェック
     C                     SETOF                     70
     C           1         DO   10        I       20
     C           GOK,I     IFNE *BLANK
     C                     SETON                     70
     C                     END
     C                     END
     C           *IN70     IFEQ '0'
     C                     SETON                     9980
     C                     MOVE ERM,1     @ERR
     C                     GOTO STEP1
     C                     END
     C*開始日付チェック
     C           @STYY     IFEQ *BLANK
     C           @STMM     OREQ *BLANK
     C           @STDD     OREQ *BLANK
     C           @STHH     OREQ *BLANK
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*年*
     C           @STYY     IFGT XYEAR
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*月*
     C           @STMM     IFLT '01'
     C           @STMM     ORGT '12'
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*日*
     C           @STDD     IFLT '01'
     C           @STDD     ORGT '31'
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*終了日付チェック
     C           @EDYY     IFEQ *BLANK
     C           @EDMM     OREQ *BLANK
     C           @EDDD     OREQ *BLANK
     C           @EDHH     OREQ *BLANK
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C*年*
     C           @EDYY     IFGT XYEAR
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C*月*
     C           @EDMM     IFLT '01'
     C           @EDMM     ORGT '12'
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C*日*
     C           @EDDD     IFLT '01'
     C           @EDDD     ORGT '31'
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C* CMD-5チェック*
     C           *INKE     IFEQ '0'
     C                     GOTO STEP1
     C                     END
     C*最初の号機が９９かチェック*
     C           @GOK01    IFEQ '99'
     C                     GOTO ALLKBN
     C                     END
     C**************************************
     C*指定号機でメッキ排出実績の抜き出し*
     C* AJSPL15 KEY=KIBAN,WINDAY           *
     C**************************************
     C           KEY1      KLIST
     C                     KFLD           KKIBAN  2
     C                     KFLD           KWINYY  40
     C                     KFLD           KWINMM  20
     C                     KFLD           KWINDD  20
     C                     KFLD           KWINJI  20
     C                     MOVE @STYY     KWINYY
     C                     MOVE @STMM     KWINMM
     C                     MOVE @STDD     KWINDD
     C                     MOVE @STHH     KWINJI
     C*画面入力が有った号機を出す
     C           1         DO   10        I       20
     C           GOK,I     IFNE *BLANK
     C******
     C                     MOVE GOK,I     KKIBAN
     C           KEY1      SETLLAJSPL151
     C           LOOP1     TAG
     C                     SETOF                     10
     C                     READ AJSPL151                 10
     C* EOF?
     C           *IN10     IFEQ '1'
     C                     GOTO EXIT1
     C                     END
     C* DEL?
     C           J1SKJY    IFEQ 'D'
     C                     GOTO LOOP1
     C                     END
     C* J5HNTE=2? (再投入) *
     C*******>>  J5HNTE    IFNE '2'
     C*******>>            GOTO LOOP1
     C*******>>            END
     C* J1SAIK=1? (再投入) *
     C           J1SAIK    IFNE '1'
     C                     GOTO LOOP1
     C                     END
     C* GOUKI?
     C           J1MKKB    IFNE KKIBAN
     C                     GOTO EXIT1
     C                     END
     C* KEY DATE?
     C           J1WIN     IFGT EDDAY
     C                     GOTO EXIT1
     C                     END
     C* WORKFILE OUT
     C                     EXCPTOUT
     C                     SETON                     11
     C* TO LOOP
     C                     GOTO LOOP1
     C******
     C                     END
     C           EXIT1     TAG
     C                     ENDDO
     C*終了へ*
     C                     GOTO END
     C****************************************
     C*全号機指定でメッキ排出実績の抜き出し*
     C*   AJSPL14 KEY=WINDAY                 *
     C****************************************
     C           ALLKBN    TAG
     C           KEY2      KLIST
     C                     KFLD           KWINYY  40
     C                     KFLD           KWINMM  20
     C                     KFLD           KWINDD  20
     C                     KFLD           KWINJI  20
     C                     MOVE @STYY     KWINYY
     C                     MOVE @STMM     KWINMM
     C                     MOVE @STDD     KWINDD
     C                     MOVE @STHH     KWINJI
     C*全号機を出す
     C           KEY2      SETLLAJSPL141
     C           LOOP2     TAG
     C                     SETOF                     10
     C                     READ AJSPL141                 10
     C* EOF?
     C           *IN10     IFEQ '1'
     C                     GOTO EXIT2
     C                     END
     C* DEL?
     C           J1SKJY    IFEQ 'D'
     C                     GOTO LOOP2
     C                     END
     C* J5HNTE=2? (再投入) *
     C*******>>  J5HNTE    IFNE '2'
     C*******>>            GOTO LOOP2
     C*******>>            END
     C* J1SAIK=1? (再投入) *
     C           J1SAIK    IFNE '1'
     C                     GOTO LOOP2
     C                     END
     C* KEY DATE?
     C           J1WIN     IFGT EDDAY
     C                     GOTO EXIT2
     C                     END
     C* WORKFILE OUT
     C                     EXCPTOUT
     C                     SETON                     11
     C* TO LOOP
     C                     GOTO LOOP2
     C           EXIT2     TAG
     C*ＰＧＭ終了*
     C           END       TAG
     C           *IN11     IFEQ '0'
     C                     MOVE '*'       USW1
     C                     END
     C                     SETON                     LR
     C                     RETRN
     OAJSWPA0 EADD             OUT
     O                         J1HIN1     5
     O                         J1HIN2    10
     O                         J1HIN3    12
     O                         J1MKTE    13
     O                         J1MKSU    16
     O                         J1IRTE    17
     O                         J1IROK    18
     O                         J1TANJ    25
     O                         J1THAI    28
     O                         J1PAG1    30
     O                         J1PAG2    32
     O                         J1PAG3    34
     O                         J1PAG4    36
     O                         J1WINY    40
     O                         J1WINM    42
     O                         J1WIND    44
     O                         J1WINJ    46
     O                         J1WINF    48
     O                         J1MKKB    50
     O                         J1KEIY    54
     O                         J1KEIM    56
     O                         J1KEID    58
     O                         J1KEIJ    60
     O                         J1KEIF    62
