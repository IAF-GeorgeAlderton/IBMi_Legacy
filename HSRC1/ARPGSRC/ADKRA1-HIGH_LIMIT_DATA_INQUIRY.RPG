     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C           *ENTRY    PLIST
     C                     PARM           P1CR1   8
     C                     PARM           P1CB1   2
     C                     PARM           P1CR2   8
     C                     PARM           P1CB2   2
     C                     PARM           P1DATA  1
     C                     PARM           P1SORT  1
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P9TBOX 102
     C                     PARM           PCMD    2
      *
     C                     TIME           SDATE
     C                     Z-ADD0         P9TBOX
     C           KEYG5     KLIST
     C                     KFLD           W1CR1
     C                     KFLD           W1CB1
     C                     MOVE P1CR1     W1CR1   80
     C                     MOVE P1CB1     W1CB1   20
     C                     MOVE P1CR2     W1CR2   80
     C                     MOVE P1CB2     W1CB2   20
     C           W1C2      IFEQ 0
     C                     Z-ADD*HIVAL    W1C2
     C                     ENDIF
     C           W1CB2     IFEQ 0
     C                     Z-ADD*HIVAL    W1CB2
     C                     ENDIF
      *
     C                     MOVEL*BLANK    P#SHN
     C                     MOVELP1SHN1    P#SHN1
     C                     MOVELP1SHN2    P#SHN2
     C                     MOVELP1SHN3    P#SHN3
      *現在の生産指示処理終了情報
     C                     Z-ADD0         @@AP
     C                     MOVEL'0'       GET     1
     C           *HIVAL    SETGTADKPP001
     C                     READPADKPP001                 80
     C           *IN80     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           ZZSKJY    IFEQ 'D'
     C           ZZSKHZ    ANDLEWDATE
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     Z-ADDZZAPHZ    @@APHZ
     C                     Z-ADDZZAPBN    @@APBN
     C                     ENDIF
     C                     READPADKPP001                 80
     C                     ENDDO
      *
     C           KEYG5     SETLLADKPL211
     C                     READ ADKPL211                 80
     C           *IN80     DOWEQ'0'
     C           D2AP      ANDLEW1C2
     C           D2SKJY    IFEQ 'D'
     C           D2SKHZ    ANDLEWDATE
     C                     ELSE
     C***        D2CUT     IFNE 0
     C                     EXSR #SB400
     C***                  ENDIF
     C                     ENDIF
     C                     READ ADKPL211                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * SELECT DATA                                        *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       GET     1
      *現在の残りだけ照会
     C           P1DATA    IFEQ '2'
     C           D2AP      IFNE @@AP
     C                     MOVEL'0'       GET
     C                     ENDIF
     C           D2CUT     IFEQ 0
     C                     MOVEL'0'       GET
     C                     ENDIF
     C                     ENDIF
      *
     C           P#SHN     IFNE *BLANK
     C           D2SHN     IFNE P#SHN
     C                     MOVEL'0'       GET
     C                     ENDIF
     C                     ENDIF
      *
     C           GET       IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARADKWPA01
     C                     MOVELD2SHN1    W0SHN1
     C                     MOVELD2SHN2    W0SHN2
     C                     MOVELD2SHN3    W0SHN3
     C                     Z-ADDD2SYUY    W0SYUY
     C                     Z-ADDD2BARL    W0BARL
     C                     Z-ADDD2NSRY    W0NSRY
     C                     Z-ADDD2HASU    W0HASU
     C                     Z-ADDD2SRYO    W0SRYO
     C                     Z-ADDD2BSRY    W0BSRY
     C                     Z-ADDD2LIMT    W0LIMT
     C                     Z-ADDD2SRYA    W0SRYA
     C                     Z-ADDD2HKSA    W0HKSA
     C                     Z-ADDD2CUT     W0CUT
     C                     Z-ADDD2HASA    W0HASA
     C                     Z-ADDD2APHZ    W0APHZ
     C                     Z-ADDD2APBN    W0APBN
     C                     EXSR #SB510
     C***        P1DATA    IFEQ '2'
     C                     ADD  W0CUTH    P9TBOX
     C***                  ENDIF
      *連続上限カット回数
     C                     Z-ADD0         WKTIMS  30
     C           D2CUT     IFEQ 0
     C                     Z-ADD0         W0TIMS
     C                     ELSE
     C                     EXSR #SB590
     C                     Z-ADDWKTIMS    W0TIMS
     C                     ENDIF
     C           P1DATA    IFEQ '2'
     C           WKTIMS    IFEQ 0
     C                     GOTO ESB500
     C                     ENDIF
     C                     ENDIF
      *並び順
     C                     SELEC
      *上限カット（降順）
     C           P1SORT    WHEQ '1'
     C           1000000   SUB  W0CUTH    @@CUTH 122
     C                     MOVE @@CUTH    W0KEY1
      *上限カットが何日分か（降順）
     C           P1SORT    WHEQ '2'
     C           1000000   SUB  W0DOH     @@DOH  122
     C                     MOVE @@DOH     W0KEY1
      *品番
     C           P1SORT    WHEQ '3'
     C                     MOVELD2SHN1    W0KEY1
     C                     MOVELD2SHN2    W0KEY2
     C                     MOVELD2SHN3    W0KEY3
      *回数（降順）
     C           P1SORT    WHEQ '4'
     C           1000      SUB  W0TIMS    @@TIMS  30
     C                     MOVE @@TIMS    W0KEY1
     C                     ENDSL
      *連続上限カット回数
     C*****      D2CUT     IFEQ 0
     C*****                Z-ADD0         W0TIMS
     C*****                ELSE
     C*****                EXSR #SB590
     C*****                Z-ADDWKTIMS    W0TIMS
     C*****                ENDIF
      *直接入力　臨時かんばん
     C                     EXSR #SB600
      *
     C                     WRITEADKWPA01
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C           KEYSHN    KLIST
     C                     KFLD           D2SHN1
     C                     KFLD           D2SHN2
     C                     KFLD           D2SHN3
      *設定数
     C           KEYSHN    CHAINFCEPL011             22
     C           *IN22     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLESDATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     Z-ADDA2GEKN    W0GEKN
     C                     ENDIF
     C                     Z-ADD0         P9GEKN 120
     C           KEYSHN    CHAINFCEPL111             22
     C           *IN22     IFEQ '0'
     C           FCSKJY    ANDEQ'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     EXSR #SB444
     C                     Z-ADDP9GEKN    W0GEKN
     C                     ENDIF
      *日当り数量
     C           W0GEKN    DIV  20        W0SETD    H
      *日当り箱数
     C           W0SYUY    IFNE 0
     C           W0SETD    DIV  W0SYUY    W0BOXD    H
     C           W0CUT     DIV  W0SYUY    W0CUTH    H
     C                     ENDIF
      * DAYS OF HAND
     C           W0BOXD    IFNE 0
     C           W0CUTH    DIV  W0BOXD    W0DOH     H
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      *必要数                                            *
      *----------------------------------------------------*
     CSR         #SB444    BEGSR
      *
     C                     Z-ADD1         X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWLE10
     C           GET       ANDEQ'0'
     C           FGH,X     IFNE 0
     C           FGH,X     ANDLED2APHZ
     C                     EXSR #SB445
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB444    ENDSR
      *-----------------------------------*
      *月間必要数　２０日稼働           *
      *-----------------------------------*
     CSR         #SB445    BEGSR
      *
     C                     Z-ADD0         XXGEKN 120
     C                     Z-ADD0         XXCD    31
     C                     Z-ADD0         YYHIKN 120
     C                     Z-ADDFGK,X     XXGEKN 120
     C                     Z-ADDFCD,X     XXCD    31
     C           XXCD      IFNE 0
     C           XXGEKN    DIV  XXCD      YYHIKN 120
     C           YYHIKN    MULT 20        P9GEKN
     C                     ENDIF
      *
     CSR         ESB445    ENDSR
      *----------------------------------------------------*
      *連続上限カット回数                                *
      *----------------------------------------------------*
     CSR         #SB590    BEGSR
      *
     C                     Z-ADD0         WKTIMS  30
     C           KEY00     KLIST
     C                     KFLD           W0APHZ
     C                     KFLD           W0APBN
     C                     MOVEL'0'       ENDSW   1
      *生産指示実行履歴を最後から読む
     C           KEY00     SETGTADKPP001
     C                     READPADKPP001                 81
     C           *IN81     DOWEQ'0'
     C           ENDSW     ANDEQ'0'
     C           ZZSKJY    IFEQ 'D'
     C           ZZSKHZ    ANDLEWDATE
     C                     ELSE
     C                     EXSR #SB591
     C                     ENDIF
     C                     READPADKPP001                 81
     C                     ENDDO
      *
     CSR         ESB590    ENDSR
      *----------------------------------------------------*
      *連続上限カット回数                                *
      *----------------------------------------------------*
     CSR         #SB591    BEGSR
      *
     C           KEY22     KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
     C                     KFLD           ZZAPHZ
     C                     KFLD           ZZAPBN
      *該当の生産指示実行日便のデータがあり、上限カットあれば
      *回数をカウントアップ
     C                     MOVEL'0'       GET22   1
     C           KEY22     SETLLADKPL221
     C           KEY22     READEADKPL221                 82
     C           *IN82     DOWEQ'0'
     C           GET22     ANDEQ'0'
     C           D2SKJY    IFEQ 'D'
     C           D2SKHZ    ANDLE*DATE
     C                     ELSE
     C           D2CUT     IFGT 0
     C           D2CUT     ANDGED2BSRY
     C                     MOVEL'1'       GET22   1
     C                     ENDIF
     C                     ENDIF
     C           KEY22     READEADKPL221                 82
     C                     ENDDO
     C           GET22     IFEQ '0'
     C                     MOVEL'1'       ENDSW
     C                     ELSE
     C                     ADD  1         WKTIMS
     C                     ENDIF
      *
     CSR         ESB591    ENDSR
      *----------------------------------------------------*
      *直接入力　臨時                                    *
      *----------------------------------------------------*
     CSR         #SB600    BEGSR
      *
     C           KEYD2     KLIST
     C                     KFLD           W0SHN1  5
     C                     KFLD           W0SHN2  5
     C                     KFLD           W0SHN3  2
     C                     KFLD           W0APHZ  80
     C                     KFLD           W0APBN  20
     C           KEYD2     SETLLADKPP111
     C           KEYD2     READEADKPP111                 82
     C           *IN82     DOWEQ'0'
     C           D1SKJY    IFEQ 'D'
     C           D1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     SELEC
     C           D1TYPE    WHEQ 'HN'
     C                     ADD  D1MAIS    W0HND
     C           D1TYPE    WHEQ 'RN'
     C                     ADD  D1MAIS    W0RNJ
     C                     ENDSL
     C                     ENDIF
     C           KEYD2     READEADKPP111                 82
     C                     ENDDO
      *
     CSR         ESB600    ENDSR
