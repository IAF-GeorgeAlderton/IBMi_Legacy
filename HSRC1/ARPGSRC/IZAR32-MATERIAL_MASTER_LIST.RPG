     FIZAPW32 CF  E                    WORKSTN
     FIZAPL04 IF  E           K        DISK
     FIZAPL10 IF  E           K        DISK
     FMBEPL02 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER                        UC
      *
      *------------------------------------------------------
     E                    CMD     1   1 60
     E                    ARY        60  1
      *------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C           KEYZB1    KLIST
     C                     KFLD           ZCZAIS
     C                     KFLD           ZCZAIK
     C                     KFLD           ZCKOJE
     C                     KFLD           ZCKAKE
     C           KEYF21    KLIST
     C                     KFLD           ZBSHN1
     C                     KFLD           ZBSHN2
     C                     KFLD           ZBSHN3
      *
      *
     C                     MOVE '01'      W@ID    2
     C                     Z-ADD1         D@CPY
     C                     TIME           WTIME   60
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *------------------------------------------------------
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRNT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *------------------------------------------------------
     C                     SETOF                     616299
      *
     C           D@SUPP    IFNE *BLANK
     C                     MOVE D@SUPP    K@SUPL  40
     C           K@SUPL    CHAINIZAPL04              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C           D@CPY     IFEQ *ZERO
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #PRNT     BEGSR
      *------------------------------------------------------
     C                     MOVEACMD,1     ARY
     C                     MOVE D@CPY     @CPY    2
     C                     MOVEA@CPY      ARY,30
     C                     MOVEAARY       P@CMD
     C                     Z-ADD70        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN QPRINT
      *
     C                     Z-ADD*ZERO     W@SUPL  40
     C           D@SUPP    IFNE *BLANK
     C           K@SUPL    SETLLIZAPL04
     C                     ELSE
     C           *LOVAL    SETLLIZAPL04
     C                     ENDIF
      *
     C           *IN80     DOUEQ*ON
     C           D@SUPP    IFNE *BLANK
     C           K@SUPL    READEIZAPL04                  80
     C                     ELSE
     C                     READ IZAPL04                  80
     C                     ENDIF
      *
     C           *IN80     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSTYY    ANDEQ9999
      *
     C           W@SUPL    IFEQ *ZERO
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     Z-ADD*ZERO     W@SUPL
     C                     ENDIF
      *
     C           W@SUPL    IFNE ZCKAKE
     C           W@SUPL    IFNE *ZERO
     C                     EXCPT@SKP
     C                     ENDIF
     C                     MOVE *ON       *IN11
     C                     ELSE
     C                     MOVE *OFF      *IN11
     C                     ENDIF
      * ACTUAL
     C                     EXSR #ACT
     C                     EXCPT@DTL
     C                     Z-ADDZCKAKE    W@SUPL
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #ACT      BEGSR
      *------------------------------------------------------
     C                     Z-ADD*ZERO     W@ACT   70
     C           KEYZB1    SETLLIZAPL101
     C           *IN81     DOUEQ*ON
     C           KEYZB1    READEIZAPL101                 81
     C           *IN81     IFEQ *OFF
     C           ZBSKJY    ANDEQ*BLANK
     C                     Z-ADD0         W@QTY   90
      *
     C           KEYF21    SETLLMBEPL021
     C           *IN82     DOUEQ*ON
     C           KEYF21    READEMBEPL021                 82
     C           *IN82     IFEQ *OFF
     C           F2SKJY    ANDEQ*BLANK
     C                     ADD  F2GOKE    W@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C           W@QTY     MULT ZBSOZI    WKJIT  112
     C           WKJIT     DIV  1000      WGOSO1  80H
     C                     ADD  WGOSO1    W@ACT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  113
