     H            Y.
     H** RGAR21 ******************************
     H* UPDATE EMPLOYEE MASTER               *
     H*     Y.MAEDA           2010.11.18     *
     H****************************** RGAR21 **
     FRGAPW21 CF  E                    WORKSTN
     FRGAPL21 UF  E           K        DISK                      A
     E                    ER      1   8 60
     I            DS
      *
      * PARM
     C           *ENTRY    PLIST
     C                     PARM           P@USR  10
      * KEY
      *
      * INITIALIZE
     C                     MOVEL*BLANK    @KBN
     C                     MOVEL*BLANK    @ENUM
     C                     TIME           WTIME   60
     C           STEP1     TAG
     C                     EXFMTRGAPW211
     C                     SETOF                     992122
      *
      * CHECK
     C           *IN01     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *IN12     IFEQ '1'
     C                     CALL 'RGAR22'
     C                     GOTO STEP1
     C                     END
      *
     C           @KBN      IFEQ *BLANK
     C                     MOVELER,1      MSG
     C                     SETON                     9921
     C                     GOTO STEP1
     C                     END
      *
     C           @KBN      IFLT '0'
     C           @KBN      ORGT '2'
     C                     MOVELER,2      MSG
     C                     SETON                     9921
     C                     GOTO STEP1
     C                     END
      *
     C           @ENUM     IFEQ *BLANK
     C                     MOVELER,5      MSG
     C                     SETON                     9922
     C                     GOTO STEP1
     C                     END
      *
      * UPDATE TYPE CHECK
     C           @KBN      IFEQ '0'
     C                     EXSR #DLT
     C                     END
      *
     C           @KBN      IFEQ '1'
     C                     EXSR #CHG
     C                     END
      *
     C           @KBN      IFEQ '2'
     C                     EXSR #ADD
     C                     END
      *
     C                     GOTO STEP1
      *
     C                     SETON                     LR
     C                     RETRN
      *------*
      *DELETE*
      *------*
     CSR         #DLT      BEGSR
     C                     SETOF                     88
     C           @ENUM     CHAINRGAPL211             88
     C           *IN88     IFEQ '0'
     C           R2SKJY    ANDEQ'D'
     C           R2SKHZ    ANDLE*DATE
     C                     SETON                     88
     C                     END
      *
     C           *IN88     IFEQ '1'
     C                     MOVELER,4      MSG
     C                     SETON                     9922
     C                     GOTO EDLT
     C                     END
      *
     C                     MOVELR2ENAM    @ENAM
     C                     SETON                     35
     C           STEP2     TAG
     C                     EXFMTRGAPW212
     C                     SETOF                     9923
      *CHECK
     C           *IN03     IFEQ '1'
     C                     GOTO EDLT
     C                     END
      *
     C           *IN05     IFEQ '0'
     C                     GOTO STEP2
     C                     END
      *
     C                     MOVEL'D'       R2SKJY
     C                     Z-ADD*DATE     R2SKHZ
     C                     Z-ADD*DATE     R2KOHZ
     C                     Z-ADDWTIME     R2KOJK
     C                     MOVELP@USR     R2KOME
     C                     MOVEL'RGAR21'  R2KPGM
     C                     UPDATRGAPL211
      *
     CSR         EDLT      ENDSR
      *------*
      *CHANGE*
      *------*
     CSR         #CHG      BEGSR
     C                     SETOF                     88
     C           @ENUM     CHAINRGAPL211             88
     C           *IN88     IFEQ '0'
     C           R2SKJY    ANDEQ'D'
     C           R2SKHZ    ANDLE*DATE
     C                     SETON                     88
     C                     END
      *
     C           *IN88     IFEQ '1'
     C                     MOVELER,3      MSG
     C                     SETON                     9922
     C                     GOTO ECHG
     C                     END
      *
     C                     MOVELR2ENAM    @ENAM
     C                     SETOF                     35
     C           STEP3     TAG
     C                     EXFMTRGAPW212
     C                     SETOF                     9923
     C           *IN03     IFEQ '1'
     C                     GOTO ECHG
     C                     END
      *
     C           @ENAM     IFEQ *BLANK
     C                     MOVELER,7      MSG
     C                     SETON                     9923
     C                     GOTO STEP3
     C                     END
      *
     C           *IN05     IFEQ '0'
     C                     GOTO STEP3
     C                     END
      *
     C                     Z-ADD*DATE     R2KOHZ
     C                     Z-ADDWTIME     R2KOJK
     C                     MOVELP@USR     R2KOME
     C                     MOVEL'RGAR21'  R2KPGM
     C                     MOVEL@ENUM     R2ENUM
     C                     MOVEL@ENAM     R2ENAM
     C                     UPDATRGAPL211
      *
     CSR         ECHG      ENDSR
      *------*
      *ADD   *
      *------*
     CSR         #ADD      BEGSR
     C                     SETOF                     88
     C           @ENUM     CHAINRGAPL211             88
     C           *IN88     IFEQ '0'
     C           R2SKJY    IFEQ 'D'
     C           R2SKHZ    ANDLE*DATE
     C                     SETON                     27
     C                     ELSE
     C                     MOVELER,8      MSG
     C                     SETON                     9922
     C                     GOTO EADD
     C                     END
     C                     END
      *
     C                     MOVEL*BLANK    @ENAM
     C                     SETOF                     35
     C           STEP4     TAG
     C                     EXFMTRGAPW212
     C                     SETOF                     9923
     C                     SETOF                     2425
      *CHECK
     C           *IN03     IFEQ '1'
     C                     GOTO EADD
     C                     END
      *
     C           @ENAM     IFEQ *BLANK
     C                     MOVELER,7      MSG
     C                     SETON                     9923
     C                     GOTO STEP4
     C                     END
      *
     C           *IN05     IFEQ '0'
     C                     GOTO STEP4
     C                     END
      *
     C           *IN27     IFEQ '1'
     C                     MOVEL*BLANK    R2SKJY
     C                     Z-ADD0         R2SKHZ
     C                     Z-ADD*DATE     R2KOHZ
     C                     Z-ADDWTIME     R2KOJK
     C                     MOVELP@USR     R2KOME
     C                     MOVEL'RGAR21'  R2KPGM
     C                     MOVEL@ENUM     R2ENUM
     C                     MOVEL@ENAM     R2ENAM
     C                     UPDATRGAPL211
     C                     GOTO EADD
     C                     END
      *
     C                     CLEARRGAPL211
     C                     Z-ADD*DATE     R2KOHZ
     C                     Z-ADDWTIME     R2KOJK
     C                     MOVELP@USR     R2KOME
     C                     MOVEL'RGAR21'  R2KPGM
     C                     MOVEL@ENUM     R2ENUM
     C                     MOVEL@ENAM     R2ENAM
      *
     C                     WRITERGAPL211
     CSR         EADD      ENDSR
** ERR   1 ...+... 2 ...+... 3 ...+... 4 ...+... 5 ...+... 6 ...+... 7
ER-01 INPUT UPDATE TYPE
ER-02 UPDATE TYPE IS WRONG < 0, 1, 2 >
ER-03 THERE IS NO DATA
ER-04 ALREADY DELETED
ER-05 INPUT EMPLOYEE NUMBER
ER-06
ER-07 INPUT ENPLOYEE NAME
ER-08 ALREADY EXIST
