      *
     CSR         EADH      ENDSR
      *----------------------------------------------------*
      * AKBPL03                                            *
      *----------------------------------------------------*
     CSR         #AKB      BEGSR
      *
     C                     Z-ADDL1KOHZ    D1KOHZ
     C                     MOVELL1KOME    D1KOME
     C                     MOVELL1SHN1    D1SHN1
     C                     MOVELL1SHN2    D1SHN2
     C                     MOVELL1SHN3    D1SHN3
      *
     C                     Z-ADDL1CMAI    D1CMAI
     C                     Z-ADDL1DAND    D1DAND
     C                     Z-ADDL1KYOT    D1KYOT
     C                     Z-ADDL1FRYO    D1FRYO
     C                     Z-ADDL1SENY    D1SENY
     C                     Z-ADDL11NAI    D11NAI
     C                     Z-ADDL12NAI    D12NAI
     C                     Z-ADDL1JISK    D1JISK
     C                     Z-ADDL1AUAJ    D1AUAJ
     C                     Z-ADDL1OTHH    D1OTHH
     C                     MOVELL1CMT1    D1CMT1
     C                     MOVELL1CMT2    D1CMT2
      *
     CSR         EAKB      ENDSR
      *-----------------------------------------------------*
      * ACHWP01                                            *
      *----------------------------------------------------*
     CSR         #ANZ      BEGSR
      *
     C                     Z-ADDZ1KOHZ    D1KOHZ
     C                     MOVE Z1KOME    D1KOME
     C                     Z-ADDZ1CMAI    D1CMAI
     C                     Z-ADDZ1DAND    D1DAND
     C                     Z-ADDZ1KYOT    D1KYOT
     C                     Z-ADDZ1FRYO    D1FRYO
     C                     Z-ADDZ1SENY    D1SENY
     C                     Z-ADDZ11NAI    D11NAI
     C                     Z-ADDZ12NAI    D12NAI
     C                     Z-ADDZ1JISK    D1JISK
     C                     Z-ADDZ1AUAJ    D1AUAJ
     C                     Z-ADDZ1OTHH    D1OTHH
     C                     MOVELZ1CMT1    D1CMT1
     C                     MOVELZ1CMT2    D1CMT2
      *
     CSR         EANZ      ENDSR
      *----------------------------------------------------*
%0001 * UPDATE WORK FILE BY AUTO ADJUSTMENT                *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYZ11    CHAINACHWP011             88
     C                     MOVELWSID      Z1JOBM
     C                     MOVELUSID      Z1USER
     C                     MOVELJBNO      Z1WNBR
     C                     Z-ADD*DATE     Z1DATE
     C                     MOVELP@FPGM    Z1FPGM
      *
     C                     Z-ADD*DATE     Z1KOHZ
     C                     TIME           Z1KOTM
     C                     MOVELUSID      Z1KOME
     C                     MOVELPGMNM     Z1KOPG
      *
     C                     MOVELP@JBN1    Z1JBN1
     C                     MOVELP@JBN2    Z1JBN2
     C                     MOVELP@JBN3    Z1JBN3
     C                     MOVELP@JBN4    Z1JBN4
     C                     Z-ADDP@UKYY    Z1UKYY
     C                     Z-ADDP@UKMM    Z1UKMM
     C                     Z-ADDP@UKDD    Z1UKDD
     C                     Z-ADDP@UBIN    Z1UBIN
      *
     C                     Z-ADDD1DAND    Z1DAND
     C                     Z-ADDD1KYOT    Z1KYOT
     C                     Z-ADDD1FRYO    Z1FRYO
     C                     Z-ADDD1SENY    Z1SENY
     C                     Z-ADDD11NAI    Z11NAI
     C                     Z-ADDD12NAI    Z12NAI
     C                     Z-ADDD1JISK    Z1JISK
     C                     Z-ADDD1OTHH    Z1OTHH
     C                     MOVEL*BLANK    Z1CMT1
     C                     MOVELCMT01     Z1CMT1
     C                     MOVEL*BLANK    Z1CMT2
      *
     C                     ADD  1         Z1CMAI
     C                     ADD  1         Z1AUAJ
      *
     C           *IN88     IFEQ '0'
     C                     UPDATACHWP011
     C                     ELSE
     C                     WRITEACHWP011
     C                     ENDIF
