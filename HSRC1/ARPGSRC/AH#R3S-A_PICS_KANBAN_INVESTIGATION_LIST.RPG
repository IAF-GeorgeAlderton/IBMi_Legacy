     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
     C                     Z-ADDCBSYUY    WSYOS
     C                     END
      *
     C                     Z-ADD1         A       20
     C           1         DO   31        A
     C           HZM,A     IFEQ *BLANK
      *
     C           HMH,A     IFNE 0
     C                     SETON                     U207
