     C           $$SKJY    IFEQ 'D'
     C           $$SKHZ    ANDLE*DATE
     C                     ELSE
     C           $$KEYM    IFGE WYM
      *
     C                     Z-ADDAHYMD     WKYMD
     C                     Z-ADDAHBIN     WKBIN
     C                     MOVEL$$SHN1    WSHN1
     C                     MOVEL$$SHN2    WSHN2
     C                     MOVEL$$SHN3    WSHN3
     C                     Z-ADD0         WTOKU
     C                     Z-ADD0         WNONY
     C                     MOVEL*BLANK    WNKOJ
     C                     MOVEL*BLANK    WNUKE
     C                     MOVEL'K'       WSKKB
     C                     MOVEL'35'      WGYOM
      *
