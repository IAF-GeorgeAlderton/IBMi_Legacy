     C           *IN20     IFEQ '0'
     C           CASKJY    IFEQ *BLANK
     C*          CANOHZ    ANDGT*DATE
      *
     C                     SETON                     U207
     C                     Z-ADDAHYMD     WKYMD   80
     C                     Z-ADDAHBIN     WKBIN   20
     C                     MOVELCASHN1    WSHN1   5
     C                     MOVELCASHN2    WSHN2   5
     C                     MOVELCASHN3    WSHN3   2
     C                     Z-ADDCATOKU    WTOKU   40
     C                     Z-ADDCANONY    WNONY   40
     C                     MOVELCANKOJ    WNKOJ   1
     C                     MOVELCANUKE    WNUKE   4
     C                     Z-ADDCANOHZ    WNOHZ   80
     C                     MOVELCASKKB    WSKKB   1
     C                     MOVELCAGYOM    WGYOM   2
     C                     Z-ADDCANSRY    WNSRY   70
     C                     Z-ADDCATEHZ    WTEHZ   80
     C                     Z-ADDCATEHF    WTEHF   40
     C                     EXCPTF02
      *
     C                     END
     C                     END
     C  N20                END
     C                     CLOSEAD#PL11
      *
     C*----------------------------------------------*
     C*  ..Ａ－ＰＩＣＳ計画発行受注累積ファイル..  *
     C*----------------------------------------------*
     C                     OPEN BTAPL02
     C           KEY1      SETLLBTAPL021
     C                     Z-ADDUDATE     WYMD
      *
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEBTAPL021                 20
     C           *IN20     IFEQ '0'
     C           BTNOHZ    ANDGT*DATE
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     ELSE
     C           BTKEYM    IFGE WYM
      *
     C                     Z-ADDAHYMD     WKYMD
     C                     Z-ADDAHBIN     WKBIN
     C                     MOVELBTSHN1    WSHN1
     C                     MOVELBTSHN2    WSHN2
     C                     MOVELBTSHN3    WSHN3
     C                     Z-ADDBTTOKU    WTOKU
     C                     Z-ADDBTNONY    WNONY
     C                     MOVELBTNKOJ    WNKOJ
     C                     MOVELBTNUKE    WNUKE
     C                     MOVEL'S'       WSKKB
     C                     MOVEL'27'      WGYOM
      *
     C                     Z-ADDBTKEYM    WHYM
      *
     C                     Z-ADD1         A       20
     C           1         DO   31        A
     C           HMA,A     IFNE 0
     C           HBU,A     IFEQ 0
      *
     C                     SETON                     U207
     C                     Z-ADDA         WHDD
     C                     Z-ADDWHYMD     WNOHZ
     C                     Z-ADDWHYMD     WTEHZ
     C                     Z-ADD800       WTEHF
     C           HMA,A     MULT BTSYUY    WNSRY
     C                     EXCPTF02
      *
     C                     END
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N20                END
