     C                     Z-ADDWHYMD     WNOHZ
     C                     Z-ADDWHYMD     WTEHZ
     C                     Z-ADD800       WTEHF
     C           HPH,A     MULT WSYOS     WNSRY
     C                     EXCPTF02
     C                     END
      *
     C                     END
     C                     END
      *
