     C                     SETOF                     25
     C           KEY3      CHAINGDLPL251             25
      *
     C           *IN25     IFEQ '0'
     C           LDSKJY    IFEQ 'D'
     C           LDSKHZ    ANDLE*DATE
     C                     SETON                     25
     C                     END
     C                     END
      *
     C                     MOVE *BLANK    LDSKJY
