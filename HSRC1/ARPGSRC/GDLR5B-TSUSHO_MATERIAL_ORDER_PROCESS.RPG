     C                     Z-ADDLAZAIK    LDZAIK
     C                     MOVELLAZETI    LDZETI
     C                     MOVELLAPTCD    LDPTCD
     C           *IN25     IFEQ '1'
     C                     Z-ADDMAIS      LDSTCK
     C                     ELSE
     C                     ADD  MAIS      LDSTCK
     C                     END
     C           *IN25     IFEQ '1'
     C                     WRITEGDLPL251
     C                     ELSE
     C                     UPDATGDLPL251
     C                     END
      *
     C                     ENDDO
      *
