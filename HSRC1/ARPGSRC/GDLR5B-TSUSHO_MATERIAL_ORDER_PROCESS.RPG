     C                     TIME           W@TIME
     C                     Z-ADD*ZERO     ITEM    50
      *
     C                     Z-ADD*ZERO     WWODNO
     C           KEY5      CHAINAFCNP911             22
     C           *IN22     IFEQ '1'
     C                     Z-ADDW@DY      CAREYY
     C                     Z-ADDW@DM      CAREMM
     C                     Z-ADD1         CARENO
     C                     Z-ADDCAODNO    WWODNO
     C                     WRITEAFCNP911
     C                     ELSE
     C                     ADD  1         CARENO
     C                     Z-ADDCAODNO    WWODNO
     C                     UPDATAFCNP911
     C                     END
