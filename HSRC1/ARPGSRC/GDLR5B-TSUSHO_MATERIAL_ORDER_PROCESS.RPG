      *-------------------*
      * PRINT ORDER SHEET *
      *-------------------*
     C           OSIRE     SETLLGDLPL01
      *
     C                     DO   *HIVAL
     C*
     C           OSIRE     READEGDLPL01                  20
     C           *IN20     IFEQ *ON
     C                     LEAVE
     C                     END
     C           LASKJY    IFEQ 'D'
     C           LASKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C           LAPTCD    IFNE 'W'
     C                     ITER
     C                     END
     C*
     C                     Z-ADD*DATE     LAKOHZ
     C                     TIME           LAKOTM
     C                     MOVEL#USER     LAKOME
     C                     MOVE '2BUPD'   LAKOME
     C                     Z-ADD*ZERO     MAI     30
     C                     Z-ADD*ZERO     MAIS    30
     C                     Z-ADD*ZERO     ZAN     30
     C                     Z-ADD*ZERO     LOTO    30
      *
     C                     SETOF                     5556
     C           KEY1      SETGTIZAPL03
      *
     C                     DO   *HIVAL
     C*
     C           KEY1      REDPEIZAPL031                 55
     C           *IN55     IFEQ *ON
     C                     LEAVE
     C                     END
     C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C           ZCUKHZ    IFLE *DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     ELSE
     C                     ITER
     C                     END
      *
     C                     SETON                     56
     C                     Z-ADDZCLOTO    LOTO
     C                     LEAVE
     C*
     C                     ENDDO
      *
     C           *IN56     IFEQ *OFF
     C                     ITER
     C                     END
      *
     C           LOTO      IFNE *ZERO
     C           LAMAIS    DIV  LOTO      MAI
     C                     MVR            ZAN
     C                     END
     C           LAMAIS    SUB  ZAN       MAIS
      *------------------------*
      * CHECK NUMBER OF KANBAN *
      *------------------------*
     C           MAIS      IFEQ 0
     C                     ITER
     C                     END
      *
     C           ZAN       IFGT 0
     C                     Z-ADDZAN       LAMAIS
     C                     ELSE
     C                     MOVEL'D'       LASKJY
     C                     Z-ADD*DATE     LASKHZ
     C                     MOVE '2BDLT'   LAKOME
     C                     END
      *
     C                     UPDATGDLPL011
     C*
     C                     EXSR @OUTF
     C*
     C                     MOVE *BLANK    LBSKJY
     C                     Z-ADD0         LBSKHZ
     C                     Z-ADD*DATE     LBKOHZ
     C                     TIME           LBKOTM
     C                     MOVEL#USER     LBKOME
      *
