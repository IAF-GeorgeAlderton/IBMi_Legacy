     FFCEPL01 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FAB#PL70 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PL65 IF  E           K        DISK
     FGDKPL02 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    TTL     1   1 23
     E                    DAT         5  8 0
     E                    DT4         5  4 0
     E                    QT1         5  9 0
     E                    QT2         5  9 0
     E                    QT3         5  9 0
      *------------------------------------------------------------
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@HMS
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@MM
     I                                       13  140W@DD
     I            DS
     I                                        1  20 A2KEY
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
     I                                       13  20 BLANK
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80ABYMD
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
      * PART
     C                     EXSR #OUT1
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#A10     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#AP70    KLIST
     C                     KFLD           BATOKU
     C                     KFLD           @@NONY  4
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           @@ODRN 10
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           K@NOBN  2
     C                     KFLD           BADEYY
     C                     KFLD           BADEMM
     C                     KFLD           BADEDD
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#65      KLIST
     C                     KFLD           @@NONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BANOBN
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C                     KFLD           K@OR12 12
      *
      *
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     MOVE *ALL'-'   @@LIN1100
     C                     MOVE *BLANK    A2KEY
      *
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD*ZERO     DAT
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     M       30
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8YOBI    ANDLE5
     C                     ADD  1         M
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C                     Z-ADDK@YMD     DAT,M
     C           M         IFEQ 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADAT
      *
     C                     Z-ADDDAT       DT4
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PART
      *------------------------------------------------------
     C           #OUT1     BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     MOVELTTL,1     HEDR   23
     C                     MOVE *ON       *IN50
      *
     C           *IN80     DOUEQ*ON
     C                     READ FCEPL01                  80
     C           *IN80     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
      * IMPORT?
      * SUPPLIER IS '0170'?
     C           A2KEY     CHAINGDKPL02              91
     C           *IN91     IFEQ *ON
TCHK C           ISVEND    ORNE '0170'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SHP
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SHIPMENT RESULT
      *------------------------------------------------------
     C           #SHP      BEGSR
      *
     C                     Z-ADD*ZERO     QT1
     C                     Z-ADD*ZERO     QT2
      *
     C           1         DO   5         X       30
     C                     Z-ADDDAT,X     K@YMD
     C           K#A10     SETLLAB#PL18
     C           *IN90     DOUEQ*ON
     C           K#A10     READEAB#PL18                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANONY    ANDNE0323
     C           BASRYO    DIV  A2SSYS    @BOX    50
     C                     Z-ADD*ZERO     @@QTY   70
     C                     MOVE BANONY    @@NONY
     C                     MOVE BANOBN    K@NOBN
     C                     MOVE BAODRN    @@ODRN
     C                     MOVE *OFF      *IN82
     C           K#AP70    SETLLAB#PL70
     C           *IN81     DOUEQ*ON
     C           K#AP70    READEAB#PL70                  81
     C           *IN81     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKHENK    ANDEQ*BLANK
     C           EKSRYO    ANDNE*ZERO
     C                     ADD  1         QT2,X
     C                     MOVE *ON       *IN82
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN82     IFEQ *OFF
     C                     MOVELBAINVN    @@ODRN
     C           K#AP70    SETLLAB#PL70
     C           *IN81     DOUEQ*ON
     C           K#AP70    READEAB#PL70                  81
     C           *IN81     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKSRYO    ANDNE*ZERO
     C                     ADD  1         QT2,X
     C                     MOVE *ON       *IN82
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           *IN82     IFEQ *OFF
     C                     MOVELBAINVN    K@OR12
     C           K#65      SETLLAB#PL65
     C           *IN81     DOUEQ*ON
     C           K#65      READEAB#PL65                  81
     C           *IN81     IFEQ *OFF
     C           A6SRYO    ANDGT*ZERO
     C                     ADD  1         QT2,X
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           @@QTY     IFGT BASRYO
     C                     Z-ADDBASRYO    @@QTY
     C                     ENDIF
      *
     C           BASRYO    DIV  A2SSYS    @BOX    50
     C                     ADD  @BOX      QT1,X
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C           QT1       SUB  QT2       QT3
     C                     XFOOTQT3       @DIF    90
     C           @DIF      IFGT *ZERO
     C           1         DO   5         X
     C           QT3,X     IFEQ 0
     C                     Z-ADD0         QT1,X
     C                     Z-ADD0         QT2,X
     C                     ENDIF
     C                     ENDDO
     C                     EXSR #PRT1
     C                     ENDIF
      *
     C                     ENDSR
