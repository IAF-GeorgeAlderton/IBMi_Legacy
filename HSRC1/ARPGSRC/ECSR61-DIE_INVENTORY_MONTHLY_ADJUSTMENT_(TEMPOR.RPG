     H            Y.
     F** ECSR50 **********************************
     F* APPLY DIE MONTHLY INVENTORY RESULT
     F* PROGRAM ID. : ECSR50
     F* CREATE DATE. : SEP.30.02                 *
     F* AUTHOR.         : TCH                    *
     F********************************** ECQR15 **
     FECSPL10 IF  E           K        DISK
     FECSPL20 IF  E           K        DISK
     FECSWL10 IF  E           K        DISK
     FECSPL05 IF  E           K        DISK
     FQPRINT  O   F     132            PRINTER
      *-----------------------------------------------------------
      *-----------------------------------------------------------
     IECSWP101
     I              E1DATE                          W1DATE
     I              E1KAT1                          W1KAT1
     I              E1KAT2                          W1KAT2
     I              E1KAT3                          W1KAT3
     I              E1KAT4                          W1KAT4
     I              E1LOC1                          W1LOC1
     I              E1LOC2                          W1LOC2
     I              E1LOC3                          W1LOC3
     I              E1LOC4                          W1LOC4
     I              E1SQTY                          W1SQTY
      *
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80EQYMD
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     I                                        7   80EQYODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C                     EXSR #CHK
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
      *
     C           KEY1      KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C******               KFLD           W1KAT4
     C                     KFLD           D@DATE
     C           KEY2      KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C*****                KFLD           W1KAT4
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
     C           K#EC1     KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#EC11    KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C           K#WEC     KLIST
     C                     KFLD           D@DATE
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #CHK      BEGSR
      *
     C                     Z-ADD20021031  D@DATE  80
     C                     Z-ADD20021031  K@YMD
     C           D@DATE    SETLLECSWL10
     C           *IN90     DOUEQ*ON
     C           D@DATE    READEECSWL10                  90
     C           *IN90     IFEQ *OFF
      * IN
     C                     Z-ADD*ZERO     @IQTY   50
     C           KEY1      SETLLECSPL20              95
     C           *IN95     DOUEQ*ON
     C           KEY2      READEECSPL20                  95
     C           *IN95     IFEQ *OFF
     C           E2DATE    ANDGTD@DATE
     C           E2WHID    ANDNE'3'
     C                     ADD  E2WQTY    @IQTY
     C                     ENDIF
     C                     ENDDO
      *  OUT
     C                     Z-ADD*ZERO     @OQTY   50
     C           K#EC1     SETLLECSPL05
     C           *IN95     DOUEQ*ON
     C           K#EC11    READEECSPL05                  95
     C           *IN95     IFEQ *OFF
     C           EQYMD     ANDGTD@DATE
     C                     ADD  EQKOSU    @OQTY
     C                     ENDIF
     C                     ENDDO
      * NEW INVENTORY
     C           W1SQTY    SUB  @OQTY     @NQTY   50
     C                     ADD  @IQTY     @NQTY
      *
     C           KEY2      CHAINECSPL10              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDE1SQTY    @@QTY   50
      *
     C           @NQTY     SUB  @@QTY     @@BAL   50
     C           @@BAL     IFNE *ZERO
     C                     EXCPT@DTL
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------
     OQPRINT  E 1              @DTL
     O                         W1KAT1     2
     O                         W1KAT2     7
     O                         W1KAT3    10
     O                         @NQTY J   18
     O                         @@BAL J   26
     O                         W1SQTYJ   34
