     H            Y.
     F** AGKR03 *********************************************
     F* KANBAN MAINTENANCE BZ                               *
     F*    ITS.             2013.12.24                      *
     F*******************************************************
     FFCEPP01 IF  E           K        DISK
     FAAFPL03 IF  E           K        DISK
     FAAHPL03 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FAGKWP02 O   E                    DISK                      A
     E                    NH         99  8 0
     E                    SR         99 10 0
     E                    JK      1  20  2
      *
     I            DS
     I                                        1   80A2GS
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TR
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80A2SY
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
      *
     I            DS
     I                                        1   80BANO
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      *
     I            DS
     I                                        1   80BASK
     I                                        1   40BASKYY
     I                                        5   60BASKMM
     I                                        7   80BASKDD
      *
     I            DS
     I                                        1   80W2DE
     I                                        1   40W2DEYY
     I                                        5   60W2DEMM
     I                                        7   80W2DEDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
     I                                        7  100SDATEY
     I                                       11  120SDATEM
     I                                       12  140SDATED
     I                                        1   20STIMEH
     I                                        3   40STIMEM
     I                                        5   60STIMES
      *
     I            DS
     I                                        1  100WKDB
     I                                        1   80WKDATE
     I                                        9  100WKBIN
      *
     I            DS
     I                                        1   60HMS
     I                                        1   20HH
     I                                        3   40MM
     I                                        5   60SS
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     Z-ADD*DATE     W2DE    80
     C                     SUB  2         W2DEMM
     C           W2DEMM    IFLE 0
     C                     ADD  12        W2DEMM
     C                     SUB  1         W2DEYY
     C                     ENDIF
      *
     C                     READ FCEPP011                 80
     C           *IN80     DOWEQ'0'
     C           A2GSKD    IFEQ 'D'
     C           A2GS      ANDLE*DATE
     C                     ELSE
     C                     MOVEL'0'       WKGET   1
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ FCEPP011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           A2TR      IFLE *DATE
     C           A2STRT    IFEQ '52'
     C           A2STRT    OREQ '53'
     C                     MOVEL'1'       WKGET
     C                     ENDIF
     C                     ELSE
     C           A2KTRT    IFEQ '52'
     C           A2KTRT    OREQ '53'
     C                     MOVEL'1'       WKGET
     C                     ENDIF
     C                     ENDIF
      *
     C           WKGET     IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAGKWP021
     C                     MOVELA2BHB1    W2BHB1
     C                     MOVELA2BHB2    W2BHB2
     C                     MOVELA2BHB3    W2BHB3
     C           A2TR      IFLE *DATE
     C                     MOVELA2STRK    W2STRK
     C                     MOVELA2STRT    W2STRT
     C                     MOVELA2STRR    W2STRR
     C                     MOVELA2STRD    W2STRD
     C                     ELSE
     C                     MOVELA2KTRK    W2STRK
     C                     MOVELA2KTRT    W2STRT
     C                     MOVELA2KTRR    W2STRR
     C                     MOVELA2KTRD    W2STRD
     C                     ENDIF
     C           A2SY      IFLE *DATE
     C                     Z-ADDA2SSYS    W2SSYS
     C                     ELSE
     C                     Z-ADDA2KSYS    W2SSYS
     C                     ENDIF
     C                     Z-ADDA2GEKN    W2GEKN
     C                     Z-ADD0         W2KMAX
     C                     Z-ADD0         W2SRT
     C                     EXSR #SB510
     C                     Z-ADD0         W2AB#
     C                     EXSR #SB520
     C                     WRITEAGKWP021
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * KANBAN                                             *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     MOVEL*BLANK    WKJOK1  2
     C                     MOVEL*BLANK    WKJOK2  2
     C                     MOVEL*BLANK    WKJOK3  2
     C                     MOVEL*BLANK    WKJOK4  2
      *
     C           KEYKKK    KLIST
     C                     KFLD           W2STRK
     C                     KFLD           W2STRT
     C                     KFLD           W2STRR
     C                     KFLD           W2STRD
     C           KEYKKK    SETLLAAFPL031
     C           KEYKKK    READEAAFPL031                 83
     C           *IN83     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3UKHZ    IFLE *DATE
     C           A3STHZ    ANDGT*DATE
     C                     Z-ADDA3KMAX    W2KMAX
     C                     MOVELA3JOK3    WKJOK1
     C                     MOVELA3JOK4    WKJOK2
     C                     MOVELA3JOK5    WKJOK3
     C                     MOVELA3JOK6    WKJOK4
     C                     ENDIF
     C                     ENDIF
     C           KEYKKK    READEAAFPL031                 83
     C                     ENDDO
      *
     C           KEYKKK    SETLLAAHPL031
     C           KEYKKK    READEAAHPL031                 83
     C           *IN83     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6UKHZ    IFLE *DATE
     C           L6STHZ    ANDGT*DATE
     C                     Z-ADDL6KMAX    W2KMAX
     C                     MOVELL6JOK4    WKJOK1
     C                     MOVELL6JOK5    WKJOK2
     C                     MOVELL6JOK6    WKJOK3
     C                     MOVELL6JOK7    WKJOK4
     C                     ENDIF
     C                     ENDIF
     C           KEYKKK    READEAAHPL031                 83
     C                     ENDDO
      *
     C                     MOVELWKJOK1    W2JOK1
     C                     MOVELWKJOK2    W2JOK2
     C                     MOVELWKJOK3    W2JOK3
     C                     MOVELWKJOK4    W2JOK4
     C           WKJOK1    IFNE *BLANK
     C           WKJOK1    LOKUPJK                       29
     C           *IN29     IFEQ '1'
     C                     Z-ADD1         W2SRT
     C                     ENDIF
     C                     ENDIF
     C           WKJOK2    IFNE *BLANK
     C           WKJOK2    LOKUPJK                       29
     C           *IN29     IFEQ '1'
     C                     Z-ADD1         W2SRT
     C                     ENDIF
     C                     ENDIF
     C           WKJOK3    IFNE *BLANK
     C           WKJOK3    LOKUPJK                       29
     C           *IN29     IFEQ '1'
     C                     Z-ADD1         W2SRT
     C                     ENDIF
     C                     ENDIF
     C           WKJOK4    IFNE *BLANK
     C           WKJOK4    LOKUPJK                       29
     C           *IN29     IFEQ '1'
     C                     Z-ADD1         W2SRT
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      * ORDER DATA                                         *
      *----------------------------------------------------*
     CSR         #SB520    BEGSR
      *
     C           KEYJJJ    KLIST
     C                     KFLD           W2BHB1
     C                     KFLD           W2BHB2
     C                     KFLD           W2BHB3
     C                     CLEARNH
     C                     CLEARSR
     C                     Z-ADD0         X       30
     C                     Z-ADD0         Y       30
     C           KEYJJJ    SETLLAB#PL181
     C           KEYJJJ    READEAB#PL181                 83
     C           *IN83     DOWEQ'0'
     C           BANO      ANDLE*DATE
     C           BASKJY    IFEQ 'D'
     C           BASK      ANDLE*DATE
     C                     ELSE
     C           BANO      IFGE W2DE
     C                     Z-ADD1         X       30
     C           BANO      LOKUPNH,X                     29
     C           *IN29     IFEQ '1'
     C                     ADD  BASRYO    SR,X
     C                     ELSE
     C                     ADD  1         Y
     C                     Z-ADDBANO      NH,Y
     C                     Z-ADDBASRYO    SR,Y
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYJJJ    READEAB#PL181                 83
     C                     ENDDO
      *
     C                     Z-ADD0         W2AB#
     C                     Z-ADD0         #2AB#  100
     C                     Z-ADD1         X
     C           X         DOWLE99
     C           SR,X      IFGT #2AB#
     C           SR,X      DIV  W2SSYS    W2AB#
     C                     Z-ADDSR,X      #2AB#
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB520    ENDSR
