TCHK6C*                    Z-ADDW@DY      AXKOYY
TCHK6C*                    Z-ADDW@DM      AXKOMM
TCHK6C*                    Z-ADDW@DD      AXKODD
TCHK6C*                    Z-ADDW@TH      AXKOHH
TCHK6C*                    Z-ADDW@TM      AXKOSS
TCHK6C*TCHK2               MOVEL#USER     AXKOME                        -
TCHK6C*TCHK2               MOVELF0USER    AXKOME                        -
TCHK6C*TCHK3               MOVE F0SHFT    AXKOME
TCHK6C*                    MOVEL#WSID     AXKOWS
TCHK6C*                    MOVEL#PGM      AXKOPG
TCHK6C*                    Z-ADDWSDATE    AXCDAT
TCHK6C*                    Z-ADDWSTIME    AXCTIM
