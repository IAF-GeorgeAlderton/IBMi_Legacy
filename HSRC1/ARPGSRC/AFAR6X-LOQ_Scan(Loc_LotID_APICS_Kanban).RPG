TCHK3C                     MOVELW@AKAN    AYERDT
TCHK3C                     WRITEAFAPP6Y1
TCHK3C                     EXFMTFMT905
TCHK3C                     MOVEL*BLANK    ERMSG
     C                     ITER
     C                     END
     C*
     C           W#DUP     IFNE *BLANK
     C                     ADD  1         I4
     C                     MOVELW#DUP     DUP,I4
     C                     END
     C*
     C           @INKE     IFEQ *ON
     C           I4        IFGT *ZERO
     C                     EXSR @OUTF4
TCHK3C                     EXFMTFMT901
     C                     LEAVE
     C                     ELSE
     C                     MOVELEMSG,10   ERMSG
TCHK3C                     CLEARAFAPP6Y1
TCHK3C                     TIME           W@TIME
TCHK3C                     Z-ADDW@SDT     AYKSDT
TCHK3C                     Z-ADDW@STM     AYKSTM
TCHK3C                     MOVELF0USER    AYOPER                        -
TCHK3C                     MOVELF0SHFT    AYSHFT
TCHK3C                     MOVEL'APICS K4'AYERSC
TCHK3C                     MOVEL'10'      AYERID
TCHK3C                     MOVELW@AKAN    AYERDT
TCHK3C                     WRITEAFAPP6Y1
TCHK3C                     EXFMTFMT905
TCHK3C                     MOVEL*BLANK    ERMSG
     C                     ITER
     C                     END
     C                     ELSE
     C                     CLEARSFL401
     C                     ADD  1         RRN4
     C                     MOVEL*ON       *IN41
     C                     WRITESFL401
     C                     ADD  1         W#RRN4
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*=====================================================
     C*  4th Screen initial set                            =
     C*=====================================================
     C           @F4INT    BEGSR
     C*
     C                     MOVEL*ON       *IN51
     C                     WRITECTL401
     C                     MOVEL*OFF      *IN51
     C                     MOVEL*BLANK    ERMSG
     C                     CLEARSFL401
     C                     Z-ADD1         RRN4    40
     C                     MOVEL*ON       *IN41
     C                     WRITESFL401
     C                     Z-ADD1         W#RRN4  40
     C                     MOVEL*OFF      W#ERR
     C                     MOVEL*OFF      *IN81
     C                     CLEARDUP
     C                     Z-ADD*ZERO     I4      40
     C*
     C                     ENDSR
     C*=====================================================
     C*  4th Screen check
     C*=====================================================
     C           @F4CHK    BEGSR
     C*
TCHK3C                     MOVEL*BLANK    W@ERID
TCHK3C                     MOVEL*BLANK    W@AKAN
     C                     DO
     C*
     C           RRN4      CHAINSFL401               97
     C   97                LEAVE
      *
TCHK3C                     MOVELS4KNBN    W@AKAN
TCHK3 *
     C           S4KNBN    IFEQ *BLANK
     C                     MOVEL*ON       @INKE
     C                     LEAVE
     C                     END
      *
     C                     MOVELS4KNBN    W#KNBN
TCHK3C*
TCHK3C           W#KK      IFNE 'A'
TCHK3C                     MOVEL*ON       W#ERR
TCHK3C                     MOVELEMSG,2    ERMSG
TCHK3C                     MOVEL'02'      W@ERID
TCHK3C                     LEAVE
TCHK3C                     END
TCHK2C*
TCHK6C           W#LCZT    IFNE W#ZETI
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,2    ERMSG
TCHK3C                     MOVEL'02'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
      * CHECK CHECK DIGIT
prv  C*          P#BRC     PLIST
prv  C*                    PARM           PMAREA100
prv  C*                    PARM           PMBYTE  3
prv  C*                    PARM           PMCHK   1
prv  C*                    PARM           PMRTCD  1
     C                     MOVELW#KNBN    PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,8    ERMSG
TCHK3C                     MOVEL'08'      W@ERID
     C                     LEAVE
     C                     ELSE
     C           PMCHK     IFNE W#CHKD
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,8    ERMSG
TCHK3C                     MOVEL'08'      W@ERID
     C                     LEAVE
     C                     END
     C                     END
      *
     C           W#ZETI    CHAINFCETL11              92
     C           *IN92     IFEQ *ON
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,4    ERMSG
TCHK3C                     MOVEL'04'      W@ERID
     C                     LEAVE
     C                     END
      *
prv  C*          K#AAMP    KLIST
prv  C*                    KFLD           A2BHB1           PART 1
prv  C*                    KFLD           A2BHB2           PART 2
prv  C*                    KFLD           A2BHB3           PART 3
     C           K#AAMP    CHAINAAMPL11              92
     C           *IN92     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,4    ERMSG
TCHK3C                     MOVEL'04'      W@ERID
     C                     LEAVE
     C                     END
      *
     C                     Z-ADD1         X       20
     C                     MOVE F1LOC     W##6A   6
     C           W##6A     LOKUPLOC,X                    92
     C           *IN92     IFEQ *OFF
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,1    ERMSG
TCHK3C                     MOVEL'01'      W@ERID
     C                     LEAVE
     C                     END
      *
     C                     MOVEL*BLANK    W#DUP
     C                     MOVELW#ZETI    W#DUP1
     C                     MOVELW#PAGE    W#DUP2
     C                     Z-ADD1         Y       40
     C           W#DUP     LOKUPDUP,Y                    96
     C           *IN96     IFEQ *ON
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,9    ERMSG
TCHK3C                     MOVEL'09'      W@ERID
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     DO
      *
     C           W#ERR     IFEQ *ON
     C                     MOVEL*ON       *IN41
TCHK3C                     MOVEL*BLANK    S4KNBN
     C                     LEAVE
     C                     END
     C           S4KNBN    IFEQ *BLANK
     C                     MOVEL*ON       *IN41
     C                     LEAVE
     C                     END
      *
     C                     MOVEL*OFF      *IN41
      *
     C                     ENDDO
     C*
     C                     UPDATSFL401
     C*
     C                     ENDSR
     C*====================================================*
     C*  Write file (include cancel data)                  *
     C*====================================================*
     C           @OUTF4    BEGSR
     C* GET SEQ#
prv  C*          K#6X      KLIST
prv  C*                    KFLD           WSDATE
prv  C*                    KFLD           WSTIME
prv  C*                    KFLD           W#CSEQ
     C                     Z-ADD1         W#CSEQ
     C                     DO   *HIVAL
     C           K#6X      CHAINAFAPP6X1             95
     C           *IN95     IFEQ *ON
     C                     LEAVE
     C                     ELSE
     C                     ADD  1         W#CSEQ
     C                     END
     C                     ENDDO
     C*
     C                     Z-ADD*ZERO     W#DSEQ
     C* -- LOCATION --
     C                     CLEARAFAPP6X1
     C                     TIME           W@TIME
     C                     Z-ADDW@DY      AXKOYY
     C                     Z-ADDW@DM      AXKOMM
     C                     Z-ADDW@DD      AXKODD
     C                     Z-ADDW@TH      AXKOHH
     C                     Z-ADDW@TM      AXKOSS
TCHK2C*                    MOVEL#USER     AXKOME                        -
TCHK2C                     MOVELF0USER    AXKOME                        -
TCHK3C                     MOVE F0SHFT    AXKOME
     C                     MOVEL#WSID     AXKOWS
     C                     MOVEL#PGM      AXKOPG
     C                     Z-ADDWSDATE    AXCDAT
     C                     Z-ADDWSTIME    AXCTIM
     C                     Z-ADDW#CSEQ    AXCSEQ
     C                     MOVEL'LOCATION'AXDKND
     C                     MOVE F1LOC     W##6A
     C                     MOVELW##6A     AXDATA
     C                     ADD  1         W#DSEQ
     C                     Z-ADDW#DSEQ    AXDSEQ
     C                     WRITEAFAPP6X1
     C* -- LOT ID ---
     C                     Z-ADD*ZERO     RRN2
     C                     DO   *HIVAL
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL201               97
     C   97                LEAVE
     C           S2LTID    IFEQ *BLANK
     C                     ITER
     C                     END
     C                     CLEARAFAPP6X1
     C                     TIME           W@TIME
     C                     Z-ADDW@DY      AXKOYY
     C                     Z-ADDW@DM      AXKOMM
     C                     Z-ADDW@DD      AXKODD
     C                     Z-ADDW@TH      AXKOHH
     C                     Z-ADDW@TM      AXKOSS
TCHK2C*                    MOVEL#USER     AXKOME                        -
TCHK2C                     MOVELF0USER    AXKOME                        -
TCHK3C                     MOVE F0SHFT    AXKOME
     C                     MOVEL#WSID     AXKOWS
     C                     MOVEL#PGM      AXKOPG
     C                     Z-ADDWSDATE    AXCDAT
     C                     Z-ADDWSTIME    AXCTIM
     C                     Z-ADDW#CSEQ    AXCSEQ
