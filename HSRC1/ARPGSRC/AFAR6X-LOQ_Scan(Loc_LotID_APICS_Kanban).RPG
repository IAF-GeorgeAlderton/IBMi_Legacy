     C******************************************************
     C*  Main control                                      *
     C******************************************************
     C                     EXSR @INT
     C*
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C*  Initialize                                        *
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           W@TIME
     C                     Z-ADDW@TH      WSTH
     C                     Z-ADDW@TM      WSTM
     C                     Z-ADDW@TS      WSTS
     C                     Z-ADDW@DM      WSDM
     C                     Z-ADDW@DD      WSDD
     C                     Z-ADDW@DY      WSDY
     C*
     C                     Z-ADD*ZERO     W#CSEQ  40
     C*
     C                     MOVEL*OFF      W#ERR   1
     C*
     C                     ENDSR
     C******************************************************
     C*  Main process                                      *
     C******************************************************
     C           @MAIN     BEGSR
     C*
TCHK2C                     DO
TCHK2C*
TCHK2C                     EXSR @F0PRC
TCHK2C   KC                LEAVE
TCHK2C*
     C                     DO   *HIVAL
     C*
     C                     EXSR @F1PRC
     C   KC                LEAVE
     C*
     C                     DO   *HIVAL
     C                     EXSR @F2PRC
     C   KC
     COR KD                LEAVE
     C*
TCHK6C*TCHK3               DO   *HIVAL
TCHK6C*TCHK3               EXSR @FCPRC
TCHK6C*TCHK2    KC
TCHK6C*TCHK2 OR KD                LEAVE
TCHK6C*TCHK2
     C                     MOVEL*OFF      @INKE   1
     C                     DO   *HIVAL
     C                     EXSR @F3PRC
     C   KC
     COR KD                LEAVE
     C           @INKE     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C                     EXSR @F4PRC
     C   KC                LEAVE
     C           @INKE     IFEQ *ON
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
TCHK6C*  KC                LEAVE
TCHK6C*          @INKE     IFEQ *ON
TCHK6C*                    LEAVE
TCHK6C*                    END
TCHK6C*
TCHK6C*                    ENDDO
     C*
     C   KC                LEAVE
TCHK3C           @INKE     IFEQ *ON
TCHK3C                     LEAVE
TCHK3C                     END
     C                     ENDDO
TCHK3C*
TCHK3C   KC                LEAVE
TCHK3C                     ENDDO
TCHK3C*
TCHK2C                     ENDDO
TCHK2C*
     C                     ENDSR
TCHK2C******************************************************
TCHK2C*  0th Screen process                                *
TCHK2C******************************************************
TCHK2C           @F0PRC    BEGSR
TCHK2C*
TCHK3C                     SELEC
TCHK3C           WSTIME    WHLE 120000
TCHK3C                     MOVEL'3'       W0SHFT  1
TCHK3C           WSTIME    WHLE 170000
TCHK3C                     MOVEL'1'       W0SHFT
TCHK3C           WSTIME    WHLE 240000
TCHK3C                     MOVEL'2'       W0SHFT
TCHK3C                     ENDSL
TCHK3C*
TCHK3C                     MOVELW0SHFT    F0SHFT
TCHK2C                     MOVEL*BLANK    F0USER
TCHK2C                     MOVEL*BLANK    ERMSG
TCHK2C                     MOVEL*OFF      W#ERR
TCHK2C                     MOVEL*OFF      *IN81
TCHK2C*
TCHK2C                     DO   *HIVAL
TCHK2C*
TCHK2C                     EXFMTFMT001
TCHK2C   KC                LEAVE
TCHK2C*
TCHK2C                     MOVEL*BLANK    ERMSG
TCHK2C                     MOVEL*OFF      W#ERR
TCHK2C                     MOVEL*OFF      *IN81
TCHK2C                     EXSR @F0CHK
TCHK2C           W#ERR     IFEQ *ON
TCHK3C                     EXFMTFMT905
TCHK3C                     MOVELW0SHFT    F0SHFT
TCHK2C                     MOVEL*BLANK    F0USER
TCHK3C                     MOVEL*BLANK    ERMSG
TCHK2C                     ITER
TCHK2C                     END
TCHK2C*
TCHK2C                     LEAVE
TCHK2C*
TCHK2C                     ENDDO
TCHK2C*
TCHK2C                     ENDSR
TCHK2C*=====================================================
TCHK2C*  0th Screen check                                  =
TCHK2C*=====================================================
TCHK2C           @F0CHK    BEGSR
TCHK2C*
TCHK2C           F0USER    CHAINALBPL301             91
TCHK2C           *IN91     IFEQ *OFF
TCHK2C           ALSKJY    ANDEQ*BLANK
TCHK2C                     ELSE
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,6    ERMSG
TCHK2C                     END
TCHK2C*
TCHK3C           F0SHFT    IFEQ '1'
TCHK3C           F0SHFT    OREQ '2'
TCHK3C           F0SHFT    OREQ '3'
TCHK3C                     ELSE
TCHK3C                     MOVEL*ON       W#ERR
TCHK3C           ERMSG     IFEQ *BLANK
TCHK3C                     MOVELEMSG,13   ERMSG
TCHK3C                     END
TCHK3C                     END
TCHK3C*
TCHK2C                     ENDSR
     C******************************************************
     C*  1st Screen process                                *
     C******************************************************
     C           @F1PRC    BEGSR
     C*
     C                     MOVEL*BLANK    F1LOC
     C                     MOVEL*BLANK    ERMSG
     C                     MOVEL*OFF      W#ERR
     C                     MOVEL*OFF      *IN81
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT101
     C   KC                LEAVE
     C*
     C                     MOVEL*BLANK    ERMSG
     C                     MOVEL*OFF      W#ERR
     C                     MOVEL*OFF      *IN81
     C                     EXSR @F1CHK
     C           W#ERR     IFEQ *ON
TCHK3C                     CLEARAFAPP6Y1
TCHK3C                     TIME           W@TIME
TCHK3C                     Z-ADDW@SDT     AYKSDT
TCHK3C                     Z-ADDW@STM     AYKSTM
TCHK3C                     MOVELF0USER    AYOPER                        -
TCHK3C                     MOVELF0SHFT    AYSHFT
TCHK3C                     MOVEL'LOCATION'AYERSC
TCHK3C                     MOVELW@ERID    AYERID
TCHK3C                     MOVELF1LOC     AYERDT
TCHK3C                     WRITEAFAPP6Y1
TCHK3C                     EXFMTFMT905
TCHK3C                     MOVEL*BLANK    ERMSG
TCHK3C                     MOVEL*BLANK    F1LOC
     C                     ITER
     C                     END
     C*
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*=====================================================
     C*  1st Screen check                                  =
     C*=====================================================
     C           @F1CHK    BEGSR
     C*
     C                     MOVELF1LOC     W#LOC
     C                     MOVEL*BLANK    W@ERID  2
     C*
TCHK6C*          K#AAJP    KLIST
TCHK6C*                    KFLD           W#LOC1
TCHK6C*                    KFLD           W#LOC2
TCHK6C*                    KFLD           W#LOC3
TCHK6C*                    KFLD           W#LOC4
TCHK6C*          K#AAJP    CHAINAAJPL111             91
TCHK6C*          *IN91     IFEQ *ON
TCHK6C*                    MOVEL*ON       W#ERR
TCHK6C*                    MOVELEMSG,1    ERMSG
TCHK6C*                    MOVEL'01'      W@ERID
TCHK6C*                    END
TCHK6C           W#LCZT    CHAINFCETL11              92
TCHK6C           *IN92     IFEQ *ON
TCHK6C           A2GSKD    ORNE *BLANK
TCHK6C                     MOVEL*ON       W#ERR
TCHK6C                     MOVELEMSG,1    ERMSG
TCHK6C                     MOVEL'01'      W@ERID
TCHK6C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  2nd Screen process                                *
     C******************************************************
     C           @F2PRC    BEGSR
     C*
     C                     EXSR @F2INT
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT299
     C                     Z-ADDW#RRN2    #RCNO2
     C                     EXFMTCTL201
     C   KC
     COR KD                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RRN2
     C                     END
     C*
     C                     MOVEL*BLANK    ERMSG
     C                     MOVEL*OFF      W#ERR
     C                     MOVEL*OFF      *IN81
     C                     EXSR @F2CHK
     C           W#ERR     IFEQ *ON
TCHK3C                     CLEARAFAPP6Y1
TCHK3C                     TIME           W@TIME
TCHK3C                     Z-ADDW@SDT     AYKSDT
TCHK3C                     Z-ADDW@STM     AYKSTM
TCHK3C                     MOVELF0USER    AYOPER                        -
TCHK3C                     MOVELF0SHFT    AYSHFT
TCHK3C                     MOVEL'LOT ID'  AYERSC
TCHK3C                     MOVELW@ERID    AYERID
TCHK3C                     MOVELW2LTID    AYERDT
TCHK3C                     WRITEAFAPP6Y1
TCHK3C                     EXFMTFMT905
TCHK3C                     MOVEL*BLANK    ERMSG
     C                     ITER
     C                     END
     C*
     C           S2LTID    IFEQ *BLANK
     C           I2        ANDGE1
     C                     LEAVE
     C                     END
     C*
     C                     ADD  1         I2
     C                     MOVELW#LTID    DUP,I2
TCHK3C           I2        IFEQ 2
TCHK3C                     LEAVE
TCHK3C                     END
     C                     CLEARSFL201
     C                     ADD  1         RRN2
     C                     MOVEL*ON       *IN21
     C                     WRITESFL201
     C                     ADD  1         W#RRN2
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*====================================================*
     C*  2nd Screen initial set                            *
     C*====================================================*
     C           @F2INT    BEGSR
     C*
     C                     MOVEL*ON       *IN51
     C                     WRITECTL201
     C                     MOVEL*OFF      *IN51
     C                     MOVEL*BLANK    ERMSG
     C                     CLEARSFL201
     C                     Z-ADD1         RRN2    40
     C                     MOVEL*ON       *IN21
     C                     WRITESFL201
     C                     Z-ADD1         W#RRN2  40
     C                     MOVEL*OFF      W#ERR
     C                     MOVEL*OFF      *IN81
     C                     CLEARDUP
     C                     Z-ADD*ZERO     I2      40
     C*
     C                     ENDSR
     C*=====================================================
     C*  2nd Screen check                                  =
     C*=====================================================
     C           @F2CHK    BEGSR
     C*
TCHK3C                     MOVEL*BLANK    W@ERID
TCHK3C                     MOVEL*BLANK    W2LTID 10
TCHK3C*
     C                     DO
     C*
     C           RRN2      CHAINSFL201               97
     C   97                LEAVE
     C*
TCHK3C                     MOVELS2LTID    W2LTID
TCHK3C*
     C           S2LTID    IFEQ *BLANK
     C           I2        IFEQ *ZERO
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,14   ERMSG
TCHK3C                     MOVEL'14'      W@ERID
     C                     END
     C                     LEAVE
     C                     END
TCHK3C           W2LTBK    IFNE *BLANK
TCHK3C                     MOVEL*ON       W#ERR
TCHK3C           ERMSG     IFEQ *BLANK
TCHK3C                     MOVELEMSG,14   ERMSG
TCHK3C                     MOVEL'14'      W@ERID
TCHK3C                     END
TCHK3C                     LEAVE
TCHK3C                     END
     C*
     C                     Z-ADD1         Y       40
     C           S2LTID    LOKUPDUP,Y                    96
     C           *IN96     IFEQ *ON
     C                     MOVEL*ON       W#ERR
     C                     MOVELEMSG,7    ERMSG
TCHK3C                     MOVEL'07'      W@ERID
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           W#ERR     IFEQ *ON
     C                     MOVEL*ON       *IN21
TCHK3C                     MOVEL*BLANK    S2LTID
     C                     ELSE
     C                     MOVELS2LTID    W#LTID 10
     C                     MOVEL*OFF      *IN21
     C                     END
     C                     UPDATSFL201
     C*
     C                     ENDSR
TCHK2C******************************************************
TCHK2C*  'C' Screen process                                *
TCHK2C******************************************************
TCHK2C           @FCPRC    BEGSR
TCHK2C*
TCHK2C                     MOVEL*BLANK    FCLOQK
TCHK2C                     MOVEL*BLANK    ERMSG
TCHK2C                     MOVEL*OFF      W#ERR
TCHK2C                     MOVEL*OFF      *IN81
TCHK2C*
TCHK2C                     DO   *HIVAL
TCHK2C*
TCHK2C                     EXFMTFMTC01
TCHK2C   KC
TCHK2COR KD                LEAVE
TCHK2C*
TCHK2C                     MOVEL*BLANK    ERMSG
TCHK2C                     MOVEL*OFF      W#ERR
TCHK2C                     MOVEL*OFF      *IN81
TCHK2C                     EXSR @FCCHK
TCHK2C           W#ERR     IFEQ *ON
TCHK3C                     CLEARAFAPP6Y1
TCHK3C                     TIME           W@TIME
TCHK3C                     Z-ADDW@SDT     AYKSDT
TCHK3C                     Z-ADDW@STM     AYKSTM
TCHK3C                     MOVELF0USER    AYOPER                        -
TCHK3C                     MOVELF0SHFT    AYSHFT
TCHK3C                     MOVEL'LOQ K#'  AYERSC
TCHK3C                     MOVELW@ERID    AYERID
TCHK3C                     MOVELFCLOQK    AYERDT
TCHK3C                     WRITEAFAPP6Y1
TCHK3C                     EXFMTFMT905
TCHK3C                     MOVEL*BLANK    ERMSG
TCHK3C                     MOVEL*BLANK    FCLOQK
TCHK2C                     ITER
TCHK2C                     END
TCHK2C*
TCHK2C                     LEAVE
TCHK2C*
TCHK2C                     ENDDO
TCHK2C*
TCHK2C                     ENDSR
TCHK2C*=====================================================
TCHK2C*  'C' Screen check                                  =
TCHK2C*=====================================================
TCHK2C           @FCCHK    BEGSR
TCHK2C*
TCHK3C                     MOVEL*BLANK    W@ERID
TCHK2C*
TCHK2C                     DO
TCHK2C*
TCHK2C                     MOVELFCLOQK    W#LOQK
TCHK2C*
TCHK2C           W#LKK     IFEQ 'A'
TCHK2C           W#LKK     OREQ 'R'
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,2    ERMSG
TCHK3C                     MOVEL'02'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C* CHECK CHECK DIGIT
TCHK2C**         P#BRC     PLIST
TCHK2C**                   PARM           PMAREA100
TCHK2C**                   PARM           PMBYTE  3
TCHK2C**                   PARM           PMCHK   1
TCHK2C**                   PARM           PMRTCD  1
TCHK2C                     MOVELW#LOQK    PMAREA    P
TCHK2C                     MOVE '014'     PMBYTE
TCHK2C                     MOVE *BLANK    PMCHK
TCHK2C                     MOVE *BLANK    PMRTCD
TCHK2C                     CALL 'ALBRCC'  P#BRC
TCHK2C           PMRTCD    IFNE *BLANK
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,8    ERMSG
TCHK3C                     MOVEL'08'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     ELSE
TCHK2C           PMCHK     IFNE W#LCHK
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,8    ERMSG
TCHK3C                     MOVEL'08'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     END
TCHK2C*
TCHK2C           W#LZET    CHAINFCETL11              92
TCHK2C           *IN92     IFEQ *ON
TCHK2C           A2GSKD    ORNE *BLANK
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,4    ERMSG
TCHK3C                     MOVEL'04'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
TCHK2C**         K#AAMP    KLIST
TCHK2C**                   KFLD           A2BHB1           PART 1
TCHK2C**                   KFLD           A2BHB2           PART 2
TCHK2C**                   KFLD           A2BHB3           PART 3
TCHK2C           K#AAMP    CHAINAAMPL11              92
TCHK2C           *IN92     IFEQ *ON
TCHK2C           CKSKJY    ORNE *BLANK
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,4    ERMSG
TCHK3C                     MOVEL'04'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
TCHK2C                     Z-ADD1         X       20
TCHK2C                     MOVE F1LOC     W##6A   6
TCHK2C           W##6A     LOKUPLOC,X                    92
TCHK2C           *IN92     IFEQ *OFF
TCHK2C                     MOVEL*ON       W#ERR
TCHK2C                     MOVELEMSG,1    ERMSG
TCHK3C                     MOVEL'01'      W@ERID
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
TCHK2C                     ENDDO
TCHK2C*
TCHK2C                     ENDSR
     C******************************************************
     C*  3rd Screen process                                *
     C******************************************************
     C           @F3PRC    BEGSR
     C*
     C                     EXSR @F3INT
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT399
     C                     Z-ADDW#RRN3    #RCNO3
     C                     EXFMTCTL301
     C   KC
     COR KD                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RRN3
     C                     END
     C*
     C                     MOVEL*BLANK    ERMSG
     C                     MOVEL*BLANK    W#DUP
     C                     MOVEL*OFF      W#ERR
     C                     MOVEL*OFF      *IN81
     C                     MOVEL*OFF      W#AH11  1
