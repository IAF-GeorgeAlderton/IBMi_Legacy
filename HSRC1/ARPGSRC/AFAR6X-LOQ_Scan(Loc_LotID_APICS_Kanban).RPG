     C                     LEAVE
     C                     ELSE
     C                     Z-ADD12        LOTLMT
     C                     ENDIF
      *
     C                     ENDDO
      *
      *
      *  divide lot size in half to get lot limit until it's less than 16...
     C           LOTLMT    DOWGT16
     C           LOTLMT    DIV  2         LOTLMT
     C                     ENDDO
      *
      *
      *  if kanban count entered is more than the lot limit, set error flag...
     C           W#MA3     IFGT LOTLMT
     C                     MOVEL*ON       WW@ERR
     C                     ENDIF
      *
      *
      * LEC
      *
TCHK7C*
