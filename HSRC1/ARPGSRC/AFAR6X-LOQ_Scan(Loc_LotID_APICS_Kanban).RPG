     C                     MOVELS2LTID    AXDATA
     C                     ADD  1         W#DSEQ
     C                     Z-ADDW#DSEQ    AXDSEQ
     C                     WRITEAFAPP6X1
     C                     ENDDO
     C* -- LOQ KANBAN --
TCHK6C*                    CLEARAFAPP6X1
