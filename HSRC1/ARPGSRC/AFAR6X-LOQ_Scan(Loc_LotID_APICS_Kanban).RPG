     C           RRN3      CHAINSFL301               97
     C   97                LEAVE
     C           S3KNBN    IFEQ *BLANK
     C                     ITER
     C                     END
      *
     C                     Z-ADD*ZERO     W#CCNT  20
     C                     MOVELS3KNBN    W#KNBN
TCHK2C                     MOVELW#PAGE    W##PG#  20
TCHK6C                     MOVELW#PAGE    WWPAGE  2
TCHK7C*
TCHK7C                     MOVEL*OFF      WW@PAG  1
TCHK7C                     SELEC
TCHK7C           W#LOC3    WHEQ '02'                       LOT 14(28)
TCHK7C           W#LCZT    OREQ '2967'
TCHK7C           WWPAGE    IFEQ '01'
TCHK7C           WWPAGE    OREQ '15'
TCHK7C           WWPAGE    OREQ '29'
TCHK7C                     MOVEL*ON       WW@PAG
TCHK7C                     END
TCHK7C           W#LOC3    WHEQ '08'                       LOT 16(32)
TCHK7C           W#LCZT    OREQ '2966'
TCHK7C           WWPAGE    IFEQ '01'
TCHK7C           WWPAGE    OREQ '17'
TCHK7C           WWPAGE    OREQ '33'
TCHK7C                     MOVEL*ON       WW@PAG
TCHK7C                     END
TCHK8C           W#LOC3    WHEQ '01'                       LOT 15(30)
TCHK8C           W#LCZT    OREQ '2171'
TCHK8C           WWPAGE    IFEQ '01'
TCHK8C           WWPAGE    OREQ '16'
TCHK8C           WWPAGE    OREQ '31'
TCHK8C                     MOVEL*ON       WW@PAG
TCHK8C                     END
TCHK7C                     OTHER
TCHK7C           WWPAGE    IFEQ '01'
TCHK7C           WWPAGE    OREQ '13'
TCHK7C           WWPAGE    OREQ '25'
TCHK7C                     MOVEL*ON       WW@PAG
TCHK7C                     END
TCHK7C                     ENDSL
      *
     C                     DO   *HIVAL
