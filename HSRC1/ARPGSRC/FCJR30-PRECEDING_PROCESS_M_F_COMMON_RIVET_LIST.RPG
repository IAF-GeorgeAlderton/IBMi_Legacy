     C           K#MBD     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C           K#MBDX    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
     C           K#KEY     KLIST
     C                     KFLD           F3SHN1
     C                     KFLD           F3SHN2
     C                     KFLD           F3SHN3
      *
     C                     Z-ADD3411      K@TOKU
     C                     Z-ADD3931      K@NONY
     C                     TIME           WTIME   60
      *
     C           K#MBD     SETLLMBDPL02
     C           *IN90     DOUEQ*ON
     C           K#MBD     READEMBDPL02                  90
     C           *IN90     IFEQ *OFF
      *
     C           K#KEY     CHAINFCEPL01              91
     C           A2GEKN    DIV  20        WQTY    90
     C           WQTY      DIV  A2SSYS    WCASE   50
     C                     MVR            @@MVR   30
     C           @@MVR     IFNE 0
     C                     ADD  1         WCASE
     C                     ENDIF
      *
     C           K#KEY     CHAINAAMPL11              91
     C           *IN91     IFEQ *OFF
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
     C           1         DO   15        X       20
     C                     MOVELPRC,X     PRX,X
     C                     ENDDO
     C                     EXCPT@DTL
     C                     ENDIF
     C                     MOVE F3NKOJ    K@NKOJ  1
     C                     MOVE F3NUKE    K@NUKE  4
     C                     MOVE F3MHN1    K@MHN1  5
     C                     MOVE F3MHN2    K@MHN2  5
     C                     MOVE F3MHN3    K@MHN3  5
     C                     MOVE F3MHN4    K@MHN4  5
     C           K#MBDX    SETGTMBDPL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
     OQPRINT  E  102           @HED
     O                                  104 'PAGE'
