     H            Y.
     F** ALDR11 *****************************************
     F*  THE NUMBER OF PROCESSED BOXES BY WORKER LIST   *
     F*                                                 *
     F*  TCH 2002.10.10                                 *
     F******************************* AAAR35 ************
     FALDWP05 IP  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     F*************************************************************
     E                    DAT        31  8 0
     E                    DT2        31  2 0
     E                    YOB        31  5
     E                    BOX        31  4 0
     E                    TOT        31  4 0
     E                    WD      7   7  3
      *------------------------------------------------------------
     IALDWP051    01
     I                                              D5OPERL2
     I                                              D5YYYYL1
     I                                              D5MMMML1
     I                                              D5DDDDL1
     I            DS
     I                                        1   80F8DATE
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80WDATE
     I                                        1   40WYY
     I                                        5   60WMM
     I                                        7   80WDD
     I* SYSTEM DATE
     I            DS
     I                                        1  120WWTIME
     I                                        1   60WTIME
     I                                        9  100WPMM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PYYYY   40
     C                     PARM           PMM     20
      *
     C                     SETOF                     50
      *
     C           *IN51     IFEQ '0'
     C                     SETON                     5051
     C                     TIME           WWTIME
     C                     EXCPT@HED
     C                     END
      *
     C           *INL2     IFEQ *ON
     C                     Z-ADD*ZERO     BOX
     C                     ENDIF
      *
     C                     Z-ADDD5DDDD    WDD
     C                     Z-ADDD5YYYY    WYY
     C                     Z-ADDD5MMMM    WMM
     C                     Z-ADD1         X
     C           WDATE     LOKUPDAT,X                    10
     C   10                ADD  D5BOX     BOX,X
     C   10                ADD  D5BOX     TOT,X
     CL2 51                EXSR #OUT
     CLR                   EXSR #TOT
      *-----------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     XFOOTBOX       @@TOT   60
     C                     MOVELD5NAME    WNAME  15
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *-----------------------------------------------------------
     C           #TOT      BEGSR
      *
     C                     XFOOTTOT       @@GTT   60
      *
     C                     EXCPT@TOT
      *
     C                     ENDSR
      *-----------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           PYYYY
     C                     KFLD           PMM
      *
     C                     Z-ADD*ZERO     DAT
     C                     Z-ADD*ZERO     DT2
     C                     Z-ADD*ZERO     X       20
     C                     MOVE *BLANK    YOB
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C*********  F8YOBI    ANDNE7
     C                     ADD  1         X
     C                     Z-ADDF8DATE    DAT,X
     C                     Z-ADDF8DATE    DT2,X
     C                     Z-ADDF8YOBI    Y       20
     C                     MOVE WD,Y      YOB,X
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ALL'-'   @LIN  198
      *
     C                     ENDSR
     O*****************************************************************
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         PUSR     161
     O                         UDATE Y  174
     O                         WTIME    183 '  :  :  '
     O                                  188 'PAGE'
     O                         PAGE  Z  192
     O        E   02           @HED
     O                                   67 '** THE NUMBER OF'
     O                                   83 'PROCESSED BOXES'
     O                                   96 'BY WORKER **'
     O                         PYYYY Z  104
     O                                  105 '/'
     O                         PMM   Z  107
     O        E   04           @HED
     O                                   11 'WORKER NAME'
     O                         DT2      177 '&&&  '
     O        E   05           @HED
     O                         YOB      177
     O                                  195 'TOTAL'
     O        E   06           @HED
     O                         @LIN     198
     O        E 1              @DTL
     O                         D5OPER     6
     O                         WNAME     22
     O                         BOX      177 '&    '
     O                         @@TOT 1  195
     O        E 1              @TOT
     O                         @LIN     198
     O        E 1              @TOT
     O                                   15 'DAILY TOTAL'
     O                         TOT      177 '&    '
     O                         @@GTT 1  195
     O************************************************************
