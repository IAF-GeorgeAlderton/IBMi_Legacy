     C                     END
     C                     ADD  1         Y
TCHK4C                     MOVELAY,Z      A15,Y
     C                     ENDDO
     C                     MOVEAA15       W@A15  15
TCHK4C*                    MOVELW@A15     ATORDN
TCHK4C                     ADD  1         I
TCHK4C                     MOVELW@A15     OD#,I
TCHK4C*
TCHK5C*TCHK4               ENDDO
TCHK6C                     ENDDO
