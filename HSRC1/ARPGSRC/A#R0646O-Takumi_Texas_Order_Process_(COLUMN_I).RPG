      *
     C                     MOVEL*ZERO     YMD
     C                     Z-ADDX         Z
     C* MM
     C                     ADD  1         Z
     C           '/'       LOKUPAY,Z                     10
     C  N10                GOTO @END
     C           Z         SUB  2         Y
     C                     MOVEAAY,Y      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      MONTH
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      MONTH
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      MONTH
     C                     END
     C                     END
     C* DD
     C                     ADD  1         Z
     C           '/'       LOKUPAY,Z                     10
     C  N10                GOTO @END
     C           Z         SUB  2         Y
     C                     MOVEAAY,Y      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      DAY
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      DAY
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      DAY
     C                     END
     C                     END
     C* YY
     C           Z         ADD  1         Y
     C                     MOVEAAY,Y      W@A4    4
     C                     MOVELW@A4      YEAR
      *
TCHK3C*          YMD       IFGT *DATE
TCHK3C*                    MOVE *ON       *IN98
TCHK3C*                    END
TCHK3C*                    GOTO @END
      *
