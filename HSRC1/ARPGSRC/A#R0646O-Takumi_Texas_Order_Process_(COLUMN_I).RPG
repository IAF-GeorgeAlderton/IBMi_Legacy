JW   C  N10      'IAF'     SCAN DAT1      X              10
JW   C  N10                Z-ADD1         X
TCHK2C  N10      'pickup'  SCAN DAT1      X              10
     C  N10                GOTO @END
     C*
TCHK3C                     Z-ADD*ZERO     I
TCHK3C                     Z-ADD*ZERO     DAT
