      * GET QPC
     C**                   Z-ADD1         X
     C**         ','       LOKUPAY,X                     10
     C**N10                GOTO @END
      *
     C                     MOVE *BLANK    A6
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFLT '0'
     C           AY,X      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         Y
     C                     MOVE AY,X      A6,Y
     C                     ENDDO
      * CONVERT QPC
     C                     Z-ADD6         A       30
     C                     Z-ADD6         B       30
     C                     MOVEL*ALL'0'   A6X
     C                     DO   6
     C           A6,A      IFNE *BLANK
     C                     MOVE A6,A      A6X,B
     C                     SUB  1         B
     C                     END
     C                     SUB  1         A
     C           A         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA6X       @6N     6
     C                     MOVE @6N       ATSYOS
JW1  C* SKIP WGT
 .   C                     DO   *HIVAL
 .   C                     ADD  1         X
