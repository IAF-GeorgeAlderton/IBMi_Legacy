     H            Y.                                    1
     H***ALDR92*****************************************************************
     H* 2 PONT SCAN                                                            *
     H*
     H**************************************************************************
     H*
     H**************************************************************************
     FALDPW92 CF  E                    WORKSTN
     FALAPL02 IF  E           K        DISK
     FFCETL11 IF  E           K        DISK
     FGADPL15 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FALDWP90 O   E           K        DISK                      A
     FAGDPL12 IF  E           K        DISK
     FAB#PL71 IF  E           K        DISK
     F**************************************************************************
     E                    BCD         4  7               TOYOTA BCD DATA
     E                    KBN         4  1               TOYOTA BCD KBN
     E                    ERR     1   6 15
     E                    WUSR        4  7               BACK KANBAN W/F
     E                    QTY         4  1               QTY
     E                    HEX    16  16  1               HEX CODE
     E                    NUM    16  16  2 0             CHAR NUMERIC
     E                    TTL     1   2 16
     E                    HON        20  1               HONDA BARCODE
     E                    HNO        20  1               HONDA PART
     E                    BB          4  7
     E                    AA          4  7
     E                    NB          4  1 0
     I**************************************************************************
     I* TOYOTA (BACK KANBAN 1,BLOCK NUMBER=0)
     I            DS
     I                                        1   7 BARCD1
     I                                        1   6 BARCC1
     I                                        1   1 BLKNO1
     I                                        2   6 CUST3
     I                                        2   2 CUST21
     I                                        3   3 CUST22
     I                                        4   4 CUST23
     I                                        5   5 CUST24
     I                                        7   7 CHKD1
     I* TOYOTA (BACK KANBAN 2,BLOCK NUMBER=1)
     I            DS
     I                                        1   7 BARCD2
     I                                        1   6 BARCC2
     I                                        1   1 BLKNO2
     I                                        2   2 CUST1
     I                                        7   7 CHKD2
     I* TOYOTA (BACK KANBAN 3 ,BLOCK NUMBER=3)
     I            DS
     I                                        1   7 BARCD3
     I                                        1   6 BARCC3
     I                                        1   1 BLKNO3
     I                                        2   5 BQTY
     I                                        7   7 CHKD3
     I* TOYOTA (BACK KANBAN 4 ,BLOCK NUMBER=+)
     I            DS
     I                                        1   7 BARCD4
     I                                        1   6 BARCC4
     I                                        1   1 BLKNO4
     I                                        2   5 IDPNO
     I                                        7   7 CHKD4
     I* BACK KANBAN(OTHERS)
     I            DS
     I                                        1  19 BAROTH
     I                                        1  18 BARCC5
     I                                        1   4 DELIVL
     I                                        1   40WELIVL
     I                                        5   5 FACTRY
     I                                        6   9 DOCK
     I                                       10  13 IDCD
     I                                       14  180HQTY
     I                                       19  19 CHKD5
     I* LOCATION
     I            DS
     I                                        1   8 BARLOC
     I                                        1   7 BARCC6
     I                                        1   4 IDNO6
     I                                        8   8 CHKD6
     I* A-PICS,KOUTEI,IAF
     I            DS
   T3I                                        1  17 BARKAX
     I                                        1  15 BARKAN
     I                                        1  16 IIAF
     I                                        1  14 IAPICS
     I                                        1   1 BARKBN
     I                                        2   5 IDNO7
     I                                        6   8 LOT
     I                                        9  10 PAG
     I                                       15  15 CHKD8
     I                                       17  17 CHKD7
     I                                       16  17 NODGT
     I* SYSTEM DATE(8 DIGITS) FOR FIRST SCREEN
     I            DS
     I                                        1   80WSDATE
     I                                        1   4 WSYYYY
     I                                        5   6 WSMM
     I                                        7   8 WSDD
     I                                        1   8 WSDAT
     I            DS
     I                                        1   80W@YMD8
     I                                        1   40SYY
     I                                        5   60SMM
     I                                        7   80SDD
     I* ACCOMMODATED QTY. CHANGE DATE(8 DIGITS)
     I            DS
     I                                        1   80WQDATE
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I* LOCATION CHANGE DATE(8 DIGITS)
     I            DS
     I                                        1   80WLDATE
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I* SYSTEM TIME
     I            DS
     I                                        1  120WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        7   80WSSYYY
     I                                        9  100WSSMMM
     I                                       11  120WSSDDD
     I                                        1   4 WSTIME
     I* OUT-GOING TRACK DATA FILE(IAF) ALDPP20
     I* KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
     I            DS
     I                                        1  16 WIAF
     I                                        1   1 A1KANS
     I                                        2   5 A1ZETI
     I                                        6  11 A1ORDR
     I                                       12  12 A1SEHI
     I                                       13  160A1LOTN
     I* OUT-GOING TRACK DATA FILE(A-PICS) ALDPP30
     I* KANBAN TYPE,ABSOLUTE#,TEHI#,PAGE#,2ND WORK TIME,OBJ TYPE,YUKO,BOX
     I            DS
     I                                        1  14 WAPICS
     I                                        1   1 A3KANS
     I                                        2   5 A3ZETI
     I                                        6   8 A3TEHI
     I                                        9  10 A3PAGE
     I                                       11  11 A32KAK
     I                                       12  12 A3TASY
     I                                       13  13 A3YUKO
     I                                       14  14 A3HASY
     I* ALDWP10
     I            DS
     I                                        1 100 DATA
     I                                        1  17 A0BAR1
     I                                       18  45 A0BAR2
     I                                       46  53 A0SDAT
     I                                       54  57 A0PTIM
     I                                       58  63 A0UID
     I* ALAPP01 (KEY)
     I            DS
     I                                        1   6 KEY3
     I                                        1   5 KEY31
     I                                        6   6 KEY32
     I* FCEPL01 (KEY)
     I            DS
     I                                        1  12 WKPNO
     I                                        1   5 K11
     I                                        6  10 K12
     I                                       11  12 K13
     I            DS
     I                                        1  28 BB
     I                                        1   7 D@BCD0
     I                                        8  14 D@BCD1
     I                                       15  21 D@BCD2
     I                                       22  28 D@BCD3
     I            DS
     I                                        1   4 NB
     I                                        1   10D@NBR0
     I                                        2   20D@NBR1
     I                                        3   30D@NBR2
     I                                        4   40D@NBR3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
     C*
     C* BBHR50
     C           P1        PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PMHIN  20
     C                     PARM           PSHIN  12
     C                     PARM           PFLG    1
     C** KLIST
     C           KEY1      KLIST
     C                     KFLD           K11
     C                     KFLD           K12
     C                     KFLD           K13
     C* AGDPL12(CALENDER MASTER)
     C           K#AGD     KLIST
     C                     KFLD           #KYY    40
     C                     KFLD           #KMM    20
     C                     KFLD           #KDD    20
     C*  WORK FIELD
     C                     MOVEL*ALL'0'   WCLR   10        WORK FLG CLR
     C                     MOVEL*ALL'0'   WBBK2  12        WORK FLG CLR
     C                     MOVEAWCLR      *IN,30
     C                     MOVEL*BLANK    MSG
     C           120       SUB  TOTAL     EMPTY
     C                     Z-ADD120       GTOTL
     C                     MOVEL*BLANK    WUSR
     C                     Z-ADD*ZERO     I       20       KBN INDEX
     C                     Z-ADD*ZERO     M       20       CUL
     C                     Z-ADD*ZERO     L       20       TBL INDEX
     C                     Z-ADD*ZERO     X       20       TBL INDEX
     C                     Z-ADD*ZERO     WQTY2   40       FPR HEX CAL WORK
     C                     Z-ADD*ZERO     WQTY3   40       FPR HEX CAL WORK
     C                     Z-ADD*ZERO     WSISU   40       SISUU
     C*
     C                     Z-ADD*DATE     WSDATE
     C                     Z-ADD*DATE     D@YMD
     C                     MOVE '00'      @@ID    2
     C                     Z-ADD1         NN      20
     C                     MOVE *BLANK    BB
     C                     MOVE *BLANK    AA
     C                     Z-ADD*ZERO     NB
     C*
     C                     CLEARALDPW012
     C                     MOVE *BLANK    @@T     1
     C*
     C                     ENDSR
     C*************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'00'      @SCRN0           1ST
     C           @@ID      CASEQ'01'      @SCRN1           OTHERS
     C           @@ID      CASEQ'02'      @SCRN2           LOCATION
     C           @@ID      CASEQ'03'      @SCRN3           APCS
     C           @@ID      CASEQ'04'      @SCRN4           ASJ
     C           @@ID      CASEQ'05'      @SCRN5
     C           @@ID      CASEQ'06'      @SCRN6
     C           @@ID      CASEQ'08'      @SCRN8           E-KANBAN
     C                     ENDCS
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C           @SCRN0    BEGSR
     C**************************************************************************
      *
     C                     EXFMTALDPW010                   OTHERS
     C*
     C                     SELEC
     C           *INKE     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR @CHK0
     C           *IN90     IFEQ *OFF
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*    CHECK FOR 1ST SCREEN
     C**************************************************************************
     C           @CHK0     BEGSR
      *
     C                     Z-ADDD@YMD     W@YMD8
     C                     ADD  2000      SYY
     C                     Z-ADDSYY       #KYY
     C                     Z-ADDSMM       #KMM
     C                     Z-ADDSDD       #KDD
      *
     C           K#AGD     CHAINAGDPL121             90
      *
     C                     ENDSR
     C**************************************************************************
     C           @SCRN1    BEGSR
     C**************************************************************************
      *
     C                     EXFMTALDPW013                   OTHERS
     C*
     C                     SELEC
     C           *INKE     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKH     WHEQ *ON
     C                     MOVE '08'      @@ID
     C                     MOVE 'E'       @@T     1
     C           *INKG     WHEQ *ON
     C                     MOVE 'T'       @@T     1
     C                     MOVE '06'      @@ID
     C                     MOVE *BLANK    AA
     C                     Z-ADD1         NN
     C           *INKB     WHEQ *ON
     C                     EXSR #TOT
     C                     EXFMTALDPW014
      *
     C                     OTHER
     C                     EXSR @CHK1
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1(ONE-WAY KANBAN OTHERS)
     C**************************************************************************
     C           @CHK1     BEGSR
     C*
     C                     MOVE *BLANK    MSG
     C                     SETOF                     3037
     C* PART MASTER
     C           IDCD      CHAINFCETL11              90
B01  C           *IN90     IFEQ '0'
     C** QTY CHECK
     C*  DEPENDS ON SYSTEM DATE, USE OLD/NEW QTY
B02  C           WSDATE    IFGE WQDATE
B03  C           HQTY      IFEQ A2SSYS
     C                     ELSE
     C                     SETON                     3037
B04  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E04  C                     END
E03  C                     END
     C*
     C                     ELSE
B03  C           HQTY      IFEQ A2KSYS
     C                     ELSE
     C                     SETON                     3037
B04  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E04  C                     END
E03  C                     END
E02  C                     END
     C*
     C                     ELSE
     C* NOT FILE READ
     C                     SETON                     3037
B02  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E02  C                     END
     C* ERROR
     C                     SETON                     3037
B02  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E02  C                     END
     C                     END
     C*
     C           *IN30     IFEQ '0'
     C                     MOVE *BLANK    WUSR
     C                     MOVEABAROTH    WUSR
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C           @SCRN2    BEGSR
     C**************************************************************************
     C                     EXFMTALDPW015
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     CLEARALDPW011
     C                     CLEARALDPW012
     C                     CLEARALDPW013
     C                     CLEARALDPW015
     C                     CLEARALDPW016
     C                     CLEARALDPW020
     C                     CLEARALDPW021
     C                     SELEC
     C           @@T       WHEQ *BLANK
     C                     MOVE '01'      @@ID
     C           @@T       WHEQ 'T'
     C                     MOVE '06'      @@ID
     C                     MOVE *BLANK    AA
     C                     Z-ADD1         NN
     C           @@T       WHEQ 'E'
     C                     MOVE '08'      @@ID
     C                     ENDSL
     C*DSP5 ENTER
     C                     OTHER                           DSP5 ENTER
     C                     EXSR @CHK2                      LOCATION CHK
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
     C                     ELSE
  T3 C           @IAF      IFEQ 'Y'
     C                     MOVE '04'      @@ID
     C                     ELSE
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK2(LOCATION)
     C**************************************************************************
     C           @CHK2     BEGSR
      *
     C                     SETOF                     3038
     C                     MOVE *BLANK    MSG
     C*  PART MASTER = BARCODE
   B1C           A2ZETI    IFNE IDNO6
     C* ID NO ERROR
     C                     SETON                     3038
     C                     MOVE ERR,4     MSG
   E2C                     END
      *
     C                     ENDSR
     C**************************************************************************
     C           @SCRN3    BEGSR
     C**************************************************************************
      ** APICS
     C                     EXFMTALDPW016
     C*
   B1C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     CLEARALDPW011
     C                     CLEARALDPW012
     C                     CLEARALDPW013
     C                     CLEARALDPW015
     C                     CLEARALDPW016
     C                     CLEARALDPW020
     C                     CLEARALDPW021
     C                     SELEC
     C           @@T       WHEQ *BLANK
     C                     MOVE '01'      @@ID
     C           @@T       WHEQ 'T'
     C                     MOVE '06'      @@ID
     C                     MOVE *BLANK    AA
     C                     Z-ADD1         NN
     C           @@T       WHEQ 'E'
     C                     MOVE '08'      @@ID
     C                     ENDSL
     C           *INKG     WHEQ *ON
     C                     MOVE ' '       @IAF    1
     C                     MOVE '04'      @@ID
     C*
   B2C                     OTHER
     C                     EXSR @CHK3
      *
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
   B4C                     ELSE
     C           DELIVL    IFNE '0295'
     C           DELIVL    ANDNE'3128'
     C           DELIVL    ANDNE'0296'
     C           DELIVL    ANDNE'4126'
     C           DELIVL    ANDNE'0402'
     C           DELIVL    ANDNE'2020'
     C           DELIVL    ANDNE'0294'
     C           DELIVL    ANDNE'0293'
     C           DELIVL    ANDNE'3129'
     C           @APC      IFEQ 'APCS'
     C                     EXSR @WRT1
     C                     ELSE
     C                     EXSR @WRT2
     C                     ENDIF
     C                     EXSR @WRT
   E4C                     ELSE
     C                     MOVE '05'      @@ID
     C*
 T3E3C                     END
   E2C                     END
   E  *
   E0C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK3(APICS KANBAN)
     C**************************************************************************
     C           @CHK3     BEGSR
      *
     C                     MOVEL'APCS'    @APC    4
     C                     SETOF                     3039
     C                     MOVE *BLANK    MSG
     C* KANBAN KUBUN OK?
     C           BARKBN    IFEQ 'A'
     C           BARKBN    OREQ 'R'
     C           BARKBN    OREQ 'T'
     C* ERROR
     C                     ELSE
     C                     SETON                     3039
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E2C                     END
   E1C                     END
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E3C                     END
   E2C                     END
   E1C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*      SCREEN 4
     C**************************************************************************
     C           @SCRN4    BEGSR
      *
     C                     EXFMTALDPW020
     C*
   B1C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     CLEARALDPW011
     C                     CLEARALDPW012
     C                     CLEARALDPW013
     C                     CLEARALDPW015
     C                     CLEARALDPW016
     C                     CLEARALDPW020
     C                     CLEARALDPW021
     C                     SELEC
     C           @@T       WHEQ *BLANK
     C                     MOVE '01'      @@ID
     C           @@T       WHEQ 'T'
     C                     MOVE '06'      @@ID
     C                     MOVE *BLANK    AA
     C                     Z-ADD1         NN
     C           @@T       WHEQ 'E'
     C                     MOVE '08'      @@ID
     C                     ENDSL
     C           *INKG     WHEQ *ON
     C                     MOVE 'Y'       @IAF    1
     C                     MOVE '03'      @@ID
     C                     OTHER
     C                     EXSR @CHK4
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
   B4C                     ELSE
     C           DELIVL    IFNE '0295'
     C           DELIVL    ANDNE'3128'
     C           DELIVL    ANDNE'0296'
     C           DELIVL    ANDNE'4126'
     C           DELIVL    ANDNE'0402'
     C           DELIVL    ANDNE'2020'
     C           DELIVL    ANDNE'0294'
     C           DELIVL    ANDNE'0293'
     C           DELIVL    ANDNE'3129'
     C           @APC      IFEQ 'APCS'
     C                     EXSR @WRT1
     C                     ELSE
     C                     EXSR @WRT2
     C                     ENDIF
      *
     C                     EXSR @WRT
   E4C                     ELSE
     C                     MOVE '05'      @@ID
     C*
 T3E3C                     END
   E2C                     END
   E  *
   E0C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK4(ASJ KANBAN)
     C**************************************************************************
     C           @CHK4     BEGSR
      *
     C                     MOVE 'ASJ '    @APC
     C                     SETOF                     3039
     C                     MOVE *BLANK    MSG
     C* APICS,KOTEI KANBAN(15 DIGITS) ERROR
     C           NODGT     IFEQ *BLANK                     APICS,KOTEI
     C                     SETON                     3039
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     END
     C                     END
     C* KANBAN KUBUN OK?
   B1C           *IN30     IFEQ '0'
   B2C           BARKBN    IFEQ 'I'
     C* ERROR
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E3C                     END
   E2C                     END
   E1C                     END
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E3C                     END
   E2C                     END
   E1C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*      SCREEN 5
     C**************************************************************************
     C           @SCRN5    BEGSR
      *
     C                     EXFMTALDPW021
     C*
   B1C                     SELEC
     C           *INKE     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK5
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
   B4C                     ELSE
     C           @APC      IFEQ 'APCS'
     C                     EXSR @WRT1
     C                     ELSE
     C                     EXSR @WRT2
     C                     ENDIF
     C                     EXSR @WRT
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
     C           #CHK5     BEGSR
      *--------------------------------------------------------
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C* EDIT PART NUMBER
     C                     Z-ADD2         K       20
     C                     Z-ADD0         L       20
     C                     MOVEABARHON    HON
     C                     MOVEA*BLANK    HNO
B03  C           2         DO   19        K
B04  C           HON,K     IFNE ' '
     C           HON,K     ANDNE'-'
     C                     ADD  1         L
     C                     MOVE HON,K     HNO,L
E04  C                     END
E03  C                     END
     C*
     C* GET CUTOMER CODE FROM DELIVERY CODE
     C*
     C                     MOVE *BLANK    PTOKU
     C                     MOVE *BLANK    PNONY
     C                     MOVE *BLANK    PNKOJ
     C                     MOVE *BLANK    PMHIN
     C                     MOVE *BLANK    PSHIN
     C                     MOVE *BLANK    PFLG
     C*
     C           WELIVL    SETLLGADPP111
     C           #READ1    TAG
     C           WELIVL    READEGADPP111                 92
B03  C           *IN92     IFEQ '0'
B04  C           B5SKJY    IFEQ 'D'
     C                     GOTO #READ1
E04  C                     END
     C*
     C                     MOVE B5TOKU    PTOKU
     C                     MOVE B5NONY    PNONY
     C                     MOVE B5NKOJ    PNKOJ
     C                     MOVE DOCK      PNUKE
     C                     MOVEAHNO       PMHIN
E03  C                     END
     C*
     C* EXCHANGE USER PART # TO IAF PART
     C                     CALL 'BBHR50'  P1
     C                     MOVE PSHIN     WKPNO
     C*
     C* GET ABSOLUTE NUMBER
     C                     SETOF                     89
     C           KEY1      SETLLFCEPL011
     C           #READ2    TAG
     C           KEY1      READEFCEPL011                 93
B03  C           *IN93     IFEQ '0'
B04  C           A2GSKD    IFNE 'D'
     C*
     C* CHECK ABSOLUTE #(HONDA LABEL & AIAG)
     C                     SETON                     89
B05  C           A2ZETI    IFEQ IDCD
     C                     SETON                     26
     C*
     C                     ELSE
     C                     SETON                     30
B06  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,4     MSG
     C                     END
     C                     END
     C*
     C                     ELSE
     C                     GOTO #READ2
     C                     END
E03  C                     END
     C*
     C           *IN89     IFEQ '0'
     C                     SETON                     30
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,4     MSG
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C           @SCRN6    BEGSR
     C**************************************************************************
     C                     Z-ADDNN        D@NBR0
     C           NN        IFEQ 1
     C                     MOVE TTL,1     D@TITL
     C                     ELSE
     C                     MOVE TTL,2     D@TITL
     C                     ENDIF
      *
     C                     EXFMTALDPW012                   TOYOTA
     C*
     C                     SELEC
     C           *INKE     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKF     WHEQ *ON
     C                     MOVE '08'      @@ID
     C           *INKG     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     OTHER
     C                     EXSR @CHK6
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------
     C           @CHK6     BEGSR
      *----------------------------------------------
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
      *
     C           D@BCD0    IFNE *BLANK
     C           D@BCD0    LOKUPAA                       90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           NN        IFEQ 4
     C                     EXSR @CHK61
     C           *IN30     IFEQ *OFF
     C                     MOVE '02'      @@ID
     C                     ENDIF
      *
     C                     ELSE
     C                     ADD  1         NN
     C                     MOVE D@BCD0    AA,NN
     C                     MOVEAAA        BB
     C                     MOVE *BLANK    D@BCD0
     C           NN        SUB  1         NB,NN
     C                     Z-ADDNN        NB,1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------
     C           @CHK61    BEGSR
      *----------------------------------------------
     C                     SETOF                     3033
      *
     C                     MOVE BB,2      BARCD1
     C                     MOVE BB,3      BARCD2
     C                     MOVE BB,4      BARCD3
     C                     MOVE BB,1      BARCD4
     C                     MOVE BLKNO1    KBN,1
     C                     MOVE BLKNO2    KBN,2
     C                     MOVE BLKNO3    KBN,3
     C                     MOVE BLKNO4    KBN,4
     C*
     C                     MOVE BARCD1    BCD,1
     C                     MOVE BARCD2    BCD,2
     C                     MOVE BARCD3    BCD,3
     C                     MOVE BARCD4    BCD,4
     C*
     C                     CLEARWUSR
     C                     Z-ADD1         I
     C           '0'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,1
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C                     Z-ADD1         I
     C           '1'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,2
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C                     Z-ADD1         I
     C           '2'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,3
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C                     Z-ADD1         I
     C           '+'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,4
     C*
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C           *IN30     IFEQ '0'
     C                     MOVEAWUSR,1    BARCD1
     C                     MOVEAWUSR,2    BARCD2
     C                     MOVEAWUSR,3    BARCD3
     C                     MOVEAWUSR,4    BARCD4
     C*
     C                     ELSE
     C                     SETON                     30
     C                     MOVEA'1111'    *IN,33
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     END
     C                     END
     C*
     C                     MOVELCUST3     KEY31
     C                     MOVE CUST1     KEY32
     C           KEY3      CHAINALAPL02              91
     C           *IN91     IFEQ '1'
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     END
     C                     GOTO #CHK61
     C*
     C                     ELSE
     C                     END
     C* PART MASTER
     C           IDPNO     CHAINFCETL11              90
     C           *IN90     IFEQ '0'
     C** QTY CHECK START ****************************************
     C*
     C*  TRANSFER FROM HEX TO CHAR NUMERIC
     C                     Z-ADD*ZERO     WQTY2
     C                     Z-ADD*ZERO     WQTY3
     C                     Z-ADD1         WSISU
     C                     Z-ADD4         L
     C                     MOVEABQTY      QTY
     C*
     C                     DO   4
     C                     Z-ADD1         X
     C           QTY,L     LOKUPHEX,X                    42
     C*
     C           *IN42     IFNE '0'
     C           WSISU     MULT NUM,X     WQTY2
     C                     ADD  WQTY2     WQTY3
     C                     END
     C           16        MULT WSISU     WSISU
     C                     SUB  1         L
     C*
     C                     END
     C*
     C*  DEPENDS ON SYSTEM DATE, USE OLD/NEW QTY
     C           WSDATE    IFGE WQDATE
     C           WQTY3     IFEQ A2SSYS
     C                     ELSE
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,3     MSG
     C                     END
     C                     END
     C*
     C                     ELSE
     C           WQTY3     IFEQ A2KSYS
     C                     ELSE
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,3     MSG
     C                     END
     C                     END
     C                     END
     C* NOT FILE READ
     C                     ELSE
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,3     MSG
     C                     END
     C                     END
      *
     C           #CHK61    TAG
      *
     C           *IN30     IFEQ '1'
     C                     MOVE *BLANK    BARCD1
     C                     MOVE *BLANK    BARCD2
     C                     MOVE *BLANK    BARCD3
     C                     MOVE *BLANK    BARCD4
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C           @SCRN8    BEGSR
     C**************************************************************************
     C                     EXFMTALDPW011                   TOYOTA
     C*
     C                     SELEC
     C           *INKE     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKF     WHEQ *ON
     C                     MOVE 'T'       @@T
     C                     MOVE '06'      @@ID
     C                     MOVE *BLANK    AA
     C                     Z-ADD1         NN
     C           *INKG     WHEQ *ON
     C                     MOVE *BLANK    @@T
     C                     MOVE '01'      @@ID
     C                     OTHER
     C                     EXSR @CHK8
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------
     C           @CHK8     BEGSR
      *----------------------------------------------
     C                     SETOF                     3033
     C                     MOVE *BLANK    MSG
      *
     C           BARCD0    IFEQ *BLANK
     C                     SETON                     3033
     C                     MOVE ERR,6     MSG
     C                     ELSE
     C           BARCD0    SETLLAB#PL71
     C           *IN90     DOUEQ*ON
     C           BARCD0    READEAB#PL71             N    90
     C           *IN90     IFEQ *OFF
     C           EKLTNO    IFNE *BLANK
     C                     ITER
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE ERR,6     MSG
     C                     SETON                     3033
     C                     ENDIF
     C                     ENDIF
      *
     C           EKZETI    CHAINFCETL11              90
      *
     C                     ENDSR
     C**************************************************************************
     C*    TOTAL
     C**************************************************************************
     C           #TOT      BEGSR
     C*
     C           120       SUB  TOTAL     EMPTY
     C                     Z-ADD120       GTOTL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT      BEGSR
     C*
     C                     ADD  1         TOTAL
     C*
     C                     CLEARALDPW012
     C                     CLEARALDPW013
     C                     CLEARALDPW016
     C                     CLEARALDPW020
     C                     CLEARALDPW021
     C*
     C                     EXFMTALDPW997
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT2     BEGSR
     C*
     C                     CLEARALDPP901
     C                     TIME           A9UPTM
     C                     Z-ADD*DATE     A9UPDT
     C                     MOVEL#USER     A9USER
     C                     MOVEL#WSID     A9WSID
     C                     MOVE A2BHB1    A9SHN1           INTERNAL PART
     C                     MOVE A2BHB2    A9SHN2           INTERNAL PART
     C                     MOVE A2BHB3    A9SHN3           INTERNAL PART
     C                     ADD  SYY       A9INYY
     C                     Z-ADDSMM       A9INMM
     C                     Z-ADDSDD       A9INDD
     C                     MOVE IIAF      WIAF             IAF KANBAN
     C*
     C                     MOVE WORKER    A9OPER           WORKER
     C                     MOVE *BLANK    A9MHN1           USER PART
     C                     MOVE *BLANK    A9MHN2
     C                     MOVE *BLANK    A9MHN3
     C                     MOVE *BLANK    A9MHN4
     C                     Z-ADDHQTY      A9SSYS           UNIT QTY
     C                     Z-ADDHQTY      A9USYS           USER UNIT QTY
     C                     MOVE DELIVL    A9NONY           DELIVERY POINY
     C                     MOVE FACTRY    A9NKOJ                    FACTORY
     C                     MOVE DOCK      A9NUKE                    RECV
     C                     MOVE *BLANK    A9TOPX           TOPIX CODE
     C                     MOVE *BLANK    A9SALE           EFU/KANBAN
     C                     MOVE *BLANK    A9UPAG           BOTTOM KANBAN ISSU#
     C                     WRITEALDPP901
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT1     BEGSR
     C*
     C                     CLEARALDPP901
     C                     TIME           A9UPTM
     C                     Z-ADD*DATE     A9UPDT
     C                     MOVEL#USER     A9USER
     C                     MOVEL#WSID     A9WSID
     C                     MOVE A2BHB1    A9SHN1           INTERNAL PART
     C                     MOVE A2BHB2    A9SHN2           INTERNAL PART
     C                     MOVE A2BHB3    A9SHN3           INTERNAL PART
     C                     ADD  SYY       A9INYY
     C                     Z-ADDSMM       A9INMM
     C                     Z-ADDSDD       A9INDD
     C****                 MOVE IIAF      WIAF             IAF KANBAN
     C*
     C                     MOVE WORKER    A9OPER           WORKER
     C                     MOVE *BLANK    A9MHN1           USER PART
     C                     MOVE *BLANK    A9MHN2
     C                     MOVE *BLANK    A9MHN3
     C                     MOVE *BLANK    A9MHN4
     C                     Z-ADDHQTY      A9SSYS           UNIT QTY
     C                     Z-ADDHQTY      A9USYS           USER UNIT QTY
     C                     MOVE DELIVL    A9NONY           DELIVERY POINY
     C                     MOVE FACTRY    A9NKOJ                    FACTORY
     C                     MOVE DOCK      A9NUKE                    RECV
     C                     MOVE *BLANK    A9TOPX           TOPIX CODE
     C                     MOVE *BLANK    A9SALE           EFU/KANBAN
     C                     MOVE PAG       A9PAG            BOTTOM KANBAN ISSU#
     C                     MOVE LOT       A9LOT            BOTTOM KANBAN ISSU#
     C                     MOVE IDNO7     A9ZETI
     C                     WRITEALDPP901
