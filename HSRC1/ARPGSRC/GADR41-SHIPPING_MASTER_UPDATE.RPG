     C                     ENDSR
      *===============================================================
      *サブファイルチェックGADPP41
     C*===============================================================
     C           #CHK3     BEGSR
      *
      *  追加・変更のみチェック
S1   C           D1KKBN    IFEQ '0'                        :CANCEL
     C                     GOTO $CHK3Z
E1   C                     ENDIF
      *
     C                     MOVEA'00000000'*IN,51            51-58
      *-------------------------
     C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               95
     C   95                LEAVE
     C                     EXSR #SFCHK
     C*
     C                     UPDATSFREC1
     C   99                Z-ADDRRN1      DSPRRN
     C  N99                ENDDO
      *-------------------------
      * CHANGE OVER DATE (58)
      *-------------------------
     C  N99      D3CHDT    IFEQ 0
     C                     SETON                     5899
     C                     MOVELER,40     D3ERR
     C                     ELSE
     C*PRTN='1':NG
     C                     MOVELD3CHDT    P1DATE
     C                     CALL 'DATR10'
     C                     PARM           P1DATE  8
     C                     PARM           P1RTN   1
     C           P1RTN     IFEQ '1'
     C                     SETON                     5899
     C                     MOVELER,41     D3ERR
     C                     ENDIF
     C                     ENDIF
     C*-------------------------
     C           $CHK3Z    TAG
     C*-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK3 F5'
     C                     MOVE '#UPDAT  '@STEP
     C                     ELSE
     C                     MOVE '#DSP3   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *サブファイルチェック
      *===============================================================
     C           #SFCHK    BEGSR
     C                     MOVEA'00000000'*IN,51            51-58
      *
      * N SHIPMENT ADJ. DAY (51)
      *
     C           S1NSPD    IFEQ 0                          N SHIPMENT ADJ. DAY
     C                     SETON                     5199
     C                     MOVELER,31     D3ERR
     C                     GOTO $SFCH9
     C                     ENDIF
      *
      * N SHIPPING # (52)
      *
     C           S1NSHP    IFEQ *BLANK                     N SHIPPING #
     C                     SETON                     5299
     C                     MOVELER,32     D3ERR
     C                     GOTO $SFCH9
     C                     ELSE
     C*   << WORK TIME M/F >>
     C           S1NSHP    CHAINBTMPL20              96
     C  N96      B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDEQ@SYSHZ
     C                     SETON                     96
     C                     ENDIF
     C   96                SETON                     5299
     C   96                MOVELER,33     D3ERR
     C   96                GOTO $SFCH9
     C                     ENDIF
      *
      * N CARRIER (53)
      *
     C           S1NCAR    IFEQ *BLANK                     N CARRIER
     C                     SETON                     5399
     C                     MOVELER,34     D3ERR
     C                     GOTO $SFCH9
     C                     ELSE
     C* CARRIER M/F                                *
     C           S1NCAR    CHAINGAHPL35              96    N CARRIER
     C  N96      G5SKJY    IFEQ 'D'
     C           G5SKHZ    ANDEQ@SYSHZ
     C                     SETON                     96
     C                     ENDIF
     C   96                SETON                     5399
     C   96                MOVELER,35     D3ERR
     C   96                GOTO $SFCH9
     C                     ENDIF
      *
      *  N ROUTE (54)
      *
     C           S1NRUT    IFEQ *BLANK                     N ROUTE
     C                     SETON                     5499
     C                     MOVELER,36     D3ERR
     C                     GOTO $SFCH9
     C                     ELSE
     C* ROUTE M/F                                  *
     C           S1NRUT    CHAINGAHPL37              96    N CARRIER
     C  N96      G7SKJY    IFEQ 'D'
     C           G7SKHZ    ANDEQ@SYSHZ
     C                     SETON                     96
     C                     ENDIF
     C   96                SETON                     5499
     C   96                MOVELER,37     D3ERR
     C   96                GOTO $SFCH9
     C                     ENDIF
      *
      * N BIN # (55)
      *
     C           S1NBIN    IFEQ 0                          N BIN #
     C   96                SETON                     5599
     C   96                MOVELER,38     D3ERR
     C   96                GOTO $SFCH9
     C                     ENDIF
      *
      * TRANSPORTATION M/F                         *
      *
     C           KEY03     KLIST
     C                     KFLD           S1NCAR           CARRIER
     C                     KFLD           S1NRUT           ROUTE
     C                     KFLD           S1NBIN           BIN #
     C*
     C           KEY03     CHAINGAHPL30              96
     C  N96      G3SKJY    IFEQ 'D'
     C           G3SKHZ    ANDEQ@SYSHZ
     C                     SETON                     96
     C                     ENDIF
     C   96                SETON                     535455
     C   96                SETON                     99
     C   96                MOVELER,39     D3ERR
     C   96                GOTO $SFCH9
     C*-------------------------
     C           $SFCH9    TAG
