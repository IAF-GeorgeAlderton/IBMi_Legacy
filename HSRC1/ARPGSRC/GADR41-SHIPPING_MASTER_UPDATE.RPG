     C*===============================================================
     C*
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#DSP3   '#DSP3
     C           @STEP     CASEQ'#CHK3   '#CHK3
     C           @STEP     CASEQ'#CHK3 F5'#CHK3
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
      * 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
      *
     C                     MOVE *BLANK    D1KKBN           更新区分
     C                     MOVE *BLANK    D1TOKU           CUSTOMER CODE
     C                     MOVE *BLANK    D1NONY           DELIVERY POINT CODE
     C                     MOVE *BLANK    D1NKOJ           FACTORY CODE
     C                     MOVE *BLANK    D1NUKE           RECEIVING
     C                     MOVE *BLANK    D1ERR            d[ｰxｮﾈｰﾆﾞ
     C                     MOVE *BLANK    D2KKBN           更新区分
     C                     MOVE *BLANK    D2TOKU           CUSTOMER CODE
     C                     MOVE *BLANK    D2NONY           DELIVERY POINT CODE
     C                     MOVE *BLANK    D2NKOJ           FACTORY CODE
     C                     MOVE *BLANK    D2NUKE           RECEIVING
      *
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTGADPW411
     C                     MOVEA'00000000'*IN,21
     C                     SETOF                     99
     C                     MOVE '#CHK1   '@STEP
      *-------*
      * (F1)  *
      *-------*
     C   KA                MOVE '#END    '@STEP
      *-------*
      * (F24) * DOWNLOAD
      *-------*
     C           *INKY     IFEQ *ON
     C                     CALL 'GADC42'
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*===============================================================
      *画面１チェック
     C*===============================================================
     C           #CHK1     BEGSR
      *----------------------*
      * UPDATE更新区分
      *----------------------*
S1   C                     SELEC
 1   C           D1KKBN    WHEQ '0'                        :取消
     C                     MOVEL'0-CANCEL'D2KKBN
     C                     SETON                     29    (PR)
 1   C           D1KKBN    WHEQ '1'                        :変更
     C                     MOVEL'1-CHANGE'D2KKBN
     C                     SETOF                     29    (CS)
 1   C           D1KKBN    WHEQ '2'                        :追加
     C                     MOVEL'2-ADD   'D2KKBN
     C                     SETOF                     29    (CS)
 1   C                     OTHER
     C                     SETON                     2199
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
E1   C                     ENDSL
      *----------------------*
      * CUSTOMER CODE (22)
      *----------------------*
     C           D1TOKU    IFEQ *BLANK
     C                     SETON                     2299
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVE D1TOKU    $$TOKU  40
     C           $$TOKU    CHAINFGBPL01              91
     C  N91      B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C                     SETON                     2299
     C                     MOVELER,3      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *----------------------*
      * DELIVERY POINT CODE (23)
      *----------------------*
     C           D1NONY    IFEQ *BLANK
     C                     SETON                     2399
     C                     MOVELER,4      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVE D1NONY    $$NONY  40
     C           $$NONY    CHAINFGBPL01              91
     C  N91      B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C                     SETON                     2399
     C                     MOVELER,5      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *----------------------*
      * FACTORY CODE (24)
      *----------------------*
     C           D1NKOJ    IFEQ *BLANK
     C                     SETON                     2499
     C                     MOVELER,6      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *----------------------*
      * RECEIVING (25)
      *----------------------*
     C           D1NUKE    IFEQ *BLANK
     C                     SETON                     2599
     C                     MOVELER,7      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *----------------------*
      *----------------------*
     C           KEY01     KLIST
     C                     KFLD           $$TOKU           CUSTOMER CODE
     C                     KFLD           $$NONY           DELIVERY POINT CODE
     C                     KFLD           D1NKOJ           FACTORY CODE
     C                     KFLD           D1NUKE           RECEIVING
     C           KEY01     CHAINGADPL11             N90
      **
S1   C                     SELEC
-1   C           D1KKBN    WHEQ '0'                        :取消
     C           *IN90     IFEQ *ON
     C                     MOVEA'11111'   *IN,21           : 21-25
     C                     SETON                     99
     C                     MOVELER,8      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE@SYSHZ
     C                     MOVEA'11111'   *IN,21           : 21-25
     C                     SETON                     99
     C                     MOVELER,9      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
-1   C           D1KKBN    WHEQ '1'                        :変更
     C           *IN90     IFEQ *ON
     C                     MOVEA'11111'   *IN,21           : 21-25
     C                     SETON                     99
     C                     MOVELER,10     D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE@SYSHZ
     C                     MOVEA'11111'   *IN,21           : 21-25
     C                     SETON                     99
     C                     MOVELER,11     D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
-1   C           D1KKBN    WHEQ '2'                        :追加
     C           *IN90     IFEQ *OFF
     C           B5SKJY    ANDNE'D'
     C                     MOVEA'11111'   *IN,21           : 21-25
     C                     SETON                     99
     C                     MOVELER,12     D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
E1   C                     ENDSL
     C*
      *----------------------*
      *----------------------*
     C                     MOVEA'00000000'*IN,31           31-38
     C                     MOVEA'00000000'*IN,39           39-46
     C                     MOVELD1TOKU    D2TOKU           CUSTOMER CODE
     C                     MOVELD1NONY    D2NONY           DELIVERY POINT CODE
     C                     MOVELD1NKOJ    D2NKOJ           FACTORY CODE
     C                     MOVELD1NUKE    D2NUKE           RECEIVING
     C                     MOVEL*BLANK    D2KMEI           FACTORY NAME (KANA)
     C                     Z-ADD0         D2HIZK           CYCLE (DAY)
     C                     Z-ADD0         D2KAIS           TIME
     C                     Z-ADD0         D2NBIN           BIN
     C                     MOVEL*BLANK    D2YOB1           MONDAY
     C                     MOVEL*BLANK    D2YOB2           TUESDAY
     C                     MOVEL*BLANK    D2YOB3           WEDNESDAY
     C                     MOVEL*BLANK    D2YOB4           THURSDAY
     C                     MOVEL*BLANK    D2YOB5           FRIDAY
     C                     MOVEL*BLANK    D2YOB6           SATURDAY
     C                     MOVEL*BLANK    D2YOB7           SUNDAY
     C                     MOVEL*BLANK    D2SIRE           SUPPLIER CODE
     C                     MOVEL*BLANK    D2SMEI           FACTORY CODE
     C                     MOVEL*BLANK    D2SKYU           PROVISION POINT CODE
     C                     MOVEL*BLANK    D2CSUC           CARRIER SET UP CALLED
     C                     MOVEL*BLANK    D2ERR
     C*
S1   C           D1KKBN    IFEQ '0'                        :削除
 1   C           D1KKBN    OREQ '1'                        :変更
     C                     MOVELB5KMEI    D2KMEI           FACTORY NAME (KANA)
     C                     Z-ADDB5HIZK    D2HIZK           CYCLE (DAY)
     C                     Z-ADDB5KAIS    D2KAIS           TIME
     C                     Z-ADDB5NBIN    D2NBIN           BIN
     C                     MOVELB5YOB1    D2YOB1           MONDAY
     C                     MOVELB5YOB2    D2YOB2           TUESDAY
     C                     MOVELB5YOB3    D2YOB3           WEDNESDAY
     C                     MOVELB5YOB4    D2YOB4           THURSDAY
     C                     MOVELB5YOB5    D2YOB5           FRIDAY
     C                     MOVELB5YOB6    D2YOB6           SATURDAY
     C                     MOVELB5YOB7    D2YOB7           SUNDAY
     C                     MOVELB5SIRE    D2SIRE           SUPPLIER CODE
     C                     MOVELB5SMEI    D2SMEI           FACTORY CODE
     C                     MOVELB5SKYU    D2SKYU           PROVISION POINT CODE
     C                     MOVELB5CSUC    D2CSUC           CARRIER SET UP CALLED
E1   C                     ENDIF
     C*
      *----------------------*
     C           $CHK1Z    TAG
      *----------------------*
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
      *----------------------*
     C                     ENDSR
      *===============================================================
      *画面２表示
      *===============================================================
     C           #DSP2     BEGSR
     C                     EXFMTGADPW412
     C                     MOVEA'0'       *IN,99
     C                     MOVEA'00000000'*IN,31           31-38
     C                     MOVEA'00000000'*IN,39           39-46
     C                     MOVEL*BLANK    D2ERR
     C                     MOVE '#CHK2   '@STEP
      *----*
      * F3 *
      *----*
     C           *INKC     IFEQ *ON
     C                     MOVEA'00000000'*IN,21           : 21-28
     C                     SETOF                         99
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *----*
     C                     ENDSR
     C*===============================================================
      *画面２チェック
     C*===============================================================
     C           #CHK2     BEGSR
     C*
      *
      *  追加・変更のみチェック
S1   C           D1KKBN    IFEQ '0'                        :CANCEL
     C                     GOTO $CHK2Z
E1   C                     ENDIF
     C*-------------------------
      *----------------------*
      * FACTORY NAME (31)
      *----------------------*
     C           D2KMEI    IFEQ *BLANK                     FACTORY NAME (KANA)
     C                     SETON                     3199
     C                     MOVELER,14     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * CYCLE (DAY)  (32)
      *----------------------*
     C           D2HIZK    IFEQ 0                          CYCLE (DAY)
     C                     SETON                     3299
     C                     MOVELER,15     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * TIME         (33)
      *----------------------*
     C           D2KAIS    IFEQ 0                          TIME
     C                     SETON                     3399
     C                     MOVELER,16     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * BIN          (34)
      *----------------------*
     C           D2NBIN    IFEQ 0                          BIN
     C                     SETON                     3499
     C                     MOVELER,17     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * MONDAY      (35)
      *----------------------*
     C                     MOVELD2YOB1    $$YOBI  1        MONDAY
     C                     EXSR ##YOBI
     C   99                SETON                     35
     C   99                GOTO $CHK2Z
      *----------------------*
      * TUESDAY     (36)
      *----------------------*
     C                     MOVELD2YOB2    $$YOBI           TUESDAY
     C                     EXSR ##YOBI
     C   99                SETON                     36
     C   99                GOTO $CHK2Z
      *----------------------*
      * WEDNESDAY   (37)
      *----------------------*
     C                     MOVELD2YOB3    $$YOBI           WEDNESDAY
     C                     EXSR ##YOBI
     C   99                SETON                     37
     C   99                GOTO $CHK2Z
      *----------------------*
      * THURSDAY    (38)
      *----------------------*
     C                     MOVELD2YOB4    $$YOBI           THURSDAY
     C                     EXSR ##YOBI
     C   99                SETON                     38
     C   99                GOTO $CHK2Z
      *----------------------*
      * FRIDAY      (39)
      *----------------------*
     C                     MOVELD2YOB5    $$YOBI           FRIDAY
     C                     EXSR ##YOBI
     C   99                SETON                     39
     C   99                GOTO $CHK2Z
      *----------------------*
      * SATURDAY    (40)
      *----------------------*
     C                     MOVELD2YOB6    $$YOBI           SATURDAY
     C                     EXSR ##YOBI
     C   99                SETON                     40
     C   99                GOTO $CHK2Z
      *----------------------*
      * SUNDAY      (41)
      *----------------------*
     C                     MOVELD2YOB7    $$YOBI           SUNDAY
     C                     EXSR ##YOBI
     C   99                SETON                     41
     C   99                GOTO $CHK2Z
      *----------------------*
      * SUPPLIER CODE (42)
      *----------------------*
     C           D2SIRE    IFEQ *BLANK                     SUPPLIER CODE
     C                     SETON                     4299
     C                     MOVELER,19     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * FACTORY CODE (43)
      *----------------------*
     C           D2SMEI    IFEQ *BLANK                     FACTORY CODE
     C                     MOVE '0'       D2SMEI           FACTORY CODE
     C                     ENDIF
      *----------------------*
      * PROVISION POINT CODE (44)
      *----------------------*
     C           D2SKYU    IFEQ *BLANK                     PROVISION POINT CODE
     C                     SETON                     4499
     C                     MOVELER,20     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * CARRIER SET UP CALLED (45)
      *----------------------*
     C           D2CSUC    IFNE '0'                        DAY OF'
     C           D2CSUC    ANDNE'1'                        1 DAY BEFORE
     C           D2CSUC    ANDNE'2'                        2 DAY BEFORE
     C           D2CSUC    ANDNE'3'                        OTHER(SPECIFY)
     C           D2CSUC    ANDNE'4'                        MILKRUN AUTOMATIC
     C           D2CSUC    ANDNE'5'                        IAF CALLS
     C                     SETON                     4599
     C                     MOVELER,21     D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
     C           $CHK2Z    TAG
      *----------------------*
S1   C           *IN99     IFEQ *OFF
     C                     EXSR #SFSET                     GADPP41-SFL
     C                     Z-ADD1         DSPRRN
     C                     MOVE '#DSP3   '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C                     ENDSR
      *================================================================
      *** E-18 DAY IN A WEEK IS ERROR <BLANK A / B / C / D>
      *================================================================
     C           ##YOBI    BEGSR
     C           $$YOBI    IFNE ' '
     C           $$YOBI    ANDNE'A'
     C           $$YOBI    ANDNE'B'
     C           $$YOBI    ANDNE'C'
     C           $$YOBI    ANDNE'D'
     C                     SETON                       99
     C                     MOVELER,18     D2ERR
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *サブファイル作成GADPP41
      *===============================================================
     C           #SFSET    BEGSR
     C*<SFLCLR>
     C                     SETON                     73
     C                     WRITESFCTL1
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
      *サイクル編集
     C                     MOVE '-'       D2HF1
     C                     MOVE '-'       D2HF2
     C           KEY02     KLIST
     C                     KFLD           $$TOKU           CUSTOMER CODE
     C                     KFLD           $$NONY           DELIVERY POINT CODE
     C                     KFLD           D1NKOJ           FACTORY CODE
     C                     KFLD           D1NUKE           RECEIVING
     C                     KFLD           S1BIN   20
      *サブファイルの件数
     C                     Z-ADDD2KAIS    ENDRRN  40
      *
     C                     Z-ADD0         $$BIN   20
     C                     MOVEA'00000000'*IN,51            51-58
      *-------------------------
      *-------------------------
S1   C                     DO   ENDRRN
     C*                *** CLEARSFREC1
     C                     ADD  1         $$BIN   20
     C                     Z-ADD$$BIN     S1BIN
     C           KEY02     CHAINGADPL41              91
 S2  C  N91      B4SKJY    IFEQ 'D'
     C                     SETON                     91
 E2  C                     ENDIF
     C*
 S2  C           *IN91     IFEQ *OFF
  S3 C           D1KKBN    IFEQ '0'                        :削除
     C                     Z-ADDB4NSPD    S1NSPD           N SHIPMENT ADJ. DAY
     C                     MOVELB4NSHP    S1NSHP           N SHIPPING #
     C                     MOVELB4NCAR    S1NCAR           N CARRIER
     C                     MOVELB4NRUT    S1NRUT           N ROUTE
     C                     Z-ADDB4NBIN    S1NBIN           N BIN #
     C                     Z-ADDB4OSPD    S1OSPD           O SHIPMENT ADJ. DAY
     C                     MOVELB4OSHP    S1OSHP           O SHIPPING #
     C                     MOVELB4OCAR    S1OCAR           O CARRIER
     C                     MOVELB4ORUT    S1ORUT           O ROUTE
     C                     Z-ADDB4OBIN    S1OBIN           O BIN #
  X3 C                     ELSE
     C                     Z-ADD0         S1NSPD           N SHIPMENT ADJ. DAY
     C                     MOVEL*BLANK    S1NSHP           N SHIPPING #
     C                     MOVEL*BLANK    S1NCAR           N CARRIER
     C                     MOVEL*BLANK    S1NRUT           N ROUTE
     C                     Z-ADD0         S1NBIN           N BIN #
     C                     Z-ADDB4NSPD    S1OSPD           O SHIPMENT ADJ. DAY
     C                     MOVELB4NSHP    S1OSHP           O SHIPPING #
     C                     MOVELB4NCAR    S1OCAR           O CARRIER
     C                     MOVELB4NRUT    S1ORUT           O ROUTE
     C                     Z-ADDB4NBIN    S1OBIN           O BIN #
  E3 C                     ENDIF
 X2  C                     ELSE
     C                     Z-ADD0         S1NSPD           N SHIPMENT ADJ. DAY
     C                     MOVEL*BLANK    S1NSHP           N SHIPPING #
     C                     MOVEL*BLANK    S1NCAR           N CARRIER
     C                     MOVEL*BLANK    S1NRUT           N ROUTE
     C                     Z-ADD0         S1NBIN           N BIN #
     C                     Z-ADD0         S1OSPD           O SHIPMENT ADJ. DAY
     C                     MOVEL*BLANK    S1OSHP           O SHIPPING #
     C                     MOVEL*BLANK    S1OCAR           O CARRIER
     C                     MOVEL*BLANK    S1ORUT           O ROUTE
     C                     Z-ADD0         S1OBIN           O BIN #
 E2  C                     ENDIF
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
E1   C                     ENDDO
      *-------------------------
      * CHANGE OVER DATE
     C           D1KKBN    IFEQ '0'                        :削除
     C           D1KKBN    OREQ '1'                        :削除
     C                     Z-ADDB4CHDT    D3CHDT            CHANGE OVER DATE
     C                     ELSE
     C                     Z-ADD@SYSHZ    D3CHDT            CHANGE OVER DATE
     C                     ENDIF
