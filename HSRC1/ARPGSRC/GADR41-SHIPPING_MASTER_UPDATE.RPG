     C           #DSP3     BEGSR
     C                     WRITEGADPW413
     C                     SETON                     7172   SFLDSPCTL
     C                     EXFMTSFCTL1
     C                     SETOF                     7172
     C                     MOVEA'00000000'*IN,51            51-58
     C                     SETOF                     99
     C                     Z-ADD$$RRN     TOPRRN  40
     C                     Z-ADD$$RRN     DSPRRN
      *
     C                     MOVE '#CHK3   '@STEP
