     C                     ENDSR
     C*===============================================================
      *ファイル更新処理
     C*===============================================================
     C           #UPDAT    BEGSR
      ******************************************************
      *        SHIPMENT M/F                                *
      ******************************************************
     C           KEY01     CHAINGADPL11              90
     C   90                CLEARGADPL111
     C*
S1   C                     SELEC
-1   C           D1KKBN    WHEQ '0'                        :削除
     C                     MOVEL'D'       B5SKJY           DELETE CODE D
     C                     Z-ADD@SYSHZ    B5SKHZ           DELETE DATE
     C                     MOVELW$USER    B5SKME           DELETED MEMBER
-1   C                     OTHER                           :ADD CHANGE
     C                     MOVEL' '       B5SKJY           DELETE CODE D
     C                     Z-ADD0         B5SKHZ           DELETE DATE
     C                     MOVEL*BLANK    B5SKME           DELETED MEMBER
     C                     Z-ADD@SYSHZ    B5KOHZ           UPDATE DATE
     C                     Z-ADD@SYSTM    B5KOTM           UPDATE TIME
     C                     MOVELW$USER    B5KOME           UPDATED MEMBER
     C                     Z-ADD$$TOKU    B5TOKU           CUSTOMER CODE
     C                     Z-ADD$$NONY    B5NONY           DELIVERY POINT CODE
     C                     MOVELD1NKOJ    B5NKOJ           FACTORY CODE
     C                     MOVELD1NUKE    B5NUKE           RECEIVING
     C                     MOVELD2KMEI    B5KMEI           FACTORY NAME (KANA)
     C                     Z-ADDD2HIZK    B5HIZK           CYCLE (DAY)
     C                     Z-ADDD2KAIS    B5KAIS           TIME
     C                     Z-ADDD2NBIN    B5NBIN           BIN
     C                     MOVELD2YOB1    B5YOB1           MONDAY
     C                     MOVELD2YOB2    B5YOB2           TUESDAY
     C                     MOVELD2YOB3    B5YOB3           WEDNESDAY
     C                     MOVELD2YOB4    B5YOB4           THURSDAY
     C                     MOVELD2YOB5    B5YOB5           FRIDAY
     C                     MOVELD2YOB6    B5YOB6           SATURDAY
     C                     MOVELD2YOB7    B5YOB7           SUNDAY
     C                     MOVELD2SIRE    B5SIRE           SUPPLIER CODE
     C                     MOVELD2SMEI    B5SMEI           FACTORY CODE
     C                     MOVELD2SKYU    B5SKYU           PROVISION POINT CODE
     C                     MOVELD2CSUC    B5CSUC           CARRIER SET UP CALLED
E1   C                     ENDSL
      *
     C   90                WRITEGADPL111
     C  N90                UPDATGADPL111
      *
      ******************************************************
      *  EXTENTED BIN MASTER (FOR SHIPMENT M/F)            *
      ******************************************************
      *削除（登録・変更も一旦削除する）
     C           KEY01     SETLLGADPL41
      *-------------------------
     C                     DO   *HIVAL
     C           KEY01     READEGADPL41                  90
     C   90                LEAVE
     C           B4SKJY    IFEQ 'D'                        DELETE CODE
     C           B4SKDT    ANDLE@SYSHZ                     DELETED DATE
     C                     ITER
     C                     ENDIF
     C                     MOVE 'D'       B4SKJY           DELETE CODE
     C                     Z-ADD@SYSHZ    B4SKDT           DELETED DATE
     C                     Z-ADD@SYSTM    B4SKTM           DELETED TIME
     C                     MOVELW$USER    B4SKNM           DELETED PERSON
     C                     UPDATGADPL411
     C                     ENDDO
      *-------------------------
      *削除はここで終了
     C           D1KKBN    IFEQ '0'                        :削除
     C                     GOTO $$NEXT
     C                     ENDIF
      *-------------------------
      *登録・変更
     C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               95
     C   95                LEAVE
     C*
     C           KEY02     CHAINGADPL41              90
     C   90                CLEARGADPL411
     C                     MOVE ' '       B4SKJY           DELETE CODE
     C                     Z-ADD0         B4SKDT           DELETED DATE
     C                     Z-ADD0         B4SKTM           DELETED TIME
     C                     MOVEL*BLANK    B4SKNM           DELETED PERSON
     C                     Z-ADD@SYSHZ    B4KODT           UPDATED DATE
     C                     Z-ADD@SYSTM    B4KOTM           UPDATED TIME
     C                     MOVELW$USER    B4KONM           UPDATED PERSON
     C* KEY
     C                     Z-ADD$$TOKU    B4TOKU           CUSTOMER CODE
     C                     Z-ADD$$NONY    B4NONY           DELIVERY POINT CODE
     C                     MOVELD1NKOJ    B4NKOJ           FACTORY CODE
     C                     MOVELD1NUKE    B4NUKE           RECEIVING
     C                     Z-ADDS1BIN     B4KAIS           BIN #
      * OLD BIN INFO.
     C                     MOVELS1OSHP    B4OSHP           SHIPPING #
     C                     MOVELS1OCAR    B4OCAR           CARRIER
     C                     MOVELS1ORUT    B4ORUT           ROUTE
     C                     Z-ADDS1OBIN    B4OBIN           BIN #
     C                     Z-ADDS1OSPD    B4OSPD           SHIPMENT ADJ. DAY
     C*                  * Z-ADD0         B4OSPH           SHIPMENT HOUR
     C*                  * Z-ADD0         B4OSPM           SHIPMENT MINUTES
     C*                  * Z-ADD0         B4OSLD           SALES ADJ. DAY
     C*                  * Z-ADD0         B4OSLH           SALES ADJ. HOUR
     C*                  * Z-ADD0         B4OSLM           SALES ADJ. MINUTES
      * NEW BIN INFO.
     C                     MOVELS1NSHP    B4NSHP           SHIPPING #
     C                     MOVELS1NCAR    B4NCAR           CARRIER
     C                     MOVELS1NRUT    B4NRUT           ROUTE
     C                     Z-ADDS1NBIN    B4NBIN           BIN #
     C                     Z-ADDS1NSPD    B4NSPD           SHIPMENT ADJ. DAY
     C*                  * Z-ADD0         B4NSPH           SHIPMENT HOUR
     C*                  * Z-ADD0         B4NSPM           SHIPMENT MINUTES
     C*                  * Z-ADD0         B4NSLD           SALES ADJ. DAY
     C*                  * Z-ADD0         B4NSLH           SALES ADJ. HOUR
     C*                  * Z-ADD0         B4NSLM           SALES ADJ. MINUTES
      * CHANGE OVER DATE
     C                     Z-ADDD3CHDT    B4CHDT           CHANGE OVER DATE
     C*
     C   90                WRITEGADPL411
     C  N90                UPDATGADPL411
     C  N99                ENDDO
      ******************************************************
      ******************************************************
      *-------------------------
     C           $$NEXT    TAG
      *-------------------------
     C                     MOVE *BLANK    D1KKBN           更新区分
     C                     MOVE *BLANK    D1TOKU           CUSTOMER CODE
     C                     MOVE *BLANK    D1NONY           DELIVERY POINT CODE
     C                     MOVE *BLANK    D1NKOJ           FACTORY CODE
     C                     MOVE *BLANK    D1NUKE           RECEIVING
     C                     MOVE *BLANK    D1ERR            d[ｰxｮﾈｰﾆﾞ
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
