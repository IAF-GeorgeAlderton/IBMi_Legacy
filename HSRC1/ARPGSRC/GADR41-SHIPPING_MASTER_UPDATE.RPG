      * ROLLUP(75)
      * ROLLDOWN(76)
      *-------*
     C           *IN75     IFEQ *ON
     C           *IN76     OREQ *ON
     C                     MOVE '#DSP3   '@STEP
     C                     ENDIF
      *-------*
      * (F3)  *
      *-------*
     C           *INKC     IFEQ *ON
     C                     MOVEA'00000000'*IN,31           31-38
     C                     MOVEA'00000000'*IN,39           39-46
     C                     SETOF                         99
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
      *-------*
      * (F5)  *
      *-------*
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK3 F5'@STEP
     C                     ENDIF
