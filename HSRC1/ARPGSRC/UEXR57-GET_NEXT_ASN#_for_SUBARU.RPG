     H            Y.
      ** UEXR57 ****************************************************
      *  GET NEXT ASN# FOR SUBARU                                  *
      *  JW     2025.02.18                                         *
      **************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR57 '
      *                    PARM           $NOHZ   8
      *                    PARM           $ASN   12
      *   IN  $NOHZ   8A  SHIP DATE
      *   OUT $ASN   12A  SUBARU NEW ASN#
      ***********************************************************
     FAB#PPCT3UF  E           K        DISK                      A
      ***********************************************************
     I            DS
     I                                        1  12 ASN#O
     I                                        1   3 #OSUPP
     I                                        4   5 #ODEPT
     I                                        6   7 #OMON
     I                                        8   9 #ODAY
     I                                       10  12 #OSEQ
     I            DS
     I                                        1  12 ASN#N
     I                                        1   3 #NSUPP
     I                                        4   5 #NDEPT
     I                                        6   6 #NMON
     I                                        7   8 #NDAY
     I                                        9  10 #NYEAR
     I                                       11  12 #NSEQ
     I            DS
     I                                        1   8 XXNOHZ
     I                                        1   4 XXYY
     I                                        5   6 XXMM
     I                                        7   8 XXDD
     I            DS
     I                                        1   30@SEQ3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           $NOHZ   8
     C                     PARM           $ASN   12
      *
     C                     TIME           SDATE
     C                     MOVE *BLANK    $ASN
     C                     MOVE *ALL'0'   ASN#O
     C                     MOVE *ALL'0'   ASN#N
      * CHECK DATE
     C                     MOVEL$NOHZ     $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
      *
     C           $RTN      IFNE ' '
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVEL$TRUE     @NOHZ   80
      *
     C           @NOHZ     IFLE 20250228
     C                     EXSR #OLD
     C                     ELSE
     C                     EXSR #NEW
     C                     ENDIF
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *************************************************************
      * ASN (OLD FORMAT)
      *************************************************************
     C           #OLD      BEGSR
      * GET SEQ#
     C                     CALL 'RTVR02'
     C                     PARM           @SEQ3
      * EDIT ASN#O
     C                     MOVEL@NOHZ     XXNOHZ
     C                     MOVEL'123'     #OSUPP
     C                     MOVEL'01'      #ODEPT
     C                     MOVELXXMM      #OMON
     C                     MOVELXXDD      #ODAY
     C                     MOVEL@SEQ3     #OSEQ
     C                     MOVELASN#O     $ASN
      *
     C                     ENDSR
      *************************************************************
      * ASN (NEW FORMAT)
      *************************************************************
     C           #NEW      BEGSR
      * GET SEQ# FROM PPCT3
     C           @NOHZ     CHAINAB#PPCT3             98
      *
     C           *IN98     IFEQ *OFF
     C                     ADD  1         CTSEQ
     C                     Z-ADDTODAY     CTKOHZ
     C                     Z-ADDNOW       CTKOTM
     C                     MOVEL#USER     CTKOUS
     C                     MOVEL#PGM      CTKOPG
     C                     UPDATAB#PCT31
     C                     Z-ADDCTSEQ     @SEQ2   20
     C                     ELSE
     C                     CLEARAB#PCT31
     C                     Z-ADD@NOHZ     CTNOHZ
     C                     Z-ADD1         CTSEQ
     C                     Z-ADDTODAY     CTKOHZ
     C                     Z-ADDNOW       CTKOTM
     C                     MOVEL#USER     CTKOUS
     C                     MOVEL#PGM      CTKOPG
     C                     WRITEAB#PCT31
     C                     Z-ADD1         @SEQ2
     C                     ENDIF
      * EDIT ASN#N
     C                     MOVEL@NOHZ     XXNOHZ
     C                     MOVEL'123'     #NSUPP
     C                     MOVEL'01'      #NDEPT
      *
     C                     SELEC
     C           XXMM      WHEQ '01'
     C                     MOVE 'A'       #NMON
     C           XXMM      WHEQ '02'
     C                     MOVE 'B'       #NMON
     C           XXMM      WHEQ '03'
     C                     MOVE 'C'       #NMON
     C           XXMM      WHEQ '04'
     C                     MOVE 'D'       #NMON
     C           XXMM      WHEQ '05'
     C                     MOVE 'E'       #NMON
     C           XXMM      WHEQ '06'
     C                     MOVE 'F'       #NMON
     C           XXMM      WHEQ '07'
     C                     MOVE 'G'       #NMON
     C           XXMM      WHEQ '08'
     C                     MOVE 'H'       #NMON
     C           XXMM      WHEQ '09'
     C                     MOVE 'I'       #NMON
     C           XXMM      WHEQ '10'
     C                     MOVE 'J'       #NMON
     C           XXMM      WHEQ '11'
     C                     MOVE 'K'       #NMON
     C           XXMM      WHEQ '12'
     C                     MOVE 'L'       #NMON
     C                     ENDSL
      *
     C                     MOVELXXDD      #NDAY
     C                     MOVE XXYY      #NYEAR
     C                     MOVEL@SEQ2     #NSEQ
     C                     MOVELASN#N     $ASN
      *
     C                     ENDSR
