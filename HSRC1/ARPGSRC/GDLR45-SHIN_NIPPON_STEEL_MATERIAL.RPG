     H            Y/
     F***************************************************
     F*   SHIN NIPPON STEEL MATERIAL
     F*                                                 *
     F*                                                 *
     F*   JUL/24/02  TCH                                *
     F***************************************************
     FGDLPW45 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FIZNPP01 UF  E           K        DISK                      A
     FIZAPL01 IF  E           K        DISK
      *------------------------------------------------------------
     E                    MAT       100 20
     E                    CMD     1   1 78
     E                    MSG     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  20 @MAT
     I                                        1  15 S@ZAIS
     I                                       16  202S@ZAIK
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#IZ      KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVEL'01'      W@ID    2
     C                     EXSR #SET
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C           *LOVAL    SETLLIZNPP01
      *
     C           *IN80     DOUEQ*ON
     C                     READ IZNPP01             N    80
     C           *IN80     IFEQ *OFF
     C           ZNSKJY    ANDEQ*BLANK
     C                     MOVE ZNZAIS    S@ZAIS
     C                     Z-ADDZNZAIK    S@ZAIK
     C                     MOVE ZNZAIS    H@ZAIS
     C                     Z-ADDZNZAIK    H@ZAIK
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     DO   50
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
      * F1
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     SETOF                     9961
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVE *BLANK    MAT
     C                     Z-ADD*ZERO     X       30
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVE *OFF      *IN61
     C           S@ZAIS    IFNE *BLANK
     C           @MAT      LOKUPMAT                      10
     C           *IN10     IFEQ *ON
     C                     SETON                     9961
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C                     MOVE S@ZAIS    K@ZAIS
     C                     Z-ADDS@ZAIK    K@ZAIK
     C           K#IZ      CHAINIZAPL01              95
     C           *IN95     IFEQ *ON
     C                     SETON                     9961
     C                     MOVE MSG,2     D@MSG
     C                     ELSE
     C                     ADD  1         X
     C                     MOVE @MAT      MAT,X
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
      * DELETE
     C           S@ZAIS    IFNE H@ZAIS
     C           H@ZAIS    ANDNE*BLANK
     C                     MOVE H@ZAIS    K@ZAIS
     C                     Z-ADDH@ZAIK    K@ZAIK
     C           K#IZ      CHAINIZNPP01              95
     C           *IN95     IFEQ *OFF
     C                     MOVE 'D'       ZNSKJY
     C                     Z-ADD*DATE     ZNSKDT
     C                     Z-ADD*DATE     ZNKODT
     C                     TIME           ZNKOTM
     C                     MOVEL#USER     ZNKOME
     C                     UPDATIZNPP011
     C                     ENDIF
     C                     ENDIF
      * UPDATE/ADD
     C           S@ZAIS    IFNE H@ZAIS
     C           S@ZAIS    ANDNE*BLANK
     C                     MOVE S@ZAIS    K@ZAIS
     C                     Z-ADDS@ZAIK    K@ZAIK
     C           K#IZ      CHAINIZNPP01              95
     C           *IN95     IFEQ *OFF
     C                     MOVE *BLANK    ZNSKJY
     C                     Z-ADD*ZERO     ZNSKDT
     C                     Z-ADD*DATE     ZNKODT
     C                     TIME           ZNKOTM
     C                     MOVEL#USER     ZNKOME
     C                     UPDATIZNPP011
     C                     ELSE
     C                     CLEARIZNPP011
     C                     MOVE K@ZAIS    ZNZAIS
     C                     Z-ADDK@ZAIK    ZNZAIK
     C                     Z-ADD*DATE     ZNKODT
     C                     TIME           ZNKOTM
     C                     MOVEL#USER     ZNKOME
     C                     WRITEIZNPP011
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
**  CMD
F1:END      F5:UPDATE
**  MSG
    DUPLICATE
    MATERIAL CODE ERROR
