     H            Y.
     F** AL#R85 *********************************************
     F* PALLET PULLING LOCATION M/F
     F*    KATOGI.          2016.02.17                      *
     F*******************************************************
     FAL#PW85 CF  E                    WORKSTN
     FAL#PP85 UF  E           K        DISK                      A
     E                    ER      1  11 65
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAL#PW851
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C                     TIME           WTIME
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN08     IFEQ '1'
     C                     CALL 'AL#R86'
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1UPD     IFEQ '0'
     C           D1UPD     OREQ '2'
     C                     ELSE
     C                     SETON                     3099
     C                     MOVELER,1      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1TKR1    IFEQ *BLANK
     C           D1TKR2    ANDEQ*BLANK
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           KEYCN     KLIST
     C                     KFLD           D1TKR1
     C                     KFLD           D1TKR2
      *
     C           KEYCN     CHAINAL#PP851             20
     C           *IN20     IFEQ '0'
     C           CLSKJY    ANDEQ'D'
     C           CLSKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
      *
     C                     SELEC
     C           D1UPD     WHEQ '0'
     C           *IN20     IFEQ '1'
     C                     SETON                     303199
     C                     MOVELER,3      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C           D1UPD     WHEQ '2'
     C           *IN20     IFEQ '0'
     C                     SETON                     303199
     C                     MOVELER,4      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDSL
      *
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTAL#PW852
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     EXSR #SB500
     C                     MOVELD1UPD     Z1UPD
     C                     MOVELD1TKR1    Z1TKR1
     C                     MOVELD1TKR2    Z1TKR2
     C                     MOVEL*BLANK    D1UPD
     C                     MOVEL*BLANK    D1TKR1
     C                     MOVEL*BLANK    D1TKR2
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYCN     CHAINAL#PP851             20
      *
     C                     SELEC
      *
     C           D1UPD     WHEQ '0'
     C                     MOVEL'D'       CLSKJY
     C                     Z-ADD0         CLSKHZ
     C           *IN20     IFEQ '0'
     C                     UPDATAL#PP851
     C                     ENDIF
      *
     C           D1UPD     WHEQ '2'
     C                     CLEARAL#PP851
     C                     Z-ADD*DATE     CLKOHZ
     C                     TIME           CLKOTI
     C                     MOVELW#USER    CLKOME
     C                     MOVELD1TKR1    CLTKR1
     C                     MOVELD1TKR2    CLTKR2
     C           *IN20     IFEQ '0'
     C                     UPDATAL#PP851
     C                     ELSE
     C                     WRITEAL#PP851
     C                     ENDIF
      *
     C                     ENDSL
      *
     CSR         ESB500    ENDSR
**
ER-1 INPUT 1 OR 2.
ER-2 INPUT LOCATION.
ER-3 NO DATA.
ER-4 ALREADY EXIST.
ER-5 NO PART# M/F.
