     C                     MOVE '-'       WKF4
     C                     MOVE '-'       WKF5
     C           @MHN4     IFEQ *BLANK
     C                     MOVE *BLANK    WKF5
     C                     END
     C           @MHN3     IFEQ *BLANK
     C                     MOVE *BLANK    WKF4
     C                     END
     C                     Z-ADDWKNTAN    @TNK
     C                     Z-ADDWKTKHZ    @SYMD
      *
     C                     MOVE WKTOKU    KTOKU
     C                     MOVE WKNONY    KNONY
