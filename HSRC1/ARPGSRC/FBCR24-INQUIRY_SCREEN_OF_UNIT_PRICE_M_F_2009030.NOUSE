     C                     MOVE '1'       SVFLG
     C           BKSW      IFEQ *BLANK
     C                     MOVE CHKFLD    BKFLD
     C                     MOVE '1'       BKSW    1
     C                     END
     C           INFLD     IFNE SVFLD
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
      *
     C                     END
     C           *IN81     IFEQ '1'
     C           SVFLG     ANDEQ'1'
     C                     MOVE *BLANK    BKSW
      *
     C           @TKCD     IFEQ WKTOKU
     C           @MHN1     ANDEQWKMHN1
     C           @MHN2     ANDEQWKMHN2
     C           @MHN3     ANDEQWKMHN3
     C           @MHN4     ANDEQWKMHN4
     C                     MOVE '1'       GETFLG
     C                     END
      *
     C           GETFLG    IFEQ '1'
