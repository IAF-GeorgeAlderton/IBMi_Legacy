     C           @NOCD     IFEQ 0
     C                     MOVE '1'       GETFLG
     C                     ELSE
     C           @NOCD     IFEQ FBNONY
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
      * FACTORY CHECK
     C           GETFLG    IFEQ '1'
     C                     MOVE '0'       GETFLG
     C           @NKOJ     IFEQ *BLANK
     C                     MOVE '1'       GETFLG
     C                     ELSE
