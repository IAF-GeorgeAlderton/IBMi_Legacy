     H            Y/
     FAB#PPM1 IF  E           K        DISK
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4
     C                     PARM           P@BIN   2
     C                     PARM           P@SDAT  80
     C                     PARM           P@TIME  40
      *
     C                     Z-ADD9999      P@TIME
      *
     C                     MOVE P@NONY    K@NONY  4
     C                     MOVE P@BIN     K@BIN   2
      *
     C           KEY       KLIST
     C                     KFLD           K@NONY
     C                     KFLD           K@BIN
      *
     C           KEY       CHAINAB#PPM1              88
     C           *IN88     IFEQ '0'
     C           M@SKJY    IFEQ 'D'
     C                     SETON                     88
     C                     END
     C                     END
     C           *IN88     IFEQ '0'
     C                     Z-ADDM@NTIM    P@TIME
     C           P@SDAT    IFLT M@CHGD
     C                     Z-ADDM@OTIM    P@TIME
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
