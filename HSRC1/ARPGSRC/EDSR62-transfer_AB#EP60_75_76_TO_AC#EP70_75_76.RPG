     H            Y.
     F** EDSR62 *****************************************************
     F*  PROGRAM: TRANSFER AB#EP60/75/76 TO AC#EP70/75/76 FOR NAPCK *
     F*  TARGET : NAPCK(0323)                                       *
     F*  WRITTEN: JW (SRA)  2022.08.08                              *
     F*  FUNCTION: -------------------                              *
     F*  COPY AB#EP60 TO --> AC#EP70 & DELETE AB#EP60               *
     F*  COPY AB#EP75 TO --> AC#EP75 & DELETE AB#EP75               *
     F*  COPY AB#EP76 TO --> AC#EP76 & DELETE AB#EP76               *
     F*-------------------------------------------------------------*
     FAB#EL60 UF  E           K        DISK
     FAB#EP75 UF  E           K        DISK
     FAB#EP76 UF  E           K        DISK
     FAC#EP70 UF  E           K        DISK                      A
     FAC#EP75 UF  E           K        DISK                      A
     FAC#EP76 UF  E           K        DISK                      A
     FAC#EP70SO   E           K        DISK
     FAC#EP75SO   E           K        DISK
     FAC#EP76SO   E           K        DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *--------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
     C                     EXSR #INIT
      * READ AB#EP60
     C           *LOVAL    SETLLAB#EL60
     C                     DO   *HIVAL
     C                     READ AB#EL60                  91
     C   91                LEAVE
      *
     C           E1PRTN    IFNE '0323'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELE1SHID    K1SHID
     C                     MOVELE1ORDN    K1ORDN
     C                     EXSR #DLT
     C                     EXSR #EP75
     C                     EXSR #EP76
      * ADD HEADER
     C           E1SHID    CHAINAC#EP70              99
     C           *IN99     IFEQ *ON
     C                     WRITEAC#EP701
     C                     Z-ADDTODAY     ECRDT
     C                     Z-ADDNOW       ECRTM
     C                     MOVEL#WSID     ECRWS
     C                     MOVEL#USER     ECRUS
     C                     MOVEL#PGM      ECRPG
     C                     WRITEAC#E70S1
     C                     ENDIF
      *
     C                     DELETAB#EP601
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------
      * DELETE AC#EP75/AC#EP76
      *----------------------------------------------------
     C           #DLT      BEGSR
      * DELETE AC#EP70
     C           K#EP60    SETLLAC#EP70
     C                     DO   *HIVAL
     C           K#EP60    READEAC#EP70                  91
     C   91                LEAVE
      *
     C           E1PRTN    IFNE '0323'
     C                     ITER
     C                     ENDIF
      *
     C                     DELETAC#EP701
     C                     ENDDO
      * DELETE AC#EP70S
     C**         K#EP60    SETLLAC#EP70S
     C**                   DO   *HIVAL
     C**         K#EP60    READEAC#EP70S                 91
     C** 91                LEAVE
      *
     C**         E1PRTN    IFNE '0323'
     C**         ECRDT     ORNE TODAY
     C**                   ITER
     C**                   ENDIF
      *
     C**                   DELETAC#E70S1
     C**                   ENDDO
      * DELETE AC#EP75
     C           K#EP60    SETLLAC#EP75
     C                     DO   *HIVAL
     C           K#EP60    READEAC#EP75                  91
     C   91                LEAVE
      *
     C           E2PRTN    IFNE '0323'
     C                     ITER
     C                     ENDIF
      *
     C                     DELETAC#EP751
     C                     ENDDO
      * DELETE AC#EP75S
     C**         K#EP60    SETLLAC#EP75S
     C**                   DO   *HIVAL
     C**         K#EP60    READEAC#EP75S                 91
     C** 91                LEAVE
      *
     C**         E2PRTN    IFNE '0323'
     C**         E2CRDT    ORNE TODAY
     C**                   ITER
     C**                   ENDIF
      *
     C**                   DELETAC#E75S1
     C**                   ENDDO
      * DELETE AC#EP76
     C           K#EP60    SETLLAC#EP76
     C                     DO   *HIVAL
     C           K#EP60    READEAC#EP76                  91
     C   91                LEAVE
      *
     C           E3PRTN    IFNE '0323'
     C                     ITER
     C                     ENDIF
      *
     C                     DELETAC#EP761
     C                     ENDDO
      * DELETE AC#EP76S
     C**         K#EP60    SETLLAC#EP76S
     C**                   DO   *HIVAL
     C**         K#EP60    READEAC#EP76S                 91
     C** 91                LEAVE
      *
     C**         E3PRTN    IFNE '0323'
     C**         E3CRDT    ORNE TODAY
     C**                   ITER
     C**                   ENDIF
      *
     C**                   DELETAC#E76S1
     C**                   ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
      * TRANSFER AB#EP75
      *----------------------------------------------------
     C           #EP75     BEGSR
      *
     C           K#EP60    SETLLAB#EP75
     C                     DO   *HIVAL
     C           K#EP60    READEAB#EP75                  91
     C   91                LEAVE
      *
     C           E2PRTN    IFNE '0323'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    E2FILE
     C                     WRITEAC#EP751
     C                     Z-ADDTODAY     E2CRDT
     C                     Z-ADDNOW       E2CRTM
     C                     MOVEL#WSID     E2CRWS
     C                     MOVEL#USER     E2CRUS
     C                     MOVEL#PGM      E2CRPG
     C                     WRITEAC#E75S1
     C                     DELETAB#EP751
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
      * TRANSFER AB#EP76
      *----------------------------------------------------
     C           #EP76     BEGSR
      *
     C           K#EP60    SETLLAB#EP76
     C                     DO   *HIVAL
     C           K#EP60    READEAB#EP76                  91
     C   91                LEAVE
      *
     C           E3PRTN    IFNE '0323'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    E3FILE
     C                     WRITEAC#EP761
     C                     Z-ADDTODAY     E3CRDT
     C                     Z-ADDNOW       E3CRTM
     C                     MOVEL#WSID     E3CRWS
     C                     MOVEL#USER     E3CRUS
     C                     MOVEL#PGM      E3CRPG
     C                     WRITEAC#E76S1
     C                     DELETAB#EP761
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
      * INITIAL SET
      *----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K#EP60    KLIST
     C                     KFLD           K1SHID 10
     C                     KFLD           K1ORDN 10
      *
     C                     TIME           SDATE
      *
     C                     ENDSR
