      *************************************************************
      * MAIN ROUTINE
      *************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ASNWP70                  98
     C   98                LEAVE
      *
     C           W1URIM    CHAINAB#PLNO1             99
     C           *IN99     IFEQ *OFF
     C                     ADD  1         I5RENO
     C                     UPDATAB#PLNO1
     C                     ELSE
     C                     Z-ADDW1URIM    I5TUKI
     C                     Z-ADD1         I5RENO
     C                     WRITEAB#PLNO1
     C                     ENDIF
     C* UPDATE AB#PP10
     C                     EXSR #PP10
     C* UPDATE AC#PP10
     C                     EXSR #PP10C
     C* UPDATE AB#PPA1
     C                     EXSR #PPA1
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *************************************************************
      * UPDATE AB#PP10
      *************************************************************
     C           #PP10     BEGSR
      *
     C                     SETOF                     20
     C           KEY1      SETLLAB#PL131
     C           *IN20     DOUEQ*ON
     C           KEY1      READEAB#PL131                 20
     C           *IN20     IFEQ '0'
     C           BASKJY    ANDEQ*BLANK
     C           BADEYY    ANDEQW1REYY
     C           BADEMM    ANDEQW1REMM
     C           BADEDD    ANDEQW1REDD
     C           BAURHZ    ANDEQ*ZERO
     C                     Z-ADDW1TANK    BATANK
     C                     Z-ADDTODAY     BAURHZ
     C                     Z-ADDI5RENO    BARCOD
     C                     Z-ADDWYY       BAKOYY
     C                     Z-ADDWMM       BAKOMM
     C                     Z-ADDWDD       BAKODD
     C                     Z-ADDWJI       BAKOHH
     C                     Z-ADDWFN       BAKOSS
     C                     MOVE #USER     BAKOME
     C                     UPDATAB#PL131
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * UPDATE AC#PP10
      *************************************************************
