      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C*
     C                     TIME           WSDT
     C                     Z-ADDWSSYM     D@YYMM
     C*
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@YYMM    IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
     C*
     C           *LOVAL    SETLLAAMPL11
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AAMPL11                  98
     C   98                LEAVE
     C           CKSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEL*OFF      W@FND   1
     C                     DO   15        X       20
     C                     Z-ADDCHG,X     W@CHG
     C           W@CHG     IFEQ *ZERO
     C                     LEAVE
     C                     END
     C           W@CHG1    IFEQ D@YYMM
     C                     MOVEAPRO       W@PRO  45
     C           W@PRO     IFEQ *BLANK
     C                     ITER
     C                     END
     C                     MOVEAPRC       W@PRC  45
     C           W@PRO     IFNE W@PRC
     C                     MOVEL*ON       W@FND
     C                     LEAVE
     C                     END
     C                     END
     C                     ENDDO
     C*
     C           W@FND     IFEQ *OFF
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL01
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELCKHIN1    W@SHN1
     C                     MOVELCKHIN2    W@SHN2
     C                     MOVELCKHIN3    W@SHN3
     C           CKHIN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C           CKHIN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELW@SHIN    S1PART
     C                     MOVEL'new'     S1TYPE
     C*
     C                     DO   10        X       20
     C                     MOVEAPRC,X     SKO,X
     C           DEP,X     IFNE *ZERO
     C           DEP,X     CHAINFGBPL01              97
     C           *IN97     IFEQ *OFF
     C                     MOVELB2SMEI    SBM,X
     C                     END
     C                     END
     C                     ENDDO
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
      ****
      *  write subfile record showing the effective day of the change.
      *
     C                     CLEARSFL01
      *
     C                     MOVEL'day'     S1TYPE
     C                     DO   10        X
     C                     MOVEACHG,X     W@CHG
     C           W@CHG1    IFEQ D@YYMM
     C**                   MOVELW@CHGD    SKO,X
JW?  C                     MOVELW@CHDD    SKO,X
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      ***************************
     C                     CLEARSFL01
     C*
     C                     MOVEL'old'     S1TYPE
     C                     DO   10        X       20
     C                     MOVEAPRO,X     SKO,X
     C           DEO,X     IFNE *ZERO
     C           DEO,X     CHAINFGBPL01              97
     C           *IN97     IFEQ *OFF
     C                     MOVELB2SMEI    SBM,X
     C                     END
     C                     END
     C                     ENDDO
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C***JW                ENDDO
     C*
     C                     Z-ADD1         #RCNO
     C                     MOVEL*ON       *IN54
     C                     MOVEL*ON       N#MODE
     C*
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C           *INKJ     WHEQ *OFF
     C                     MOVELN#MODE    *IN54
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1:EXIT   ENTER:NEXT
F1:EXIT   F12:GO BACK   F10:DEP NAME
**  MSG
NO DATA
