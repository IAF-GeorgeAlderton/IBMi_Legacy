     FAL#PPC1 IF  E           K        DISK
     FAL#WPC1 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KIHZ  8
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     MOVE P1KIHZ    K1KIHZ  80
     C                     Z-ADD1         WKSORT  50
     C           WKSORT    DOWLE99
     C                     MOVE WKSORT    W1TRKB
     C                     MOVE WKSORT    W1SEQ
     C                     WRITEAL#WPC11
     C                     ADD  1         WKSORT
     C                     ENDDO
      *
     C           K1KIHZ    SETLLAL#PPC11
     C           K1KIHZ    READEAL#PPC11                 80
     C           *IN80     DOWEQ'0'
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB500
     C                     ENDIF
     C           K1KIHZ    READEAL#PPC11                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
      *現在のマスターの値をワークの新旧の値へ
     C           C5TRKB    CHAINAL#WPC11             20
     C           *IN20     IFEQ '0'
     C                     MOVEL'1'       GET     1
     C                     MOVELC5TRKB    W1TRKB
     C                     MOVELC5SURT    W1SURT
     C                     Z-ADDC5STTN    W1STTN
     C                     Z-ADDC5EDTN    W1EDTN
     C                     Z-ADDC5KIHZ    W1KIHZ
     C                     MOVELC5SURT    W1KURT
     C                     Z-ADDC5STTN    W1STTK
     C                     Z-ADDC5EDTN    W1EDTK
     C                     UPDATAL#WPC11
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
