     FEJKPL01 IF  E           K        DISK
     I*
     I            DS
     I                                        1  140@TIME
     I                                        1   60@@TIME
     I                                        7  140@@DATE
     I*
     IINFDSP     SDS
     I                                        1  10 PGMNM
     I                                      254 263 USID
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@JYKB  2         PARTNER GROUP
     C                     PARM           P@LIBL 10         LIBRARY
     C                     PARM           P@FILE 10         FILE
     C                     PARM           P@DKBN  3         EDI DATA CODE
     C                     PARM           P@ORGF 10         RAW FILE NAME
     C                     PARM           P@SAKI 10         HOST NAME
     C*
     C                     TIME           @TIME
     C*
     C                     MOVEL*BLANK    P@JYKB
     C                     MOVEL*BLANK    P@LIBL
     C                     MOVEL*BLANK    P@FILE
     C                     MOVEL*BLANK    P@DKBN
     C                     MOVEL*BLANK    P@ORGF
     C                     MOVEL*BLANK    P@SAKI
     C*
     C           KEY1      KLIST
     C                     KFLD           P@JYKB
     C                     KFLD           P@DKBN
     C*
     C           *LOVAL    SETLLEJKPL011
     C                     DO   *HIVAL
     C                     READ EJKPL011                 99
     C   99                LEAVE
     C*
     C           DJSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C*
     C           DJERHZ    IFNE 0
     C                     ITER
     C                     END
     C*
     C                     MOVELDJJSYS    P@JYKB
     C                     MOVELDJLIBL    P@LIBL
     C                     MOVELDJFILE    P@FILE
     C                     MOVELDJDKBN    P@DKBN
     C                     MOVELDJORGF    P@ORGF
     C                     MOVELDJSAKI    P@SAKI
     C*
