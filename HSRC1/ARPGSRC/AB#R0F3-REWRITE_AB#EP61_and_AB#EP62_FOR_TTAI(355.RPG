     H            Y.
     F** AB#R0F3 ************************************************************
     F*  REWRITE AB#EP61 AND AB#EP62 FOR TTAI(3556)                         *
     F*  JW   2020.11.01                                                    *
JW1  F*  JW   2021.10.06 CHG BOX 4 DIGITS                                   *
     F****************************************** AB#R2C *********************
     FAB#EP61 UF  E           K        DISK                      A
     FAB#EP62 UF  E           K        DISK
     E*****************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************************
      *                    MAIN ROUTINE                                     *
      ***********************************************************************
     C                     EXSR #INIT1
     C                     EXSR #INIT2
      *
     C           SVPRTN    IFEQ '3556'
      * ADJUST AB#EP61
     C                     EXSR #EP61
      * ADJUST AB#EP62
     C                     EXSR #EP62
      *
     C                     ENDIF
      *
     C           ENDP      TAG
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* ADJUST AB#EP61
     C***********************************************************
     C           #EP61     BEGSR
      *
     C                     EXSR #DLT61
      *
     C                     EXSR #WRT61
      *
     C                     ENDSR
     C***********************************************************
     C* ADJUST AB#EP62
     C***********************************************************
     C           #EP62     BEGSR
      *
     C           *LOVAL    SETLLAB#EP62
     C                     DO   *HIVAL
     C                     READ AB#EP62                  96
     C   96                LEAVE
      *
     C           E3PRTN    IFEQ '3556'
     C                     MOVELMST01     E3ORDN
     C                     UPDATAB#EP621
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* FIRST PROCESS
     C***********************************************************
     C           #INIT2    BEGSR
      *
     C                     Z-ADD0         RCNT    40
     C**                   Z-ADD0         BOX#    30
JW1  C                     Z-ADD0         BOX#    40
     C                     Z-ADD0         PAL#    30
     C                     Z-ADD0         MAX#    30
     C                     Z-ADD0         REM#    30
      *
     C           *LOVAL    SETLLAB#EP61
     C                     DO   *HIVAL
     C                     READ AB#EP61                  98
     C   98                LEAVE
      *
     C           E2PRTN    IFEQ '3556'
     C                     ADD  1         RCNT
     C                     EXSR #SV61
     C                     ENDIF
      *
     C                     ENDDO
     C* GET PALLET#
     C                     MOVELSVSHID    $PL#
     C                     CALL 'UEXR07D'
     C                     PARM           $PL#    9
     C                     PARM           $QTY    8
     C                     PARM           $BOX    4
     C                     PARM           $MST#   3
     C                     PARM           $MAX    3
     C                     PARM           $RTN    1
     C                     MOVEL$BOX      BOX#
     C                     MOVEL$MST#     PAL#
     C                     MOVEL$MAX      MAX#
     C           PAL#      SUB  1         WPAL    30
     C           MAX#      MULT WPAL      WBOX    40
     C           BOX#      SUB  WBOX      REM#
      *
     C                     ENDSR
     C***********************************************************
     C* SAVE AB#EP61
     C***********************************************************
     C           #SV61     BEGSR
      *
     C                     MOVELE2SHID    SVSHID
     C                     MOVELE2PRTN    SVPRTN
     C                     MOVELE2MAN#    SVMAN#
     C                     MOVELE2BLN#    SVBLN#
     C                     MOVELE2INVN    SVINVN
     C                     MOVELE2ORDN    SVORDN
     C                     MOVELE2SUPL    SVSUPL
     C                     MOVELE2DEHZ    SVDEHZ
     C                     MOVELE2#LOD    SV#LOD
     C                     MOVELE2#UNT    SV#UNT
     C                     MOVELE2PKCD    SVPKCD
     C                     MOVELE2SERL    SVSERL
      *
     C                     ENDSR
     C***********************************************************
     C* DELETE AB#EP61
     C***********************************************************
     C           #DLT61    BEGSR
      *
     C           *LOVAL    SETLLAB#EP61
     C                     DO   *HIVAL
     C                     READ AB#EP61                  97
     C   97                LEAVE
      *
     C           E2PRTN    IFEQ '3556'
     C                     DELETAB#EP611
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* WRITE AB#EP61
     C***********************************************************
     C           #WRT61    BEGSR
      *
     C           1         DO   PAL#      IX      20
     C                     CLEARAB#EP611
     C                     MOVELSVSHID    E2SHID
     C                     MOVELSVPRTN    E2PRTN
     C                     MOVELSVMAN#    E2MAN#
     C                     MOVELSVBLN#    E2BLN#
     C                     MOVELSVINVN    E2INVN
     C                     MOVELSVSUPL    E2SUPL
     C                     MOVELSVDEHZ    E2DEHZ
      *
     C                     Z-ADD1         E2#LOD
     C                     Z-ADDMAX#      E2#UNT
     C                     MOVEL'BOX'     E2PKCD    P
      *
     C                     MOVELSVSERL    LTR10  10
     C                     MOVE IX        LTR10
     C                     MOVELLTR10     E2SERL    P
     C                     MOVELLTR10     E2ORDN    P
      * FIRST RECORD
     C           IX        IFEQ 1
     C                     MOVELLTR10     MST01
     C                     ENDIF
      * LAST RECORD
     C           IX        IFEQ PAL#
     C                     Z-ADDREM#      E2#UNT
     C                     ENDIF
      *
     C                     WRITEAB#EP611
      *
     C           IX        IFEQ 99
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* INITIAL SET
     C***********************************************************
     C           #INIT1    BEGSR
     C*
     C           *LIKE     DEFN E2SHID    SVSHID
     C           *LIKE     DEFN E2PRTN    SVPRTN
     C           *LIKE     DEFN E2MAN#    SVMAN#
     C           *LIKE     DEFN E2BLN#    SVBLN#
     C           *LIKE     DEFN E2INVN    SVINVN
     C           *LIKE     DEFN E2ORDN    SVORDN
     C           *LIKE     DEFN E2SUPL    SVSUPL
     C           *LIKE     DEFN E2DEHZ    SVDEHZ
     C           *LIKE     DEFN E2#LOD    SV#LOD
     C           *LIKE     DEFN E2#UNT    SV#UNT
     C           *LIKE     DEFN E2PKCD    SVPKCD
     C           *LIKE     DEFN E2SERL    SVSERL
      *
     C                     MOVE *BLANK    MST01  10
      *
     C                     ENDSR
