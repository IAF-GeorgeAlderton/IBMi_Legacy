     H            Y.
     F** AGLR01 **********************************
     F*平準化　箱数変更履歴照会                *
     F*     KATOGI.        2016.01.19            *
     F********************************************
     FAGLPP01 IF  E           K        DISK
     FAGLWP00 O   E                    DISK                      A
      *
     I            DS
     I                                        1  100W1C1
     I                                        1   80W1CR1
     I                                        9  100W1CB1
      *
     I            DS
     I                                        1  100W1C2
     I                                        1   80W1CR2
     I                                        9  100W1CB2
      *
     I            DS
     I                                        1  100Y1AP
     I                                        1   80Y1APHZ
     I                                        9  100Y1APBN
      *
     I            DS
     I                                        1  12 Y1SHN
     I                                        1   5 Y1SHN1
     I                                        6  10 Y1SHN2
     I                                       11  12 Y1SHN3
      *
     I            DS
     I                                        1  12 P#SHN
     I                                        1   5 P#SHN1
     I                                        6  10 P#SHN2
     I                                       11  12 P#SHN3
      *
     I            DS
     I                                        1  100@@AP
     I                                        1   80@@APHZ
     I                                        9  100@@APBN
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C           *ENTRY    PLIST
     C                     PARM           P1CR1   8
     C                     PARM           P1CB1   2
     C                     PARM           P1CR2   8
     C                     PARM           P1CB2   2
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           PCMD    2
      *
     C                     TIME           SDATE
     C           KEYG5     KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C                     KFLD           W1CR1
     C                     KFLD           W1CB1
     C           KEYG6     KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C                     MOVE P1CR1     W1CR1   80
     C                     MOVE P1CB1     W1CB1   20
     C                     MOVE P1CR2     W1CR2   80
     C                     MOVE P1CB2     W1CB2   20
     C           W1C2      IFEQ 0
     C                     Z-ADD*HIVAL    W1C2
     C                     ENDIF
     C           W1CB2     IFEQ 0
     C                     Z-ADD*HIVAL    W1CB2
     C                     ENDIF
      *
     C                     MOVEL*BLANK    P#SHN
     C                     MOVELP1SHN1    P#SHN1
     C                     MOVELP1SHN2    P#SHN2
     C                     MOVELP1SHN3    P#SHN3
      *
     C                     Z-ADD0         WKNO    30
     C           *LOVAL    SETLLAGLPP011
     C                     READ AGLPP011                 80
     C           *IN80     DOWEQ'0'
     C*****      Y1AP      ANDLEW1C2
     C           Y1SKJY    IFEQ 'D'
     C           Y1SKHZ    ANDLEWDATE
     C                     ELSE
     C           Y1AP      IFGE W1C1
     C                     EXSR #SB400
     C                     ENDIF
     C                     ENDIF
     C                     READ AGLPP011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           Y1AP      IFLE W1C2
     C           P#SHN     IFEQ *BLANK
     C                     EXSR #SB500
     C                     ELSE
     C           P#SHN     IFEQ Y1SHN
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAGLWP001
     C                     Z-ADDY1KOHZ    W0KOHZ
     C                     Z-ADDY1KOTI    W0KOTI
     C                     MOVELY1KOME    W0KOME
     C                     MOVELY1SHN1    W0SHN1
     C                     MOVELY1SHN2    W0SHN2
     C                     MOVELY1SHN3    W0SHN3
     C                     Z-ADDY1BHAK    W0BHAK
     C                     Z-ADDY1AHAK    W0AHAK
     C                     Z-ADDY1APHZ    W0APHZ
     C                     Z-ADDY1APBN    W0APBN
     C                     ADD  1         WKNO
     C                     Z-ADDWKNO      W0NO
     C                     WRITEAGLWP001
      *
     CSR         ESB500    ENDSR
