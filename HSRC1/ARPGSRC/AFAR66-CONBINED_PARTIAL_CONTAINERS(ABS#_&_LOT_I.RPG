     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT1,P
     C                     MOVEAAWZETI    ABS1,P
     C                     MOVEAAWPART    PAR1,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT1,P
     C                     MOVEA*BLANK    ABS1,P
     C                     MOVEA'OTHERS'  PAR1,P
     C                     END
     C*
     C                     CLOSEAFAWP60
     C*
     C                     ENDSR
     C**************************************************************************
     C* @WRT:MAKE TBL AND PRINT
     C**************************************************************************
     C           @WRT      BEGSR
     C*
     C* PRINT
     C                     EXCPT#HED1
     C                     EXCPT#HED2
     C                     EXCPT#HED3
     C                     DO   20        Q
     C*
     C                     Z-ADDQ         WRANK   20
     C*
     C                     Z-ADDCNT1,Q    WCNT1   40
     C                     Z-ADDCNT2,Q    WCNT2   40
     C                     Z-ADDCNT3,Q    WCNT3   40
     C                     Z-ADDCNT4,Q    WCNT4   40
     C                     Z-ADDCNT5,Q    WCNT5   40
     C                     Z-ADDCNT6,Q    WCNT6   40
     C                     Z-ADDCNT7,Q    WCNT7   40
     C*
     C                     MOVE ABS1,Q    WABS1   4
     C                     MOVE ABS2,Q    WABS2   4
     C                     MOVE ABS3,Q    WABS3   4
     C                     MOVE ABS4,Q    WABS4   4
     C                     MOVE ABS5,Q    WABS5   4
     C                     MOVE ABS6,Q    WABS6   4
     C                     MOVE ABS7,Q    WABS7   4
     C*
     C                     MOVE PAR1,Q    WPAR1  12
     C                     MOVE PAR2,Q    WPAR2  12
     C                     MOVE PAR3,Q    WPAR3  12
     C                     MOVE PAR4,Q    WPAR4  12
     C                     MOVE PAR5,Q    WPAR5  12
     C                     MOVE PAR6,Q    WPAR6  12
     C                     MOVE PAR7,Q    WPAR7  12
     C*
     C                     EXCPT#DTL
     C*
     C                     END
     C*
     C                     ENDSR
