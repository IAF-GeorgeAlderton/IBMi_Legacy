     H            Y.
     F** AFAR66 *********************************************
     F*  CONBINED PARTIAL CONTAINERS SUMMARY LIST           *
     F*                                                     *
     F*  N-HYOTO  2000.08.25                                *
     F*  H-AMANO  2001.09.07  COUNT = NUMBERS OF ISSUED     *
     F*                                                     *
     F*  *IN90=1(NOT READ AFAPL63)                          *
     F*  *IN91=1(NOT READ AFAWP60)                          *
     F*  *IN88=0(FIRST RECORD)                              *
     F******************************************* AFAR66 ****
     FAFAWP60 IF  E           K        DISK                           UC
     F            AFAWP601                          KRENAMEAFAWP6X
     FAFAWL60 UF  E           K        DISK                      A    UC
     FAFAPL63 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     ********************************************************
     E                    MON         6  3
     E                    NAM     1  12  3
     E                    RAN        26  2 0             RANK
     E                    CNT1       26  4 0             COUNTER
     E                    CNT2       26  4 0             COUNTER
     E                    CNT3       26  4 0             COUNTER
     E                    CNT4       26  4 0             COUNTER
     E                    CNT5       26  4 0             COUNTER
     E                    CNT6       26  4 0             COUNTER
     E                    CNT7       26  4 0             COUNTER
     E                    ABS1       26  4               ABSOLUTE
     E                    ABS2       26  4               ABSOLUTE
     E                    ABS3       26  4               ABSOLUTE
     E                    ABS4       26  4               ABSOLUTE
     E                    ABS5       26  4               ABSOLUTE
     E                    ABS6       26  4               ABSOLUTE
     E                    ABS7       26  4               ABSOLUTE
     E                    PAR1       26 12               PART NUMBER
     E                    PAR2       26 12               PART NUMBER
     E                    PAR3       26 12               PART NUMBER
     E                    PAR4       26 12               PART NUMBER
     E                    PAR5       26 12               PART NUMBER
     E                    PAR6       26 12               PART NUMBER
     E                    PAR7       26 12               PART NUMBER
     ********************************************************
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I                                        7   80SYYYYY
     I                                        9  100SYMMMM
     I* YYYY MM
     I            DS
     I                                        1   60WYM
     I                                        1   40WYMYY
     I                                        5   60WYMMM
     I* DATE(YYYYMMDD) AFAPP60
     I            DS
     I                                        1   40AAYYYY
     I                                        5   60AAMMMM
     I                                        1   60A1DATE
     I* DATE(YYYYMM) AFAWP60
     I            DS
     I                                        1   60K3
     I                                        1   40W2YYYY
     I                                        5   60W2MMMM
     I* DATE(YYYYMMDD) AFAPL60
     I            DS
     I                                        1   80K1
     I                                        1   40WWYYYY
     I                                        5   60WWMMMM
     I                                        7   80WWDDDD
     I* PART1
     I            DS
     I                                        1  12 WPAR1
     I                                        1   5 WPAR11
     I                                        6  10 WPAR12
     I                                       11  12 WPAR13
     I* PART2
     I            DS
     I                                        1  12 WPAR2
     I                                        1   5 WPAR21
     I                                        6  10 WPAR22
     I                                       11  12 WPAR23
     I* PART3
     I            DS
     I                                        1  12 WPAR3
     I                                        1   5 WPAR31
     I                                        6  10 WPAR32
     I                                       11  12 WPAR33
     I* PART4
     I            DS
     I                                        1  12 WPAR4
     I                                        1   5 WPAR41
     I                                        6  10 WPAR42
     I                                       11  12 WPAR43
     I* PART5
     I            DS
     I                                        1  12 WPAR5
     I                                        1   5 WPAR51
     I                                        6  10 WPAR52
     I                                       11  12 WPAR53
     I* PART6
     I            DS
     I                                        1  12 WPAR6
     I                                        1   5 WPAR61
     I                                        6  10 WPAR62
     I                                       11  12 WPAR63
     I* PART7
     I            DS
     I                                        1  12 WPAR7
     I                                        1   5 WPAR71
     I                                        6  10 WPAR72
     I                                       11  12 WPAR73
     C*********************************************************
     C*
     C           *ENTRY    PLIST
     C                     PARM           USRP   10
     C* DEFINE KEY1 FIELD
     C           KEY1      KLIST
     C                     KFLD           WWYYYY
     C                     KFLD           WWMMMM
     C*
     C           KEY2      KLIST
     C                     KFLD           K3
     C                     KFLD           WAZETI  4
     C*
     C           KEY3      KLIST
     C                     KFLD           K3
     C                     KFLD           K32     40
     C*
     C* CALUCULATE 6MONTH BEFORE
     C                     TIME           WTIME
     C                     Z-ADD2000      WWYYYY  40
     C                     ADD  SYYYYY    WWYYYY
     C           SYMMMM    SUB  5         WWMMMM  20
     C           WWMMMM    IFLT 1
     C                     ADD  12        WWMMMM
     C                     SUB  1         WWYYYY
     C                     END
     C*
     C* WORK AREA
     C                     Z-ADD*HIVAL    K32
     C                     Z-ADD*LOVAL    WWDDDD  20
     C                     Z-ADD9999      W2YYYY
     C                     Z-ADD99        W2MMMM
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD*ZERO     Q       20
     C                     Z-ADD*ZERO     P       40
     C                     Z-ADD6         M       20
     C                     Z-ADD*ZERO     WWDATE  60
     C                     Z-ADD*ZERO     WCUNT   40
     C                     Z-ADD*ZERO     WWCUNT  40
     C                     SETON                     88
     C*
     C* SET TITLE OF MONTH
     C                     Z-ADDWWMMMM    I
     C*
     C                     DO   6
     C                     MOVE NAM,I     MON,M
     C                     ADD  1         I
     C                     SUB  1         M
     C           I         IFGT 12
     C                     Z-ADD1         I
     C                     END
     C                     END
     C*
     C* CLEAR TABLE
     C                     CLEARCNT1
     C                     CLEARCNT2
     C                     CLEARCNT3
     C                     CLEARCNT4
     C                     CLEARCNT5
     C                     CLEARCNT6
     C                     CLEARCNT7
     C                     CLEARABS1
     C                     CLEARABS2
     C                     CLEARABS3
     C                     CLEARABS4
     C                     CLEARABS5
     C                     CLEARABS6
     C                     CLEARABS7
     C                     CLEARPAR1
     C                     CLEARPAR2
     C                     CLEARPAR3
     C                     CLEARPAR4
     C                     CLEARPAR5
     C                     CLEARPAR6
     C                     CLEARPAR7
     C*
     C                     EXSR @MFILE
     C                     EXSR @MTBL
     C                     EXSR @WRT
     C*
     C                     SETON                     LR
     C                     RETRN
     C**************************************************************************
     C* @MFILE:MAKE WORK FILE AFAWP60
     C**************************************************************************
     C           @MFILE    BEGSR
     C*
     C                     OPEN AFAWL60
     C*
     C           KEY1      SETLLAFAPL63
     C                     READ AFAPL63                  90
     C           *IN90     DOWEQ'0'
     C           AAZETI    IFEQ WAZETI
     C           A1DATE    ANDEQWYM
     C           AACOPY    IFEQ *ZERO
     C                     ADD  1         WCUNT
     C                     ELSE
     C                     ADD  AACOPY    WCUNT
     C                     ENDIF
     C*
     C                     ELSE
     C* WRITE ONE MONTH
     C           *IN88     IFEQ '1'
     C                     SETOF                     88
     C*
     C                     ELSE
     C                     Z-ADDWCUNT     AWCUNT
     C                     WRITEAFAWP601
     C*
     C* WRITE YTM
     C           KEY2      CHAINAFAWL60              91
     C           *IN91     IFEQ '0'
     C                     ADD  WCUNT     AWCUNT
     C                     UPDATAFAWP601
     C*
     C                     ELSE
     C                     Z-ADD999999    AWDATE
     C                     MOVE WAZETI    AWZETI
     C                     MOVE AAPART    AWPART
     C                     Z-ADDWCUNT     AWCUNT
     C                     WRITEAFAWP601
     C                     END
      *
     C                     END
     C*
     C* SET NEXT DATA
     C                     MOVE AAZETI    WAZETI
     C******               Z-ADD1         WCUNT
     C           AACOPY    IFEQ *ZERO
     C                     Z-ADD1         WCUNT
     C                     ELSE
     C                     Z-ADDAACOPY    WCUNT
     C                     ENDIF
     C                     Z-ADDA1DATE    WYM
     C*
     C                     Z-ADDA1DATE    AWDATE
     C                     MOVE AAZETI    AWZETI
     C                     MOVE AAPART    AWPART
     C*
     C                     END
     C                     READ AFAPL63                  90
     C                     END
      *
     C           *IN88     IFEQ *OFF
     C                     Z-ADDWCUNT     AWCUNT
     C                     WRITEAFAWP601
     C* WRITE YTM
     C           KEY2      CHAINAFAWL60              91
     C           *IN91     IFEQ '0'
     C                     ADD  WCUNT     AWCUNT
     C                     UPDATAFAWP601
     C*
     C                     ELSE
     C                     Z-ADD999999    AWDATE
     C                     MOVE WAZETI    AWZETI
     C                     MOVE AAPART    AWPART
     C                     Z-ADDWCUNT     AWCUNT
     C                     WRITEAFAWP601
     C                     END
      *
     C                     END
      *
     C*
     C                     CLOSEAFAWL60
     C*
     C                     ENDSR
     C**************************************************************************
     C* @WRT:MAKE TBL SORT BY # OF COUNT
     C**************************************************************************
     C           @MTBL     BEGSR
     C*
     C                     OPEN AFAWP60
     C*
     C* SET YTD
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
     C           *IN93     DOWEQ'0'
     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT7,P
     C                     MOVEAAWZETI    ABS7,P
     C                     MOVEAAWPART    PAR7,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT7,P
     C                     MOVEA*BLANK    ABS7,P
     C                     MOVEA'OTHERS'  PAR7,P
     C                     END
     C*
     C*
     C* SET -6 MONTH
     C                     Z-ADDWWYYYY    W2YYYY
     C                     Z-ADDWWMMMM    W2MMMM
     C                     Z-ADD*ZERO     WWCUNT
     C                     Z-ADD*ZERO     P
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
     C           *IN93     DOWEQ'0'
     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT6,P
     C                     MOVEAAWZETI    ABS6,P
     C                     MOVEAAWPART    PAR6,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT6,P
     C                     MOVEA*BLANK    ABS6,P
     C                     MOVEA'OTHERS'  PAR6,P
     C                     END
     C*
     C*
     C* SET -5 MONTH
     C           WWMMMM    ADD  1         W2MMMM
     C           W2MMMM    IFGT 12
     C                     Z-ADD1         W2MMMM
     C           WWYYYY    ADD  1         W2YYYY
     C                     END
     C*
     C                     Z-ADD*ZERO     P
     C                     Z-ADD*ZERO     WWCUNT
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
     C           *IN93     DOWEQ'0'
     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT5,P
     C                     MOVEAAWZETI    ABS5,P
     C                     MOVEAAWPART    PAR5,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT5,P
     C                     MOVEA*BLANK    ABS5,P
     C                     MOVEA'OTHERS'  PAR5,P
     C                     END
     C*
     C*
     C* SET -4 MONTH
     C           WWMMMM    ADD  2         W2MMMM
     C           W2MMMM    IFGT 12
     C                     Z-ADD1         W2MMMM
     C           WWYYYY    ADD  1         W2YYYY
     C                     END
     C*
     C                     Z-ADD*ZERO     P
     C                     Z-ADD*ZERO     WWCUNT
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
     C           *IN93     DOWEQ'0'
     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT4,P
     C                     MOVEAAWZETI    ABS4,P
     C                     MOVEAAWPART    PAR4,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT4,P
     C                     MOVEA*BLANK    ABS4,P
     C                     MOVEA'OTHERS'  PAR4,P
     C                     END
     C*
     C*
     C* SET -3 MONTH
     C           WWMMMM    ADD  3         W2MMMM
     C           W2MMMM    IFGT 12
     C                     Z-ADD1         W2MMMM
     C           WWYYYY    ADD  1         W2YYYY
     C                     END
     C*
     C                     Z-ADD*ZERO     P
     C                     Z-ADD*ZERO     WWCUNT
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
     C           *IN93     DOWEQ'0'
     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT3,P
     C                     MOVEAAWZETI    ABS3,P
     C                     MOVEAAWPART    PAR3,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT3,P
     C                     MOVEA*BLANK    ABS3,P
     C                     MOVEA'OTHERS'  PAR3,P
     C                     END
     C*
     C*
     C* SET -2 MONTH
     C           WWMMMM    ADD  4         W2MMMM
     C           W2MMMM    IFGT 12
     C                     Z-ADD1         W2MMMM
     C           WWYYYY    ADD  1         W2YYYY
     C                     END
     C*
     C                     Z-ADD*ZERO     P
     C                     Z-ADD*ZERO     WWCUNT
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
     C           *IN93     DOWEQ'0'
     C*
     C                     ADD  1         P
     C           P         IFGT 19
     C                     ADD  AWCUNT    WWCUNT
     C*
     C                     ELSE
     C                     Z-ADDAWCUNT    CNT2,P
     C                     MOVEAAWZETI    ABS2,P
     C                     MOVEAAWPART    PAR2,P
     C                     END
     C*
     C           K3        REDPEAFAWP6X                  93
     C                     END
     C*
     C           P         IFGT 19
     C                     Z-ADD20        P
     C                     Z-ADDWWCUNT    CNT2,P
     C                     MOVEA*BLANK    ABS2,P
     C                     MOVEA'OTHERS'  PAR2,P
     C                     END
     C*
     C*
     C* SET THIS MONTH
     C           WWMMMM    ADD  5         W2MMMM
     C           W2MMMM    IFGT 12
     C                     Z-ADD1         W2MMMM
     C           WWYYYY    ADD  1         W2YYYY
     C                     END
     C*
     C                     Z-ADD*ZERO     P
     C                     Z-ADD*ZERO     WWCUNT
     C           KEY3      SETGTAFAWP6X
     C           K3        REDPEAFAWP6X                  93
