     H            Y.
     F** ABCR07 ************************************
     F* ... A CALCULATION OF PART WITHDRAWAL KANBAN SHEETS.. *
     F*        I-HASADA            86.10.07        *
     F*
     F* TCHK1 08/02/10 CHG ADJUST VALUE
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.23|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F******************************************************* ABCR07 **
     C           *ENTRY    PLIST
     C                     PARM           ASURI   2
     C                     PARM           L6KTSU  90
     C                     PARM           L6KEIS  32
     C                     PARM           L6LTIM  31
     C                     PARM           L6SYOS  50
     C                     PARM           L6LOTO  20
     C                     PARM           L6MAXH  30
     C                     PARM           WMAIS   50
      *
     C           ASURI     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*------------------------------------------*
     C*     ...引取かんばん枚数の計算式...     *
     C*------------------------------------------*
     C           L6KTSU    MULT L6KEIS    WTOT1   70H
     C           WTOT1     MULT L6LTIM    WTOT2   80H
     C           L6SYOS    IFNE *ZERO
     C           WTOT2     DIV  L6SYOS    WTOT3   70
     C                     MVR            AMAR1   70
      *
     C           AMAR1     IFNE 0
     C                     ADD  1         WTOT3
     C                     END
      *
     C           L6KTSU    DIV  L6SYOS    WTOT4   60
     C                     MVR            AMAR2   60
      *
     C           AMAR2     IFNE 0
     C                     ADD  1         WTOT4
     C                     END
     C                     END
      *
TCHK1C*          WTOT4     IFLE 5
TCHK1C*                    Z-ADD2         WSRO    10
TCHK1C           WTOT4     IFLE 1
TCHK1C                     Z-ADD1         WSRO    10
     C                     ELSE
     C                     Z-ADD0         WSRO
     C                     END
      *
     C           WTOT3     ADD  WSRO      WTOT5   70
     C           L6LOTO    IFNE 0
     C                     Z-ADDL6LOTO    WWLT    30
     C                     ELSE
     C                     Z-ADD1         WWLT
     C                     END
      *
     C           WWLT      SUB  1         WTOT6   30
     C           WTOT5     ADD  WTOT6     WTOT7   80
     C           WTOT7     ADD  L6MAXH    WMAIS
      *
     C                     RETRN
