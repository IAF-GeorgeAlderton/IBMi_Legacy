      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#LOC     KLIST
     C                     KFLD           @@L1
     C                     KFLD           @@L2
     C                     KFLD           @@L3
     C                     KFLD           @@L4
     C           K#AJ1     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           @@LOT
     C           K#AJ2     KLIST
     C                     KFLD           @@ZETI  4
     C                     KFLD           @@LOT
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET11
     C                     EXSR #SET12
     C           RRN1      IFNE 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           K#KEY     CHAINAH#PL50              90
     C           *IN90     IFEQ *ON
     C                     MOVE ER,1      D@MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SFL CTL
      *------------------------------------------------------
     C           #SET11    BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *BLANK    D@L
     C                     MOVE *BLANK    D@F
     C                     MOVE *BLANK    D@P
      *
     C           K#KEY     CHAINFCEPL01              90
      * LOC,ETC
     C           K#KEY     CHAINAAMPL11              90
     C           *IN90     IFEQ *OFF
     C           CKSKJY    ANDEQ*BLANK
     C           1         DO   7         A       20
     C                     Z-ADDCHG,A     DAT10
     C           DAT8      IFLT *DATE
     C                     MOVE PRC,A     D@P,A
     C           FCT,A     IFNE 0
     C                     MOVE FCT,A     D@F,A
     C                     ENDIF
     C                     MOVE LOC,A     D@L,A
      *
     C           PRC,A     IFEQ 'OQ '
     C           PRC,A     OREQ 'DCF'
     C           PRC,A     OREQ 'BZ '
     C                     MOVE MCN,A     @@MCN   3
     C                     ENDIF
      *
     C                     ELSE
     C                     MOVE ORC,A     D@P,A
     C           OCT,A     IFNE 0
     C                     MOVE OCT,A     D@F,A
     C                     ENDIF
     C                     MOVE OOC,A     D@L,A
     C                     ENDIF
     C           NCKQ,A    IFNE *BLANK
     C                     MOVE NCKQ,A    @@KAN   1
     C                     MOVE D@L,A     @@LOC
     C                     ENDIF
      *
     C           ORC,A     IFEQ 'OQ '
     C           ORC,A     OREQ 'DCF'
     C           ORC,A     OREQ 'BZ '
     C                     MOVE OCN,A     @@MCN
     C                     ENDIF
      *
     C                     ENDDO
      *
      * SETTING #
     C                     Z-ADD*ZERO     D@SETQ
     C                     SELEC
     C           @@KAN     WHEQ 'C'
     C           K#LOC     SETLLAAFPL03
     C           *IN95     DOUEQ*ON
     C           K#LOC     READEAAFPL03                  95
     C           *IN95     IFEQ *OFF
     C           A31HB5    ANDEQD@PRT1
     C           A32HB5    ANDEQD@PRT2
     C           A33HB2    ANDEQD@PRT3
     C           A3SKJY    IFEQ 'D'
     C           A3STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C                     Z-ADDA3KMAX    D@SETQ
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           @@KAN     WHEQ 'D'
     C           K#LOC     SETLLAAGPL03
     C           *IN95     DOUEQ*ON
     C           K#LOC     READEAAGPL03                  95
     C           *IN95     IFEQ *OFF
     C           O4SHN1    ANDEQD@PRT1
     C           O4SHN2    ANDEQD@PRT2
     C           O4SHN3    ANDEQD@PRT3
     C           O4SKJY    IFEQ 'D'
     C           O4STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C                     Z-ADDO4KMAX    D@SETQ
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           @@KAN     WHEQ 'E'
     C           K#LOC     SETLLAAHPL03
     C           *IN95     DOUEQ*ON
     C           K#LOC     READEAAHPL03                  95
     C           *IN95     IFEQ *OFF
     C           L6SHN1    ANDEQD@PRT1
     C           L6SHN2    ANDEQD@PRT2
     C           L6SHN3    ANDEQD@PRT3
     C           L6SKJY    IFEQ 'D'
     C           L6STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL6KMAX    D@SETQ
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           @@KAN     WHEQ '0'
     C           K#LOC     SETLLAAPPL03
     C           *IN95     DOUEQ*ON
     C           K#LOC     READEAAPPL03                  95
     C           *IN95     IFEQ *OFF
     C           L5SHN1    ANDEQD@PRT1
     C           L5SHN2    ANDEQD@PRT2
     C           L5SHN3    ANDEQD@PRT3
     C           L5SKJY    IFEQ 'D'
     C           L5STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL5KMAX    D@SETQ
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSL
      *
     C                     ENDIF
      * WIP/STOCK
     C           K#KEY     CHAINAH#PL50              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA5INVQ    D@WIP
     C                     ENDIF
      * WAITING
     C                     Z-ADD*ZERO     D@WAIT
     C           K#KEY     CHAINAGAPL31              90
     C           *IN90     IFEQ *OFF
     C           CBSKJY    ANDEQ*BLANK
     C           CBHASU    DIV  CBSYUY    D@WAIT
     C                     ENDIF
     C           K#KEY     SETLLAD#PL11
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAD#PL11                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  CAHAKO    D@WAIT
     C                     ENDIF
     C                     ENDDO
      *
     C           D@WAIT    ADD  D@WIP     D@HAND
     C           D@SETQ    SUB  D@HAND    D@RSLT
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SFL
      *------------------------------------------------------
     C           #SET12    BEGSR
      *
     C                     MOVE *BLANK    @@LOT   3
     C                     CLEARSFL01
     C           K#KEY     SETLLAH#PL61
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAH#PL61                  90
     C           *IN90     IFEQ *OFF
     C           A6SKJY    ANDEQ*BLANK
     C           @@LOT     IFNE *BLANK
     C           @@LOT     ANDNEA6THNO
     C                     ADD  1         RRN1
     C                     EXSR #PLAT
     C                     WRITESFL01
     C                     CLEARSFL01
     C                     ENDIF
      *
     C                     MOVE A6THNO    @@LOT
     C                     MOVE A6ZENO    @@ZETI
     C                     MOVE A6THNO    S@THNO
     C                     MOVE A6CHYU    S@KID
     C                     Z-ADDA6ISDT    S@ISDT
     C                     Z-ADDA6ISDT    H@ISDT
     C                     Z-ADDA6ISBN    S@ISBN
     C                     ADD  1         S@KQTY
     C                     ENDIF
     C                     ENDDO
      *
     C           S@KQTY    IFNE *ZERO
     C                     ADD  1         RRN1
     C                     EXSR #PLAT
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PLATING INFORMATION
      *------------------------------------------------------
     C           #PLAT     BEGSR
      *
     C                     MOVE *OFF      *IN96
     C           K#AJ2     SETGTAJSPL25
     C           *IN95     DOUEQ*ON
     C           K#AJ2     REDPEAJSPL25                  95
     C           *IN95     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
     C           J2HIN1    ANDEQD@PRT1
     C           J2HIN2    ANDEQD@PRT2
     C           J2HIN3    ANDEQD@PRT3
     C           J2KEDT    ANDGEH@ISDT
     C                     Z-ADDJ2WIDT    S@INDT
     C                     Z-ADDJ2KEDT    S@OTDT
     C                     MOVE *ON       *IN96
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN96     IFEQ *OFF
     C           K#AJ1     SETGTAJSPL16
     C           *IN95     DOUEQ*ON
     C           K#AJ1     REDPEAJSPL16                  95
     C           *IN95     IFEQ *OFF
     C           J1WIDT    ANDGEH@ISDT
     C                     Z-ADDJ1WIDT    S@INDT
     C                     MOVE *ON       *IN96
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           *IN96     IFEQ *OFF
     C           K#AJ2     SETGTAJSPL65
     C           *IN95     DOUEQ*ON
     C           K#AJ2     REDPEAJSPL65                  95
     C           *IN95     IFEQ *OFF
     C           J6SKJY    ANDEQ*BLANK
     C           J6HIN1    ANDEQD@PRT1
     C           J6HIN2    ANDEQD@PRT2
     C           J6HIN3    ANDEQD@PRT3
     C           J6KEDT    ANDGEH@ISDT
     C                     Z-ADDJ6WIDT    S@INDT
     C                     Z-ADDJ6KEDT    S@OTDT
     C                     MOVE *ON       *IN96
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO1
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK - 2ND SCREEN
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@OPT     ANDNE*BLANK
     C                     MOVE *BLANK    S@OPT
     C                     UPDATSFL01
     C                     MOVE S@THNO    @@LOT
     C                     MOVE S@THNO    D@THNO
     C                     MOVE S@KID     D@KID
     C                     Z-ADDS@ISDT    D@ISDT
     C                     Z-ADDS@ISBN    D@ISBN
     C                     Z-ADDS@KQTY    D@KQTY
     C                     Z-ADDS@INDT    D@INDT
     C                     Z-ADDS@OTDT    D@OTDT
     C                     EXSR #SET2
     C           RRN2      IFEQ *ZERO
     C                     EXSR #SET22
     C                     ENDIF
      *
     C           RRN2      IFNE *ZERO
     C                     MOVE '03'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SFL CTL
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2    40
      *
     C           K#AJ1     SETLLAJSPL16
     C           *IN95     DOUEQ*ON
     C           K#AJ1     READEAJSPL16                  95
     C           *IN95     IFEQ *OFF
     C           J1SKJY    ANDEQ*BLANK
     C           J1WIDT    ANDGEH@ISDT
     C                     CLEARSFL02
     C                     ADD  1         RRN2
     C                     MOVEAJ1G       S@G
     C                     MOVE J1MKKB    S@MCN
     C                     MOVE J1THAI    S@LOTN
     C                     Z-ADDJ1WIDT    S@CHDT
     C                     Z-ADDJ1TIME    S@CHTM
      *
     C           1         DO   4         X       20
     C           J1G,X     IFNE *BLANK
     C                     ADD  1         S@BOX
     C                     ENDIF
     C                     ENDDO
      *
     C           S@BOX     MULT A2SSYS    S@QTY
      *  DISCHARGE
     C                     EXSR #DCH
      *
     C                     WRITESFL02
      *
     C                     ENDIF
     C                     ENDDO
      *
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DISCHARGE DATE
      *------------------------------------------------------
     C           #DCH      BEGSR
      *
     C           K#AJ2     SETGTAJSPL25
     C           *IN96     DOUEQ*ON
     C           K#AJ2     REDPEAJSPL25                  96
     C           *IN96     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
     C           J2HIN1    ANDEQD@PRT1
     C           J2HIN2    ANDEQD@PRT2
     C           J2HIN3    ANDEQD@PRT3
     C           J2KEDT    ANDGEH@ISDT
      *
     C           J2KEDT    IFLT J1WIDT
     C           J2KEDT    OREQ J1WIDT
     C           J2TIME    ANDLTJ1TIME
     C                     ITER
     C                     ENDIF
      *
     C           1         DO   4         X
     C           J2G,X     LOKUPJ1G                      10
     C           *IN10     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN10     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDJ2KEDT    S@DCDT
     C                     Z-ADDJ2TIME    S@DCTM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SFL CTL
      *------------------------------------------------------
     C           #SET22    BEGSR
      *
     C           K#AJ2     SETGTAJSPL65
     C           *IN96     DOUEQ*ON
     C           K#AJ2     REDPEAJSPL65                  96
     C           *IN96     IFEQ *OFF
     C           J6SKJY    ANDEQ*BLANK
     C           J6HIN1    ANDEQD@PRT1
     C           J6HIN2    ANDEQD@PRT2
     C           J6HIN3    ANDEQD@PRT3
     C           J6KEDT    ANDGEH@ISDT
     C                     CLEARSFL02
      *
     C                     ADD  1         RRN2
     C                     MOVEAJ6G       S@G
     C                     MOVE @@MCN     S@MCN
     C                     MOVE J6THAI    S@LOTN
     C                     Z-ADDJ6WIDT    S@CHDT
     C                     Z-ADDJ6TIM1    S@CHTM
     C                     Z-ADDJ6KEDT    S@DCDT
     C                     Z-ADDJ6TIM2    S@DCTM
      *
     C           1         DO   4         X       20
     C           J6G,X     IFNE *BLANK
     C                     ADD  1         S@BOX
     C                     ENDIF
     C                     ENDDO
      *
     C           S@BOX     MULT A2SSYS    S@QTY
      *
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN2      IFEQ *ZERO
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'02'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
 F1:EXIT
 F1:EXIT    F12:GO BACK
**  ER
  NO DATA
