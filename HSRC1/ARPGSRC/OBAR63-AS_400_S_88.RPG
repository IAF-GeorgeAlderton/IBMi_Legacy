     F* AUTHOR.         : S.OOTAKE                  *
     A*********************************   OBAR63   **
     F** WORK FILE
     FOBAWP60 IP  F     100            DISK
     I****************************************
     F***** PART M/F
     FFCETL11 IF  E           K        DISK
     F*****************************************
     F** PRINTER FILE
     FOBAPR63 O   E             95     PRINTER
     F********************************************
     IOBAWP60 AA
     I                                        3   60NONYM
     I                                        7   7 NKOJM
     I                                        8  11 NUKEM
     I                                       20  23 ZETI
     I                                       38  430SUURYO
     I                                       44  480SYUYO
     I                                       49  510HAKOSU
     I                                       52  580HASU
     I                                       59  590HASUHK
     I                                       67  680KMM
     I                                       69  730RCDNM
     I* 部品マスターの削除日付 *
     I            DS
     I                                        1   80A2HIZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   70WJUCHU
     I                                        1   20WKMM
     I                                        3   70WRCDNM
     C*
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C           KEY       KLIST
     C                     KFLD           ZETI
     C*****************************************
     C***     プログラム　スタート        ***
     C*****************************************
     C*
     C           *IN50     IFEQ '0'
     C                     MOVE *BLANK    PUSNM  15
     C                     CALL 'APLR00'
     C                     PARM           USER
     C                     PARM           PUSNM
     C                     MOVELPUSNM     TANNAM  8
     C                     WRITEOBAPR631
     C                     SETON                     50
     C                     GOTO STEP
     C                     END
     C*
     C           *IN95     IFEQ '1'
     C                     WRITEOBAPR631
     C                     SETOF                     95
     C                     END
     C*
     C           STEP      TAG
     C                     MOVE NONYM     PNONYM
     C                     MOVE NKOJM     PNKOJM
     C                     MOVE NUKEM     PNUKEM
     C                     MOVE ZETI      PZETI
     C                     MOVE SUURYO    PSURYO
     C                     MOVE SYUYO     PSYUYO
     C                     MOVE HAKOSU    PHAKO
     C                     MOVE HASU      PHASU
     C                     MOVE HASUHK    PHAHK
     C                     MOVE KMM       WKMM    20
     C                     MOVE RCDNM     WRCDNM  50
     C                     MOVE WJUCHU    PJUCHU
     C*  ﾎﾞﾍ] uﾇjｰ ･ CHAIN
     C                     MOVE *BLANK    PHIN1
     C                     MOVE *BLANK    PHIN2
     C                     MOVE *BLANK    PHIN3
     C                     MOVE *BLANK    PHIF1
     C                     MOVE *BLANK    PHIF2
     C                     SETOF                     30
     C           KEY       CHAINFCETL11              30
     C           *IN30     IFEQ '1'
     C                     GOTO SKIP
     C                     END
     C           *IN30     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2HIZ     ANDLE*DATE
     C                     GOTO SKIP
     C                     END
     C                     END
     C*
     C                     MOVE A2BHB1    PHIN1   5
     C                     MOVE A2BHB2    PHIN2   5
     C                     MOVE A2BHB3    PHIN3   2
     C                     MOVE '-'       PHIF1
     C                     MOVE '-'       PHIF2
     C           SKIP      TAG
     C                     WRITEOBAPR632
     C                     ADD  1         PTOTAL
     CLR                   WRITEOBAPR633
     C*
