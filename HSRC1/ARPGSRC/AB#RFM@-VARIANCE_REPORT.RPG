     C* MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C* NIRVANA PLANT EXISTS IN ROUTE MASTER
     C* READ AND PROCESS ALL ROUTE MASTER RECORD
TCH23C*          *LOVAL    SETLLABFDP01R
TCH23C           *LOVAL    SETLLABFDL01R
TCH23C*                    READ ABFDP01R                 90
TCH23C                     READ ABFDL01R                 90
B01  C           *IN90     DOWEQ'0'
  |  C                     Z-ADDQANONY    K@NONY
     C                     MOVE QADOCK    K@DOCK
%0001C           QASKJY    IFEQ *BLANK
     C           QAEFHZ    ANDLE*DATE
     C           @@NONY    IFEQ *ZERO
     C           @@NONY    ORNE *ZERO
     C           @@NONY    ANDEQQANONY
TCH23C*
  |  C**                   Z-ADDQANONY    K@NONY
     C**                   MOVE QADOCK    K@DOCK
      *
     C           K#ADF     SETGTABFDL01R
     C           *IN88     DOUEQ*ON
     C           K#ADF     REDPEABFDL01R                 88
     C           *IN88     IFEQ *ON
     C           K#ADF     SETGTABFDL01R
     C                     LEAVE
     C                     ELSE
%0001C           QASKJY    IFEQ 'D'
%0001C           QASKHZ    ANDLE*DATE
%0001C                     ITER
     C                     ENDIF
     C           QAEFHZ    IFGT *DATE
%0001C                     ITER
     C                     ENDIF
     C                     LEAVE
      *
     C                     ENDIF
   | C                     ENDDO
TCHK9C*
TCHK9C*****      *IN88     IFEQ *ON
TCHK9C*****                GOTO @@JUMP
TCHK9C*****                END
TCH23C*
     C*
     C* SET ROUTE CODE TO INVOICE#
     C                     MOVE WROUT     WINV1
     C*
     C* READ ADDRESS MASTER
     C           QAPLAN    CHAINABF9P01              93
B02  C           *IN93     IFEQ '1'
TCHK1C           *INOF     IFEQ *ON
TCHK1C                     EXCPT#HED1
TCHK1C                     EXCPT#HED2
TCHK1C                     SETOF                     OF
TCHK1C                     END
TCHK1C                     MOVEL'  '      W#MARK  2
TCHK9C*TCHK1     *IN96     IFEQ *OFF
TCHK9C*TCHK1     WSURY     IFGT BASRYO
TCHK9C*TCHK1               MOVEL'++'      W#MARK
TCHK9C*TCHK1               END
TCHK9C*TCHK1               END
     C                     EXCPT#DTL1
E02  C                     END
     C*
     C* READ EDI KEY FILE
     C                     MOVELQADOCK    K12     4
     C           KEY1      SETLLABFAP01R
     C           KEY1      READEABFAP01R                 91
B02  C           *IN91     DOWEQ'0'
TCHK2C*TCH65     CFDLCD    ANDEQ' '
TCHK2C           CFDLCD    IFNE *BLANK
TCHK2C                     GOTO @@SKP
TCHK2C                     END
TCHK4C           CFDOCK    IFEQ '0095'
TCHK4C                     GOTO @@SKP
TCHK4C                     END
TCHK6C           CFDK@2    IFEQ 'IE'
TCHK6C                     GOTO @@SKP
TCHK6C                     END
     C*
     C* READ FORD EDI FILE
     C           CFSIDT    CABLTW@LMT     @@SKP
      *
     C                     MOVELCFPART    K21    20
TCHK7C                     Z-ADD1         WW      10
TCHK7C           CFPART    LOKUPP1,WW                    10
TCHK7C   10                MOVELP2,WW     K21
     C*******              Z-ADDWSDAT     K22     80
     C                     Z-ADDWRDAT     K22     80
     C           KEY2      CHAINABF2P011             92
B03  C           *IN92     IFEQ '0'
     C*
     C* SET AB#WP451(INPUT FILE FOR AB#R45)
     C                     MOVE 'AVRT'    WSIRE   4        SUPPLIER CODE
     C                     MOVE 'A'       WSIRK   1        FACTORY  CODE
     C                     MOVE '5149'    WTOKU   40       CUSTOMER CODE
     C                     MOVE QANONY    WNONY   40       DELIVERY CODE
     C                     MOVE '0'       WNKOJ   1        FACTORY  CODE
     C                     MOVELQADOCK    WNUKE   4        RECEIVING   E
     C                     MOVE *BLANK    WSBAN   4        NUMBER      E
     C                     MOVE *BLANK    WMHIN
     C                     MOVELAFIPAR    WMHIN  20        PART NUMBER E
     C                     Z-ADDWSDAT     WNYMD   80       DELIVERY DATE
     C                     MOVEL'11111'   WODRN  10        ORDER #     E
      *
     C                     Z-ADD*ZERO     XXQTY   90
     C                     Z-ADD*ZERO     XXYMD
     C                     Z-ADD*ZERO     WQTY2
     C                     Z-ADD*ZERO     WSURY
TCHK8C*          AFLSDT    IFNE *ZERO
TCHK8C           AFLSDT    IFNE *ZERO
     C           20000000  ADD  AFLSDT    XXYMD
TCHK8C                     ELSE
TCHK8C           2000      ADD  WDAYY     XXYY
TCHK8C                     END
     C                     Z-ADDXXYY      @@YYYY
     C                     Z-ADDXXMM      @@MMMM
     C                     Z-ADDXXDD      @@DDDD
     C           K#AB      SETGTAB#PL15
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEAB#PL15                  97
     C           *IN97     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE WSDAT
     C                     LEAVE
     C                     ENDIF
     C                     ADD  BASRYO    XXQTY
     C                     ENDIF
     C                     ENDDO
TCHK8C*                    ENDIF
     C*
     C* NOT WORKING DAY,RE-CULUCULATE
     C           *IN89     IFEQ '1'
TCHK3C*                    EXSR @MOVE
TCHK3C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
TCHK3C                     SUB  XXQTY     WQTY2
TCHK3C                     Z-ADDWQTY2     WSURY   70
     C*
     C                     ELSE
     C*
     C* REQUESTED CUM - SHIPPED CUM
      *
      *
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  XXQTY     WQTY2
     C                     Z-ADDWQTY2     WSURY   70
     C                     END
      *
TCHK9C*B04       WQTY2     IFGT *ZERO
     C*
     C                     EXSR #ER1
     C*
     C***** GET UNIT QUANTITY
     C                     MOVELWTOKU     PTOKU   4
     C                     MOVELWNONY     PNONY   4
     C                     MOVELWNKOJ     PNKOJ   1
     C                     MOVELWNUKE     PNUKE   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVELWMHIN     WMHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
     C*
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           @MHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG
     C*
     C* GET QTY./CONT. FROM PART MASTER
     C********8            Z-ADD1         WSYOS            FOR ERROR
     C           KEY4      SETLLFCEPL011
     C           #READ1    TAG
     C           KEY4      READEFCEPL011                 94
B05  C           *IN94     IFEQ '0'
B06  C           A2GSKD    ANDEQ*BLANK
     C*
B06  C           A2SSHZ    IFLE *DATE
     C                     Z-ADDA2SSYS    WSYOS   60
     C                     ELSE
     C                     Z-ADDA2KSYS    WSYOS
E06  C                     ENDIF
     C*
E04  C                     ENDIF
     C*
     C* CHECK FRACTION OR NOT
B04  C           WSYOS     IFNE *ZERO
     C           WQTY2     DIV  WSYOS     WQTY2
     C                     MVR            WREST   40
B05  C           WREST     IFNE *ZERO
E05  C                     END
     C*
E04  C                     ENDIF
     C*
     C                     Z-ADD*ZERO     WNOTM   40       INVOICE TIME
     C                     Z-ADD*ZERO     WUSYS   60       USER QTY/CONT.
TCH23C***                  MOVE '01'      WBIN    20       BIN
   | C           QAROUT    CHAINABFBP10              95
     C           *IN95     IFEQ *OFF
     C                     MOVE B1BINN    WBIN    20
     C                     ELSE
   | C                     MOVE '06'      WBIN
TCH23C                     ENDIF
     C                     MOVELAFALFL    WALFL   4        FEED LINE
     C*
     C* GET INVOICE NUMBER(ROUTE + JULIAN DATE)
     C           KEY3      CHAINABFEP01              95
B04  C           *IN95     IFEQ '0'
     C           QB#DAY    ADD  WSDDDD    WINV2
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     WINV2
E04  C                     END
     C*
     C                     MOVELAFRALF    WRLOC   4
     C*
     C                     MOVE *OFF      *IN87
     C****       KEY6      CHAINAB#PL151             96
     C           KEY6      SETLLAB#PL151
     C           *IN96     DOUEQ*ON
     C           KEY6      READEAB#PL151                 96
     C           *IN96     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     MOVE *ON       *IN87
TCHK1C           *INOF     IFEQ *ON
TCHK1C                     EXCPT#HED1
TCHK1C                     EXCPT#HED2
TCHK1C                     SETOF                     OF
TCHK1C                     END
TCHK1C                     MOVEL'  '      W#MARK
TCHK1C           *IN96     IFEQ *OFF
TCHK1C           WSURY     IFGT BASRYO
TCHK1C                     MOVEL'++'      W#MARK
TCHK1C                     END
TCHK1C                     END
     C                     EXCPT#DTL1
     C   77                EXCPTDT
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN87     IFEQ *OFF
TCHK1C           *INOF     IFEQ *ON
TCHK1C                     EXCPT#HED1
TCHK1C                     EXCPT#HED2
TCHK1C                     SETOF                     OF
TCHK1C                     END
TCHK1C                     MOVEL'  '      W#MARK
TCHK9C*TCHK1     *IN96     IFEQ *OFF
TCHK9C*TCHK1     WSURY     IFGT BASRYO
TCHK9C*TCHK1               MOVEL'++'      W#MARK
TCHK9C*TCHK1               END
TCHK9C*TCHK1               END
     C                     EXCPT#DTL1
     C   77                EXCPTDT
     C                     ENDIF
      *
TCHK9C*E03                 ENDIF
     C*
     C                     ENDIF
     C*
     C           @@SKP     TAG
     C           KEY1      READEABFAP01R                 91
     C                     ENDDO
     C*
     C                     ENDIF
TCH23C*          K#FD      SETGTABFDP01R
TCHK9C           @@JUMP    TAG
TCH23C           K#ADF     SETGTABFDL01R
     C                     ENDIF
TCH23C*                    READ ABFDP01R                 90
TCH23C                     READ ABFDL01R                 90
     C                     ENDDO
