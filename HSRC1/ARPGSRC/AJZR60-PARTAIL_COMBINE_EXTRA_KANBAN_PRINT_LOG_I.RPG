     F******************************************** AJZR60 **
     FAJZPW60 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FAJZPL31 IF  E           K        DISK
     FALDPL30 IF  E           K        DISK
      *
     E                    MSG     1  20 60               d[ｰ xｮﾈｰﾆﾞ
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  15 J1BARC
     I                                        1   1 J1BAR1
     I                                        2   5 J1ZETI
     I* * *                                   6   8 J1TEHI
     I                                        9  10 J1PAGE
     I                                       11  11 J12KAK
     I                                       12  12 J1TASY
     I                                       13  13 J1YUKO
     I                                       14  14 J1HASY
     I* * *                                  15  15
     I            DS
     I                                        1   80J1PRDT
     I                                        1   40J1PRYY
     I                                        5   60J1PRMM
     I                                        7   80J1PRDD
     I            DS
     I                                        1   40J1PRTM
     I                                        1   20J1PRHH
     I                                        3   40J1PRMN
     I            DS
     I                                        1   80A3SYDT
     I                                        1   40A3SYYY
     I                                        5   60A3SYMM
     I                                        7   80A3SYDD
     I            DS
     I                                        1   40A3SYTM
     I                                        1   20A3SYJI
     I                                        3   40A3SYFN
     I            DS
     I                                        1   80K@PRDT
     I                                        1   40K@PRYY
     I                                        5   60K@PRMM
     I                                        7   80K@PRDD
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@DATE  8
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
      *
     C                     MOVEA*ALL'0'   *IN
      *
     C                     MOVE P@HIN1    K@HIN1
     C                     MOVE P@HIN2    K@HIN2
     C                     MOVE P@HIN3    K@HIN3
      *
     C                     SETOF                     66
     C           K@HIN1    IFNE *BLANK
     C                     MOVE P@DATE    K@PRDT
     C                     SETON                     66
     C                     END
      *
     C           HINKE0    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
     C                     KFLD           K@PRYY
     C                     KFLD           K@PRMM
     C                     KFLD           K@PRDD
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C*  SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
      *
     C   66      HINKE0    SETLLAJZPL31
      *
     C                     DO   *HIVAL
      *
     C  N66                READ AJZPL31                  90
     C   66      HINKEY    READEAJZPL31                  90
     C   90                LEAVE
      *
     C           *IN66     IFEQ '1'
     C           J1APPL    IFNE 'A'
     C           J1APPL    ANDNE'1'
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVEL*BLANK    W1APNM
     C           J1APPL    IFEQ 'A'
     C                     MOVEL'A-PICS'  W1APNM
     C                     ENDIF
     C           J1APPL    IFEQ '1'
     C                     MOVEL'EXTRA'   W1APNM
     C                     ENDIF
      *
     C                     MOVE J1ZETI    A3ZETI
     C                     MOVE J1PTEH    A3TEHI
     C                     MOVE J1PPAG    A3PAGE
     C                     MOVE J12KAK    A32KAK
     C                     MOVE J1TASY    A3TASY
     C                     MOVE J1YUKO    A3YUKO
     C                     MOVE J1HASY    A3HASY
     C                     Z-ADDJ1PRYY    A3SYYY
     C                     Z-ADDJ1PRMM    A3SYMM
     C                     Z-ADDJ1PRDD    A3SYDD
     C                     Z-ADDJ1PRHH    A3SYJI
     C                     Z-ADDJ1PRMN    A3SYFN
     C                     EXSR #ALD
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
      *
E1   C                     ENDDO
     C*-------------------------
     C*
     C           @END      TAG
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     Z-ADDRRN       ENDRRN
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
      *
     C           @DSP01    TAG
      *
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     7071
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
      *----*
     C   KC                MOVE '#END    '@STEP
     C   KC                GOTO @DSP1Z
      *
     C                     Z-ADD0         @X      40
     C                     Z-ADD0         @CNT    40
      *
     C           @CNT      IFGE 2
     C                     SETON                     99
     C                     MOVELMSG,01    @ERR
     C                     GOTO @DSP01
     C                     END
      *
      *
     C           @DSP1Z    ENDSR
      *-----------------------------------------------------
     C           #ALD      BEGSR
      *
     C           ALDKEY    KLIST
     C                     KFLD           A3ZETI
     C                     KFLD           A3TEHI
     C                     KFLD           A3PAGE
     C                     KFLD           A32KAK
     C                     KFLD           A3TASY
     C                     KFLD           A3YUKO
     C                     KFLD           A3HASY
     C                     KFLD           A3SYYY
     C                     KFLD           A3SYMM
     C                     KFLD           A3SYDD
     C                     KFLD           A3SYJI
     C                     KFLD           A3SYFN
      *
     C           ALDKY2    KLIST
     C                     KFLD           A3ZETI
     C                     KFLD           A3TEHI
     C                     KFLD           A3PAGE
     C                     KFLD           A32KAK
     C                     KFLD           A3TASY
     C                     KFLD           A3YUKO
     C                     KFLD           A3HASY
      *
     C           ALDKEY    SETLLALDPL30
     C                     DO   *HIVAL
     C           ALDKY2    READEALDPL30                  55
     C   55                LEAVE
     C                     LEAVE
     C                     ENDDO
      *
     C           *IN55     IFEQ '1'
     C                     Z-ADD0         A3SYYY
     C                     Z-ADD0         A3SYMM
     C                     Z-ADD0         A3SYDD
     C                     Z-ADD0         A3SYJI
     C                     Z-ADD0         A3SYFN
     C                     END
      *
     C           EALD      ENDSR
      *-----------------------------------------------------
**  MSG
 SELECT 1 DATA.
