     H            Y.
     F** UEXR31 *********************************************
     F*  PROGRAM: CHECK PROCESSED ORDER (HONDA)             *
     F*  WRITTEN: JW (SRA) 2020.06.29                       *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR31'
     F*                    PARM           $NONY   4
     F*                    PARM           $PLSH   8
     F*                    PARM           $BIN    2
     F*                    PARM           $MHN1   5
     F*                    PARM           $MHN2   5
     F*                    PARM           $MHN3   5
     F*                    PARM           $MHN4   5
     F*                    PARM           $ODRN  20
     F*                    PARM           $RTN    1
     F*  IN  $NONY :  4A DELIVERY#
     F*      $PLSH :  8A SHIP DATE
     F*      $BIN  :  2A BUN#
     F*      $MHN1 :  5A USER PART1
     F*      $MHN2 :  5A USER PART2
     F*      $MHN3 :  5A USER PART3
     F*      $MHN4 :  5A USER PART4
     F*      $ODRN : 20A PO#
     F*  OUT $RTN  :  1A RETURN CODE (Y:YES, N:NO)
     F******************************************************
     FAB#PL2P IF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
     C           K#PL2P    SETLLAB#PL2P
      * CHECK AB#PL2P
     C                     DO   *HIVAL
     C           K#PL2P    READEAB#PL2P                  98
     C   98                LEAVE
      *
     C           ACUPID    IFEQ '1'
     C           ACUPID    OREQ '3'
     C                     MOVE 'Y'       $RTN
     C**                   MOVELERR,1     MSG1
     C**                   EXSR #PRINT
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $PLSH   8
     C                     PARM           $BIN    2
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $ODRN  20
     C                     PARM           $RTN    1
      *
     C           K#PL2P    KLIST
     C                     KFLD           K#PLSH  80
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#BIN   20
     C                     KFLD           K#ODRN 20
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
      * SET KEY
     C                     MOVEL$PLSH     K#PLSH
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL'0'       K#NKOJ
     C                     MOVEL'00  '    K#NUKE
     C                     MOVEL$BIN      K#BIN
     C                     MOVEL$ODRN     K#ODRN
     C                     MOVEL$MHN1     K#MHN1
     C                     MOVEL$MHN2     K#MHN2
     C                     MOVEL$MHN3     K#MHN3
     C                     MOVEL$MHN4     K#MHN4
      *
     C                     TIME           SDATE
     C                     MOVEL'N'       $RTN
      *
     C                     ENDSR
