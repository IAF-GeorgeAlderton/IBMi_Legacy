     C           *IN49     IFEQ '0'
     C                     MOVELB2SMEI    WNMEI2 16
     C                     END
      **
     C                     ENDSR
      *------------------------------------*
      *調整理由                          *
      *------------------------------------*
     CSR         #SBTYO    BEGSR
      *
     C                     MOVELM6JBN1    P@JBN1
     C                     MOVELM6JBN2    P@JBN2
     C                     MOVELM6JBN3    P@JBN3
     C                     MOVELM6JBN4    P@JBN4
     C                     MOVELM6UKYY    P@UKYY
     C                     MOVELM6UKMM    P@UKMM
     C                     MOVELM6UKDD    P@UKDD
     C                     MOVELM6UBIN    P@UBIN
     C* FINALLY UPDATE ADJUSTMENT #
     C                     CALL 'ACHR08'
     C                     PARM           P@JBN1  1
     C                     PARM           P@JBN2  2
     C                     PARM           P@JBN3  2
     C                     PARM           P@JBN4  1
     C                     PARM           P@UKYY  40
     C                     PARM           P@UKMM  20
     C                     PARM           P@UKDD  20
     C                     PARM           P@UBIN  20
      *
     CSR         ESBTYO    ENDSR
      **
