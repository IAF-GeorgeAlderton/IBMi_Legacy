     H            Y.
     F***CHKR72*****************************************************************
     F*  PROGRAM    : CREATE FILE UODATE LOG                                   *
     F*  WRITTEN    : 2019.03.25                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FVJBPP20 O   E                    DISK
      *---------------------------------------------------
     E                    MSG     1   2 10
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
      *  MAIN ROUTINE
      ***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           $FILE  10
     C                     PARM           $LIB   10
     C                     PARM           $PGM   10
     C                     PARM           $TYP    3
      *
     C                     TIME           @SDATE
      *
     C                     CLEARVJBPP201
     C                     Z-ADDTODAY     V2CRDT
     C                     Z-ADDNOW       V2CRTM
     C                     MOVEL#USER     V2CRUS
     C                     MOVEL#WSID     V2CRWD
     C                     MOVEL#PGM      V2CRPG
     C                     MOVEL$FILE     V2FILE
     C                     MOVEL$LIB      V2LIB
     C                     MOVEL$PGM      V2PGM
     C                     MOVEL$TYP      V2TYPE
      *
     C                     SELEC
     C           $TYP      WHEQ 'RGZ'
     C                     MOVELMSG,1     V2TPNM
     C           $TYP      WHEQ 'NRG'
     C                     MOVELMSG,2     V2TPNM
     C                     ENDSL
      *
     C                     WRITEVJBPP201
      *
     C                     SETON                     LR
     C                     RETRN
**   MSG (10A)
REORG
NOT REORG
