      *----------- s]ﾇc ﾃcyh ﾈlxb --------------------------*
      *  PARM6  :   'L' OR 'R'   ==> d[ｰﾒﾇn ﾅhﾈb            *
      *             ﾆﾞﾑcg bfﾞb   ==> d[ｰﾒﾇn ﾅhﾈb ﾆob        *
      *                                                     *
      *  PARM7  :   'H'          ==> udﾃcmb ﾉcpｬcﾍﾞﾑﾒ ibﾅ]  *
      *             'M'          ==> xｮg ﾉcpｬcﾍﾞﾑﾒ ibﾅ]     *
      *             'T'          ==> 2ﾆﾞfﾃc ﾉcﾃｬcﾍﾞﾑﾒ ibﾅ]  *
      *             'R'          ==> ﾉcgibﾅ] ﾆﾏcﾒﾑc         *
      *                                                     *
      *  PARM32 :   ' '          ==> ﾉcg ibﾅ] f]ﾒｭc         *
      *             'D'          ==> ﾉcg ibﾅ] ﾎfﾉc          *
      *                                                     *
      *  PARM33 :   'P'          ==> ﾌﾟ[xｰj d[ｰ             *
      *             'M'          ==> uﾇjｰ F d[ｰ             *
      *==( ﾒﾇn ﾌlﾃc hﾎﾞ] )==*                               *
      *  PSW1   :   ' '          ==> d[ｰﾒﾇn vﾌｮﾃc           *
      *             '*'          ==> d[ｰﾒﾇn ﾌｮﾃcﾇv          *
      *==( ﾎabﾓ ﾑvﾃv tctc )=*                               *
      *  READPT :   '1'          ==> CHAIN mﾞ ﾑw            *
      *             ' '          ==> READ(E) mﾞ ﾑw          *
      *==( ﾉcg ﾅ]ﾆｬl fbﾆ/ﾆｬcﾒｭc hﾎﾞ] )=*                    *
      *  START  :   '1'          ==> ibﾅ] fbﾆ               *
      *             ' '          ==> ibﾅ] ﾆｬcﾒｭc            *
      *==( ﾆﾑﾒ hﾎﾞ] )=======*                               *
      *  SHORKB :   'H'          ==> ﾍgnﾒ                   *
      *             'K'          ==> fhmb                   *
      *==( c]ﾃcﾍﾞ ﾑvﾃvﾆﾑﾒ )=*                               *
