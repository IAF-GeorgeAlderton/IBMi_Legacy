     C           *IN80     DOWEQ'0'
     C           M6SKJY    IFEQ ' '
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ ABHPP011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           M6STDD    IFEQ 99
     C           M6OTHH    IFLT 0
     C                     MOVE *BLANK    M6CMT1
     C                     MOVE *BLANK    M6CMT2
     C                     ADD  M6OTHH    M6AUAJ
     C*****                ADD  M6OTHH    M6CMAI
     C*****                ADD  M6OTHH    M6MAIS
     C                     Z-ADD0         M6OTHH
     C                     UPDATABHPP011
     C                     END
     C                     END
     CSR         ESB400    ENDSR
