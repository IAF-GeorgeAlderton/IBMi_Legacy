     H            Y.
     F** AAMR81 ********************************************
     F*かんばん回転日数データ作成(ABHPP01)               *
     F*   MSK.                            2011.02.15       *
     F* 2021.01.20 DCS. T.MITSUI
     F*   CHANGE WITH THE NUMBER OF FIGURES EXPANSION OF THE "KANBAN"
     F******************************************************
     FABHPP01 IF  E                    DISK
     FAAMWP80 O   E                    DISK                      A
     E                    M6A         4  3
      *
     I            DS
     I                                        1   80M6SKHZ
     I                                        1   40M6SKYY
     I                                        5   60M6SKMM
     I                                        7   80M6SKDD
      *
     I            DS
     I                                        1   80M6STHZ
     I                                        1   40M6STYY
     I                                        5   60M6STMM
     I                                        7   80M6STDD
      *
     I            DS
     I                                        1  12 M6A
     I                                        1   3 M6AKT1
     I                                        4   6 M6AKT2
     I                                        7   9 M6AKT3
     I                                       10  12 M6AKT4
      *
     I            DS
     I                                        1   3 M6JBN
     I                                        1   1 M6JBN1
     I                                        2   3 M6JBN2
      *
     I            DS
     I                                        1   3 WKF
     I                                        1   1 WKK1F
     I                                        2   3 WKT1F
      *
     I            DS
     I                                        1   3 WKT
     I                                        1   1 WKK1T
     I                                        2   3 WKT1T
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
      ** CALL(PARM) **
     C           ACALL     PLIST
     C                     PARM           XBMN    4        部門
     C                     PARM           M6HIN1  5        品番・１
     C                     PARM           M6HIN2  5        　　・２
     C                     PARM           M6HIN3  2        　　・３
     C                     PARM           M6KSN1  1        計算区分１
     C                     PARM           M6KSN2  1        　　　　２
     C                     PARM           XKTS    9        確定設定数
     C                     PARM           XSYU    7        自工程収容数
     C                     PARM           XGLT    4        合計Ｌ・Ｔ
     C                     PARM           XANZ    3        安全率
     C                     PARM           XBRA    3        バラツキ箱数
     C                     PARM           XSET    3        セット数
     C                     PARM           XALT    2        後工程ロット
     C                     PARM           M6JBN1  1        所番地・１
     C                     PARM           M6JBN2  2        　　　・２
     C                     PARM           M6JBN3  2        　　　・３
     C                     PARM           M6JBN4  1        　　　・４
     C                     PARM           XUYY    4        有効日　年
     C                     PARM           XUMM    2        有効日　月
     C                     PARM           XUDD    2        有効日　日
     C                     PARM           XUBN    2        有効日　便
     C                     PARM           PKJY    3        基準値
     C                     PARM           PLOT    3        生産ロット
     C                     PARM           PMIS    5        かんばん枚数
     C                     PARM           PERR    1        エラー
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL'9'       WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL'99'      WKT1T
     C                     ENDIF
      *
     C                     READ ABHPP011                 81
     C           *IN81     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ ABHPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           M6BMON    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
      *≠ブランクの最後の工程
     C                     Z-ADD1         X       20
     C                     MOVEL*BLANK    WKKTEI  3
     C           X         DOWLE4
     C           M6A,X     IFNE *BLANK
     C                     MOVELM6A,X     WKKTEI
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           PKOTE     IFNE *BLANK
     C           WKKTEI    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           WKF       IFNE '   '
     C           M6JBN     IFLT WKF
     C****       M6JBN     ORNE '------'
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
     C           WKT       IFNE '   '
     C           M6JBN     IFGT WKT
     C****       M6JBN     ORNE '------'
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELM6BMON    W0BMON
     C                     MOVELM6HIN1    W0SHN1
     C                     MOVELM6HIN2    W0SHN2
     C                     MOVELM6HIN3    W0SHN3
     C                     MOVELWKKTEI    W0KOTE
     C                     MOVELM6JBN1    W0TKR1
     C                     MOVELM6JBN2    W0TKR2
     C                     MOVELM6JBN3    W0TKR3
     C                     MOVELM6JBN4    W0TKR4
     C                     Z-ADDM6KTSU    W0KTSU
     C                     Z-ADDM6KSSU    W0KSSU
     C           M6KSSU    DIV  20        DMY6   103
     C           M6SYUY    IFNE 0
     C           DMY6      DIV  M6SYUY    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDM6SYUY    W0SYUY
     C                     Z-ADDM6LOTK    W0LOTK
     C                     Z-ADDM6KJNK    W0KJNK
     C                     Z-ADDM6SETO    W0SETO
     C                     Z-ADDM6KMAX    W0KMAX
     C                     MOVEL'A'       W0KCD1
     C                     MOVEL'A'       W0KCD2
      *
     C                     MOVE M6KSN1    W0KSN1
     C                     MOVE M6KSN3    W0KSN3
     C                     MOVE M6KSN2    W0KSN2
     C                     Z-ADDM6ATLT    W0HITO
     C                     Z-ADDM6TYOS    W0TYLT
     C                     Z-ADDM6LIGK    W0LTIM
     C                     Z-ADDM6ANZN    W0KEIS
     C                     Z-ADD0         W0MAXS
     C                     Z-ADDM6MAIS    W0CYOU
     C                     MOVE *BLANK    W0KKEY
      *---------------------------------------------------------------*
      * かんばん枚数　の　計算                           CALL-PGM   *
      *---------------------------------------------------------------*
     C           M6BMON    IFEQ 8249
     C                     MOVE '8982'    XBMN
     C                     ELSE
     C                     MOVE M6BMON    XBMN    4
     C                     END
      *
     C                     MOVE M6KSSU    XKTS    9
     C                     MOVE M6SYUY    XSYU    7
     C                     MOVE M6LIGK    XGLT    4
     C                     MOVE M6ANZN    XANZ    3
     C                     MOVE M6BRAH    XBRA    3
     C                     MOVE M6SETO    XSET    3
     C                     MOVE M6ATLT    XALT    2
     C                     MOVE M6UKYY    XUYY    4
     C                     MOVE M6UKMM    XUMM    2
     C                     MOVE M6UKDD    XUDD    2
     C                     MOVE M6UBIN    XUBN    2
     C                     MOVE M6KJNK    PKJY    3
     C                     MOVE M6LOTK    PLOT    3
     C                     MOVE '00000'   PMIS    5
     C                     MOVE *BLANK    PERR    1
      *
     C                     CALL 'ABCR20'  ACALL
     C                     MOVE PMIS      W@SMAX  50
     C           M6MAIS    IFNE 0
     C           W@SMAX    ADD  M6MAIS    W0SMAX
     C                     ELSE
     C                     MOVE W@SMAX    W0SMAX
     C                     END
     C*
     C                     MOVE PLOT      W0SLOT
     C                     MOVE PKJY      W0SJNK
      *
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
