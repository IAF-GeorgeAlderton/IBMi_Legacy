     C           KE$1      KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
      *
     C                     Z-ADD*DATE     W@YMD
      *
     C*----------------------------------------*
     C*  ..カレンダーより翌日の日付　決定..  *
     C*----------------------------------------*
     C                     Z-ADD0         WWYOYY  40
     C                     Z-ADD0         WWYOMM  20
     C                     Z-ADD0         WWYODD  20
     C           KE$1      SETGTAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     01
     C                     READ AGDPL121                 01
     C           *IN01     IFEQ '0'
      *
     C           F8HIRU    IFEQ *BLANK
     C                     SETON                     01
     C                     Z-ADDF8KAYY    WWYOYY
     C                     Z-ADDF8KAMM    WWYOMM
     C                     Z-ADDF8KADD    WWYODD
     C                     END
      *
     C                     END
     C  N01                END
