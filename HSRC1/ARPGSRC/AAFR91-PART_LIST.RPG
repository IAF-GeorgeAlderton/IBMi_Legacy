     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@SORT  1
      *
     C           K#GAD     KLIST
     C                     KFLD           F3TOKU
     C                     KFLD           F3NONY
     C                     KFLD           F3NKOJ
     C                     KFLD           F3NUKE
      *
     C           K#FC1     KLIST
     C                     KFLD           F3SHN1
     C                     KFLD           F3SHN2
     C                     KFLD           F3SHN3
     C           K#AFP     KLIST
