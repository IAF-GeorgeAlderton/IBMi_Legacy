     C           *IN26     IFEQ *OFF
     C                     Z-ADDM6KMAX    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ 'B'
     C           K#AFP     CHAINADHPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDJ6KMAX    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ '7'
     C           K#AFP     CHAINAAXPL101             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDL9KMAX    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ 'F'
