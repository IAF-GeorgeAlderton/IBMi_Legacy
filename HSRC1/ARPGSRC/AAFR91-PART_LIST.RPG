     C                     KFLD           A2STRT
     C                     KFLD           A2STRR
     C                     KFLD           A2STRD
     C                     KFLD           KNE
     C                     KFLD           KTU
     C                     KFLD           KHI
     C                     KFLD           KBIN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE WORK FILE
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C           K#FC1     CHAINAAFWL91              99
     C           *IN99     IFEQ *ON
     C                     CLEARAAFWL911
     C                     ELSE
     C                     MOVE '*'       AACOMN
     C                     MOVE AAKKID    @@ID    1
     C                     ENDIF
      *
     C                     MOVE F3SHN1    AAPRT1
     C                     MOVE F3SHN2    AAPRT2
     C                     MOVE F3SHN3    AAPRT3
     C           K#GAD     CHAINGADPL11              90
     C  N90                MOVELB5KMEI    AANAME
      *
     C                     SELEC
     C           F3TOKU    WHEQ 3411
     C                     MOVE '0'       AAKKID
     C                     OTHER
     C           K#GAD     CHAINGADPL11              90
     C           *IN90     IFEQ *OFF
     C           B5HIZK    ANDEQ1
     C                     MOVE '1'       AAKKID
     C                     ELSE
     C                     MOVE '9'       AAKKID
     C                     ENDIF
     C                     ENDSL
      *
     C           *IN99     IFEQ *ON
     C           *IN99     OREQ *OFF
     C           AAKKID    ANDLT@@ID
      *
     C                     MOVE F3NONY    AANONY
     C                     MOVE F3TOKU    AATOKU
      *
     C           K#FC1     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     MOVE A2STRK    AALOC1
     C                     MOVE A2STRT    AALOC2
     C                     MOVE A2STRR    AALOC3
     C                     MOVE A2STRD    AALOC4
      *
     C           K#FC1     CHAINAAMPL11              90
      *
     C                     Z-ADD15        K       20
     C                     DO   15
     C           NKAN,K    IFNE *BLANK
     C                     MOVE NKAN,K    KANSY   1
     C                     Z-ADDKANK,K    KHIB
     C                     LEAVE
     C                     ENDIF
     C                     SUB  1         K
     C                     ENDDO
      *
     C                     SELEC
     C           KANSY     WHEQ 'C'
     C           K#AFP     CHAINAAFPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDA3KMAX    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ 'D'
     C           K#AFP     CHAINAAGPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDO4KMAX    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ 'E'
