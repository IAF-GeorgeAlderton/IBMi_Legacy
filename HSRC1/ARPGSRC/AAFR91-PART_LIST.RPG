     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ '4'
     C           K#AFP     CHAINAEAPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDAESYOS    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ '1'
     C           K#AFP     CHAINAAOPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDT1KMAX    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ '2'
     C           K#AFP     CHAINAAYPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDL8KMAX    AAKQTY
     C                     ENDIF
     C*
     C           KANSY     WHEQ '6'
     C           K#AFP     CHAINAANPL031             26
     C           *IN26     IFEQ *OFF
     C                     Z-ADDL7SYOS    AAKQTY
     C                     ENDIF
     C* ----------- *
     C           KANSY     WHEQ 'A'
