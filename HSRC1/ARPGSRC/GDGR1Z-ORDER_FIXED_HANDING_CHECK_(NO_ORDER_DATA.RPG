      ** GDGR1Z ******************************************************
      *    ORDER FIXED HANDING / CHECK (NO ORDER DATA TO P@FACT)
      *    KIRI 2014.10.08
      ****************************************************************
     H            Y/                                    1
      *
     FGDGPL10 IF  E           K        DISK
      *
     FAKBPL04 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAAPTL01 IF  E           K        DISK
      *================================================================
      *================================================================
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
      *
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
     I            DS
     I                                        1   80L7UKHZ
     I                                        1   40L7UKYY
     I                                        5   60L7UKMM
     I                                        7   80L7UKDD
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
      *     <<
     I           SDS
     I                                        1  10 @@PGM
     I                                      254 263 @@USID
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@FACT  3
     C                     PARM           P@REC  100
     C*===============================================================
     C                     Z-ADD0         REC1   100
     C* DAYLY ORDER DATA BEFOR ADDING FILE
     C           *LOVAL    SETLLGDGPL10
     C*--------------------
S1   C                     DO   *HIVAL
     C                     READ GDGPL10                  90
     C   90                LEAVE
 S2  C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVE *BLANK    WKBMON  4
     C                     EXSR #TYPE
      *
     C                     SELEC
     C           WKBMON    WHEQ '0002'
     C           WKBMON    OREQ '0094'
     C           P@FACT    IFNE 'ATC'
     C                     ITER
     C                     ENDIF
     C                     OTHER
     C           P@FACT    IFEQ 'ATC'
     C                     ITER
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ADD  1         REC1
     C                     LEAVE
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDREC1      P@REC
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
 %002C           #TYPE     BEGSR                                     *
     C****************************************************************
     C*<KANBAN TYPE>
     C           KEY02     KLIST
     C                     KFLD           IBHIN1
     C                     KFLD           IBHIN2
     C                     KFLD           IBHIN3
     C                     SETOF                     54
     C           KEY02     SETGTAAPTL011
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY02     REDPEAAPTL011                 54
     C           *IN54     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C*
     C           L5UKHZ    IFGT *DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C*
     C                     MOVE L5BMON    WKBMON
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY02     SETLLAKBPL041                 54
     C                     DO   *HIVAL
     C           ##2       TAG
     C           KEY02     READEAKBPL041                 54
     C           *IN54     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE *DATE
     C                     GOTO ##2
     C                     END
     C                     END
     C           L1UKHZ    IFGT *DATE
     C                     GOTO ##2
     C                     END
     C           L1STHZ    IFLE *DATE
     C                     GOTO ##2
     C                     END
     C                     MOVELL1BMON    WKBMON
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY02     SETLLAANPL061                 54
     C                     DO   *HIVAL
     C           ##3       TAG
     C           KEY02     READEAANPL061                 54
     C           *IN54     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE *DATE
     C                     GOTO ##3
     C                     END
     C                     END
     C           L7UKHZ    IFGT *DATE
     C                     GOTO ##3
     C                     END
     C           L7STHZ    IFLE *DATE
     C                     GOTO ##3
     C                     END
     C                     MOVELL7BMON    WKBMON
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
     C*
     C           ETYPE     ENDSR
     C****************************************************************
