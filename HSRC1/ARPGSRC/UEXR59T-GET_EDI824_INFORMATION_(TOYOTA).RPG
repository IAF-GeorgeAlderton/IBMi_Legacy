     H            Y.
      ** UEXR59T ***************************************************
      *  GET EDI824 INFORMATION (TOYOTA)                           *
      *  JW     2025.05.15                                         *
      **************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR59T'
      *                    PARM           $SHID  10
      *                    PARM           $STT    3
      *                    PARM           $DATE   8
      *                    PARM           $TIME   6
      *   IN  $SHID  10A  SHID
      *   OUT $STT    3A  YES:ACCEPTED, NO:REJECTED, BLANK:NO ANSWER
      *   "   $DATE   8A  RECEIVE DATE
      *   "   $TIME   6A  RECEIVE TIME
      ***********************************************************
     FAB#PLE1 IF  E           K        DISK
      ***********************************************************
     C                     EXSR #INIT
      *
      *
     C           K#SHID    SETLLAB#PLE1
      *
     C                     DO   *HIVAL
     C           K#SHID    READEAB#PLE1             N    51
     C   51                LEAVE
      *
      * IGNORE HONDA
     C           M6PTRN    IFEQ 'HONDA'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         @CNT
     C                     MOVELM6PTRN    M6      8
      *
     C                     SELEC
      * TMS
     C           M6        WHEQ 'TMS     '
     C                     EXSR #TMS
     C           $STT      IFNE *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           $STT      IFNE *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDSL
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ***********************************************************
      * DENSO, PISTON, SUBARU
      ***********************************************************
     C           #CHK1     BEGSR
      *
     C           M6ACKC    IFEQ 'TR'
     C           M6ACKC    OREQ 'IR'
     C                     MOVEL'NO '     $STT
     C                     MOVELM6CRDT    $DATE
     C                     MOVELM6CRTM    $TIME
     C                     ENDIF
      *
     C           M6ACKC    IFEQ 'TA'
     C           M6ACKC    OREQ 'IA'
     C           M6ACKC    OREQ 'IE'
     C                     MOVEL'YES'     $STT
     C                     MOVELM6CRDT    $DATE
     C                     MOVELM6CRTM    $TIME
     C                     ENDIF
      *
     C                     ENDSR
      ***********************************************************
      * .......
      ***********************************************************
     C           #CHK2     BEGSR
      *
      *
     C                     ENDSR
      ***********************************************************
      * TMS
      ***********************************************************
     C           #TMS      BEGSR
      *
     C           M6ACKC    IFEQ *BLANK
     C                     MOVEL'YES'     $STT
     C                     MOVELM6CRDT    $DATE
     C                     MOVELM6CRTM    $TIME
     C                     ENDIF
      *
     C                     ENDSR
      ***********************************************************
      * INITIAL SETTINGS
      ***********************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHID  10
     C                     PARM           $STT    3
     C                     PARM           $DATE   8
     C                     PARM           $TIME   6
      *
     C                     MOVEL$SHID     K#SHID 15
     C                     MOVE *BLANK    $STT
     C                     Z-ADD0         @CNT    50
      *
     C                     ENDSR
