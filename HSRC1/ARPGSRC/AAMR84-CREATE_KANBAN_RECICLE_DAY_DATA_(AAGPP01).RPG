     H            Y.
     F** AAMR84 ********************************************
     F*かんばん回転日数データ作成(AAGPP01)               *
     F*   MSK.                            2011.02.15       *
     F******************************************************
     FAAGPP01 IF  E                    DISK
     FAAMWP80 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80O4SKHZ
     I                                        1   40O4SKYY
     I                                        5   60O4SKMM
     I                                        7   80O4SKDD
      *
     I            DS
     I                                        1   80O4STHZ
     I                                        1   40O4STYY
     I                                        5   60O4STMM
     I                                        7   80O4STDD
      *
     I            DS
     I                                        1   3 O4JBN
     I                                        1   1 O4BAN1
     I                                        2   3 O4BAN2
      *
     I            DS
     I                                        1   3 WKF
     I                                        1   1 WKK1F
     I                                        2   3 WKT1F
      *
     I            DS
     I                                        1   3 WKT
     I                                        1   1 WKK1T
     I                                        2   3 WKT1T
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
     C           ACALL     PLIST
     C                     PARM           ASTLR            SETON LR ﾍｭcﾆg
     C                     PARM           O4KSSU
     C                     PARM           O4SYOS
     C                     PARM           O4KEIS
     C                     PARM           O4LTIM
     C                     PARM           O4BARA
     C                     PARM           O4CBKO
     C                     PARM           O4LOTO
     C                     PARM           O4MAXH
     C                     PARM           WMAIS
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKT1T
     C                     ENDIF
      *
     C                     READ AAGPP011                 81
     C           *IN81     DOWEQ'0'
     C           O4SKJY    IFEQ 'D'
     C           O4SKHZ    ANDLE*DATE
     C                     ELSE
     C           O4STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AAGPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           O4BMON    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
     C           PKOTE     IFNE *BLANK
     C           O4KTEI    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           O4JBN     IFLT WKF
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C           O4JBN     IFGT WKT
     C                     MOVEL'0'       WKOK
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELO4BMON    W0BMON
     C                     MOVELO4SHN1    W0SHN1
     C                     MOVELO4SHN2    W0SHN2
     C                     MOVELO4SHN3    W0SHN3
     C                     MOVELO4KTEI    W0KOTE
     C                     MOVELO4BAN1    W0TKR1
     C                     MOVELO4BAN2    W0TKR2
     C                     MOVELO4BAN3    W0TKR3
     C                     MOVELO4BAN4    W0TKR4
     C           O4KTSU    MULT 20        W0KTSU
     C           O4KSSU    MULT 20        W0KSSU
     C           O4SYOS    IFNE 0
     C           O4KSSU    DIV  O4SYOS    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDO4SYOS    W0SYUY
     C                     Z-ADD0         W0LOTK
     C                     Z-ADD0         W0KJNK
     C                     Z-ADD0         W0SETO
     C                     Z-ADDO4KMAX    W0KMAX
     C                     MOVELO4KCD1    W0KCD1
     C                     MOVELO4KCD2    W0KCD2
      *
     C                     MOVE *BLANK    W0KSN1
     C                     MOVE *BLANK    W0KSN3
     C                     MOVE *BLANK    W0KSN2
     C                     Z-ADD0         W0HITO
     C                     Z-ADD0         W0TYLT
     C                     Z-ADDO4LTIM    W0LTIM
     C                     Z-ADDO4KEIS    W0KEIS
     C                     Z-ADDO4MAXH    W0MAXS
     C                     MOVE *BLANK    W0KKEY
     C                     Z-ADD0         W0CYOU
     C           O4SYOS    IFNE 0
     C                     EXSR $SB600
     C                     END
      *
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
     C**************************************************************
     C           $SB600    BEGSR
     C*----------------------------------------*
     C*     ...かんばん枚数　の　計算...     *
     C*----------------------------------------*
     C                     MOVE *BLANK    ASTLR   2        SETON LR ﾍｭcﾆg
     C                     Z-ADD0         WMAIS   40
     C                     CALL 'ABCR06'  ACALL
     C                     Z-ADDWMAIS     W0SMAX
     C                     MOVE O4LOTO    W0SLOT
     C                     MOVE *BLANK    W0SJNK
     CSR         $S600E    ENDSR
