     C           KEY       KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           KEY1      KLIST
     C                     KFLD           OASHN1
     C                     KFLD           OASHN2
     C                     KFLD           OASHN3
      *
     C           KEY2      KLIST
     C                     KFLD           WTKR1
     C                     KFLD           WTKR2
     C                     KFLD           WTKR3
     C                     KFLD           WTKR4
      *
     C           *ENTRY    PLIST
     C                     PARM           PKBN    1
     C                     PARM           PYM     6
     C                     PARM           PUS    10
     C                     MOVE PYM       WYM
      *
     C*--------------------*
     C*  ..カレンダー..  *
     C*--------------------*
     C           *IN10     IFEQ '0'
     C                     SETON                     10
      *
     C           PKBN      IFEQ 'Z'
     C           *IN20     IFEQ '0'
     C                     SETON                     20
     C                     OPEN QPRINT
     C                     TIME           WTIME   60
     C                     EXCPTHD
     C                     END
     C                     END
      *
     C                     Z-ADD0         WCD     31
     C           KEY       SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY       READEAGDPL121                 11
     C           *IN11     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         WCD
     C                     ELSE
     C                     ADD  0.5       WCD
     C                     END
      *
     C                     END
     C                     END
     C  N11                END
      *
     C                     END
      *
     C           OASKJY    IFEQ 'D'
     C           OASKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           OAZKLV    IFEQ '01'
     C           OASTHZ    IFGT *DATE
      *
     C*--------------------------*
     C*  ..ＡＲＲＳマスター..  *
     C*--------------------------*
     C           WSHIN     IFNE OASHIN
     C                     MOVE OASHIN    WSHIN  12
      *
     C                     SETOF                     12
     C           KEY1      CHAINOABPL011             12
     C           *IN12     IFEQ '0'
     C           OBSKJY    ANDEQ'D'
     C           OBSKHZ    ANDLE*DATE
     C                     SETON                     12
     C                     END
     C                     END
      *
     C           *IN12     IFEQ '1'
     C                     MOVE 'D'       OASKJY
     C                     Z-ADD*DATE     OASKHZ
     C                     Z-ADD*DATE     OAKOHZ
     C                     TIME           OAKOHS
     C                     MOVE *BLANK    OAKOME
      *
     C           PKBN      IFEQ 'Z'
     C                     MOVEL'ZOUGEN'  OAKOME
     C                     ELSE
     C                     MOVELPUS       OAKOME
     C                     END
      *
     C                     UPDATOACPL011
     C                     ELSE
      *
     C*----------------------------------*
     C*  ..内示テ゛ータ累積ファイル..  *
     C*----------------------------------*
     C                     Z-ADD0         WNSU    90
     C           KEY1      SETLLABBPL021
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY1      READEABBPL021                 11
     C           *IN11     IFEQ '0'
      *
     C           Q5NNNM    IFNE 0
     C                     Z-ADDQ5NNNM    WNNNM   90
     C                     ELSE
     C                     Z-ADDQ5N1GM    WNNNM
     C                     END
      *
     C           Q5MHIZ    IFEQ 0
     C                     Z-ADD1         Q5MHIZ
     C                     END
     C           Q5MKAI    IFEQ 0
     C                     Z-ADD1         Q5MKAI
     C                     END
     C           WNNNM     IFEQ 0
     C                     Z-ADD1         WNNNM
     C                     END
      *
     C           WNNNM     DIV  WCD       WNSU1   90H
     C           WNSU1     MULT Q5MHIZ    WNSU2   90
     C           WNSU2     DIV  Q5MKAI    WNSU3   90H
     C                     ADD  WNSU3     WNSU
      *
     C                     END
     C  N11                END
      *
     C*----------------------*
     C*  ..部品マスター..  *
     C*----------------------*
     C                     SETOF                     13
     C                     Z-ADD0         WSYOS   50
     C           KEY1      CHAINFCEPL011             13
     C           *IN13     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     13
     C                     END
      *
     C           *IN13     IFEQ '0'
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    WSYOS
     C                     ELSE
     C                     Z-ADDA2SSYS    WSYOS
     C                     END
     C                     END
      *
     C                     Z-ADD0         WKSU    50
     C           WSYOS     IFNE 0
     C           WNSU      DIV  WSYOS     WKSU
     C                     MVR            WKAMR   50
     C           WKAMR     IFNE 0
     C                     ADD  1         WKSU
     C                     END
     C                     END
      *
     C*----------------------------------*
     C*  ..社内かんばん切替マスター..  *
     C*----------------------------------*
     C                     SETOF                     11
     C                     MOVE *BLANK    WKANS   1
     C                     MOVE *BLANK    WTKRO
     C                     Z-ADD0         WJSU    50
     C           KEY1      CHAINAAMPL111             11
     C           *IN11     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C                     MOVELNUKH,A    WUKH    80
     C           NUKH,A    IFNE 0
      *
     C           WUKH      IFGT *DATE
     C           OKAS,A    IFNE *BLANK
     C                     MOVE OKAS,A    WKANS
     C                     MOVE OTKR,A    WTKRO
     C                     END
     C                     ELSE
      *
     C           NKAS,A    IFNE *BLANK
     C                     MOVE NKAS,A    WKANS
     C                     MOVE NTKR,A    WTKRO
     C                     END
     C                     END
      *
     C                     END
     C                     END
      *
     C*--------------------------------*
     C*  ..メッキかんばんマスター..  *
     C*--------------------------------*
     C           WKANS     IFEQ 'C'
      *
     C           KEY2      SETGTAAFPL031
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      REDPEAAFPL031                 11
     C           *IN11     IFEQ '0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           A3UKHZ    IFLE *DATE
     C           A3STHZ    ANDGT*DATE
     C                     SETON                     11
     C                     Z-ADDA3KMAX    WJSU
     C                     END
      *
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C*----------------------------------*
     C*  ..トンネルかんばんマスター..  *
     C*----------------------------------*
     C           WKANS     IFEQ 'D'
      *
     C           KEY2      SETGTAAGPL031
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      REDPEAAGPL031                 11
     C           *IN11     IFEQ '0'
     C           O4SKJY    IFEQ 'D'
     C           O4SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           O4UKHZ    IFLE *DATE
     C           O4STHZ    ANDGT*DATE
     C                     SETON                     11
     C                     Z-ADDO4KMAX    WJSU
     C                     END
      *
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C*------------------------------*
     C*  ..引取かんばんマスター..  *
     C*------------------------------*
     C           WKANS     IFEQ 'E'
      *
     C           KEY2      SETGTAAHPL031
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      REDPEAAHPL031                 11
     C           *IN11     IFEQ '0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           L6UKHZ    IFLE *DATE
     C           L6STHZ    ANDGT*DATE
     C                     SETON                     11
     C                     Z-ADDL6KMAX    WJSU
     C                     END
      *
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C                     END
      *
     C*--------------------------------*
     C*  ..上限数・下限数チェック..  *
     C*--------------------------------*
     C           WJSU      IFEQ 0
     C           WKSU      OREQ 0
     C                     MOVE ER,1      WERR   30
     C                     EXSR SUBRT
     C                     GOTO END
     C                     END
      *
     C           WJSU      IFLE WKSU
     C                     MOVE ER,2      WERR
     C                     EXSR SUBRT
     C                     GOTO END
     C                     END
      *
     C*--------------------------*
     C*  ..使用区分＇００＇..  *
     C*--------------------------*
     C           OAAZKS    IFEQ '00'
      *
     C           WJSU      IFEQ OAAZRU
     C           WKSU      ANDEQOAAZRS
     C           WJSU      ANDEQOAAZTU
     C           WKSU      ANDEQOAAZTS
     C                     GOTO END
     C                     ELSE
      *
     C                     Z-ADDWJSU      OAAZRU
     C                     Z-ADDWKSU      OAAZRS
     C                     Z-ADDWJSU      OAAZTU
     C                     Z-ADDWKSU      OAAZTS
     C                     END
     C                     END
      *
     C*--------------------------*
     C*  ..使用区分＇０１＇..  *
     C*--------------------------*
     C           OAAZKS    IFEQ '01'
      *
     C           WJSU      IFEQ OAAZRU
     C           WKSU      ANDEQOAAZRS
     C           WJSU      ANDEQOAAZTU
     C                     GOTO END
     C                     ELSE
      *
     C                     Z-ADDWJSU      OAAZRU
     C                     Z-ADDWKSU      OAAZRS
     C                     Z-ADDWJSU      OAAZTU
     C                     END
     C                     END
      *
     C*--------------------------*
     C*  ..使用区分＇１０＇..  *
     C*--------------------------*
     C           OAAZKS    IFEQ '10'
      *
     C           WJSU      IFEQ OAAZRU
     C           WKSU      ANDEQOAAZRS
     C           WKSU      ANDEQOAAZTS
     C                     GOTO END
     C                     ELSE
      *
     C                     Z-ADDWJSU      OAAZRU
     C                     Z-ADDWKSU      OAAZRS
     C                     Z-ADDWKSU      OAAZTS
     C                     END
     C                     END
      *
     C*--------------------------*
     C*  ..使用区分＇１１＇..  *
     C*--------------------------*
     C           OAAZKS    IFEQ '11'
      *
     C           WJSU      IFEQ OAAZRU
     C           WKSU      ANDEQOAAZRS
     C                     GOTO END
     C                     ELSE
      *
     C                     Z-ADDWJSU      OAAZRU
     C                     Z-ADDWKSU      OAAZRS
     C                     END
     C                     END
      *
     C                     Z-ADD*DATE     OAKOHZ
     C                     TIME           OAKOHS
     C                     MOVE 'F'       OADTKJ
      *
     C                     MOVE *BLANK    OAKOME
     C           PKBN      IFEQ 'Z'
     C                     MOVEL'ZOUGEN'  OAKOME
     C                     ELSE
     C                     MOVELPUS       OAKOME
     C                     END
      *
     C                     UPDATOACPL011
      *
     C           END       TAG
     C                     END
     C                     END
     C                     END
     C                     END
      *
     CLR 20                EXCPTTR
     CLR 20                CLOSEQPRINT
      *
      *
     C*----------------------*
     C*     ..ﾅﾎﾞﾓｰk]..      *
     C*  ..d[ｰﾒﾇn ﾒﾇnaｮﾎﾟ..  *
     C*----------------------*
     C           SUBRT     BEGSR
      *
     C                     SETON                     U1
     C                     ADD  1         TRECD   40
      *
     C           PKBN      IFNE 'Z'
     C           *IN20     IFEQ '0'
     C                     SETON                     20
     C                     OPEN QPRINT
     C                     TIME           WTIME   60
     C                     EXCPTHD
     C                     END
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     END
      *
     C                     EXCPTDT
      *
     C                     ENDSR
      *
     OQPRINT  E  102           HD
     O                                  131 '+-------------------+'
     O        E  1             HD
     O                                  131 '|         |         |'
     O        E  1             HD
     O                                   30 '*-PART M/F NO EXIST'
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '|         |         |'
     O        E  2             HD
     O                                   10 'OACR02-1'
     O                                   28 'BATCH PROCESSING'
     O                         TBL,1     81
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '+-------------------+'
     O        E  1             HD
     O                                   63 '-STOCK STANDARD VALUE-'
     O                                   78 '-MANUAL INPUT-'
     O                                   94 '-CALCULATION-'
     O        E  2             HD
     O                                   15 'INT CO P/N'
     O                                   28 'EFF DATE'
     O                                   40 'LAPSE DATE'
     O                                   53 'THEORY MAX'
     O                                   59 'MIN'
     O                                   68 'MAX'
     O                                   76 'MIN'
     O                                   85 'MAX'
     O                                   93 'MIN'
     O                                  111 'ERROR CONTENTS'
     O        E  1             DT
     O                 13                 4 '*'
     O                         OASHN1    10
     O                                   11 '-'
     O                         OASHN2    16
     O                                   17 '-'
     O                         OASHN3    19
     O                         OAUKHZ    30 '    .  .  '
     O                         OASTHZ    40 '    .  .  '
     O                         OAAZRU1   51
     O                         OAAZRS1   61
     O                         OAAZTU1   70
     O                         OAAZTS1   78
     O                         WJSU  1   87
     O                         WKSU  1   95
     O                         WERR     127
     O        E 1              TR
     O                                   34 '** TOTAL COUNT'
     O                         TRECD 1   40
