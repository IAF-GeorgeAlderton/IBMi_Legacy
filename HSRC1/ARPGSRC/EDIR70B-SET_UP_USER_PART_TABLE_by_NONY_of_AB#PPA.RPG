     H            Y/                                    1
     H** EDIR70 *******************************************************
     H*  SET UP USER PART TABLE                                       *
     H*  JW  2019.09.25                                               *
     H*****************************************************************
     FAB#PLA3 IF  E           K        DISK
     FEDIPP45 UF  E           K        DISK                      A
      *================================================================
     E                    CHR        20  1
     I            DS
     I                                        1  140@TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
     C*===============================================================
     C*  MAIN PROGRAM
     C*===============================================================
     C                     EXSR #INIT
     C*
     C           @NONY     SETLLAB#PLA3
     C                     DO   *HIVAL
     C           @NONY     READEAB#PLA3                  90
     C   90                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C           BAFLD2    OREQ *BLANK
     C                     ITER
     C                     ENDIF
      * CHECK BLANK OR - OR .
     C                     Z-ADD1         IX      20
     C                     MOVEABAFLD2    CHR
     C           '-'       LOKUPCHR,IX                   98
     C           *IN98     IFEQ *ON
     C                     GOTO SKIP1
     C                     ENDIF
      *
     C                     Z-ADD1         IX
     C           '.'       LOKUPCHR,IX                   98
     C           *IN98     IFEQ *ON
     C                     GOTO SKIP1
     C                     ENDIF
      * CHECK SPACE
     C                     Z-ADD1         IX
     C           ' '       LOKUPCHR,IX                   98
     C           *IN98     IFEQ *ON
     C           IX        ADD  1         IY      20
     C           ' '       LOKUPCHR,IY                   97
     C           *IN97     IFEQ *OFF
     C                     ITER
     C                     ENDIF
     C           *IN97     IFEQ *ON
     C           IY        SUB  IX        NUM1    20
     C           NUM1      IFEQ 1
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           SKIP1     TAG
     C                     MOVELBAMHN1    K#MHN1
     C                     MOVELBAMHN2    K#MHN2
     C                     MOVELBAMHN3    K#MHN3
     C                     MOVELBAMHN4    K#MHN4
     C                     MOVELBANONY    K#NONY
     C           K#PP45    CHAINEDIPP45              99
     C  N99                ITER
      *
     C                     CLEAREDIPP451
     C                     TIME           @TIME
     C                     MOVELBAMHN1    E5MHN1
     C                     MOVELBAMHN2    E5MHN2
     C                     MOVELBAMHN3    E5MHN3
     C                     MOVELBAMHN4    E5MHN4
     C                     Z-ADDBANONY    E5NONY
     C                     MOVELBAFLD2    E5UPRT
     C                     Z-ADDTODAY     E5CRHZ
     C                     Z-ADDNOW       E5CRTM
     C                     Z-ADDNOW       E5CRTM
     C                     MOVEL#USER     E5CRME
     C                     MOVEL#PGM      E5CRPG
     C                     WRITEEDIPP451
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P#NONY  4
      *
     C           K#PP45    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
      *
     C                     TIME           @TIME
     C                     MOVELP#NONY    @NONY   40
      *
     C                     ENDSR
      *===============================================================
