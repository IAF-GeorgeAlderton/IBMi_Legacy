     CSR         @SUB1     BEGSR
     C           WKEY      KLIST
     C                     KFLD           KHIN1
     C                     KFLD           KHIN2
     C                     KFLD           KHIN3
      *
     C           PNTKR     IFEQ '------'
     C           PNTKR     OREQ '++++++'
     C                     GOTO @ESUB1
     C                     END
      *
     C                     MOVE *BLANK    KHIN1   5
     C                     MOVE *BLANK    KHIN2   5
     C                     MOVE *BLANK    KHIN3   2
      *
     C                     MOVELL5SHN1    KHIN1
     C                     MOVELL5SHN2    KHIN2
     C                     MOVELL5SHN3    KHIN3
     C                     MOVE *BLANK    CHK     1
     C                     Z-ADDL5UKHZ    L5UK
     C                     Z-ADDL5STHZ    L5ST
      *
     C                     SETOF                     77
     C           WKEY      CHAINAAMPL111             77
     C           *IN77     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADD1         #X      20
     C                     Z-ADD0         @X      20
     C                     Z-ADDL5UBIN    WUBIN
     C                     Z-ADDL5SBIN    WSBIN
      *
     C           1         DO   15        #X
     C           @UKO,#X   IFGE L5UKHB
     C           @UKO,#X   ANDLTL5STHB
     C                     ADD  1         @X
     C                     MOVE NKAB,#X   @KS,@X
     C                     MOVE KBN,#X    @TK,@X
     C                     ELSE
     C                     ADD  1         @X
     C                     MOVE OKAB,#X   @KS,@X
     C                     MOVE OTKR,#X   @TK,@X
     C                     END
     C                     ENDDO
      *
     C                     Z-ADD1         $X      20
     C           PNTKR     LOKUP@TK,$X                   88
      *
     C                     ADD  1         $X
     C                     Z-ADD$X        #X      20
     C           @X        IFNE 0
     C           $X        DO   @X        #X
     C           @KS,#X    IFNE *BLANK
      *
     C           @KS,#X    IFEQ 'C'
     C           @KS,#X    OREQ 'D'
     C           @KS,#X    OREQ 'E'
     C           @KS,#X    OREQ '0'
     C           @KS,#X    OREQ 'F'
     C                     MOVE '*'       CHK
     C                     END
      *
     C                     END
     C                     ENDDO
     C                     END
      *
     C                     END
     C                     END
