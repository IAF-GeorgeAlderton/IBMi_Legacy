     H            Y.
     F*** ABCR15 ***********************************
     F* CALCULATION  OF HEAT TREATMENT PLATING KANBAN SHEETS
     F*         A.IDOTA         1992.04.22         *
     F*********************************** ABCR15 ***
     C           *ENTRY    PLIST
     C                     PARM           PARM1   2        SETON LR ﾍｭcﾆg
     C                     PARM           PARM2   90       fhmbﾈｮmbﾇc
     C                     PARM           PARM3   50       ﾆｬcﾑcﾇc
     C                     PARM           PARM4   40       udﾎﾞy]
     C                     PARM           PARM5   20       ﾜｮn
     C                     PARM           PARM6   20       ﾌﾞﾛﾓ
     C                     PARM           PARM7   20       Cﾌﾞﾃﾍﾒl
     C                     PARM           PARM8   32       ibﾇc
     C                     PARM           PARM9   30       kｭcﾈb
     C                     PARM           PARM10  40       f]ﾌﾞ]ubﾇc
     C                     PARM           PARM11  6        ﾆｭﾒﾍﾇﾞi
     C                     PARM           PARM12  31       xｮg L.T
     C                     PARM           PARM13  31       zgbﾛ L.T
      *
     C                     Z-ADDPARM2     @KAKU   90
     C                     Z-ADDPARM3     @SYOY   50
     C                     Z-ADDPARM4     @SBMN   40
     C                     Z-ADDPARM5     @LOTO   20
     C                     Z-ADDPARM6     @BARA   20
     C                     Z-ADDPARM7     @CBKO   20
     C                     Z-ADDPARM8     @KISU   32
     C                     Z-ADDPARM9     @TYSI   30
     C                     Z-ADDPARM12    @MKLT   31
     C                     Z-ADDPARM13    @YKLT   31
      *
     C           @LOTO     IFEQ 0
     C                     Z-ADD1         @LOTO
     C                     END
      *
     C           PARM1     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
      ********************************************
      * 日当箱数＝確定設定数／稼動日数／収容数 *
      ********************************************
     C                     Z-ADD0         HAKO    62
     C                     Z-ADD0         DMI1    92
     C           @KAKU     IFNE 0
     C           @KAKU     DIV  20        DMI1
     C                     END
     C           DMI1      IFNE 0
     C           DMI1      DIV  @SYOY     HAKO
     C                     END
      *
      ******************************
      * Ｌ．Ｔ＝OQ L.T + BZ L.T  *
      ******************************
     C                     Z-ADD0         LITM    41
      *
     C           @MKLT     ADD  @YKLT     LITM
      *
      ****************
      * 少量品補数 *
      ****************
     C                     Z-ADD0         HOSU    21
      *
     C           0         IFLE HAKO
     C           3         ANDGEHAKO
     C                     Z-ADD2         HOSU
     C                     END
     C           3         IFLT HAKO
     C           5         ANDGEHAKO
     C                     Z-ADD1.5       HOSU
     C                     END
     C           5         IFLT HAKO
     C           7         ANDGEHAKO
     C                     Z-ADD1.0       HOSU
     C                     END
     C           7         IFLT HAKO
     C           14        ANDGEHAKO
     C                     Z-ADD0.3       HOSU
     C                     END
     C           14        IFLT HAKO
     C                     Z-ADD0.2       HOSU
     C                     END
      *
      **********************  計算式  ****************************
      *  N:f]ﾌﾞ] ubﾇc  A:ﾍajﾒ ﾌﾃﾇc  L.T:ﾒｰnﾞjbw(OQ L.T + BZ L.T)   *
      *  R:ﾆｭcﾒｭcﾍ] tﾇc  Y:1ﾜｮn zgbﾛ ﾌﾃﾇc  B:xｮgﾌﾞﾛﾓ ncpｬc ﾌﾃﾇc    *
      *  Z:Cﾌﾞﾃ ﾍﾒl  H:ﾌﾞ[lg ibﾇc  X:kｭcﾈb ubﾇc                    *
      **************************************************************
      *                                                            *
      * 焼入ロット＜メッキロット                                 *
      *   Ｎ＝（Ａ＊Ｈ＊Ｌ．Ｔ）＋Ｒ＋（Ｂ－１）＋Ｘ             *
      *                                                            *
      *           ＞                                             *
      * 焼入ロット＝メッキロット                                 *
      *   Ｎ＝（（Ａ＊Ｈ＊Ｌ．Ｔ）＋Ｒ＋（Ｙ＊Ｚ－１）＋Ｘ）／Ｙ *
      *                                                            *
      **************************************************************
     C                     Z-ADD0         MISU    40
      *
      ******************************
      * 焼入ロット＝＜メッキロット *
      ******************************
     C           @LOTO     IFLT @BARA
     C                     Z-ADD0         DMI2    92
     C                     Z-ADD0         DMI3    92
     C                     Z-ADD0         DMI4    92
     C           HAKO      MULT @KISU     DMI2
     C           DMI2      MULT LITM      DMI2
      *
     C                     Z-ADD@BARA     DMI3
     C           DMI3      SUB  1         DMI3
      *
     C           DMI2      ADD  HOSU      DMI4
     C                     ADD  DMI3      DMI4
     C*                    ADD  @TYSI     DMI4
      *
     C           DMI4      ADD  0.9       MISU
     C                     END
      *
      ******************************
      * 焼入ロット＞メッキロット *
      ******************************
     C           @LOTO     IFGE @BARA
     C                     Z-ADD0         DMI2
     C                     Z-ADD0         DMI3
     C                     Z-ADD0         DMI4
     C                     Z-ADD0         DMI5    92
     C           HAKO      MULT @KISU     DMI2
     C           DMI2      MULT LITM      DMI2
      *
     C           @CBKO     IFEQ 0
     C                     Z-ADD@LOTO     DMI3
     C                     ELSE
     C           @LOTO     MULT @CBKO     DMI3
     C                     END
     C           DMI3      SUB  1         DMI3
      *
     C           DMI2      ADD  HOSU      DMI4
     C                     ADD  DMI3      DMI4
     C*                    ADD  @TYSI     DMI4
      *
     C           DMI4      IFNE 0
     C           DMI4      DIV  @LOTO     DMI5
     C                     END
      *
     C           DMI5      ADD  0.9       MISU
     C                     END
      *
     C                     ADD  PARM9     MISU
     C           MISU      IFGT PARM10
     C                     Z-ADDMISU      PARM10
     C                     END
      *
     C                     RETRN
