     H            Y.
     F** EGBR16 ********************************************
     F*  ADJUST EGBWP11                                    *
     F*  ADD DAY USED TIMES (FROM OBJECT)                  *
     F*  J.WATA       2023.01.16                           *
     F******************************************************
     FEGBWP11 UF  E           K        DISK
     FVVVPP40 IF  E           K        DISK
      ******************************************************
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      * MAIN ROUTINE
      ******************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ EGBWP11                  98
     C   98                LEAVE
      *
     C                     MOVELG2PGM     LTR4    4
     C           LTR4      IFEQ 'MENU'
     C                     DELETEGBWP111
     C                     ITER
     C                     ENDIF
      *
     C           G2LUHZ    IFLT @FROM
     C           G2LUHZ    ANDNE0
     C                     ITER
     C                     ENDIF
      * CHECK VVVPP40
     C           G2PGM     CHAINVVVPP40              97
     C           *IN97     IFEQ *OFF
     C                     ADD  ODUCNT    G2TMS
     C           G2LUHZ    IFEQ 0
     C           G2TMS     ANDNE0
     C                     MOVELG2CRHZ    G2LUHZ
     C                     ENDIF
     C                     UPDATEGBWP111
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* INITIAL SETTING
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
      *
     C                     TIME           @SDATE
     C                     MOVEL$FROM     @FROM   80
     C                     MOVEL$TO       @TO     80
     C*
     C                     ENDSR
