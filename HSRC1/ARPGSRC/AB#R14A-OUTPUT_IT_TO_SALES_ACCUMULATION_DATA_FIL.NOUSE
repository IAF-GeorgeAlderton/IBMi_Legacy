      ** AB#R13 *******************************************
      * OUTPUT IT TO SALES ACCUMULATION DATA FILE         *
      *              AND SALES DETAILS DATA LIST.         *
      * PROGRAM ID.  : AB#R13. <RPG>                      *
      * CREATE DATE. : 1997/MAR/22.                       *
      * AUTHOR.      : S.OHTAKE.                          *
      ******************************************* AB#R13 **
     FAB#WP11 UP  E                    DISK
     FAB#PP01 O   E                    DISK                      A
     FAB#PLNO UF  E           K        DISK                      A
     FQPRINT  O   F     156     OF     PRINTER
     IAB#WP111
     I                                              W1UHN3          50
     I                                              W1UHN4          51
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIM
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        5   60WBY
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
     I            DS
     I                                        1   80HIZK
     I                                        1   20HIZM
     I                                        3   40HIZD
     I                                        5   80HIZY
      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           WTIME
     C                     Z-ADDWYY       HIZY
     C                     Z-ADDWMM       HIZM
     C                     Z-ADDWDD       HIZD
     C                     MOVE PUS       USER   10
     C                     EXCPTHD
     C                     ENDIF
      *
     C                     MOVE *BLANK    B1SKJY
     C                     Z-ADD0         B1SKYY
     C                     Z-ADD0         B1SKMM
     C                     Z-ADD0         B1SKDD
     C                     Z-ADD*YEAR     B1KSYY
     C                     Z-ADD*MONTH    B1KSMM
     C                     Z-ADD*DAY      B1KSDD
     C                     Z-ADDWJI       B1KSJI
     C                     Z-ADDWFN       B1KSPN
     C                     MOVE USER      B1KSNA
      *
     C                     MOVE W1USRI    B1RENO
     C                     MOVE W1ODKE    B1JTYU
     C                     MOVE W1TEIS    B1REYU
     C                     Z-ADDW1TOKU    B1TOKU
     C                     MOVE W1TKOJ    B1TKOJ
     C                     MOVE W1TUKE    B1TUKE
     C                     Z-ADDW1NONY    B1NONY
     C                     MOVE W1NKOJ    B1NKOJ
     C                     MOVE W1NUKE    B1NUKE
     C                     MOVE W1UHN1    B1MHN1
     C                     MOVE W1UHN2    B1MHN2
     C                     MOVE W1UHN3    B1MHN3
     C                     MOVE W1UHN4    B1MHN4
     C                     MOVE W1SHN1    B1SHN1
     C                     MOVE W1SHN2    B1SHN2
     C                     MOVE W1SHN3    B1SHN3
     C                     MOVE W1ODNO    B1ODR1
     C                     Z-ADDW1ODED    B1ODR2
     C                     MOVE W1KANR    B1KBAN
     C                     Z-ADDW1TANK    B1TANK
     C                     MOVE W1TAKB    B1TKBN
     C                     MOVE W1TATN    B1TTAI
     C                     MOVELW1NOBN    B1NBAN
     C                     MOVE W1NOKB    B1NSYO
     C                     Z-ADDW1NOYY    B1NOYY
     C                     Z-ADDW1NOMM    B1NOMM
     C                     Z-ADDW1NODD    B1NODD
     C                     Z-ADDW1NOBI    B1NOBI
     C                     Z-ADDW1NOSU    B1SRYO
     C                     MOVE W1SUTN    B1TANI
     C                     Z-ADDW1KING    B1KING
     C                     Z-ADDW1JYRY    B1JRYY
     C                     Z-ADDW1JYRM    B1JRMM
     C                     Z-ADDW1JYRD    B1JRDD
     C                     MOVE W1JKKB    B1JRYO
     C                     MOVE W1JUNJ    B1SQES
     C                     Z-ADDW1SEIY    B1SEYY
     C                     Z-ADDW1SEIM    B1SEMM
     C                     Z-ADDW1SEID    B1SEDD
     C                     MOVE W1KENS    B1KSYU
     C                     MOVE W1MACH    B1MACH
     C                     Z-ADDW1MACY    B1KAYY
     C                     Z-ADDW1MACM    B1KAMM
     C                     Z-ADDW1MACD    B1KADD
     C                     Z-ADDW1GETU    B1GEMM
     C                     MOVE W1KURK    B1KRKS
     C                     MOVE W1SEBN    B1SBAN
     C                     MOVE W1UHIN    B1UHIN
     C                     Z-ADDW1HAKO    B1HAKO
     C                     Z-ADDW1SYUY    B1SYUY
     C                     Z-ADDW1LTNO    B1LOTO
     C                     Z-ADDW1PANO    B1PAGE
     C                     Z-ADD0         B1GIYO
     C                     MOVE W1STKB    B1THAI
     C                     Z-ADDW1URIY    B1URYY
     C                     Z-ADDW1URIM    B1URMM
     C                     Z-ADDW1URID    B1URDD
     C                     MOVE W1SYBT    B1SYBT
     C                     MOVE W1SOBT    B1SOBT
     C                     MOVE W1GYOM    B1GYOM
     C                     MOVE W1TUKA    B1CURE
     C                     Z-ADDW1ATNK    B1ATNK
      *
      ******************************************************
      *  SALES ACCUMULATION PRN & SHR CONTROL FILE CHAIN   *
      ******************************************************
     C                     SETOF                     18
     C           W1URIM    CHAINAB#PLNO1             18
     C           *IN18     IFEQ '0'
     C                     ADD  1         I5RENO
     C                     UPDATAB#PLNO1
     C                     ELSE
     C                     Z-ADDW1URIM    I5TUKI
     C                     Z-ADD1         I5RENO
     C                     WRITEAB#PLNO1
     C                     END
      *
     C                     Z-ADDI5RENO    W1RECN
     C                     UPDATAB#WP111
      *
     C                     Z-ADDI5RENO    B1RCOD
     C                     WRITEAB#PP011
      *
     C                     EXCPTMS
      *
     C   OF                EXCPTHD
     C                     SETOF                     OF
      *
     C                     ADD  1         CT3     50
      *
     CLR                   EXCPTTO
      *
     OQPRINT  E  102           HD
     O                                  131 '.....................'
     O        E  1             HD
     O                                  131 '.         .         .'
     O        E  1             HD
     O                                   12 'AB#R13-1'
     O                                   89 'TIME'
     O                         WTIM      98 '  :  :  '
     O                                  131 '.         .         .'
     O        E  1             HD
     O                                    9 'DAILY'
     O                         HIZK      25 '  .  .    '
     O                                   46 'SALES DETAILS'
     O                                   51 'LIST'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE2 Z  108
     O                                  131 '.....................'
     O        E 2              HD
     O                                  103 'DELIVERY'
     O                                  113 'DELIVERY'
     O                                  124 'RCV'
     O                                  130 'BOX'
     O                                  144 'PACKAGE'
     O        E 12             HD
     O                                   20 'ABNORMAL CONTENTS'
     O                                   33 'CUSTOMER'
     O                                   43 'DELIVERY'
     O                                   46 'F'
     O                                   51 'RCV'
     O                                   66 'USER PART NO'
     O                                   87 'ORDER NO'
     O                                  103 'QUANTITY'
     O                                  111 'DATE'
     O                                  119 'BIN'
     O                                  124 'NO'
     O                                  135 'QUANTITY'
     O                                  145 'CAPACITY'
     O        E  1             MS
     O                         W1TOKU    31
     O                         W1NONY    41
     O                         W1NKOJ    46
     O                         W1NUKE    52
     O                         W1UHN1    59
     O                                   60 '-'
