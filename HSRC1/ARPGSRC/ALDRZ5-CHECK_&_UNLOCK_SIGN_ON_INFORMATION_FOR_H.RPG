     H            Y.                                                      EER030
     F** ALDRZ5 **************************************
     F*CHECK & UNLOCK SIGN-ON INFORMATION FOR HANDY *
     F*       T.SAKAKI         2015.10.15             *
     F************************************************
     FALDPWZ5 CF  E                    WORKSTN
     FAM#PP31 IF  E           K        DISK
      * ONLY ERROR RECORDS
     FALDPLZ6 UF  E           K        DISK
      *
     E                    ER      1  11 65
     E                    R3PG       10  1
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTHMS
     I                                        7  140WDATE
      *
     I            DS
     I                                        1   80A@ONDT
     I                                        1   40W@YEAR
     I                                        5   60W@MONT
     I                                        7   80W@DAY
      *
     I            DS
     I                                        1  10 D1ONDT
     I                                        1   2 D@MONT
     I                                        3   3 D1
     I                                        4   5 D@DAY
     I                                        6   6 D2
     I                                        7  10 D@YEAR
      *
     I            DS
     I                                        1   60A@ONTM
     I                                        1   20W@HOUR
     I                                        3   40W@MINU
     I                                        5   60W@SECO
      * AM#PP31
     I            DS
     I                                        1  10 R3PG
     I                                        1   1 R3PGM1
     I                                        2   2 R3PGM2
     I                                        3   3 R3PGM3
     I                                        4   4 R3PGM4
     I                                        5   5 R3PGM5
     I                                        6   6 R3PGM6
     I                                        7   7 R3PGM7
     I                                        8   8 R3PGM8
     I                                        9   9 R3PGM9
     I                                       10  10 R3PGMA
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW
     C                     TIME           WTIME
     C                     Z-ADD0         D1WKCD
     C                     MOVE '/'       D1
     C                     MOVE '/'       D2
     C*
     C           K#WSI     KLIST
     C                     KFLD           K@WSID 10
     C*
     C                     MOVELW#WSID    K@WSID
     C*
     C                     SETOF                     98
     C           K#WSI     CHAINALDPLZ61             98
      * GET ERROR RECORD INFO
     C           *IN98     IFEQ *OFF
     C                     MOVE W@YEAR    D@YEAR
     C                     MOVE W@MONT    D@MONT
     C                     MOVE W@DAY     D@DAY
     C                     MOVE W@HOUR    D1ONHH
     C                     MOVE W@MINU    D1ONMM
     C                     MOVE W@SECO    D1ONSS
     C                     MOVELA@PGNM    D1PGNM
     C                     MOVELA@WKNM    D1WKNM 20
     C                     Z-ADDA@WKCD    W1WKCD  60
     C                     Z-ADDA@PGRP    W1PGRP  20
     C                     ENDIF
      * IF NO ERROR
     C           *IN98     IFEQ *ON
     C                     MOVEL'99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN 1                                             *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN 2 UNLOCK PROCESS                              *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
      * CHECK PASSWORD
     C           D1WKCD    CHAINAM#PP311             21
     C           *IN21     IFEQ '0'
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C                     MOVEL*BLANK    FLG     1
     C           *IN21     IFEQ '0'
     C                     Z-ADDW1PGRP    X       20
     C                     MOVELR3PG,X    FLG
     C                     ENDIF
      *
      * FLG '1' = UNLOCK
     C           FLG       IFEQ '1'
     C                     EXSR @UPDAT
     C                     MOVEL'99'      DSPSW   2
     C                     ELSE
      * PASSWORD ERROR
     C                     SETON                     3199
     C                     MOVELER,1      MSG    25
     C                     EXSR #SB999
     C                     Z-ADD0         D1WKCD
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
     C**************************************************************************
     C*                    @UPDAT
     C**************************************************************************
     C           @UPDAT    BEGSR
     C                     MOVEL'D'       A@SKJY
     C                     Z-ADDWDATE     A@OFDT
     C                     Z-ADDWTHMS     A@OFTM
     C                     MOVELD1WKCD    A@UNCD
      *
     C                     UPDATALDPLZ61
      *
     C                     ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * ERR                                                *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     CSR         ESB999    ENDSR
**
PASSWORD ERROR
