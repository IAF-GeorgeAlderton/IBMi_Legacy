     H            Y.
     F** AFGR10 *********************************************
     F* INPUT CHECK INQUIRY EDI ORDER FOR OUTSOURCE         *
     F*             T.SAKAKI       2016.11.20               *
     F*******************************************************
     FAFGPW10 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAFGPL03 IF  E           K        DISK
      *
     E                    ER      1  20 60
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
     I                                        7  100WYYYY
     I                                       11  120WMMMM
     I                                       13  140WDDDD
      *
     I            DS
     I                                        1   80D1SDAT
     I                                        1   40D1SDYY
     I                                        5   60D1SDMM
     I                                        7   80D1SDDD
     I            DS
     I                                        1   80F8KYMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SUPP  4
     C                     PARM           P1SDAT  80
     C                     PARM           P1EDAT  80
     C                     PARM           P1GPPO 17
     C                     PARM           P9CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
     C           KEYS      KLIST
     C                     KFLD           D1SDYY
     C                     KFLD           D1SDMM
     C                     KFLD           D1SDDD
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD0         D1CODE
     C                     Z-ADD0         D1SDAT
     C                     Z-ADD99999999  D1EDAT
     C                     MOVEL*BLANK    D1SMEI
     C                     MOVEL*BLANK    D1GPPO
     C                     MOVEL*BLANK    P9CMD
      *
      * VENDOR CODE
     C                     MOVE P1SUPP    D1CODE
     C           D1CODE    CHAINFGBPL011             92
     C           *IN92     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLEWDATE
     C                     ELSE
     C                     MOVELB2SMEI    D1SMEI
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN 2                                             *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAFGPW101
     C                     SETOF                     616299
     C                     MOVEL*BLANK    D1MSG
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      * INPUT CHECK
     C           D1SDAT    IFEQ 0
     C           D1GPPO    ANDEQ*BLANK
     C                     MOVELER,3      D1MSG
     C                     SETON                     616299
     C                     GOTO ESB210
     C                     ENDIF
      *
      * GPS P.O.#
     C           D1GPPO    IFNE *BLANK
     C           D1GPPO    CHAINAFGPL03              91
     C           *IN91     IFEQ '1'
     C                     MOVELER,2      D1MSG
     C                     SETON                     6299
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
      * START DATE
     C           D1SDAT    IFNE 0
     C           KEYS      CHAINAGDPL12              90
     C           *IN90     IFEQ '1'
     C                     MOVELER,1      D1MSG
     C                     SETON                     6199
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     MOVEL'99'      DSPSW
      *
     C                     Z-ADDD1SDAT    P1SDAT
     C           D1EDAT    IFEQ 0
     C                     Z-ADD99999999  P1EDAT
     C                     ELSE
     C                     Z-ADDD1EDAT    P1EDAT
     C                     ENDIF
     C                     MOVELD1GPPO    P1GPPO
     C                     MOVEL'05'      P9CMD
      *
     C                     ENDIF
      *
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
** ER
E-01 INPUT CORRECT DATE.
E-02 NO DATA.
E-03 EITHER ONE IS REQUIRED.
E-04
E-05
E-06
