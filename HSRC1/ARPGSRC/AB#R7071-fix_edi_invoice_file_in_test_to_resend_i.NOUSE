     H            Y.
     FAB#PL19FIF  E           K        DISK
     FAB#EL70XIF  E           K        DISK
     FAB#EL71XIF  E           K        DISK
     FAB#WP70XO   E           K        DISK
     FAB#WP71XO   E           K        DISK
     FAB#WP7XXO   E           K        DISK
      *
     E                    PART      100 20
      *
     I            DS
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I                                        1  20 MHIN
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     C           *ENTRY    PLIST
     C                     PARM           IN#INV 16
     C                     PARM           INISDT  8
      *
     C           KEY19F    KLIST
     C                     KFLD           NONY    40
     C                     KFLD           IN#INV
      *
     C           L71KEY    KLIST
     C                     KFLD           IN#INV
     C                     KFLD           MHIN
     C                     KFLD           CRDT
     C                     KFLD           ISDT
      *
     C                     Z-ADD3503      NONY
     C                     MOVE 'Y'       FIRST   1
     C           INISDT    IFEQ *BLANK
     C                     TIME           WTIME
     C                     ELSE
     C                     MOVELINISDT    SDATE
     C                     ENDIF
      *
     C           KEY19F    SETLLAB#PL19F
     C           *IN50     DOWEQ*OFF
     C           KEY19F    READEAB#PL19F                 50
      *
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           BANOBN    IFEQ 33
     C                     ADD  1         X       30
     C                     MOVELMHIN      PART,X
     C                     ENDIF
      *
     C                     ENDDO
      *
      *
     C                     MOVE *OFF      *IN50
     C           KEY19F    SETLLAB#PL19F
     C           *IN50     DOWEQ*OFF
     C           KEY19F    READEAB#PL19F                 50
      *
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           MHIN      LOKUPPART                     30
     C           *IN30     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR GETINV
      *
     C                     ENDDO
      *
     C           RCDS      IFGT *ZERO
      *
     C           BAINVN    SETLLAB#EL70X
     C           BAINVN    READEAB#EL70X                 51
     C           *IN51     IFEQ *OFF
     C           EINVN     CAT  'Y':0     EINVN
     C                     Z-ADDSDATE     EISDT
     C                     WRITEAB#WP701
     C                     ENDIF
      *
     C                     MOVELIN#INV    AUINVN
     C                     WRITEAB#WP7X1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *********************************************************************
     C           GETINV    BEGSR
      *
     C           FIRST     IFEQ 'Y'
      *
     C           BAINVN    SETLLAB#EL70X
     C           BAINVN    READEAB#EL70X                 51
     C           *IN51     IFEQ *OFF
     C                     Z-ADDE7CRDT    CRDT    80
     C                     Z-ADDEISDT     ISDT    80
     C                     MOVE 'N'       FIRST
     C                     ENDIF
      *
     C                     ENDIF
      *
      *
     C           L71KEY    SETLLAB#EL71X
     C           L71KEY    READEAB#EL71X                 51
     C           *IN51     IFEQ *OFF
     C           EINVN     CAT  'Y':0     EINVN
     C                     Z-ADDSDATE     EISDT
     C                     WRITEAB#WP711
     C                     ADD  1         RCDS    60
     C                     ENDIF
      *
     C                     ENDSR
