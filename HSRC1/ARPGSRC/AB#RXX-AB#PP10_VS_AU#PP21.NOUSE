     C           CBSKJY    OREQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     @QTY    70
     C           K#AU      SETLLAU#PL24
     C           *IN95     DOUEQ*ON
     C           K#AU      READEAU#PL24                  95
     C           *IN95     IFEQ *OFF
     C                     ADD  CQSRYO    @QTY
     C                     ENDIF
     C                     ENDDO
      *
     C           BASRYO    IFNE @QTY
     C                     EXSR #ERR
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
     C           #ERR      BEGSR
      *-----------------------------------------------------
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
