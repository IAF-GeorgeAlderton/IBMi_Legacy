     C           K#AU      KLIST
     C                     KFLD           BANONY
     C                     KFLD           BANUKE
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C           K#AG      KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
      *
     C                     Z-ADD20011201  K@DATE  80
     C           K@DATE    SETLLAB#PL1A
     C           *IN90     DOUEQ*ON
     C                     READ AB#PL1A                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           K#AG      CHAINAGAPL31              50
