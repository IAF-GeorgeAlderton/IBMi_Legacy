     C           15.9      MULT J1MSKB    A2      93
     C                     Z-ADD55.37     A3      93
     C           A1        ADD  A2        A       93
     C           A3        ADD  A         A
     C*膜厚係数Ｂの算出*
     C           J1MSMA    IFLE 0
     C                     SETON                     96
     C                     GOTO EXIT1
