     C*
     C           J1MSMA    ADD  3         B1      93
     C           B1        DIV  1.6       B       93
     C*熱処理係数Ｃの算出*
     C           J1MSNT    IFNE 0
%0001C*                    Z-ADD1.1       C       93
%0001C                     Z-ADD1.05      C       93
     C                     ELSE
     C                     Z-ADD1         C
     C                     END
     C*形状係数Ｄの算出*
     C*六角ボルト*
     C           J1MSKJ    IFEQ '13'
     C                     Z-ADD0.8       D       93
     C                     GOTO EXIT2
     C                     END
     C*座金組込六角ボルト・セレイションボルト*
     C           J1MSKJ    IFEQ '24'
     C           J1MSKJ    OREQ '35'
     C*
     C           J1MSWS    IFEQ 0
     C                     Z-ADD0.8       D
     C                     GOTO EXIT2
     C                     END
     C           J1MSWS    IFEQ 1
     C                     Z-ADD0.9       D
     C                     GOTO EXIT2
     C                     END
     C           J1MSWS    IFGE 2
     C                     Z-ADD1         D
     C                     GOTO EXIT2
     C                     END
     C*
     C                     END
     C*つば付座六角ボルト*
     C           J1MSKJ    IFEQ '19'
     C*
     C           J1MSWS    IFEQ 0
