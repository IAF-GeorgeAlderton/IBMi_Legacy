     F** ECQR09 **********************************
     F* 6  MONTHS DIE USED RESULT INQUIRY  *
     F* PROGRAM ID. : ECQR09. <RPG> *
     F* CREATE DATE. : AUG.05,'88.               *
     F* TCH 02/14/05   TCH70                     *
     F********************************** ECQR09 **
     FECQPW36 CF  E                    WORKSTN
     FECSPL12 IF  E           K        DISK
     FGCQTL31 IF  E           K        DISK
     FMBEPL05 IF  E           K        DISK
TCH70F*CQPL36 IF  E           K        DISK
     FECSWP36 UF  E           K        DISK                      A
     E                    MSG     1   5 60               d[ｰxｮﾈｰﾆﾞ
     I            DS
     I                                        1   60WYYMM
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     I            DS
     I                                        1   60@YMF
     I                                        1   40@YF
     I                                        5   60@MF
     I            DS
     I                                        1   60@YMT
     I                                        1   40@YT
     I                                        5   60@MT
     I            DS
     I                                        1  15 WDIE
     I                                        1   2 DIE1
     I                                        3   3 WDASH
     I                                        4   7 DIE2
     I            DS
     I                                        1   60YYMMF
     I                                        1   40CYYF
     I                                        5   60CMMF
     I            DS
     I                                        1   60YYMMT
     I                                        1   40CYYT
     I                                        5   60CMMT
TCH70I            DS
     I                                        1  15 DFKATA
     I                                        1   2 WDIE1
TCH70I                                        4   7 WDIE2
     C                     MOVE '-'       WDASH
      *
     C           KEY1      KLIST
     C                     KFLD           @YF
     C                     KFLD           @MF
      *
TCH70C           KEY5      KLIST
     C                     KFLD           WDIE1
TCH70C                     KFLD           WDIE2
      *
     C           PART      KLIST
     C                     KFLD           EQKAT1
     C                     KFLD           EQKAT2
      *
     C           KEY2      KLIST
     C                     KFLD           WDIE   15
     C           KEY3      KLIST
     C                     KFLD           @YYYY   40
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
      *
     C           STP0      TAG
     C                     CLEARYYMMF
     C                     CLEARYYMMT
     C                     SETOF                     010203
     C                     SETOF                     99
     C                     MOVE *BLANK    ERR
      *
     C******************************************************
     C*  EXFMT  <fﾞx] 1>                                   *
     C******************************************************
     C           STP1      TAG
     C*                    WRITEECQPW361
     C*                    READ ECQPW36                9999<TIME eｰﾌﾞｰ>
     C                     EXFMTECQPW361
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     SETOF                     010203
     C                     SETOF                     99
     C                     MOVE *BLANK    ERR
      *
     C           *IN99     IFEQ '1'
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
      *
     C******************************************************
     C*  <fﾞx] 1 ﾉ kｩｮh>                                   *
     C******************************************************
      *
     C*  DATE CHECK
     C           YYMMF     IFEQ 0
     C                     SETON                     0299
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C           YYMMT     IFEQ 0
     C                     SETON                     0299
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C           YYMMF     IFGT YYMMT
     C                     SETON                     0299
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C           CMMT      IFGT 12
     C                     SETON                     0299
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C           CMMF      IFGT 12
     C                     SETON                     0299
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C           CYYF      IFLT 2004
     C           CYYT      ORGT 2006
     C                     SETON                     0299
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C           SKIP1     TAG
      *-------------------
     C                     Z-ADDYYMMF     @YMF    60
     C                     Z-ADDYYMMT     @YMT    60
      *
     C           KEY1      SETLLECSPP011
B0   C           *IN10     DOWEQ'0'
     C                     READ ECSPP011                 10
B1   C           *IN10     IFEQ '1'
     C           YYMMT     ORLT WYYMM
     C                     LEAVE
E1   C                     ENDIF
B1   C           EQSKJY    IFEQ 'D'
     C                     ITER
E1   C                     ENDIF
     C           PART      CHAINECSWP36              46
B1   C           *IN46     IFEQ '0'
     C                     ADD  EQKOSU    COUNT
     C                     UPDATECSWP361
     C                     ELSE
     C                     MOVE EQKAT1    DIE1
     C                     MOVE EQKAT2    DIE2
     C                     Z-ADDEQKOSU    COUNT
     C                     WRITEECSWP361
E1   C                     ENDIF
E0   C                     ENDDO
TCH70C* APPEND FROM GCQPP31 FOR 0 COUNT
     C                     MOVE '0'       *IN88
     C           *IN88     DOWEQ'0'
     C                     READ GCQTL311                 88
     C           *IN88     IFEQ '0'
     C           DFSKJY    ANDEQ' '
     C           KEY5      CHAINECSWP36              67
     C           *IN67     IFEQ '1'
     C                     MOVE WDIE1     DIE1
     C                     MOVE WDIE2     DIE2
     C                     Z-ADD0         COUNT
     C                     WRITEECSWP361
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
TCH70C*
      * UPDATE UNIT
     C                     MOVE '0'       *IN22
     C           *LOVAL    SETLLECSWP36
B0   C           *IN22     DOWEQ'0'
     C                     READ ECSWP36                  22
B1   C           *IN22     IFEQ '0'
     C                     EXSR #UNIT
     C*          UNIT      DIV  10000     UNIT      H
     C                     UPDATECSWP361
E1   C                     ENDIF
E0   C                     ENDDO
      *
     C*                    GOTO STP0
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------------*
     C           #UNIT     BEGSR
      *---------------------------------------------------*
      *
     C                     Z-ADD0         UNIT
     C                     MOVE '0'       *IN15
     C           KEY2      SETLLGCQTL311
B0   C           *IN15     DOWEQ'0'
     C           KEY2      READEGCQTL311                 15
B1   C           *IN15     IFEQ '0'
     C           DFSKJY    ANDEQ' '
     C                     EXSR #MBEP
E1   C                     ENDIF
E0   C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------*
     C           #MBEP     BEGSR
      *---------------------------------------------------*
     C* FROM
B0   C           @YT       IFGT @YF
     C           12        SUB  @MF       WCOUNT  20
     C                     ADD  1         WCOUNT
     C                     Z-ADD@MF       WWCNT   20
     C                     ELSE
     C           @MT       SUB  @MF       WCOUNT
     C                     ADD  1         WCOUNT
     C                     Z-ADD@MF       WWCNT   20
E0   C                     ENDIF
     C                     Z-ADD@YF       @YYYY
     C           KEY3      CHAINMBEPL051             80
B0   C           *IN80     IFEQ '0'
B1   C           1         DO   WCOUNT
     C                     EXSR #SELEC
     C                     ADD  1         WWCNT
E1   C                     ENDDO
E0   C                     ENDIF
     C* TO
B0   C           @YT       IFGT @YF
     C                     Z-ADD@YT       @YYYY
     C                     Z-ADD@MT       WCOUNT
     C                     Z-ADD1         WWCNT
     C           KEY3      CHAINMBEPL051             80
B1   C           *IN80     IFEQ '0'
B2   C           1         DO   WCOUNT
     C                     EXSR #SELEC
     C                     ADD  1         WWCNT
E2   C                     ENDDO
E1   C                     ENDIF
     C*
E0   C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------*
     C           #SELEC    BEGSR
      *---------------------------------------------------*
     C           WWCNT     IFEQ 1
     C           I6SRO1    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 2
     C           I6SRO2    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 3
     C           I6SRO3    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 4
     C           I6SRO4    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 5
     C           I6SRO5    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 6
     C           I6SRO6    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 7
     C           I6SRO7    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 8
     C           I6SRO8    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 9
     C           I6SRO9    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 10
     C           I6SROA    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 11
     C           I6SROB    DIV  10000     ER     111H
     C                     ENDIF
     C           WWCNT     IFEQ 12
     C           I6SROC    DIV  10000     ER     111H
     C                     ENDIF
     C*
     C                     ADD  ER        UNIT
     C                     ENDSR
      *
**  MSG (ERROR MESSAGE )
E-01 PLEASE SIGNOFF WHEN DOESN'T USE IT LONG TIME.
E-02 INPUT FACTORY CODE.
E-03 FACTORY CODE ISN'T RIGHT.
E-04 INPUT DIE NO
E-05 DATE IS NOT CORRECT
