     H            Y.
     F*** FCER60 *****************************
     F* SERVICE PARTS M/F MAINTENANCE      *
     F*                                      *
     F***************************** FCER60 ***
     FFCEPP30 UP  E                    DISK
     FFCEPL01 IF  E           K        DISK
     I            DS
     I                                        1   6 A2LOC
     I                                        1   1 A2STRK
     I                                        2   3 A3STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
     I            DS
     I                                        1   6 F3LOC
     I                                        1   1 F3PTRK
     I                                        2   3 F3TTRT
     I                                        4   5 F3TTRR
     I                                        6   6 F3TTRD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      *  MAIN ROUTINE
      *****************************************************
     C           K#KEY     KLIST
     C                     KFLD           F3BHB1
     C                     KFLD           F3BHB2
     C                     KFLD           F3BHB3
      *
     C           K#KEY     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           A2LOC     ANDNEF3LOC
     C                     MOVELA2STRK    F3PTRK
     C                     MOVELA2STRT    F3PTRT
     C                     MOVELA2STRR    F3PTRR
     C                     MOVELA2STRD    F3PTRD
      *
     C                     UPDATFCEPP301
     C                     ENDIF
      *
