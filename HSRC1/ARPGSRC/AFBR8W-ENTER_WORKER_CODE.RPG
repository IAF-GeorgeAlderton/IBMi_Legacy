     H** AFBR8W *******************************************************
     H* TCHK1 06/16/10 ADD CHECK SKJY
     H**************************************************************************
     FAFBPW8W CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     I**************************************************************************
     C*
     C           *ENTRY    PLIST
     C                     PARM           PWKCD   6
     C                     PARM           ENDID   1
     C*
     C           *INKC     DOUEQ*ON
     C                     EXFMTDSP1
      *
     C           *INKC     IFEQ *OFF
     C           CODE      CHAINALBPL30              90
     C           *IN90     IFEQ *OFF
TCHK1C           ALSKJY    ANDEQ*BLANK
     C                     MOVE CODE      PWKCD
     C                     MOVE *BLANK    ENDID
     C                     LEAVE
     C                     ENDIF
     C                     ELSE
     C                     MOVE '1'       ENDID
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
