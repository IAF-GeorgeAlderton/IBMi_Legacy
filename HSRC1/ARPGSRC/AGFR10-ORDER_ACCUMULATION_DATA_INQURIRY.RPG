     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     CLEARDSP01
     C                     TIME           @TIME
     C                     Z-ADD0         D1KARA
     C                     Z-ADD0         D1MADE
     C                     MOVEL*BLANK    D1HIN1
     C                     MOVEL*BLANK    D1HIN2
     C                     MOVEL*BLANK    D1HIN3
     C                     MOVEL*BLANK    D1SUPP
     C                     MOVEL*BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'00000000'*IN,11
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* F5 *
     C           *INKE     WHEQ *ON
     C                     MOVE '#CHK1 F5'@STEP
     C*    *
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
     C*===============================================================
      *画面１チェック
     C*===============================================================
     C           #CHK1     BEGSR
      **
     C           D1KARA    IFNE 0
     C                     MOVELD1KARA    P$DATE  8
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C*                                              P$RTN='1':NG
     C           P$RTN     IFEQ '1'
     C                     SETON                     1199
     C                     MOVELER,1      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C                     ENDIF
      **
     C           D1MADE    IFNE 0
     C                     MOVELD1MADE    P$DATE  8
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C*                                              P$RTN='1':NG
     C           P$RTN     IFEQ '1'
     C                     SETON                     1299
     C                     MOVELER,1      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C                     ENDIF
      **
     C           D1KARA    IFGT D1MADE
     C                     SETON                     111299
     C                     MOVELER,2      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      **
     C           D1KARA    IFEQ 0
     C           D1MADE    ANDEQ0
     C           D1HIN1    ANDEQ*BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C                     SETON                     111213
     C                     SETON                         99
     C                     MOVELER,3      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      **
      **
     C           @STEP     IFEQ '#CHK1 F5'
     C                     MOVE *BLANK    @@UMU   1
     C                     EXSR #UPD
     C           @@UMU     IFEQ ' '
     C                     SETON                     111213
     C                     SETON                         99
     C                     MOVELER,4      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C                     ENDIF
     C*
     C*-------------------------
     C           @CHK1     TAG
     C*-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1 F5'
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #UPD      BEGSR
     C           KEY01     KLIST
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C           KEY02     KLIST
     C                     KFLD           D1KRYY
     C                     KFLD           D1KRMM
     C                     KFLD           D1KRDD
      *-------------------------
      *-------------------------
S1   C           D1HIN1    IFNE *BLANK
     C           D1HIN2    ORNE *BLANK
     C           D1HIN3    ORNE *BLANK
     C*(AFAPL96) ORDER ACTUAL FILE
     C                     EXSR #AFA96
     C*(AFDPL25) OUTGOING ORDER FILE
     C                     EXSR #AFD25
     C*
X1   C                     ELSE
     C*(AFAPL99) ORDER ACTUAL FILE
     C                     EXSR #AFA99
     C*(AFDPL23) OUTGOING ORDER FILE
     C                     EXSR #AFD23
     C*
E1   C                     ENDIF
      *-------------------------
      *-------------------------
     C                     ENDSR
      *===============================================================
      *(AFAPL96) ORDER ACTUAL FILE
      *===============================================================
     C           #AFA96    BEGSR
     C           KEY01     SETLLAFAPL96
     C                     MOVE ' '       @FAST   1
      *-------------------------
S1   C                     DO   *HIVAL
     C           KEY01     READEAFAPL96                  91
     C   91                LEAVE
     C*
     C           A9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           D1KARA    IFNE 0
     C           D1MADE    ORNE 0
     C           A9ODHZ    IFLT D1KARA
     C           A9ODHZ    ORGT D1MADE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1SUPP    IFNE *BLANK
     C           D1SUPP    ANDNEA9SUPP
     C                     ITER
     C                     ENDIF
     C**
     C                     EXSR #OUTF1
     C**
E1   C                     ENDDO
      *-------------------------
     C           @FAST     IFEQ '*'
     C                     MOVE '*'       @@UMU
     C                     WRITEAGFWP101
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *(AFAPL99) ORDER ACTUAL FILE
      *===============================================================
     C           #AFA99    BEGSR
     C           KEY02     SETLLAFAPL99
     C                     MOVE ' '       @FAST
      *-------------------------
S1   C                     DO   *HIVAL
     C                     READ AFAPL99                  91
     C   91                LEAVE
     C           A9ODHZ    IFGT D1MADE
     C                     LEAVE
     C                     ENDIF
     C*
     C           A9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           D1SUPP    IFNE *BLANK
     C           D1SUPP    ANDNEA9SUPP
     C                     ITER
     C                     ENDIF
     C**
     C                     EXSR #OUTF1
     C**
E1   C                     ENDDO
      *-------------------------
     C           @FAST     IFEQ '*'
     C                     MOVE '*'       @@UMU
     C                     WRITEAGFWP101
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *(AFDPL25) OUTGOING ORDER FILE
      *===============================================================
     C           #AFD25    BEGSR
     C           KEY01     SETLLAFDPL25
     C                     MOVE ' '       @FAST
      *-------------------------
S1   C                     DO   *HIVAL
     C           KEY01     READEAFDPL25                  91
     C   91                LEAVE
     C*
     C           AFSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           D1KARA    IFNE 0
     C           D1MADE    ORNE 0
     C           AFODHZ    IFLT D1KARA
     C           AFODHZ    ORGT D1MADE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1SUPP    IFNE *BLANK
     C           D1SUPP    ANDNEAFSUPP
     C                     ITER
     C                     ENDIF
     C**
     C                     EXSR #OUTF2
     C**
E1   C                     ENDDO
      *-------------------------
     C           @FAST     IFEQ '*'
     C                     EXSR #LOTNO
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *(AFDPL23) OUTGOING ORDER FILE
      *===============================================================
     C           #AFD23    BEGSR
     C           KEY02     SETLLAFDPL23
     C                     MOVE ' '       @FAST
      *-------------------------
S1   C                     DO   *HIVAL
     C                     READ AFDPL23                  91
     C   91                LEAVE
     C           AFODHZ    IFGT D1MADE
     C                     LEAVE
     C                     ENDIF
     C*
     C           AFSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           D1SUPP    IFNE *BLANK
     C           D1SUPP    ANDNEAFSUPP
     C                     ITER
     C                     ENDIF
     C**
     C                     EXSR #OUTF2
     C**
E1   C                     ENDDO
      *-------------------------
     C           @FAST     IFEQ '*'
     C                     EXSR #LOTNO
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *(AFAPP90) ORDER ACTUAL FILEから
      *===============================================================
     C           #OUTF1    BEGSR
      *
      *
     C           A9PAR1    IFEQ W9PAR1
     C           A9PAR2    ANDEQW9PAR2
     C           A9PAR3    ANDEQW9PAR3
     C           A9ODNO    ANDEQW9ODNO
     C           A9ODHZ    ANDEQW9ODHZ
     C           A9ODBB    ANDEQ$$ODBB
     C           A9SUPP    ANDEQW9SUPP
     C           A9NOHZ    ANDEQW9NOHZ
     C           A9ZETI    ANDEQW9ZETI
     C           A9TEHI    ANDEQW9TEHI
     C                     ADD  A9HAKO    W9HAKO
     C                     ADD  A9NOSU    W9NOSU
     C                     ELSE
     C*
     C           @FAST     IFEQ '*'
     C                     WRITEAGFWP101
     C                     ENDIF
     C                     MOVE '*'       @FAST
     C                     CLEARAGFWP101
     C                     Z-ADDA9ODHZ    W9ODHZ           ORDER DATE
     C                     MOVELA9ODBB    W9ODBB                    BIN
     C                     MOVELA9ODBB    $$ODBB  20                BIN
     C                     MOVELA9PAR1    W9PAR1           INTERNAL PART1
     C                     MOVELA9PAR2    W9PAR2                   2
     C                     MOVELA9PAR3    W9PAR3                   3
     C                     MOVELA9SUPP    W9SUPP           SUPPLIER
     C                     Z-ADDA9ODNO    W9ODNO
     C                     MOVELA9ZETI    W9ZETI
     C                     MOVELA9TEHI    W9TEHI
     C                     Z-ADDA9SYOS    W9SYOS
     C                     Z-ADDA9NYHZ    W9NYHZ
     C                     Z-ADDA9NOHZ    W9NOHZ
     C                     EXSR #ADDRS
     C                     MOVEL@TKR      W9TKR
     C                     Z-ADDA9HAKO    W9HAKO
     C                     Z-ADDA9NOSU    W9NOSU
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *(AFDPP20) OUTGOING ORDER FILEから
      *===============================================================
     C           #OUTF2    BEGSR
     C           AFPAR1    IFEQ W9PAR1
     C           AFPAR2    ANDEQW9PAR2
     C           AFPAR3    ANDEQW9PAR3
     C           AFODNO    ANDEQW9ODNO
     C           AFODHZ    ANDEQW9ODHZ
     C           AFBINN    ANDEQ$9ODBB
     C           AFSUPP    ANDEQW9SUPP
     C           AFNOHZ    ANDEQW9NOHZ
     C                     ELSE
     C           @FAST     IFEQ '*'
     C                     EXSR #LOTNO
     C                     ENDIF
     C                     MOVE '*'       @FAST
      *
     C                     CLEARAGFWP101
     C                     Z-ADDAFODHZ    W9ODHZ           ORDER DATE
     C                     MOVELAFBINN    $9ODBB  3                 BIN
     C                     MOVELAFBINN    W9ODBB    P               BIN
     C                     MOVELAFPAR1    W9PAR1           INTERNAL PART1
     C                     MOVELAFPAR2    W9PAR2                   2
     C                     MOVELAFPAR3    W9PAR3                   3
     C                     MOVELAFSUPP    W9SUPP           SUPPLIER
     C                     Z-ADDAFODNO    W9ODNO
     C                     MOVELAFZETI    W9ZETI
     C                     Z-ADDAFSYOS    W9SYOS
     C                     Z-ADDAFNYHZ    W9NYHZ
     C                     Z-ADDAFNOHZ    W9NOHZ
     C                     EXSR #ADDRS
     C                     MOVEL@TKR      W9TKR
     C                     Z-ADD0         W9HAKO
     C                     Z-ADD0         W9NOSU
     C                     MOVELAFAKI2    W9NOBB
     C                     ENDIF
      ******************
     C                     ENDSR
      *===============================================================
      *      LEVELLED PTODUCTION FICD ORDERING FILE READ   *
      *===============================================================
     C           #ADDRS    BEGSR
     C           KEY03     KLIST
     C                     KFLD           W9PAR1           INTERNAL PART1
     C                     KFLD           W9PAR2                   2
     C                     KFLD           W9PAR3                   3
     C*
     C                     MOVE *BLANK    @TKR    9
     C*
     C           KEY03     CHAINAGAPL31              92
     C  N92      CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     92
     C                     ENDIF
     C*
     C           *IN92     IFEQ *OFF
     C           CBKDAI    CASEQ'C'       #SBKBC           AAFTL06
     C           CBKDAI    CASEQ'E'       #SBKBD           AAHTL06
     C                     ENDCS
     C                     ENDIF
     C*
     C                     ENDSR
      *----------------------------------------------------*
      *  PLATING KANBAN                                    *
      *----------------------------------------------------*
     C           #SBKBC    BEGSR
     C           KEY03     SETGTAAFTL061
     C                     MOVE *BLANK    @TKR
      *
S1   C                     DO   *HIVAL
     C           KEY03     REDPEAAFTL061                 95
     C   95                LEAVE
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C           A3STHZ    IFGE *DATE
     C                     MOVE A3ATK1    WKATK1
     C                     MOVE A3ATK2    WKATK2
     C                     MOVE A3ATK3    WKATK3
     C                     MOVE A3ATK4    WKATK4
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVE '-'       WKF3
     C                     MOVE WKATKR    @TKR
     C                     LEAVE
     C                     ENDIF
E1   C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PART WITHDRAWAL  KANBNAN                          *
      *----------------------------------------------------*
     C           #SBKBD    BEGSR
     C           KEY03     SETGTAAHTL061
     C                     MOVE *BLANK    @TKR
      *
S1   C                     DO   *HIVAL
     C           KEY03     REDPEAAHTL061                 95
     C   95                LEAVE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C           L6STHZ    IFGE *DATE
     C                     MOVE L6ATK1    WKATK1
     C                     MOVE L6ATK2    WKATK2
     C                     MOVE L6ATK3    WKATK3
     C                     MOVE L6ATK4    WKATK4
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVE '-'       WKF3
     C                     MOVE WKATKR    @TKR
     C                     LEAVE
     C                     ENDIF
E1   C                     ENDDO
      *
     C                     ENDSR
      *===============================================================
      *シリアル＃（ＬＯＴ＃）                                        *********
      *===============================================================
     C           #LOTNO    BEGSR
     C           KEY04     KLIST
     C                     KFLD           W9SUPP           SUPPLIER
     C                     KFLD           W9ODYY           ORDER DATE YYYY
     C                     KFLD           W9ODMM           MM
     C                     KFLD           W9ODDD           DD
     C                     KFLD           $9ODBB
     C                     MOVEL*BLANK    W9SHMK           SHP
     C                     MOVEL*BLANK    W9TEH2           TEHAI NO.
     C                     MOVEL*BLANK    W9PAGE           PAGE NO.
     C                     Z-ADD0         W9QTY            QTY/CONT.
     C                     MOVEL*BLANK    LT               LOT#
     C                     Z-ADD0         Z       30
     C                     MOVEL*BLANK    @TH              手配№
     C                     Z-ADD0         @SU              箱数
     C*
     C           KEY04     SETLLAFDPL10
      *-------------------------
      *-------------------------
S1   C                     DO   *HIVAL
     C           KEY04     READEAFDPL10                  95
     C   95                LEAVE
 S2  C           ADSKJY    IFNE *BLANK
     C                     ITER
 E2  C                     ENDIF
      *
 S2  C           ADSUPP    IFEQ '5555'
     C           W9PAR1    IFEQ ADPAR1
     C           W9PAR2    ANDEQADPAR2
     C           W9PAR3    ANDEQADPAR3
     C                     ELSE
     C                     ITER
     C                     ENDIF
 E2  C                     ENDIF
     C*
 S2  C           ADSUPP    IFEQ '3111'
     C           ADSUPP    OREQ '3222'
     C                     MOVELADTAIS    W@TICD
     C                     MOVELADSYUK    W@YUKO
     C                     MOVELADHKOS    W@HASY
     C                     MOVELW@LOT#    W9TEHI
 X2  C                     ELSE
     C                     MOVELADTEHI    W9TEHI
 E2  C                     ENDIF
     C                     Z-ADD1         X       30
     C           W9TEHI    LOKUP@TH,X                    50手配№
     C           *IN50     IFEQ *OFF
     C                     ADD  1         Z
     C                     MOVELW9TEHI    @TH,Z            手配№
     C                     Z-ADD1         @SU,Z            箱数
     C                     ELSE
     C                     ADD  1         @SU,X            箱数
     C                     ENDIF
      *
E1   C                     ENDDO
      *-------------------------
     C           Z         IFNE 0
     C                     DO   Z         X
     C           @SU,X     IFNE 0                          箱数
     C                     MOVEL@TH,X     W9TEHI
     C                     MOVEL@TH,X     W9TEH2
     C                     Z-ADD@SU,X     W9HAKO
     C                     MOVE '*'       @@UMU
     C                     WRITEAGFWP101
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
