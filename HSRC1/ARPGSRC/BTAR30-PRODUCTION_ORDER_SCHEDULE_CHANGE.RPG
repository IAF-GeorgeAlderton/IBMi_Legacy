      *
     C                     Z-ADD*ZERO     @@LT
     C           1         DO   15        A       30
      *
     C           NCKQ,A    IFEQ 'C'
     C           NCKQ,A    OREQ 'D'
     C           NCKQ,A    OREQ 'E'
     C           NCKQ,A    OREQ '0'
     C                     MOVELNCKQ,A    KAN     1
