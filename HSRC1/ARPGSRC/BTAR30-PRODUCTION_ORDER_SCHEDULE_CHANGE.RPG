     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@LOC2    ANDNE*BLANK
      *
     C                     MOVE *OFF      *IN34
     C                     Z-ADD*ZERO     D@SAVD
      * WASHER
     C                     EXSR #SET13
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN2      IFNE *ZERO
     C                     Z-ADD1         @@P     20
     C                     EXSR #SSET
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
