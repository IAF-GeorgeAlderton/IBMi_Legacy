     C           D@CAL     CAT  '+':1     D@CAL     P
     C           D@CAL     CAT  @@DD:1    D@CAL     P
     C           D@CAL     CAT  '+':1     D@CAL     P
     C           D@CAL     CAT  @@EE:1    D@CAL     P
     C           D@CAL     CAT  '+':1     D@CAL     P
     C           D@CAL     CAT  @@FF:1    D@CAL     P
     C           D@CAL     CAT  '+':1     D@CAL     P
     C           D@CAL     CAT  @@GG:1    D@CAL     P
     C           D@CAL     CAT  '+':1     D@CAL     P
     C           D@CAL     CAT  @@HH:1    D@CAL     P
     C           D@CAL     CAT  ') =':1   D@CAL     P
