     C                     Z-ADD1         @@P
     C                     ELSE
     C                     EXSR #SSET
     C                     ENDIF
      * NEXT PAGE
     C           *INKI     WHEQ *ON
     C                     ADD  1         @@P
     C           @@P       IFGT 4
     C                     Z-ADD4         @@P
     C                     ELSE
     C                     EXSR #SSET
     C                     ENDIF
      * SAVE
     C           *INKD     WHEQ *ON
     C                     EXSR #CHK2
     C                     EXSR #SAV
     C                     MOVE '01'      W@ID
      * LIST
     C           *INKK     WHEQ *ON
