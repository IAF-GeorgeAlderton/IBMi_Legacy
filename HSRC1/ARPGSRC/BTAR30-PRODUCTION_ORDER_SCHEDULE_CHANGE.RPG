     C                     MOVE *OFF      *IN53
      *
     C                     Z-ADD@@REC     #RCNO2
      *
     C                     SELEC
      * END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      * GO BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
      * DETAIL
     C           *INKJ     WHEQ *ON
     C                     EXSR #CHK2
     C                     EXSR #CUR
      * PRV PAGE
     C           *INKH     WHEQ *ON
