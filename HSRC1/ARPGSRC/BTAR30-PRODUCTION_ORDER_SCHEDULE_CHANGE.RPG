     C           @@RRN     CHAINSFL02                90
     C           *IN90     IFEQ *OFF
      *
     C                     Z-ADD@Q        Q       20
     C                     Z-ADD*ZERO     NW
     C                     Z-ADD*ZERO     QT
     C           1         DO   5         X
     C                     ADD  1         Q
     C                     Z-ADDQX,Q      QT,X
     C                     Z-ADDNX,Q      NW,X
     C                     ENDDO
     C                     UPDATSFL02
     C                     ENDIF
     C                     ENDDO
