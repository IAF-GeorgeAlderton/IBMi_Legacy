     C                     ENDSR
      *------------------------------------------------------
      *  CALCULATE SCHEDULE QTY
      *------------------------------------------------------
     C           #CALX2    BEGSR
      *
     C           S@BDAY    MULT 5         @@B5    30
     C                     MOVE S@BDAY    @2      2
     C           @2        IFNE '00'
     C                     ADD  1         @@B5
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     QX
     C           H@AA      SUB  S@B       S@ANS
     C                     SUB  S@D       S@ANS
     C                     SUB  H@EE      S@ANS
     C                     SUB  H@GG      S@ANS
     C                     SUB  H@HH      S@ANS
     C                     Z-ADDS@ANS     @@BOX   30
      *
     C           @@BOX     IFLE *ZERO
     C                     Z-ADD@@BOX     QX,1
     C                     ELSE
     C           @@B5      IFNE *ZERO
     C                     Z-ADD*ZERO     X
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           @@BOX     IFGT @@B5
     C                     ADD  @@B5      QX,X
     C                     ELSE
     C                     ADD  @@BOX     QX,X
     C                     LEAVE
     C                     ENDIF
      *
     C                     SUB  @@B5      @@BOX
     C           X         IFEQ 20
     C                     Z-ADD*ZERO     X
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
