     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
      *
     C           K#GD      KLIST
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
     C                     KFLD           K@Y     40
     C                     KFLD           K@M     20
      *
     C           K#GDG     KLIST
     C                     KFLD           ICODER
     C                     KFLD           ICITEM
      *
     C                     Z-ADD*YEAR     K@Y
     C           *MONTH    SUB  2         K@M
     C           K@M       IFLE *ZERO
     C                     ADD  12        K@M
     C                     SUB  1         K@Y
     C                     ENDIF
      *
     C                     Z-ADD*DATE     W@YMD
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADD*ZERO     D@D
     C                     MOVE '01'      W@ID    2
      *
     C                     Z-ADD*ZERO     W@DY    30
     C                     Z-ADD*DATE     K@YMD
     C           K#AGDX    SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#AGDX    READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         W@DY
     C                     ENDIF
     C                     ENDDO
      *
     C                     EXSR #SET0
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET 1ST SCREEN
      *------------------------------------------------------
     C           #SET0     BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     DO   50
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE '1'       S@LOC1
     C                     MOVE '0'       S@LOC4
     C                     MOVE '**'      S@LOC3
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN2      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     MOVE *BLANK    LOC
     C                     Z-ADD*ZERO     X
      *
      * DATE CHECK
     C                     Z-ADDD@DATE    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C           *IN90     OREQ *OFF
     C           D@DATE    ANDLE*DATE
     C  N99                MOVE ER,3      D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN91
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVE *OFF      *IN63
     C           S@LOC2    IFNE *BLANK
      *
     C           S@LOC1    IFEQ *BLANK
     C  N99                MOVE ER,4      D@MSG
     C                     SETON                     9963
     C                     ENDIF
     C           S@LOC4    IFEQ *BLANK
     C  N99                MOVE ER,4      D@MSG
     C                     SETON                     9963
     C                     ENDIF
     C           S@LOC3    IFEQ *BLANK
     C  N99                MOVE ER,4      D@MSG
     C                     SETON                     9963
     C                     ENDIF
      * DUPLICATE CHECK
     C           S@LOC     LOKUPLOC                      10
     C           *IN10     IFEQ *ON
     C  N99                MOVE ER,5      D@MSG
     C                     SETON                     9963
     C                     ELSE
     C                     ADD  1         X
     C                     MOVE S@LOC     LOC,X
     C                     ENDIF
      *
     C           *IN63     IFEQ *OFF
     C                     MOVE *ON       *IN91
     C                     ENDIF
     C                     ENDIF
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN91     IFEQ *OFF
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,61
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     Z-ADD*ZERO     RRN2
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
      * SET CALENDAR
     C                     EXSR #DAT2
      *
     C                     Z-ADD1         #RCNO2
      *
     C                     MOVE *BLANK    PRT
     C                     Z-ADD*ZERO     Z       30
     C                     Z-ADD*ZERO     @@RRN
