      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C           KEY1      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C           KEY2      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C                     KFLD           WKYM
      *
     C           KEY3      KLIST
     C                     KFLD           @KYY
     C                     KFLD           @KMM
      *
     C*----------------------------------------------------*
     C*                   １画面                         *
     C*----------------------------------------------------*
      *
     C           STP1      TAG
     C                     MOVE *BLANK    @KYY
     C                     MOVE *BLANK    @KMM
     C                     MOVE *BLANK    @HIN
      *
     C           STP2      TAG
     C                     Z-ADD0         #PH
     C                     Z-ADD0         #MH
     C                     MOVE *BLANK    #ZM
     C                     MOVE *BLANK    @HOL
     C                     EXFMTBTAPW061
     C                     SETOF                     010203
     C                     SETOF                     04
     C                     SETOF                     99
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *------------*
      *計画予定日*
      *------------*
     C           @KYY      IFLT 1994
     C           @KMM      ORLT 1
     C           @KMM      ORGT 12
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     MOVEL@KYY      WKYM    60
     C                     MOVE @KMM      WKYM
     C                     MOVEL*YEAR     WUKYM   60
     C                     MOVE UMONTH    WUKYM
      *------*
      *品番*
      *------*
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     SETON                     0399
     C                     MOVELER,4      MSG
     C                     GOTO STP2
     C                     END
      *-------------------------------*
      *平準化ファイルにあればエラー *
      *-------------------------------*
     C           KEY1      CHAINAGAPL311             90
     C           *IN90     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C                     SETON                     90
     C                     END
     C           *IN90     IFEQ '0'
     C                     SETON                     0399
     C                     MOVELER,10     MSG
     C                     GOTO STP2
     C                     END
      *----------------------------*
      *部品マスター／品番チェック*
      *----------------------------*
     C                     Z-ADD0         WSYOS   60
      *
     C                     SETOF                     03
     C           KEY1      CHAINFCEPL011             03
     C           *IN03     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
     C           *IN03     IFEQ '0'
      *収容数
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    WSYOS
     C                     ELSE
     C                     Z-ADDA2SSYS    WSYOS
     C                     END
     C                     ELSE
      *
     C                     SETOF                     03
     C           KEY1      CHAINAKCPL011             03
     C           *IN03     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
      *
     C           *IN03     IFEQ '0'
      *収容数
     C           M1SYHZ    IFGT *DATE
     C                     Z-ADDM1KSYS    WSYOS
     C                     ELSE
     C                     Z-ADDM1SSYS    WSYOS
     C                     END
     C                     ELSE
      *
     C                     SETON                     99
     C                     MOVELER,5      MSG
     C                     GOTO STP2
     C                     END
     C                     END
      *
     C           KEY1      SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           KEY1      READEAAPTL01                  90
     C           *IN90     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STHZ    ANDEQ99999999
     C                     Z-ADDL5SYOS    WSYOS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *----------------------------------*
      *ＰＴ計画発行受注ファイル*
      *----------------------------------*
     C                     SETOF                     98
     C           KEY2      CHAINBTAPL051             98
      *
     C           *IN98     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,6      MSG
     C                     GOTO STP2
     C                     END
      *
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,7      MSG
     C                     GOTO STP2
     C                     END
      *
      *計画予定日
     C                     MOVE '  .  '   @KYM
     C                     MOVEL@KYYX     @KYM
     C                     MOVE @KMM      @KYM
      *品番
     C                     MOVE '-'       WH1
     C                     MOVE '-'       WH2
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WH2
     C                     END
      *収容数
     C                     Z-ADDWSYOS     @SYUSU
     C*青山カレンダーチェック
     C                     EXSR $HOLI
      *
     C*----------------------------------------------------*
     C*                   ２画面                         *
     C*----------------------------------------------------*
     C*画面罫線
     C                     BITOF'01234567'X00     1
     C                     MOVE X00       X2F     1
     C                     BITON'24567'   X2F
     C                     MOVE 'F'       KBFR
      *
     C                     WRITEBTAPW064
     C                     WRITEBTAPW063
      *
     C           STP4      TAG
     C                     EXFMTBTAPW062
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     101112
     C                     SETOF                     131415
     C                     SETOF                     161718
     C                     SETOF                     192021
     C                     SETOF                     222324
     C                     SETOF                     252627
     C                     SETOF                     282930
     C                     SETOF                     3199
      *
     C           *INKC     IFEQ '1'
     C                     GOTO STP1
     C                     END
      *
     C                     GOTO STP4
     C*****************************************************************
     C*         青山カレンダーチェック
     C*****************************************************************
     C           $HOLI     BEGSR                                      $
      *
     C*休日'*XX*'
     C                     MOVEA'00000000'*IN,41
     C                     MOVEA'00000000'*IN,49
     C                     MOVEA'00000000'*IN,57
     C                     MOVEA'0000000' *IN,65
     C                     MOVE *BLANK    @HOL
     C                     Z-ADD*ZERO     WDY
     C                     MOVE *BLANK    EXC
      *
     C                     Z-ADD0         N       20
     C                     Z-ADD1         A       20
     C           KEY3      SETLLAGDPL121
     C           1         DO   31        A
     C                     SETOF                     80
     C           KEY3      READEAGDPL121                 80
     C           *IN80     IFEQ '0'
     C                     Z-ADDF8YOBI    WDY,A
     C           F8YMD     IFEQ 20031223
     C                     MOVE '1'       EXC,A
     C                     ENDIF
      *
     C                     MOVE *BLANK    WHOL
     C                     MOVELA         WHH23
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       WHH1
     C                     MOVE '*'       WHH4
     C                     END
     C           WHH2      IFEQ '0'
     C                     MOVE *BLANK    WHH2
     C                     END
     C                     MOVE WHOL      @HOL,A
     C                     END
     C                     END
      *
     C* 今日以前は入力禁止
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
      *
 %001C***        WDY,A     IFNE 3
     C***        EXC,A     ANDEQ*BLANK
     C***                  MOVE '1'       *IN,N
 %001C***                  ENDIF
      *
     C           WKYM      IFEQ WUKYM
     C           A         IFLE UDAY
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     MOVE @HOL,A    WHOL
     C           WHH1      IFEQ '*'
     C                     MOVE '1'       *IN,N
     C                     END
     C           WHH23     IFEQ *BLANK
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C           WKYM      IFLT WUKYM
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     ENDSR
      *
