     H            Y.
     F** UTLR06 ********************************************
     F*  PROGRAM: UTILITY - GET COUNTRY OF ORIGIN          *
     F*  WRITTEN: JW (SRA)                                 *
     F*           04/19/2016                               *
JW1  F*  JW       06/22/2016 CHG AB#PP55 TO AB#PL57        *
     F*                      CHG AB#PL55 TO AB#PL56        *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR06'
JW1  F*                    PARM           $CGRP   3
     F*                    PARM           $PART  20
     F*                    PARM           $PNONY  4
     F*                    PARM           $PTYP   1
     F*                    PARM           $CO     3
     F*                    PARM           $RTN    1
     F*  IN  $CGRP  :  3A CUSTOMER GROUP (HND:HONDA, HND<>:OTHER THAN HONDA)
     F*      $PART  : 20A IAF OR USER PART#
     F*      $PNONY :  4A DELIVERY CODE (BLANK=ALL)
     F*      $PTYP  :  1A PART# TYPE (I:IAF PART, I<>:USER PART)
     F*  OUT $CO    :  3A COUNTRY OF ORIGIN
     F*      $RTN   :  1A RETURN CODE (BLANK/*)
     F******************************************************
     F**   AB#PP55 IF  E           K        DISK
     F**   AB#PL55 IF  E           K        DISK
JW1  FAB#PL57 IF  E           K        DISK
JW1  FAB#PL56 IF  E           K        DISK
     F            AB#PP551                          KRENAMEAB#PL561
      *--------------------------------------------------------
     E                    DAT        10  1
     I            DS
     I                                        1  20 WHIN
     I                                        1   5 WHIN1
     I                                        6  10 WHIN2
     I                                       11  15 WHIN3
     I                                       11  12 WHIN3I
     I                                       16  20 WHIN4
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR @INIT
     C                     SELEC
      * GET FROM IAF  PART ----------------------------
     C           $PTYP     WHEQ 'I'
     C                     MOVE *OFF      *IN91
     C                     MOVEL$PART     WHIN
     C                     MOVEL$PNONY    K5NONY
     C**JW1      KEY1      CHAINAB#PP55              91
JW1  C           KEY1      CHAINAB#PL57              91
     C           *IN91     IFEQ *OFF
     C                     MOVELA5EDIC    $CO
     C                     GOTO @END
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN91
     C                     MOVEL$PART     WHIN
     C                     Z-ADD0         K5NONY
     C*JW1       KEY1      CHAINAB#PP55              91
JW1  C           KEY1      CHAINAB#PL57              91
     C           *IN91     IFEQ *OFF
     C                     MOVELA5EDIC    $CO
     C                     GOTO @END
     C                     ENDIF
      * GET FROM CUSTOMER PART -----------------------
     C                     OTHER
     C                     MOVE *OFF      *IN91
     C                     MOVEL$PART     WHIN
     C                     MOVEL$PNONY    K5NONY
     C**         KEY2      CHAINAB#PL55              91
JW1  C           KEY2      CHAINAB#PL56              91
     C           *IN91     IFEQ *OFF
     C                     MOVELA5EDIC    $CO
     C                     GOTO @END
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN91
     C                     MOVEL$PART     WHIN
     C                     Z-ADD0         K5NONY
     C**         KEY2      CHAINAB#PL55              91
JW1  C           KEY2      CHAINAB#PL56              91
     C           *IN91     IFEQ *OFF
     C                     MOVELA5EDIC    $CO
     C                     GOTO @END
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $CGRP   3
     C                     PARM           $PART  20
     C                     PARM           $PNONY  4
     C                     PARM           $PTYP   1
     C                     PARM           $CO     3
     C                     PARM           $RTN    1
      *
     C           KEY1      KLIST
JW1  C                     KFLD           @CGRP
     C                     KFLD           WHIN1
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3I
     C                     KFLD           K5NONY
      *
     C           KEY2      KLIST
JW1  C                     KFLD           @CGRP
     C                     KFLD           WHIN1
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3
     C                     KFLD           WHIN4
     C                     KFLD           K5NONY
      *
     C           *LIKE     DEFN A5NONY    K5NONY
      *
     C                     MOVEL'US'      $CO
     C                     CLEAR$RTN
      *
     C           $CGRP     IFNE 'HND'
     C                     MOVE 'TYT'     $CGRP
     C                     ENDIF
JW1  C                     MOVEL$CGRP     @CGRP   3
      *
     C                     ENDSR
