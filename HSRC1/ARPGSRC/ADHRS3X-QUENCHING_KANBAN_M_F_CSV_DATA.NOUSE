     C  N96                EXCPTOHED
     C                     SETON                     96
JW1   * SET KANBAN TYPE
 |   C                     MOVEL*BLANK    J6SS   14
     C                     SELEC
     C           J6SSKB    WHEQ '1'
     C                     MOVELSS1       J6SS
     C           J6SSKB    WHEQ '2'
     C                     MOVELSS2       J6SS
     C           J6SSKB    WHEQ '3'
     C                     MOVELSS3       J6SS
