      *================================================================
      * .. PART INFORMATION M/F   *.
      *================================================================
     C           #FCE      BEGSR
      *
     C           FCEKEY    CHAINFCEPL01              55
     C           *IN55     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     SETON                     55
     C                     END
     C                     END
      *設定数
     C                     Z-ADD0         W@GEKN
     C                     Z-ADD0         O@TANJ  72
     C           *IN55     IFEQ '0'
     C           A2GEKN    DIV  20        W@GEKN  90
     C           J6HKKB    IFEQ 'S'
     C                     Z-ADDA2SOZI    O@TANJ
     C                     ENDIF
     C           J6HKKB    IFEQ 'K'
     C                     Z-ADDA2KASI    O@TANJ
     C                     ENDIF
     C                     ENDIF
     C*
     C*  BOX/DAY
     C                     Z-ADDA2SSYS    W2SSYS  50
     C           A2SYHZ    IFGT *DATE
     C           A2KSYS    ANDNE0
     C                     Z-ADDA2KSYS    W2SSYS  50
     C                     ENDIF
     C*
     C           W@GEKN    DIV  W2SSYS    O@BXPD  51H
     C*
      *内示
      *社内品番で各月内示の合計を求める。
     C                     MOVELO@HIN1    P$HIN1  5
     C                     MOVELO@HIN2    P$HIN2  5
     C                     MOVELO@HIN3    P$HIN3  2
     C                     EXSR #NAIJI
     C                     Z-ADDP$NNNM    P@NNNM 100
     C                     Z-ADDP$1NNM    P@1NNM 100
     C                     Z-ADDP$2NNM    P@2NNM 100
     C                     Z-ADDP$NTYM    P@NTYM  60
     C                     Z-ADDP$TNSU    P@TNSU 100
     C                     Z-ADDP$GOKE    P@GOKE  80
      *
      *構成部品使用実績チェック
      *         親品番がある時は、親品番の内示を集計する
     C           FCEKEY    SETLLMCENP13
     C                     MOVE ' '       $$ZERO  1
     C                     DO   *HIVAL
     C           FCEKEY    READEMCENP13                  77
     C   77                LEAVE
     C           $$ZERO    IFEQ ' '
     C                     Z-ADD0         P@NNNM
     C                     Z-ADD0         P@1NNM
     C                     Z-ADD0         P@2NNM
     C                     Z-ADD0         P@TNSU
     C                     Z-ADD0         P@GOKE
     C                     MOVE '*'       $$ZERO
     C                     ENDIF
     C                     MOVELMCSHN1    P$HIN1  5
     C                     MOVELMCSHN2    P$HIN2  5
     C                     MOVELMCSHN3    P$HIN3  2
     C                     EXSR #NAIJI
     C                     ADD  P$NNNM    P@NNNM
     C                     ADD  P$1NNM    P@1NNM
     C                     ADD  P$2NNM    P@2NNM
     C                     Z-ADDP$NTYM    P@NTYM           内示月度
     C                     ADD  P$TNSU    P@TNSU
     C                     ADD  P$GOKE    P@GOKE
     C                     ENDDO
      *
     C           KEY2      KLIST
     C                     KFLD           O@HIN1
     C                     KFLD           O@HIN2
     C                     KFLD           O@HIN3
     C                     KFLD           J6ATOK
     C                     KFLD           J6ATOB
     C                     KFLD           J6ATK1
     C                     KFLD           J6ATK2
     C                     KFLD           J6ATK3
     C                     KFLD           J6ATK4
      *
     C                     MOVELJ6ATK2    CHKT    1
     C           $$ZERO    IFEQ ' '
     C           CHKT      ANDEQ'R'
     C           KEY2      SETLLGHCPL221
     C                     DO   *HIVAL
     C           KEY2      READEGHCPL221                 77
     C   77                LEAVE
     C*
     C           $$ZERO    IFEQ ' '
     C                     Z-ADD0         P@NNNM
     C                     Z-ADD0         P@1NNM
     C                     Z-ADD0         P@2NNM
     C                     Z-ADD0         P@TNSU
     C                     Z-ADD0         P@GOKE
     C                     MOVE '*'       $$ZERO
     C                     ENDIF
     C                     MOVELMMJHN1    P$HIN1  5
     C                     MOVELMMJHN2    P$HIN2  5
     C                     MOVELMMJHN3    P$HIN3  2
     C                     EXSR #NAIJI
     C                     ADD  P$NNNM    P@NNNM
     C                     ADD  P$1NNM    P@1NNM
     C                     ADD  P$2NNM    P@2NNM
     C                     Z-ADDP$NTYM    P@NTYM           内示月度
     C                     ADD  P$TNSU    P@TNSU
     C                     ADD  P$GOKE    P@GOKE
     C                     ENDDO
     C                     ENDIF
      *
      *内示月度
     C                     MOVELP@NTYM    F@NTYM
     C                     CALL 'AGDRS1'
     C                     PARM           F@NTYM  6
     C                     PARM           F@DAYS  2
     C                     MOVE F@DAYS    F#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@NTYM    F@NTMM  2
     C***        F@NTMM    IFEQ '07'
     C***                  SUB  5         F#DAYS
     C***                  END
JW2   * 2020/04 SPECIAL
 |   C           F#DAYS    IFEQ 0
 |   C           P@NTYM    ANDEQ202004
 |   C                     Z-ADD22        F#DAYS
JW2  C                     ENDIF
      *
     C           P@NNNM    DIV  F#DAYS    F@NNNM 100
      * N/N+1/N+2を求める
     C                     CALL 'ABBRSD'
     C                     PARM           F@NTYM
     C                     PARM           F@N1
     C                     PARM           F@N2
      * N+1の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N1    6
     C                     PARM           F@DAY1  2
     C                     MOVE F@DAY1    F#DAY1  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N1      F@N1MM  2
     C***        F@N1MM    IFEQ '07'
     C***                  SUB  5         F#DAY1
     C***                  END
      *
     C           P@1NNM    DIV  F#DAY1    F@1NNM 100
      * N+2の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N2    6
     C                     PARM           F@DAY2  2
     C                     MOVE F@DAY2    F#DAY2  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N2      F@N2MM  2
     C***        F@N2MM    IFEQ '07'
     C***                  SUB  5         F#DAY2
     C***                  END
      *
     C           P@2NNM    DIV  F#DAY2    F@2NNM 100
      *実績月度
     C                     CALL 'MCEC00'
     C                     PARM           R@DATE  8
     C                     MOVELR@DATE    R@YYMM  6
      *実績月度の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           R@YYMM  6
     C                     PARM           R@DAYS  2
     C                     MOVE R@DAYS    R#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE R@YYMM    R@MM    2
     C***        R@MM      IFEQ '07'
     C***                  SUB  5         R#DAYS
     C***                  END
      *
     C           P@GOKE    DIV  R#DAYS    R@GOKE  80
      *重量換算
     C           R@GOKE    MULT J6SOZI    W@KTJY 120H
     C           W@KTJY    DIV  1000      R@GOKJ  90H
      *
      *内示なし実績
     C           P@TNSU    DIV  R#DAYS    R@TNSU  80
      * N
     C                     ADD  R@TNSU    F@NNNM
      *重量換算
     C           F@NNNM    MULT J6SOZI    W@KTJY 120H
     C           W@KTJY    DIV  1000      F@NNNJ  90H
      * N+1
     C                     ADD  R@TNSU    F@1NNM
      *重量換算
     C           F@1NNM    MULT J6SOZI    W@KTJY 120H
     C           W@KTJY    DIV  1000      F@1NNJ  90H
      * N+2
     C                     ADD  R@TNSU    F@2NNM
      *重量換算
     C           F@2NNM    MULT J6SOZI    W@KTJY 120H
     C           W@KTJY    DIV  1000      F@2NNJ  90H
      *
     C                     EXSR #FCG
      *
     C                     MOVE A21HB5    K@CMP1
     C                     MOVE A22HB5    K@CMP2
     C                     MOVE A23HB2    K@CMP3
     C                     EXSR #CMP
     C                     Z-ADDEDHDSC    E#HDS1  83
     C                     Z-ADDED2SDS    E#2SD1  83
     C                     MOVE W@ENGN    W@ENG1 15
      *
     C                     MOVE A24HB5    K@CMP1
     C                     MOVE A25HB5    K@CMP2
     C                     MOVE A26HB2    K@CMP3
     C                     EXSR #CMP
     C                     Z-ADDEDHDSC    E#HDS2  83
     C                     Z-ADDED2SDS    E#2SD2  83
     C                     MOVE W@ENGN    W@ENG2 15
      *
     C                     EXSR #NEXT
      *
     C                     EXSR #PRE
      *
     C           EFCE      ENDSR
      *================================================================
      *  FACILITY MANAGEMENT M/F設備管理マスター
      *================================================================
     C           #MFA      BEGSR
      *
     C                     Z-ADD0         W@KADO 100
      *
     C           MFAKEY    KLIST
     C                     KFLD           W@BMON
     C                     KFLD           W@KBN
     C                     KFLD           W@AKT
      *
     C           MFAKEY    SETLLMFAPL25
     C                     DO   *HIVAL
     C           MFAKEY    READEMFAPL25                  44
     C   44                LEAVE
     C           M@SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
      *
     C                     Z-ADD0         T#OUTS 100
     C                     Z-ADD0         T#HOUR 100
     C                     Z-ADD0         T#RPMH  60
      *
     C           *IN44     IFEQ '1'
     C                     MOVE *BLANK    M@KGUN
     C                     MOVE *BLANK    M@KEIS
     C                     Z-ADD0         M@RPMH
     C                     GOTO EMFA
     C                     END
      *実績月度
     C                     CALL 'MCEC00'
     C                     PARM           R@DATE  8
      *
     C                     MOVE R@DATE    T#SDAT
     C                     MOVE '01'      T#SDAT
     C                     MOVE R@DATE    T#EDAT
     C                     MOVELW@KBN     T#KIBN
     C                     CALL 'MTARS1'
