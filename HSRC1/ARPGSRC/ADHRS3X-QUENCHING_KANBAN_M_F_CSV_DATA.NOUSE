     C                     MOVELPOKIBN    @@KIBN
     C**         POBMON    IFNE *BLANK
     C**         POBMON    ANDNE'0111'
     C**                   MOVE POBMON    N@BMON  40
     C**         N@BMON    CHAINFGBPL01              65
     C**N65                MOVELB2SMEI    @@KIBN
     C**                   END
      *
     C                     ENDSR
      *================================================================
      *  ..製品図面　情報マスター（最新のみ）
      *================================================================
     C           #CMP      BEGSR
      *
     C                     MOVE *BLANK    W@ENGN 15
      *
     C           CMPKEY    KLIST
     C                     KFLD           K@CMP1  5
     C                     KFLD           K@CMP2  5
     C                     KFLD           K@CMP3  2
     C           CMPKEY    SETGTFCGPP05
     C           CMPKEY    REDPEFCGPP05                  75
     C   75                Z-ADD0         EDHDSC
     C   75                Z-ADD0         ED2SDS
     C   75                GOTO ECMP
      *
     C           FCGKKK    KLIST
     C                     KFLD           EDSHP1
     C                     KFLD           FCGKY1  1
     C                     KFLD           FCGKY2  1
      *
     C                     MOVE '4'       FCGKY1
     C                     MOVE EDSHP4    FCGKY2
     C           FCGKKK    CHAINFCGPP41              76
     C           *IN76     IFEQ '0'
     C                     MOVELE@ENGN    W@ENGN
     C                     END
      *
     C           ECMP      ENDSR
      *================================================================
      *社内品番で各月内示の合計を求める。
      *================================================================
     C           #NAIJI    BEGSR
      * P@TNSU:内示がなかった納入先の実績
     C                     CALL 'ABBRS6'
     C                     PARM           P$HIN1  5
     C                     PARM           P$HIN2  5
     C                     PARM           P$HIN3  2
     C                     PARM           P$N2NM 100
     C                     PARM           P$N1NM 100
     C                     PARM           P$NNNM 100
     C                     PARM           P$1NNM 100
     C                     PARM           P$2NNM 100
     C                     PARM           P$NTYM  60
     C                     PARM           P$TNSU 100
      *実績
     C                     CALL 'MBERS1'
     C                     PARM           P$HIN1  5
     C                     PARM           P$HIN2  5
     C                     PARM           P$HIN3  2
     C                     PARM           P$GOKE  80
     C                     ENDSR
      *================================================================
      *  SEARCH COMMON PART
      *================================================================
     C           #GHC      BEGSR
      *
     C           BANKEY    KLIST
     C                     KFLD           J6ATK1
     C                     KFLD           J6ATK2
     C                     KFLD           J6ATK3
     C                     KFLD           J6ATK4
      *
     C           BANKEY    SETLLGHCTL21
     C                     DO   *HIVAL
     C           BANKEY    READEGHCTL21                  77
     C   77                LEAVE
     C           J6SHN1    IFEQ MDJHN1
     C           J6SHN2    ANDEQMDJHN2
     C           J6SHN3    ANDEQMDJHN3
     C                     ITER
     C                     END
      *
     C                     MOVE MDJHN1    O@HIN1
     C                     MOVE MDJHN2    O@HIN2
     C                     MOVE MDJHN3    O@HIN3
     C                     EXSR #FCE
     C   55                GOTO EGHC
JW3   *
      *
     C                     EXCPTODAT
      *
     C                     ENDDO
      *
     C           EGHC      ENDSR
