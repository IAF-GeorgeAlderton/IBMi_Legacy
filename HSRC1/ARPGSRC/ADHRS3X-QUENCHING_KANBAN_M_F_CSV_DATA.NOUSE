     C           J6SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     ENDIF
      *
     C           J6SBIN    IFNE 99
     C                     GOTO @END
     C                     ENDIF
      *
     C           J6SYOS    IFEQ 0
     C                     GOTO @END
     C                     ENDIF
      *
     C*****      J6KTSU    DIV  20        W@KTSU  90
JW3   * GET SET# FRM AAFPP01
 |   C                     MOVELJ6SHIN    $SHN
 |   C                     CALL 'UTLR68B'
 |   C                     PARM           $SHN   12
 |   C                     PARM           $SET#   9
 |   C                     PARM           $RTNX   1
 |   C           $RTNX     IFEQ ' '
 |   C                     MOVEL$SET#     W@KTSU
 |   C                     ELSE
 |   C           J6KSSU    DIV  20        W@KTSU  90
JW3  C                     ENDIF
      *
     C           W@KTSU    DIV  J6SYOS    O@BXPD  51
      *日当り重量
     C           W@KTSU    MULT J6SOZI    W@KTJY 120H
     C           W@KTJY    DIV  1000      O@KTJY  90H
      *
     C                     SETOF                     66
      *
     C                     MOVE J6SHN1    P@HIN1  5
     C                     MOVE J6SHN2    P@HIN2  5
     C                     MOVE J6SHN3    P@HIN3  2
     C                     MOVE *BLANK    P@BAN1  1
     C                     MOVE *BLANK    P@BAN2  2
     C                     MOVE *BLANK    P@BAN3  2
     C                     MOVE *BLANK    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'OQ '     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
      *
     C           AAMRS9    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@BMON  4
     C                     PARM           P@KOTE  3
     C                     PARM           P@KIBN  3
     C                     PARM           P@KHIN 12
      *
     C           P@BMON    IFEQ *BLANK
     C                     MOVE *BLANK    P@BAN1  1
     C                     MOVE *BLANK    P@BAN2  2
     C                     MOVE *BLANK    P@BAN3  2
     C                     MOVE *BLANK    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'LOQ'     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
      *
     C           P@BMON    IFEQ *BLANK
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE *BLANK    P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     ENDIF
     C                     ENDIF
      *****
     C                     MOVE P@BMON    W@BMON  40
     C                     MOVE P@KOTE    W@AKT   3
     C                     MOVE P@KIBN    W@KBN   3
