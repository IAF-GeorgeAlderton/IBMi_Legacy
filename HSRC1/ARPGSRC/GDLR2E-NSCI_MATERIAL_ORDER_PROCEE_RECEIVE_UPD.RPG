     I                                        1   60LBKOTM
     I                                        1   20LBKOHH
     I                                        3   40LBKOSS
     I            DS
     I                                        1   80LBODHZ
     I                                        1   40LBODRY
     I                                        5   60LBODRM
     I                                        7   80LBODRD
     I            DS
     I                                        1  10 W@DTDT
     I                                        1   20GDDTMM
     I I            '/'                       3   3 W@DTAA
     I                                        4   50GDDTDD
     I I            '/'                       6   6 W@DTBB
     I                                        7  100GDDTYY
      *=====================================================
     C                     TIME           W@TIME
     C*
     C                     EXSR #CTL20
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=====================================================
      * SCREEN
      *=====================================================
     C           #CTL20    BEGSR
      *
     C                     EXSR #SET20
     C                     Z-ADD1         W#RNP2  40
      *
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     LEAVE
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD
     C                     LEAVE
     C                     OTHER
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*-----------------------------------------------------           ********
     C*
     C*-----------------------------------------------------           *********
     C           #SET20    BEGSR
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C           1         SETLLGDLWP2D
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GDLWP2D                  99
     C   99                LEAVE
     C*
     C                     CLEARSFL020
     C*
     C                     MOVELW@DTDT    S2PODT
     C                     MOVELGDZAIS    S2ZAIS
     C                     Z-ADDGDZAIK    S2ZAIK
     C                     MOVELGDTYPE    S2TYPE
     C                     MOVELGDHEAT    S2HEAT
     C                     Z-ADDGDWHT     S2WHT
     C                     MOVELGDM#      S2M#
     C                     MOVELGDCIL#    S2C#
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL020
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     SETON                     49
     C                     CLEARSFL020
     C                     Z-ADD1         RRN2
     C                     WRITESFL020
     C                     MOVELEMSG,2    MSG
     C                     END
     C*
     C                     ENDSR
     C*=====================================================
     C* UPDATE
     C*=====================================================
     C           #UPD      BEGSR
     C*
     C           1         SETLLGDLWP2D
      *
     C                     DO   *HIVAL
     C*
     C                     READ GDLWP2D                  98
     C   98                LEAVE
     C*
     C           K#QP01    KLIST
     C                     KFLD           K@M#    7
     C                     KFLD           K@C#    3
     C                     MOVELGDM#      K@M#
     C                     MOVELGDCIL#    K@C#
     C           K#QP01    SETLLGDLQP02
     C*
     C                     DO   *HIVAL
     C           K#QP01    READEGDLQP02                  97
     C   97                LEAVE
     C           GQSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN97     IFEQ *OFF
     C                     EXSR @DLT
     C                     END
     C*
     C                     EXSR @ADD
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C*  DELETE PREV INFO
     C*-----------------------------------------------------
     C           @DLT      BEGSR
     C*
     C                     DO
     C*
     C           K#L14A    KLIST
     C                     KFLD           GQZAIS
     C                     KFLD           GQZAIK
     C                     KFLD           GQDTYY
     C                     KFLD           GQDTMM
     C                     KFLD           GQDTDD
     C*
     C                     DO   *HIVAL
     C*
     C           K#L14A    READEGDLPL14                  89
     C   89                LEAVE
     C           LBSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           LBSIRE    IFNE 4530
     C                     ITER
     C                     END
      *
     C           LBREMA    IFGT *ZERO
     C                     SUB  1         LBREMA
     C           LBREMA    IFLE *ZERO
     C                     Z-ADD*ZERO     LBREYY
     C                     Z-ADD*ZERO     LBREMM
     C                     Z-ADD*ZERO     LBREDD
     C                     END
     C                     END
     C*
     C                     Z-ADDW@DY      LBKOYY
     C                     Z-ADDW@DM      LBKOMM
     C                     Z-ADDW@DD      LBKODD
     C                     Z-ADDW@TH      LBKOHH
     C                     Z-ADDW@TM      LBKOSS
     C                     MOVEL#USER     LBKOME
     C*
     C                     UPDATGDLPP101
     C                     LEAVE
     C*
     C                     ENDDO
     C   89                LEAVE
     C*
     C                     MOVEL'D'       GQSKJY
     C                     Z-ADDW@DY      GQSKYY
     C                     Z-ADDW@DM      GQSKMM
     C                     Z-ADDW@DD      GQSKDD
     C                     Z-ADDW@THMS    GQSKTM
     C                     MOVEL#USER     GQSKME
     C                     UPDATGDLQP021
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*
     C*-----------------------------------------------------
     C*  ADD NEW INFO
     C*-----------------------------------------------------
     C           @ADD      BEGSR
     C*
JW2  C                     MOVE *BLANK    XXSTAT  3
     C                     DO
     C*
     C           K#L14B    KLIST
     C                     KFLD           GDZAIS
     C                     KFLD           GDZAIK
     C                     KFLD           GDDTYY
     C                     KFLD           GDDTMM
     C                     KFLD           GDDTDD
     C           K#L14B    SETLLGDLPL14
     C*
     C                     DO   *HIVAL
     C*
     C           K#L14B    READEGDLPL14                  89
JW2  C   89                MOVE 'NOT'     XXSTAT
     C   89                LEAVE
     C           LBSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           LBSIRE    IFNE 4530
     C                     ITER
     C                     END
      *
     C                     ADD  1         LBREMA
     C                     Z-ADDW@DY      LBREYY
     C                     Z-ADDW@DM      LBREMM
     C                     Z-ADDW@DD      LBREDD
     C*
     C                     Z-ADDW@DY      LBKOYY
     C                     Z-ADDW@DM      LBKOMM
     C                     Z-ADDW@DD      LBKODD
     C                     Z-ADDW@TH      LBKOHH
     C                     Z-ADDW@TM      LBKOSS
     C                     MOVEL#USER     LBKOME
     C*
     C                     UPDATGDLPP101
JW2  C                     MOVE 'UPD'     XXSTAT
     C                     LEAVE
     C*
     C                     ENDDO
JW2  C** 89                LEAVE
     C*
     C                     CLEARGDLQP021
     C                     Z-ADDW@DY      GQKOYY
     C                     Z-ADDW@DM      GQKOMM
     C                     Z-ADDW@DD      GQKODD
     C                     Z-ADDW@THMS    GQKOTM
     C                     MOVEL#USER     GQKOME
     C                     MOVE '4530'    GQKOME
     C*
     C                     Z-ADDGDDTYY    GQDTYY
     C                     Z-ADDGDDTMM    GQDTMM
     C                     Z-ADDGDDTDD    GQDTDD
     C                     Z-ADDLBODR1    GQODR1
     C                     Z-ADDLBODR2    GQODR2
     C                     Z-ADDLBODR3    GQODR3
     C                     MOVELGDZAIS    GQZAIS
     C                     Z-ADDGDZAIK    GQZAIK
     C                     MOVELGDTYPE    GQTYPE
     C                     MOVELGDHEAT    GQHEAT
     C                     Z-ADDGDWHT     GQWHT
     C                     MOVELGDM#      GQM#
     C                     MOVELGDCIL#    GQCIL#
     C                     Z-ADDW@DY      GQRCYY
     C                     Z-ADDW@DM      GQRCMM
     C                     Z-ADDW@DD      GQRCDD
     C                     Z-ADDW@THMS    GQRCTM
     C*
JW2  C                     Z-ADDTODAY     GQCRHZ
 .   C                     Z-ADDNOW       GQCRTM
 .   C                     MOVEL#PGM      GQCRPG
 .   C                     MOVEL#WSID     GQCRWS
 .   C                     MOVEL#USER     GQCRUS
JW2  C                     MOVELXXSTAT    GQSTAT
     C*
     C                     WRITEGDLQP021
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*
