     H            Y.
     F** CHKR25   **************************************************************
     F*  PROGRAM    : FIX EDIPP42 (SET UP E4NNY2)                              *
     F*  WRITTEN    : 07/27/2017                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   :                                                          *
     F**************************************************************************
     FEDIPP42 UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      * -------------------------------------
     E                    ZN      1  51  3   ZNC     3
      * -------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **************************************************************************
     C                     EXSR #INIT
      *
     C           *IN98     DOWEQ*OFF
     C                     READ EDIPP42                  98
     C           *IN98     IFEQ *OFF
     C                     MOVE *BLANK    XMSG
      * -------------------------------------
     C           E4CNT     IFEQ 'US '
     C                     MOVEL'USA'     E4CNT
     C                     ENDIF
      * -------------------------------------
     C           E4CNT     IFEQ 'MX '
     C                     MOVEL'MEX'     E4CNT
     C                     ENDIF
      * -------------------------------------
     C           E4NNY2    IFEQ 0
     C                     ADD  1         CNT
     C                     MOVEL'* NONY=0'XMSG
     C                     EXSR #PRINT
     C                     MOVELE4NONY    E4NNY2
     C                     ENDIF
      * -------------------------------------
     C           E4TMZN    IFEQ *BLANK
     C           E4CNT     ANDEQ'USA'
     C                     Z-ADD1         IX
     C                     MOVELE4STCD    LTR3    3
     C           LTR3      LOKUPZN,IX                    99
     C           *IN99     IFEQ *ON
     C                     MOVELZNC,IX    E4TMZN
     C                     ENDIF
     C                     ENDIF
      * -------------------------------------
     C           E4GRP2    IFEQ *BLANK
     C           E4GRP     IFEQ 'FRD'
     C           E4GRP     OREQ 'TYT'
     C           E4GRP     OREQ 'SIA'
     C           E4GRP     OREQ 'AIS'
     C                     MOVELE4GRP     E4GRP2
     C                     ENDIF
     C                     ENDIF
      * -------------------------------------
      *
     C           UPDFLG    IFEQ 'Y'
     C                     UPDATEDIPP421
     C                     ENDIF
      * -------------------------------------
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           UPDFLG  1
      *
     C                     Z-ADD0         CNT     40
     C                     MOVE *BLANK    XMSG   30
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD0         IX      20
      *
     C                     EXCPT@HDR
      *
     C           EINIT     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   60 '** UPDATE EDIPP42 **    '
     O                                   99 'DATE'
     O                         @DATE    102 '    .  .  '
     O                         @TIME    112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   02           @HDR
     O                                    5 'SEQ#'
     O                                   12 'DELV1'
     O                                   18 'DELV2'
     O                                   28 'ERROR MSG'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         E4NONY  +002
     O                         E4NNY2  +002
     O                         XMSG    +002
** ZN,
AL CST        1
AK AST        2
AR CST        3
AZ MST        4
CA PST        5
CO MST        6
CT EST        7
DE EST        8
DC EST        9
FL EST       10
GA EST       11
