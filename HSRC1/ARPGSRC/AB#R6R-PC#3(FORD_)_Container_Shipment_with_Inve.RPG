     C           #SFL02    BEGSR
      *
     C                     Z-ADD0         RRN2
     C                     MOVEL'Y'       FIRST   1
     C           *LOVAL    SETLLAB#WL6V
     C                     DO   *HIVAL
     C                     READ AB#WL6V             N    90
     C   90                LEAVE
      * UNSCAN ONLY?
     C**         D@SCAN    IFEQ ' '
     C**         P6UNS     ANDEQ0
     C**                   ITER
     C**                   ENDIF
      * SELECT SHORTAGE?
     C           D@APCS    IFEQ '1'
     C                     MOVELP6SHN1    K#SHN1
     C                     MOVELP6SHN2    K#SHN2
     C                     MOVELP6SHN3    K#SHN3
     C           K#P6V2    CHAINAB#WP6V3             99
     C           *IN99     IFEQ *OFF
     C           P7APCS    ANDEQ'N'
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * SELECT DAYS?
     C           D@DAYS    IFNE *BLANK
     C                     MOVELP6SHN1    K#SHN1
     C                     MOVELP6SHN2    K#SHN2
     C                     MOVELP6SHN3    K#SHN3
     C           K#P6V2    CHAINAB#WP6V3             99
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           D@DAYS    WHEQ '1'
     C           P7DAYS    ANDGT1.0
     C                     ITER
     C           D@DAYS    WHEQ '2'
     C           P7DAYS    ANDGT2.0
     C                     ITER
     C           D@DAYS    WHEQ '3'
     C           P7UNS     ANDLEP7INV
     C                     ITER
     C                     ENDSL
