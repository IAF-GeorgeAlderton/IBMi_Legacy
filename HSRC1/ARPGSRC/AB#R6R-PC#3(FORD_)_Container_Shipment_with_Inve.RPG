     O                                   42 '/'
     O                         D@DD      44
     O                                   84 '--'
     O                                   87 '--'
     O                                   90 '--'
     O                                   93 '--'
     O                                   96 '--'
A    O        E   04           @HED
A    O                                   60 '--INSPECTION--'
A    O                                   80 '  ------------ LAST '
A    O                                  100 'PROCESS ------------'
     O        E   05           @HED
     O                                    5 'SEQ#'
     O                                   10 'LOC'
     O                                   21 'IAF_PART#'
     O                                   34 'UNSCAN'
     O                                   44 'INV/DAY'
     O                                   52 'SRT#'
     O                                   60 'SORT'
     O                                   69 'PRC/MCN'
     O                                   79 'AFTER'
     O                                   91 'INPROCESS'
     O                                  100 ' BEFORE'
     O                                  110 'CNV_PULL'
     O        E 11             @DTL
     O                         SEQ#  3 +001
