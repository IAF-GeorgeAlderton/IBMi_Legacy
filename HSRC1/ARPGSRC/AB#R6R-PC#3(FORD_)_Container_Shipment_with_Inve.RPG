      *--------------------------------------------------
     C           #SCRN2    BEGSR
      * CLEAR SFL01
     C           RSFLG1    IFEQ 'Y'
     C                     MOVE *ON       *IN71
     C                     WRITECTL01
     C                     MOVE *OFF      *IN71
     C                     MOVE *OFF      *IN72
      * SET SFL01
     C                     EXSR #SFL01
     C           RNMAX1    IFEQ 0
     C                     SETON                     61  85
     C                     MOVEL'01'      @@ID
     C                     MOVELERR,09    D@MSG
     C                     GOTO XSCRN2
     C                     ELSE
     C                     MOVE 'N'       RSFLG1
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE CMX,3     D@CMD
     C                     WRITEDSP98
     C                     Z-ADDW@REC3    #RCNO3
     C                     EXFMTCTL01
      *
     C           @@REC     IFNE 0
     C                     Z-ADD@@REC     W@REC3  40
     C                     ELSE
     C                     Z-ADD1         W@REC3
     C                     END
      *
     C                     SELEC
      * <F1:END>
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * <F12:BACK>
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
      * <ENTER>
     C                     OTHER
     C                     MOVE '03'      @@ID
     C                     Z-ADD1         W@REC#
     C                     ENDSL
      *
     C           XSCRN2    ENDSR
      *--------------------------------------------------
      * SET DATA IN SFL01
      *--------------------------------------------------
     C           #SFL01    BEGSR
      *
     C                     Z-ADD0         RRN1
     C                     MOVEL'Y'       FIRST   1
     C           *LOVAL    SETLLAB#WP6V
     C           *IN90     DOUEQ*ON
     C                     READ AB#WP6V             N    90
     C   90                LEAVE
      * UNSCAN ONLY?
     C**         D@SCAN    IFEQ ' '
     C**         P6UNS     ANDEQ0
     C**                   ITER
     C**                   ENDIF
      * SELECT SHORTAGE
     C           D@APCS    IFEQ '1'
     C                     MOVELP6SHN1    K#SHN1
     C                     MOVELP6SHN2    K#SHN2
     C                     MOVELP6SHN3    K#SHN3
     C           K#P6V2    CHAINAB#WP6V3             99
     C           *IN99     IFEQ *OFF
     C           P7APCS    ANDEQ'N'
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * SELECT DAYS
     C           D@DAYS    IFNE *BLANK
     C                     MOVELP6SHN1    K#SHN1
     C                     MOVELP6SHN2    K#SHN2
     C                     MOVELP6SHN3    K#SHN3
     C           K#P6V2    CHAINAB#WP6V3             99
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           D@DAYS    WHEQ '1'
     C           P7DAYS    ANDGT1.0
     C                     ITER
     C           D@DAYS    WHEQ '2'
     C           P7DAYS    ANDGT2.0
     C                     ITER
     C           D@DAYS    WHEQ '3'
     C           P7UNS     ANDLEP7INV
     C                     ITER
     C                     ENDSL
     C                     ENDIF
     C                     ENDIF
     C* FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDP6NONY    SVNONY  40
     C                     Z-ADD0         SVTBOX  70
     C                     Z-ADD0         SVUNS   70
     C                     ENDIF
      * BREAK?
     C           P6NONY    IFNE SVNONY
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     ADD  P6TBOX    SVTBOX
     C                     ADD  P6UNS     SVUNS
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     Z-ADDRRN1      RNMAX1  40
     C                     Z-ADD1         RRN1
      *
     C           RRN1      IFEQ 0
     C                     CLEARSFL01
     C                     MOVELERR,9     S1NAME
     C                     WRITESFL01
     C                     MOVEL*ON       *IN98
     C                     END
      *
     C                     ENDSR
      *--------------------------------------------------
      * BREAK SCREEN2 (SFL01)
      *--------------------------------------------------
     C           #BRK1     BEGSR
      * CHECK UNSCAN ONLY
     C           D@SCAN    IFEQ *BLANK
     C           SVUNS     ANDNE0
     C           D@SCAN    OREQ '1'
     C                     Z-ADDSVNONY    S1NONY
