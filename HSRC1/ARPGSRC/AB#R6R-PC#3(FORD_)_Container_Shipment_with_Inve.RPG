     C                     Z-ADDSVTBOX    S1TBOX
     C                     Z-ADDSVUNS     S1UNS
     C                     ADD  SVTBOX    D@TBOX
     C                     ADD  SVUNS     D@UNS
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      * RESET
     C                     Z-ADDP6NONY    SVNONY
     C                     Z-ADD0         SVTBOX
     C                     Z-ADD0         SVTBOX
     C                     Z-ADD0         SVUNS
      *
     C                     ENDSR
