     C                     ENDIF
     C* FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELP6MHN1    SVMHN1  5
     C                     MOVELP6MHN2    SVMHN2  5
     C                     MOVELP6MHN3    SVMHN3  5
     C                     MOVELP6MHN4    SVMHN4  5
     C                     MOVELP6SHN1    SVSHN1  5
     C                     MOVELP6SHN2    SVSHN2  5
     C                     MOVELP6SHN3    SVSHN3  2
     C                     Z-ADD0         SVINV   70
     C                     Z-ADD0         SVUNS   70
     C                     Z-ADD0         SVTBOX  70
     C                     ENDIF
      * BREAK?
     C           P6MHN1    IFNE SVMHN1
     C           P6MHN2    ORNE SVMHN2
     C           P6MHN3    ORNE SVMHN3
     C           P6MHN4    ORNE SVMHN4
     C           P6SHN1    ORNE SVSHN1
     C           P6SHN2    ORNE SVSHN2
     C           P6SHN3    ORNE SVSHN3
     C                     EXSR #BRK2
     C                     ENDIF
      * PROCESS
     C                     ADD  P6TBOX    SVTBOX
     C                     ADD  P6UNS     SVUNS
     C                     MOVELP6LOC     SVLOC   9
     C                     ENDDO
      * LAST BREAK --------
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK2
     C                     ENDIF
      *
     C                     Z-ADDRRN2      RNMAX2  40
     C                     Z-ADD1         RRN2
      *
     C           RRN2      IFEQ 0
     C                     CLEARSFL02
     C                     MOVEL'** NO'   S2MHN1
     C                     MOVEL' DATA'   S2MHN2
     C                     MOVEL' **  '   S2MHN3
     C                     WRITESFL02
     C                     MOVEL*ON       *IN98
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------
      * BREAK SCREEN3 (SFL02)
      *--------------------------------------------------
     C           #BRK2     BEGSR
      *
      * CHECK UNSCAN ONLY
     C           D@SCAN    IFEQ *BLANK
     C           SVUNS     ANDNE0
     C           D@SCAN    OREQ '1'
      *
     C                     MOVE *BLANK    S2SLCT
     C                     MOVELSVMHN1    S2MHN1
     C                     MOVELSVMHN2    S2MHN2
     C                     MOVELSVMHN3    S2MHN3
     C                     MOVE *BLANK    S2BMON
     C                     Z-ADDSVUNS     S2UNS
     C                     Z-ADDSVINV     S2INV
     C                     Z-ADDSVTBOX    S2TBOX
     C                     MOVELSVSHN1    S@SHN1
     C                     MOVELSVSHN2    S@SHN2
     C                     MOVELSVSHN3    S@SHN3
     C                     MOVELSVLOC     S@LOC
      * GET DAYS
     C                     MOVELSVSHN1    K#SHN1
     C                     MOVELSVSHN2    K#SHN2
     C                     MOVELSVSHN3    K#SHN3
     C           K#P6V2    CHAINAB#WP6V3             99
     C           *IN99     IFEQ *ON
     C                     Z-ADD0         P7INV
     C                     Z-ADD0         P7DAYS
     C                     ENDIF
     C                     Z-ADDP7INV     S2INV
     C                     Z-ADDP7DAYS    S2DAYS
      * GET BOX STUTUS
     C                     MOVELSVSHN1    P1SHN1
     C                     MOVELSVSHN2    P1SHN2
     C                     MOVELSVSHN3    P1SHN3
     C                     CALL 'ALOR28'                   GET PRIOTITY QTY
     C                     PARM           P1SHN1  5         IAF PART1        1
     C                     PARM           P1SHN2  5         IAF PART2        2
     C                     PARM           P1SHN3  2         IAF PART3        3
     C                     PARM 0         P9ALD3  40        SHIPPING SCANNED 4
     C                     PARM 0         P9ADA1  40        RE-ISSUE         5
     C                     PARM 0         P9NYKO  40        STOCK IN         6
     C                     PARM 0         P9SRT   40        SRT(CONVEYANCE)  7
     C                     PARM 0         P9OUK   40        OUTSRC AFTER     8
     C                     PARM 0         P9BZK   40        BZ AFTER         9
     C                     PARM 0         P9DSK   40        JC AFTER        10
     C                     PARM 0         P9JCK   40        DS AFTER        11
     C                     PARM 0         P9SBK   40        SB AFTER        12
     C                     PARM 0         P9LOQK  40        LOQ AFTERSING   13
     C                     PARM 0         P9OUI   40        OUTSRC IN PROC  14
     C                     PARM 0         P9BZI   40        BZ IN PROCESS   15
     C                     PARM 0         P9DSI   40        JC IN PROCESS   16
     C                     PARM 0         P9JCI   40        DS IN PROCESS   17
     C                     PARM 0         P9SBI   40        SB IN PROCESS   18
     C                     PARM 0         P9LOQI  40        LOQ IN PROCESS  19
     C                     PARM 0         P9PLOU  40        OUTSRC BEFORE   20
     C                     PARM 0         P9PLBZ  40        BZ BEFORE       21
     C                     PARM 0         P9PLDS  40        DS BEFORE       22
     C                     PARM 0         P9PLJC  40        JC BEFORE       23
     C                     PARM 0         P9PLSB  40        SB BEFORE       24
     C                     PARM 0         P9PLLO  40        LOQ BRFORE      25
     C                     PARM 0         P9PRE   40        CV AFTER        26
     C                     PARM 0         P9CVS   40        CV BEFORE       27
     C                     PARM 0         P9LPLD  80        LAST PRE DATE   28
     C                     PARM 0         P9LPLT  60        TIME            29
     C                     PARM 0         P9ALL   40        # OF ISSUED     30
JW3   * P/T STATUS
"    C                     PARM 0         P9PLPD  80       PT BF OUT DATE   31
"    C                     PARM 0         P9PLPS  40       PT SHIP PRELOAD  32
      * SORT
     C                     Z-ADDP9SRT     S2SRT
      * AFTER
     C                     Z-ADDP9BZK     S2AF
     C                     ADD  P9JCK     S2AF
     C                     ADD  P9DSK     S2AF
     C                     ADD  P9SBK     S2AF
     C                     ADD  P9OUK     S2AF
     C                     ADD  P9LOQK    S2AF
      * IN PROCESS
     C                     Z-ADDP9BZI     S2IN
     C                     ADD  P9JCI     S2IN
     C                     ADD  P9DSI     S2IN
     C                     ADD  P9SBI     S2IN
     C                     ADD  P9OUI     S2AF
     C                     ADD  P9LOQI    S2AF
      * BEFORE
     C                     Z-ADDP9PLBZ    S2BF
     C                     ADD  P9PLDS    S2BF
     C                     ADD  P9PLJC    S2BF
     C                     ADD  P9PLSB    S2BF
     C                     ADD  P9PLOU    S2AF
     C                     ADD  P9PLLO    S2AF
      * PROCESS AFTER
     C                     MOVE *BLANK    H2PRC
     C                     SELEC
     C           P9BZK     WHNE 0
     C                     MOVEL'BZ  '    H2PRC
     C           P9JCK     WHNE 0
     C                     MOVEL'JC  '    H2PRC
     C           P9DSK     WHNE 0
     C                     MOVEL'DS  '    H2PRC
     C           P9SBK     WHNE 0
     C                     MOVEL'SB  '    H2PRC
     C           P9OUK     WHNE 0
     C                     MOVEL'--  '    H2PRC
     C           P9LOQK    WHNE 0
     C                     MOVEL'LOQ '    H2PRC
     C                     ENDSL
      * PROCESS IN
     C           H2PRC     IFEQ *BLANK
     C                     SELEC
     C           P9BZI     WHNE 0
     C                     MOVEL'BZ  '    H2PRC
     C           P9JCI     WHNE 0
     C                     MOVEL'JC  '    H2PRC
     C           P9DSI     WHNE 0
     C                     MOVEL'DS  '    H2PRC
     C           P9SBI     WHNE 0
     C                     MOVEL'SB  '    H2PRC
     C           P9OUI     WHNE 0
     C                     MOVEL'--  '    H2PRC
     C           P9LOQI    WHNE 0
     C                     MOVEL'LOQ '    H2PRC
     C                     ENDSL
     C                     ENDIF
      * PROCESS BEFORE
     C           H2PRC     IFEQ *BLANK
     C                     SELEC
     C           P9PLBZ    WHNE 0
     C                     MOVEL'BZ  '    H2PRC
     C           P9PLJC    WHNE 0
     C                     MOVEL'JC  '    H2PRC
     C           P9PLDS    WHNE 0
     C                     MOVEL'DS  '    H2PRC
     C           P9PLSB    WHNE 0
     C                     MOVEL'SB  '    H2PRC
     C           P9PLOU    WHNE 0
     C                     MOVEL'--  '    H2PRC
     C           P9PLLO    WHNE 0
     C                     MOVEL'LOQ '    H2PRC
     C                     ENDSL
     C                     ENDIF
      * CV PULL
     C                     Z-ADDP9PRE     S2CVP
     C**X                  ADD  P9CVS     S2CVP
      * TOTAL APICS
     C           S2INV     ADD  S2SRT     S2QTY
     C                     ADD  S2AF      S2QTY
     C                     ADD  S2IN      S2QTY
     C                     ADD  S2BF      S2QTY
     C                     ADD  S2CVP     S2QTY
      * GET TOTAL DAYS
     C           P7HAKO    IFEQ 0
     C                     Z-ADD0         NUM81
     C                     ELSE
     C           S2QTY     DIV  P7HAKO    NUM81     H
     C                     ENDIF
     C           NUM81     IFGE 100
     C                     Z-ADD99.9      S2TDYS
     C                     ELSE
     C                     Z-ADDNUM81     S2TDYS
     C                     ENDIF
      * REVERSE
     C           S2DAYS    IFLT 1.0
     C                     MOVE *ON       *IN39
     C                     MOVE *ON       HIN39
     C                     ELSE
     C                     MOVE *OFF      *IN39
     C                     MOVE *OFF      HIN39
     C                     ENDIF
      *
     C           S2TDYS    IFLT 2.0
     C                     MOVE *ON       *IN40
     C                     MOVE *ON       HIN40
     C                     ELSE
     C                     MOVE *OFF      *IN40
     C                     MOVE *OFF      HIN40
     C                     ENDIF
      *
     C           S2TDYS    IFLT 1.0
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       HIN41
     C                     ELSE
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      HIN41
     C                     ENDIF
      *
     C           S2UNS     IFGT S2INV
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       HIN42
     C                     ELSE
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      HIN42
     C                     ENDIF
JW1   * PART
 |   C                     MOVELS@SHIN    $SHIN
 |   C                     MOVE *BLANK    $DATE
 |   C                     CALL 'UTLR21B'
 |   C                     PARM           $SHIN  12
 |   C                     PARM           $DATE   8
 |   C                     PARM           $LLOC   6
 |   C                     PARM           $LQC    50
 |   C                     PARM           $LPRC   3
 |   C                     PARM           $LDPT   40
 |   C                     PARM           $LMCN   3
 |   C                     PARM           $ZETI   4
 |   C                     PARM           $MQTY   90
 |   C                     PARM           $RTN    1
 |   C           $RTN      IFEQ *BLANK
 |   C           $LDPT     ANDNE0111
 |   C                     MOVE *ON       *IN43
 |   C                     MOVE *ON       HIN43
 |   C                     ELSE
 |   C                     MOVE *OFF      *IN43
 |   C                     MOVE *OFF      HIN43
JW1  C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
      * RESET ------
     C                     MOVELP6MHN1    SVMHN1
     C                     MOVELP6MHN2    SVMHN2
     C                     MOVELP6MHN3    SVMHN3
     C                     MOVELP6MHN4    SVMHN4
     C                     MOVELP6SHN1    SVSHN1
     C                     MOVELP6SHN2    SVSHN2
     C                     MOVELP6SHN3    SVSHN3
     C                     Z-ADD0         SVINV
     C                     Z-ADD0         SVUNS
     C                     Z-ADD0         SVTBOX
      *
     C                     ENDSR
      *--------------------------------------------------
      * CHECK BIN#
      *--------------------------------------------------
     C           #CHKBN    BEGSR
      *
     C                     Z-ADD0         BCNT    10
     C           1         DO   5         IY      10
     C           BIN,IY    IFEQ WBIN
     C                     ADD  1         BCNT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------
      * SET PRINTER
      *---------------------------------------------------
     C           #PRSET    BEGSR
      *
     C                     MOVEL'QPRINT  '$FILE
     C                     CALL 'UTLC69'                   SELECT PRINTER
     C                     PARM           $FILE   8
     C                     PARM           $TEXT  40
      *
     C                     MOVEA$TEXT     ARY       P
     C                     MOVEL*BLANK    P@CMD
     C                     MOVEAARY       P@CMD
     C                     Z-ADD80        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
      *
     C                     OPEN QPRINT
     C                     EXSR #PRINT
     C                     CLOSEQPRINT
      *
     C                     ENDSR
      *---------------------------------------------------
      * GO TO LINK PROGRAM
      *---------------------------------------------------
     C           #LINK     BEGSR
      *
     C                     Z-ADD0         RRN2
     C**                   MOVE 'N'       @STOP   1
      *
     C                     DO   *HIVAL
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL02                91
     C   91                LEAVE
      *
     C           S2SLCT    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C**         @STOP     IFEQ 'N'
     C                     MOVE *BLANK    P@MODE
     C                     MOVELS@SHN1    P@HIN1
     C                     MOVELS@SHN2    P@HIN2
     C                     MOVELS@SHN3    P@HIN3
     C                     CALL 'AHBR02'                   APICS INQ
     C                     PARM           P@MODE  1
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C**                   ENDIF
      *
     C                     MOVE *BLANK    S2SLCT
     C                     MOVE HIN39     *IN39
     C                     MOVE HIN40     *IN40
     C                     MOVE HIN41     *IN41
     C                     MOVE HIN42     *IN42
JW1  C                     MOVE HIN43     *IN43
     C                     UPDATSFL02
     C                     LEAVE
     C**                   MOVE 'Y'       @STOP
      *
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------
     C           #PRINT    BEGSR
      *---------------------------------------------------
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD80        LIN#    30
     C                     Z-ADD0         RRN2
      *
     C                     DO   *HIVAL
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL02                90
     C   90                LEAVE
      *
     C                     MOVELS@LOC     P#LOC9
      *
     C                     MOVE S@SHN1    P#SHN1  5
     C           S@SHN2    IFNE *BLANK
     C                     MOVE '-'       P#SHNA  1
     C                     ELSE
     C                     MOVE *BLANK    P#SHNA
     C                     END
     C                     MOVE S@SHN2    P#SHN2  5
     C           S@SHN3    IFNE *BLANK
     C                     MOVE '-'       P#SHNB  1
     C                     ELSE
     C                     MOVE *BLANK    P#SHNB
     C                     END
     C                     MOVE S@SHN3    P#SHN3  2
      * GET SRT#
     C                     MOVELS@SHIN    $SHIN
     C                     CALL 'UTLR57'                   GET SRT#
     C                     PARM           $SHIN  12
     C                     PARM           $SRTN  20
     C                     PARM           $SRT#  20
     C                     PARM           $RTN    1
     C                     MOVEL$SRT#     P#SRT   6
      * GET MACHINE#
     C                     EXSR #MCN
     C                     MOVE *BLANK    P2PRC
      *
     C           PPRC      IFEQ 'TSL'
     C                     MOVELPPRCA     P2PRC1
     C                     MOVELPMCNA     P2PRC2
     C                     ELSE
     C                     MOVELPPRC      P2PRC1
     C                     MOVELPMCN      P2PRC2
     C                     ENDIF
      *
     C           PBMN      IFNE '0111'
     C                     MOVELPBNAM     P2PRC
     C                     ENDIF
      * CHECK INVENTORY
     C                     EXSR #AST
      * BIN
     C                     MOVE *BLANK    P@BIN1  2
     C                     MOVE *BLANK    P@BIN2  2
     C                     MOVE *BLANK    P@BIN3  2
     C                     MOVE *BLANK    P@BIN4  2
     C                     MOVE *BLANK    P@BIN5  2
     C           D@BIN1    IFNE 0
     C                     MOVELD@BIN1    P@BIN1
     C                     ENDIF
     C           D@BIN2    IFNE 0
     C                     MOVELD@BIN2    P@BIN2
     C                     ENDIF
     C           D@BIN3    IFNE 0
     C                     MOVELD@BIN3    P@BIN3
     C                     ENDIF
     C           D@BIN4    IFNE 0
     C                     MOVELD@BIN4    P@BIN4
     C                     ENDIF
     C           D@BIN5    IFNE 0
     C                     MOVELD@BIN5    P@BIN5
     C                     ENDIF
      * PRINT
     C           LIN#      IFGE 60
     C                     EXCPT@HED
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  2         LIN#
      *
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------
      * CGECK INVENTORY AND PUT * TO QTY
      *--------------------------------------------------
     C           #AST      BEGSR
      *
     C                     MOVE ' '       S2SRTX  1
     C                     MOVE ' '       S2AFX   1
     C                     MOVE ' '       S2INX   1
     C                     MOVE ' '       S2BFX   1
     C                     MOVE ' '       S2CVPX  1
     C           S2INV     SUB  S2UNS     WKINV   40
      *
     C           WKINV     IFLT 0
     C           S2SRT     ANDNE0
     C                     MOVE '*'       S2SRTX
     C                     ADD  S2SRT     WKINV
     C                     ENDIF
      *
     C           WKINV     IFLT 0
     C           S2AF      ANDNE0
     C                     MOVE '*'       S2AFX
     C                     ADD  S2AF      WKINV
     C                     ENDIF
      *
     C           WKINV     IFLT 0
     C           S2IN      ANDNE0
     C                     MOVE '*'       S2INX
     C                     ADD  S2IN      WKINV
     C                     ENDIF
      *
     C           WKINV     IFLT 0
     C           S2BF      ANDNE0
     C                     MOVE '*'       S2BFX
     C                     ADD  S2BF      WKINV
     C                     ENDIF
      *
     C           WKINV     IFLT 0
     C           S2CVP     ANDNE0
     C                     MOVE '*'       S2CVPX
     C                     ADD  S2CVP     WKINV
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------
      * GET MACHINE#
      *--------------------------------------------------
     C           #MCN      BEGSR
      *
     C                     MOVELS@SHN1    PSHIN1
     C                     MOVELS@SHN2    PSHIN2
     C                     MOVELS@SHN3    PSHIN3
     C                     MOVELP#LC1     W#LC1
     C                     MOVELP#LC2     W#LC2
     C                     MOVELP#LC3     W#LC3
     C                     MOVELP#LC4     W#LC4
     C                     MOVELW#LOC6    PLOC6
     C                     CALL 'UTLR15B'                  GET MACHINE
     C                     PARM           PSHIN1  5
     C                     PARM           PSHIN2  5
     C                     PARM           PSHIN3  2
     C                     PARM           PLOC6   6
     C                     PARM           PPRC1   3
     C                     PARM           PPRC    3
     C                     PARM           PMCN1   3
     C                     PARM           PMCN    3
     C                     PARM           PBMN1   4
     C                     PARM           PBMN    4
     C                     PARM           PBNAM  10
     C                     PARM           PPRCA   3
     C                     PARM           PMCNA   3
     C                     PARM           PBMNA   4
     C                     PARM           PRTN    1
      *
     C                     ENDSR
      *--------------------------------------------------
      * INITIAL PROCESS
      *--------------------------------------------------
     C           #INIT     BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           K#P6V2    KLIST
     C                     KFLD           K#SHN1  5
     C                     KFLD           K#SHN2  5
     C                     KFLD           K#SHN3  2
      *
     C                     MOVEL'01'      @@ID    2
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
     C                     TIME           @SDATE
     C                     CLEARDSP01
     C                     MOVEL#PGM      @PGM
     C                     Z-ADDTODAY     D@SHDT
     C                     MOVEL'C'       D@TYP
     C                     MOVE '01'      @@ID    2
     C                     MOVELCMX,5     D@MSG2
     C                     MOVE *ALL'_'   PLINE  75
     C           *LIKE     DEFN S2TBOX    W@TBOX
     C                     CLEARW@TBOX
     C                     CLEARW@LOC
      *
     C* ORDER DATE(START 1 MONTH BEFORE)
     C           K#AGDP    KLIST
     C                     KFLD           K@SYYY  40
     C                     KFLD           K@SMMM  20
     C                     KFLD           K@SDDD  20
     C                     Z-ADDWSSYYY    K@SYYY
     C                     Z-ADDWSSMMM    K@SMMM
     C                     Z-ADDWSSDDD    K@SDDD
     C                     SUB  1         K@SMMM
     C           K@SMMM    IFLE *ZERO
     C                     ADD  12        K@SMMM
     C                     SUB  1         K@SYYY
     C                     END
     C           K#AGDP    SETLLAGDPL12
     C                     DO   *HIVAL
     C                     READ AGDPL12                  94
     C           *IN94     IFEQ *ON
     C                     Z-ADDK@SYYY    F8KAYY
     C                     Z-ADDK@SMMM    F8KAMM
     C                     Z-ADDK@SDDD    F8KADD
     C                     LEAVE
     C                     END
     C           F8HIRU    IFEQ '*'
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
      *
     C                     OPEN AB#WP6V
     C                     OPEN AB#WL6V
     C                     OPEN AB#WP6V3
      *
     C                     ENDSR
      ***********************************************************
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                                   11 '('
     O                         D@SELN    20
     O                                   21 ')'
     O                                   31 '(PC#3)'
     O                                   50 'CONTAINER SHIPMENT'
     O                                   70 'WITH INVENTORY (FO'
     O                                   73 'RD)'
     O                         TODAY Y   90
     O                         NOW      100 '  :  :  '
     O                                  106 'PAGE'
     O                         PAGE  Z  110
     O        E   02           @HED
     O                                    9 'OPTION:'
     O                 35                23 '<SUM & DTL  >'
     O                N35                23 '<DETAIL ONLY>'
     O                 36                38 '<UNSCAN:ALL >'
     O                N36                38 '<UNSCAN:ONLY>'
     O                 37                55 '<SHORTAGE:ONLY>'
     O                N37                55 '<SHORTAGE:ALL >'
     O                         H@DAY     73
     O                                   81 'BIN#:'
     O                         P@BIN1    84
     O                         P@BIN2    87
     O                         P@BIN3    90
     O                         P@BIN4    93
     O                         P@BIN5    96
     O        E   03           @HED
     O                                   17 'SHIP DATE FROM:'
     O                         TODAY     28 '    /  /  '
     O                                   33 'TO:'
