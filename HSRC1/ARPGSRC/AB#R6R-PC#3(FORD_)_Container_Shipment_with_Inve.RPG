      *--------------------------------------------------
      *          MAIN ROUTINE
      *--------------------------------------------------
     C                     EXSR #INIT
      *
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1           DSP01
     C           @@ID      CASEQ'02'      #SCRN2           CTL01
     C           @@ID      CASEQ'03'      #SCRN3           CTL02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
      * DISPLAY 1ST SCREEN (PARAMETER ENTRY)
      *--------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVE *BLANK    D@MSG
     C                     SETOF                     616263
     C                     SETOF                     646566
     C                     SETOF                     67
     C                     SETOF                     85
      *
     C                     SELEC
      * <F1:END>
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
      * <ENTR>
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *ON
     C                     MOVEL'01'      @@ID
     C                     GOTO XSCRN1
     C                     ELSE
     C                     Z-ADD1         W@REC3
     C                     ENDIF
      * CREATE WF
     C                     EXSR #WF
      *
     C           *IN85     IFEQ *ON
     C                     MOVE '01'      @@ID
     C                     SETON                     61  85
     C                     MOVELERR,2     D@MSG
     C                     GOTO XSCRN1
     C                     ENDIF
      * IF NO ERROR,
     C           D@SUM     IFEQ *BLANK
     C                     MOVE '03'      @@ID
     C                     Z-ADD1         W@REC#
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     Z-ADD1         W@REC3
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           XSCRN1    ENDSR
      *--------------------------------------------------
      * CHECK IST SCREEN VALUE
      *--------------------------------------------------
     C           #CHK1     BEGSR
      * CHECK DATE TO
     C           D@SHDT    IFLT TODAY
     C                     SETON                     61  85
     C                     MOVELERR,5     D@MSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELD@SHDT    $SRC
     C                     CALL 'UTLR01'                   CHECK DATE
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN1   1
     C           $RTN1     IFNE *BLANK
     C                     SETON                     61  85
     C                     MOVELERR,5     D@MSG
     C                     GOTO XCHK1
     C                     ENDIF
     C* CHECK DATA TYPE
     C                     MOVEL*BLANK    D@SELN
     C                     SELEC
     C           D@TYP     WHEQ 'A'
     C                     MOVEL'A:IAF   'D@SELN    P
     C           D@TYP     WHEQ 'B'
     C                     MOVEL'B:OUTSRC'D@SELN
     C           D@TYP     WHEQ 'C'
     C                     MOVEL'C:TOTAL 'D@SELN    P
     C                     OTHER
     C                     SETON                     62  85
     C                     MOVELERR,1     D@MSG
     C                     GOTO XCHK1
     C                     ENDSL
      *
      * SET BIN FLAG (BINFLG: *OFF=ALL BLANK)
     C                     MOVE *OFF      BINFLG  1
     C           1         DO   5         IX      10
     C           BIN,IX    IFNE 0
     C                     MOVE *ON       BINFLG
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * CHECK BIN# DUPLICATED
     C           1         DO   5         IX
     C           BIN,IX    IFNE 0
     C                     Z-ADDBIN,IX    WBIN    20
     C                     EXSR #CHKBN
     C           BCNT      IFGE 2
     C                     SETON                     63  85
     C                     MOVELERR,3     D@MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C* CHECK SUMMARY
     C           D@SUM     IFNE *BLANK
     C           D@SUM     ANDNE'1'
     C                     SETON                     64  85
     C                     MOVELERR,6     D@MSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@SUM     IFEQ *BLANK
     C                     MOVE *OFF      *IN35
     C                     ELSE
     C                     MOVE *ON       *IN35
     C                     ENDIF
      * CHECK SCAN
     C           D@SCAN    IFNE *BLANK
     C           D@SCAN    ANDNE'1'
     C                     SETON                     65  85
     C                     MOVELERR,7     D@MSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@SCAN    IFEQ *BLANK
     C                     MOVE *OFF      *IN36
     C                     ELSE
     C                     MOVE *ON       *IN36
     C                     ENDIF
      *
     C* CHECK APICS SHORTAGE
     C           D@APCS    IFNE *BLANK
     C           D@APCS    ANDNE'1'
     C                     SETON                     66  85
     C                     MOVELERR,4     D@MSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           D@APCS    IFEQ *BLANK
     C                     MOVE *OFF      *IN37
     C                     ELSE
     C                     MOVE *ON       *IN37
     C                     ENDIF
     C* CHECK INVENTORY DAYS
     C           D@DAYS    IFNE *BLANK
     C           D@DAYS    ANDNE'1'
     C           D@DAYS    ANDNE'2'
     C           D@DAYS    ANDNE'3'
     C                     SETON                     67  85
     C                     MOVELERR,8     D@MSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     SELEC
     C           D@DAYS    WHEQ *BLANK
     C                     MOVELERR,10    H@DAY
     C           D@DAYS    WHEQ '1'
     C                     MOVELERR,11    H@DAY
     C           D@DAYS    WHEQ '2'
     C                     MOVELERR,12    H@DAY
     C           D@DAYS    WHEQ '3'
     C                     MOVELERR,13    H@DAY
     C                     ENDSL
      * IF NO ERROR,
     C                     MOVE 'Y'       RSFLG1  1        RESET FLAG1
     C                     MOVE 'Y'       RSFLG2  1        RESET FLAG2
     C                     Z-ADDWSSYYY    D@FRYY
     C                     Z-ADDWSSMMM    D@FRMM
     C                     Z-ADDWSSDDD    D@FRDD
     C                     Z-ADDD@YYYY    D@TOYY
     C                     Z-ADDD@MM      D@TOMM
     C                     Z-ADDD@DD      D@TODD
     C                     Z-ADDF8KAYY    D@OOYY
     C                     Z-ADDF8KAMM    D@OOMM
     C                     Z-ADDF8KADD    D@OODD
      *
     C           XCHK1     ENDSR
      *--------------------------------------------------
      * CREATE WF
      *--------------------------------------------------
     C           #WF       BEGSR
      *
     C                     Z-ADD0         D@TBOX
     C                     Z-ADD0         D@UNS
     C                     Z-ADD0         W@CCNT  50
     C                     Z-ADD0         W@UNS   50
     C                     Z-ADD0         W@TOKU  40
     C                     Z-ADD0         W@NONY  40
      * CLEAR AB#WP6V
     C                     CLOSEAB#WP6V
     C                     CLOSEAB#WL6V
     C                     MOVELCMD,2     P@CMD
     C                     Z-ADD80        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WP6V
     C                     OPEN AB#WL6V
      *
     C                     CLOSEAB#WP6V3
     C                     MOVELCMD,3     P@CMD
     C                     Z-ADD80        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WP6V3
      *
     C           K#KEY1    KLIST
     C                     KFLD           WSSYYY
     C                     KFLD           WSSMMM
     C                     KFLD           WSSDDD
      *
      * READ AB#PL12 -------------------------------------
     C           K#KEY1    SETLLAB#PL12
     C                     DO   *HIVAL
     C                     READ AB#PL12                  92
     C   92                LEAVE
      * END
     C           BANOHZ    IFGT D@SHDT
     C                     LEAVE
     C                     END
      * IGNORE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
      * CHECK BIN#
     C                     MOVE *OFF      *IN81
     C           BINFLG    IFEQ *ON
     C           1         DO   5         IX
     C           BIN,IX    IFNE 0
     C           BANOBN    ANDEQBIN,IX
     C                     MOVE *ON       *IN81
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           BINFLG    IFEQ *ON
     C           *IN81     ANDEQ*OFF
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELBANONY    WWNONY  4
      * CHECK FORD
     C**         WWNONY    LOKUPNONY                     95
     C**N95                ITER
JW4   * CHECK FORD GROUP
"    C           BANONY    CHAINABFDL05              95
"    C   95                ITER
      * CHECK DATA TYPE
     C           D@TYP     IFNE 'C'
     C           K#AAMP    KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C           K#AAMP    CHAINAAMPL11              94
     C   94                ITER
     C                     Z-ADD1         J       20
     C           0000      LOKUPNDPT,J                   80
     C  N80                ITER
JW2   * CHECK DEPT *
 |   C           D@TYP     IFEQ 'A'
 |   C                     MOVE 'Y'       OKFLG   1
 |   C                     ENDIF
 |   C           D@TYP     IFEQ 'B'
 |   C                     MOVE 'N'       OKFLG
 |   C                     ENDIF
JW2  C                     DO   *HIVAL
     C                     SUB  1         J
     C           J         IFEQ *ZERO
     C**                   ITER
JW2  C                     LEAVE
     C                     END
      *
     C                     SELEC
     C           D@TYP     WHEQ 'A'
     C           NDPT,J    IFNE 0111
JW2  C           NDPT,J    ANDNE8990
"    C                     MOVE 'N'       OKFLG
     C                     ITER
     C                     END
      *
     C           D@TYP     WHEQ 'B'
JW2  C           NDPT,J    IFNE 0111
"    C           NDPT,J    ANDNE8990
"    C                     MOVE 'Y'       OKFLG
     C                     ITER
     C                     END
     C                     ENDSL
      *
JW2  C                     ENDDO
 |    *
 |   C           OKFLG     IFEQ 'N'
 |   C                     ITER
JW2  C                     ENDIF
     C                     ENDIF
      * CHECK FCEPP01
     C           K#FCEA    KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C           K#FCEA    CHAINFCEPL01              77
     C           *IN77     IFEQ *ON
     C           *IN77     OREQ *OFF
     C           A2GSKD    ANDEQ'D'
     C                     ITER
     C                     ENDIF
      * GET BOX ---
     C           BAUSYS    IFNE *ZERO
     C           BASRYO    DIV  BAUSYS    W#RST
     C                     ELSE
     C           BASYOS    IFNE 0
     C           BASRYO    DIV  BASYOS    W#RST   50
     C                     ELSE
     C                     Z-ADD1         W#RST
     C                     END
     C                     END
     C                     ADD  W#RST     W@CCNT  50
      *
     C                     Z-ADD*ZERO     W@SCNT  50
     C                     Z-ADD*ZERO     W@@CNT  50
     C                     EXSR #SCNT
     C           W@SCNT    IFLT W#RST
     C           W#RST     SUB  W@SCNT    W@@CNT  50
     C                     ADD  W@@CNT    W@UNS
     C                     ENDIF
      * CHAIN AB#WP6V
     C           K#WP6V    KLIST
     C                     KFLD           BANONY
     C                     KFLD           BATOKU
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C           K#WP6V    CHAINAB#WP6V              87
      *
     C           *IN87     IFEQ *ON                        *IN87=*ON
     C                     CLEARAB#WP6V1                    '
     C                     MOVELBATOKU    P6TOKU            '
     C                     MOVELBANONY    P6NONY            '
     C                     MOVELBAMHN1    P6MHN1            '
     C                     MOVELBAMHN2    P6MHN2            '
     C                     MOVELBAMHN3    P6MHN3            '
     C                     MOVELBAMHN4    P6MHN4            '
     C                     MOVELBASHN1    P6SHN1            '
     C                     MOVELBASHN2    P6SHN2            '
     C                     MOVELBASHN3    P6SHN3            '
      *                                                     '
     C**         K#FCEA    KLIST                            '
     C**                   KFLD           BASHN1            '
     C**                   KFLD           BASHN2            '
     C**                   KFLD           BASHN3            '
     C**         K#FCEA    CHAINFCEPL011             77     '
      *                                                     '
     C           *IN77     IFEQ '0'                         '
     C           A2GSKD    ANDEQ' '                         '
     C                     MOVE A2STRK    W@LOC1            '
     C                     MOVE '-'       W@LOCA            '
     C                     MOVE A2STRT    W@LOC2            '
     C                     MOVE '-'       W@LOCB            '
     C                     MOVE A2STRR    W@LOC3            '
     C                     MOVE '-'       W@LOCC            '
     C                     MOVE A2STRD    W@LOC4            '
     C                     ELSE                             '
     C                     CLEARW@LOC                       '
     C                     ENDIF                            '
     C                     MOVELW@LOC     P6LOC             '
     C                     ENDIF                            *IN87=*ON
      *
     C                     ADD  W#RST     P6TBOX
     C                     ADD  W@@CNT    P6UNS
      *
     C  N87                UPDATAB#WP6V1
     C   87                WRITEAB#WP6V1
      *
      * SET <AB#WP6V3>
     C           K#FCEA    CHAINAB#WP6V3             86
     C           *IN86     IFEQ *OFF
     C                     ADD  W@@CNT    P7UNS
     C                     UPDATAB#W6V31
     C                     ENDIF
      *
     C           *IN86     IFEQ *ON
      * SET UNSCAN
     C                     Z-ADDW@@CNT    P7UNS
      * GET INVENTORY DAY
     C                     EXSR #INV
     C                     Z-ADD#OINV     P7INV
     C                     Z-ADD#DAYS     P7DAYS    H
     C                     Z-ADDHAKO      P7HAKO
      * CHECK APICS STATUS
     C                     MOVELIPT#      $PART
     C                     CALL 'UEXR12'                   APICS SHOTAGE?
     C                     PARM           $PART  12
     C                     PARM           $SHORT  1
     C                     PARM           $RTN2   1
      *
     C                     MOVELBASHN1    P7SHN1
     C                     MOVELBASHN2    P7SHN2
     C                     MOVELBASHN3    P7SHN3
     C                     MOVEL$SHORT    P7APCS
     C                     WRITEAB#W6V31
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------
      * GET INVENTORY DAY
      *--------------------------------------------------
     C           #INV      BEGSR
      * GET Q/C
     C                     Z-ADD0         D2SYSU  50
     C           K#FCEA    CHAINFCEPL011             77
     C           *IN77     IFEQ *OFF
     C           A2SYHZ    IFLE TODAY
     C                     Z-ADDA2SSYS    D2SYSU
     C                     ELSE
     C                     Z-ADDA2KSYS    D2SYSU
     C                     ENDIF
     C                     ENDIF
      * GET HAKO=ONE DAY DEMAND
     C           A2GEKN    DIV  20        W$HIS   81
      *
     C           D2SYSU    IFEQ 0
     C                     Z-ADD0         HAKO
     C                     ELSE
     C           W$HIS     DIV  D2SYSU    HAKO    81H
     C                     ENDIF
      * GET START DATE
     C                     EXSR #GETSD
      *
     C                     MOVELBASHN1    $HIN1
     C                     MOVELBASHN2    $HIN2
     C                     MOVELBASHN3    $HIN3
     C                     MOVEL@@YY      $HAYY
     C                     MOVEL@@MM      $HAMM
     C                     MOVEL@@DD      $HADD
     C                     MOVEL'01'      $HABB
     C                     CALL 'NYUR21'                   WIP STATUS INQUIRY
     C                     PARM           $HIN1   5
     C                     PARM           $HIN2   5
     C                     PARM           $HIN3   2
     C                     PARM           $HAYY   4
     C                     PARM           $HAMM   2
     C                     PARM           $HADD   2
     C                     PARM           $HABB   2
      *OUT
     C                     PARM           $OHKSU  5
     C                     PARM           $OSISU  5
     C                     PARM           $ONYSU  5
     C                     PARM           $OSYSU  5
     C                     PARM           $OKISU  5
     C                     PARM           $OINV   5
     C                     MOVEL$OINV     #OINV   50
      *
     C           HAKO      IFEQ 0
     C                     Z-ADD0         NUM81
     C                     ELSE
     C           #OINV     DIV  HAKO      NUM81   81H
     C                     ENDIF
      *
     C           NUM81     IFGE 100
     C                     Z-ADD99.9      #DAYS   31
     C                     ELSE
     C                     Z-ADDNUM81     #DAYS
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------
      * GET START DATE
      *---------------------------------------------------
     C           #GETSD    BEGSR
      * BACK 10 DAYS
     C                     MOVE TODAY     QQDATE  8
     C                     MOVE '-'       QQPORM  1        + OR -
     C                     MOVE '0010'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR1A'                   CALCULATE DATE
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C                     MOVELQQRDAT    @@YMD
     C*
     C                     SELEC
     C           HAKO      WHGE 4
     C                     ADD  0         @@MM
     C           HAKO      WHGE 0.5
     C                     SUB  2         @@MM
     C                     OTHER
     C                     SUB  11        @@MM
     C                     ENDSL
      *
     C           @@MM      IFLE 0
     C                     ADD  12        @@MM
     C                     SUB  1         @@YY
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------
      * GET SCAN / UNSCAN
