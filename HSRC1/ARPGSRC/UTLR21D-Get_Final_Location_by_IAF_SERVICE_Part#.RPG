     H            Y.
     F** UTLR21D *************************************************************
     F*  PROGRAM: UTILITY- UTILITY- GET FINAL LOCATION BY IAF/SERVICE PART#  *
     F*  WRITTEN: JW (SRA)  2021.03.24                                       *
     F*  -----------------------------                     *
     F*  JW    2021.03.04 ADD $IAF  IAF PART Y/N           *
     F*  JW    2021.03.04 ADD $SVC  SVC PART Y/N           *
     F*----------------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR21D'
     F*                    PARM           $SHIN  12
ADD  F*                    PARM           $DATE   8
     F*                    PARM           $LLOC   6
     F*                    PARM           $LQC    50
     F*                    PARM           $LPRC   3
     F*                    PARM           $LDPT   40
     F*                    PARM           $LMCN   3
     F*                    PARM           $ZETI   4
ADD  F*                    PARM           $MQTY   90
ADD  F*                    PARM           $IAF    1
ADD  F*                    PARM           $SVC    1
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART
     F*      $DATE :  8A  TARGET DATE  (YYYYMMDD) : BLANK = TODAY
     F*  OUT $LLOC :  6A  CURRENT LAST/FINAL LOCATION
     F*      $LQC  :  5,0 CURRENT QPC
     F*      $LPRC :  3A  LAST/FINAL PROCESS
     F*      $LDPT :  4,0 LAST/FINAL DEPARTMENT
     F*      $LMCN :  3A  LAST/FINAL MACHINE
     F*      $ZETI :  4A  ID#
ADD  F*      $MQTY :  9,0 MONTHLY SETTING QTY
ADD  F*      $IAF  :  1A  IAF PART (Y/N)
ADD  F*      $SVC  :  1A  SVC PART (Y/N)
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FFCEPL01 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     FFCEPL30 IF  E           K        DISK
     F******************************************************
     E                    PRN        15  3
     E                    PRX        15  3
     E                    DPN        15  4 0
     E                    DPX        15  4 0
     E                    LCN        15  6
     E                    LCX        15  6
     E                    MCN        15  3
     E                    MCX        15  3
     E                    CHG        15 10 0
      * PROCESS TABLE NEW
