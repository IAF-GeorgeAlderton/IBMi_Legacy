     H            Y.
     F*-----------------------------------------------------
     F*社内品番で各月内示の合計を求める。
     F* T.SAKASHITA 2013.01.17
     F*-----------------------------------------------------
     F* PARM('90119' 'A0048' '  ' 0 0 0 0 0 0 0)
     F*-----------------------------------------------------
     FABBPL02 IF  E           K        DISK
     FMBDPL01 IF  E           K        DISK
     E                    TB1      9999  4 0
     C           *ENTRY    PLIST
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
     C                     PARM           P@N2NM 100
     C                     PARM           P@N1NM 100
     C                     PARM           P@NNNM 100
     C                     PARM           P@1NNM 100
     C                     PARM           P@2NNM 100
     C                     PARM           P@NTYM  60
     C                     PARM           P@TNSU 100
      *
     C                     Z-ADD0         P@N2NM
     C                     Z-ADD0         P@N1NM
     C                     Z-ADD0         P@NNNM
     C                     Z-ADD0         P@1NNM
     C                     Z-ADD0         P@2NNM
     C                     Z-ADD0         P@TNSU
      *
     C                     MOVE P@SHN1    K@SHN1
     C                     MOVE P@SHN2    K@SHN2
     C                     MOVE P@SHN3    K@SHN3
      *
     C           KEY       KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
      *
     C                     Z-ADD0         @X      50
      *
     C           KEY       SETLLABBPL02
     C                     DO   *HIVAL
     C           KEY       READEABBPL02                  88
     C   88                LEAVE
     C                     ADD  Q5N2NM    P@N2NM
     C                     ADD  Q5N1NM    P@N1NM
     C                     ADD  Q5NNNM    P@NNNM
     C                     ADD  Q51NNM    P@1NNM
     C                     ADD  Q52NNM    P@2NNM
     C                     Z-ADDQ5NTYM    P@NTYM
      *
     C           Q5N2NM    IFEQ 0
     C           Q5N1NM    ANDEQ0
     C           Q5NNNM    ANDEQ0
     C                     GOTO @JUMP
     C                     END
      *
     C           Q5NONY    LOKUPTB1                      77
     C           *IN77     IFEQ '0'
     C                     ADD  1         @X
     C                     Z-ADDQ5NONY    TB1,@X
     C                     END
      *
     C           @JUMP     TAG
      *
     C                     ENDDO
      *
     C                     EXSR #MBD
      *
     C           P@NTYM    IFEQ 0
     C                     EXSR #GET
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
     C           #MBD      BEGSR
      *
     C           KEY       SETLLMBDPL01
     C                     DO   *HIVAL
     C           KEY       READEMBDPL01                  44
     C   44                LEAVE
     C           F3NONY    LOKUPTB1                      66
     C           *IN66     IFEQ '1'
     C                     ITER
     C                     END
      *
     C                     ADD  F3TNSU    P@TNSU
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #GET      BEGSR
      *
     C           *LOVAL    SETLLABBPL02
     C                     READ ABBPL02                  45
     C                     Z-ADDQ5NTYM    P@NTYM
      *
     C                     ENDSR
