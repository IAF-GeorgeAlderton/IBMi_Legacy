     H            Y.
     F** STAR30 **************************************
     F* STOCK CHECK & MAINTENANCE
     F*     T.SAKAKI          2019.12.04             *
     F************************************************
     FSTAPW30 CF  E                    WORKSTN
     FSTAPL10 UF  E           K        DISK                      A
     FFCEPL07 IF  E           K        DISK
      *
     E                    ER      1  15 20
      *
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
     I                                        7  100SDAYY
     I                                       11  120SDAMM
     I                                       13  140SDADD
     I                                        1   20STIHH
     I                                        3   40STIMM
     I                                        5   60STISS
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *----------------------------------------------------*
      *   PARAMETER  TRANCFER                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PTACD   6
     C                     PARM           PTANM  20
      *
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      * INTIALIZE                                          *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
      *
     C                     MOVEL#WSID     @WSID
     C                     MOVEL'01'      DSPSW   2
     C                     TIME           WTIME
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEL*BLANK    Z1TKR
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *  MAIN                                            *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR $SB210
     C           DSPSW     WHEQ '02'
     C                     EXSR $SB220
     C                     ENDSL
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *  END
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *1ST SCREEN                                        *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTSTAPW301
     C                     SETOF                     9931
     C                     MOVEL*BLANK    D9TXT
     C           *IN02     IFEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C           *IN13     OREQ '1'
     C           *IN14     OREQ '1'
     C           *IN15     OREQ '1'
     C           *IN16     OREQ '1'
     C           *IN17     OREQ '1'
     C           *IN18     OREQ '1'
     C           *IN19     OREQ '1'
     C           *IN20     OREQ '1'
     C           *IN21     OREQ '1'
     C           *IN22     OREQ '1'
     C           *IN23     OREQ '1'
     C           *IN24     OREQ '1'
     C                     GOTO $S210E
     C                     ENDIF
      * F1 BACK
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           D1BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELD1BAR1    D9TXT
     C                     MOVELER,1      D9ERR
     C                     EXSR #DSPWR
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           4         SUBSTD1BAR1:1  W@ZETI  4
      *
     C                     MOVEL*BLANK    W@SHN1  5
     C                     MOVEL*BLANK    W@SHN2  5
     C                     MOVEL*BLANK    W@SHN3  2
     C           W@ZETI    CHAINFCEPP011             22
     C           *IN22     IFEQ '0'
     C                     MOVELA2BHB1    W@SHN1
     C                     MOVELA2BHB2    W@SHN2
     C                     MOVELA2BHB3    W@SHN3
     C                     ELSE
     C                     SETON                     99
     C                     MOVELD1BAR1    D9TXT
     C                     MOVELER,3      D9ERR
     C                     EXSR #DSPWR
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           1         SUBSTD1BAR1:5  W@ATK1  1
     C           2         SUBSTD1BAR1:6  W@ATK2  2
     C           2         SUBSTD1BAR1:8  W@ATK3  2
     C           1         SUBSTD1BAR1:10 W@ATK4  1
      *
     C                     Z-ADD0         D2TUHK
     C                     Z-ADD0         @2TUHK
     C           KEYST1    KLIST
     C                     KFLD           W@SHN1
     C                     KFLD           W@SHN2
     C                     KFLD           W@SHN3
     C                     KFLD           W@ATK1
     C                     KFLD           W@ATK2
     C                     KFLD           W@ATK3
     C                     KFLD           W@ATK4
     C           KEYST1    CHAINSTAPL101             22
     C           *IN22     IFEQ '0'
     C           S1SKJY    ANDEQ'D'
     C           S1SKHZ    ANDLESDATE
     C                     SETON                     22
     C                     ENDIF
      *
     C                     MOVEL'02'      DSPSW   2
     C                     Z-ADD0         @2TUHK
     C                     Z-ADD0         D2TUHK
     C           *IN22     IFEQ '0'
     C                     Z-ADDS1TUHK    @2TUHK
     C           S1TUHK    IFGE 0
     C                     Z-ADDS1TUHK    D2TUHK
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D2TKR
     C                     CALL 'APLR40'
     C                     PARM           W@ATK1  1
     C                     PARM           W@ATK2  2
     C                     PARM           W@ATK3  2
     C                     PARM           W@ATK4  1
     C                     PARM           O@BANC  9
     C                     MOVELO@BANC    D2TKR
      *
     C                     MOVEL*BLANK    D2SHN
     C                     CALL 'APLR30'
     C                     PARM           W@SHN1  5
     C                     PARM           W@SHN2  5
     C                     PARM           W@SHN3  2
     C                     PARM           P@SHNA 14
     C                     MOVELP@SHNA    D2SHN
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      * 2ND SCREEN                                         *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
      *
     C                     EXFMTSTAPW302
     C                     SETOF                     9931
     C                     MOVEL*BLANK    D9TXT
     C           *IN02     IFEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C           *IN13     OREQ '1'
     C           *IN14     OREQ '1'
     C           *IN15     OREQ '1'
     C           *IN16     OREQ '1'
     C           *IN17     OREQ '1'
     C           *IN18     OREQ '1'
     C           *IN19     OREQ '1'
     C           *IN20     OREQ '1'
     C           *IN21     OREQ '1'
     C           *IN22     OREQ '1'
     C           *IN23     OREQ '1'
     C           *IN24     OREQ '1'
     C                     GOTO $S220E
     C                     ENDIF
      * F1 BACK
     C           *IN01     IFEQ '1'
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEL'01'      DSPSW
     C                     GOTO $S220E
     C                     ENDIF
      *
      * F5 UPDATE
     C           *IN05     IFEQ '0'
     C                     GOTO $S220E
     C                     ENDIF
      *
     C                     TIME           WTIME
     C                     EXSR #SB500
     C                     EXSR #SB600
      *
     C                     MOVELD2TKR     Z1TKR
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEL'01'      DSPSW
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      * UPDATE STAPP10                                     *
      *  UPDATE BY STAR00                                  *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYST1    CHAINSTAPL101             22
     C           *IN22     IFEQ '0'
     C                     Z-ADDSDATE     S1TNHZ
     C                     Z-ADDSTIME     S1TNTI
     C                     Z-ADDD2TUHK    S1TNTU
     C                     MOVELPTANM     S1TNME
     C                     UPDATSTAPL101
      *
      * CREATE KEY RECORD. UPDATE BY STAR00
     C                     ELSE
     C                     CLEARSTAPL101
     C                     Z-ADDSDATE     S1KOHZ
     C                     Z-ADDSTIME     S1KOTI
     C                     MOVELPTACD     S1KOME
     C                     MOVEL#PGM      S1KOPG
     C                     MOVELW@SHN1    S1SHN1
     C                     MOVELW@SHN2    S1SHN2
     C                     MOVELW@SHN3    S1SHN3
     C                     MOVELW@ATK1    S1ATK1
     C                     MOVELW@ATK2    S1ATK2
     C                     MOVELW@ATK3    S1ATK3
     C                     MOVELW@ATK4    S1ATK4
     C                     Z-ADDSDATE     S1TNHZ
     C                     Z-ADDSTIME     S1TNTI
     C                     Z-ADDD2TUHK    S1TNTU
     C                     MOVELPTANM     S1TNME
     C                     WRITESTAPL101
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *  WRITE ST002P0   LOG                               *
      *----------------------------------------------------*
     CSR         #SB600    BEGSR
      *
     C                     Z-ADDSDATE     P#TIHZ
     C                     Z-ADDSTIME     P#TITI
     C                     MOVELW@SHN1    P#SHN1
     C                     MOVELW@SHN2    P#SHN2
     C                     MOVELW@SHN3    P#SHN3
     C                     MOVELW@ATK1    P#ATK1
     C                     MOVELW@ATK2    P#ATK2
     C                     MOVELW@ATK3    P#ATK3
     C                     MOVELW@ATK4    P#ATK4
     C                     MOVELPTACD     P#TANT
     C                     MOVEL#PGM      P#PGM
     C                     MOVEL*BLANK    P#BAR1
     C                     MOVEL*BLANK    P#QR11
     C                     MOVEL*BLANK    P#QR12
     C                     MOVEL*BLANK    P#BAR2
     C                     MOVEL*BLANK    P#QR21
     C                     MOVEL*BLANK    P#QR22
      * NORMAL STOCK  AFTER-BEFORE
     C           D2TUHK    SUB  @2TUHK    A       50
     C                     SELEC
     C           A         WHEQ 0                           NO CHANGE
     C           A         WHGT 0                           PLUS
     C                     Z-ADDD2TUHK    P#HKSU
     C                     MOVEL'I'       P#SYOR
     C                     MOVEL'1'       P#ZAIK
     C                     EXSR #SBST0
     C           A         WHLT 0                          MINUS
     C                     Z-ADDD2TUHK    P#HKSU
     C                     MOVEL'I'       P#SYOR
     C                     MOVEL'2'       P#ZAIK
     C                     EXSR #SBST0
     C                     ENDSL
      *
     CSR         ESB600    ENDSR
      *----------------------------------------------------*
      * STOCK MANEGEMENT                                   *
      *----------------------------------------------------*
     CSR         #SBST0    BEGSR
      *
     C                     MOVEL'0111'    P#BMON
     C                     CALL 'STAR00'
     C                     PARM           P#TIHZ  80
     C                     PARM           P#TITI  60
     C                     PARM           P#BMON  4
     C                     PARM           P#SHN1  5
     C                     PARM           P#SHN2  5
     C                     PARM           P#SHN3  2
     C                     PARM           P#ATK1  1
     C                     PARM           P#ATK2  2
     C                     PARM           P#ATK3  2
     C                     PARM           P#ATK4  1
     C                     PARM 'I'       P#SYOR  1
     C                     PARM '1'       P#ZAIK  1
     C                     PARM           P#HKSU  50
     C                     PARM PTACD     P#TMCD 10
     C                     PARM PTANM     P#TANT 20
     C                     PARM #PGM      P#PGM  10
     C                     PARM           P#BAR1 20
     C                     PARM           P#QR11256
     C                     PARM           P#QR12256
     C                     PARM           P#BAR2 20
     C                     PARM           P#QR21256
     C                     PARM           P#QR22256
      *
     CSR         ESBST0    ENDSR
      *----------------------------------------------------*
      * DISPLAY ERROR SCREEN                               *
      *----------------------------------------------------*
     CSR         #DSPWR    BEGSR
      *
     C                     EXFMTSTAPW309
      *
     C                     SETOF                     99
      *
     CSR         EDSPWR    ENDSR
** ER
ER01 INPUT.
ER02 WRONG INPUT.
ER03 NO PART MASTER.
ER04 NO STOCK DATA.


