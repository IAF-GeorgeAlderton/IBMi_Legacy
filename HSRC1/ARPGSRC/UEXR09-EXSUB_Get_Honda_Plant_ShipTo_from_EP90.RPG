     H            Y.
     F** UEXR09 ********************************************
     F*  PROGRAM: GET HONDA PLANT/SHIPTO FROM AB#EP90      *
     F*  WRITTEN: JW (SRA) 2019.06.11                      *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR09'
     F*                    PARM           $ODRN  10
     F*                    PARM           $NOHZ   8
     F*                    PARM           $PLNT   3
     F*                    PARM           $SHCD  10
     F*                    PARM           $RTN    1
     F*  IN  $ODRN : 10A ORDER#
     F*      $NOHZ :  8A SHIP DATE
     F*  OUT $PLNT :  3A PLANT CODE
     F*      $SHCD : 10A SHIP TO CODE
     F*      $RTN  :  1A RETURN CODE (BLANK/*)
     F******************************************************
     FAB#EL94SIF  E           K        DISK
     FAB#EL90SIF  E           K        DISK
     F            AB#E90S1                          KRENAMEAB#E94S1
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * GET FROM EDI862
     C                     EXSR #862
      * GET FROM EDI850
     C           $PLNT     IFEQ *BLANK
     C                     EXSR #850
     C                     ENDIF
      *
     C           $PLNT     IFEQ *BLANK
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * FOR EDI 862
      *======================================================
     C           #862      BEGSR
      *
     C           @ORD20    SETLLAB#EL94S
     C                     DO   *HIVAL
     C           @ORD20    READEAB#EL94S                 88
     C   88                LEAVE
      *
     C           AEPLSH    IFEQ @NOHZ
     C                     MOVELAEPLNT    $PLNT
     C                     MOVELAESHCD    $SHCD
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELAEPLNT    $PLNT
     C                     MOVELAESHCD    $SHCD
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * FOR EDI 850
      *======================================================
     C           #850      BEGSR
      *
     C           @ORD20    SETLLAB#EL90S
     C                     DO   *HIVAL
     C           @ORD20    READEAB#EL90S                 88
     C   88                LEAVE
      *
     C           AEPLSH    IFEQ @NOHZ
     C                     MOVELAEPLNT    $PLNT
     C                     MOVELAESHCD    $SHCD
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELAEPLNT    $PLNT
     C                     MOVELAESHCD    $SHCD
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $ODRN  10        IN
     C                     PARM           $NOHZ   8        "
     C                     PARM           $PLNT   3        OUT
     C                     PARM           $SHCD  10        "
     C                     PARM           $RTN    1        "
      *
     C                     MOVEL$ODRN     @ORD20 20
     C                     MOVEL$NOHZ     @NOHZ   80
     C                     MOVE *BLANK    $PLNT
     C                     MOVE *BLANK    $SHCD
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
      *
     C                     ENDSR
      *====================================================
