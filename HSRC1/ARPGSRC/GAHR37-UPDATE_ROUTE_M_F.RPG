     H            Y.
      ** GAHR37 *******************************************************
      *  UPDATE OF ROUTE M/F
      *  KIRI                                            2017.06.28
      *****************************************************************
     FGAHPW37 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFREC1
      * ROUTE M/F  LF1                           *
     FGAHPL37 UF  E           K        DISK                      A
      *===============================================================
     E                    ER      1  20 60
     E                    @RTC     9999  4
     E                    @RTN     9999 50
      *===============================================================
      *---
     I            DS
     I                                        1  50 S1DATA
     I                                        1   4 S1RTCD
     I                                        5  49 S1RTNA
     I                                        5  19 S1RTN1
     I                                       20  34 S1RTN2
     I                                       35  49 S1RTN3
     I                                       50  50 S1MNT
     I            DS
     I                                        1   4 D1RTCD
     I                                        1   1 D1RTC1
     I                                        2   2 D1RTC2
     I                                        3   3 D1RTC3
     I                                        4   4 D1RTC4
     I****************************
      *プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
     C*===============================================================
     C*
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
      * 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
      *
     C           *LOVAL    SETLLGAHPL37
     C                     Z-ADD0         X       40
     C                     MOVE *BLANK    @RTC
     C                     MOVE *BLANK    @RTN
      *
     C                     DO   *HIVAL
     C                     READ GAHPL37             N    90
     C   90                LEAVE
     C           G7SKJY    IFEQ 'D'
     C           G7SKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELG7RTCD    S1RTCD           ROUTE CODE
     C                     MOVELG7RTN1    S1RTN1           ROUTE NAME 1
     C                     MOVELG7RTN2    S1RTN2           ROUTE NAME 2
     C                     MOVELG7RTN3    S1RTN3           ROUTE NAME 3
     C                     MOVE *BLANK    S1MNT
     C                     ADD  1         X
     C                     MOVE S1RTCD    @RTC,X
     C                     MOVE S1DATA    @RTN,X
     C                     ENDDO
      *-------------------*
     C                     Z-ADD1         @@PAGE  40
     C                     EXSR #SFSET
     C                     SETON                     91
      *
     C                     MOVE *BLANK    D1KKBN           更新区分
     C                     MOVE *BLANK    D1RTCD            ROUTE
     C                     MOVE *BLANK    D1RTN1            NAME1
     C                     MOVE *BLANK    D1RTN2            NAME2
     C                     MOVE *BLANK    D1RTN3            NAME2
     C                     MOVE *BLANK    D1ERR            d[ｰxｮﾈｰﾆﾞ
      *
     C                     WRITEGAHPW372                   罫線CLR
     C                     WRITEGAHPW373                   罫線DSP
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *サブファイル作成
     C*===============================================================
     C           #SFSET    BEGSR
     C*<SFLCLR>
     C                     SETON                     73
     C                     WRITESFCTL1
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
     C           @@PAGE    MULT 10        X       40
     C                     SUB  10        X
     C                     SETOF                     96
      *-------------------------
     C                     DO   10
     C                     ADD  1         X
     C           @RTN,X    IFEQ *BLANK
     C                     SETON                     96
     C                     LEAVE
     C                     ENDIF
     C*
     C                     MOVE @RTN,X    S1DATA
     C                     MOVEL*BLANK    S1COM
     C                     SELEC
     C           S1MNT     WHEQ '0'
     C                     MOVEL'CANCEL'  S1COM
     C           S1MNT     WHEQ '1'
     C                     MOVEL'CHANGE'  S1COM
     C           S1MNT     WHEQ '2'
     C                     MOVEL'ADD   '  S1COM
     C                     ENDSL
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C                     ENDDO
      *-------------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C*
     C                     WRITEGAHPW371
     C           ENDRRN    IFNE 0
     C                     SETON                     72     SFLDSP
     C                     ENDIF
     C                     SETON                     71     SFLDSPCTL
     C                     EXFMTSFCTL1
     C                     SETOF                     7172
     C                     MOVEA'00000000'*IN,31
     C                     SETOF                     99
      *
     C                     SELEC
      *-------*
      * (F3)  *
      *-------*
     C           *INKC     WHEQ *ON
     C                     WRITEGAHPW372                   罫線CLR
     C                     MOVE '#END    '@STEP
      *-------*
      * (F5)  *
      *-------*
     C           *INKE     WHEQ *ON
     C                     MOVE '#CHK1 F5'@STEP
      *-------*
      * ROLL UP
      *-------*
     C           *IN75     WHEQ *ON
     C           *IN96     IFEQ *OFF
     C                     ADD  1         @@PAGE
     C                     EXSR #SFSET
     C           ENDRRN    IFEQ 0
     C                     SUB  1         @@PAGE
     C                     EXSR #SFSET
     C                     ENDIF
     C                     ENDIF
      *-------*
      * ROLL DOWN
      *-------*
     C           *IN76     WHEQ *ON
     C           @@PAGE    IFGT 1
     C                     SUB  1         @@PAGE
     C                     EXSR #SFSET
     C                     ENDIF
      *-------*
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
     C*
     C                     ENDSR
     C*===============================================================
      *画面１チェック
     C*===============================================================
     C           #CHK1     BEGSR
      *----------------------*
      * UPDATE更新区分(31)
      *----------------------*
S1   C                     SELEC
 1   C           D1KKBN    WHEQ '0'                        :取消
 1   C           D1KKBN    WHEQ '1'                        :変更
 1   C           D1KKBN    WHEQ '2'                        :追加
 1   C           D1KKBN    WHEQ ' '                        :未入力
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
 1   C                     OTHER
     C                     SETON                     3199
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
E1   C                     ENDSL
      *----------------------*
      * ROUTE CODE (32)
      *----------------------*
     C           D1RTC1    IFEQ *BLANK
     C           D1RTC2    OREQ *BLANK
     C           D1RTC3    OREQ *BLANK
     C           D1RTC4    OREQ *BLANK
     C                     SETON                     3299
     C                     MOVELER,3      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *----------------------*
     C           D1RTCD    CHAINGAHPL37             N90
      *
S1   C                     SELEC
 1   C           D1KKBN    WHEQ '0'                        :取消
     C           *IN90     IFEQ *ON
     C                     SETON                     313299
     C                     MOVELER,4      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C           G7SKJY    IFEQ 'D'
     C           G7SKHZ    ANDLE@SYSHZ
     C                     SETON                     313299
     C                     MOVELER,5      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
 1   C           D1KKBN    WHEQ '1'                        :変更
     C           *IN90     IFEQ *ON
     C                     SETON                     313299
     C                     MOVELER,6      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C           G7SKJY    IFEQ 'D'
     C           G7SKHZ    ANDLE@SYSHZ
     C                     SETON                     313299
     C                     MOVELER,5      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
 1   C           D1KKBN    WHEQ '2'                        :追加
     C           *IN90     IFEQ *OFF
     C           G7SKJY    ANDNE'D'
     C                     SETON                     313299
     C                     MOVELER,7      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
E1   C                     ENDSL
     C*
S1   C           D1KKBN    IFEQ '0'                        :取消
     C                     MOVELG7RTN1    D1RTN1           ROUTE NAME 1
     C                     MOVELG7RTN2    D1RTN2           ROUTE NAME 2
     C                     MOVELG7RTN3    D1RTN3           ROUTE NAME 3
E1   C                     ENDIF
     C*
S1   C           D1KKBN    IFEQ '1'                        :変更
     C           D1RTN1    IFEQ *BLANK
     C           D1RTN2    ANDEQ*BLANK
     C           D1RTN3    ANDEQ*BLANK
     C                     MOVELG7RTN1    D1RTN1           ROUTE NAME 1
     C                     MOVELG7RTN2    D1RTN2           ROUTE NAME 2
     C                     MOVELG7RTN3    D1RTN3           ROUTE NAME 3
     C                     ENDIF
E1   C                     ENDIF
      *----------------------*
      * CARRIER NAME (33)
      *----------------------*
     C           D1RTN1    IFEQ *BLANK
     C           D1RTN2    ANDEQ*BLANK
     C           D1RTN3    ANDEQ*BLANK
     C                     SETON                     3399
     C                     MOVELER,8      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *----------------------*
     C           $CHK1Z    TAG
      *----------------------*
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1 F5'
     C                     MOVE '#UPDAT  '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *----------------------*
     C                     ENDSR
     C*===============================================================
      *ファイル更新処理
     C*===============================================================
     C           #UPDAT    BEGSR
     C*
     C           D1RTCD    CHAINGAHPL37              90
     C   90                CLEARGAHPL371
     C*
S1   C                     SELEC
-1   C           D1KKBN    WHEQ '0'                        :CANCEL
     C                     MOVEL'D'       G7SKJY           DELETE CODE D
     C                     Z-ADD@SYSHZ    G7SKHZ           DELETE DATE
     C                     Z-ADD@SYSTM    G7SKTM           DELETE TIME
     C                     MOVELW$USER    G7SKNM           DELETE PERSON
-1   C                     OTHER                           :ADD CHANGE
     C                     MOVEL' '       G7SKJY           DELETE CODE D
     C                     Z-ADD0         G7SKHZ           DELETE DATE
     C                     Z-ADD0         G7SKTM           DELETE TIME
     C                     MOVEL*BLANK    G7SKNM           DELETE PERSON
     C                     Z-ADD@SYSHZ    G7KOHZ           UPDATE DATE
     C                     Z-ADD@SYSTM    G7KOTM           UPDATE TIME
     C                     MOVELW$PGM     G7KOPG           UPDATE PROGRAM
     C                     MOVELW$USER    G7KONM           UPDATE PERSON
     C                     MOVELD1RTCD    G7RTCD            ROUTE
     C                     MOVELD1RTN1    G7RTN1            NAME1
     C                     MOVELD1RTN2    G7RTN2            NAME2
     C                     MOVELD1RTN3    G7RTN3            NAME2
E1   C                     ENDSL
      *
     C   90                WRITEGAHPL371
     C  N90                UPDATGAHPL371
     C*
S1   C           D1KKBN    IFEQ '0'                        :CANCEL
     C           D1KKBN    OREQ '1'                        :CHANGE
     C                     Z-ADD1         X
     C           D1RTCD    LOKUP@RTC,X                   50
 S2  C           *IN50     IFEQ *ON
     C                     MOVEL@RTN,X    S1DATA
     C                     MOVELD1RTN1    S1RTN1           ROUTE NAME 1
     C                     MOVELD1RTN2    S1RTN2           ROUTE NAME 2
     C                     MOVELD1RTN3    S1RTN3           ROUTE NAME 3
     C                     MOVELD1KKBN    S1MNT
     C                     MOVELS1DATA    @RTN,X
 E2  C                     ENDIF
E1   C                     ENDIF
      *
S1   C           D1KKBN    IFEQ '2'                        :ADD
     C                     MOVELD1RTCD    S1RTCD           ROUTE CODE
     C                     MOVELD1RTN1    S1RTN1           ROUTE NAME 1
     C                     MOVELD1RTN2    S1RTN2           ROUTE NAME 2
     C                     MOVELD1RTN3    S1RTN3           ROUTE NAME 3
     C                     MOVELD1KKBN    S1MNT
     C                     Z-ADD1         X
     C           '    '    LOKUP@RTC,X                   50
 S2  C           *IN50     IFEQ *ON
     C                     MOVELD1RTCD    @RTC,X           ROUTE CODE
     C                     MOVELS1DATA    @RTN,X
 E2  C                     ENDIF
E1   C                     ENDIF
     C*
     C                     MOVEL*BLANK    D1KKBN           更新区分
     C                     MOVEL*BLANK    D1RTCD           ROUTE CODE
     C                     MOVEL*BLANK    D1RTN1           ROUTE NAME 1
     C                     MOVEL*BLANK    D1RTN2           ROUTE NAME 2
     C                     MOVEL*BLANK    D1RTN3           ROUTE NAME 3
     C                     EXSR #SFSET
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *================================================================
      *================================================================
**  ERROR
E-01 UPDATE INSTRUCTIONS ARE <0 1 2>
E-02 INPUT UPDATE INSTRUCTION.
E-03 INPUT ROUTE CODE WITH NO BLANK SPACE.
E-04 THERE ISN'T CANCEL DATA
E-05 DATA IS CANCELLED  ALREADY
E-06 THERE ISN'T CHANGE DATA
E-07 THERE IS DATA
E-08 INPUT ROUTE NAME
E-09
E-10
