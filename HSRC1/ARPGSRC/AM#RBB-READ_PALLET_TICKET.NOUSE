     H            Y.
     F** AM#RBB *********************************************
     F* READ PALLET TICKET
     F*    ITS.             2015.06.01                      *
     F*******************************************************
     FAM#PWBB CF  E                    WORKSTN
      *
     ITIK         DS
     I                                        1  25 TIK01
     I                                       26  50 TIK02
     I                                       51  75 TIK03
      *
     IB2D         DS
     I                                        1  25 BAR01
     I                                       26  50 BAR02
     I                                       51  75 BAR03
     I                                       76 100 BAR04
     I                                      101 125 BAR05
     I                                      126 150 BAR06
     I                                      151 175 BAR07
     I                                      176 200 BAR08
     I                                      201 225 BAR09
     I                                      226 250 BAR10
      *
     I            DS
     I                                        1  72 TICKET
     I                                        1   9 TISURT
     I                                       10  17 TISHID
     I                                       18  23 TISHIT
     I                                       24  38 TISMEI
     I                                       39  40 TIDOCK
     I                                       41  52 TIORD#
     I                                       53  54 TIPALT
     I                                       55  58 TINONY
     I                                       59  59 TINKOJ
     I                                       60  63 TINUKE
     I                                       64  66 TIIAFB
     I                                       67  69 TIIAFP
     I                                       70  70 TIPPUL
     I                                       71  71 TIEXT
     I                                       72  72 TISAT
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * IN
      *ＰＡＬＬＥＴＰＵＬＬＩＮＧ
      * OUT
      *チケット読み取り内容
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     CLEARTIK
     C                     CLEARB2D
     C                     MOVELTICK      TIK
     C                     MOVELKANB      B2D
     C                     MOVEL'02'      DSPSW   2
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTDSP02
     C                     SETOF                     3199
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    TICK
     C                     MOVEL*BLANK    KANB
     C                     MOVEL'01'      DSPSW   2
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
