     C                     ENDSR
     C*---------------------------------------------------------------*
     C* LOCAL SUPPLIER
     C*---------------------------------------------------------------*
     C           #LOCL     BEGSR
      *
     C                     CLEARUDAT
     C                     CLEARUTOT
     C                     Z-ADD0         QTSURY
     C                     Z-ADD0         STSURY
     C           K#PL94    SETLLAFBPL94
B02  C           *IN94     DOWEQ'0'
     C           K#PL9X    READEAFBPL94                  94
     C           *IN94     IFEQ *OFF
B03  C           B9SKJY    ANDEQ*BLANK
      *
     C   95                WRITEQHED1
     C   95                WRITEQHED2
     C                     SETOF                     95
     C                     CLEARQDET
      *
     C                     MOVE *ON       *IN55
     C                     MOVE *ON       *IN54
     C                     MOVE B9ODN1    QINVO1           ORDER #
     C                     MOVE B9ODN2    QINVO2
     C                     MOVE B9ODN3    QINVO3
     C                     Z-ADDB9ODMM    QODRM            ORDER DATE
     C                     Z-ADDB9ODDD    QODRD
     C                     Z-ADDB9ODYY    QODRY
     C           B9SYOS    MULT B9HAKO    QSURY            QTY.
     C                     Z-ADDB9SYOS    QSYOS            QTY/CONT.
     C                     Z-ADDB9HAKO    QMAIS            BOX
      *
     C           B9NOYY    IFEQ *ZERO
     C                     MOVE '*'       QFLAG            NOT RECEIVED
     C                     ADD  B9HAKO    QTSURY           ORDER TOTAL BOX
     C                     ADD  B9HAKO    STSURY  50
     C                     Z-ADDQSURY     QSURYA
     C                     ADD  QSURY     QTSURB
     C                     Z-ADDB9HAKO    QHAKO1
     C                     ADD  B9HAKO    QTSURA
     C                     Z-ADDB9NYMM    QNYUM            ARRIVAL SCHEDULE
     C                     Z-ADDB9NYDD    QNYUD
     C                     Z-ADDB9NYYY    QNYUY
     C                     ELSE
     C                     MOVEL'*'       QIFMK   1        FIN MARK
     C                     MOVEL'*'       QNFLG
     C                     Z-ADDB9NOMM    QNYUM            ARRIVAL SCHEDULE
     C                     Z-ADDB9NODD    QNYUD
     C                     Z-ADDB9NOYY    QNYUY
     C                     Z-ADDQSURY     QSURYB
     C                     Z-ADDB9HAKO    QHAKO            BOX
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C                     ADD  1         PAG
     C                     WRITEHED
     C                     WRITEQHED1
     C                     WRITEQHED2
     C                     SETOF                     21
     C                     END
      *
TCH14C           *IN68     IFEQ '1'
     C           ICODER    ANDEQIEODER
     C                     GOTO SKIP7
TCH14C                     ENDIF
      *
     C                     WRITEQDET
     C                     SETOF                     55
TCH14C           SKIP7     TAG
E04  C                     ENDIF
E03  C                     ENDDO
      *
     C  N95                WRITEQTOT
      *
     C* SET UNORDERED INFORMATION
     C                     SETON                     80
     C                     MOVE *BLANK    WODR#   6
     C                     Z-ADD0         HAHZ#   80
     C                     Z-ADD*ZERO     UMAIS
     C*
     C           K#PL9X    SETLLAFBPL80
     C           *IN94     DOUEQ*ON
     C           K#PL9X    READEAFBPL80                  94
B01  C           *IN94     IFEQ *OFF
B02  C           B8SKJY    ANDEQ*BLANK
     C*
B02  C           *IN80     IFEQ '1'
     C                     WRITEUHED1
     C                     WRITEUHED2
E02  C                     END
     C* ORDER NUMBER BREAKE
B02  C           HAHZ#     IFNE B8DATE
B03  C           *IN80     IFNE '1'
      *
B04  C           *IN21     IFEQ '1'
     C                     ADD  1         PAG
     C                     WRITEHED
     C                     WRITEUHED1
     C                     WRITEUHED2
     C                     SETOF                     21
E04  C                     END
     C*
     C                     WRITEUDAT
     C                     Z-ADD*ZERO     UMAIS
E03  C                     END
     C*
     C                     Z-ADDB8ODNO    UODER            ORDER #
     C                     MOVE B8ZETI    UZETI            ABSOLUTE #
     C                     MOVE B8KANR    USEIH            PART CODE
     C                     MOVE B8PAR1    UHIN1            PART 1
     C                     MOVE B8PAR2    UHIN2                 2
     C                     MOVE B8PAR3    UHIN3                 3
     C                     Z-ADDB8SYOS    USYOS            QTY/CONT
     C                     Z-ADDB8YY      UHAYY            ORDER DUE
     C                     Z-ADDB8MM      UHAMM
     C                     Z-ADDB8DD      UHADD
     C                     SETOF                     80
     C                     MOVE B8ODNO    WODR#
     C                     Z-ADDB8DATE    HAHZ#
     C                     ADD  1         UMAIS            #OF KANBAN
     C                     ADD  1         QTMAIS           #OF KANBAN
     C*
     C                     ELSE
     C                     ADD  1         UMAIS            #OF KANBAN
     C                     ADD  1         QTMAIS           #OF KANBAN
E02  C                     END
      *
     C                     ENDIF
