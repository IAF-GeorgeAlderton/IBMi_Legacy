     C*
     C                     WRITEUDAT
     C                     Z-ADD*ZERO     UMAIS
E03  C                     END
     C*
     C                     Z-ADDIAODER    UODER            ORDER #
     C                     MOVE IAZETI    UZETI            ABSOLUTE #
     C                     MOVE IASEIH    USEIH            PART CODE
     C                     MOVE IAHIN1    UHIN1            PART 1
     C                     MOVE IAHIN2    UHIN2                 2
     C                     MOVE IAHIN3    UHIN3                 3
     C                     Z-ADDIASYOS    USYOS            QTY/CONT
     C                     Z-ADDIAHAYY    UHAYY            ORDER DUE
     C                     Z-ADDIAHAMM    UHAMM
     C                     Z-ADDIAHADD    UHADD
     C                     SETOF                     80
     C                     MOVE WAODER    WODR#
     C                     Z-ADDIAHAHZ    HAHZ#
     C                     ADD  IAMAIS    UMAIS            #OF KANBAN
     C                     ADD  IAMAIS    QTMAIS           #OF KANBAN
     C*
     C                     ELSE
     C                     ADD  IAMAIS    UMAIS            #OF KANBAN
     C                     ADD  IAMAIS    QTMAIS           #OF KANBAN
E02  C                     END
     C*
     C           #UEND     TAG
     C           KEY       READEGDGPL011                 96
E01  C                     END
      ********
     C           KEY       SETLLGDGPL10
     C           *IN96     DOUEQ*ON
     C           KEY       READEGDGPL10                  96
B01  C           *IN96     IFEQ *OFF
B02  C           IBSKJY    ANDEQ*BLANK
     C*
B02  C           *IN80     IFEQ '1'
B04  C           *IN21     IFEQ '1'
     C                     ADD  1         PAG
     C                     WRITEHED
     C                     SETOF                     21
E04  C                     END
     C                     WRITEUHED1
     C                     WRITEUHED2
E02  C                     END
     C*
     C                     MOVE IBZETI    UZETI            ABSOLUTE #
     C                     MOVE IBSEIH    USEIH            PART CODE
     C                     MOVE IBHIN1    UHIN1            PART 1
     C                     MOVE IBHIN2    UHIN2                 2
     C                     MOVE IBHIN3    UHIN3                 3
     C                     Z-ADDIBSYOS    USYOS            QTY/CONT
     C                     SETOF                     80
     C                     ADD  IBMAIS    UMAIS            #OF KANBAN
     C                     ADD  IBMAIS    QTMAIS           #OF KANBAN
     C*
E02  C                     ENDIF
E02  C                     ENDDO
     C*
     C*
     C  N80                WRITEUDAT
     C  N80                WRITEUTOT
     C  N80                Z-ADDQTMAIS    PTOTL
     C                     Z-ADDSTSURY    PTSURA
