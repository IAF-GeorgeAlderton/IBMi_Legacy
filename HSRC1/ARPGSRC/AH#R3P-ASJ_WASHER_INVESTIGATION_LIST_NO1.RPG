     C*****                END
      *ASJ END
     C                     ENDIF
      *
     C           KEY       CHAINAGAPL311             96
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C*---------------------------------------------------------------*
     C* NECESSARY QTY.
     C*---------------------------------------------------------------*
     C           @SET1     BEGSR
     C*
     C                     Z-ADD*ZERO     WKNEC   10
     C           KEY4      SETLLFCEPL011
     C*
     C           #SET1     TAG
     C           KEY4      READEFCEPL011                 89
     C           *IN89     IFEQ '0'
     C           A2GSKD    IFNE ' '
     C                     GOTO #SET1
     C                     END
     C*
     C                     Z-ADD1         B       10
     C           AHHIN     LOKUPCOM,B                    79
     C           *IN79     IFEQ '1'
     C                     Z-ADDNEC,B     WKNEC
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C*---------------------------------------------------------------*
     C* ORDER QTY.(UPPER LINE:-10 TO INVESTIGATION DATE)
     C*---------------------------------------------------------------*
     C           @QTY1     BEGSR
     C*
     C                     Z-ADD1         I       20
     C                     DO   10        I
     C*
     C                     MOVEA@YMD,I    TBLYMD
     C                     Z-ADD2000      K3YY
     C                     ADD  TBLYY     K3YY
     C                     Z-ADDTBLMM     K3MM
     C                     Z-ADDTBLDD     K3DD
     C*
     C           KEY3      SETLLAB#PL181
     C           KEY3      READEAB#PL181                 98
     C           *IN98     DOWEQ'0'
     C           BASKJY    IFEQ ' '
     C* CALUCULATE
     C*          BAUSYS    IFNE *ZERO
     C*                    Z-ADDBAUSYS    WKSYOS  60
     C*
     C*                    ELSE
     C*          BASYOS    IFNE *ZERO
     C*                    Z-ADDBASYOS    WKSYOS
     C*                    ELSE
     C*                    Z-ADD1         WKSYOS
     C*                    END
     C*                    END
     C*
     C*          BASRYO    DIV  WKSYOS    WKBOX   40
     C*                    MVR            RST     60
     C*          RST       IFNE *ZERO
     C*                    ADD  1         WKBOX
     C*                    END
     C*                    ADD  WKBOX     HHK,I
     C*
     C           BASRYO    MULT WKNEC     WKSAIZ  70
     C                     ADD  WKSAIZ    AHK,I
     C*                    MOVE AHHIN     BAHHIN
     C*                    WRITEAH#WP3P1
     C                     END
     C           KEY3      READEAB#PL181                 98
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C*---------------------------------------------------------------*
     C* ORDER QTY.(LOWER LINE:FROM INVESTIGATION DATE TO +10DAYS)
     C*---------------------------------------------------------------*
     C           @QTY2     BEGSR
     C*
     C                     Z-ADD*ZERO     A       20
     C                     Z-ADD10        I
     C*
     C                     DO   10        A
     C                     ADD  1         I
     C                     MOVEA@YMD,I    TBLYMD
     C                     Z-ADD2000      K3YY
     C                     ADD  TBLYY     K3YY
     C                     Z-ADDTBLMM     K3MM
     C                     Z-ADDTBLDD     K3DD
     C*
     C           KEY3      SETLLAB#PL181
     C           KEY3      READEAB#PL181                 98
     C           *IN98     DOWEQ'0'
     C           BASKJY    IFEQ ' '
     C* CALUCULATE
     C*          BAUSYS    IFNE *ZERO
     C*                    Z-ADDBAUSYS    WKSYOS  60
     C*
     C*                    ELSE
     C*          BASYOS    IFNE *ZERO
     C*                    Z-ADDBASYOS    WKSYOS
     C*                    ELSE
     C*                    Z-ADD1         WKSYOS
     C*                    END
     C*                    END
     C*
     C*          BASRYO    DIV  WKSYOS    WKBOX   40
     C*                    MVR            RST     60
     C*          RST       IFNE *ZERO
     C*                    ADD  1         WKBOX
     C*                    END
     C*                    ADD  WKBOX     @HHK,I
     C*
     C           BASRYO    MULT WKNEC     WKSAIZ  70
     C                     ADD  WKSAIZ    @AHK,A
     C*                    WRITEAH#WP3P1
     C                     END
     C           KEY3      READEAB#PL181                 98
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C*---------------------------------------------------------------*
     C* SUMMARY FORECAST DATA
     C*---------------------------------------------------------------*
     C           @FORE     BEGSR
     C*
     C           KEY4      SETLLABBPL021
     C           KEY4      READEABBPL021                 92
     C           *IN92     DOWEQ'0'
     C*
TCHK3C*                    ADD  Q5N1NM    W5N1NM 110
     C                     ADD  Q5NNNM    W5NNNM 110
     C                     ADD  Q51NNM    W51NNM 110
TCHK3C                     ADD  Q52NNM    W52NNM 110
     C*
     C           KEY4      READEABBPL021                 92
     C                     END
     C*
     C                     ENDSR
     C*---------------------------------------------------------------*
     C* SUMMARY PAST 3 MONTHS ACTUAL SHIPPING QTY.
     C*---------------------------------------------------------------*
     C           @PAST     BEGSR
     C*
     C           KEY4      SETLLMBDPL011
     C           KEY4      READEMBDPL011                 91
     C           *IN91     DOWEQ'0'
     C*
     C                     ADD  F3TNSU    W3TNSU 110
     C                     ADD  F3ANSU    W3ANSU 110
     C                     ADD  F3BNSU    W3BNSU 110
     C*
     C           KEY4      READEMBDPL011                 91
     C                     END
