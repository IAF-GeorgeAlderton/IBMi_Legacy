     C           KEY1      REDPEAKBPL041                 98
B01  C           *IN98     DOWEQ'0'
     C*
B02  C           L1SKJY    IFEQ 'D'
     C                     GOTO #READ1
E02  C                     END
     C*
     C                     ADD  1         D
     C           D         IFGT 10
     C                     LEAVE
     C                     ENDIF
     C           L1KSSU    MULT 20        IGK,D
     C                     MOVE L1UKHZ    IGH,D
     C*
B02  C           L1STYY    IFEQ 9999
      *
     C           L1BMON    IFEQ 8990
     C                     MOVE '1'       @ASJ
     C                     ELSE
     C                     MOVE *BLANK    @ASJ    1
     C                     ENDIF
      *
     C           L1BMON    CHAINFGBPL01              92
     C           *IN92     IFEQ *OFF
     C                     MOVELB2SMEI    ISUPNM
     C                     ENDIF
      *
     C                     MOVE L1BMON    K@SUPP
      *
     C                     MOVE L1TKR1    BNT1
     C                     MOVE L1TKR2    BNT2
     C                     MOVE L1TKR3    BNT3
     C                     MOVE L1TKR4    BNT4
      *
     C           BNT2      IFNE *BLANK
     C                     MOVE '-'       BN1
     C                     END
     C           BNT3      IFNE *BLANK
     C                     MOVE '-'       BN2
     C                     END
     C           BNT4      IFNE *BLANK
     C                     MOVE '-'       BN3
     C                     END
     C*
E02  C                     END
     C                     MOVE L1UKHZ    @TRHZ
     C*
     C           #READ1    TAG
     C           KEY1      REDPEAKBPL041                 98
E01  C                     END
     C*
     C*
     C           KEY1      SETGTAKBPL041
     C           #READ2    TAG
     C           KEY1      REDPEAKBPL041                 98
B01  C           *IN98     IFEQ '0'
     C*
B02  C           L1SKJY    IFEQ 'D'
     C                     GOTO #READ2
E02  C                     END
B02  C           L1STHZ    IFNE *ALL'9'
     C                     GOTO #READ2
E02  C                     END
E02  C                     END
