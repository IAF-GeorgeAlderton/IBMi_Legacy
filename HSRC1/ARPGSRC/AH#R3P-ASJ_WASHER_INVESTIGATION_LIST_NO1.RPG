     C                     MOVE *BLANK    @MEMO
     C                     MOVEL*BLANK    @PSON
     C                     Z-ADD*ZERO     @MDAT
     C           KEY9      CHAINAH#PP80              85
     C           *IN85     IFEQ *OFF
     C                     MOVELAHMEMO    @MEMO
     C                     Z-ADDAHYEAR    @MYY
     C                     Z-ADDAHMNTH    @MMM
     C                     Z-ADDAHDAY     @MDD
     C           AHUSER    CHAINRGAPL111             85
     C  N85                MOVELJ8NAME    @PSON
     C                     ENDIF
     C*
