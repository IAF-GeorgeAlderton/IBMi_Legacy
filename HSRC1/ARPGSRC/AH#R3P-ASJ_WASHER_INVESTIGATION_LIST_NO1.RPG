     C* WRITE HEADER
     C*----------------------------------------------------*
     C                     SETOF                     10
     C                     ADD  1         PAG     50
TCHK1C*                    Z-ADD*DATE     WDATE0
TCHK1C                     Z-ADD*DATE     HYMD8
     C                     TIME           STMDT
     C                     Z-ADDITIME     @STIME
     C                     WRITEHED
     C                     SETOF                     21
     C*----------------------------------------------------*
     C* EDIT PART NUMBER
     C*----------------------------------------------------*
     C                     MOVE *BLANK    HINA
     C                     MOVE *BLANK    HINB
     C                     MOVELAHHIN1    HIN1
     C                     MOVELAHHIN2    HIN2
     C                     MOVELAHHIN3    HIN3
      *
B01  C           HIN2      IFNE *BLANK
     C                     MOVEL'-'       HINA
E01  C                     END
      *
B01  C           HIN3      IFNE *BLANK
     C                     MOVEL'-'       HINB
E01  C                     END
     C*---------------------------------------------------------------*
     C* CHANGE GET THE DATE OF INVESTIGATION + 1 DAY
     C*      GET THE DATE OF INVESTIGATION
     C*---------------------------------------------------------------*
     C                     MOVE AHYY      #KHY
     C                     MOVE AHMM      #KHM
     C                     MOVE AHDD      #KHD
     C*---------------------------------------------------------------*
     C*  ..BEFORE 10 DAYS WORKING DAY
     C*---------------------------------------------------------------*
     C           KEY2      SETGTAGDPL121
     C                     Z-ADD11        U       20
     C                     Z-ADD0         @YMD
     C                     Z-ADD0         HMD
     C                     MOVE *BLANK    HCD
     C                     Z-ADD0         CNT     20
      *
B01  C           1         DO   10        I       20
     C                     SETOF                     20
     C                     READPAGDPL121                 99
B02  C           *IN99     IFEQ '0'
B03  C           I         IFEQ 1
     C                     Z-ADDF8YMD     WSYMD   80
E03  C                     END
      *
     C                     Z-ADDF8YMD     WYMD
      *
     C                     SUB  1         U
     C                     Z-ADDF8MD      HMD,U
     C                     Z-ADDF8YMD     @YMD,U
      *
B03  C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       HCD,U
     C*
     C* SUMMARY WORKING DAYS FOR DELIVERY RESULT AVERAGE
     C                     ELSE
     C                     ADD  1         CNT
E03  C                     END
      *
E02  C                     END
E01  C  N99                END
      *
     C                     MOVE WYMD      PYMD1
     C                     MOVE WSYMD     PYMD2
     C*---------------------------------------------------------------*
     C*  AFTER 10 DAYS WORKING DAYS
     C*  FROM INVESTIGATION DAY + 1DAY
     C*---------------------------------------------------------------*
     C                     MOVE AHYY      #KHY
     C                     MOVE AHMM      #KHM
     C                     MOVE AHDD      #KHD
     C           KEY2      SETGTAGDPL121
     C                     Z-ADD0         U       20
     C                     Z-ADD10        Q       20
     C                     Z-ADD10        S       20
     C                     Z-ADD0         @HMD
     C                     MOVE *BLANK    @HCD
      *
B01  C           1         DO   10        I       20
     C                     SETOF                     20
     C                     READ AGDPL121                 99
B02  C           *IN99     IFEQ '0'
B03  C           I         IFEQ 1
     C                     Z-ADDF8YMD     WDATE2           PRTF(FROM)2ND.
     C                     MOVE F8KAYY    FXKAY4
     C                     MOVE F8KAMM    FXKAMM
     C                     MOVE F8KADD    FXKADD
     C                     Z-ADDF8YMD     WKSYMD  80
     C                     Z-ADDF8YMD8    WSYMD8  80
E03  C                     END
      *
     C                     MOVE F8KAYY    FXKAY4
     C                     MOVE F8KAMM    FXKAMM
     C                     MOVE F8KADD    FXKADD
     C                     Z-ADDF8YMD     WKEYMD  80
     C                     Z-ADDF8YMD8    WEYMD8  80
      *
     C                     ADD  1         U
     C                     ADD  1         Q
     C                     ADD  1         S
     C                     Z-ADDF8MD      @HMD,U
     C                     Z-ADDF8YMD     @YMD,S
      *
B03  C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       @HCD,U
E03  C                     END
E02  C                     END
E01  C  N99                END
     C                     Z-ADDF8YMD     @WSYMD           PRTF(TO)2ND.
     C*---------------------------------------------------------------*
     C* HISTORY OF COMPORNENT MASTER & SET LOCATION,CHANGE DATE
     C*---------------------------------------------------------------*
