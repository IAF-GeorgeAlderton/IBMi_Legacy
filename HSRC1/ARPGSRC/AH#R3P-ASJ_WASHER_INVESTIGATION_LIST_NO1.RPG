     C                     EXSR @QTY1                      ORDERED QTY.-10
     C                     EXSR @QTY2                                  +10
     C                     EXSR @FORE                      SUM FORECAST
     C                     EXSR @PAST                      3MONTH PAST ACT.
     C                     ADD  1         WCNT
     C           KEY1      READEMCENP131                 93
E01  C                     END
