     C***********************************************************************
     C* MAIN                                                                *
     C***********************************************************************
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C* INITIAL ROUTINE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4
     C                     PARM           P@SHDT  8
     C                     PARM           P@BIN   2
      *
     C           K#42      KLIST
     C                     KFLD           PUNONY
     C                     KFLD           K@SHDT
     C                     KFLD           PUBINN
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
      *
     C                     MOVEL'EDI856  'K@KWD1
     C                     TIME           @@TIM
     C           P@NONY    IFEQ *BLANK
     C                     MOVE '01'      W@ID    2
     C                     ELSE
     C                     MOVE P@NONY    PUNONY
     C                     MOVE P@SHDT    K@SHDT
     C                     MOVE P@BIN     PUBINN
     C                     EXSR #WRT
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
     C* 1ST SCREEN
     C***********************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C***********************************************************
     C* CHECK 1ST SCREEN
     C***********************************************************
     C           #CHK1     BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     SETOF                     6199
      *
B02  C           D@BAR     CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     MOVE MSG,1     D@MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
     C* WRITE
     C***********************************************************
     C           #WRT      BEGSR
      *
     C                     MOVE PUNONY    K@NONY  4
     C                     CLEARAB#WP2Z1
      *
     C           K#42      CHAINAB#PL42             N90
     C           *IN90     IFEQ *OFF
     C                     MOVELABSPCD    Z2SUPL
     C                     MOVELABASNO    Z2ASNO
     C                     ENDIF
      *
     C           K@NONY    CHAINEDIPL40              90
     C           *IN90     IFEQ *OFF
     C                     MOVELE4ADD1    Z2TAD1
     C                     MOVELE4ADD2    Z2TAD2
     C                     MOVELE4ADD3    Z2TAD3
     C                     MOVELE4ADD4    Z2TAD4
     C                     ENDIF
      *
     C           Z2ASNO    IFEQ *BLANK
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *ON
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     Z-ADD@@YM6     CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     WRITEAB#PPCT1
     C                     Z-ADDCTNBR2    @@NBR   60
     C                     ELSE
     C           CTNBR1    IFEQ @@YM6
     C                     ADD  1         CTNBR2
     C                     ELSE
     C                     Z-ADD@@YM6     CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     Z-ADDCTNBR2    @@NBR
     C                     ENDIF
      *
     C                     Z-ADD@@YM4     W4
     C                     Z-ADD@@NBR     W6
     C                     MOVE WSHP#     Z2ASNO
      *
     C           K#42      SETLLAB#PL42
     C           *IN90     DOUEQ*ON
     C           K#42      READEAB#PL42                  90
     C           *IN90     IFEQ *OFF
     C                     MOVE Z2ASNO    ABASNO
     C                     UPDATAB#PP421
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     WRITEAB#WP2Z1
      *
     C                     ENDSR
