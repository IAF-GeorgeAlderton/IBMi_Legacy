     H            Y.                                    1
     F**ALDRTA ********************************************************
     F* GET STORE IN  ALDPP25                                         *
     F*  2019.09.17      SAKAKI                                       *
     F*****************************************************************
     FALDPL2B IF  E           K        DISK                           UC
      *
     C           *ENTRY    PLIST
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  80
     C                     PARM           P@CODT  80
     C                     PARM           P@COTM  60
     C                     PARM           P#OPN   1
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEALDPL2B
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN ALDPL2B
     C                     ENDIF
      *
     C                     MOVE P@ZENO    K@ZENO  4
     C                     MOVE P@THNO    K@THNO  3
     C                     MOVE P@HTHZ    K@HTHZ  80
      *
     C                     Z-ADD0         P@CODT
     C                     Z-ADD0         P@COTM
      *
     C           AFAKEY    KLIST
     C                     KFLD           P@ZENO
     C                     KFLD           P@THNO
     C                     KFLD           P@PAGE
      *
     C           AFAKES    KLIST
     C                     KFLD           P@ZENO
     C                     KFLD           P@THNO
     C                     KFLD           P@PAGE
     C                     KFLD           K@HTHZ  80
      *
     C           AFAKES    SETLLALDPL2B
     C           AFAKEY    READEALDPL2B                  88
     C           *IN88     DOWEQ'0'
     C           P@CODT    ANDEQ0
     C           A9SKJY    IFEQ 'D'
     C           A9SKDT    ANDLE*DATE
     C                     ELSE
     C           A9OKNG    IFEQ 'OK'
     C                     Z-ADDA9CODT    P@CODT
     C                     Z-ADDA9COTM    P@COTM
     C                     ENDIF
     C                     ENDIF
     C           AFAKEY    READEALDPL2B                  88
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
