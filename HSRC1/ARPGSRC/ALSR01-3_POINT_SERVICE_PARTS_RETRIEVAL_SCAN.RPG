     H            Y.
     F** ALSR01 *********************************************
     F* 3 POINT SERVICE PARTS RETRIEVAL SCAN                *
     F*   LEC .................     2016.02.19              *
JW1  H*   JW  2020.09.04  ADD GDDPP06                       *
"    H*   JW  2020.09.21  ADD GDDPP06                       *
     F*******************************************************
     FALSPW01 CF  E                    WORKSTN
     FFCETL11 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     FALRPL05 IF  E           K        DISK
     FALDPP50 O   E           K        DISK
     FALSPP01 O   E                    DISK
     FKU#PP11 O   E                    DISK                      A
     FAU#NP11 UF  F       9            DISK                      A
     FGDGPP05 O   E           K        DISK
JW1  FGDGPP06 O   E           K        DISK
     FNZUPL01 UF  E           K        DISK
      *
     E                    ER      1   7 60
     IAU#NP11 AA  70
     I                                        1   20AHZMM
     I                                        3   90ARECD
      *
     I            DS
     I                                        1  14 D2SHN
     I                                        1   5 D2SHN1
     I                                        6   6 D2SF1
     I                                        7  11 D2SHN2
     I                                       12  12 D2SF2
     I                                       13  14 D2SHN3
      *
     I            DS
     I                                        1  20 D1BAR
     I                                        5  20 D1XXX
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60HHMMSS
     I                                        7  140WDATE
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
     I            DS
     I                                        1  100CKHZ01
     I                                        1   80CKHZ
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           POPR    6
     C                     PARM           PITANT 10
      *
     C           K#KEY1    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C           DSPSW     WHEQ '02'
     C                     EXSR #SB200
     C           DSPSW     WHEQ '03'
     C                     EXSR #SB300
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *--------------------------------------------------------*
      * FIRST SCREEN - Display Screen for Service Parts Kanban *
      *--------------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     EXFMTALSPW011
     C                     SETOF                     9931
      *
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'99'      DSPSW
     C                     MOVE *BLANKS   D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           D1BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,6      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           D1XXX     IFNE *BLANK
     C                     SETON                     99
     C                     MOVELER,7      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W1SHN1  5
     C                     MOVEL*BLANK    W1SHN2  5
     C                     MOVEL*BLANK    W1SHN3  2
     C                     MOVEL*BLANK    W1TBN1  1
     C                     MOVEL*BLANK    W1TBN2  2
     C                     MOVEL*BLANK    W1TBN3  2
     C                     MOVEL*BLANK    W1TBN4  1
     C                     MOVEL*BLANK    W1ZETI  4
     C                     MOVEL*BLANK    D1ZETI  4
      * get item absolute (zeti)
     C           4         SUBSTD1BAR1:1  D1ZETI
      *
      * get part information from PART INFORMATION M/F
     C           D1ZETI    CHAINFCETL111             21
     C           *IN21     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ *OFF
     C                     MOVELA2BHB1    W1SHN1
     C                     MOVELA2BHB2    W1SHN2
     C                     MOVELA2BHB3    W1SHN3
      *
     C                     TIME           WTIME
      *
     C           A2TRHZ    IFGT WDATE
      * old location code
     C                     MOVELA2KTRK    W1TBN1  1
     C                     MOVELA2KTRT    W1TBN2  2
     C                     MOVELA2KTRR    W1TBN3  2
     C                     MOVELA2KTRD    W1TBN4  1
     C                     ELSE
      * else new location code
     C                     MOVELA2STRK    W1TBN1  1
     C                     MOVELA2STRT    W1TBN2  2
     C                     MOVELA2STRR    W1TBN3  2
     C                     MOVELA2STRD    W1TBN4  1
     C                     ENDIF
      *
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,3      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D2SHN
     C                     MOVELW1SHN1    D2SHN1
     C                     MOVEL'-'       D2SF1
     C                     MOVELW1SHN2    D2SHN2
     C           W1SHN3    IFNE *BLANK
     C                     MOVEL'-'       D2SF2
     C                     MOVELW1SHN3    D2SHN3
     C                     ENDIF
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * SECOND SCREEN - Display Screen for Location Tag    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C                     EXFMTALSPW012
     C                     SETOF                     9931
      *
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'01'      DSPSW
     C                     MOVEL*BLANKS   D2BAR1
     C                     MOVEL*BLANKS   D1BAR1
     C                     GOTO ESB200
     C                     ENDIF
      *
     C           D2BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR1
     C                     GOTO ESB200
     C                     ENDIF
      *
      * CHECK DIGIT - if check digit is not correct, display
      * error screen.
     C                     MOVELD2BAR1    PMAREA
     C                     MOVEL'007'     PMBYTE
     C           1         SUBSTD2BAR1:8  WKCHK   1
     C                     EXSR GETCDG
     C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR1
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W2SHN1  5
     C                     MOVEL*BLANK    W2SHN2  5
     C                     MOVEL*BLANK    W2SHN3  2
     C                     MOVEL*BLANK    W2TBN1  1
     C                     MOVEL*BLANK    W2TBN2  2
     C                     MOVEL*BLANK    W2TBN3  2
     C                     MOVEL*BLANK    W2TBN4  1
      *
     C                     MOVEL*BLANK    D2ZETI  4
     C           4         SUBSTD2BAR1:1  D2ZETI
      *
      * check to make sure it's a match.
     C           D2ZETI    IFNE D1ZETI
     C                     SETON                     99
     C                     MOVELER,5      D9ERR
     C                     EXSR #SB290
     C                     EXSR #SB291
     C                     MOVEL'NG'      WKOKNG  2
     C                     MOVE '05'      ERRCOD  2
     C                     MOVEL*BLANK    D2BAR1
     C                     EXSR #SB500
     C                     GOTO ESB200
     C                     ENDIF
      *
      * get part information from PART INFORMATION M/F
      *
     C           D2ZETI    CHAINFCETL111             21
     C           *IN21     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ *OFF
     C                     MOVELA2BHB1    W2SHN1
     C                     MOVELA2BHB2    W2SHN2
     C                     MOVELA2BHB3    W2SHN3
      *
     C           A2TRHZ    IFGT WDATE
      * old location code
     C                     MOVELA2KTRK    W2TBN1  1
     C                     MOVELA2KTRT    W2TBN2  2
     C                     MOVELA2KTRR    W2TBN3  2
     C                     MOVELA2KTRD    W2TBN4  1
     C                     ELSE
      * else new location code
     C                     MOVELA2STRK    W2TBN1  1
     C                     MOVELA2STRT    W2TBN2  2
     C                     MOVELA2STRR    W2TBN3  2
     C                     MOVELA2STRD    W2TBN4  1
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D2SHN
     C                     MOVELW2SHN1    D2SHN1
     C                     MOVEL'-'       D2SF1
     C                     MOVELW2SHN2    D2SHN2
     C           W2SHN3    IFNE *BLANK
     C                     MOVEL'-'       D2SF2
     C                     MOVELW2SHN3    D2SHN3
     C                     ENDIF
     C                     MOVEL'03'      DSPSW
      *
     CSR         ESB200    ENDSR
      *------------------------------------------------------*
      * SCREEN THREE  - Display Screen to Input APICS KANBAN *
      *------------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     EXFMTALSPW013
     C                     SETOF                     9931
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'02'      DSPSW
     C                     MOVEL*BLANK    D3BAR1
     C                     MOVEL*BLANK    D2BAR1
     C                     GOTO ESB300
     C                     ENDIF
      *
      * if APICS KANBAN is blank, display error and start over.
     C           D3BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,4      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D3BAR1
     C                     GOTO ESB300
     C                     ENDIF
      *
      * CHECK DIGIT - call program to get check digit and compare
      *  to make sure it's correct.
      *
      *  if kanban barcode starts with an "I" then it's a Pass Thru
      *   kanban, so it will be 16 chars instead of 14 like the apics kanban
      *
     C           1         SUBSTD3BAR1:1  BCID
     C           BCID      IFEQ 'I'
     C                     MOVELD3BAR1    PMAREA
     C                     MOVEL'016'     PMBYTE
     C           1         SUBSTD3BAR1:17 WKCHK   1
     C                     ELSE
     C                     MOVELD3BAR1    PMAREA
     C                     MOVEL'014'     PMBYTE
     C           1         SUBSTD3BAR1:15 WKCHK
     C                     ENDIF
      *
     C                     EXSR GETCDG
      *
      * if check digits don't match, display error, go back to screen3.
     C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D3BAR1
     C                     GOTO ESB300
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W3SHN1  5
     C                     MOVEL*BLANK    W3SHN2  5
     C                     MOVEL*BLANK    W3SHN3  2
     C                     MOVEL*BLANK    W3ABN1  1
     C                     MOVEL*BLANK    W3ABN2  2
     C                     MOVEL*BLANK    W3ABN3  2
     C                     MOVEL*BLANK    W3ABN4  1
     C                     MOVEL*BLANK    D3ZETI  4
     C                     Z-ADD0         D3SSYS  50
     C                     MOVEL*BLANK    D3TEHI  1
     C                     MOVEL*BLANK    D3SEHI  1
      *
      * get part information from PART INFORMATION M/F
      *
     C           4         SUBSTD3BAR1:2  D3ZETI
     C           D3ZETI    CHAINFCETL111             21
      *
     C           *IN21     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
      * part number found and not marked for delete.
     C           *IN21     IFEQ *OFF
     C                     MOVELA2BHB1    W3SHN1
     C                     MOVELA2BHB2    W3SHN2
     C                     MOVELA2BHB3    W3SHN3
     C                     MOVELA2TEHI    D3TEHI  1
      *
     C           A2TRHZ    IFGT WDATE
      * old location code
     C                     MOVELA2KTRK    W3ABN1  1
     C                     MOVELA2KTRT    W3ABN2  2
     C                     MOVELA2KTRR    W3ABN3  2
     C                     MOVELA2KTRD    W3ABN4  1
     C                     ELSE
      * else new location code
     C                     MOVELA2STRK    W3ABN1  1
     C                     MOVELA2STRT    W3ABN2  2
     C                     MOVELA2STRR    W3ABN3  2
     C                     MOVELA2STRD    W3ABN4  1
     C                     ENDIF
     C           A2TRHZ    IFGT WDATE
     C                     Z-ADDA2KSYS    D3SSYS  50
     C                     ELSE
     C                     Z-ADDA2SSYS    D3SSYS  50
     C                     ENDIF
      *
     C                     ENDIF
      *
      *
      * check to make sure it's a match.
     C           D3ZETI    IFEQ D1ZETI
     C                     MOVEL'OK'      WKOKNG  2
     C                     MOVE *BLANKS   ERRCOD
     C                     EXSR #SB500
      * display ok screen...
     C                     EXFMTALSPW095
     C                     ELSE
     C                     MOVEL'NG'      WKOKNG  2
     C                     MOVE '07'      ERRCOD
     C                     EXSR #SB500
     C                     MOVEL*BLANK    D3BAR1
     C                     SETON                     99
     C                     MOVELER,7      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB300
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEL*BLANK    D2BAR1
     C                     MOVEL*BLANK    D3BAR1
     C                     MOVEL'01'      DSPSW
      *
     CSR         ESB300    ENDSR
      *
      *-----------------------------------------------------------------------*
      * ALSPP01 - Write Record to Service Parts Retrieval Scan File           *
      *  If APICS KANBAN, Update Id/Lot/Page                                  *
      *  Else, PT KANBAN, Update Id/Order#/Lot#                               *
      *-----------------------------------------------------------------------*
     C           #SB500    BEGSR
      *
      * write to ALSPP01
     C                     TIME           WTIME
     C                     CLEARALSPP011
     C                     Z-ADDWDATE     ASKODT
     C                     Z-ADDHHMMSS    ASKOTM
     C                     MOVELW#WSID    ASWSID
     C                     MOVELPITANT    ASUSER
     C                     MOVELW#JBNO    ASJOBN
     C                     MOVELW#PGM     ASKOPG
     C                     MOVELPOPR      ASWKCD
     C                     Z-ADDWDATE     ASCODT
     C                     Z-ADDHHMMSS    ASCOTM
      *
     C                     MOVELD1BAR1    ASRBAR
     C                     MOVELW1SHN1    ASRHN1
     C                     MOVELW1SHN2    ASRHN2
     C                     MOVELW1SHN3    ASRHN3
     C                     MOVELD1ZETI    ASRZET
     C           3         SUBSTD1BAR1:6  ASRTEH
     C           2         SUBSTD1BAR1:9  ASRPAG
     C                     MOVELW1TBN1    ASRBN1
     C                     MOVELW1TBN2    ASRBN2
     C                     MOVELW1TBN3    ASRBN3
     C                     MOVELW1TBN4    ASRBN4
      *
     C                     MOVELD2BAR1    ASLBAR
     C                     MOVELW2SHN1    ASLHN1
     C                     MOVELW2SHN2    ASLHN2
     C                     MOVELW2SHN3    ASLHN3
     C                     MOVELW2TBN1    ASTBN1
     C                     MOVELW2TBN2    ASTBN2
     C                     MOVELW2TBN3    ASTBN3
     C                     MOVELW2TBN4    ASTBN4
      *
     C                     MOVELD3BAR1    ASABAR
     C                     MOVELD3ZETI    ASAZET
     C                     MOVELW3SHN1    ASAHN1
     C                     MOVELW3SHN2    ASAHN2
     C                     MOVELW3SHN3    ASAHN3
     C                     MOVELW3ABN1    ASABN1
     C                     MOVELW3ABN2    ASABN2
     C                     MOVELW3ABN3    ASABN3
     C                     MOVELW3ABN4    ASABN4
      *
      * PASS THRU kanban barcodes start with an I...
      * if barcode is a pass thru kanban, then blank out
      * apics product and page numbers.
     C           1         SUBSTD3BAR1:1  BCID    1
     C           BCID      IFEQ 'I'
     C                     MOVE *BLANKS   ASTEHA
     C                     MOVE *BLANKS   ASPAGE
     C           6         SUBSTD3BAR1:6  ASPTOR
     C           4         SUBSTD3BAR1:13 ASPTLT
     C           1         SUBSTD3BAR1:12 D3SEHI  1
     C                     ELSE
     C           3         SUBSTD3BAR1:6  ASTEHA
     C           2         SUBSTD3BAR1:9  ASPAGE
     C                     MOVE *BLANKS   ASPTOR
     C                     MOVE *BLANKS   ASPTLT
     C                     ENDIF
      *
     C                     MOVELWKOKNG    ASOKNG
     C                     MOVELERRCOD    ASERCD
     C                     WRITEALSPP011
     C           WKOKNG    IFEQ 'OK'
      * PASS THRU GDGPP05
      * NOT PASS THRU AU#PP11
     C           BCID      IFEQ 'I'
     C           BCID      OREQ 'S'
     C                     EXSR #ASJ
     C                     ELSE
     C                     EXSR @AU#11
     C                     EXSR UPDSHP
     C                     EXSR #ASJ#2
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * Call Program to Get Check Digit                    *
      *----------------------------------------------------*
     C           GETCDG    BEGSR
      *
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        INPUT DATA
     C                     PARM           PMBYTE  3        LENGTH
     C                     PARM           PMCHK   1        CHECKS DIGITS
     C                     PARM           PMRTCD  1        RETRN CODE
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * ERROR SCREEN - Display Error on Screen             *
      *----------------------------------------------------*
     C           #SB290    BEGSR
      *
     C                     WRITEALSPW098
     C                     EXFMTALSPW099
      *
     C                     ENDSR
      *----------------------------------------------------*
      * BLANK OUT - Fields for Screen 3.                   *
      *----------------------------------------------------*
     C           #SB291    BEGSR
      *
     C                     MOVEL*BLANK    W3SHN1
     C                     MOVEL*BLANK    W3SHN2
     C                     MOVEL*BLANK    W3SHN3
     C                     MOVEL*BLANK    W3ABN1
     C                     MOVEL*BLANK    W3ABN2
     C                     MOVEL*BLANK    W3ABN3
     C                     MOVEL*BLANK    W3ABN4
     C                     MOVEL*BLANK    D3ZETI
     C                     MOVEL*BLANK    D3BAR1
     C                     Z-ADD0         D3SSYS  50
     C                     MOVEL*BLANK    D3TEHI  1
     C                     MOVEL*BLANK    D3SEHI  1
      *
     C                     ENDSR
      *----------------------------------------------------*
     C**************************************************************************
     C* KU#PP11 WRITE
     C**************************************************************************
     C           @AU#11    BEGSR
     C*
     C                     CLEARKU#PP111
     C                     Z-ADDWSSYYY    KQKOYY
     C                     Z-ADDWSSMMM    KQKOMM
     C                     Z-ADDWSSDDD    KQKODD
     C                     Z-ADDWSSHHH    KQKOHH
     C                     Z-ADDWSSNNN    KQKOSS
     C                     MOVELW#PGM     KQKOME
      *
     C                     Z-ADD0         KQTOKU
     C                     MOVEL*BLANK    KQTKOJ
     C                     MOVEL*BLANK    KQTUKE
     C                     MOVEL0         KQNONY
     C                     MOVEL*BLANK    KQNKOJ
     C                     MOVEL*BLANK    KQNUKE
     C                     MOVELW3SHN1    KQSHN1
     C                     MOVELW3SHN2    KQSHN2
     C                     MOVELW3SHN3    KQSHN3
     C                     MOVEL*BLANK    KQMHN1
     C                     MOVEL*BLANK    KQMHN2
     C                     MOVEL*BLANK    KQMHN3
     C                     MOVEL*BLANK    KQSEBN
     C                     MOVE *BLANK    KQKANR
     C                     MOVEL*BLANK    KQNOCR
     C                     MOVELD3SSYS    W@SYOS  50
     C                     Z-ADDW@SYOS    KQSRYO
     C                     MOVEL'C'       KQTANI
     C                     MOVEL'C'       KQNSYK
     C*
     C                     Z-ADDWSSYYY    KQTHYY
     C                     Z-ADDWSSMMM    KQTHMM
     C                     Z-ADDWSSDDD    KQTHDD
     C*
     C                     Z-ADD1         KQCIC1
     C                     Z-ADD1         KQCIC2
     C                     Z-ADD1         KQCIC3
     C                     Z-ADDWSSHHH    KQTHJI
     C                     Z-ADDWSSNNN    KQTHPN
     C                     Z-ADDWSSHHH    KQURJI
     C                     Z-ADDWSSNNN    KQURPN
     C*
     C                     MOVELW3ABN1    KQSBKJ
     C                     MOVELW3ABN2    KQSBRO
     C                     MOVELW3ABN3    KQSBRT
     C                     MOVELW3ABN4    KQSBDN
     C*
     C                     Z-ADDWSSYYY    KQNOYY
     C                     Z-ADDWSSMMM    KQNOMM
     C                     Z-ADDWSSDDD    KQNODD
     C                     MOVEL'01'      KQNOBB
     C                     MOVE D3TEHI    KQTHAI
     C*
     C                     MOVEL'K'       KQSKKB
     C                     Z-ADD1         KQHAKO
     C                     Z-ADDW@SYOS    KQSYUY
     C                     Z-ADDWSSYYY    KQURYY
     C                     Z-ADDWSSMMM    KQURMM
     C                     Z-ADDWSSDDD    KQURDD
     C*
     C                     MOVEL'S'       KQDTSY
     C                     MOVEL'4'       KQDTSO
     C           KQSBRO    IFEQ '52'
     C           KQSBRO    OREQ '53'
     C                     MOVEL'51'      KQGYOM
     C                     ELSE
     C                     MOVEL'05'      KQGYOM
     C                     ENDIF
      *
     C                     SETOF                     96
     C           1         CHAINAU#NP11              96
     C           *IN96     IFEQ '0'
     C           AHZMM     IFNE UMONTH
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     ELSE
     C                     ADD  1         ARECD
     C                     ENDIF
     C                     EXCPTUP
     C                     ELSE
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     EXCPTWT
     C                     ENDIF
     C*
     C                     Z-ADDARECD     KQJTNO
     C*
     C                     Z-ADDWSSDAT    KQSSHZ
     C                     Z-ADDWSSTM6    KQSSTI
     C                     Z-ADD0         KQNKHZ
     C                     Z-ADD0         KQNKTI
     C                     Z-ADD0         KQAPHZ
     C                     Z-ADD0         KQAPBN
     C                     WRITEKU#PP111
     C*
     C                     ENDSR
     C**************************************************************************
     C*      WRITE RECORDS IN ORDER FILE TO ASJ
     C**************************************************************************
     C           #ASJ      BEGSR
      *
     C                     CLEARGDGPP051
     C                     Z-ADDWSSYYY    IAKOYY
     C                     Z-ADDWSSMMM    IAKOMM
     C                     Z-ADDWSSDDD    IAKODD
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
     C                     MOVELW#PGM     IAKOME
     C                     MOVE ASPTOR    IAODER
     C                     MOVE ASPTLT    IARENB
     C                     MOVE D3ZETI    IAZETI
     C                     MOVE D3SEHI    IASEIH
     C                     MOVE W3SHN1    IAHIN1
     C                     MOVE W3SHN2    IAHIN2
     C                     MOVE W3SHN3    IAHIN3
     C                     Z-ADDD3SSYS    IASYOS
     C                     ADD  1         IAMAIS
     C                     Z-ADDWSSYYY    IAHAYY
     C                     Z-ADDWSSMMM    IAHAMM
     C                     Z-ADDWSSDDD    IAHADD
     C                     WRITEGDGPP051
JW1   * OUT GDGPP06
     C                     MOVEL'1'       IAFLG1
JW1  C                     MOVE 'N'       PTFLG
     C                     EXSR #PP06
      *
     C                     ENDSR
      **************************************************************************
      *  if first process is KN then write to ASJ order file.
      **************************************************************************
      *
     C           #ASJ#2    BEGSR
      *
      * get part number process information...
     C           K#KEY1    CHAINAAMPL11              51
     C           *IN51     IFEQ *OFF
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLEWSSDAT
     C                     GOTO @ENDA2
     C                     ENDIF
      *
      * if first process is KN,  then an order entry needs to be written to ASJ
     C           *IN51     IFEQ *OFF
      *
     C           WSSDAT    IFGE CKHZ
     C           CKKO01    ANDEQ'KN'
     C           WSSDAT    ORLT CKHZ
     C           CKQK01    ANDEQ'KN'
      *
     C                     CLEARGDGPP051
     C                     Z-ADDWSSYYY    IAKOYY
     C                     Z-ADDWSSMMM    IAKOMM
     C                     Z-ADDWSSDDD    IAKODD
     C                     MOVELPOPR      IAKOME
     C                     MOVE 'T'       IAKOME
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
      *
     C                     MOVE D3ZETI    IAZETI
     C                     MOVE W3SHN1    IAHIN1
     C                     MOVE W3SHN2    IAHIN2
     C                     MOVE W3SHN3    IAHIN3
     C                     Z-ADDD3SSYS    IASYOS
     C                     ADD  1         IAMAIS
     C                     Z-ADDWSSYYY    IAHAYY
     C                     Z-ADDWSSMMM    IAHAMM
     C                     Z-ADDWSSDDD    IAHADD
      *
      * get ASJ P/T order info...
     C                     MOVELD3BAR1    PTABAR
     C**JW3      PTABAR    CHAINALRPP051             51
JW1   * GET LATEST KANBAN
"    C           PTABAR    SETGTALRPL05
"    C           PTABAR    REDPEALRPL05                  51
      *
      *
      * if APICS is found, get P/T ord#, product code, lot#
     C           *IN51     IFEQ *OFF
JW1  C                     MOVE 'Y'       PTFLG   1
     C                     MOVE PTODER    IAODER
     C                     MOVE PTPRCD    IASEIH
     C                     MOVE PTLOTN    IARENB
     C                     ELSE
      *
JW1  C                     MOVE 'N'       PTFLG
     C                     MOVE *BLANKS   IAODER
     C                     MOVE '0'       IASEIH
     C                     MOVE *BLANKS   IARENB
      *
      * APICS not scanned, so write info to error log....
     C                     MOVE '30'      A5ERID
     C                     MOVE '03'      A5ERPS
     C                     Z-ADDWSSDAT    A5KSDT
     C                     Z-ADDWSSTM6    A5KSTM
     C                     MOVELPOPR      A5OPER
     C                     MOVELD1BAR1    A5SERL
     C                     MOVEL*BLANK    A52DBC
     C                     MOVELD1BAR1    A5FIL1
     C                     MOVELD2BAR1    A5FIL2
     C                     MOVELD3BAR1    A5FIL3
      *
     C                     WRITEALDPP501
      *
     C                     ENDIF
      *
     C                     WRITEGDGPP051
JW1   * OUT GDGPP06
     C                     MOVEL'2'       IAFLG1
     C                     EXSR #PP06
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           @ENDA2    ENDSR
      **************************************************************************
JW1   *  OUTPUT GDGPP06
      **************************************************************************
JW1  C           #PP06     BEGSR
      *
     C                     MOVELPTFLG     IAPFLG
     C                     MOVELPTABAR    IAABAR
     C           PTFLG     IFEQ 'Y'
     C                     MOVELPTODER    IAPDER
     C                     MOVELPTLOTN    IAPOTN
     C                     MOVELPTPBAR    IAPBAR
     C                     MOVELPTTBN1    IAPBN1
     C                     MOVELPTTBN2    IAPBN2
     C                     MOVELPTTBN3    IAPBN3
     C                     MOVELPTTBN4    IAPBN4
     C                     ELSE
     C                     MOVE *BLANK    IAPDER
     C                     MOVE *BLANK    IAPOTN
     C                     MOVE *BLANK    IAPBAR
     C                     MOVE *BLANK    IAPBN1
     C                     MOVE *BLANK    IAPBN2
     C                     MOVE *BLANK    IAPBN3
     C                     MOVE *BLANK    IAPBN4
     C                     ENDIF
      *
     C                     Z-ADD0         IAODDT
     C                     Z-ADD0         IAODTM
     C                     MOVE *BLANK    IAFLG2
      *
     C                     Z-ADDWDATE     IACRDT
     C                     Z-ADDHHMMSS    IACRTM
     C                     MOVELW#USER    IACRME
     C                     MOVELW#PGM     IACRPG
      *
     C                     WRITEGDGPP061
      *
JW1  C                     ENDSR
      **************************************************************************
      * Update NZUPL01 with Shipment Date and Time         *
      *----------------------------------------------------*
      *
     C           UPDSHP    BEGSR
      *
      * update NZUPL01
      *
     C           N2KEY     KLIST
     C                     KFLD           ASAZET
     C                     KFLD           ASTEHA
     C                     KFLD           ASPAGE
     C*
     C           N2KEY     SETGTNZUPL011
     C           N2KEY     REDPENZUPL011                 51
      *
      * if id/lot/page num is found, update record and leave.
     C           *IN51     DOWEQ*OFF
     C           N2SKJY    IFEQ *BLANK
     C           N2DEHZ    ANDEQ*ZERO
     C                     Z-ADDWSSDAT    N2KOHZ
     C                     Z-ADDWSSTM6    N2KOTI
     C                     MOVELPITANT    N2KOME
     C                     MOVELW#PGM     N2KOPG
     C                     Z-ADDWSSDAT    N2DEHZ
     C                     Z-ADDWSSTM6    N2DETI
     C                     UPDATNZUPL011
     C                     LEAVE
     C                     ENDIF
     C           N2KEY     REDPENZUPL011                 51
     C                     ENDDO
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
     OAU#NP11 E                UP
     O                         AHZMM      2
     O                         ARECD      9
     O        EADD             WT
     O                         AHZMM      2
     O                         ARECD      9
**
INPUT LOCATION BARCODE.
CHECK DIGIT ERROR.
PARTS MASTER ERROR.
INPUT APICS/PT KANBAN.
INVALID LOCATION.
INPUT RETRIEVAL KANBAN.
WRONG KANBAN.
