     H            Y.
     F** AFGR04 *********************************************
     F* UPDATE AFGWP02 BY GREAT PLAINS DATA                 *
     F*             T.SAKAKI       2016.11.13               *
     F******************************************* AFGR04 ****
     FEDIPP60 IF  E           K        DISK
     FAFGWP02 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
     I                                        7  100WYYYY
     I                                       11  120WMMMM
     I                                       13  140WDDDD
      *
     I            DS
     I                                        1  20 E6VPH1
     I                                        1   3 E6VP1
     I                                        4   6 E6VP2
     I                                        7  10 E6VP3
     I                                       11  14 E6VP4
     I            DS
     I                                        1  12 W6VPH1
     I                                        1   3 W6VP1
     I                                        4   4 W6VH1
     I                                        5   7 W6VP2
     I                                        8   8 W6VH2
     I                                        9  12 W6VP3
     I            DS
     I                                        1  20 E6PHN1
     I                                        1   3 E6SP1
     I                                        4   6 E6SP2
     I                                        7  10 E6SP3
     I                                       11  14 E6SP4
     I            DS
     I                                        1  12 W6PHN1
     I                                        1   3 W6SP1
     I                                        4   4 W6SH1
     I                                        5   7 W6SP2
     I                                        8   8 W6SH2
     I                                        9  12 W6SP3
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *-----------------------------------------------------
      *  ENTRY LIST
      *-----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P1SUPP  4
     C                     PARM           P1ODNO  60
     C                     PARM           P1GPPO 17
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1OKNG  2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
     C           KEY1      KLIST
     C                     KFLD           P1SUPP
     C                     KFLD           P1ODNO
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           SDATE
      *
     C* CHAIN EDIPP60
     C           P1GPPO    CHAINEDIPP601             80
     C           *IN80     IFEQ '0'
     C*
     C                     EXSR #SB500
     C*
     C                     ELSE
      *
     C                     MOVEL'NG'      P1OKNG
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  WRITE  AFGWP02
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEY1      CHAINAFGWP021             92
     C           *IN92     IFEQ *OFF
     C                     MOVELP1SUPP    AWSUPP
     C                     Z-ADDP1ODNO    AWODNO
     C                     MOVELP1SHN1    AWPAR1
     C                     MOVELP1SHN2    AWPAR2
     C                     MOVELP1SHN3    AWPAR3
     C                     MOVELP1GPPO    AWGPPO
     C                     MOVELE6REV#    AWREVN
     C                     MOVELE6VNAM    AWVDNM
     C                     MOVELE6VAD1    AWVDA1
     C                     MOVELE6VAD2    AWVDA2
     C                     MOVELE6VCTY    AWVDCI
     C                     MOVELE6VSTT    AWVDST
     C                     MOVELE6VZIP    AWVDZI
     C                     MOVEL'US'      AWVDCT
     C* VENDOR PHONE
     C                     MOVELE6VP1     W6VP1
     C                     MOVEL'-'       W6VH1
     C                     MOVELE6VP2     W6VP2
     C                     MOVEL'-'       W6VH2
     C                     MOVELE6VP3     W6VP3
     C*
     C                     MOVELW6VPH1    AWVDPN
     C                     MOVELE6VP4     AWVDPE
     C*
     C                     MOVELE6WNM     AWSTNM
     C                     MOVELE6WAD1    AWSTA1
     C                     MOVELE6WAD2    AWSTA2
     C                     MOVELE6WCTY    AWSTCI
     C                     MOVELE6WSTT    AWSTST
     C                     MOVELE6WZIP    AWSTZI
     C                     MOVEL'US'      AWSTCT
     C* IAF PHONE
     C           E6PHN1    IFEQ *BLANK
     C                     MOVEL'317'     W6SP1
     C                     MOVEL'-'       W6SH1
     C                     MOVEL'467'     W6SP2
     C                     MOVEL'-'       W6SH2
     C                     MOVEL'0100'    W6SP3
     C                     MOVELW6PHN1    AWSTPN
     C                     MOVEL'0000'    AWSTPE
     C                     ELSE
     C                     MOVELE6SP1     W6SP1
     C                     MOVEL'-'       W6SH1
     C                     MOVELE6SP2     W6SP2
     C                     MOVEL'-'       W6SH2
     C                     MOVELE6SP3     W6SP3
     C                     MOVELW6PHN1    AWSTPN
     C                     MOVELE6SP4     AWSTPE
     C                     ENDIF
     C*
     C                     MOVELE6PYTM    AWPAYT
     C                     MOVELE6BYID    AWCONF
     C                     MOVELE6SHMD    AWSHPM
     C                     MOVELE6VHIN    AWINBR
     C                     MOVELE6DESC    AWITDS
     C                     Z-ADDE6MDDT    AWREQD
     C                     MOVELE6FOB     AWFONB
     C                     MOVELE6UM      AWUOME
     C*
     C                     Z-ADDE6ODQT    AWORDQ
     C                     Z-ADDE6UP      AWUNTP
     C                     Z-ADDE6EXT     AWEXTP
     C                     MOVELE6COM1    AWCMT1
     C                     MOVELE6COM2    AWCMT2
     C                     MOVELE6COM3    AWCMT3
     C                     MOVELE6COM4    AWCMT4
     C                     UPDATAFGWP021
     C                     MOVEL'OK'      P1OKNG
      * WRITE
     C                     ELSE
     C                     CLEARAFGWP021
     C                     MOVELP1SUPP    AWSUPP
     C                     Z-ADDP1ODNO    AWODNO
     C                     MOVELP1SHN1    AWPAR1
     C                     MOVELP1SHN2    AWPAR2
     C                     MOVELP1SHN3    AWPAR3
     C                     MOVELP1GPPO    AWGPPO
     C                     MOVELE6REV#    AWREVN
     C                     MOVELE6VNAM    AWVDNM
     C                     MOVELE6VAD1    AWVDA1
     C                     MOVELE6VAD2    AWVDA2
     C                     MOVELE6VCTY    AWVDCI
     C                     MOVELE6VSTT    AWVDST
     C                     MOVELE6VZIP    AWVDZI
     C                     MOVEL'US'      AWVDCT
     C* VENDOR PHONE
     C                     MOVELE6VP1     W6VP1
     C                     MOVEL'-'       W6VH1
     C                     MOVELE6VP2     W6VP2
     C                     MOVEL'-'       W6VH2
     C                     MOVELE6VP3     W6VP3
     C*
     C                     MOVELW6VPH1    AWVDPN
     C                     MOVELE6VP4     AWVDPE
     C*
     C                     MOVELE6WNM     AWSTNM
     C                     MOVELE6WAD1    AWSTA1
     C                     MOVELE6WAD2    AWSTA2
     C                     MOVELE6WCTY    AWSTCI
     C                     MOVELE6WSTT    AWSTST
     C                     MOVELE6WZIP    AWSTZI
     C                     MOVEL'US'      AWSTCT
     C* IAF PHONE
     C           E6PHN1    IFEQ *BLANK
     C                     MOVEL'317'     W6SP1
     C                     MOVEL'-'       W6SH1
     C                     MOVEL'467'     W6SP2
     C                     MOVEL'-'       W6SH2
     C                     MOVEL'0100'    W6SP3
     C                     MOVELW6PHN1    AWSTPN
     C                     MOVEL'0000'    AWSTPE
     C                     ELSE
     C                     MOVELE6SP1     W6SP1
     C                     MOVEL'-'       W6SH1
     C                     MOVELE6SP2     W6SP2
     C                     MOVEL'-'       W6SH2
     C                     MOVELE6SP3     W6SP3
     C                     MOVELW6PHN1    AWSTPN
     C                     MOVELE6SP4     AWSTPE
     C                     ENDIF
     C*
     C                     MOVELE6PYTM    AWPAYT
     C                     MOVELE6BYID    AWCONF
     C                     MOVELE6SHMD    AWSHPM
     C                     MOVELE6VHIN    AWINBR
     C                     MOVELE6DESC    AWITDS
     C                     Z-ADDE6MDDT    AWREQD
     C                     MOVELE6FOB     AWFONB
     C                     MOVELE6UM      AWUOME
     C*
     C                     Z-ADDE6ODQT    AWORDQ
     C                     Z-ADDE6UP      AWUNTP
     C                     Z-ADDE6EXT     AWEXTP
     C                     MOVELE6COM1    AWCMT1
     C                     MOVELE6COM2    AWCMT2
     C                     MOVELE6COM3    AWCMT3
     C                     MOVELE6COM4    AWCMT4
      *
     C                     WRITEAFGWP021
     C                     MOVEL'OK'      P1OKNG
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
