     H            Y/                                    1
     H***INVR30*****************************************************************
     H* INVENTORY ENTRY                                                        *
     H*        09/30/03
     H*
     H**************************************************************************
     FINVPW30 CF  E                    WORKSTN
     FFCEPL03 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FINVPL10 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     E                    ERR     1   2 68
      **************************************************************************
     I            DS
     I                                        1   80A2TADT
     I                                        1   40A2TAYY
     I                                        5   60A2TAMM
     I                                        7   80A2TADD
     I            DS
     I                                        1   80A2UTDT
     I                                        1   40A2UTYY
     I                                        5   60A2UTMM
     I                                        7   80A2UTDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1           APICS
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C           K#INV     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     KFLD           W@DAT1
     C           K#INVX    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     MOVE *ALL'-'   @LINE  78
     C                     MOVE '01'      @@ID    2
     C*
     C                     ENDSR
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVEA'00'      *IN,61                       F5
     C                     MOVE *BLANK    D@ERR
      *
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FROM    D@TO
     C                     ENDIF
      *
     C           D@FROM    IFEQ *ZERO
     C                     SETON                     9961
     C                     MOVE ERR,1     D@ERR
     C                     ENDIF
      *
     C           D@TO      IFLT D@FROM
     C  N99                MOVE ERR,1     D@ERR
     C                     SETON                     996162
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     WRITE DATA
     C**************************************************************************
     C           #WRT      BEGSR
      *
     C                     Z-ADDD@FROM    W@DAT1  80
     C                     Z-ADDD@TO      W@DAT2  80
     C                     TIME           @TIME   60
     C                     Z-ADD*ZERO     @TOTL  130
      *
     C           *LOVAL    SETLLFCEPL03
     C           *IN85     DOUEQ*ON
     C                     READ FCEPL03                  85
     C           *IN85     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
      *
     C                     Z-ADD*ZERO     @KANS   70
     C           K#INV     SETLLINVPL10
     C           *IN80     DOUEQ*ON
     C           K#INVX    READEINVPL10                  80
     C           *IN80     IFEQ *OFF
     C           IVSKJY    ANDEQ*BLANK
     C           IVDATE    IFGT W@DAT2
     C                     LEAVE
     C                     ENDIF
     C                     ADD  IVKANS    @KANS
     C                     ENDIF
     C                     ENDDO
      *
     C           @KANS     IFEQ *ZERO
     C           K#INVX    CHAINFCEPL01              90
     C           A2TADT    IFGT *DATE
     C           A2UTDT    ORLE *DATE
     C           A2UTDT    ANDGT*ZERO
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
      *
     C                     EXCPT@DTL
     C                     ADD  @KANS     @TOTL
      *
     C                     ENDIF
     C                     ENDDO
      *
     C   98                EXCPT@TOT
      *
     C                     ENDSR
      *-------------------------------------------------
     OQPRINT  E   03           @HED
     O                         #PGM      12
     O                                   40 'INVENTORY CHECK LIST'
     O                         D@FROM    51 '    /  /  '
     O                                   52 '-'
     O                         D@TO      62 '    /  /  '
     O                         UDATE Y   73
     O                                   76 'P.'
     O                         PAGE  Z   80
     O        E   04           @HED
     O                         @TIME     73 '  :  :  '
     O        E   05           @HED
     O                                   11 'LOCATION'
     O                                   20 'PART#'
     O                                   40 '# OF BOXES'
     O        E   06           @HED
     O                         @LINE     80
     O        E 1              @DTL
     O                         A2STRK     4
     O                                    5 '-'
     O                         A2STRT     7
     O                                    8 '-'
     O                         A2STRR    10
     O                                   11 '-'
     O                         A2STRD    12
     O                         A2BHB1    20
     O                         A2BHB2    26
     O                         A2BHB3    29
     O                         @KANS 1   40
     O        E 1              @TOT
     O                         @LINE     80
     O        E 1              @TOT
     O                                   10 'TOTAL'
     O                         @TOTL 1   40
