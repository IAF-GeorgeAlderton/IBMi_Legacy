     H            Y.
     F** UTLR82 ****************************************************************
     F*  GET A-PICS STATUS BY IAF PART#,LOT,PAGE (NZUPP01)                     *
     F*  T.SAKAKI        2021.07.30                                            *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR82'
     F*                    PARM           $DATE   80
     F*                    PARM           $KANR   1
     F*                    PARM           $SZET   4
     F*                    PARM           $STHI   3
     F*                    PARM           $SPAG   2
     F*                    PARM           $NYHZ   80
     F*                    PARM           $NYTI   60
     F*                    PARM           $DEHZ   80
     F*                    PARM           $DETI   60
     F*                    PARM           $RTN    1
     F*
     F*   IN  $DATE :  8S 0 BASE DATE
     F*   IN  $KANR :  1A   MANAGEMENT
     F*   IN  $SZET :  4A   ID #
     F*   IN  $STHI :  3A   LOT #
     F*   IN  $SPAG :  2A   PAGE #
     F*
     F*   OUT $NYHZ :  8S 0 STORE IN DATE
     F*   OUT $NYTI :  6S 0 STORE IN TIME
     F*   OUT $DEHZ :  8S 0 SHIPMENT DATE
     F*   OUT $DETI :  6S 0 SHIPMENT TIME
     F*   OUT $RTN  :  1A RETURN FLAG (BLANK=OK, *=ERROR)
     F**************************************************************************
     FNZUPL06 IF  E           K        DISK
      *----------------------------------------------------*
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *----------------------------------------------------*
      *     ENTRY LIST                                     *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           $DATE   80
     C                     PARM           $HIN1   5
     C                     PARM           $HIN2   5
     C                     PARM           $HIN3   2
     C                     PARM           $KANR   1
     C                     PARM           $SZET   4
     C                     PARM           $STHI   3
     C                     PARM           $SPAG   2
     C                     PARM           $NYHZ   80
     C                     PARM           $NYTI   60
     C                     PARM           $DEHZ   80
     C                     PARM           $DETI   60
     C                     PARM           $RTN    1
      *----------------------------------------------------*
      *               KEY LIST                             *
      *----------------------------------------------------*
     C           KEYN11    KLIST
     C                     KFLD           K#SHN1  5
     C                     KFLD           K#SHN2  5
     C                     KFLD           K#SHN3  2
     C                     KFLD           K#HAHZ  80
      *----------------------------------------------------*
      *                    MAIN ROUTINE                    *
      *----------------------------------------------------*
     C                     EXSR #INIT
      * SET KEY
     C                     Z-ADD0         @REC    60
     C           KEYN11    SETLLNZUPL06
     C                     DO   *HIVAL
     C           KEYN12    READENZUPL02                  81
     C   81                LEAVE
      *
     C                     ADD  1         @REC
     C                     SELEC
     C           N2DEHZ    WHNE 0
     C                     ADD  1         @IN
     C                     ADD  1         @OUT
     C           N2NYHZ    WHNE 0
     C                     ADD  1         @IN
     C                     ENDSL
      *
     C                     ENDDO
      *
     C           @IN       SUB  @OUT      @INV
     C                     MOVEL@INV      $INV
      * PART NOT EXIST
     C           @REC      IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
