      *** GDJR11 *************************************
      *        INVENTORY DATA CONVERSION             *
      *  G.B.C                         97/05/27      *
      ************************************************
     H            Y/                                    1
     FGDJPW11 CF  E                    WORKSTN
     FGDJPP15 IF  E           K        DISK
     FGDJPP01 IF  E           K        DISK
     FGDJPP20 O   E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
     E                    MSG     1   5 30               ERROR MESSAGE
     I            DS
     I                                        1  17 IOBAR
     I                                        1   1 IOBAR1
     I                                        2   5 IOBAR2
     I                                        6  13 IOKATA
     I                                        9  11 IOKOTE
     I                                       12  12 IOBAR3
     I            DS
     I                                        1  12 WWHIN
     I                                        1   5 WWHIN1
     I                                        6  10 WWHIN2
     I                                       11  12 WWHIN3
     I                                        1   2 WWDIE1
     I                                        3   6 WWDIE2
     I                                        7   7 WWDIE3
     I                                        8   8 WWDIE4
     I            DS
     I                                        1  12 @WHIN
     I                                        1   5 @WHIN1
     I                                        6  10 @WHIN2
     I                                       11  12 @WHIN3
     I                                        1   2 @WDIE1
     I                                        3   6 @WDIE2
     I                                        7   7 @WDIE3
     I                                        8   8 @WDIE4
     I            DS
     I                                        1  14 S1PART
     I                                        1   5 S1HIN1
     I                                        6   6 S1HW1
     I                                        7  11 S1HIN2
     I                                       12  12 S1HW2
     I                                       13  14 S1HIN3
     I                                        1   2 S1DIE1
     I                                        3   3 S1DW1
     I                                        4   7 S1DIE2
     I                                        8   8 S1DW2
     I                                        9   9 S1DIE3
     I                                       10  10 S1DW3
     I                                       11  11 S1DIE4
     I                                       12  14 S1DW4
     I            DS
     I                                        1   80DDDATE
     I                                        1   20DDDATM
     I                                        3   40DDDATD
     I                                        5   80DDDATY
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C           ##1       TAG
     C                     EXSR #INIT
     C*** DSP01 ***
     C           ##2       TAG
     C                     DO   *HIVAL
     C                     READ GDJPP15                  90
     C           *IN90     IFEQ '0'
     C*
     C                     Z-ADD0         ERSW    20
     C                     EXSR #CHK
     C           ERSW      IFEQ 0
     C                     Z-ADD@@DEP     IPBUMN           DEP
     C                     MOVE IOKKBN    IPKKBN           PROCESS CLASS
     C                     MOVE WWHIN1    IPHIN1           PARTS NO.1
     C                     MOVE WWHIN2    IPHIN2           PARTS NO.2
     C                     MOVE WWHIN3    IPHIN3           PARTS NO.3
      *** ADD 11/13 A.IDOTA ***
     C           @@LOT     IFEQ 0
     C                     Z-ADDIOMAIS    IPHAKO           BOXES
     C                     ELSE
     C           @@LOT     MULT IOMAIS    IPHAKO           BOXES
     C                     END
      *** ADD 11/13 A.IDOTA ***
     C                     Z-ADD@@SYUY    IPSYUY           QUANTITY IN BOX
     C           IPHAKO    MULT @@SYUY    IPSRY            QUANTITY
     C                     Z-ADD0         IPTANK           UNIT PRICE
     C           IOKKBN    IFEQ '1'
     C                     Z-ADDIMATST    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '2'
     C                     Z-ADDIMTENT    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '3'
     C                     Z-ADDIMNEST    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '4'
     C                     Z-ADDIMHYOT    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '5'
     C                     Z-ADDIMKNRT    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '6'
     C                     Z-ADDIMKOST    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '7'
     C                     Z-ADDIMKANT    IPTANK           UNIT PRICE
     C                     END
     C           IOKKBN    IFEQ '8'
     C                     Z-ADDIMAPIC    IPTANK           UNIT PRICE
     C                     END
     C           IPSRY     MULT IPTANK    IPKIN     H      AMOUNT
     C*
     C                     WRITEGDJPP201
     C                     END
     C                     END
     C  N90                END
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*
     C*
     C           #CHK      BEGSR
     C                     MOVE *BLANK    WWHIN
     C                     Z-ADD0         @@SYUY
     C           IOKKBN    COMP '1'                      51
     C  N51      IOKKBN    COMP '2'                      51
     C  N51      IOKKBN    COMP '3'                      51
     C  N51      IOKKBN    COMP '4'                      51
     C  N51      IOKKBN    COMP '5'                      51
     C  N51      IOKKBN    COMP '6'                      51
     C  N51      IOKKBN    COMP '7'                      51
     C  N51      IOKKBN    COMP '8'                      51
     C           *IN51     IFEQ '0'
     C                     Z-ADD1         ERSW
     C                     GOTO CHKERR
     C                     END
     C*
     C           IOMAIS    IFEQ 0
     C                     Z-ADD2         ERSW
     C                     GOTO CHKERR
     C                     END
     C*
     C                     MOVE *BLANK    @@HIN  12
     C                     MOVE *BLANK    @@PART
     C                     Z-ADD0         @@SYUY
     C                     Z-ADD0         @@DEP
     C                     Z-ADD0         @@ERR
      *** ADD 11/13 A.IDOTA ***
     C                     Z-ADD0         @@LOT
      *** ADD 11/13 A.IDOTA ***
     C                     CALL 'GDJR12'               20
     C                     PARM           IOKKBN           PROCESS CODE
     C                     PARM           IOBAR1           KANBAN KBN
     C                     PARM           IOBAR2           ID NUMBER
     C                     PARM           IOBAR3           SEIHIN KBN
     C                     PARM           IOKATA           KATA NO.
     C                     PARM           IOKOTE           KOTE NO.
     C                     PARM           @@HIN
     C                     PARM           @@SYUY  70       QUANTITY IN BOX
     C                     PARM           @@PART 12        PARTS NO.
     C                     PARM           @@DEP   40       DEPARTMENT
     C                     PARM           @@ERR   10       ERROR
      *** ADD 11/13 A.IDOTA ***
     C                     PARM           @@LOT   30       LOT
      *** ADD 11/13 A.IDOTA ***
     C                     FREE 'GDJR12'
     C   20                Z-ADD1         @@ERR
     C           @@ERR     IFEQ 1
     C                     Z-ADD3         ERSW
     C                     GOTO CHKERR
     C                     END
     C                     MOVE @@PART    WWHIN
     C                     MOVE @@PART    @WHIN
     C*
     C           HINKEY    KLIST
     C                     KFLD           @WHIN1
     C                     KFLD           @WHIN2
     C                     KFLD           @WHIN3
      *
     C                     SETOF                     30
      *
     C           STP1      TAG
     C                     SETOF                     91
     C           HINKEY    CHAINGDJPP01              91
     C           *IN91     IFEQ '1'
      *
     C           IOKKBN    IFEQ '7'
     C           *IN30     IFEQ '0'
     C                     SETON                     30
     C                     MOVE *BLANK    @WDIE3
     C                     MOVE *BLANK    @WDIE4
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     Z-ADD4         ERSW
     C                     GOTO CHKERR
      *
     C                     END
     C                     GOTO CHKEND
     C*
     C*
     C           CHKERR    TAG
     C           IOKIKI    IFNE @@KIKI
     C                     SETON                     OF
     C                     MOVE IOKIKI    @@KIKI  1
     C                     END
     C                     MOVE *BLANK    ERRMSG 30
     C                     MOVELMSG,ERSW  ERRMSG
     C*
     C                     MOVE *ALL'-'   S1PART
     C           IOKKBN    IFNE '7'
     C                     MOVE WWHIN1    S1HIN1
     C                     MOVE WWHIN2    S1HIN2
     C                     MOVE WWHIN3    S1HIN3
     C           WWHIN3    IFEQ *BLANK
     C                     MOVE '   '     S1PART
     C                     END
     C                     ELSE
     C                     MOVE WWDIE1    S1DIE1
     C                     MOVE WWDIE2    S1DIE2
     C                     MOVE WWDIE3    S1DIE3
     C                     MOVE WWDIE4    S1DIE4
     C                     MOVE *BLANK    S1DW4
     C           WWDIE4    IFEQ *BLANK
     C                     MOVE *BLANK    S1DW3
     C                     END
     C           WWDIE3    IFEQ *BLANK
     C                     MOVE *BLANK    S1DW2
     C                     END
     C                     END
     C           *INOF     IFEQ '1'
     C                     EXCPTHED
     C                     SETOF                     OF
     C                     END
     C                     EXCPTDET
     C           CHKEND    ENDSR
     C*
     C*
     C*
     C           #INIT     BEGSR
     C*
     C                     MOVEA'0'       *IN,11
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C                     Z-ADD0         DDDATE
     C           #INIT1    TAG
     C                     EXFMTDSP01
     C   KA                SETON                     LR
     C   KA                RETRN
     C                     MOVEA'0'       *IN,11
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C           DDDATM    IFLT 01
     C           DDDATM    ORGT 12
     C                     MOVEA'1'       *IN,11
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     D#MSG
     C                     GOTO #INIT1
     C                     END
     C           DDDATD    IFLT 01
     C           DDDATD    ORGT 31
     C                     MOVEA'1'       *IN,11
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     D#MSG
     C                     GOTO #INIT1
     C                     END
     C  NKE                GOTO #INIT1
     C*
     C           *NAMVAR   DEFN           GDJD01  8
     C           *LOCK     IN   *NAMVAR
     C                     MOVE DDDATE    GDJD01
     C                     OUT  *NAMVAR
     C*
     C                     MOVE '*'       @@KIKI  1
     C                     SETON                     OF
     C                     TIME           TIME    60
     C                     ENDSR
     OQPRINT  E   02           HED
     O                                    8 'GDJR11'
     O                                   50 'IAF PHYSICAL INVENTORY'
     O                                 +  1 'ERROR LIST'
     O                                   80 'INVENTORY DATE'
     O                         DDDATE  +  1 '  /  /    '
     O                                  105 'DATE'
     O                         *DATE Y +  1
     O                                  124 'PAGE'
     O                         PAGE  Z +  1
     O        E   03           HED
     O                                  105 'TIME'
     O                         TIME    +  1 '  :  :  '
     O        E   04           HED
     O                                   23 'BAR CODE READER NO. :'
     O                         @@KIKI  +  1
     O        E   05           HED
     O                                   23 'SEQ  PROCESS CLASS'
     O                                   33 'BAR CODE'
     O                                   55 'NO. OF BOXES'
     O                                   66 'PARTS NO.'
     O                                   86 'QUANTITY OF BOX'
     O                                  105 'DETAILES OF ERROR'
     O        E   06           HED
     O                                   23 '---      -        '
     O                                   42 '-----------------'
     O                                   51 '----'
     O                                   71 '--------------'
     O                                   83 '---------'
     O                                  103 '---------------'
     O                                  118 '---------------'
     O        E 1              DET
     O                         IOSEQ 4    8
     O                         IOKKBN    15
     O                         IOBAR     42
     O                         IOMAIS4   51
     O                         S1PART    71
     O                         @@SYUY4   83
     O                         ERRMSG   118
**
WRONG PROCESS CLASS.
NO QUANTITY IN BOX.
NO KANBAN MASTER.
NO UNIT PRICE MASTER.
WRONG INVENTORY DATE.
