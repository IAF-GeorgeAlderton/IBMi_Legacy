     H            Y.
      ** CHKCV0 *******************************************************
      * ..ディスク処理状況ファイル作成..
      *  KIRI 2015.04.23
      *****************************************************************
     FCHKWPV0 IP  F     256            DISK
     FCHKWPV1 O   E                    DISK
      *
     E                    @US         4  1
     E                    $US         4  1
     ICHKWPV0 AA
     I                                        3   6 IUNIT
     I                                        9  12 ITYPE
     I                                       23  27 IUSED
     I                                       23  23 IUSED1
     I                                       24  24 IUSED2
     I                                       25  25 IUSED3
     I                                       27  27 IUSED4
     I                                       92  97 ISTAT
     I            DS
     I                                        1   4 @US
     I                                        1   1 WUSED1
     I                                        2   2 WUSED2
     I                                        3   3 WUSED3
     I                                        4   4 WUSED4
     I            DS
     I                                        1   4 $US
     I                                        1   4 $$USED
      *================================================================
     C                     SELEC
     C           IUNIT     WHEQ 'Unit'
     C           ITYPE     ANDEQ'Type'
     C                     SETON                     10
     C           IUNIT     WHEQ '    '
     C           ITYPE     ANDEQ'    '
     C                     SETOF                     10
     C                     OTHER
     C   10                EXSR #OUTF
     C                     ENDSL
      *================================================================
      *
      *================================================================
     C           #OUTF     BEGSR
     C                     MOVELIUNIT     CSUNIT           UNIT
     C                     MOVELITYPE     CSTYPE           TYPE
     C*
     C                     MOVELIUSED1    WUSED1
     C                     MOVELIUSED2    WUSED2
     C                     MOVELIUSED3    WUSED3
     C                     MOVELIUSED4    WUSED4
     C                     MOVEL'0000'    $$USED
     C                     DO   4         Z       20
     C           @US,Z     IFGE '0'
     C           @US,Z     ANDLE'9'
     C                     MOVE @US,Z     $US,Z
     C                     ENDIF
     C                     ENDDO
     C                     MOVEL$$USED    CSUSED           USED
     C*
     C                     MOVELISTAT     CSSTAT           状況
     C                     WRITECHKWPV11
     C                     ENDSR
      *================================================================
