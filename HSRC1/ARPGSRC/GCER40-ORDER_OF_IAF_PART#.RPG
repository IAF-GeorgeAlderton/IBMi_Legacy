     H            Y.
     F** GCER40 **********************************
     F*   ..ORDER OF INTRAL COMPANY PART NUMBER  *
     F*   WASHER TAG PRING                       *
     F*       TCH  07/19/02                      *
     F********************************** GCER40 **
     FGCEPW40 CF  E                    WORKSTN
     FAKBPL04 IF  E           K        DISK
     FAKBPL01 IF  E           K        DISK
     FGCEWP31 O   F     100            DISK
     E                    CMD     1   1 78
     E                    ERR     1   3 78
     E                    ARY         3  1
     E                    ARX         3  1
     I            DS
     I                                        1  12 HNB
     I                                        1   5 D@PRT1
     I                                        6  10 D@PRT2
     I                                       11  12 D@PRT3
     I            DS
     I                                        1   3 LOC
     I                                        1   1 D@LOC1
     I                                        2   3 D@LOC2
     I            DS
     I                                        1  14 HBAN
     I                                        1   5 L1SHN1
     I                                        6   6 L11
     I                                        7  11 L1SHN2
     I                                       12  12 L12
     I                                       13  14 L1SHN3
     I            DS
     I                                        1   9 TKOB
     I                                        1   1 L1TKR1
     I                                        2   2 L13
     I                                        3   4 L1TKR2
     I                                        5   5 L14
     I                                        6   7 L1TKR3
     I                                        8   8 L15
     I                                        9   9 L1TKR4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@END   1
     C           K#AKB4    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#AKB1    KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
      *
     C                     MOVEL'01'      W@ID    2
     C                     MOVE *BLANK    P@END
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     MOVE '1'       P@END
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000'   *IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     SELEC
     C           HNB       WHNE *BLANK
     C           LOC       ANDNE*BLANK
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,3     D@MSG
      *
     C           HNB       WHEQ *BLANK
     C           LOC       ANDEQ*BLANK
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,3     D@MSG
      *
     C           HNB       WHNE *BLANK
     C           K#AKB4    SETLLAKBPL04
     C           *IN90     DOUEQ*ON
     C           K#AKB4    READEAKBPL04                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDGE*DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
      *
     C           LOC       WHNE *BLANK
     C           K#AKB1    SETLLAKBPL01
     C           *IN90     DOUEQ*ON
     C           K#AKB1    READEAKBPL01                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDGE*DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE ERR,2     D@MSG
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PRINT
      *------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     SELEC
     C           HNB       WHNE *BLANK
     C           K#AKB4    SETLLAKBPL04
     C           *IN90     DOUEQ*ON
     C           K#AKB4    READEAKBPL04                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDGE*DATE
     C                     EXSR #WRT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           LOC       WHNE *BLANK
     C           K#AKB1    SETLLAKBPL01
     C           *IN90     DOUEQ*ON
     C           K#AKB1    READEAKBPL01                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDGE*DATE
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE RECORDS IN WORK FILE
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     MOVE *BLANK    L11
     C                     MOVE *BLANK    L12
     C                     MOVE *BLANK    L13
     C                     MOVE *BLANK    L14
     C                     MOVE *BLANK    L15
     C           L1SHN2    COMP *BLANK                   11
     C           L1SHN3    COMP *BLANK                   12
     C  N11                MOVE '-'       L11
     C  N12                MOVE '-'       L12
     C           L1TKR2    COMP *BLANK                   13
     C           L1TKR3    COMP *BLANK                   14
     C           L1TKR4    COMP *BLANK                   15
     C  N13                MOVE '-'       L13
     C  N14                MOVE '-'       L14
     C  N15                MOVE '-'       L15
      *
     C           L1KTSU    DIV  L1SYOS    DI1     52
     C                     MOVE DI1       @1      1
     C           @1        IFNE '0'
     C                     ADD  0.1       DI1
     C                     ENDIF
      *
     C                     Z-ADDDI1       HAKO    41
      *
     C           L1BMON    IFEQ 8990
     C           HAKO      MULT 5         HAKO
     C                     ENDIF
      *
     C                     MOVE L1KMAX    MISU
     C                     MOVEAMISU      ARY
     C                     MOVE *BLANK    ARX
     C                     MOVE *OFF      *IN93
     C           1         DO   3         X       30
     C           *IN93     IFEQ *OFF
     C           ARY,X     ANDEQ'0'
     C                     MOVE *BLANK    ARX,X
     C                     ELSE
     C                     MOVE ARY,X     ARX,X
     C                     MOVE *ON       *IN93
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAARX       MISU    3
     C                     Z-ADDL1UZAR    MAXH    30
     C                     Z-ADD*DATE     TOKI    80
     C                     MOVE '000'     BARA    3
     C                     EXCPTDT
      *
     C                     ENDSR
%0001 *-----------------------------------------------------*
     OGCEWP31 E                DT
     O                         HBAN      14
     O                         TKOB      23
     O                         HAKO      27
     O                         MISU      30
     O                         TOKI      38
     O********                 SENY      39
     O                         BARA      41
     O                         MAXH      44
** CMD
  F1:END   F5:PRINT
