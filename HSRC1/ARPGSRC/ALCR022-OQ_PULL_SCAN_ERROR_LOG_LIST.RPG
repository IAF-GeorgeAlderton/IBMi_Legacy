     FALCPP01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F*
     E                    TBL     1   1 50
TCHKBE                    LOC     1  20 20   LON    15
     I*
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80W@SCDT
     I                                        1   40W@SCYY
     I                                        5   60W@SCMM
     I                                        7   80W@SCDD
     I            DS
     I                                        1   80W@ECDT
     I                                        1   40W@ECYY
     I                                        5   60W@ECMM
     I                                        7   80W@ECDD
     I            DS
     I                                        1  14 W@PRT
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     C**************************************************************
     C           K#01      KLIST
     C                     KFLD           W@SCDT
     C                     KFLD           W@STTM
      *
     C           K#01      SETLLALCPP01
      *
     C                     DO   *HIVAL
      *
     C                     READ ALCPP01                  99
     C   99                LEAVE
      *
     C           A8USER    IFNE 'O'
     C                     ITER
     C                     END
      *
     C           A8ERR     IFEQ *BLANK
     C                     ITER
     C                     END
     C           A8EM03    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C                     MOVELA8TMCD    W@TMCD  6
     C                     MOVELW@TMCD    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C**TEMP     *IN97     IFEQ *OFF
     C**         ALDPCD    ANDNE'C'
     C**                   ITER
     C**                   ENDIF
      *
     C           *IN97     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C  N97                MOVELALWKNM    P@WKNM 20
     C   97                MOVEL*BLANK    P@WKNM
      *
     C           A8DATE    IFEQ W@ECDT
     C           A8TIME    ANDGTW@EDTM
     C                     LEAVE
     C                     END
     C*
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     END
     C*
     C*
TCHK4C                     Z-ADD1         X       20
TCHK4C           A8BRC2    LOKUPLOC,X                    96
TCHK4C           *IN96     IFEQ *ON
TCHK4C                     MOVELLON,X     W@BRC2 15
TCHK4C                     ELSE
TCHK4C                     MOVELA8BRC2    W@BRC2
TCHK4C                     END
TCHK4C*
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELA8PR11    W@PRT1
     C                     MOVELA8PR12    W@PRT2
     C                     MOVELA8PR13    W@PRT3
     C           A8PR12    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C           A8PR13    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELW@PRT     P@PRT1 14
     C*
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELA8PR21    W@PRT1
     C                     MOVELA8PR22    W@PRT2
     C                     MOVELA8PR23    W@PRT3
     C           A8PR22    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C           A8PR23    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELW@PRT     P@PRT2 14
     C*
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELA8PR31    W@PRT1
     C                     MOVELA8PR32    W@PRT2
     C                     MOVELA8PR33    W@PRT3
     C           A8PR32    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C           A8PR33    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELW@PRT     P@PRT3 14
     C*
     C                     EXCPT@DTL
TCHK2C                     MOVEL*ON       PMRFLG
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* INITIAL SET
     C*-----------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           PMSHFT  1
     C                     PARM           PMSCDT  8
TCHK2C                     PARM           PMRFLG  1
TCHK2C                     MOVEL*OFF      PMRFLG
     C*
     C                     TIME           WSDT
     C*
     C           PMSCDT    IFNE *BLANK
     C                     MOVELPMSCDT    W@SCDT
     C                     MOVELPMSCDT    W@ECDT
     C                     ELSE
     C                     MOVELWSSDAT    W@SCDT
     C                     MOVELWSSDAT    W@ECDT
     C                     END
     C*
     C                     SELEC
     C           PMSHFT    WHEQ '1'
     C                     Z-ADD070000    W@STTM  60
     C                     Z-ADD145959    W@EDTM  60
     C           PMSHFT    WHEQ '2'
     C                     Z-ADD150000    W@STTM
     C                     Z-ADD225959    W@EDTM
     C           PMSHFT    WHEQ '3'
     C           K#AGDP    KLIST
     C                     KFLD           W@SCYY
     C                     KFLD           W@SCMM
     C                     KFLD           W@SCDD
     C           K#AGDP    CHAINAGDPL12              98
     C           *IN98     IFEQ *OFF
     C                     READPAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KAYY    W@SCYY
     C                     Z-ADDF8KAMM    W@SCMM
     C                     Z-ADDF8KADD    W@SCDD
     C                     END
     C                     END
     C                     Z-ADD230000    W@STTM
     C                     Z-ADD065959    W@EDTM
     C                     OTHER
     C                     Z-ADD000000    W@STTM
     C                     Z-ADD000000    W@EDTM
     C                     ENDSL
     C*
     C                     MOVEL*ON       W@1STP  1
     C*
     C                     ENDSR
