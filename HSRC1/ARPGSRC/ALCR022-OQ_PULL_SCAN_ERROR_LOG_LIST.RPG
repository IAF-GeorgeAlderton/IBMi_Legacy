     C**************************************************************************
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   15 'SCANNED DATE AT'
     O                         W@SCDTY   26
     O                                   36 'SHIFT#:'
     O                         PMSHFT    38
     O        E   05           @HED
     O                                    4 'TIME'
     O                                   20 'TEAM MEMBER'
     O                                   45 'A/P KANBAN'
     O                                   62 'LOCATION'
     O                                   80 'MFG KANBAN'
     O                                   99 'ERROR MESSAGE'
     O        E 1              @DTL
     O                         A8TIME     8 ' 0:  :  '
     O                         P@WKNM    29
     O                         A8KIND    36
     O                         A8BRC1    52
     O                         W@BRC2    69
     O                         A8BRC3    85
