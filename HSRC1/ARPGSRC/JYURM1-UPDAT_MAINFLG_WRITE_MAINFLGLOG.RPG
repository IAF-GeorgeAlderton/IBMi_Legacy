     H            Y.
     F** JYURM1 **********************************
     F*    UPDAT MAINFLG / WRITE MAINFLGLOG      *
     F*                                          *
     F*       CODING:             2015.05.21     *
     F********************************** JYURM1 **
     FINPUT   UF  F      64            DISK                      A
     FJYUPPML O   E                    DISK
     E                    FLG     1  10  1   TXT    50
     IINPUT   AA  01
     I                                        1  64 IDATA
     I                                        1   40IKOYY
     I                                        5   60IKOMM
     I                                        7   80IKODD
     I                                        9  100IKOTI
     I                                       11  120IKOMI
     I                                       13  140IKOSE
     I                                       15  24 IKOME
     I                                       25  25 IFLAG
     I           SDS
     I                                        1  10 ##PGM
     I                                      244 253 ##JOB
     I                                      254 263 ##USR
     I            DS
     I                                        1  140LGTIME
     I                                        1   20LGDTTI
     I                                        3   40LGDTMI
     I                                        5   60LGDTSE
     I                                        7  100LGDTYY
     I                                       11  120LGDTMM
     I                                       13  140LGDTDD
     I            DS
     I                                        1  140#TIME
     I                                        1   20#KOTI
     I                                        3   40#KOMI
     I                                        5   60#KOSE
     I                                        7  100#KOYY
     I                                       11  120#KOMM
     I                                       13  140#KODD
     C           *ENTRY    PLIST
     C                     PARM           PKUBN   1
     C                     PARM           PFLAG   1
     C                     PARM           PLIBL  10
     C                     PARM           PFILE  10
     C*
     C           PKUBN     CASEQ'W'       #SB100
     C           PKUBN     CASEQ'R'       #SB200
     C                     ENDCS
     C*
      *-----------------------------------------------------*
      *          #SB100 : WRITE MAINFLG                     *
      *-----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           #TIME  140
     C*
     C                     SETOF                     10
     C                     READ INPUT                    10
     C           *IN10     IFEQ '1'
     C                     EXCPTWRITE
     C                     ELSE
     C                     EXCPTUPDAT
     C                     ENDIF
     C*
     C                     MOVEL#KOYY     WKOYY   40
     C                     MOVEL#KOMM     WKOMM   20
     C                     MOVEL#KODD     WKODD   20
     C                     MOVEL#KOTI     WKOTI   20
     C                     MOVEL#KOMI     WKOMI   20
     C                     MOVEL#KOSE     WKOSE   20
     C                     MOVEL##PGM     WKOME  10
     C*
     C                     MOVEL*BLANK    WTEXT  50
     C                     Z-ADD1         #A      20
     C                     SETOF                     20
     C           PFLAG     LOKUPFLG,#A                   20
     C           *IN20     IFEQ '1'
     C                     MOVE TXT,#A    WTEXT
     C                     ENDIF
      *
     C                     EXSR #SB900
     C                     WRITEJYUPPML1
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     CSR         ESB100    ENDSR
      *-----------------------------------------------------*
      *          #SB200 : READ  MAINFLG                     *
      *-----------------------------------------------------*
     CSR         #SB200    BEGSR
     C*
     C                     TIME           #TIME
     C*
     C                     SETOF                     10
     C                     READ INPUT                    10
     C           *IN10     IFEQ '1'
     C                     MOVEL*BLANK    PFLAG
     C                     MOVEL*BLANK    WKOYY
     C                     MOVEL*BLANK    WKOMM
     C                     MOVEL*BLANK    WKODD
     C                     MOVEL*BLANK    WKOTI
     C                     MOVEL*BLANK    WKOMI
     C                     MOVEL*BLANK    WKOSE
     C                     MOVEL*BLANK    WKOME
     C                     ELSE
     C                     MOVELIFLAG     PFLAG
     C                     MOVELIKOYY     WKOYY
     C                     MOVELIKOMM     WKOMM
     C                     MOVELIKODD     WKODD
     C                     MOVELIKOTI     WKOTI
     C                     MOVELIKOMI     WKOMI
     C                     MOVELIKOSE     WKOSE
     C                     MOVELIKOME     WKOME
     C                     ENDIF
     C*
     C                     MOVEL*BLANK    WTEXT  50
     C                     Z-ADD1         #A
     C                     SETOF                     20
     C           PFLAG     LOKUPFLG,#A                   20
     C           *IN20     IFEQ '1'
     C                     MOVELTXT,#A    WTEXT
     C                     ENDIF
      *
     C                     EXSR #SB900
     C                     WRITEJYUPPML1
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         ESB200    ENDSR
      *-----------------------------------------------------*
      *          #SB900 : DATA MOVE                         *
      *-----------------------------------------------------*
     CSR         #SB900    BEGSR
     C                     TIME           LGTIME
     C                     MOVELPLIBL     LGLIBL
     C                     MOVELPFILE     LGFILE
     C                     MOVEL'M'       LGKUBN
     C                     MOVELWKOME     LGKOME
     C                     Z-ADDWKOYY     LGKOYY
     C                     Z-ADDWKOMM     LGKOMM
     C                     Z-ADDWKODD     LGKODD
     C                     Z-ADDWKOTI     LGKOHO
     C                     Z-ADDWKOMI     LGKOMI
     C                     Z-ADDWKOSE     LGKOSE
     C                     MOVELPFLAG     LGFLAG
     C                     MOVELWTEXT     LGTEXT
     C                     MOVEL*BLANK    LGDREC
     C                     MOVEL*BLANK    LGSTAT
     CSR         ESB900    ENDSR
      *
     OINPUT   E                UPDAT
     O                         #KOYY      4
     O                         #KOMM      6
     O                         #KODD      8
     O                         #KOTI     10
     O                         #KOMI     12
     O                         #KOSE     14
     O                         ##PGM     24
     O                         PFLAG     25
     O                                   64 '*'
     O        EADD             WRITE
     O                         #KOYY      4
     O                         #KOMM      6
     O                         #KODD      8
     O                         #KOTI     10
     O                         #KOMI     12
     O                         #KOSE     14
     O                         ##PGM     24
     O                         PFLAG     25
     O                                   64 '*'
**
0INITIAL STATE.
1EDIDATA MAKING DEMAND.
2EDIDATA MAKING COMPLETION.
3THERE IS NO EDIDATA.
4
5
6
7
8
9THE FLAG IS ABNORMAL.
