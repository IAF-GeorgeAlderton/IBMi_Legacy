      **************************************************************************
     C           #CHK40    BEGSR
      *
     C                     MOVELF4LOT     W4LOT  25
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           F4LOT     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
JW1  C                     MOVE '05'      F3ERR
 "   C                     MOVE '05'      F99ER1
     C                     MOVELERR,10    F99ER2
