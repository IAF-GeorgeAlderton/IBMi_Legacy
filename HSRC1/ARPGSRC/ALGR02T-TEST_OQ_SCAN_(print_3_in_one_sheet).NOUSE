     C**************************************************************************
      *                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
      *
     C                     SELEC
     C           @@ID      WHEQ '10'
     C                     EXSR #FMT10
     C           @@ID      WHEQ '15'
     C                     EXSR #FMT15
     C           @@ID      WHEQ '20'
     C           X         ANDLENUMCRT
     C                     EXSR #FMT20
     C           @@ID      WHEQ '30'
     C           X         ANDLENUMCRT
     C                     EXSR #FMT30
     C           @@ID      WHEQ '40'
     C           X         ANDLENUMCRT
     C                     EXSR #FMT40
     C                     OTHER
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVE '15'      @@ID
     C                     EXSR #FMT15
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      * FOR KANBAN CHECK DEGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     TIME           WSDT
      *
     C                     CLEARFMT100
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
      *
     C                     MOVEL'10'      @@ID    2
      * DUMMY READ
     C                     READ ALGPP01                  98
     C                     READ ALGPP11                  98
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(TM-CODE ENTRY)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C                     MOVE '15'      @@ID
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     616263
     C                     SETOF                     9964
      * TM-CODE CHECK
     C           F1USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     6199
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,1     F1ERR
     C                     END
     C                     END
      * SHIFT CODE CHECK
     C           F1SHFT    IFEQ '1'
      *          F1SHFT    OREQ '2'
     C           F1SHFT    OREQ '3'
     C                     ELSE
     C                     SETON                     6299
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,2     F1ERR
     C                     END
     C                     END
      * LINE NO CHECK
     C           F1LINE    IFGE '1'
%0001C           F1LINE    ANDLE'8'
     C                     ELSE
     C                     SETON                     6499
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,12    F1ERR
     C                     END
     C                     END
      * PRINTER CODE CHECK
     C                     CLEARARY
     C                     MOVEACMD,1     ARY
     C                     SELEC
      *** oq1
     C           F1PRNT    WHEQ '21'
     C                     MOVEA'LANPRT21'ARY,28
      *** oq2
     C           F1PRNT    WHEQ '22'
     C                     MOVEA'LANPRT22'ARY,28
      *** oq3
     C           F1PRNT    WHEQ '23'
     C                     MOVEA'LANPRT23'ARY,28
      *** oq4
     C           F1PRNT    WHEQ '24'
     C                     MOVEA'LANPRT24'ARY,28
      *** oq5
     C           F1PRNT    WHEQ '25'
     C                     MOVEA'LANPRT25'ARY,28
      *** oq6
     C           F1PRNT    WHEQ '26'
     C                     MOVEA'LANPRT26'ARY,28
      *** oq7
     C           F1PRNT    WHEQ '29'
     C                     MOVEA'LANPRT29'ARY,28
      *** oq8
     C           F1PRNT    WHEQ '32'
     C                     MOVEA'LANPRT32'ARY,28
      *** test
     C           F1PRNT    WHEQ '99'
     C           #USER     ANDEQ'OQTEST'
     C                     MOVEA'QDKT    'ARY,28
      *** error
     C                     OTHER
     C                     SETON                     6399
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,3     F1ERR
     C                     END
     C                     ENDSL
      *
     C           *IN99     IFEQ *OFF
     C                     MOVEAARY       P@CMD
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     END
      *
     C                     ENDSR
      *************************************************************************
      *         SCREEN(ENTER NUMBER OF CARTS)
      **************************************************************************
     C           #FMT15    BEGSR
      *
     C                     EXFMTFMT150
     C                     MOVEL*BLANK    F2ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVE '15'      @@ID
     C                     OTHER
     C                     EXSR #CHK15
     C           *IN99     IFEQ *OFF
     C                     MOVE '20'      @@ID
     C                     MOVE *BLANKS   SVZETI
     C                     MOVE *BLANKS   KAN
     C                     Z-ADDF2CART    NUMCRT  10
     C                     Z-ADD1         X       10
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *         SCREEN CHECK FOR NUMBER OF CARTS FMT150
      **************************************************************************
     C           #CHK15    BEGSR
      *
     C                     SETOF                     9961
      *
     C           F2CART    IFEQ *ZERO
     C           F2CART    ORGT 4
     C                     SETON                     9961
     C                     MOVELERR,13    F2ERR
     C                     MOVELERR,13    F99ER1
     C                     MOVELERR,14    F99ER2
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN(KANBAN)
      **************************************************************************
     C           #FMT20    BEGSR
      *
     C                     Z-ADDX         F2X
     C                     Z-ADDNUMCRT    F2#CRT
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVE '15'      @@ID
     C                     OTHER
     C                     EXSR #CHK20
     C           *IN99     IFEQ *OFF
     C                     MOVE '30'      @@ID
     C                     MOVELW2KAN     KAN,X
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     2ND SCREEN CHECK
      **************************************************************************
     C           #CHK20    BEGSR
      *
LC1  C                     MOVELF2KAN     QR
 |    *
     C           QRID      IFEQ 'B01'
     C                     MOVELF2KAN     P1QR1 256
     C                     MOVE *BLANKS   P1QR2 256
     C                     CALL 'UEXR13'
     C                     PARM           P1QR1
     C                     PARM           P1QR2
     C                     PARM           P9BAR  20
     C                     MOVELP9BAR     W2KAN
     C                     ELSE
     C                     MOVELF2KAN     W2KAN
     C                     ENDIF
 |    *
LC1  C                     SETOF                     9961
      *
     C                     DO
      *
     C           W2KAN     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '01'      F2ERR
 "   C                     MOVE '01'      F99ER1
     C                     MOVELERR,5     F99ER2
     C                     LEAVE
     C                     END
      * CHECK DIGIT
     C                     MOVELW2KAN     PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '02'      F2ERR
 "   C                     MOVE '02'      F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE W2CHKD
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '03'      F2ERR
 "   C                     MOVE '03'      F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C   99                LEAVE
      *
     C           W2ZETI    CHAINFCEPL07              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '04'      F2ERR
 "   C                     MOVE '04'      F99ER1
     C                     MOVELERR,7     F99ER2
     C                     LEAVE
     C                     END
      *
     C                     TIME           WSDT
     C           K#ADH     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#ADH     SETGTADHTL05
     C                     DO   *HIVAL
     C           K#ADH     REDPEADHTL05                  90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '05'      F2ERR
 "   C                     MOVE '05'      F99ER1
     C                     MOVELERR,8     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C           J6SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
JW2   * IGNORE IF EFFECTIVE DATE < TODAY
 |   C           J6STHZ    IFLT WSDATE
 |   C                     ITER
JW2  C                     ENDIF
      *
      * can't compare temp and co2 from barcode to master because no
      * longer scanning that barcode. they are going to scan barcode on
      * other side of kanban...
      *******    J6ONDO    IFEQ W2ONDO
      *******    J6CO2P    ANDEQW2CO2P
      *******              ELSE
      *******              ITER
      *******              ENDIF
      *
     C                     LEAVE
     C                     ENDDO
      *
      * make sure this kanban hasn't already been scanned...
LC1  C           W2KAN     LOKUPKAN                      10
     C           *IN10     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '06'      F2ERR
 "   C                     MOVE '06'      F99ER1
     C                     MOVELERR,11    F99ER2
     C                     LEAVE
     C                     ENDIF
      *
      * make sure this cart has same part number...
     C           X         IFGT 1
     C           W2ZETI    ANDNESVZETI
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '07'      F2ERR
 "   C                     MOVE '07'      F99ER1
     C                     MOVELERR,15    F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
      *
      * if mismatch error on part number, then lock pgm
     C           F99ER2    IFEQ ERR,15
      *
      * call pgm for PASSWORD LOCK...
     C                     Z-ADD4         P1PGM
     C                     MOVELF99ER2    P1ERR
     C                     MOVEL#PGM      P1PID
     C                     MOVELF1USRC    P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
      *
     C                     MOVE *BLANKS   F2KAN
     C                     SETOF                     61
      *
     C                     ELSE
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C           X         ANDEQ1
     C                     MOVELW2ZETI    SVZETI  4
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     3RD SCREEN(LOTID)
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     EXFMTFMT300
     C                     MOVEL*BLANK    F3ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVE '15'      @@ID
     C           *INKH     WHEQ *ON
     C                     MOVE '40'      @@ID
     C                     OTHER
     C                     EXSR #CHK30
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRTOK
     C           @@ID      IFEQ '15'
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     ELSE
     C                     MOVE '20'      @@ID
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     ADD  1         X
     C                     ENDIF
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     3RD SCREEN CHECK
      **************************************************************************
     C           #CHK30    BEGSR
      *
     C                     MOVELF3LOT     W3LOT
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           F3LOT     IFEQ *BLANK
     C           F3LOT1    ANDEQ*BLANK
     C           F3LOT2    ANDEQ*BLANK
     C           F3LOT3    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
JW1  C                     MOVE '01'      F3ERR
 "   C                     MOVE '01'      F99ER1
     C                     MOVELERR,10    F99ER2
     C                     LEAVE
     C                     END
     C           F3LOT     IFEQ *BLANK
     C                     LEAVE
     C                     END
      * CHECK DIGIT
     C           #USER     IFNE 'TEST'
     C           #USER     ANDNE'OQTEST'
     C                     MOVELW3LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
JW1  C                     MOVE '02'      F3ERR
 "   C                     MOVE '02'      F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE W3CHKD
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
JW1  C                     MOVE '03'      F3ERR
 "   C                     MOVE '03'      F99ER1
     C                     MOVELERR,6     F99ER2
     C                     END
     C                     END
TEST C                     END
     C   99                LEAVE
      *
     C           F3LOT     IFEQ F3LOT1
     C           F3LOT     OREQ F3LOT2
     C           F3LOT     OREQ F3LOT3
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
JW1  C                     MOVE '04'      F3ERR
 "   C                     MOVE '04'      F99ER1
     C                     MOVELERR,11    F99ER2
     C                     END
     C                     LEAVE
     C                     END
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           F3LOT1    WHEQ *BLANK
     C                     MOVELF3LOT     F3LOT1
     C                     MOVEL*BLANK    F3LOT
     C           F3LOT2    WHEQ *BLANK
     C                     MOVELF3LOT     F3LOT2
     C                     MOVEL*BLANK    F3LOT
     C           F3LOT3    WHEQ *BLANK
     C                     MOVELF3LOT     F3LOT3
     C                     MOVEL*BLANK    F3LOT
     C                     ENDSL
     C                     END
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
      *
     C                     ENDSR
      *************************************************************************
      *     4TH SCREEN(FREEWAY LOT ID)
      **************************************************************************
     C           #FMT40    BEGSR
      *
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVE '15'      @@ID
     C                     OTHER
     C                     EXSR #CHK40
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRTOK
     C           @@ID      IFEQ '15'
     C                     CLEARFMT150
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
