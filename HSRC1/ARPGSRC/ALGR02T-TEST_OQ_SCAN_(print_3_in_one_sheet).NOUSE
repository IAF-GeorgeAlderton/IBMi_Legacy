      **************************************************************************
      *       WRITE A OK RECORD FOR FREEWAY LOT ID
      **************************************************************************
     C           #WRT40    BEGSR
      *
     C           XFWLOT    IFNE *BLANK
     C                     CLEARALGPP111
     C                     Z-ADDA1KOYY    ABKOYY
     C                     Z-ADDA1KOMM    ABKOMM
     C                     Z-ADDA1KODD    ABKODD
     C                     Z-ADDA1KOTM    ABKOTM
     C                     MOVELA1USER    ABUSER
     C                     MOVELA1WSID    ABWSID
     C                     MOVELA1PGID    ABPGID
     C                     MOVELA1LINE    ABLINE
     C                     Z-ADDA1TSQY    ABTSQY
     C                     Z-ADDA1TSQM    ABTSQM
     C                     Z-ADDA1TSQ#    ABTSQ#
     C                     Z-ADDA1SCYY    ABSCYY
     C                     Z-ADDA1SCMM    ABSCMM
     C                     Z-ADDA1SCDD    ABSCDD
     C                     Z-ADDA1SCTM    ABSCTM
     C                     MOVELXFWLOT    ABLOT0
     C                     MOVELXFWLOT    W3LOT
     C                     MOVELW3LOT1    ABLOT1
     C                     MOVELW3CHKD    ABLOT2
     C                     WRITEALGPP111
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *       WRITE A OK RECORD
      **************************************************************************
     C           #WRTOK    BEGSR
      *
      * set occurrence of lot id multiple occurring data structure...
     C           X         OCUR MOLOT
     C                     MOVEALOT       XLOT
     C                     MOVELF4LOT     XFWLOT
     C                     MOVE '20'      @@ID
      *
      * if last cart, write out all carts with all lot ids...
     C           X         IFEQ NUMCRT
      *
      *    for every cart, move lot ids back in and write recs...
     C                     DO   NUMCRT    X
      *
     C           X         OCUR MOLOT
     C                     MOVELXLOT      ZLOT
      *
     C                     CLEARALGPP011
     C                     CLEARALGPP111
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    A1KOYY
     C                     Z-ADDWSSMMM    A1KOMM
     C                     Z-ADDWSSDDD    A1KODD
     C                     Z-ADDWSSTM6    A1KOTM
     C                     Z-ADDWSSYYY    A1SCYY
     C                     Z-ADDWSSMMM    A1SCMM
     C                     Z-ADDWSSDDD    A1SCDD
     C                     Z-ADDWSSTM6    A1SCTM
     C                     MOVEL#USER     A1USER
     C                     MOVEL#WSID     A1WSID
     C                     MOVEL#PGM      A1PGID
      *
     C           K#PCT1    KLIST
     C                     KFLD           K@WD1   8
     C                     KFLD           K@WD2   8
     C                     MOVEL'ALGR011 'K@WD1     P
     C                     MOVELF1LINE    K@WD2     P
     C           K#PCT1    CHAINAB#PPCT              97
     C           *IN97     IFEQ *ON
     C                     CLEARAB#PPCT1
     C                     MOVEL'ALGR011 'CTKEY1
     C                     MOVELF1LINE    CTKEY2    P
     C                     Z-ADDWSSYM     CTNBR1
     C                     END
     C           WSSYM     IFNE CTNBR1
     C                     Z-ADDWSSYM     CTNBR1
     C                     Z-ADD*ZERO     CTNBR2
     C                     END
     C                     Z-ADDCTNBR1    W@YYMM
     C                     Z-ADDW@YYYY    A1TSQY
     C                     Z-ADDW@MMMM    A1TSQM
     C                     ADD  1         CTNBR2
     C                     Z-ADDCTNBR2    A1TSQ#
     C   97                WRITEAB#PPCT1
     C  N97                UPDATAB#PPCT1
      *
     C                     MOVELF1USRC    A1TMCD
     C                     MOVELF1SHFT    A1SHFT
     C                     MOVELJ6RONO    A1RONO
      *
     C                     MOVELA2BHB1    A1SHN1
     C                     MOVELA2BHB2    A1SHN2
     C                     MOVELA2BHB3    A1SHN3
TCHK1C                     MOVELJ6ZACD    A1ZACD
TCHK1C           J6ZACD    CHAINFCETL06              97
TCHK1C           *IN97     IFEQ *OFF
     C                     MOVELA2ZANM    A1ZANM
TCHK1C                     END
      *
     C                     Z-ADDJ6HOJI    A1HOJI
     C                     Z-ADDJ6ONDO    A1ONDO
     C                     Z-ADDJ6CO2P    A1CO2P
     C                     Z-ADDJ6HKJR    A1HKJR
     C                     Z-ADDJ6LOTO    A1CONT
     C           A1HKJR    MULT A1CONT    A1TTLW    H
      *
     C                     MOVELW2ZETI    XXZETI
      * CHECK DIGIT
     C                     MOVELXXBARC    PMAREA    P
     C                     MOVE '010'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C                     MOVELPMCHK     XXCHKD
      *
     C                     MOVELXXKAN     A1KAN
      *
     C                     MOVELF1PRNT    A1PRNT
     C                     MOVELF1LINE    A1LINE
      *
      * ------------------------------------------------------------
      * THIS SECTION OF CODE WAS MOVED FROM BOTTOM OF THIS SUBR ****
      *  SO THAT SERIAL BARCODE COULD BE STORED IN DATA FILES ALSO.  ****
      *
     C           'ALGR012 'CHAINAB#PPCT              97
     C           *IN97     IFEQ *ON
     C                     CLEARAB#PPCT1
     C                     MOVEL'ALGR012 'CTKEY1
     C                     Z-ADDWSSDAT    CTNBR1
     C                     END
     C           WSSDAT    IFNE CTNBR1
     C                     Z-ADDWSSDAT    CTNBR1
     C                     Z-ADD*ZERO     CTNBR2
     C                     END
     C                     Z-ADDCTNBR1    W@BAR1
     C                     ADD  1         CTNBR2
     C                     Z-ADDCTNBR2    W@BAR2
     C   97                WRITEAB#PPCT1
     C  N97                UPDATAB#PPCT1
      *
      * CHECK DIGIT
     C                     MOVELW@BAR@    PMAREA    P
     C                     MOVE '011'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C                     MOVELPMCHK     W@BAR3
      *
     C                     MOVELW@BARC    A1SERL
      *
      * ------------------------------------------------------------
      *
     C                     WRITEALGPP011
      *
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
      *
     C                     ADD  1         Y
     C           Y         IFGT 4
     C                     LEAVE
     C                     END
     C           LOT,Y     IFEQ *BLANK
     C                     LEAVE
     C                     END
      *
     C                     CLEARALGPP111
      *
     C                     Z-ADDA1KOYY    ABKOYY
     C                     Z-ADDA1KOMM    ABKOMM
     C                     Z-ADDA1KODD    ABKODD
     C                     Z-ADDA1KOTM    ABKOTM
     C                     MOVELA1USER    ABUSER
     C                     MOVELA1WSID    ABWSID
     C                     MOVELA1PGID    ABPGID
      *
     C                     MOVELA1LINE    ABLINE
     C                     Z-ADDA1TSQY    ABTSQY
     C                     Z-ADDA1TSQM    ABTSQM
     C                     Z-ADDA1TSQ#    ABTSQ#
     C                     Z-ADDA1SCYY    ABSCYY
     C                     Z-ADDA1SCMM    ABSCMM
     C                     Z-ADDA1SCDD    ABSCDD
     C                     Z-ADDA1SCTM    ABSCTM
      *
     C                     MOVELLOT,Y     ABLOT0
     C                     MOVELLOT,Y     W3LOT
     C                     MOVELW3LOT1    ABLOT1
     C                     MOVELW3CHKD    ABLOT2
      *
     C                     MOVELW@BARC    ABSERL
      *
     C                     WRITEALGPP111
      *
     C                     ENDDO
      *
     C                     EXSR #WRT40
      *
     C                     OPEN ALGPR02
      *
     C                     SORTALOT
     C                     DO   4
     C           LOT,1     IFEQ *BLANK
     C                     MOVELLOT,2     LOT,1
     C                     MOVELLOT,3     LOT,2
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     END
     C           LOT,2     IFEQ *BLANK
     C                     MOVELLOT,3     LOT,2
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     END
     C           LOT,3     IFEQ *BLANK
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     END
     C                     ENDDO
      *
     C                     Z-ADDWSSMMM    P@MM
     C                     Z-ADDWSSDDD    P@DD
     C                     Z-ADDWSSYYY    P@YY
     C                     MOVELF1SHFT    P@SHFT
     C           LOT,1     IFNE *BLANK
     C                     MOVELLOT,1     W3LOT
     C                     MOVELW3LOT1    P@LOT1    P
     C                     MOVELLOT,2     W3LOT
     C                     MOVELW3LOT1    P@LOT2    P
     C                     MOVELLOT,3     W3LOT
     C                     MOVELW3LOT1    P@LOT3    P
     C                     MOVELLOT,4     W3LOT
     C                     MOVELW3LOT1    P@LOT4    P
     C                     ELSE
     C                     MOVELXFWLOT    P@LOT1
     C                     MOVEL*BLANK    P@LOT2
     C                     MOVEL*BLANK    P@LOT3
     C                     MOVEL*BLANK    P@LOT4
     C                     END
     C                     MOVELF1LINE    P@LINE
     C                     Z-ADDA1TSQ#    P@TSQ#
     C                     CLEARW@SHIN
     C                     MOVELA2BHB1    W@SHN1
     C           A2BHB2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELA2BHB2    W@SHN2
     C           A2BHB3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELA2BHB3    W@SHN3
     C                     MOVELW@SHIN    P@SHIN
     C                     MOVELA2ZANM    P@ZANM
     C                     Z-ADDJ6HOJI    P@HOJI
     C                     Z-ADDJ6ONDO    P@ONDO
     C                     Z-ADDJ6CO2P    P@CO2P
     C                     MOVELW@BARC    P@BARC
     C                     MOVELW@BARC    P@BAR2
     C                     WRITEP@REC1
     C                     WRITEP@REC2
     C                     WRITEP@REC3
      *
     C                     CLOSEALGPR02
      *
     C                     ENDDO
      *
      * after records have been output and printed, call pgm to delay
      * job for 5 mins. so that the input is locked and nothing else can
      * be scanned in and loaded.  in between job delay...
      ************         WRITEFMTDLY
     C           #USER     IFNE 'TEST'
     C           #USER     ANDNE'OQTEST'
     C                     CALL 'ALGC05'
     C                     ENDIF
     C                     MOVE '15'      @@ID
      *
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
** ERR
USER CODE ERR                    #01
SHIFT CD  ERR                   #02
PRINTER# ERR                     #03
KANBAN ERROR                     #04
BLANK                            #05
CHECK DIGIT                      #06
PART M/F ERR                     #07
KANBAN M/F ERR                   #08
LOT ID ERROR                     #09
BLANK                            #10
DUPLICATE                        #11
LINE NO ERROR                    #12
# OF CARTS ERR                   #13
ENTER 1,2,3,OR 4                 #14
P/N MISMATCH                     #15
                                 #16
                                 #17
                                 #18
                                 #19
                                 #20
** CMD
OVRPRTF FILE(ALGPR02) OUTQ(QPRINT  ) SAVE(*YES)
