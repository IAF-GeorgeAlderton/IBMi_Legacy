      *================================================================
      *   MAIN
      *================================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#D2SET  '#D2SET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * INITIALIZATION
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     MOVELP@HIN1    D1HIN1
     C                     MOVELP@HIN2    D1HIN2
     C                     MOVELP@HIN3    D1HIN3
     C                     Z-ADDP@DATE    D1DATE
     C                     Z-ADDP@BIN     D1BIN   20
      *
     C                     TIME           @TIME
     C                     Z-ADD@SYSHZ    $$YMD
     C*
     C                     SETON                     44
     C                     SETOF                     454647
     C                     SETOF                     4849
     C*
     C                     SETOF                     57     (BL)
     C                     SETOF                     58     (BL)
     C                     SETOF                     59     (BL)
     C*  PART M/F
     C           KEY01     CHAINFCEPL01              91
     C  N91      A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C*  PROCESS M/F
     C           *IN91     IFEQ *OFF
     C           KEY01     CHAINAAMPL11              91
     C  N91      CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN91     IFEQ *OFF
     C                     MOVE '#D2SET  '@STEP
     C                     ELSE
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
     C           #D2SET    BEGSR
      *===============================================================
     C                     SETOF                     212223
     C                     SETOF                     242526
      * QTY CHANGE OVER DATE
     C           A2SYHZ    IFLE @SYSHZ
     C                     Z-ADDA2SSYS    D2SYSU  50       新収容数
     C                     ELSE
     C                     Z-ADDA2KSYS    D2SYSU           旧収容数
     C                     ENDIF
      * BOX/DAY
     C           A2GEKN    DIV  20        W$HIS   90       日当数量
     C           W$HIS     DIV  D2SYSU    HAKO      H      日当数量
     C*
     C                     MOVEL*BLANK    @KT              旧製造工程
     C                     Z-ADD0         @BM              旧製造部門
     C                     MOVEL*BLANK    @HN              旧工程内品番
     C                     MOVEL*BLANK    @KB              旧引当機番
     C                     MOVEL*BLANK    @BN              旧所番地
     C                     MOVEL*BLANK    @KS              旧かんばん種類
     C                     Z-ADD0         @HZ              切替日・便
     C*
S1   C           1         DO   15        A       20
     C           KHZ,A     IFNE 0
     C                     MOVELKHZ,A     $CHKDT  80       1
     C                     MOVELKQK,A     @KT,A            旧製造工程
     C                     MOVELKQB,A     @BM,A            旧製造部門
     C                     MOVELKQH,A     @HN,A            旧工程内品番
     C                     MOVELKQN,A     @KB,A            旧引当機番
     C                     MOVELKQT,A     @BN,A            旧所番地
     C                     MOVELKQS,A     @KS,A            旧かんばん種類
     C                     MOVELKHZ,A     @HZ,A            切替日・便
     C           @SYSHZ    IFGE $CHKDT
     C                     MOVELKKO,A     @KT,A            製造工程
     C                     MOVELKBM,A     @BM,A            製造部門
     C                     MOVELKHB,A     @HN,A            工程内品番
     C                     MOVELKKB,A     @KB,A            引当機番
     C                     MOVELKNB,A     @BN,A            所番地
     C                     MOVELKTY,A     @KS,A            かんばん種類
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETOF                     79
     C           'SB '     LOKUP@KT                      79
      *
      *最終工程から前の６工程と表示
      *
     C                     MOVE *BLANK    DKT              工程
     C                     Z-ADD0         DBM              部門
     C                     MOVEL*BLANK    DNM
     C                     MOVEL*BLANK    DKB              機番
     C                     MOVEL*BLANK    DBN              番地
     C                     MOVEL*BLANK    DHN              品番
     C                     Z-ADD0         DHZ              切替日
     C                     Z-ADD6         B       20
     C                     Z-ADD15        C       20
     C                     MOVE *BLANK    LAST
     C                     MOVEL*BLANK    WCHK    1
     C                     Z-ADD0         K       20
     C                     MOVE *BLANK    @@GAI   4        外注
     C*-------------------------
S1   C           1         DO   15        A       20
     C*------------------S2
 S2  C           @KT,C     IFNE *BLANK                     工程
  S3 C           C         IFLT B
     C                     Z-ADDC         B
  E3 C                     ENDIF
     C*
     C                     MOVE @KT,C     DKT,B            工程
     C                     Z-ADD@BM,C     DBM,B            部門
     C                     MOVEL@KB,C     DKB,B            機番
     C                     MOVEL@BN,C     DBN,B            番地
     C                     MOVEL@HN,C     DHN,B            品番
     C                     MOVE @HZ,C     DHZ,B            切替日
     C** *
     C           @@GAI     IFEQ *BLANK                     外注= *
     C           C         SUB  1         C1      20
     C           @BM,C     IFNE 111                        部門
     C                     MOVE @BM,C     @@GAI            外注= *
     C                     MOVE @HN,C     @@HIN            品番
     C                     ELSE
     C           C1        IFNE 0                          番地
     C           @BN,C1    ANDNE'------'                   番地
     C                     MOVE @BM,C     @@GAI            外注= *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C**
     C           B         ADD  20        K
     C           WCHK      IFEQ *BLANK
     C           SSU,C     IFNE 0
     C           A2GEKN    ANDNESSU,C
     C                     MOVE '1'       *IN,K
     C                     MOVEL'1'       WCHK    1
     C                     ENDIF
     C                     ENDIF
     C**
     C           LAST      IFEQ *BLANK
     C                     MOVE DBM,B     LAST    4
     C                     END
     C           DBM,B     CHAINFGBPL01              91
     C  N91                MOVELB2SMEI    DNM,B
     C*
     C           B         IFLE 1
     C                     LEAVE
     C                     ENDIF
     C           B         SUB  1         B
 E2  C                     ENDIF
     C*------------------E2
     C           C         IFLE 1
     C                     LEAVE
     C                     ENDIF
     C           C         SUB  1         C
E1   C                     ENDDO
