     C                     PARM           S1ZENO
     C                     PARM           S1THNO
     C                     PARM           P$FLG            1=F1,3=F3
     C                     ENDIF
     C                     MOVE ' '       S1SEL
     C           S1CHYU    COMP 'R'                      41
     C                     SETOF                     9293
     C           S1IN92    IFEQ '1'
     C                     SETON                     92
     C                     END
     C           S1IN93    IFEQ '1'
     C                     SETON                     93
     C                     END
     C           S1IN94    IFEQ '1'
     C                     SETON                     94
     C                     END
      *
     C                     UPDATSFREC1
     C           P$FLG     IFEQ '1'                        1=F1,3=F3
     C                     MOVE '#END    '@STEP
     C                     LEAVE
     C                     ENDIF
E1   C  N99                ENDDO
     C*-------------------------
     C                     ENDSR
      *===============================================================
      * EDIT DATE AND TIME
      *===============================================================
     C           ##EDIT    BEGSR
     C                     MOVEL*BLANK    $$DAY   5
     C                     MOVEL*BLANK    $$TIME  5
     C*
     C           W$DATE    IFNE 0
     C                     Z-ADDW$MM      $$HBMM
     C                     MOVE '.'       $$HB1
     C                     Z-ADDW$DD      $$HBDD
     C                     MOVEL$$HB      $$DAY
     C                     Z-ADDW$JJ      $$HBMM
     C                     MOVE ':'       $$HB1
     C                     Z-ADDW$FF      $$HBDD
     C                     MOVEL$$HB      $$TIME
     C                     ENDIF
     C*
     C                     MOVE '.'       $$HB1
     C                     ENDSR
      *===============================================================
      * INQUIRE PRODUCTION PROCESS INFORMATION
      *===============================================================
     C           ##AKAR    BEGSR
      *
     C                     MOVE 'X'       P$SNO   1
     C                     MOVE *BLANK    P$F3    1
     C                     MOVE *BLANK    P$ERR   1
      *-------------------------
