     H            Y/
      *** ALDRS5 *************************************
      *  GET STATUS OF EACH PLASTIC KANBAN           *
      *     2019.09.25         T-SAKAKI              *
      ************************************* ALDRS4 ***
     I            DS
     I                                        1   80K@HTHZ
     I                                        1   40K@SYYY
     I                                        5   60K@SYMM
     I                                        7   80K@SYDD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  8
     C                     PARM           P@BFLG  1         BZ/DS MACHINE
     C                     PARM           P@AFLG  1         JC MACHINE
     C                     PARM           P@MAIS  4
     C                     PARM           P9BZK   40        BZ計量済み
     C                     PARM           P9DSK   40        DS計量済み
     C                     PARM           P9JCK   40        JC計量済み
     C                     PARM           P9BZI   40        BZ投入中
     C                     PARM           P9DSI   40        DS投入中
     C                     PARM           P9JCI   40        JC投入中
      *
     C                     MOVE P@CHYU    K@CHYU  1
     C                     MOVE P@ZENO    K@ZENO  4
     C                     MOVE P@THNO    K@THNO  3
     C                     MOVE P@HTHZ    K@HTHZ  80
     C                     MOVE P@PAGE    K@PAGE  2
     C                     MOVE P@HIN1    K@SHN1  5
     C                     MOVE P@HIN2    K@SHN2  5
     C                     MOVE P@HIN3    K@SHN3  2
      *
      *
     C           ALJKEY    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C                     Z-ADD0         @CNT    40
     C                     Z-ADD0         P9BZK
     C                     Z-ADD0         P9DSK
     C                     Z-ADD0         P9JCK
     C                     Z-ADD0         P9BZI
     C                     Z-ADD0         P9DSI
     C                     Z-ADD0         P9JCI
      *
     C                     MOVE P@HTHZ    Q@HTHZ
      *
     C                     MOVE @CNT      P@MAIS
      *------------------------------------------------
      * OUT
      *------------------------------------------------
     C                     EXSR #SBK                       KEIRYO
      *------------------------------------------------
      * IN
      *------------------------------------------------
     C           P9BZK     IFEQ 0
     C           P9DSK     ANDEQ0
     C           P9JCK     ANDEQ0
     C                     EXSR #SBI                       TONYU
     C                     ENDIF
      *------------------------------------------------
      *
     C                     EXSR #CLOSE
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      *計量                                            *
      *--------------------------------------------------*
     CSR         #SBK      BEGSR
      *
     C                     EXSR ##KEI
      *
     C           P9JCK     IFEQ 0
     C                     EXSR ##KEI2
     C                     ENDIF
      *
     C           P9JCK     IFEQ 0
     C           P9JCI     ANDEQ0
     C                     EXSR ##KEI3
     C                     ENDIF
      *
     C           P9JCK     IFEQ 0
     C           P9JCI     ANDEQ0
     C           P9DSK     ANDEQ0
     C                     EXSR ##KEI4
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         計量日・時刻   JC
      *===============================================================
     CSR         ##KEI     BEGSR
      *
     C                     CALL 'ALDRT2'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
      *
     C           P@KEHZ    IFNE 0
     C                     ADD  4         P9JCK
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻    JC
      *===============================================================
     CSR         ##KEI2    BEGSR
      *
     C                     CALL 'ALDRT3'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
      *
     C                     MOVELP@AFLG    AFLG    1
      *
     C           P@KEHZ    IFNE 0
     C           AFLG      IFEQ '1'
     C                     ADD  1         P9JCI
     C                     ELSE
     C                     ADD  1         P9JCK
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         計量日・時刻  DS
      *===============================================================
     CSR         ##KEI3    BEGSR
      *
     C                     CALL 'ALDRT4'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C                     MOVELP@BFLG    BFLG    1
      *
     C           P@WIHZ    IFNE 0
      * BFLG = '1' DS1,2,3,4
     C           BFLG      IFEQ '1'
     C                     ADD  2         P9DSK
     C                     ELSE
     C                     ADD  4         P9DSK
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         計量日・時刻  BZ
      *===============================================================
     CSR         ##KEI4    BEGSR
     C                     CALL 'ALDRT8'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  4         P9BZK
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------*
      *投入                                            *
      *--------------------------------------------------*
     CSR         #SBI      BEGSR
      *
     C                     EXSR ##WIN
      *
     C           P9BZI     IFEQ 0
     C                     EXSR ##WIN2
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻 BZ
      *===============================================================
     CSR         ##WIN     BEGSR
     C                     CALL 'ALDRT5'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
      *                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  1         P9BZI
     C                     ENDIF
      *
     CSR                   ENDSR
      *===============================================================
      *         投入日・時刻  DS
      *===============================================================
     CSR         ##WIN2    BEGSR
     C                     CALL 'ALDRT6'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  1         P9DSI
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------*
      * CLOSE FILE                                       *
      *--------------------------------------------------*
     CSR         #CLOSE    BEGSR
      *
     C                     MOVEL'9'       P#OPN   1
      *
     C                     CALL 'ALDRT2'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
      *
     C                     CALL 'ALDRT3'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
      *
     C                     CALL 'ALDRT4'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C                     CALL 'ALDRT5'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
      *                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C                     CALL 'ALDRT6'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C                     CALL 'ALDRT8'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     CSR         ECLOSE    ENDSR
