     H            Y.
     F** AN#RFI ********************************************
     F*  ANDROID PRINT BILL OF LADING                      *
     F*                                                    *
     F* TCHK1 07/27/06 CREATE(COPY FROM AB#RFI)            *
     F******************************************************
     FAN#PWFI CF  E                    WORKSTN
     FABR6L03 IF  E           K        DISK                           UC
     FABR6L04 IF  E           K        DISK                           UC
     F            ABR6P011                          KRENAMEABR6L041
TCH  FABR6L07 IF  E           K        DISK                           UC
TCH  F            ABR6P011                          KRENAMEABR6L071
     FAGDPL12 IF  E           K        DISK
     FAN#WPFI1O   F     256            DISK                           UC
     E                    ERR     1  20 60
     I            DS
     I                                        1   80FCSKHZ
     I                                        1   40FCSKYY
     I                                        5   60FCSKMM
     I                                        7   80FCSKDD
     I            DS
     I                                        1   80FCSHDT
     I                                        1   40FCSHYY
     I                                        5   60FCSHMM
     I                                        7   80FCSHDD
     I            DS
     I                                        1   80FCRYHZ
     I                                        1   40FCRYYY
     I                                        5   60FCRMMM
     I                                        7   80FCRDDD
     I            DS
     I                                        1   80@REHZ2
     I                                        1   40@REYY2
     I                                        5   60@REMM2
     I                                        7   80@REDD2
     I            DS
     I                                        1   80@SIHZ2
     I                                        1   40@SIYY2
     I                                        5   60@SIMM2
     I                                        7   80@SIDD2
     I            DS
     I                                        1   80@SIHZ3
     I                                        1   40@SIYY3
     I                                        5   60@SIMM3
     I                                        7   80@SIDD3
TCH  I            DS
 |   I                                        1   80@SIHZ4
     I                                        1   40@SIYY4
 |   I                                        5   60@SIMM4
TCH  I                                        7   80@SIDD4
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@CAR  15
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     MOVEL*BLANK    @DATA   1
     C                     MOVEL*BLANK    @KOKB1
     C                     MOVEL*BLANK    @KOKB2
     C                     MOVEL*BLANK    @KOKB3
TCH  C                     MOVEL*BLANK    @KOKB4
     C                     MOVEL*BLANK    @BINO1           BILL OF LADING
     C                     MOVEL*BLANK    @BINO2           BILL OF LADING
     C                     Z-ADD0         @REHZ2           RELEASED DATE
     C                     Z-ADD0         @SIHZ2           SHIPPING DATE
     C                     Z-ADD0         @DECD3           DELIVERY CODE
     C                     Z-ADD0         @SIHZ3           SHIPPING DATE
     C                     Z-ADD0         @SIBN3           BIN
TCH  C                     Z-ADD0         @SIHZ4           SHIPPING DATE
TCH  C                     Z-ADD0         @SIBN4           BIN
     C                     Z-ADD*ZERO     D@SHDT
      *
     C           @STP1     TAG
     C                     EXFMTAN#PWFI1
     C                     MOVEL*BLANK    @DATA
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     109911
     C*
     C           *INKA     IFEQ '1'
     C                     SETON                     LRU1
     C                     RETRN
     C                     END
     C*
     C           @KOKB1    IFEQ *BLANK
     C           @KOKB2    ANDEQ*BLANK
     C           @KOKB3    ANDEQ*BLANK
TCH  C           @KOKB4    ANDEQ*BLANK
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELERR,1     MSG
     C                     GOTO @STP1
     C                     END
     C*
     C           @KOKB1    IFNE *BLANK
     C           @KOKB2    ANDNE*BLANK
     C           @KOKB3    ANDNE*BLANK
TCH  C           @KOKB4    ANDNE*BLANK
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C*
     C           @KOKB1    IFNE *BLANK
     C           @KOKB2    ANDNE*BLANK
     C                     SETON                     0102
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C*
     C           @KOKB1    IFNE *BLANK
     C           @KOKB3    ANDNE*BLANK
     C                     SETON                     0103
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C*
     C           @KOKB2    IFNE *BLANK
     C           @KOKB3    ANDNE*BLANK
     C                     SETON                     0203
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
TCH  C*
     C           @KOKB4    IFNE *BLANK
     C           @KOKB1    ANDNE*BLANK
     C                     SETON                     0111
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C           @KOKB4    IFNE *BLANK
     C           @KOKB2    ANDNE*BLANK
     C                     SETON                     1102
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C           @KOKB4    IFNE *BLANK
     C           @KOKB3    ANDNE*BLANK
     C                     SETON                     1103
     C                     SETON                     99
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
TCH  C*
     C*
     C           @KOKB1    IFEQ *BLANK
     C           @KOKB1    OREQ '1'
     C                     ELSE
     C                     SETON                     0199
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C*
     C           @KOKB2    IFEQ *BLANK
     C           @KOKB2    OREQ '1'
     C                     ELSE
     C                     SETON                     0299
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
     C*
     C           @KOKB3    IFEQ *BLANK
     C           @KOKB3    OREQ '1'
     C                     ELSE
     C                     SETON                     0399
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
TCH  C*
     C           @KOKB4    IFEQ *BLANK
     C           @KOKB4    OREQ '1'
     C                     ELSE
     C                     SETON                     1199
     C                     MOVELERR,2     MSG
     C                     GOTO @STP1
     C                     END
TCH  C*
     C*
     C           @KOKB1    IFEQ '1'
     C           @BINO1    IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVELERR,3     MSG
     C                     GOTO @STP1
     C                     END
     C                     END
     C*
     C           @KOKB2    IFEQ '1'
     C           @BINO2    IFEQ *BLANK
     C                     SETON                     0599
     C                     MOVELERR,3     MSG
     C                     GOTO @STP1
     C                     END
     C           @REHZ2    IFEQ 0
     C                     SETON                     0699
     C                     MOVELERR,4     MSG
     C                     GOTO @STP1
     C                     END
     C           @REYY2    IFLT 2000
     C           @REMM2    ORLT 1
     C           @REMM2    ORGT 12
     C           @REDD2    ORLT 1
     C           @REDD2    ORGT 31
     C                     SETON                     0699
     C                     MOVELERR,5     MSG
     C                     GOTO @STP1
     C                     END
     C           @SIHZ2    IFEQ 0
     C                     SETON                     0799
     C                     MOVELERR,6     MSG
     C                     GOTO @STP1
     C                     END
     C           @SIYY2    IFLT 2000
     C           @SIMM2    ORLT 1
     C           @SIMM2    ORGT 12
     C           @SIDD2    ORLT 1
     C           @SIDD2    ORGT 31
     C                     SETON                     0799
     C                     MOVELERR,9     MSG
     C                     GOTO @STP1
     C                     END
     C                     END
     C*
B0   C           @KOKB3    IFEQ '1'
B1   C           @DECD3    IFEQ 0
     C                     SETON                     0899
     C                     MOVELERR,7     MSG
     C                     GOTO @STP1
E1   C                     END
B1   C           @SIHZ3    IFEQ 0
     C                     SETON                     0999
     C                     MOVELERR,6     MSG
     C                     GOTO @STP1
E1   C                     END
B1   C           @SIYY3    IFLT 2000
     C           @SIMM3    ORLT 1
     C           @SIMM3    ORGT 12
     C           @SIDD3    ORLT 1
     C           @SIDD3    ORGT 31
     C                     SETON                     0999
     C                     MOVELERR,9     MSG
     C                     GOTO @STP1
E1   C                     END
B1   C           @SIBN3    IFEQ 0
     C                     SETON                     1099
     C                     MOVELERR,8     MSG
     C                     GOTO @STP1
E1   C                     END
E0   C                     END
TCH  C*
B0 | C           @KOKB4    IFEQ '1'
B1   C           @SIHZ4    IFEQ 0
     C                     SETON                     1299
     C                     MOVELERR,6     MSG
     C                     GOTO @STP1
E1   C                     END
B1   C           @SIYY4    IFLT 2000
     C           @SIMM4    ORLT 1
     C           @SIMM4    ORGT 12
     C           @SIDD4    ORLT 1
     C           @SIDD4    ORGT 31
     C                     SETON                     1299
     C                     MOVELERR,9     MSG
     C                     GOTO @STP1
E1   C                     END
B1   C           @SIBN4    IFEQ 0
     C                     SETON                     1399
     C                     MOVELERR,8     MSG
     C                     GOTO @STP1
E1   C                     END
E0 | C                     END
TCH  C*
      *
     C           D@SHDT    IFNE *ZERO
     C                     Z-ADDD@SHDT    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     1199
     C                     MOVELERR,11    MSG
     C                     GOTO @STP1
     C                     ENDIF
     C                     ENDIF
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP1
     C                     END
     C*
     C                     CALL 'AN#CFJ'
     C                     OPEN AN#WPFI1
     C*
     C                     MOVE D@CARR    P@CAR
      *
     C           @KOKB1    IFEQ '1'
     C                     MOVEL*BLANK    KBINO  11
     C                     MOVEL@BINO1    KBINO  11
     C*
     C                     OPEN ABR6L03
     C                     SETOF                     20
     C           KBINO     SETLLABR6P011
     C                     DO   *HIVAL
     C           KBINO     READEABR6P011                 20
     C           *IN20     IFEQ '0'
     C           FCSKJY    IFEQ 'D'
     C           FCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #PLANT
     C           D@SHDT    IFEQ *ZERO
     C                     Z-ADDFCSHDT    D@SHDT
     C                     ENDIF
     C                     EXCPTDT
     C           @DATA     IFEQ *BLANK
     C                     MOVEL'*'       @DATA
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
     C                     CLOSEABR6L03
     C                     END
      *
     C           @KOKB2    IFEQ '1'
      *
     C                     MOVEL*BLANK    KBINO  11
     C                     MOVEL@BINO2    KBINO  11
     C           KEY1      KLIST
     C                     KFLD           KBINO
     C                     KFLD           @REYY2
     C                     KFLD           @REMM2
     C                     KFLD           @REDD2
     C                     KFLD           @SIHZ2
      *
     C                     OPEN ABR6L03
     C                     SETOF                     20
     C           KEY1      SETLLABR6P011
     C                     DO   *HIVAL
     C           KEY1      READEABR6P011                 20
     C           *IN20     IFEQ '0'
     C           FCSKJY    IFEQ 'D'
     C           FCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #PLANT
     C           D@SHDT    IFEQ *ZERO
     C                     Z-ADDFCSHDT    D@SHDT
     C                     ENDIF
     C                     EXCPTDT
     C           @DATA     IFEQ *BLANK
     C                     MOVEL'*'       @DATA
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
     C                     CLOSEABR6L03
     C                     END
      *
B0   C           @KOKB3    IFEQ '1'
      *
     C           KEY2      KLIST
     C                     KFLD           @DECD3
     C                     KFLD           @SIHZ3
     C                     KFLD           @SIBN3
      *
     C                     OPEN ABR6L04
     C                     SETOF                     20
     C           KEY2      SETLLABR6L041
B1   C                     DO   *HIVAL
     C           KEY2      READEABR6L041                 20
B2   C           *IN20     IFEQ '0'
B3   C           FCSKJY    IFEQ 'D'
     C           FCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #PLANT
B4   C           D@SHDT    IFEQ *ZERO
     C                     Z-ADDFCSHDT    D@SHDT
E4   C                     ENDIF
     C                     EXCPTDT
B4   C           @DATA     IFEQ *BLANK
     C                     MOVEL'*'       @DATA
E4   C                     END
E3   C                     END
E2   C                     END
E1   C  N20                ENDDO
     C                     CLOSEABR6L04
E0   C                     END
TCH  C*
B0 | C           @KOKB4    IFEQ '1'
      *
     C           KEY4      KLIST
     C                     KFLD           @SIHZ4
     C                     KFLD           @SIBN4
      *
     C                     OPEN ABR6L07
     C                     SETOF                     20
     C           KEY4      SETLLABR6L071
B1   C                     DO   *HIVAL
     C           KEY4      READEABR6L071                 20
B2   C           *IN20     IFEQ '0'
B3   C           FCSKJY    IFEQ 'D'
     C           FCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #PLANT
B4   C           D@SHDT    IFEQ *ZERO
     C                     Z-ADDFCSHDT    D@SHDT
E4   C                     ENDIF
     C                     EXCPTDT
B4   C           @DATA     IFEQ *BLANK
     C                     MOVEL'*'       @DATA
E4   C                     END
E3   C                     END
E2   C                     END
E1   C  N20                ENDDO
     C                     CLOSEABR6L07
E0 | C                     END
TCH  C*
B0   C           @DATA     IFEQ '*'
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ELSE
     C                     SETON                     99
     C                     MOVELERR,10    MSG
     C                     CLOSEAN#WPFI1
     C                     GOTO @STP1
E0   C                     END
     C*****************************************************************
     CSR         #PLANT    BEGSR
     C*****************************************************************
     C*
     C                     SELEC
     C           FCDELY    WHEQ 2855
     C                     MOVEL'AIW01'   WWPLAN  5
     C           FCDELY    WHEQ 2856
     C                     MOVEL'AIL01'   WWPLAN
     C                     OTHER
     C                     MOVEL'XXXXX'   WWPLAN
     C                     ENDSL
     C*
     CSR         EPLANT    ENDSR
     OAN#WPFI1E                DT
     O                         FCSHDT
     O                         FCSHTM
     O                         FCRYHZ
     O                         FCASN#
     O                         FCDELY
     O                         FCDOCK
     O                         FC#CON
     O                         WWPLAN
     O                         D@SHDT
** ERR
E-01 PLEASE MAKE ONE SELECTION
E-02 PLEASE ENTER ONLY 1 TO SELECTION
E-03 PLEASE ENTER THE BILL OF LADING NUMBER
E-04 PLEASE ENTER THE RELEASE DATE
E-05 INCORRECT RELEASE DATE
E-06 PLEASE ENTER THE SHIPPING DATE
E-07 PLEASE ENTER THE DELIVERY CODE
E-08 PLEASE SPECIFY BIN
E-09 INCORRECT SHIPPING DATE
E-10 NO DATA FOUND
E-11 DATE ERROR
