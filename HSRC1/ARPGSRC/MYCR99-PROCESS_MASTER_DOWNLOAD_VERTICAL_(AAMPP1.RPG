      ****************************************************
     FGHCPL21 IF  E           K        DISK
     F**FCEPL01 IF  E           K        DISK
     FGHCWP21AO   E                    DISK
      ****************************************************
     E**                  COM     1   1  1
     I            DS
     I                                        1  14 M7JHIN
     I                                        1   5 M7JHN1
     I                                        6   6 PH1
     I                                        7  11 M7JHN2
     I                                       12  12 PH2
     I                                       13  14 M7JHN3
     I            DS
     I                                        1  14 M7MHIN
     I                                        1   5 M7MHN1
     I                                        6   6 PH3
     I                                        7  11 M7MHN2
     I                                       12  12 PH4
     I                                       13  14 M7MHN3
     I            DS
     I                                        1   9 M7LOC
     I                                        1   1 M7MBN1
     I                                        2   2 PH5
     I                                        3   4 M7MBN2
     I                                        5   5 PH6
     I                                        6   7 M7MBN3
     I                                        8   8 PH7
     I                                        9   9 M7MBN4
      ****************************************************
      *  MAIN ROUTINE
      ****************************************************
     C                     MOVE '-'       PH5
     C                     MOVE '-'       PH6
     C                     MOVE '-'       PH7
      *
     C                     DO   *HIVAL
     C                     READ GHCPL21                  98
     C   98                LEAVE
      *
     C           M7JHN2    IFEQ *BLANK
     C                     MOVE ' '       PH1
     C                     ELSE
     C                     MOVE '-'       PH1
     C                     ENDIF
      *
     C           M7JHN3    IFEQ *BLANK
     C                     MOVE ' '       PH2
     C                     ELSE
     C                     MOVE '-'       PH2
     C                     ENDIF
      *
     C           M7MHN2    IFEQ *BLANK
     C                     MOVE ' '       PH3
     C                     ELSE
     C                     MOVE '-'       PH3
     C                     ENDIF
      *
     C           M7MHN3    IFEQ *BLANK
     C                     MOVE ' '       PH4
     C                     ELSE
     C                     MOVE '-'       PH4
     C                     ENDIF
      *
     C**                   MOVELCOM,1     X7MBMN
     C**                   MOVE M7MBMN    X7MBMN
     C                     MOVE *BLANK    X7MBMN
     C                     MOVELM7MBMN    X7MBMN
      *
     C                     WRITEGHCWP211
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
