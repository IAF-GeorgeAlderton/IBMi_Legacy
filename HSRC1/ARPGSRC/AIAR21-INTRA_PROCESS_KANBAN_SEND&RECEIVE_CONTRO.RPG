     C                     MOVE '19'      DAERCD           *
     C                     GOTO STP15                      *
     C                     END                             *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  データ転送コントロールファイルにＪＯＢＮＯ更新  *
     C*----------------------------------------------------*
     C           STP14     TAG                             *
     C                     SETOF                     03    *
     C           KEY1      CHAINAALPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDUJOBN     CLJOBN           *
     C                     UPDATAALPL111                   *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  ファイル名セット                                *
     C*  Ａ　データグループ　工場コード　便　リラン      *
     C*  リランは、再生の場合の時                        *
     C*----------------------------------------------------*
     C                     MOVE *BLANK    WMILE            *
     C                     MOVE 'A'       WMA              *
     C                     MOVE AGRUP     WMGRUP           *
     C                     MOVE ABMON     WMBMON           *
     C                     MOVE AKUBN     WMRIRN           *
     C                     MOVE WMILE     UFILE            *
     C                     EXSR SUBCHK                     *
     C           WCHK      IFEQ '1'                        *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     TIME           HHMMSS           *
     C                     MOVE HHMMSS    ETIME            *
     C                     SETON                     LR    *
     C                     RETRN                           *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C           STP15     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     Z-ADDCLDTHZ    ANOHZ            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
      *
     C*--------------------------*                         *
     C*  工程内かんばんデータ  *                         *
     C*  焼入かんばんデータ    *                         *
     C*--------------------------*                         *
     C*----------*                                         *
     C*  再生  *                                         *
     C*----------*                                         *
     C           AKUBN     IFEQ 'Y'                        *
     C           AIJUNB    IFEQ '*'                        *
     C           AIKANR    ANDEQ'*'                        *
     C                     ELSE                            *
      *
     C*------------------------*                           *
     C*  データ準備中か？    *                           *
     C*------------------------*                           *
     C           AIJUNB    IFEQ 'H'                        *
     C                     MOVE '35'      AMESG            *
     C                     MOVE '35'      DAERCD           *
     C                     GOTO STP16                      *
     C                     END                             *
      *
     C*----------------------*                             *
     C*  データ有るか？    *                             *
     C*----------------------*                             *
     C           AIJUNB    IFEQ 'D'                        *
     C                     MOVE '36'      AMESG            *
     C                     MOVE '36'      DAERCD           *
     C                     GOTO STP16                      *
     C                     END                             *
     C                     END                             *
     C                     ELSE                            *
      *
     C*----------*                                         *
     C*  新規  *                                         *
     C*----------*                                         *
     C           AIJUNB    IFEQ '*'                        *
     C           AIKANR    ANDEQ*BLANK                     *
     C                     ELSE                            *
      *
     C*------------------------*                           *
     C*  データ準備中か？    *                           *
     C*------------------------*                           *
     C           AIJUNB    IFEQ 'H'                        *
     C                     MOVE '37'      AMESG            *
     C                     MOVE '37'      DAERCD           *
     C                     GOTO STP16                      *
     C                     END                             *
      *
     C*----------------------*                             *
     C*  データ有るか？    *                             *
     C*----------------------*                             *
     C           AIJUNB    IFEQ 'D'                        *
     C                     MOVE '38'      AMESG            *
     C                     MOVE '38'      DAERCD           *
     C                     GOTO STP16                      *
     C                     END                             *
      *
     C*----------------------*                             *
     C*  データ完了か？    *                             *
     C*----------------------*                             *
     C           AIJUNB    IFEQ '*'                        *
     C           AIKANR    ANDEQ'*'                        *
     C                     MOVE '39'      AMESG            *
     C                     MOVE '39'      DAERCD           *
     C                     GOTO STP16                      *
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C* ファイル転送コントロールマスターにＪＯＢＮＯ更新 *
     C*----------------------------------------------------*
     C                     SETOF                     03    *
     C           XFILE     CHAINAAIPP211             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDUJOBN     AIJOBN           *
     C                     UPDATAAIPP211                   *
     C                     END                             *
      *
     C*----------------------*                             *
     C*  ファイル名セット  *                             *
     C*----------------------*                             *
     C                     MOVE *BLANK    WMILE            *
     C                     MOVELXFILE     WMILE            *
     C                     MOVE WMILE     UFILE            *
     C                     EXSR SUBCHK                     *
     C           WCHK      IFEQ '1'                        *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     TIME           HHMMSS           *
     C                     MOVE HHMMSS    ETIME            *
     C                     SETON                     LR    *
     C                     RETRN                           *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C           STP16     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     Z-ADD*DATE     ANOHZ            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
      *
     C*----------------------------------------------------*
     C*  サブルーチン                                    *
     C*  ＪＯＢＬＯＧファイル　ＷＲＩＴＥ (AI#PP01)      *
     C*----------------------------------------------------*
     C           SUBJOB    BEGSR                           *
     C                     MOVE *BLANK    DADATA           *
     C                     MOVELAALLD     DADATA           *
     C                     Z-ADDABMON     DABUCD           *
     C                     Z-ADD*DATE     DATUHZ           *
     C                     TIME           DATIME           *
     C                     WRITEAI#PP011                   *
     C                     ENDSR                           *
      *
     C*----------------------------------------------------*
     C*  サブルーチン                                    *
     C*  ファイル　の　チェック                          *
     C*----------------------------------------------------*
     C           SUBCHK    BEGSR                           *
     C                     MOVE *BLANK    WCHK    1        *
     C                     CALL 'AIACCC'                   *
     C                     PARM           UFILE            *
     C                     PARM           WCHK             *
     C           WCHK      IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '32'      AMESG            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '32'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     END                             *
     C                     ENDSR                           *
      *
     C*----------------------------------------------------*
     C*  サブルーチン　　ＡＴ                            *
     C*  ローカルデータエリア　工場別レコード区分変更    *
     C*----------------------------------------------------*
     C           SAT       BEGSR                           *
     C           ABMON     IFEQ 0111                       *
     C                     MOVE 'AT'      U0111            *
     C                     END                             *
     C                     ENDSR                           *
      *
     C*----------------------------------------------------*
     C*  サブルーチン　　ＲＱ                            *
     C*  ローカルデータエリア　工場別レコード区分変更    *
     C*----------------------------------------------------*
     C           SRQ       BEGSR                           *
     C           ABMON     IFEQ 0111                       *
     C                     MOVE 'RQ'      U0111            *
     C                     END                             *
     C                     ENDSR                           *
     C*----------------------------------------------------*
      *
     C*----------------------------------*
     C* ERROR SUBROUTINE                 *
     C*----------------------------------*
     C           INFSR     BEGSR
     C           SW        IFNE '1'
     C                     CALL 'AIAC01'
     C                     TIME           HHMMSS  60
     C                     MOVE *DATE     DATUHZ
     C                     MOVE HHMMSS    DATIME
     C                     MOVE ERRCD1    DARETN
     C                     MOVE *BLANK    DADATA
     C                     MOVEL'**AB_OPE'TXT1   16
     C                     MOVE ' EXIT  *'TXT1
     C                     MOVELTXT1      DADATA
     C                     WRITEAI#PP011
     C                     ELSE
     C                     SETON                     H1
     C                     RETRN
     C                     END
     C                     MOVE '0'       SW      1
     C                     ENDSR'*CANCL'
      *
     C*----------------------------------*
     C* ERROR SUBROUTINE                 *
     C*----------------------------------*
     C           *PSSR     BEGSR
     C           SW        IFNE '1'
     C                     CALL 'AIAC01'
     C                     TIME           HHMMSS  60
     C                     MOVE *DATE     DATUHZ
