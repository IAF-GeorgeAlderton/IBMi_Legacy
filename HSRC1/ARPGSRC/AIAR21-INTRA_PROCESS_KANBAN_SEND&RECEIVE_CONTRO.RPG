     C                     MOVE ERRCD2    DARETN
     C                     MOVE *BLANK    DADATA
     C                     MOVEL'**AB_OPE'TXT1   16
     C                     MOVE ' EXIT  *'TXT1
     C                     MOVELTXT1      DADATA
     C                     WRITEAI#PP011
     C                     ELSE
     C                     SETON                     H1
     C                     RETRN
     C                     END
     C                     MOVE '0'       SW      1
     C                     ENDSR'*CANCL'
