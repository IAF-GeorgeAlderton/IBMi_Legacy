      *
     C                     TIME           HHMMSS  60
     C                     MOVE HHMMSS    STIME
      *
     C*----------------------*
     C*   mﾞｰjdﾒa  JOBNO     *
     C*----------------------*
     C           *NAMVAR   DEFN AIADS1    DJOBN   50
      *
     C*---------------------------------*
     C*   RQﾛﾃｰnﾞ､ATﾛﾃｰnﾞを　読む     *
     C*---------------------------------*
     C           STP1      TAG
     C                     Z-ADD0         X       20
     C                     DO   *HIVAL
     C                     READ AIARV01                  03
     C                     ADD  1         X
     C           X         IFEQ 1
     C                     MOVELRDATA     ADATA
     C                     END
     C  N02                END
      *
     C*------------------------------------*
     C*  時間　の　設定                  *
     C*   ﾜｰfﾓmﾞｰjdﾒa xｮﾈｰﾆﾞﾃｰnﾞ '00'      *
     C*               ﾎｦbﾓxb     ﾎﾞ[]h     *
     C*   JOBLOGﾎｦbﾓ  ﾒjｰ]ﾃｰnﾞ   ﾎﾞ[]h     *
     C*------------------------------------*
     C                     TIME           WTIME
     C                     MOVE AMESG     UMESG
     C                     MOVE AKUBN     UKUBN
     C                     MOVE ABLOK     UBLOK
     C                     MOVE AKANB     UKANB
     C                     MOVE *BLANK    UFILE
     C                     MOVE *BLANK    DARETN
      *
     C*--------------------------------------------*
     C*  ＲＥＣ．ＩＤ　レコード区分　ＡＴ以外    *
     C*   mﾞｰjdﾒa  JOBNO + 1 = JOBNO               *
     C*--------------------------------------------*
     C           ARECD     IFNE 'AT'
     C           *LOCK     IN   *NAMVAR
     C                     ADD  1         DJOBN
     C                     Z-ADDDJOBN     UJOBN
     C                     OUT  *NAMVAR
     C                     END
      *
     C*------------------------------------------------*
     C*  ＲＥＣ．ＩＤ　工場コード                    *
     C*   0111 の　チェック                          *
     C*------------------------------------------------*
     C                     SETOF                     03
     C                     Z-ADD1         A       20
     C           ABMON     LOKUPHKJ,A                    03
     C           *IN03     IFEQ '0'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     DAJBNO
     C                     MOVE '25'      DAERCD
     C                     EXSR SUBJOB
     C           ARECD     IFEQ 'AT'
     C                     GOTO STP1
     C                     END
      *
     C                     GOTO STP1
     C                     END
      *
     C*-----------------------------------*
     C*  ＲＥＣ．ＩＤ　レコード区分     *
     C*  ＲＱ・ＡＴ　？                 *
     C*-----------------------------------*
     C           ARECD     IFNE 'RQ'
     C           ARECD     IFNE 'AT'
     C                     MOVE '1'       *IN01
     C                     MOVE 'HD'      ARECD
     C                     MOVE '24'      AMESG
     C                     Z-ADDUJOBN     DAJBNO
     C                     MOVE '24'      DAERCD
     C                     MOVELADATA     SDATA
     C                     EXSR SUBJOB
     C                     WRITEAIASD01
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C*-------------------------------------*
     C*  ＲＥＣ．ＩＤ　データグループ     *
     C*  ０Ａ・ＡＡ・ＡＢ・ＡＣ・ＡＦ　？ *
     C*-------------------------------------*
     C           AGRUP     IFNE 'AB'
     C           AGRUP     IFNE 'AC'
     C           AGRUP     IFNE 'AH'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     DAJBNO
     C                     MOVE '03'      DAERCD
     C                     EXSR SUBJOB
     C           ARECD     IFEQ 'RQ'
     C                     MOVE 'HD'      ARECD
     C                     MOVE '03'      AMESG
     C                     MOVELADATA     SDATA
     C                     WRITEAIASD01
     C                     END
     C                     GOTO STP1
     C                     END
     C                     END
     C                     END
      *
     C*----------------------------------------------------*
     C*  ＡＴレコード　の　処理     *                    *
     C*-------------------------------*                    *
     C           ARECD     IFEQ 'AT'                       *
      *
     C*----------------------------------------------------*
     C*  ＡＴレコード　データグループ                    *
     C*  0A --> JOBNO =データ転送コントロールファイル    *
     C*  AA --> JOBNO =時刻別計算便マスター              *
     C*  AB --> JOBNO =工程内かんばんデータ              *
     C*  AC --> JOBNO =焼入かんばんデータ                *
     C*  AH --> JOBNO =メッキかんばんデータ              *
     C*----------------------------------------------------*
     C*------------------------------*                     *
     C*  各かんばんマスターデータ  *                     *
     C*------------------------------*                     *
     C           AGRUP     IFEQ '0A'                       *
     C                     SETOF                     03    *
     C           KEY1      CHAINAALPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDCLJOBN    WJOBN   50       *
     C                     UPDATAALPL111                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------*                               *
     C*  生産指示データ  *                               *
     C*--------------------*                               *
     C           AGRUP     IFEQ 'AA'                       *
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDCDJOBN    WJOBN            *
     C                     UPDATAAIPL111                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------------*                         *
     C*  工程内かんばんデータ  *                         *
     C*  焼入かんばんデータ    *                         *
     C*  メッキかんばんデータ  *                         *
     C*--------------------------*                         *
     C                     SETOF                     03    *
     C                     MOVE *BLANK    XFILE            *
      *
     C           AGRUP     IFEQ 'AB'                       *
     C                     MOVE 'AADT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
      *
     C           AGRUP     IFEQ 'AC'                       *
     C                     MOVE 'AAET'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
      *
     C           AGRUP     IFEQ 'AH'                       *
     C                     MOVE 'AAFT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C           XFILE     CHAINAAIPP211             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDAIJOBN    WJOBN            *
     C                     UPDATAAIPP211                   *
     C                     END                             *
     C                     END                             *
     C                     END                             *
     C                     EXSR SAT                        *
      *
     C*---------------------------------------------*      *
     C*  ローカルデータエリア　レコード種別       *      *
     C*  ブランク・ＨＤ・ＤＴ・ＲＱ・ＢＫ　？     *      *
     C*---------------------------------------------*      *
     C           URECD     IFNE 'AT'                       *
     C           URECD     IFNE 'EE'                       *
     C                     Z-ADDWJOBN     DAJBNO           *
     C                     MOVE '26'      DAERCD           *
     C           AMESG     IFEQ '07'                       *
     C                     MOVE '07'      DAERCD           *
     C                     END                             *
     C                     EXSR SUBJOB                     *
     C                     GOTO STP2                       *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------------------------*      *
     C*  ローカルデータエリア　レコード種別       *      *
     C*  ＥＥ　？                                 *      *
     C*---------------------------------------------*      *
     C           URECD     IFEQ 'EE'                       *
     C                     GOTO STP3                       *
     C                     END                             *
     C                     Z-ADDWJOBN     DAJBNO           *
     C                     MOVE '27'      DAERCD           *
     C           AMESG     IFEQ '07'                       *
     C                     MOVE '07'      DAERCD           *
     C                     END                             *
     C                     EXSR SUBJOB                     *
      *
     C*--------------------------------------*             *
     C*  ＡＴレコード　メッセージコード    *             *
     C*  ＇００＇　＇０７＇　？            *             *
     C*--------------------------------------*             *
     C           STP2      TAG                             *
     C           AMESG     IFEQ '07'                       *
     C                     MOVE '1'       *IN01            *
     C                     GOTO STP1                       *
     C                     ELSE                            *
     C                     GOTO STP4                       *
     C                     END                             *
      *
     C*----------------------------------------------*     *
     C*  ローカルデータエリアの転送工場コードと    *     *
     C*  ＡＴレコードの工場コード同様か？          *     *
     C*----------------------------------------------*     *
     C           STP3      TAG                             *
     C           UBMON     IFEQ ABMON                      *
     C                     Z-ADDWJOBN     UJOBN            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDWJOBN     DAJBNO           *
     C                     MOVE '00'      DAERCD           *
     C           AMESG     IFEQ '07'                       *
     C                     MOVE '07'      DAERCD           *
     C                     END                             *
     C                     EXSR SUBJOB                     *
     C                     ELSE                            *
     C                     Z-ADDWJOBN     DAJBNO           *
     C                     MOVE '28'      DAERCD           *
     C           AMESG     IFEQ '07'                       *
     C                     MOVE '07'      DAERCD           *
     C                     END                             *
     C                     EXSR SUBJOB                     *
      *
     C*--------------------------------------*             *
     C*  ＡＴレコード　メッセージコード    *             *
     C*  ＇００＇　＇０７＇　？            *             *
     C*--------------------------------------*             *
     C           AMESG     IFEQ '07'                       *
     C                     MOVE '1'       *IN01            *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     END                             *
     C           STP4      TAG                             *
      *
     C*----------------------------------------------------*
     C*  ＡＴレコード　データグループ                    *
     C*  0A -->データ転送コントロールファイル完了マーク  *
     C*  AA -->時刻別計算便マスター完了マーク            *
     C*  AB -->工程内かんばんデータ完了マーク            *
     C*  AC -->焼入かんばんデータ完了マーク              *
     C*  AH -->メッキかんばんデータ完了マーク            *
     C*----------------------------------------------------*
     C*------------------------------*                     *
     C*  各かんばんマスターデータ  *                     *
     C*------------------------------*                     *
     C           AGRUP     IFEQ '0A'                       *
     C           AKUBN     IFEQ *BLANK                     *
     C                     SETOF                     03    *
     C           KEY1      CHAINAALPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     MOVE '*'       CLTENS           *
     C                     UPDATAALPL111                   *
     C                     END                             *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  転送用マスターデータ　ファイル　ＣＬＲＰＦＭ    *
     C*----------------------------------------------------*
     C                     MOVE *BLANK    WMILE            *
     C                     MOVE 'A'       WMA              *
     C                     MOVE AGRUP     WMGRUP           *
     C                     MOVE ABMON     WMBMON           *
     C                     MOVE AKUBN     WMRIRN           *
     C           AKUBN     IFEQ *BLANK                     *
     C                     MOVEL'AIANP04' WFILE  10        *
     C           CTP1      TAG                             *
     C                     SETOF                     03    *
     C           WFILE     CHAINAZZPPDF1             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE WFILE     ZZFILE           *
     C                     Z-ADD0         ZZTIME           *
     C                     WRITEAZZPPDF1                   *
     C                     GOTO CTP1                       *
     C                     END                             *
      *
     C                     MOVEL'AIAR02'  ZZPROG           *
     C                     TIME           ZZTIME           *
     C                     UPDATAZZPPDF1                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------*                               *
     C*  生産指示データ  *                               *
     C*--------------------*                               *
     C           AGRUP     IFEQ 'AA'                       *
     C           AKUBN     IFEQ *BLANK                     *
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     SETOF                     03    *
     C                     Z-ADD1         A                *
     C           ANBIN     LOKUPHBI,A                    03*
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '*'       HOK,A            *
     C                     END                             *
     C                     UPDATAAIPL111                   *
     C                     END                             *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------------*                         *
     C*  工程内かんばんデータ  *                         *
     C*  焼入かんばんデータ    *                         *
     C*--------------------------*                         *
     C           AKUBN     IFEQ *BLANK                     *
     C                     SETOF                     03    *
     C                     MOVE *BLANK    XFILE            *
      *
     C           AGRUP     IFEQ 'AB'                       *
     C                     MOVE 'AADT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
      *
     C           AGRUP     IFEQ 'AC'                       *
     C                     MOVE 'AAET'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
      *
     C           AGRUP     IFEQ 'AH'                       *
     C                     MOVE 'AAFT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C           XFILE     CHAINAAIPP211             03    *
     C           *IN03     IFEQ '0'                        *
     C                     MOVE '*'       AIKANR           *
     C                     UPDATAAIPP211                   *
     C                     END                             *
     C                     END                             *
     C                     END                             *
     C                     END                             *
     C                     MOVE '1'       *IN01            *
     C                     GOTO STP1                       *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*----------------------------------------------------*
     C*  ＲＱレコード　の　処理     *                    *
     C*-------------------------------*                    *
     C*----------------------------------------------------*
     C*  ＲＱレコード　データグループ                    *
     C*  0A --> データ転送コントロールファイルに有るか？ *
     C*  AA --> 時刻別計算便マスターに有るか？           *
     C*  AB --> 工程内かんばんデータに有るか？           *
     C*  AC --> 焼入かんばんデータに有るか？             *
     C*  AH --> メッキかんばんデータに有るか？           *
     C*----------------------------------------------------*
     C*------------------------------*                     *
     C*  各かんばんマスターデータ  *                     *
     C*------------------------------*                     *
     C           AGRUP     IFEQ '0A'                       *
     C           KEY1      KLIST                           *
     C                     KFLD           ABMON            *
     C                     KFLD           AGRUP            *
     C                     SETOF                     03    *
     C           KEY1      CHAINAALPL111             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '01'      AMESG            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '01'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     ELSE                            *
     C                     UPDATAALPL111                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------*                               *
     C*  生産指示データ  *                               *
     C*--------------------*                               *
     C           AGRUP     IFEQ 'AA'                       *
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '02'      AMESG            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '02'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     ELSE                            *
     C                     UPDATAAIPL111                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------------*                         *
     C*  工程内かんばんデータ  *                         *
     C*  焼入かんばんデータ    *                         *
     C*  メッキかんばんデータ  *                         *
     C*--------------------------*                         *
     C                     SETOF                     03    *
     C                     MOVE *BLANK    XFILE            *
      *
     C           AGRUP     IFEQ 'AB'                       *
     C                     MOVE 'AADT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
      *
     C           AGRUP     IFEQ 'AC'                       *
     C                     MOVE 'AAET'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
      *
     C           AGRUP     IFEQ 'AH'                       *
     C                     MOVE 'AAFT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C           XFILE     CHAINAAIPP211             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '34'      AMESG            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '34'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     ELSE                            *
     C                     UPDATAAIPP211                   *
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------------------------*      *
     C*  ローカルデータエリア　レコード種別       *      *
     C*  ブランク・ＡＴ？                         *      *
     C*---------------------------------------------*      *
     C           URECD     IFNE *BLANK                     *
     C           URECD     IFNE 'AT'                       *
      *
     C*---------------------------------------------*      *
     C*  ローカルデータエリア　レコード種別       *      *
     C*  ＥＥ？                                   *      *
     C*---------------------------------------------*      *
     C           URECD     IFEQ 'EE'                       *
      *
     C*----------------------------------------------*     *
     C*  ＩＦ文　比較                              *     *
     C*  現時刻　・　ローカルデータエリア          *     *
     C*  －５分　・　転送時刻                      *     *
     C*----------------------------------------------*     *
     C                     TIME           CTIME            *
     C           CMM       IFLE 09                         *
     C                     SUB  10        CMM              *
     C                     ADD  60        CMM              *
     C           CHH       IFEQ 0                          *
     C                     Z-ADD23        CHH              *
     C                     ELSE                            *
     C                     SUB  1         CHH              *
     C                     END                             *
     C                     ELSE                            *
     C                     SUB  10        CMM              *
     C                     END                             *
     C           UHH       IFGT CHH                        *
     C                     ADD  UHH       CHH              *
     C                     ADD  1         CHH              *
     C                     END                             *
     C           CTIME     IFGE UTIME                      *
     C                     MOVE '30'      DAERCD           *
     C                     GOTO STP5                       *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  ＡＴレコードの前に                              *
     C*  ＲＱレコードを受信した場合　データ送信          *
     C*----------------------------------------------------*
     C           ABMON     IFEQ 0111                       *
     C           U0111     ANDEQ'EE'                       *
     C                     MOVE '33'      DAERCD           *
     C                     GOTO STP5                       *
     C                     END                             *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '04'      AMESG            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '04'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     MOVE '29'      DAERCD           *
     C                     GOTO STP5                       *
     C                     END                             *
     C                     END                             *
     C                     MOVE '00'      DAERCD           *
     C           STP5      TAG                             *
     C                     MOVE 'RQ'      URECD            *
     C                     Z-ADDABMON     UBMON            *
     C                     MOVE AGRUP     UGRUP            *
     C                     TIME           UTIME            *
     C                     Z-ADDANOHZ     UNOHZ            *
     C                     Z-ADDANBIN     UNBIN            *
     C                     MOVE AKUBN     UKUBN            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     EXSR SRQ                        *
     C                     EXSR SUBJOB                     *
      *
     C*--------------------------*                         *
     C*  生産指示データか？    *                         *
     C*--------------------------*                         *
     C           AGRUP     IFEQ 'AA'                       *
      *
     C*------------*                                       *
     C*  再生    *                                       *
     C*------------*                                       *
     C           AKUBN     IFEQ 'R'                        *
      *
     C*----------------------------------------------------*
     C*  ＲＱレコードの納入日が時刻別計算便マスターの    *
     C*  前日便の日付・当日便の日付のどちらかが？        *
     C*----------------------------------------------------*
     C           ANOHZ     IFNE CDZNHZ                     *
     C           ANOHZ     IFNE CDTOHZ                     *
     C                     MOVE '15'      AMESG            *
     C                     MOVE '15'      DAERCD           *
     C                     GOTO STP10                      *
     C                     END                             *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  ＲＱレコードの納入日便が時刻別計算便マスターの  *
     C*  引取サイクルの便と等しく小さいか？              *
     C*----------------------------------------------------*
     C           ANBIN     IFLE CDCIBI                     *
     C                     GOTO STP11                      *
     C                     END                             *
     C                     MOVE '16'      AMESG            *
     C                     MOVE '16'      DAERCD           *
     C           STP10     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
      *
     C*----------------------------------------------------*
     C*  ＲＱレコードの転送日付は、前日便の日付・        *
     C*  当日便の日付か？                                *
     C*----------------------------------------------------*
     C           STP11     TAG                             *
     C                     Z-ADDANBIN     F       20       *
     C           ANOHZ     IFEQ CDZNHZ                     *
     C                     SETOF                     03    *
     C                     Z-ADD1         B                *
     C           F         LOKUPHCB,B                    03*
     C           *IN03     IFEQ '0'                        *
     C                     MOVE '16'      AMESG            *
     C                     MOVE '16'      DAERCD           *
     C                     GOTO STP13                      *
     C                     END                             *
      *
     C*-----------------------------*                      *
     C*  データ準備未完了か？     *                      *
     C*-----------------------------*                      *
     C           HDT,B     IFEQ *BLANK                     *
      *
     C*-----------------------*                            *
     C*  転送未完了か？     *                            *
     C*-----------------------*                            *
     C           HOK,B     IFEQ *BLANK                     *
     C                     Z-ADDCDZNHZ    UNOHZ            *
     C                     GOTO STP12                      *
     C                     END                             *
     C                     END                             *
     C                     MOVE '17'      AMESG            *
     C                     MOVE '17'      DAERCD           *
     C                     GOTO STP13                      *
     C                     END                             *
      *
     C*-----------------------------------*                *
     C*  指定された便データ有るか？     *                *
     C*-----------------------------------*                *
     C                     SETOF                     03    *
     C                     Z-ADD1         B                *
     C           F         LOKUPHCB,B                    03*
     C           *IN03     IFEQ '0'                        *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '31'      AMESG            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '31'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
      *
     C*---------------------------*                        *
     C*  データ準備完了か？     *                        *
     C*---------------------------*                        *
     C           HDT,B     IFEQ '*'                        *
      *
     C*---------------------*                              *
     C*  転送完了か？     *                              *
     C*---------------------*                              *
     C           HOK,B     IFEQ '*'                        *
     C                     Z-ADDCDTOHZ    UNOHZ            *
     C                     GOTO STP12                      *
     C                     END                             *
     C                     END                             *
     C                     MOVE '18'      AMESG            *
     C                     MOVE '18'      DAERCD           *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C           STP13     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C           STP12     TAG                             *
      *
     C*----------------------------------------------------*
     C*  時刻別計算便マスターにＪＯＢＮＯ更新            *
     C*----------------------------------------------------*
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDUJOBN     CDJOBN           *
     C                     UPDATAAIPL111                   *
     C                     END                             *
      *
     C*-------------------------------------------*        *
     C*  ファイル名セット                       *        *
     C*  Ａ　データグループ　工場コード　便     *        *
     C*-------------------------------------------*        *
     C                     MOVE *BLANK    WSILE            *
     C                     MOVE 'A'       WSA              *
     C                     MOVE AGRUP     WSGRUP           *
     C                     MOVE ABMON     WSBMON           *
     C                     MOVE UNBIN     WSBIN            *
     C                     MOVE WSILE     UFILE            *
     C                     EXSR SUBCHK                     *
     C           WCHK      IFEQ '1'                        *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     TIME           HHMMSS           *
     C                     MOVE HHMMSS    ETIME            *
     C                     SETON                     LR    *
     C                     RETRN                           *
     C                     END                             *
      *
     C*------------*                                       *
     C*  新規    *                                       *
     C*------------*                                       *
     C*-------------------------------------*              *
     C*  当日８時便　－　翌日７時便迄     *              *
     C*  を読む                           *              *
     C*-------------------------------------*              *
     C                     Z-ADD1         B       20       *
     C           1         DO   48        B                *
      *
     C*-----------------*                                  *
     C*  便が０？     *                                  *
     C*-----------------*                                  *
     C           HBI,B     IFNE 0                          *
     C           B         IFEQ 17                         *
     C                     Z-ADD0         D       20       *
     C                     ELSE                            *
     C           B         IFLE 16                         *
     C           B         ADD  7         D                *
     C                     ELSE                            *
     C           B         IFGE 18                         *
     C           B         SUB  17        D                *
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------*                        *
     C*  データ準備完了か？     *                        *
     C*---------------------------*                        *
     C           HDT,B     IFNE '*'                        *
     C                     GOTO STP7                       *
     C                     END                             *
      *
     C*---------------------*                              *
     C*  転送完了か？     *                              *
     C*---------------------*                              *
     C           HOK,B     IFEQ '*'                        *
     C                     GOTO STP8                       *
     C                     END                             *
      *
     C*---------------------------*                        *
     C*  翌日の便データか？     *                        *
     C*---------------------------*                        *
     C           B         IFGE 25                         *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '05'      AMESG            *
     C                     Z-ADDCDTOHZ    ANOHZ            *
     C                     Z-ADDHBI,B     ANBIN            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDCDTOHZ    UNOHZ            *
     C                     Z-ADDHBI,B     UNBIN            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '05'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     GOTO STPOI                      *
      *
     C*------------------------------------*               *
     C*  ＩＦ文　比較                    *               *
     C*  システム時刻（時）：　便時刻    *               *
     C*------------------------------------*               *
     C           WHH       IFLT D                          *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '06'      AMESG            *
     C                     Z-ADDCDTOHZ    ANOHZ            *
     C                     Z-ADDHBI,B     ANBIN            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDCDTOHZ    UNOHZ            *
     C                     Z-ADDHBI,B     UNBIN            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '06'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
     C           STPOI     TAG                             *
      *
     C*-------------------------------*                    *
     C*  次のデータ準備完了か？     *                    *
     C*-------------------------------*                    *
     C           WHH       IFGT D                          *
     C                     Z-ADD1         A                *
     C           25        DO   48        A                *
     C           HDT,A     IFEQ '*'                        *
     C                     MOVE '08'      UMESG            *
     C                     GOTO STP9                       *
     C                     END                             *
     C                     END                             *
     C                     END                             *
     C           STP9      TAG                             *
     C                     Z-ADDCDTOHZ    UNOHZ            *
     C                     Z-ADDHBI,B     UNBIN            *
      *
     C*----------------------------------------------------*
     C*  時刻別計算便マスターにＪＯＢＮＯ更新            *
     C*----------------------------------------------------*
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDUJOBN     CDJOBN           *
     C                     UPDATAAIPL111                   *
     C                     END                             *
      *
     C*-------------------------------------------*        *
     C*  ファイル名セット                       *        *
     C*  Ａ　データグループ　工場コード　便     *        *
     C*-------------------------------------------*        *
     C                     MOVE *BLANK    WSILE            *
     C                     MOVE 'A'       WSA              *
     C                     MOVE AGRUP     WSGRUP           *
     C                     MOVE ABMON     WSBMON           *
     C                     MOVE UNBIN     WSBIN            *
     C                     MOVE WSILE     UFILE            *
     C                     EXSR SUBCHK                     *
     C           WCHK      IFEQ '1'                        *
     C                     GOTO STP1                       *
     C                     END                             *
     C                     TIME           HHMMSS           *
     C                     MOVE HHMMSS    ETIME            *
     C                     SETON                     LR    *
     C                     RETRN                           *
      *
     C*-------------------------*                          *
     C*  データ準備中か？     *                          *
     C*-------------------------*                          *
     C           STP7      TAG                             *
     C           HDT,B     IFEQ 'H'                        *
      *
     C*------------------------------------*               *
     C*  ＩＦ文　比較                    *               *
     C*  システム時刻（時）：　便時刻    *               *
     C*------------------------------------*               *
     C           WHH       IFGT D                          *
     C                     MOVE '09'      AMESG            *
     C                     MOVE '09'      DAERCD           *
     C                     ELSE                            *
     C           WHH       IFEQ D                          *
     C                     MOVE '10'      AMESG            *
     C                     MOVE '10'      DAERCD           *
     C                     ELSE                            *
     C                     MOVE '11'      AMESG            *
     C                     MOVE '11'      DAERCD           *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     Z-ADDCDTOHZ    ANOHZ            *
     C                     Z-ADDHBI,B     ANBIN            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDCDTOHZ    UNOHZ            *
     C                     Z-ADDHBI,B     UNBIN            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
      *
     C*-----------------------------*                      *
     C*  データ準備未完了処理     *                      *
     C*-----------------------------*                      *
     C           WHH       IFGT D                          *
     C                     MOVE '12'      AMESG            *
     C                     MOVE '12'      DAERCD           *
     C                     ELSE                            *
     C           WMM       IFEQ D                          *
     C                     MOVE '13'      AMESG            *
     C                     MOVE '13'      DAERCD           *
     C                     ELSE                            *
     C                     MOVE '14'      AMESG            *
     C                     MOVE '14'      DAERCD           *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     Z-ADDCDTOHZ    ANOHZ            *
     C                     Z-ADDHBI,B     ANBIN            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDCDTOHZ    UNOHZ            *
     C                     Z-ADDHBI,B     UNBIN            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C           STP8      TAG                             *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '05'      AMESG            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     DAJBNO           *
     C                     MOVE '05'      DAERCD           *
     C                     MOVELADATA     SDATA            *
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     *
     C                     WRITEAIASD01                    *
     C                     GOTO STP1                       *
     C                     END                             *
      *
     C*------------------------------*                     *
     C*  各かんばんマスターデータ  *                     *
     C*  再生                      *                     *
     C*------------------------------*                     *
     C           AGRUP     IFEQ '0A'                       *
     C           AKUBN     IFEQ 'A'                        *
     C                     GOTO STP14                      *
     C                     END                             *
      *
     C*------------------------------*                     *
     C*  データ作成日が本日か？    *                     *
     C*  新規                      *                     *
     C*------------------------------*                     *
     C           CLDTHZ    IFNE *DATE                      *
     C                     MOVE '22'      AMESG            *
     C                     MOVE '22'      DAERCD           *
     C                     GOTO STP15                      *
     C                     END                             *
      *
     C*--------------------------*                         *
     C*  データ準備完了か？    *                         *
     C*--------------------------*                         *
     C           CLDTOK    IFNE '*'                        *
      *
     C*------------------------*                           *
     C*  データ準備中か？    *                           *
     C*------------------------*                           *
     C           CLDTOK    IFEQ 'H'                        *
     C                     MOVE '20'      AMESG            *
     C                     MOVE '20'      DAERCD           *
     C                     GOTO STP15                      *
     C                     ELSE                            *
     C                     MOVE '21'      AMESG            *
     C                     MOVE '21'      DAERCD           *
     C                     GOTO STP15                      *
     C                     END                             *
      *
     C*------------------------*                           *
     C*  データ未転送か？    *                           *
