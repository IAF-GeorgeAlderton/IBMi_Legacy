     H            Y.
     F** FBCR61L ***************************************************************
     F*  PROGRAM    : DEELETE AFTER EXP=9999                                   *
     F*             : COPID FROM @FBCPP01L                                     *
     F*  WRITTEN    : 2019.12.05                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*-------------
     F*  PARAMETERS
     F*  UPDFLG  1A: "Y"=UPDATE, " "=CHECK ONLY
     F*  $RTN    1A: "*"=ERROR,  " "=NO ERROR
     F**************************************************************************
     FFBCPL03 UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **************************************************************************
     C                     EXSR @INIT
      *
     C           *LOVAL    SETLLFBCPL03
      *
     C           *IN98     DOWEQ*OFF
     C   88                READ FBCPL03                  98
     C  N88                READ FBCPL03             N    98
     C           *IN98     IFEQ *OFF
     C           FBSKJY    ANDEQ' '
      * BRAEK?
     C           FBTOKU    IFEQ SVTOKU
     C           FBNONY    ANDEQSVNONY
     C           FBNKOJ    ANDEQSVNKOJ
     C           FBNUKE    ANDEQSVNUKE
     C           FBMHN1    ANDEQSVMHN1
     C           FBMHN2    ANDEQSVMHN2
     C           FBMHN3    ANDEQSVMHN3
     C           FBMHN4    ANDEQSVMHN4
     C                     EXSR #PRINT
     C           UPDFLG    IFEQ 'Y'
     C                     MOVE 'D'       FBSKJY
     C                     Z-ADDTODAY     FBSKHZ
     C                     MOVE '01L'     FBKOME
     C                     UPDATFBCPL031
     C                     ENDIF
     C                     ITER
     C                     ENDIF
      * PROCESS
     C           FBTSHZ    IFEQ 99999999
     C                     EXSR #SAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * FOOT
     C           SEQ#      IFEQ 0
     C                     EXCPT@FOT
     C                     ELSE
     C                     MOVEL'*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  SAVE                                              *
      *----------------------------------------------------*
     C           #SAVE     BEGSR
      *
     C                     Z-ADDFBTOKU    SVTOKU  40
     C                     Z-ADDFBNONY    SVNONY  40
     C                     MOVELFBNKOJ    SVNKOJ  1
     C                     MOVELFBNUKE    SVNUKE  4
     C                     MOVELFBMHN1    SVMHN1  5
     C                     MOVELFBMHN2    SVMHN2  5
     C                     MOVELFBMHN3    SVMHN3  5
     C                     MOVELFBMHN4    SVMHN4  5
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           UPDFLG  1
     C                     PARM           $RTN    1
      * IN88: UPD FLAG
     C           UPDFLG    IFEQ 'Y'
     C                     MOVE *ON       *IN88
     C                     ELSE
     C                     MOVE *OFF      *IN88
     C                     ENDIF
      *
     C                     MOVEL*BLANK    $RTN
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
      *
     C                     EXCPT@HDR
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                         UPDFLG    12
     O                                   60 '** ERROR REPORT **      '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   02           @HDR
     O                                   54 '(REORD AFTER EXP=999'
     O                                   74 '9)                  '
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   17 'F'
     O                                   22 'DOCK'
     O                                   32 'CUST_PART'
     O                                   55 'EFFECTIV'
     O                                   64 'EXP_DT'
     O                                   75 'UPD_DT'
     O                                   86 'UPD_ID'
     O                                  103 'PRICE'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         FBTOKU  +001
     O                         FBNONY  +001
     O                         FBNKOJ  +001
     O                         FBNUKE  +001
     O                         FBMHN1  +001
     O                         FBMHN2  +001
     O                         FBMHN3  +001
     O                         FBMHN4  +001
     O                         FBTKHZ  +001 '    /  /  '
     O                         FBTSHZ  +001 '    /  /  '
     O                         FBKOHZ  +001 '    /  /  '
     O                         FBKOME  +001
     O                         FBNTAN1 +001
     O                                 +001 '<-- TO BE DELETED'
     O        E 1              @FOT
     O                                   20 '** THERE IS NO TARGE'
     O                                   40 'T DATA **           '
