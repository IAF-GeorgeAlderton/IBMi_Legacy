     H            Y
      ** AN#RFO ********************************************
      *  CHECK  JULIAN CALENDAR                            *
      *                                                    *
      * TCHK1 07/12/06 CREATE(COPY FROM AB#RFO)            *
      ******************************************************
     FABFEP01 IF  E           K        DISK
     FAB#PPCT IF  E           K        DISK
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@ERR   1
     C           K#KEY     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
      *
     C                     MOVE *BLANK    P@ERR
     C           *YEAR     CHAINABFEP01              80
     C           *IN80     IFEQ '1'
     C                     MOVE '1'       P@ERR
     C                     ENDIF
      *
     C                     Z-ADD*YEAR     K@YY
     C           *MONTH    ADD  1         K@MM
     C           K@MM      IFGT 12
     C                     SUB  12        K@MM
     C                     ADD  1         K@YY
     C                     ENDIF
      *
     C           K#KEY     CHAINABFEP01              80
     C           *IN80     IFEQ '1'
     C                     MOVE '1'       P@ERR
     C                     ENDIF
      *
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
     C                     KFLD           K@KWD2  8
      *
     C           P@ERR     IFEQ *BLANK
      * CUM CHECK
     C                     MOVEL'ANDROID' K@KWD1    P
     C                     MOVEL'CUM'     K@KWD2    P
     C           K#PCT     CHAINAB#PPCT              95
     C           *IN95     IFEQ *ON
     C           *IN95     OREQ *OFF
     C           CTNBR1    ANDNE*DATE
     C                     MOVE '2'       P@ERR
     C                     ENDIF
     C                     ENDIF
      *
     C           P@ERR     IFEQ *BLANK
     C           *MONTH    IFGE 08
     C                     MOVEL'ANDROID' K@KWD1    P
     C                     MOVEL'AUGUST'  K@KWD2    P
     C           K#PCT     CHAINAB#PPCT              95
     C           *IN95     IFEQ *ON
     C           *IN95     OREQ *OFF
     C           CTNBR1    ANDLT*YEAR
     C                     MOVE '3'       P@ERR
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
