     H            Y.
     F***CHKR53*****************************************************************
     F*  PROGRAM    : CHECK HONDA ORDERS CREATED BEFORE AUTO PROCESS           *
     F*             : READ AB#PL1A                                             *
     F*  WRITTEN    : 2019.06.21                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLA1 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @YESTD    SETLLAB#PLA1
     C                     DO   *HIVAL
     C                     READ AB#PLA1                  98
     C   98                LEAVE
      * SELECT ENTRY TYPE
     C           $TYPE     IFNE *BLANK
     C           BAEDIK    ANDNE$TYPE
     C                     ITER
     C                     ENDIF
      * SELECT HONDA
     C           BATOKU    IFNE 0294
     C           BATOKU    ANDNE0295
     C           BATOKU    ANDNE0296
     C           BATOKU    ANDNE0390
     C           BATOKU    ANDNE0391
     C           BATOKU    ANDNE0400
     C           BATOKU    ANDNE1602
     C           BATOKU    ANDNE3135
     C                     ITER
     C                     ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           BACRHZ    IFEQ @YESTD
     C           BACRTM    ANDLE101000
     C                     ITER
     C                     ENDIF
      *
     C           BACRHZ    IFEQ TODAY
     C           BACRTM    ANDGE100000
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #PRINT
     C                     Z-ADDBANONY    SVNONY  40
     C                     MOVELBANKOJ    SVNKOJ  1
     C                     MOVELBANUKE    SVNUKE  4
     C                     Z-ADDBANOHZ    SVNOHZ  80
     C                     Z-ADDBANOBN    SVNOBN  20
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * GET CUSTOMER NAME
     C                     MOVELBANONY    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME1    XNAME  15
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C           BANONY    IFNE SVNONY
     C           BANKOJ    ORNE SVNKOJ
     C           BANUKE    ORNE SVNUKE
     C           BANOHZ    ORNE SVNOHZ
     C           BANOBN    ORNE SVNOBN
     C           SVNONY    IFNE 0
     C                     EXCPT@DTL2
     C                     ADD  1         LIN#
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELBACRME    @USER   7
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
     C                     PARM           $TYPE   1
     C                     PARM           $RTN    1
      *
      *
     C                     MOVEL$DATE     @YESTD  80
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK HONDA ORDER'
     O                                   60 'S CREATED BEFORE 10:'
     O                                   80 '00AM **             '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   14 'CRT_DATE'
     O                                   21 'TIME'
     O                                   30 'USER'
     O                                   38 'TYPE'
     O                                   43 'CUST'
     O                                   48 'DELV'
     O                                   64 'SHP_DATE'
     O                                   69 'BN'
     O                                   76 'ORDER#'
     O                                   94 'QTY'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         BACRHZ  +001 '    /  /  '
     O                         BACRTM  +001 '0 :  :  '
     O                         @USER   +001
     O                         BAEDIK  +002
     O                         BATOKU  +003
     O                         BANONY  +001
     O                         BANKOJ  +001
     O                         BANUKE  +001
     O                         BANOHZ  +001 '    /  /  '
     O                         BANOBN  +001
     O                         BAODRN  +001
     O                         BASRYO1 +001
     O                         XNAME   +001
     O        E 1              @DTL2
     O                                    1 '.'
