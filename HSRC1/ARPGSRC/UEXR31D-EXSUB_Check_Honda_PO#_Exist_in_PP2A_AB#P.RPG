     H            Y.
     F** UEXR31D ********************************************
     F*  PROGRAM: CHECK HONDA PO# EXIST IN PP2A             *
     F*  WRITTEN: JW (SRA) 2023.01.17                       *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR31D'
     F*                    PARM           $NONY   4
     F*                    PARM           $ODRN  10
     F*                    PARM           $RTN    1
     F*  IN  $NONY :  4A DELIVERY#
     F*      $ODRN : 10A PO#
     F*  OUT $RTN  :  1A RETURN CODE (Y:EXIST)
     F*                              (N:NOT EXIST)
     F******************************************************
     FAB#PL2ACIF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#PL2A    SETLLAB#PL2AC
      * CHECK AB#PL2AC
     C                     DO   *HIVAL
     C           K#PL2A    READEAB#PL2AC                 98
     C   98                LEAVE
      *
     C                     LEAVE
     C                     ENDDO
      *
     C           *IN98     IFEQ *OFF
     C                     MOVE 'Y'       $RTN
     C                     ENDIF
      * EXCEPTION
JW   C           $NONY     IFEQ '1620'
.    C                     MOVE 'Y'       $RTN
JW   C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $ODRN  10
     C                     PARM           $RTN    1
      *
     C           K#PL2A    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#ODRN 20
      * SET KEY
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$ODRN     K#ODRN    P
      *
     C                     TIME           SDATE
     C                     MOVEL'N'       $RTN
      *
     C                     ENDSR
