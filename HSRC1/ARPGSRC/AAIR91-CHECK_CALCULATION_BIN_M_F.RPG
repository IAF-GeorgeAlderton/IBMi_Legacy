     C           *ENTRY    PLIST
     C                     PARM           PSTS    1
      *
     C                     TIME           WTIME
     C                     MOVEL'9'       PSTS
      *
     C           0111      CHAINAAIPL111             44
     C           *IN44     IFEQ '0'
      *翌日がシステム日付以下はＯＫ
     C           CDYOHZ    IFLE SDATE
     C                     MOVEL'0'       PSTS
     C                     ELSE
     C                     EXSR #SB111
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------*
      *翌日がシステム日付以降
      *　完了していない便があれば実行可
      *---------------------------------------*
     CSR         #SB111    BEGSR
      *
     C                     Z-ADD1         JJ      30
     C                     MOVEL'0'       ESW     1
     C           JJ        DOWLE24
     C           ESW       ANDEQ'0'
     C           @BI,JJ    IFNE *ZERO
     C           @DT,JJ    IFEQ *BLANK
     C                     MOVEL'1'       ESW
     C                     MOVEL'0'       PSTS
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         JJ
     C                     ENDDO
      *
     CSR         ESB111    ENDSR
