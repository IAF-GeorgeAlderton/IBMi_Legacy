     H            Y.
     F** ABMRG1 *********************************************
     F*未納ＫＰＩ瞬間未納ALDPP65
     F*   HOTTA.          2018.10.05                        *
     F*******************************************************
     FALDPL66 IF  E           K        DISK
     FABMWPG1 IF  E           K        DISK                      A
      *
     I            DS
     I                                        1   80K@DATE
     I                                        1   60K@NTYM
     I                                        7   80K@NTDD
      *
     I            DS
     I                                        1   80Z@DATE
     I                                        1   60Z@NTYM
     I                                        7   80Z@NTDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NTYM  60
     C                     PARM           P9SYUN  70
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     Z-ADD0         K@DATE
     C                     Z-ADDP@NTYM    K@NTYM
     C                     Z-ADD1         K@NTDD
     C                     Z-ADDP@NTYM    Z@NTYM
     C                     Z-ADD99        Z@NTDD
     C                     Z-ADD0         P9SYUN
     C           K@DATE    SETLLALDPL66
     C                     READ ALDPL66                  80
     C           *IN80     DOWEQ'0'
     C           AFSKJC    IFEQ 'D'
     C           AFSKHZ    ANDLE*DATE
     C                     ELSE
     C*****      AFTIME    IFLE 070000
     C                     EXSR #SB200
     C*****                ENDIF
     C                     ENDIF
     C                     READ ALDPL66                  80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYW      KLIST
     C                     KFLD           AFTOKU
     C                     KFLD           AFNONY
     C                     KFLD           AFNKOJ
     C                     KFLD           AFNUKE
     C                     KFLD           AFLPR1
     C                     KFLD           AFLPR2
     C                     KFLD           AFLPR3
     C                     KFLD           AFNODT
     C                     KFLD           AFNOBN
     C           KEYW      CHAINABMWPG11             23
     C           *IN23     IFEQ '1'
     C                     ADD  1         P9SYUN
     C                     CLEARABMWPG11
     C                     MOVELAFTOKU    W1TOKU
     C                     MOVELAFNONY    W1NONY
     C                     MOVELAFNKOJ    W1NKOJ
     C                     MOVELAFNUKE    W1NUKE
     C                     MOVELAFLPR1    W1LPR1
     C                     MOVELAFLPR2    W1LPR2
     C                     MOVELAFLPR3    W1LPR3
     C                     MOVELAFNODT    W1NODT
     C                     MOVELAFNOBN    W1NOBN
     C                     WRITEABMWPG11
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
