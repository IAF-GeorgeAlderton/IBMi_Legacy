      *
     C           SSTP2     TAG
     C                     DO   *HIVAL
     C           BMN       READEBAHPL011                 30
     C           *IN30     IFEQ '0'
     C           BASKJY    IFEQ 'D'
     C                     GOTO SSTP2
     C                     END
      *初期設定*
     C           SW        IFEQ *BLANK
     C                     MOVE *BLANK    @KBN1
     C                     MOVE *BLANK    @KBN2
     C                     MOVE *BLANK    @KBN3
     C                     MOVE *BLANK    HIKA
     C                     Z-ADD0         LOTA
     C                     MOVE *BLANK    HIKB
     C                     Z-ADD0         LOTB
     C                     MOVE *BLANK    HIKC
     C                     Z-ADD0         LOTC
     C                     ADD  1         PAG
     C                     MOVE '*'       SW
     C                     END
      * MOVE *
     C                     Z-ADD1         B       20
     C           1         DO   8         B
     C           HIU,B     IFNE 0
     C           B         OREQ 1
     C                     MOVE *BLANK    WRK1
     C                     MOVE *BLANK    WRK2
     C                     MOVELHIU,B     WRK11
     C                     MOVE '.'       WRK12
     C                     MOVE HIU,B     WRK13
     C           WRK10     IFEQ '0'
     C                     MOVE *BLANK    WRK10
     C                     END
     C                     MOVELWRK1      WRK21
      *
     C                     MOVE '-'       WRK22
     C                     MOVE *BLANK    WRK1
     C           HIS,B     IFNE 0
     C                     MOVELHIS,B     WRK11
     C                     MOVE '.'       WRK12
     C                     MOVE HIS,B     WRK13
     C                     END
     C           HIS,B     IFEQ 0
     C                     MOVEL'99'      WRK11
     C                     MOVE '.'       WRK12
     C                     MOVE '99'      WRK13
     C                     END
     C           WRK10     IFEQ '0'
     C                     MOVE *BLANK    WRK10
     C                     END
     C                     MOVELWRK1      WRK23
      *
     C           A         IFEQ 1
     C                     MOVELBAKUBN    @KBN1
     C                     MOVELWRK2      HIKA,B
     C                     Z-ADDLOT,B     LOTA,B
     C                     END
     C           A         IFEQ 2
     C                     MOVELBAKUBN    @KBN2
     C                     MOVELWRK2      HIKB,B
     C                     Z-ADDLOT,B     LOTB,B
     C                     END
     C           A         IFEQ 3
     C                     MOVELBAKUBN    @KBN3
     C                     MOVELWRK2      HIKC,B
     C                     Z-ADDLOT,B     LOTC,B
     C                     END
     C                     END
     C                     END
      *
     C                     ADD  1         A
     C           A         IFGE 4
     C                     SETON                     30
     C                     END
     C                     END
     C  N30                END
      *
     C                     ENDSR
      *===============================================================*
      * 画面SET (ROLL-DOWN)                                  SUB-3  *
      *===============================================================*
     C           SUB3      BEGSR
     C                     MOVEL@KBN1     KKBN    1
     C                     Z-ADD3         A       20
     C                     SETOF                     30
     C           KEY       SETLLBAHPL011
      *
     C           SSTP3     TAG
     C                     DO   *HIVAL
     C           BMN       REDPEBAHPL011                 30
     C           *IN30     IFEQ '0'
     C           BASKJY    IFEQ 'D'
     C                     GOTO SSTP3
     C                     END
      *初期設定*
     C           SW        IFEQ *BLANK
     C                     MOVE *BLANK    @KBN1
     C                     MOVE *BLANK    @KBN2
     C                     MOVE *BLANK    @KBN3
     C                     MOVE *BLANK    HIKA
     C                     Z-ADD0         LOTA
     C                     MOVE *BLANK    HIKB
     C                     Z-ADD0         LOTB
     C                     MOVE *BLANK    HIKC
     C                     Z-ADD0         LOTC
     C                     SUB  1         PAG
     C                     MOVE '*'       SW
     C                     END
      * MOVE *
     C                     Z-ADD1         B       20
     C           1         DO   8         B
     C           HIU,B     IFNE 0
     C           B         OREQ 1
     C                     MOVE *BLANK    WRK1
     C                     MOVE *BLANK    WRK2
     C                     MOVELHIU,B     WRK11
     C                     MOVE '.'       WRK12
     C                     MOVE HIU,B     WRK13
     C           WRK10     IFEQ '0'
     C                     MOVE *BLANK    WRK10
     C                     END
     C                     MOVELWRK1      WRK21
      *
     C                     MOVE '-'       WRK22
     C                     MOVE *BLANK    WRK1
     C           HIS,B     IFNE 0
     C                     MOVELHIS,B     WRK11
     C                     MOVE '.'       WRK12
     C                     MOVE HIS,B     WRK13
     C                     END
     C           HIS,B     IFEQ 0
     C                     MOVEL'99'      WRK11
     C                     MOVE '.'       WRK12
     C                     MOVE '99'      WRK13
     C                     END
     C           WRK10     IFEQ '0'
     C                     MOVE *BLANK    WRK10
     C                     END
     C                     MOVELWRK1      WRK23
      *
     C           A         IFEQ 1
     C                     MOVELBAKUBN    @KBN1
     C                     MOVELWRK2      HIKA,B
     C                     Z-ADDLOT,B     LOTA,B
     C                     END
     C           A         IFEQ 2
     C                     MOVELBAKUBN    @KBN2
     C                     MOVELWRK2      HIKB,B
     C                     Z-ADDLOT,B     LOTB,B
     C                     END
     C           A         IFEQ 3
     C                     MOVELBAKUBN    @KBN3
     C                     MOVELWRK2      HIKC,B
     C                     Z-ADDLOT,B     LOTC,B
     C                     END
     C                     END
     C                     END
      *
     C                     SUB  1         A
     C           A         IFLE 0
     C                     SETON                     30
     C                     END
     C                     END
     C  N30                END
      *
     C                     ENDSR
      *===============================================================*
      * 更新エリアにＭＯＶＥ                                 SUB-4  *
      *===============================================================*
     C           SUB4      BEGSR
     C                     MOVE *BLANK    @KBN4
     C                     Z-ADD0         HIKD
     C                     Z-ADD0         HIMD
     C                     Z-ADD0         LOTD
      * MOVE *
     C                     MOVELBAKUBN    @KBN4
     C                     Z-ADD1         B       20
     C           1         DO   8         B
     C           HIU,B     IFNE 0
     C                     Z-ADDHIU,B     HIKD,B
     C                     END
     C           HIS,B     IFNE 0
     C                     Z-ADDHIS,B     HIMD,B
     C                     END
     C           LOT,B     IFNE 0
     C                     Z-ADDLOT,B     LOTD,B
     C                     END
     C                     END
      *
     C                     ENDSR
**  ERR / MSG
E-01 INPUT SECTION CODE
E-02  SECTION CODE YOU INPUT IS NOT RIGHT
E-03 THERE ISN'T NEXT DETAILS
E-04 THERE ISN'T THE DETAILS BEFORE
E-05 INPUT UPDATE INSTRUCTION
E-06 UPDATE INSTRUCTION IS <0 1 2>.
E-07 INPUT INSTRUCTION
E-08 THERE IS NOT CANCEL DATA
E-09 IT IS CANCELLED ALREADY
E-10 THERE IS NOT CHANGE DATA
E-11 CHANGE DATA IS CANCELLED
E-12 THER IS DATA
E-13 INPUT DATA  SEQUENTIALLY FROM THE FIRST
E-14 INPUT DATA
E-15 IT IS NOT RIGHT THAT SIZE OF THOSE
E-16 INPUT  NUMBER OF BOXES
E-17 DO NOT INPUT LAST DATA
E-18 INPUT  LOT
E-19 LAST COMBINATION  IS MORE THAN 2
E-20 THERE MUST  BE SAME NUMBER OF BOXES BEFORE
E-21 IF NUMBER OF BOXES DOESN'T INPUT, DO NOT INPUT LOT
E-22 DON'T USE ''99.99'' IN  NUMBER OF BOXES
E-23 DON'T USE ''Z'' FOR  INSTRUCTION
**  SECTION CODE
0111
