      *** GDLR83 *************************************
      *        UNIT PRICE MASTER REFERENCE           *
      *  TCH(N.HYOTO) 2000.12.20                     *
      *                                              *
      ************************************************
     H            Y/                                    1
     F*
     FGDLPW83 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS INFWS
     F*
      *        DETAIL CODE MANAGEMENT RECORD .LAYOUT ..LOGICAL FILE .. *
     FFGBPL01 IF  E           K        DISK
      *
      * INPORT GOODS UNIT PRICE MASTER     *
     FGDLPL81 IF  E           K        DISK
     E*================================================================
     E                    MSG     1   9 59
     I*================================================================
     IINFWS       DS
     I                                    B 370 3710@CORSR
     I                                    B 378 3790@TOPRN
     I            DS
     I                                        1   60W@TIME
     I                                        1   40W@HM
     I*  SAKUJYO
     I            DS
     I                                        1   80LHSKHZ
     I                                        1   40LHSKYY
     I                                        5   60LHSKMM
     I                                        7   80LHSKDD
     I*  KOUSINN
     I            DS
     I                                        1   80LHKODT
     I                                        1   40LHKOYY
     I                                        5   60LHKOMM
     I                                        7   80LHKODD
     I*
     I            DS
     I                                        1   40LHKOHS
     I                                        1   20LHKOHH
     I                                        3   40LHKOSS
     I* STARTING DATE *
     I            DS
     I                                        1   80S1STDT
     I                                        1   40S1STYY
     I                                        5   60S1STMM
     I                                        7   80S1STDD
     I* ENDING DATE *
     I            DS
     I                                        1   80S1ENDT
     I                                        1   40S1ENYY
     I                                        5   60S1ENMM
     I                                        7   80S1ENDD
     I            DS
     I                                        1   80F8DATE
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I* DATE *
     I            DS
     I                                        1   80WWYMD
     I                                        1   40WWYY
     I                                        5   60WWMM
     I                                        7   80WWDD
     C*================================================================
     C*           PARM LIST                                          *
     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*================================================================
     C*           KEY LIST                                           *
     C*================================================================
     C*** UNIT PRICE MASTER (GDLPL81)
     C           KEY1      KLIST
     C                     KFLD           D1WIRE
     C                     KFLD           D1WDIA
     C*
     C           KEY2      KLIST
     C                     KFLD           D1WIRE
     C                     KFLD           D1WDIA
     C                     KFLD           LHSIRE
     C                     KFLD           LHSIRK
     C* AOYAMA PRODUCTION PLACE CALENDAR FILE(INCLUDE HOLIDAY)
     C           F8KEY     KLIST
     C                     KFLD           WWYY
     C                     KFLD           WWMM
     C                     KFLD           WWDD
     C*================================================================
     C*           MAIN ROUTINE                                       *
     C*================================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#SET1   '#SET1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C*          @STEP     CASEQ'#UPD    '#UPD
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*================================================================
     C*  INIT
     C*================================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1WIRE
     C                     Z-ADD*ZERO     D1WDIA
     C                     MOVE *BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP1
     C*================================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVE '#CHK1   '@STEP
     C* < F1=ON >
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  CHK1
     C*================================================================
     C           #CHK1     BEGSR
     C                     MOVEA'0'       *IN,11           <11>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D1ERR
     C*
     C** WIRE *
     C*
     C           D1WIRE    IFEQ *BLANK
     C  N99                MOVELMSG,1     D1ERR
     C                     SETON                     1199
     C                     ENDIF
     C*
     C** FILE **
     C*
S1   C           *IN99     IFEQ *OFF
     C           KEY1      SETLLGDLPL811
     C                     MOVE ' '       @@UMU   1
     C*----------
 S2  C                     DO   *HIVAL
     C           KEY1      READEGDLPL811                 90
     C   90                LEAVE
  S3 C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKHZ    ANDLE*DATE                      DELETE DATE
     C                     ITER
  E3 C                     ENDIF
     C                     MOVE '1'       @@UMU
     C                     LEAVE
 E2  C                     ENDDO
     C*----------
     C           @@UMU     IFEQ ' '
     C                     MOVELMSG,2     D1ERR
     C                     SETON                     1199
     C                     MOVE LHPTCD    WPTCD   1
     C*
     C                     ELSE
     C                     MOVE LHPTCD    WPTCD   1
     C                     ENDIF
E1   C                     ENDIF
     C*
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#SET1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
      *  SET1
     C*================================================================
     C           #SET1     BEGSR
     C*
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D2ERR
     C                     MOVELD1WIRE    D2WIRE
     C                     Z-ADDD1WDIA    D2WDIA
     C** FILE **
     C*
     C** SFLCLR **
     C                     SETON                     21
     C                     WRITECTL01
     C                     SETOF                     21
     C                     Z-ADD*ZERO     RRN     40
     C                     Z-ADD*ZERO     LSTRRN  40
     C**
     C           KEY1      SETLLGDLPL811
     C*--------------------
S1   C                     DO   *HIVAL
     C           KEY1      READEGDLPL811                 90
     C   90                LEAVE
     C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKHZ    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C           KEY2      SETGTGDLPL811
 S2  C                     DO   *HIVAL
     C           KEY2      REDPEGDLPL811                 91
     C   91                LEAVE
     C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKHZ    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C                     EXSR #SFSET
     C                     LEAVE
 E2  C                     ENDDO
     C*
     C           KEY2      SETGTGDLPL811
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN       LSTRRN
     C                     Z-ADD1         RRN1
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C           #SFSET    BEGSR
     C*
     C                     MOVE LHSIRE    S1VEND
     C                     MOVE LHPTCD    S1TYPE
     C                     MOVE *BLANK    S1SEL
     C                     Z-ADDLHSTHZ    S1STDT
     C                     Z-ADDLHENHZ    S1ENDT
     C                     Z-ADDLHTANK    S1SEA
     C                     ADD  1         RRN
     C                     WRITESFL01
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP2
     C*================================================================
     C           #DSP2     BEGSR
     C*
     C                     WRITEDSP02
     C                     SETON                     20
     C                     EXFMTCTL01
     C                     SETOF                     20
     C                     Z-ADD@TOPRN    TOPRRN  40
     C                     Z-ADD@RRN1     CSRRRN  50
     C                     MOVE '#CHK2   '@STEP
     C* < F3=ON >
     C           *INKC     IFEQ *ON
     C                     MOVE '#INIT   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
     C*  CHK2
     C*================================================================
     C           #CHK2     BEGSR
     C                     Z-ADD0         DSPRRN  40
     C*
S1   C                     DO   LSTRRN    RRN
     C           RRN       CHAINSFL01                90
     C   90                LEAVE
     C*
     C           S1SEL     IFEQ 'M'
     C                     EXSR #DSP3
     C                     Z-ADDRRN       DSPRRN
     C                     ENDIF
      *
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
E1   C                     ENDDO
     C*
     C           DSPRRN    IFNE 0
     C                     Z-ADDDSPRRN    RRN1
     C*
     C                     ELSE
     C           CSRRRN    IFNE 0
     C                     Z-ADDCSRRRN    RRN1
     C                     ELSE
     C                     Z-ADDTOPRRN    RRN1
     C                     ENDIF
     C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*
     C*================================================================
     C           #DSP3     BEGSR
     C*
     C                     MOVELS1VEND    D2VEND
     C                     MOVELS1TYPE    D2TYPE
     C                     MOVELD1WIRE    D2WIRE
     C                     Z-ADDD1WDIA    D2WDIA
     C                     MOVE *BLANK    D2VDNM
     C                     MOVELD2VEND    B2CODE
     C           B2CODE    CHAINFGBPL011             92
     C  N92                MOVELB2SMEI    D2VDNM
     C*
     C           WPTCD     IFEQ 'W'
     C                     MOVEL'WIRE'    D2PTNM
     C*
     C                     ELSE
     C                     MOVEL'ROD'     D2PTNM
     C                     END
     C*
     C** FILE **
     C*
     C** SFLCLR **
     C                     SETON                     23
     C                     WRITECTL02
     C                     SETOF                     23
     C                     Z-ADD*ZERO     RRN2    40
     C**
     C           KEY1      SETGTGDLPL811
     C*--------------------
S1   C                     DO   *HIVAL
     C           KEY1      REDPEGDLPL811                 92
     C   92                LEAVE
     C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKHZ    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADDLHSTHZ    S2STDT
     C                     Z-ADDLHENHZ    S2ENDT
     C                     Z-ADDLHTANK    S2SEA
     C                     ADD  1         RRN2
     C                     WRITESFL02
E1   C                     ENDDO
     C                     Z-ADD1         RRN2
     C*--------------------
     C*
     C*--------------------
     C           @DSP3     TAG
     C                     WRITEDSP03
     C                     SETON                     22
     C                     EXFMTCTL02
     C                     SETOF                     22
     C                     Z-ADD@TOPRN    RRN2
     C* < F3=OFF>
     C           *INKC     IFEQ *OFF
     C                     GOTO @DSP3
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*================================================================
**  MSG  **
PLEASE ENTER WIRE
UNIT PRICE MASTER FILE NOT FOUND.
UNIT PRICE MASTER FILE FOUND.
NO. INPUT ERROR.
DATA OVERLAP.
INCORRECT DATE.
DETAIL M/F <CODE COMPLETION> NOT FOUND.
INPUT ERROR. ONLY THE LATEST RECORD CAN BE ERASED.
INPUT ERROR. THE DIGITS FOR PART NUMBER IS TOO LONG.
