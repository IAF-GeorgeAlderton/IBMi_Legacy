      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C           KEY1      KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
      *
     C           K#ECQ     KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C                     KFLD           K@KAT4  1
     C           K#ECQX    KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C                     KFLD           D@DIE4  1
     C                     KFLD           KYMD
      *
     C           K#AGX     KLIST
     C                     KFLD           KYY
     C                     KFLD           KMM
     C                     KFLD           KDD
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     SETOF                     6199
      *
     C           KEY1      CHAINFCQPL31              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET      BEGSR
      *-----------------------------------------------------
      * UNIT PRICE
      *
     C                     Z-ADD*ZERO     D@UPRC
     C                     Z-ADD*ZERO     D@VALD
     C           K#ECQ     SETGTECQPP01
     C           *IN20     DOUEQ*ON
     C           K#ECQ     REDPEECQPP01                  20
     C           *IN20     IFEQ *OFF
     C           ECVALD    ANDLE*DATE
     C                     Z-ADDECUPRC    D@UPRC
     C                     Z-ADDECVALD    D@VALD
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
