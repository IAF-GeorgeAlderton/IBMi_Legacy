     C           A#SIZE    WHEQ 'M8 '
     C                     ADD  1         CNT,2
     C           A#SIZE    WHEQ 'M10'
     C                     ADD  1         CNT,3
     C           A#SIZE    WHEQ 'TS '
     C                     ADD  1         CNT,4
     C           A#SIZE    WHEQ 'E/G'
