     H            Y
     F**************************************************
     F* CREATE CONDITION DATA SAFEKEEPING            *
     F**************************************************
     FADAWP30 IP  E                    DISK
     FADAPPNO UF  E           K        DISK                      A
     FADAPP30 O   E           K        DISK                      A
     I            DS
     I                                        1   80HYMD
     I                                        1   40HY
     I                                        5   60HM
     I                                        7   80HD
     C           *ENTRY    PLIST
     C                     PARM           PARM6   6        *番地
     C                     PARM           PARM7   8        *Ｓ日付
     C                     PARM           PARM8   8        *Ｅ日付
     C                     PARM           PARM9   1        *前夜勤区
     C                     PARM           PARM10  6        *年月
     C                     PARM           PARM11  1        *旬
     C                     PARM           SAKUDT  8        *作成日
     C                     PARM           SAKUNO  2        *作成番号
      *  作成日及び番号採番
     C           FRSTSW    IFEQ *BLANK
     C                     Z-ADD*YEAR     HY
     C                     Z-ADD*MONTH    HM
     C                     Z-ADD*DAY      HD
     C                     SETOF                       21
     C           HYMD      CHAINADAPPNO1             21
     C           *IN21     IFEQ '0'
     C                     ADD  1         DANO
     C                     MOVE DANO      SAKUNO
     C                     UPDATADAPPNO1
     C                     ELSE
     C                     MOVE HYMD      DADATE
     C                     Z-ADD1         DANO
     C                     MOVE 1         SAKUNO
     C                     WRITEADAPPNO1
     C                     END
     C                     MOVE '1'       FRSTSW  1
     C                     END
      *
      *
     C                     MOVEL*BLANK    DBSKJY
     C                     MOVEL*ZERO     DBSKYY
     C                     MOVEL*ZERO     DBSKMM
     C                     MOVELDADATE    DBSAHZ
     C                     MOVELSAKUNO    DBSARD
     C                     MOVELDANONU    DBNONU
     C                     MOVELDAKOJO    DBKOJO
     C                     MOVELDAUKEI    DBUKEI
     C                     MOVELDABIN     DBBIN
     C                     MOVELDANIS     DBNIS
     C                     MOVELPARM6     DBTKRO
     C                     MOVELPARM7     DBKAHZ
     C                     MOVELPARM8     DBSRHZ
     C                     MOVELPARM9     DBMYKB
     C                     MOVELPARM10    DBNAYM
     C                     MOVELPARM11    DBNAJN
     C                     WRITEADAPP301
