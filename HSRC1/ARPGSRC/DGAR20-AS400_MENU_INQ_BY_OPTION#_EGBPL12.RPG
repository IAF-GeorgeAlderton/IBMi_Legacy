     H            Y.
     F** DGAR20 ********************************************
     F*  AS400 MENU INQ BY OPTION#                         *
     F*  J.WATANABE  2025.04.24                            *
     F******************************************************
     FDGAPW20 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFL01
     FEGBPL12 IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I           SDS
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      * MAIN ROUTINE                                      *
      *****************************************************
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#CTL01  '#CTL01
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*  INITIAL SET
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $USER  10
      *
     C           $USER     IFEQ *BLANK
     C                     MOVEL#USER     KUSER  10
     C                     ELSE
     C                     MOVEL$USER     KUSER
     C                     ENDIF
      * GET USER NAME
     C                     MOVELKUSER     D1USR
     C                     MOVELKUSER     $USER
     C                     CALL 'UTLR31'
     C                     PARM           $USER  10
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     D1NAM
      * SET SFL01
     C                     MOVEL'000'     XXOPT   3
     C                     EXSR #SFL01
      *
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#CTL01  '@STEP
     C                     ENDIF
      *
     C                     ENDSR
     C*===============================================================
      *  DISPLAY SCREEN
     C*===============================================================
     C           #CTL01    BEGSR
     C                     SETON                     71
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *
     C                     SELEC
      * F3 *
     C           *INKA     WHEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '#END    '@STEP
      * F7: INQ BY PGM
     C           *INKG     WHEQ *ON
     C                     CALL 'DGAR21'
     C                     PARM           $USER
      * ENTER
     C                     OTHER
     C           D1OPT     IFEQ SVOPT
     C                     ELSE
     C                     MOVELD1OPT     XXOPT
     C                     EXSR #SFL01
     C           RRN       IFEQ 0
     C                     MOVE *BLANK    S1OPT
     C                     MOVE *BLANK    S1PGM
     C                     MOVEL'NO DATA!'S1TXT     P
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
     C*===============================================================
      *  SET SFL01
     C*===============================================================
     C           #SFL01    BEGSR
      * CLEAR SFL01
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         DSPRRN
      *
     C           KUSER     SETLLEGBPL12
      *-------------------------
     C                     DO   *HIVAL
     C           KUSER     READEEGBPL12                  98
     C   98                LEAVE
      * SELECT
     C           M1SKJY    IFEQ 'D'
     C           M1PGMN    OREQ ' '
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELM1MNNO    S1OPT
     C                     MOVE M1MNDN    S1OPT
      * SELECT
     C           S1OPT     IFLT XXOPT
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELM1PGMN    S1PGM
     C                     MOVELM1TEXT    S1TXT
      *
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     Z-ADD1         DSPRRN
     C                     MOVELXXOPT     SVOPT   30
      *
     C                     ENDSR
