TCH78C                     EXSR #CHK2X
TCH78C                     ELSE
     C                     EXSR #CHK1
TCH78C                     ENDIF
     C           *IN99     IFEQ *OFF
     C                     MOVE '03'      @@ID
     C                     ENDIF
TCH83C                     ENDIF
