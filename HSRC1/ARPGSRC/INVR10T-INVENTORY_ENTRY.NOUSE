TCH26C**************************************************************************
     C*                    @LOG  LOCK/UNLOCK LOCK FILE
     C**************************************************************************
     C           @LOG      BEGSR
     C*
     C*  TRY TO LOCK
     C*
B0   C           WFLG      IFEQ '1'
     C           D@USER    CHAINALDPP621            N97
B1   C           *IN97     IFEQ '0'
     C*          SCNID     IFEQ ALSCID
     C*                    GOTO EXIT1
     C*                    ENDIF
     C                     SETON                     3031
     C                     MOVE '2'       WFLG
     C                     MOVEAERR,5     MSG
     C                     MOVE '00'      @@ID
X1   C                     ELSE
     C                     MOVE #WSID     ALWKID
     C*                    Z-ADDSCNID     ALSCID
     C                     Z-ADDD@USER    ALWKCD
     C           D@USER    CHAINALBPL301             45
     C                     WRITEALDPP621
E1   C                     ENDIF
     C*
X0   C                     ELSE
     C*
     C*  TRY TO UNLOCK
     C*
B1   C           WFLG      IFEQ '2'
     C           D@USER    CHAINALDPP621            N97
B2   C           *IN97     IFEQ '0'
     C           D@USER    CHAINALDPP621             97
B3   C           *IN97     IFEQ '0'
     C                     DELETALDPP621
E3   C                     ENDIF
E2   C                     ENDIF
E1   C                     ENDIF
     C*
E0   C                     ENDIF
     C           EXIT1     TAG
TCH26C                     ENDSR
