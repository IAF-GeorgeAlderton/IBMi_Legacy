     ******************************************************** AB#RAE **
     FAB#PWAE CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FMBDPL03 IF  E           K        DISK
     FMBDPL01 IF  E           K        DISK
     FABBPL03 IF  E           K        DISK
     FABBPL02 IF  E           K        DISK
     FGADTL17 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCEPL11 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    MSG     1   2 78
     E                    MN     12  12  3
     E                    PRT       500 12
     E                    MON         3  3
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  12 PART
     I                                        1   5 PART1
     I                                        6  10 PART2
     I                                       11  12 PART3
     I            DS
     I                                        1   9 MON
     I                                        1   3 D@MON1
     I                                        4   6 D@MON2
     I                                        7   9 D@MON3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------------
      *   MAIN
      *------------------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C           @@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C           K#MBD     KLIST
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C                     KFLD           D@DOCK
     C           K#MBDX    KLIST
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
      *
     C           K#KEY     KLIST
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C                     KFLD           D@DOCK
     C           K#KEYX    KLIST
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C           K#ABB     KLIST
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
     C                     KFLD           K@TOKU  40
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C                     KFLD           D@DOCK
     C           K#ABBX    KLIST
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
     C                     KFLD           K@TOKU  40
     C                     KFLD           D@NONY
     C                     KFLD           D@NKOJ
     C           K#FCE     KLIST
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #DSP01    BEGSR
      *-----------------------------------------------------
     C                     MOVE CMD,1     D@CMD
      *
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           *IN99     IFEQ *OFF
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
      *
     C           D@DOCK    IFNE *BLANK
     C           K#MBD     SETLLGADTL17
     C                     ELSE
     C           K#MBDX    SETLLGADTL17
     C                     ENDIF
     C           *IN90     DOUEQ*ON
     C           D@DOCK    IFNE *BLANK
     C           K#MBD     READEGADTL17                  90
     C                     ELSE
     C           K#MBDX    READEGADTL17                  90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C           B5SKJY    ANDEQ*BLANK
     C                     Z-ADDB5TOKU    K@TOKU
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVEA'111'     *IN,61
     C                     MOVE *ON       *IN99
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
      *
     C           D@DOCK    IFNE *BLANK
     C                     MOVE D@DOCK    D@DOCX
     C                     ELSE
     C                     MOVEL'ALL '    D@DOCX
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET1     BEGSR
      *-----------------------------------------------------
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     MOVE *ALL'9'   PRT
     C                     Z-ADD*ZERO     X       30
     C                     MOVE *BLANK    MON
     C                     CLEARDSP98
      *
     C           D@DOCK    IFNE *BLANK
     C           K#MBD     SETLLMBDPL03
     C                     ELSE
     C           K#MBDX    SETLLMBDPL03
     C                     ENDIF
      *
     C           *IN90     DOUEQ*ON
     C           D@DOCK    IFNE *BLANK
     C           K#MBD     READEMBDPL03                  90
     C                     ELSE
     C           K#MBDX    READEMBDPL03                  90
     C                     ENDIF
     C           *IN90     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
     C           F3TNSU    ANDNE*ZERO
     C                     MOVE F3SHN1    PART1
     C                     MOVE F3SHN2    PART2
     C                     MOVE F3SHN3    PART3
     C           PART      LOKUPPRT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C                     MOVE PART      PRT,X
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           K@TOKU    SETLLABBPL03
     C           *IN90     DOUEQ*ON
     C           K@TOKU    READEABBPL03                  90
     C           *IN90     IFEQ *OFF
     C           Q5NONY    ANDEQD@NONY
     C           Q5NKOJ    ANDEQD@NKOJ
      *
     C           D@DOCK    IFNE *BLANK
     C           Q5NUKE    ANDNED@DOCK
     C                     ITER
     C                     ENDIF
     C           Q5NNNM    IFGT *ZERO
     C           Q51NNM    ORGT *ZERO
     C           Q52NNM    ORGT *ZERO
      *
     C                     MOVE Q5SHN1    PART1
     C                     MOVE Q5SHN2    PART2
     C                     MOVE Q5SHN3    PART3
     C           PART      LOKUPPRT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C                     MOVE PART      PRT,X
     C                     ENDIF
      *
     C           MON,1     IFEQ *BLANK
     C                     Z-ADDQ5NTYM    Y       20
     C           1         DO   3         Z       20
     C                     MOVE MN,Y      MON,Z
     C                     ADD  1         Y
     C           Y         IFGT 12
     C                     SUB  12        Y
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           X         IFEQ *ZERO
     C                     MOVE *ON       *IN99
     C                     ELSE
     C                     SORTAPRT
     C                     EXSR #SET2
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET2     BEGSR
      *-----------------------------------------------------
     C           1         DO   500       X
     C           PRT,X     IFEQ *ALL'9'
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE PRT,X     PART
     C                     MOVE PART1     S@PRT1
     C                     MOVE PART2     S@PRT2
     C                     MOVE PART3     S@PRT3
     C           D@DOCK    IFNE *BLANK
     C           K#KEY     SETLLMBDPL01
     C                     ELSE
     C           K#KEYX    SETLLMBDPL01
     C                     ENDIF
      *
     C           *IN90     DOUEQ*ON
     C           D@DOCK    IFNE *BLANK
     C           K#KEY     READEMBDPL01                  90
     C                     ELSE
     C           K#KEYX    READEMBDPL01                  90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
     C                     ADD  F3TNSU    S@ACTQ
     C           S@MHN1    IFEQ *BLANK
     C                     MOVE F3MHN1    S@MHN1
     C                     MOVE F3MHN2    S@MHN2
     C                     MOVE F3MHN3    S@MHN3
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           D@DOCK    IFNE *BLANK
     C           K#ABB     SETLLABBPL02
     C                     ELSE
     C           K#ABBX    SETLLABBPL02
     C                     ENDIF
      *
     C           *IN90     DOUEQ*ON
     C           D@DOCK    IFNE *BLANK
     C           K#ABB     READEABBPL02                  90
     C                     ELSE
     C           K#ABBX    READEABBPL02                  90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C                     ADD  Q5NNNM    S@FCQ1
     C                     ADD  Q51NNM    S@FCQ2
     C                     ADD  Q52NNM    S@FCQ3
     C           S@MHN1    IFEQ *BLANK
     C                     MOVE Q5MHN1    S@MHN1
     C                     MOVE Q5MHN2    S@MHN2
     C                     MOVE Q5MHN3    S@MHN3
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           K#FCE     CHAINFCEPL11              95
     C           *IN95     IFEQ *OFF
     C           FCGK01    DIV  FCCD01    W@SETQ 111
     C           W@SETQ    MULT 20        S@SETQ
     C                     ENDIF
      *
     C           K#FCE     CHAINFCEPL01              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDA2SSYS    S@SYOS
     C           S@ACTQ    DIV  A2SSYS    S@ACTB
     C                     MVR            @@MVR   50
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         S@ACTB
     C                     ENDIF
     C                     ADD  S@ACTB    D@ACTB
     C           S@FCQ1    DIV  A2SSYS    S@FCB1
     C                     MVR            @@MVR   50
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         S@FCB1
     C                     ENDIF
     C                     ADD  S@FCB1    D@FCB1
     C           S@FCQ2    DIV  A2SSYS    S@FCB2
     C                     MVR            @@MVR   50
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         S@FCB2
     C                     ENDIF
     C                     ADD  S@FCB2    D@FCB2
     C           S@FCQ3    DIV  A2SSYS    S@FCB3
     C                     MVR            @@MVR   50
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         S@FCB3
     C                     ENDIF
     C                     ADD  S@FCB3    D@FCB3
     C           S@SETQ    DIV  A2SSYS    S@SETB
     C                     MVR            @@MVR   50
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         S@SETB
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C                     ENDSR
