     H            Y.
     F** AB#R82 ************************************
     F* ..EDI FIXED ORDER DATA NOT ON SALES LIST.. *
     F*    K.OKACHI                    98.03.12    *
     F*    N.HYOTO 2000.11.21 ADD BIN              *
     F* TCHK1 10/01/09 ADD IAF P# TO AB#WP80       *
     F************************************ AB#R80 **
     FAB#PL12 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#WP80 O   F     128            DISK
      *
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
      *
     C           *IN90     DOUEQ*ON
     C                     READ AB#PL12                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANONY    ANDNE*ZERO
      *
     C           BANOHZ    IFEQ W@YMD
     C                     LEAVE
     C                     ENDIF
      *
     C           BAURHZ    IFEQ 0
     C                     EXCPTDAT
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVE *ALL'0'   SDATE   8
     C                     MOVE *DATE     EDATE   8
      *
     C           K#KEY     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C                     Z-ADD*DAY      K@DD
     C           K#KEY     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     Z-ADDF8KAYY    W@YY
     C                     Z-ADDF8KAMM    W@MM
     C                     Z-ADDF8KADD    W@DD
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *
      *
     OAB#WP80 E                DAT
     O                         BATOKU     4
     O                         BANONY     8
     O                         BANKOJ     9
     O                         BANUKE    13
     O                         BASBAN    17
     O                         BAMHIN    37
     O                         BAODRN    47
     O                         BANOHZ    55
     O                         BASRYO    65
     O                         SDATE     73
     O                         EDATE     81
     O                         BANOBN    83
TCHK2O                         BASHN1    88
TCHK2O                         BASHN2    93
TCHK2O                         BASHN3    95
TCHK2O                         BASYOS   101
TCHK2O                         BAUSYS   107
