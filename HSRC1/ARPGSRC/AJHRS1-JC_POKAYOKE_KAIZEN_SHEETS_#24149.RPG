     H            Y.
     F** AJHRS1 *********************************************
     F* JC POKAYOKE       KAIZEN SHEETS #24149              *
     F*    C.SAKTHIP            2025.02.01                  *
     F*******************************************************
     F*AJHPL14 IF  E           K        DISK
     FAJHPL15 IF  E           K        DISK
     FAJHPPS1 IF  E           K        DISK
     FAH#PL11 IF  E           K        DISK
     FAJZPL16 IF  E           K        DISK
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BAR  20
     C                     PARM           P@RTN   1
      *
     C                     PARM           P@WINY  40
     C                     PARM           P@WINM  20
     C                     PARM           P@WIND  20
     C                     PARM           P@WINJ  20
     C                     PARM           P@WINF  20
     C                     PARM           P@WMJY  20
     C                     PARM           P@MKKB  2
      *
     C                     MOVE *BLANK    P@RTN
     C                     Z-ADD0         P@WINY  40
     C                     Z-ADD0         P@WINM  20
     C                     Z-ADD0         P@WIND  20
     C                     Z-ADD0         P@WINJ  20
     C                     Z-ADD0         P@WINF  20
     C                     Z-ADD0         P@WMJY  20
     C                     MOVE *BLANK    P@MKKB  2
      *
     C                     CALL 'BARR81'
     C                     PARM           P@BAR  20
     C                     PARM           P#KRKB  1
     C                     PARM           P#ZETI  4
     C                     PARM           P#TEHI  3
     C                     PARM           P#PAGN  2
     C                     PARM           P#BCKA  1
     C                     PARM           P#BCTK  1
     C                     PARM           P#BCYK  1
     C                     PARM           P#BCHK  1
     C                     PARM           P#BCKD  1
      *
     C                     MOVE P#KRKB    K@KANK  1
     C                     MOVE P#ZETI    K@ZETI  4
     C                     MOVE P#TEHI    K@THAI  3
     C                     MOVE P#PAGN    K@PAG4  2
     C                     MOVE P#BCKA    K@2JKA  1
     C                     MOVE P#BCTK    K@TASY  1
     C                     MOVE P#BCYK    K@SYKO  1
     C                     MOVE P#BCHK    K@HKBR  1
      *
     C                     MOVE 'JC '     JDKOTE
     C                     MOVE P@BAR     JDBARC
     C           AJHKEY    KLIST
     C                     KFLD           JDKOTE
     C                     KFLD           JDBARC
     C           AJHKEY    CHAINAJHPPS1              77
     C           *IN77     IFEQ '0'
     C           JDSKJY    IFEQ 'D'
     C                     SETON                     77
     C                     END
     C                     END
     C           *IN77     IFEQ '0'
     C                     MOVE '*'       P@RTN
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
      *PARCIAL KANBAN CHECK
     C                     EXSR #SB200
      *
     C                     Z-ADD0         W@HTHZ  80
     C           AH#KEY    KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@THAI
     C           AH#KEY    SETGTAH#PL11
     C                     DO   *HIVAL
     C           AH#KEY    REDPEAH#PL11                  88
     C   88                LEAVE
     C           CFSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     Z-ADDCFHTHZ    W@HTHZ
     C                     LEAVE
     C                     ENDDO
      *
     C           W@HTHZ    IFEQ 0
     C                     MOVEL'*'       P@RTN
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C           KEY       KLIST
     C                     KFLD           K@KANK  1
     C                     KFLD           K@ZETI  4
     C                     KFLD           K@THAI  3
     C                     KFLD           K@PAG4  2
     C*                    KFLD           K@2JKA  1
     C*                    KFLD           K@TASY  1
     C*                    KFLD           K@SYKO  1
     C*                    KFLD           K@HKBR  1
      *
     C           KEY       SETGTAJHPL15
     C                     DO   *HIVAL
     C           KEY       REDPEAJHPL15                  77
     C   77                LEAVE
     C                     ADD  1         @KEN    40
      *
     C                     CALL 'DATRD4'
     C                     PARM           JCWINY
     C                     PARM           JCWINM
     C                     PARM           JCWIND
     C                     PARM           JCWDAT  80
      *
     C           W@HTHZ    IFNE 0
     C           JCWDAT    IFGE W@HTHZ
     C                     ELSE
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVE '*'       P@RTN
     C                     Z-ADDJCWINY    P@WINY
     C                     Z-ADDJCWINM    P@WINM
     C                     Z-ADDJCWIND    P@WIND
     C                     Z-ADDJCWINJ    P@WINJ
     C                     Z-ADDJCWINF    P@WINF
     C                     Z-ADDJCWMJY    P@WMJY
     C                     MOVE JCMKKB    P@MKKB
     C                     LEAVE
     C                     ENDDO
      *
     C                     Z-ADD@KEN      @KEN
      *
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************
     C*  PARCIAL KANBAN CHECK                             *
     C*****************************************************
     C           #SB200    BEGSR
     C*
     C                     Z-ADD0         W@KEHZ  80
     C                     MOVELP@BAR     J1BA   15
     C           J1#KEY    KLIST
     C                     KFLD           J1BA
     C           J1#KEY    SETGTAJZPL16
     C                     DO   *HIVAL
     C           J1#KEY    REDPEAJZPL16                  89
     C   89                LEAVE
     C           J1SKJY    IFEQ 'D'
     C           J1APPL    ORNE 'A'
     C                     ITER
     C                     END
     C                     Z-ADDJ1KEHZ    W@KEHZ
     C                     LEAVE
     C                     ENDDO
     C*
     C           W@KEHZ    IFEQ 0
     C                     GOTO ESB200
     C                     ELSE
     C                     MOVELJ1THAI    K@THAI
     C                     MOVELJ1PAG1    K@PAG4
     C                     ENDIF
      *
     C*
     C           ESB200    ENDSR
