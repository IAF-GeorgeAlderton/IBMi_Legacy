     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------
     C           *INZSR    BEGSR
      *----------------------------------------------------
      *
     C           K#FCE     KLIST
     C                     KFLD           WSHN1
     C                     KFLD           WSHN2
     C                     KFLD           WSHN3
      *
     C           K#FCC     KLIST
     C                     KFLD           K@MAMM  20
     C                     KFLD           H@NONY
     C                     KFLD           H@NKOJ
     C                     KFLD           H@NUKE
     C                     KFLD           S@MHN1
     C                     KFLD           S@MHN2
     C                     KFLD           S@MHN3
      * AGDPL12
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C           K#2H      KLIST
     C                     KFLD           AENONY
     C                     KFLD           K@RENO 15
      *
     C           K#21      KLIST
     C                     KFLD           @@TOKU  4
     C                     KFLD           @@NONY  4
     C                     KFLD           H@NKOJ
     C                     KFLD           H@NUKE
     C                     KFLD           H@ACDT
     C                     KFLD           AEMHN1
     C                     KFLD           AEMHN2
     C                     KFLD           AEMHN3
      *
     C                     MOVE '01'      @@ID    2
     C                     EXSR #SET1
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #SET1     BEGSR
      *----------------------------------------------------
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     D@FROM
     C                     Z-ADD*ZERO     D@TO
      *
     C           *IN90     DOUEQ*ON
     C                     READ AB#EP21             N    90
     C           *IN90     IFEQ *OFF
     C           AESHDT    ANDNE*ZERO
     C           AEQNTY    ANDNE*ZERO
     C           AEUPID    ANDEQ*BLANK
      *
     C                     CLEARSFL01
     C                     Z-ADDAEQNTY    S@QTY
     C                     Z-ADDAESHDT    S@SHDT
     C                     Z-ADDAEUDAT    S@DATE
     C                     Z-ADDAEUTIM    S@TIME
     C                     Z-ADDAESHDT    H@SHDT
     C                     Z-ADDAESHDT    H@ACDT
     C                     MOVE AEORNO    H@ORNO
     C                     MOVE AESHNO    H@SHNO
      * SATURDAY
     C                     Z-ADDAESHDT    K@YMD
     C           K#AGD     CHAINAGDPL12              95
     C           *IN95     IFEQ *OFF
     C           F8HIRU    IFNE *BLANK
     C           *IN95     DOUEQ*ON
     C                     READPAGDPL12                  95
     C           *IN95     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     Z-ADDWKKADT    S@SHDT
     C                     Z-ADDWKKADT    H@SHDT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELAESHNO    K@RENO
     C           K#2H      CHAINAB#PP2H              95
     C           *IN95     IFEQ *OFF
     C                     MOVELAHORNO    S@ORDN
     C                     ELSE
     C           AEORNO    IFNE *BLANK
     C                     MOVELAEORNO    S@ORDN
     C                     ELSE
     C                     MOVELAESHNO    S@ORDN
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE AENONY    H@NONY
     C                     MOVE AENONY    S@NONY
     C                     MOVE AETOKU    H@TOKU
     C                     MOVE AENKOJ    H@NKOJ
     C                     MOVELAENUKE    H@NUKE
     C                     MOVE AESHTM    H@SHTM
     C                     MOVELAEMHIN    H@MHIN
      *
      * CUSTOMER PART#
      *
     C                     MOVELWMHIN     H@WMHN
     C                     MOVELAEMHN1    S@MHN1
     C                     MOVELAEMHN2    S@MHN2
     C                     MOVELAEMHN3    S@MHN3
      * IAF PART#
     C                     MOVELAETOKU    PTOKU   4
     C                     MOVELAENKOJ    PNKOJ   1
     C                     MOVELAENUKE    PNUKE   4
     C                     MOVE AENONY    PNONY   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVEL@SHIN     H@SHIN    P
     C                     MOVELAESBAN    H@SBAN    P
     C                     MOVELAESUPL    H@SUPL
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     MOVE ER,2      D@MSG
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #SCRN1    BEGSR
      *----------------------------------------------------
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKI     WHEQ *ON
     C                     EXSR #ALL
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #ALL      BEGSR
      *----------------------------------------------------
     C                     Z-ADD*ZERO     RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVE 'X'       S@SLCT
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #CHK1     BEGSR
      *----------------------------------------------------
     C                     SETOF                     616299
     C                     MOVE *BLANK    D@MSG
      *
     C                     MOVE *BLANK    DT
     C                     Z-ADD*ZERO     QY
     C                     MOVE *BLANK    UP
     C                     Z-ADD*ZERO     Y       20
      *
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FROM    D@TO
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W@FROM
     C                     Z-ADD*ZERO     W@TO
     C           D@FROM    IFNE *ZERO
     C           20000000  ADD  D@FROM    W@FROM  80
     C                     ENDIF
     C           W@FROM    IFNE *ZERO
     C           W@FROM    ANDLT*DATE
     C                     SETON                     6199
     C                     MOVE ER,3      D@MSG
     C                     ENDIF
      *
     C           D@TO      IFNE *ZERO
     C           20000000  ADD  D@TO      W@TO    80
     C                     ENDIF
      *
     C           W@TO      IFLT W@FROM
     C                     SETON                     616299
     C                     MOVE ER,3      D@MSG
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN98
     C                     Z-ADD*ZERO     RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           D@FROM    IFNE *ZERO
     C           H@SHDT    IFGE W@FROM
     C           H@SHDT    ANDLEW@TO
     C                     MOVE 'X'       S@SLCT
     C                     ELSE
     C                     MOVE *BLANK    S@SLCT
     C                     ENDIF
     C                     ENDIF
     C           S@SLCT    IFNE *BLANK
     C                     MOVE *ON       *IN98
     C                     ENDIF
      *
     C                     UPDATSFL01
     C           S@SLCT    IFNE *BLANK
     C                     Z-ADD1         X
     C                     MOVE H@SHDT    @SHDT
     C                     MOVELH@MHIN    @MHN
     C           @DTA      LOKUPDT,X                     10
     C           *IN10     IFEQ *ON
     C                     ADD  S@QTY     QY,X
     C                     ELSE
     C                     ADD  1         Y
     C                     MOVE @DTA      DT,Y
     C                     Z-ADDS@QTY     QY,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN98     IFEQ *OFF
     C  N99                MOVE ER,4      D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #UPD      BEGSR
      *----------------------------------------------------
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN80     DOUEQ*ON
      *
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                80
     C           *IN80     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
      *
     C                     MOVE S@SLCT    XXSLCT  1
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
      *
     C                     MOVE H@NONY    WNONY   40
     C                     MOVE H@TOKU    WTOKU   40
     C                     MOVE H@WMHN    WMHIN
     C                     MOVE H@NKOJ    WNKOJ   1
     C                     MOVELH@NUKE    WNUKE   4
      *
     C                     MOVE H@SHDT    WNYMD   80
     C                     MOVE H@SHTM    WNOTM   40
      *
      *
     C                     MOVE WTOKU     @@TOKU
     C                     MOVE WNONY     @@NONY
     C           K#21      SETLLAB#EP21
     C           *IN97     DOUEQ*ON
     C           K#21      READEAB#EP21                  97
     C           *IN97     IFEQ *OFF
     C                     MOVE '1'       AEUPID
     C                     UPDATAB#EP211
     C                     ENDIF
     C                     ENDDO
      *
     C           XXSLCT    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD1         WNOBN   20
     C                     MOVELS@ORDN    WODRN  10
     C                     Z-ADD1         X       20
     C                     MOVE H@SHDT    @SHDT
     C                     MOVELH@MHIN    @MHN
     C           @DTA      LOKUPDT,X                     10
     C           *IN10     IFEQ *ON
     C           UP,X      IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C                     MOVE '1'       UP,X
     C                     ENDIF
      *
      *
     C                     Z-ADDQY,X      WSURY   70
      * INVOICE#
     C                     MOVE *BLANK    WINV#  16
     C                     MOVELH@SHIN    WSHIN
     C                     Z-ADD*ZERO     WSYOS   60
      *
     C           K#FCE     CHAINFCEPL011             90
     C           *IN90     IFEQ *ON
     C                     MOVE '2'       WERID   1
     C                     EXCPT@ERR
     C                     ELSE
     C           A2GSKD    IFEQ *BLANK
     C           A2SSHZ    IFLE WNYMD
     C                     Z-ADDA2SSYS    WSYOS
     C                     ELSE
     C                     Z-ADDA2KSYS    WSYOS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           WSYOS     IFEQ 0
     C                     Z-ADD1         WSYOS   60
     C                     ENDIF
      *
     C                     MOVELH@SHDT    K@YMD
      * KANBAN #(SBAN)
     C           H@SBAN    IFEQ *BLANK
      *
     C                     MOVE WNOMM     K@MM
     C           K#FCC     SETGTFCCTL13
     C           *IN90     DOUEQ*ON
     C           K#FCC     REDPEFCCTL13                  90
     C           *IN90     IFEQ *OFF
     C           B4SKBN    ANDEQ*BLANK
      *
     C           B4MAYY    IFNE WNOYY
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELB4SBAN    H@SBAN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     Z-ADDWNOYY     @@YY    40
     C                     SUB  1         K@MM
     C           K@MM      IFEQ 0
     C                     ADD  12        K@MM
     C                     SUB  1         @@YY
     C                     ENDIF
      *
     C           K#FCC     SETGTFCCTL13
     C           *IN90     DOUEQ*ON
     C           K#FCC     REDPEFCCTL13                  90
     C           *IN90     IFEQ *OFF
     C           B4SKBN    ANDEQ*BLANK
      *
     C           B4MAYY    IFNE @@YY
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELB4SBAN    H@SBAN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           H@SBAN    IFEQ *BLANK
     C                     MOVEL'0000'    H@SBAN
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELH@SBAN    WSBAN   4
      * SUPPLIER CODE
     C                     MOVELH@SUPL    WSUPL
      * WRITE RECORD
     C                     EXCPT@DT
     C                     SETON                     U1
      *
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
