     FGK#PL31 IF  E           K        DISK
     FGKBPL21 IF  E           K        DISK
     FGKBPR25 O   E             80     PRINTER                        UC
     E                    TBL1    1  10  4 0 TBL2   14   ﾃcﾆﾞｭcxb
     I            DS
     I                                        1   80X9SYHZ
     I                                        1   40X9SYYY
     I                                        5   60X9SYMM
     I                                        7   80X9SYDD
     C           *ENTRY    PLIST
     C                     PARM           PARM1   4        r]
     C                     PARM           PARM2   2        lg
     C                     PARM           PARM3   2        fnﾞcﾍﾞ
     C                     PARM           PARM4   4        ﾎﾞy]
     C                     PARM           PARM5   1        hﾎﾞ]
     C                     MOVE PARM1     @PARM1  40
     C                     MOVE PARM2     @PARM2  20
     C                     MOVE PARM3     @PARM3  20
     C                     MOVE PARM4     @PARM4  40
     C                     MOVE PARM5     @PARM5  1
     C*
     C           KEY1      KLIST
     C                     KFLD           X9BMON
     C                     KFLD           X9KUBN
     C                     KFLD           X9ZANM
     C                     KFLD           X9ZAIK
     C*
     C           *IN90     IFEQ '0'
     C                     TIME           @TIME
     C                     Z-ADD*DATE     @DATE
     C                     Z-ADD0         @PAGE
     C                     MOVE *BLANK    PSW     1
     C                     Z-ADD0         K1      40
     C                     MOVE *BLANK    K2     15
     C                     Z-ADD0         K3      52
     C                     MOVEA'11'      *IN,70
     C                     MOVEL'1'       *IN80
     C                     MOVEL'1'       *IN90
     C                     END
     C*
     C                     SETOF                     50
     C           @PARM4    IFNE 9999
     C           @PARM4    SETLLGK#PL311
     C                     END
     C*
     C                     DO   *HIVAL
     C           @PARM4    IFNE 9999
     C           @PARM4    READEGK#PL311                 50
     C                     ELSE
     C                     READ GK#PL311                 50
     C                     END
     C*
     C           *IN,50    IFEQ '0'
     C           @PARM1    ANDEQX9SYYY
     C           @PARM2    ANDEQX9SYMM
     C           @PARM5    ANDEQX9KUBN
     C*
     C           X9SKJY    IFNE 'D'
     C*
     C           K3        IFNE X9ZAIK
     C           K2        ORNE X9ZANM
     C           K1        ORNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR251
     C                     MOVEL'0'       *IN80
     C                     END
     C                     MOVEL'0'       *IN30
     C           KEY1      CHAINGKBPL211             30
     C           *IN30     IFEQ '1'
     C                     Z-ADD1000      X8JRYO
     C                     END
     C           WJRYO     DIV  @PARM3    XJRYO   60H
     C           XJRYO     DIV  X8JRYO    HJRYO     H
     C                     WRITEGKBPR253
     C                     SETON                     51
     C                     END
     C                     MOVEA'1'       *IN,70
     C                     Z-ADD0         HJRYO
     C                     Z-ADD0         WJRYO
     C                     Z-ADD0         K3
     C                     Z-ADDX9ZAIK    K3
     C                     END
     C*
     C           K2        IFNE X9ZANM
     C           K1        ORNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR251
     C                     MOVEL'0'       *IN80
     C                     END
     C                     WRITEGKBPR254
     C                     SETON                     52
     C                     END
     C                     MOVEA'1'       *IN,71
     C                     Z-ADD0         @JRYO
     C                     MOVE *BLANK    K2
     C                     MOVE X9ZANM    K2
     C                     END
     C*
     C           K1        IFNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR251
     C                     MOVEL'0'       *IN80
     C                     END
     C                     WRITEGKBPR255
     C                     END
     C                     Z-ADD0         $JRYO
     C                     MOVEA'11'      *IN,70
     C           @PARM4    IFEQ 9999
     C                     MOVEL'1'       *IN80
     C                     END
     C                     MOVE *BLANK    @BMEI
     C                     Z-ADD1         A       20
     C                     MOVEL'0'       *IN30
     C           X9BMON    LOKUPTBL1,A                   30
     C   30                MOVELTBL2,A    @BMEI
     C                     Z-ADD0         K1
     C                     Z-ADDX9BMON    K1
     C                     END
     C*
     C           PSW       IFEQ *BLANK
     C                     OPEN GKBPR25
     C                     MOVEL'1'       *IN80
     C                     MOVEL'*'       PSW
     C                     END
     C*
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR251
     C                     MOVEL'0'       *IN80
     C                     END
     C*
     C                     ADD  X9JRYO    WJRYO
     C                     ADD  X9JRYO    @JRYO
     C                     ADD  X9JRYO    $JRYO
     C                     WRITEGKBPR252
     C                     SETOF                     5152
     C                     MOVEA'00'      *IN,70
     C*
     C                     END
     C                     END
     C  N50                END
     C* END ﾆｭﾒ *
     C           PSW       IFNE *BLANK
