     H            Y.
      ** FBCR21A *********************************************
      *  UNIT PRICE M/F INQ BY IAF PART# V.2                 *
      *  J.WATANABE 2023.06.20                               *
      ********************************************************
     FFBCPW21ACF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     FFAAPL04 IF  E           K        DISK
     FFAAPL05 IF  E           K        DISK
     FFBCPL01 IF  E           K        DISK
     FFBCPL08 IF  E           K        DISK
     FFBCWP21 UF  E           K        DISK                      A
      ********************************************************
     E                    MSG     1  12 60
      *
     I            DS
     I                                        1   80FBTKHZ
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1   80FBTSHZ
     I                                        1   40FBTSYY
     I                                        5   60FBTSMM
     I                                        7   80FBTSDD
     I            DS
     I                                        1  12 XSHIN
     I                                        1   5 XSHN1
     I                                        6  10 XSHN2
     I                                       11  12 XSHN3
     I            DS
     I                                        1  20 S1MHIN
     I                                        1   5 S1MHN1
     I                                        6  10 S1MHN2
     I                                       11  15 S1MHN3
     I                                       16  20 S1MHN4
     I            DS
     I                                        1  20 FBMHIN
     I                                        1   5 FBMHN1
     I                                        6  10 FBMHN2
     I                                       11  15 FBMHN3
     I                                       16  20 FBMHN4
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP1
     C           W@ID      CASEQ'02'      #CTL01
     C                     ENDCS
     C                     ENDDO
      *
     C           *IN01     IFEQ *ON
     C                     MOVE '1'       PCMD
     C                     ENDIF
      *
     C           *IN03     IFEQ *ON
     C                     MOVE '3'       PCMD
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * DISPLAY 1ST SCREEN
      *************************************************************
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
      * F1/F3: EXIT
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO XDSP1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     ENDIF
      *
     C           XDSP1     ENDSR
      *************************************************************
      *  CHECK ENTRY DATA
      *************************************************************
     C           #CHK1     BEGSR
      * CHECK DATE FROM
     C           XSHN1     IFEQ *BLANK
     C           XSHN2     ANDEQ*BLANK
     C           XSHN3     ANDEQ*BLANK
     C                     MOVELMSG,1     XMSG
     C                     SETON                     41  85
     C                     GOTO XCHK1
     C                     ENDIF
      * IF NO ERROR....
     C           *IN85     IFEQ *OFF
     C                     EXSR #SETW1
      *
     C           RCNT      IFGT 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVELMSG,2     XMSG
     C                     SETON                     41  85
     C                     ENDIF
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *************************************************************
      *  SET DATA IN WF
      *************************************************************
     C           #SETW1    BEGSR
     C                     Z-ADD0         RCNT
      * DELETE WORK FILE
     C           *LOVAL    SETLLFBCWP21
     C                     DO   *HIVAL
     C                     READ FBCWP21                  99
     C   99                LEAVE
     C                     DELETFBCWP211
     C                     ENDDO
      *
      * READ COMMON PART MASTER ---------------------------
     C           K#FAAA    SETLLFAAPL04
     C                     DO   *HIVAL
     C           K#FAAA    READEFAAPL04                  98
     C   98                LEAVE
      *
     C           B7SKBN    IFEQ ' '
     C                     EXSR #PRC1
     C                     ENDIF
      *
     C                     ENDDO
      * NOT COMMON PART
     C                     EXSR #PRC2
      *
     C                     ENDSR
      ************************************************************
      *  WRITE FBCWP21 BY COMMON MASTER
      ************************************************************
     C           #PRC1     BEGSR
      *
     C                     Z-ADDB7TOKU    FKTOKU
     C                     Z-ADDB7NONY    FKNONY
     C                     MOVELB7NKJO    FKNKOJ
     C                     MOVELB7NUKE    FKNUKE
     C                     MOVELB7MHN1    FKMHN1
     C                     MOVELB7MHN2    FKMHN2
     C                     MOVELB7MHN3    FKMHN3
     C                     MOVELB7MHN4    FKMHN4
     C           K#FB1A    SETLLFBCPL01
      *
     C                     DO   *HIVAL
     C           K#FB1A    READEFBCPL01                  97
     C   97                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELB7SHN1    FBSHN1
     C                     MOVELB7SHN2    FBSHN2
     C                     MOVELB7SHN3    FBSHN3
     C                     ADD  1         RCNT
     C                     WRITEFBCWP211
      *
     C                     ENDDO
      *
     C                     ENDSR
      ************************************************************
      *  WRITE FBCWP21 BY PRICE MASTER
      ************************************************************
     C           #PRC2     BEGSR
      *
     C                     MOVE 'Y'       FIRST2  1
     C                     MOVELXSHN1     FKMHN1
     C                     MOVELXSHN2     FKMHN2
     C                     MOVELXSHN3     FKMHN3    P
     C                     MOVE *BLANK    FKMHN4
     C           K#PL8B    SETLLFBCPL08
      *
     C                     DO   *HIVAL
     C           K#PL8B    READEFBCPL08                  97
     C   97                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           FBMHN1    IFNE FBSHN1
     C           FBMHN2    ORNE FBSHN2
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #COMM
      *
     C           COMFLG    IFEQ 'N'
     C                     MOVE 'N'       FBCOM
     C                     ADD  1         RCNT
     C                     WRITEFBCWP211
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      ************************************************************
      *  CHECK COMMON PART
      ************************************************************
     C           #COMM     BEGSR
      *
     C                     MOVE 'N'       COMFLG  1
      * READ COMMON
     C                     MOVELFBMHN1    XMHN1
     C                     MOVELFBMHN2    XMHN2
     C                     MOVELFBMHN3    XMHN3
     C                     MOVELFBMHN4    XMHN4
     C                     Z-ADDFBTOKU    K#TOKU  40
     C                     Z-ADDFBNONY    K#NONY  40
     C                     MOVELFBNKOJ    K#NKOJ  1
     C                     MOVELFBNUKE    K#NUKE  4
     C           K#FAAB    SETLLFAAPL05
     C                     DO   *HIVAL
     C           K#FAAB    READEFAAPL05                  99
     C   99                LEAVE
     C                     MOVE 'Y'       COMFLG
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 2ND SCREEN
      ************************************************************
     C           #CTL01    BEGSR
      *
     C                     EXSR #SET1
      *
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F1: EXIT
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F3/12: BACK
     C           *INKC     WHEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      ************************************************************
      *  SET DATA FOR SFL01
      ************************************************************
     C           #SET1     BEGSR
      * CLEAR SFL01
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN1
      * EDIT SHIN
     C                     MOVELXSHIN     $SHIN
     C                     CALL 'UUUR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    X1SHIN
      *
     C                     MOVE 'Y'       FIRST
     C                     Z-ADD0         RRN1
     C           *LOVAL    SETLLFBCWP21
     C                     DO   *HIVAL
     C                     READ FBCWP21                  96
     C   96                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDFBTOKU    SVTOKU  40       K
     C                     Z-ADDFBNONY    SVNONY  40       K
     C                     MOVELFBNKOJ    SVNKOJ  1        K
     C                     MOVELFBNUKE    SVNUKE  4        K
     C                     MOVELFBMHIN    SVMHIN 20        K
     C                     ENDIF
      * BREAK?
     C           FBTOKU    IFNE SVTOKU
     C           FBNONY    ORNE SVNONY
     C           FBNKOJ    ORNE SVNKOJ
     C           FBNUKE    ORNE SVNUKE
     C           FBMHIN    ORNE SVMHIN
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL
     C                     Z-ADDFBNTAN    SVNTAN 105
     C                     Z-ADDFBTKHZ    SVTKHZ  80
     C                     Z-ADDFBTSHZ    SVTSHZ  80
      *
     C                     ENDDO
      * LAST PROCESS
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     Z-ADDRRN1      COUNT1  60
     C                     Z-ADD1         RRN1
      *
     C                     ENDSR
      ************************************************************
      * BREAK
      ************************************************************
     C           #BRK1     BEGSR
      *
     C                     MOVE ' '       S1SEL
     C                     Z-ADDSVTOKU    S1TOKU
     C                     Z-ADDSVNONY    S1NONY
     C                     MOVELSVNKOJ    S1NKOJ
     C                     MOVELSVNUKE    S1NUKE
     C                     MOVELSVMHIN    S1MHIN
      * EDIT MHIN
     C                     MOVELSVMHIN    $FLD1     P
     C                     CALL 'UUUR03'
     C                     PARM           $FLD1  20
     C                     PARM           $FLD2  23
     C                     MOVEL$FLD2     X1MHIN
      *
     C                     Z-ADDSVNTAN    S1NTAN
     C                     Z-ADDSVTKHZ    S1TKHZ
     C                     Z-ADDSVTSHZ    S1TSHZ
     C           S1TSHZ    IFEQ 99999999
     C                     MOVE *OFF      *IN45
     C                     MOVE *OFF      S145
     C                     ELSE
     C                     MOVE *ON       *IN45
     C                     MOVE *ON       S145
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      * RESET
     C                     Z-ADDFBTOKU    SVTOKU
     C                     Z-ADDFBNONY    SVNONY
     C                     MOVELFBNKOJ    SVNKOJ
     C                     MOVELFBNUKE    SVNUKE
     C                     MOVELFBMHIN    SVMHIN
     C                     Z-ADDFBNTAN    SVNTAN
     C                     Z-ADDFBTKHZ    SVTKHZ
     C                     Z-ADDFBTSHZ    SVTSHZ
      *
     C                     ENDSR
      *************************************************************
      *  CHECK SUB FILE
      *************************************************************
     C           #CHK2     BEGSR
      *
      *
     C           1         DO   COUNT1    RRN1
      *
     C           RRN1      CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C           S1SEL     ANDNE' '
     C                     EXSR #CTL02
     C           *IN03     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * DISPLAY SFL02 SCREEN
      *************************************************************
     C           #CTL02    BEGSR
      *
     C                     MOVELX1SHIN    X2SHIN
     C                     MOVELX1SHIN    X2SHIN
     C                     MOVELX1SHIN    X2SHIN
     C                     MOVELX1SHIN    X2SHIN
     C                     EXSR #SET2
     C                     Z-ADDS1TOKU    S2TOKU
     C                     Z-ADDS1NONY    S2NONY
     C                     MOVELS1NKOJ    S2NKOJ
     C                     MOVELS1NUKE    S2NUKE
     C                     MOVELX1SHIN    X2SHIN
     C                     MOVELX1MHIN    X2MHIN
      *
     C           @CTL02    TAG
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL02
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F1: EXIT
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F3: BACK
     C           *INKC     WHEQ *ON
     C                     MOVEL'02'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVEL'02'      W@ID
      * ENTR
     C                     OTHER
     C                     GOTO @CTL02
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * SET DATA FOR SFL02
      *************************************************************
     C           #SET2     BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL02
     C                     SETOF                     71
      *
     C                     Z-ADD0         RRN2
     C                     Z-ADDS1TOKU    KBTOKU
     C                     Z-ADDS1NONY    KBNONY
     C                     MOVELS1NKOJ    KBNKOJ
     C                     MOVELS1NUKE    KBNUKE
     C                     MOVELS1MHN1    KBMHN1
     C                     MOVELS1MHN2    KBMHN2
     C                     MOVELS1MHN3    KBMHN3
     C                     MOVELS1MHN4    KBMHN4
     C           K#WP21    SETLLFBCWP21
     C                     DO   *HIVAL
     C           K#WP21    READEFBCWP21                  96
     C   96                LEAVE
      *
     C                     Z-ADDFBNTAN    S2NTAN
     C                     Z-ADDFBTKHZ    S2TKHZ
     C                     Z-ADDFBTSHZ    S2TSHZ
     C           S2TSHZ    IFEQ 99999999
     C                     MOVE *ON       *IN48
     C                     MOVE *ON       S148
     C                     ELSE
     C                     MOVE *OFF      *IN48
     C                     MOVE *OFF      S148
     C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     Z-ADDRRN2      S2SEQ
     C                     WRITESFL02
     C                     ENDDO
      *
     C                     Z-ADDRRN2      COUNT2  60
     C                     Z-ADD1         RRN2
      *
     C                     ENDSR
      *************************************************************
      * INITIAL SETTING
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PCMD    1
      *
     C           K#FAAA    KLIST
     C                     KFLD           XSHN1
     C                     KFLD           XSHN2
     C                     KFLD           XSHN3
      *
     C           K#FB1A    KLIST
     C                     KFLD           FKTOKU  40
     C                     KFLD           FKNONY  40
     C                     KFLD           FKNKOJ  1
     C                     KFLD           FKNUKE  4
     C                     KFLD           FKMHN1  5
     C                     KFLD           FKMHN2  5
     C                     KFLD           FKMHN3  5
     C                     KFLD           FKMHN4  5
      *
     C           K#FAAB    KLIST
     C                     KFLD           XMHN1   5
     C                     KFLD           XMHN2   5
     C                     KFLD           XMHN3   5
     C                     KFLD           XMHN4   5
     C                     KFLD           K#TOKU  40
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
      *
     C           K#PL8B    KLIST
     C                     KFLD           FKMHN1
     C                     KFLD           FKMHN2
     C                     KFLD           FKMHN3
     C                     KFLD           FKMHN4
      *
     C           K#WP21    KLIST
     C                     KFLD           KBTOKU  40
     C                     KFLD           KBNONY  40
     C                     KFLD           KBNKOJ  1
     C                     KFLD           KBNUKE  4
     C                     KFLD           KBMHN1  5
     C                     KFLD           KBMHN2  5
     C                     KFLD           KBMHN3  5
     C                     KFLD           KBMHN4  5
      *
     C                     MOVE ' '       PCMD
     C                     TIME           SDATE
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
     C                     Z-ADD0         RCNT    40
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
