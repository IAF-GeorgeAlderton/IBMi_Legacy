     H            Y/
     F***************************************************
     F*   UPDATE IMPORT ORDER SCHEDULE                    *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FMBDPW70 CF  E                    WORKSTN
     FMBEPL02 IF  E           K        DISK
PART FFCEPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E*                   A11        10  4
      *
     E*                   ER      1   4 25
      *------------------------------------------------------------
     I            DS
     I                                        1  75 KEY1
     I                                        1   5 F2SHN1
     I                                        6  10 F2SHN2
     I                                       11  12 F2SHN3
     I                                        1  75 KEY1SV
     I                                        1   5 SVSHN1
     I                                        6  10 SVSHN2
     I                                       11  12 SVSHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           FBCKEY    KLIST
     C                     KFLD           SHN1SV
     C                     KFLD           SHN2SV
     C                     KFLD           SHN3SV
      *  DISPLAY SCREEN
     C           TOBU      TAG
     C                     EXFMTMBDPW701
     C   KA                SETON                     LR
     C   KA                GOTO END
     C                     SETOF                     99
      *
     C           STEP1     TAG
      *  ------------------------------------ *
     C                     CLEARSUM
      *
B1   C           *IN80     DOUEQ*ON
     C                     READ MBEPL02                  80
B2   C           *IN80     IFEQ *OFF
      *
B3   C           *IN77     IFEQ *OFF
     C                     MOVE F2SHN1    SHN1SV  5
     C                     MOVE F2SHN2    SHN2SV  5
     C                     MOVE F2SHN3    SHN3SV  2
     C                     MOVE '1'       *IN77
     C                     Z-ADD0         COUNT   10
E3   C                     ENDIF
      *
B3   C           F2SHN1    IFNE SHN1SV
     C           F2SHN2    ORNE SHN2SV
     C           F2SHN3    ORNE SHN3SV
     C                     EXSR #PRT
     C                     MOVE F2SHN1    SHN1SV
     C                     MOVE F2SHN2    SHN2SV
     C                     MOVE F2SHN3    SHN3SV
     C                     Z-ADDF2GOKE    SUM     60
     C                     Z-ADD1         COUNT
     C                     EXSR #DEV
     C                     ELSE
     C                     ADD  F2GOKE    SUM     60
     C                     ADD  1         COUNT
     C                     EXSR #DEV
E3   C                     ENDIF
E2   C                     ENDIF
E1   C                     ENDDO
      *  ------------------------------------ *
      *
     C           END       TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  #DEV
      *-------------------------------------------------------
     C           #DEV      BEGSR
     C           COUNT     IFEQ 1
     C                     MOVE F2NONY    A11     4
     C                     ENDIF
     C           COUNT     IFEQ 2
     C                     MOVE F2NONY    A12     4
     C                     ENDIF
     C           COUNT     IFEQ 3
     C                     MOVE F2NONY    A13     4
     C                     ENDIF
     C           COUNT     IFEQ 4
     C                     MOVE F2NONY    A14     4
     C                     ENDIF
     C           COUNT     IFEQ 5
     C                     MOVE F2NONY    A15     4
     C                     ENDIF
     C                     ENDSR
      *------------------------------------------------------
      *  PRINT
      *-------------------------------------------------------
     C           #PRT      BEGSR
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     TIME           @TIME   60
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C*                    MOVE @ER       A       10
      *CALCULATE BOX
     C           FBCKEY    CHAINFCEPL011             56
     C           *IN56     IFEQ '0'
     C           SUM       DIV  A2SSYS    BOX     40
     C                     ELSE
     C                     Z-ADDSUM       BOX
     C                     ENDIF
      *
     C           BOX       IFLT N1
     C                     EXCPT@DTL
     C                     ENDIF
      *
     C                     CLEARA11
     C                     CLEARA12
     C                     CLEARA13
     C                     CLEARA14
     C                     CLEARA15
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#BTA     KLIST
     C*                    KFLD           PRT1
     C*                    KFLD           PRT2
     C*                    KFLD           PRT3
     C                     KFLD           K@YM    60
      *
     C                     MOVE *ALL'-'   @LINE  90
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   02           @HED
     O                         #PGM       9
     O                         UDATE Y   60
     O                         @TIME     69 '  :  :  '
     O                                   72 'P.'
     O                         PAGE  Z   76
     O        E   03           @HED
     O                                   50 'DELIVERY > 16 BOXS'
     O        E   04           @HED
     O                                    6 'PART#'
     O                                   30 'DEL. QTY.'
     O                                   40 'QPC.'
     O                                   60 '# OF BOXES'
     O                                   70 'DEL1'
     O                                   75 'DEL2'
     O                                   80 'DEL3'
     O                                   85 'DEL4'
     O                                   90 'DEL5'
     O        E   05           @HED
     O                         @LINE     90
     O        E 1              @DTL
     O                         SHN1SV     6
     O                         SHN2SV    12
     O                         SHN3SV    15
     O                         SUM   J   30
     O                         A2SSYSJ   40
     O                         BOX   J   60
     O                         A11       70
     O                         A12       75
     O                         A13       80
     O                         A14       85
     O                         A15       90
