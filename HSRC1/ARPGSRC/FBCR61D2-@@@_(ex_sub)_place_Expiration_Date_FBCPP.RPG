     H            Y.
     F** FBCR61D2 ****************************************************
     F*  COPIED FROM: @FBCPP1D                                       *
     F*  WRITTEN    : 12/08/2015                                     *
     F*  WRITTEN BY : JW (SRA)                                       *
     F*  FUNCTION   : GET EXPIRATION DATE FROM PARAMETER             *
     F*             : AND PLACE IT IN EXPIRATION DATE                *
     F*             : EXTERNAL SUBROUTINE                            *
     F*  CALLING SEQ:                                                *
     F*                    CALL 'FBCR61D2'
     F*                    PARM           @CUST   4
     F*                    PARM           @DELV   4
     F*                    PARM           @MHN1   5
     F*                    PARM           @MHN2   5
     F*                    PARM           @MHN3   5
     F*                    PARM           @MHN4   5
     F*                    PARM           @EFDAT  8
     F*                    PARM           #EXDAT  8
     F*                    PARM           #RTN    1
     F****************************************************************
     FFBCPL16 UF  E           K        DISK
      *---------------------------------------------------------------
     I            DS
     I                                        1   8 KBTK
     I                                        1   40KBTKYY
     I                                        5   60KBTKMM
     I                                        7   80KBTKDD
     I            DS
     I                                        1   8 KBTS
     I                                        1   40KBTSYY
     I                                        5   60KBTSMM
     I                                        7   80KBTSDD
     I            DS
     I                                        1   8 FBTS
     I                                        1   40FBTSYY
     I                                        5   60FBTSMM
     I                                        7   80FBTSDD
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      *                    MAIN PROCESS
      ******************************************************
     C                     EXSR @INIT
      * LOOP
     C                     MOVEL@CUST     KBTOKU
     C                     MOVEL@DELV     KBNONY
     C                     MOVEL@MHN1     KBMHN1
     C                     MOVEL@MHN2     KBMHN2
     C                     MOVEL@MHN3     KBMHN3
     C                     MOVEL@MHN4     KBMHN4
     C                     MOVEL@EFDAT    KBTK
     C                     MOVEL@EXDAT    KBTS
     C           KEY       CHAINFBCPL16              91
     C           *IN91     IFEQ *OFF
     C           FBSKJY    ANDEQ' '
     C                     MOVE 'AD1'     FBKOME
     C                     MOVEL#EXDAT    FBTS
     C                     UPDATFBCPL161
     C                     ENDIF
      *
     C           *IN91     IFEQ *ON
     C                     MOVE '1'       #RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      *                  INITIAL ROUTINE
      ******************************************************
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           @CUST   4
     C                     PARM           @DELV   4
     C                     PARM           @MHN1   5
     C                     PARM           @MHN2   5
     C                     PARM           @MHN3   5
     C                     PARM           @MHN4   5
     C                     PARM           @EFDAT  8
     C                     PARM           @EXDAT  8
     C                     PARM           #EXDAT  8
     C                     PARM           #RTN    1
      *
     C           KEY       KLIST
     C                     KFLD           KBTOKU
     C                     KFLD           KBNONY
     C                     KFLD           KBMHN1
     C                     KFLD           KBMHN2
     C                     KFLD           KBMHN3
     C                     KFLD           KBMHN4
     C                     KFLD           KBTKYY
     C                     KFLD           KBTKMM
     C                     KFLD           KBTKDD
     C                     KFLD           KBTSYY
     C                     KFLD           KBTSMM
     C                     KFLD           KBTSDD
      *
     C           *LIKE     DEFN FBTOKU    KBTOKU
     C           *LIKE     DEFN FBNONY    KBNONY
     C           *LIKE     DEFN FBMHN1    KBMHN1
     C           *LIKE     DEFN FBMHN2    KBMHN2
     C           *LIKE     DEFN FBMHN3    KBMHN3
     C           *LIKE     DEFN FBMHN4    KBMHN4
      *
     C                     CLEAR#RTN
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
      *
     C                     ENDSR
