     CSR         #SB800    BEGSR
      *
     C           KEYF8     KLIST
     C                     KFLD           KAYY    40
     C                     KFLD           KAMM    20
     C                     KFLD           KADD    20
     C                     Z-ADD*YEAR     KAYY
     C                     Z-ADDUMONTH    KAMM
     C                     Z-ADDUDAY      KADD
     C                     Z-ADD1         CNT     30
     C                     Z-ADD0         W@01HZ  80
     C                     Z-ADD0         W@05HZ  80
     C                     Z-ADD0         W@10HZ  80
     C                     Z-ADD0         W@20HZ  80
     C           KEYF8     SETLLAGDPL111
     C                     READPAGDPL111                 28
     C           *IN28     DOWEQ'0'
     C           CNT       ANDLE20
     C           F8HIRU    IFEQ *BLANK
     C           W@01HZ    IFEQ 0
     C                     Z-ADDF8KAHZ    W@01HZ
     C                     ENDIF
     C                     SELEC
     C           CNT       WHLE 5
     C                     Z-ADDF8KAHZ    W@05HZ
     C                     Z-ADDF8KAHZ    W@10HZ
     C                     Z-ADDF8KAHZ    W@20HZ
     C           CNT       WHLE 10
     C                     Z-ADDF8KAHZ    W@10HZ
     C                     Z-ADDF8KAHZ    W@20HZ
     C           CNT       WHLE 20
     C                     Z-ADDF8KAHZ    W@20HZ
     C                     ENDSL
     C                     ADD  1         CNT
     C                     ENDIF
     C                     READPAGDPL111                 28
     C                     ENDDO
      *
     CSR         ESB800    ENDSR
