     C           B1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  B1SRYO    W@SRYO
     C                     ADD  B1SRYO    X120AL
     C                     SELEC
     C           B1NOHZ    WHGE W@05HZ
     C                     ADD  B1SRYO    X105AL
     C                     ADD  B1SRYO    X110AL
     C           B1NOHZ    WHGE W@10HZ
     C                     ADD  B1SRYO    X110AL
     C                     ENDSL
     C                     ENDIF
     C           AEYA11    READEAB#PL071                 28
     C                     ENDDO
      *
     C           X110AL    DIV  10        W210AV
      *
     CSR         ESB213    ENDSR
