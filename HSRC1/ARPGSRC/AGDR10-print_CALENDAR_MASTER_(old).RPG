     H            Y.
     F* AGDR10 **********************************************************
     F* PRINT IAF CALENDAR                                              *
     F* JW    2018.09.05                                                *
     F*******************************************************************
     FAGDPL12 IF  E           K        DISK         KINFDS INF1
     FQPRINT  O   F     198     OF     PRINTER
      *------------
     E                    NAM     1   4 11                FILE NAME
     E                    DAY        31  5                DAY
     IINF1        DS
     I                                       83  92 #FILE
     I                                    B 156 1590RCNT
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1   4 #DAY
     I                                        1   2 #D1
     I                                        3   3 #DH
     I                                        4   4 #DY
     I            DS
     I                                        1   60#FROM
     I                                        1   40#FRYY
     I                                        5   60#FRMM
     I            DS
     I                                        1   60#TO
     I                                        1   40#TOYY
     I                                        5   60#TOMM
     I            DS
     I                                        1   60#YM
     I                                        1   40#YY
     I                                        5   60#MM
     I            DS
     I                                        1   60SVYM
     I                                        1   40SVYY
     I                                        5   60SVMM
     I            DS
     I                                        1   60F8YM
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************
      * MAIN ROUTINE
      *************************************************
     C                     EXSR #INIT
      *
     C           KEY1      SETLLAGDPL12
      *
     C                     DO   *HIVAL
     C                     READ AGDPL12                  98
     C   98                LEAVE
      * END?
     C           F8YM      IFGT #TO
     C                     LEAVE
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDF8YM      SVYM
     C                     Z-ADDSVYY      PRYY
     C                     ENDIF
      * BREAK?
     C           F8YM      IFNE SVYM
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C                     Z-ADDF8KADD    IX      20
     C                     MOVELF8KADD    #D1
     C                     MOVELF8HIRU    #DH
     C                     MOVELF8YORU    #DY
     C                     MOVEL#DAY      DAY,IX
      * SET DAY OF FIRST DAY
     C           F8KADD    IFEQ 01
     C                     SELEC
     C           F8YOBI    WHEQ 1
     C                     MOVE 'MO'      DAY1
     C           F8YOBI    WHEQ 2
     C                     MOVE 'TU'      DAY1
     C           F8YOBI    WHEQ 3
     C                     MOVE 'WE'      DAY1
     C           F8YOBI    WHEQ 4
     C                     MOVE 'TH'      DAY1
     C           F8YOBI    WHEQ 5
     C                     MOVE 'FR'      DAY1
     C           F8YOBI    WHEQ 6
     C                     MOVE 'SA'      DAY1
     C           F8YOBI    WHEQ 7
     C                     MOVE 'SU'      DAY1
     C                     ENDSL
     C                     ENDIF
      *
     C                     SELEC
     C           F8YOBI    WHEQ 1
     C                     MOVE 'MO'      DAY31
     C           F8YOBI    WHEQ 2
     C                     MOVE 'TU'      DAY31
     C           F8YOBI    WHEQ 3
     C                     MOVE 'WE'      DAY31
     C           F8YOBI    WHEQ 4
     C                     MOVE 'TH'      DAY31
     C           F8YOBI    WHEQ 5
     C                     MOVE 'FR'      DAY31
     C           F8YOBI    WHEQ 6
     C                     MOVE 'SA'      DAY31
     C           F8YOBI    WHEQ 7
     C                     MOVE 'SU'      DAY31
     C                     ENDSL
      *
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*===========
     C* BREAK
     C*===========
     C           #BRK1     BEGSR
      *
     C                     EXSR #PRNT
      * RESET
     C                     Z-ADDF8YM      SVYM
     C                     MOVEA*BLANK    DAY
      *
     C                     ENDSR
      *===========
      * PRINT
      *===========
     C           #PRNT     BEGSR
     C           LIN#      IFGE 63
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT .
     C           SVYY      IFNE PRYY
     C                     EXCPT@P
     C                     Z-ADDSVYY      PRYY
     C                     ADD  1         LIN#
     C                     ENDIF
      *
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *************************************************
      * INITIAL SET
      *************************************************
     C           #INIT     BEGSR
     C*  PARAMETER
     C           *ENTRY    PLIST
     C                     PARM           $FROM   6
     C                     PARM           $TO     6
     C*  KEY
     C           KEY1      KLIST
     C                     KFLD           #YY     40
     C                     KFLD           #MM     20
      *
     C                     MOVEL$FROM     #FROM
     C                     MOVEL$FROM     #YM
     C                     MOVEL$TO       #TO
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         SVYM    60
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         PRYY    40
     C                     MOVE *BLANK    DAY1    2
     C                     MOVE *BLANK    DAY31   2
      *
     C                     MOVEA*BLANK    DAY
     C                     TIME           SDATE
      * SET FILE NAME INDEX
     C                     Z-ADD1         IY      10
     C                     SELEC
     C           #FILE     WHEQ 'AGDPL12'
     C                     Z-ADD1         IY
\    C           #FILE     WHEQ 'A#DPL12'
     C                     Z-ADD2         IY
     C           #FILE     WHEQ 'A@DPL12'
     C                     Z-ADD3         IY
     C           #FILE     WHEQ 'A$DPL12'
     C                     Z-ADD4         IY
     C                     ENDSL
      *
     C                     MOVEA*BLANK    DAY
     C                     TIME           SDATE
     C                     ENDSR
      *************************************************
     OQPRINT  E   01           @HDR
     O                                    4 'PGM:'
     O                         #PGM      12
     O                                   18 'FILE:'
     O                         #FILE     28
     O                         NAM,IY    38
     O                                   66 '** CALENDAR MASTER **'
     O                                   72 '(FROM'
     O                         $FROM     79
     O                                   82 'TO'
     O                         $TO       89
     O                                   90 ')'
     O                                  160 'DATE:'
     O                         TODAY    169
     O        E   03           @HDR
     O                                    1 ' '
     O        E  1             @DTL
     O                         SVYM    +  0
     O                         DAY1    +  1
     O                         DAY,01  +  2
     O                         DAY,02  +  0
     O                         DAY,03  +  0
     O                         DAY,04  +  0
     O                         DAY,05  +  0
     O                         DAY,06  +  0
     O                         DAY,07  +  0
     O                         DAY,08  +  0
     O                         DAY,09  +  0
     O                         DAY,10  +  0
     O                         DAY,11  +  0
     O                         DAY,12  +  0
     O                         DAY,13  +  0
     O                         DAY,14  +  0
     O                         DAY,15  +  0
     O                         DAY,16  +  0
     O                         DAY,17  +  0
     O                         DAY,18  +  0
     O                         DAY,19  +  0
     O                         DAY,20  +  0
     O                         DAY,21  +  0
     O                         DAY,22  +  0
     O                         DAY,23  +  0
     O                         DAY,24  +  0
     O                         DAY,25  +  0
     O                         DAY,26  +  0
     O                         DAY,27  +  0
     O                         DAY,28  +  0
     O                         DAY,29  +  0
     O                         DAY,30  +  0
     O                         DAY,31  +  0
     O                         DAY31   +  1
      *
     O        E  1             @P
     O                                    1 '.'
** NAM -> (9A)
(1.IAF)           1.AGDPL12
(2.ASJ-PT)        2.A#DPL12
(3.CUST-FC)       3.A@DPL12
(4.REGULAR)       4.A$DPL12
