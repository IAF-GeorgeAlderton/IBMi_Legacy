     C                     ENDSR
      *------------------------------------------------------------
      *  DOWNLOAD TO CSV
      *------------------------------------------------------------
     C           #CSV      BEGSR
      * CLEAR AB#WP09
     C           *LOVAL    SETLLAB#WP09
     C                     DO   *HIVAL
     C                     READ AB#WP09                  99
     C   99                LEAVE
     C                     DELETAB#WP091
     C                     ENDDO
      *
     C                     EXSR #CSVH
      *
     C                     Z-ADD0         RRN1
     C                     DO   *HIVAL
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                99
     C   99                LEAVE
     C                     EXSR #CSVD
     C                     ENDDO
      *
     C                     CALL 'AB#C09C'
      *
     C                     ENDSR
      *------------------------------------------------------------
      *  SET CSV HEADER
      *------------------------------------------------------------
     C           #CSVH     BEGSR
      *
     C                     CLEARAB#WP091
     C                     MOVEL'EDI     'W9EDIK
     C                     MOVEL'CUST#   'W9TOKU
     C                     MOVEL'DELIV#  'W9NONY
     C                     MOVEL'FACTORY 'W9NKOJ
     C                     MOVEL'DOCK    'W9DOCK
     C                     MOVEL'SHP_DATE'W9DAT1
     C                     MOVEL'BIN#    'W9BIN
     C                     MOVEL'USR_PART'W9MHIN
     C                     MOVEL'IAF_PART'W9SHIN
     C                     MOVEL'QTY     'W9OQTY
     C                     MOVEL'BOX     'W9BOX
     C                     MOVEL'QPC     'W9QPC
     C                     MOVEL'ORDER#  'W9ODRN
     C                     MOVEL'BIL_DATE'W9UDAT
     C                     MOVEL'U/PRICE 'W9UP
     C                     MOVEL'AMOUNT  'W9AMT
     C                     WRITEAB#WP091
      *
     C                     ENDSR
      *------------------------------------------------------------
      *  SET CSV DETAIL
      *------------------------------------------------------------
     C           #CSVD     BEGSR
      *
     C                     CLEARAB#WP091
     C                     MOVELS@EDIK    W9EDIK
     C                     MOVELH@TOKU    W9TOKU
     C                     MOVELH@NONY    W9NONY
     C                     MOVELS@FACT    W9NKOJ
     C                     MOVELS@DOCK    W9DOCK
      * NOHZ
     C                     MOVELH@NOHZ    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE2    W9DAT1
      *
     C                     MOVELS@BIN     W9BIN
      *
     C                     MOVELH@MHIN    $MHIN     P
     C                     CALL 'UUUR03'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    W9MHIN
      *
     C                     MOVELS@SHIN    $SHIN     P
     C                     CALL 'UUUR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    W9SHIN
      *
     C                     MOVELS@OQTY    W9OQTY
     C           H@QPC     IFEQ 0
     C                     MOVEL'1'       W9BOX     P
     C                     ELSE
     C           S@OQTY    DIV  H@QPC     SHO     90
     C                     MVR            REM     50
     C           REM       IFNE 0
     C                     ADD  1         SHO
     C                     ENDIF
     C                     MOVELSHO       W9BOX
     C                     ENDIF
      *
     C                     MOVELH@QPC     W9QPC
     C                     MOVELH@ODRN    W9ODRN
      * URHZ
     C           H@URHZ    IFEQ 0
     C                     MOVELH@URHZ    W9UDAT
     C                     ELSE
     C                     MOVELH@URHZ    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE2    W9UDAT
     C                     ENDIF
      *
     C                     Z-ADDH@UP      $IN
     C                     CALL 'UTLR64'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     W9UP
      *
     C           H@UP      MULT S@OQTY    NUM105 105
     C                     Z-ADDNUM105    $IN
     C                     CALL 'UTLR64'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     W9AMT
      *
     C                     WRITEAB#WP091
      *
     C                     ENDSR
      *------------------------------------------------------------
      *  SET DATA FOR 3RD SCREEN
      *------------------------------------------------------------
     C           #SET21    BEGSR
      *
     C                     MOVE *OFF      *IN98
      *
JW2  C           K#AP7X    SETLLAB#PL70A
     C           *IN81     DOUEQ*ON
JW2  C           K#AP7X    READEAB#PL70A                 81
     C           *IN81     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
      *
     C           *IN98     IFEQ *OFF
     C           EKISNO    ANDNE*BLANK
     C                     MOVELTTL,1     D@TTL
     C                     MOVE *ON       *IN98
     C                     ENDIF
     C                     MOVE *OFF      *IN02
     C                     CLEARSFL02
      *
TCHK4C           S@OQTY    IFNE S@SQTY
     C           EKSRYO    ANDEQ*ZERO
     C                     MOVE *ON       *IN02
     C                     MOVE EKSERL    S@SRNO
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ELSE
     C           EKSRYO    IFNE *ZERO
TCHK2C           EKNONY    IFEQ '3222'
TCHK2C           EKSRYO    ANDNEH@USYS
TCHK2C                     ITER
TCHK2C                     END
     C                     ADD  EKSRYO    S@QTY
     C                     Z-ADDEKDATE    S@SHDT
     C                     Z-ADDEKDETM    S@TIME
     C                     MOVE EKSERL    S@SRNO
     C                     MOVELEKLTNO    S@KANB
     C                     MOVE EKISNO    S@KANB
     C                     MOVE EKHENK    S@RTY
     C           EKHENK    IFNE *BLANK
     C                     ADD  EKSRYO    D@RQTY
     C                     ENDIF
TCHK3C*
TCHK3C                     MOVEL*BLANK    S@QSSS
TCHK3C           EKNONY    IFEQ '4044'
TCHK3C           EKSERL    SETLLALDPL46
TCHK3C                     DO   *HIVAL
TCHK3C           EKSERL    READEALDPL46                  70
TCHK3C   70                LEAVE
TCHK3C           AEERR     IFNE *BLANK
TCHK3C                     ITER
TCHK3C                     END
TCHK3C                     MOVELAESRL#    S@QSSS
TCHK3C                     LEAVE
TCHK3C                     ENDDO
TCHK3C                     END
TCHK4C*
TCHK4C           EKNONY    IFEQ '0170'
TCHK4C           EKSERL    CHAINGTAPL10              79
TCHK4C           *IN79     IFEQ *OFF
TCHK4C           G1SKJY    ANDEQ*BLANK
TCHK4C           G1KNHZ    IFEQ *ZERO
TCHK4C                     MOVEL*ON       *IN02
TCHK4C                     END
TCHK4C                     END
TCHK4C                     END
