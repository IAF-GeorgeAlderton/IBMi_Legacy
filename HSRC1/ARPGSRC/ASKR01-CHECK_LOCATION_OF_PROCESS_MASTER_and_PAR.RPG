     H            Y.
     F** ASKR01 **************************************
     F*工程Ｍの番地と部品Ｍの番地比較
     F*       SAKAKI.       2019.11.28               *
     F************************************************
     FNZUPL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     E                    OTK        15  6               所番地
      *
     I            DS
     I                                        1  12 A2BHB
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
      *
     I            DS
     I                                        1   6 A2KTR
     I                                        1   1 A2KTRK
     I                                        2   3 A2KTRT
     I                                        4   5 A2KTRR
     I                                        6   6 A2KTRD
      *
     I            DS
     I                                        1   6 A2STR
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1  10 W@YMDB
     I                                        1   8 W@HAHZ
     I                                        9  10 W@HABB
      *
     I            DS
     I                                        1   6 WTKR
     I                                        1   1 WTKR1
     I                                        2   3 WTKR2
     I                                        4   5 WTKR3
     I                                        6   6 WTKR4
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C           *ENTRY    PLIST
     C                     PARM           P1ZETI  4
     C                     PARM           P1TEHI  3
     C                     PARM           P1PAGN  2
     C                     PARM           P@HNTE  2
      *
     C                     TIME           SDATE
     C                     MOVEL'NG'      P@HNTE
      *
     C           KEYNZU    KLIST
     C                     KFLD           K1ZETI  4
     C                     KFLD           K1TEHI  3
     C                     KFLD           K1PAGN  2
     C                     MOVELP1ZETI    K1ZETI
     C                     MOVELP1TEHI    K1TEHI
     C                     MOVELP1PAGN    K1PAGN
     C                     MOVEL*BLANK    W@YMDB
     C                     MOVEL*BLANK    W@SHN1  5
     C                     MOVEL*BLANK    W@SHN2  5
     C                     MOVEL*BLANK    W@SHN3  2
     C           KEYNZU    SETGTNZUPL01
     C           KEYNZU    REDPENZUPL01                  80
     C           *IN80     DOWEQ'0'
     C           N2SKJY    IFEQ 'D'
     C           N2SKHZ    ANDLEWDATE
     C                     ELSE
     C                     MOVE N2HAHZ    W@HAHZ
     C                     MOVE N2HABB    W@HABB
     C                     MOVELN2SHN1    W@SHN1
     C                     MOVELN2SHN2    W@SHN2
     C                     MOVELN2SHN3    W@SHN3
     C                     LEAVE
     C                     ENDIF
     C           KEYNZU    REDPENZUPL01                  80
     C                     ENDDO
      *
     C           KEYFCE    KLIST
     C                     KFLD           W@SHN1  5
     C                     KFLD           W@SHN2  5
     C                     KFLD           W@SHN3  2
     C                     MOVEL'1'       OPNCLS
     C           KEYFCE    CHAINFCEPL011             80
     C           *IN80     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLEWDATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C                     ENDIF
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           W@YMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DATA                                               *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *部品Ｍ番地
     C                     MOVELA2STR     FCETKR  6
     C           A2TRHZ    IFGT WDATE
     C                     MOVELA2KTR     FCETKR
     C                     ENDIF
      *
     C                     MOVEA*BLANK    OTK
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           W@YMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPTKR      OTK
      *工程Ｍ番地
      *最終番地
     C                     Z-ADD15        X       30
     C                     MOVEL*BLANK    AAMTKR  6
     C           X         DOWGE1
     C           AAMTKR    ANDEQ*BLANK
     C                     MOVELOTK,X     AAMTKR
     C                     SUB  1         X
     C                     ENDDO
      *工程Ｍ番地と部品Ｍ番地
     C           AAMTKR    IFEQ FCETKR
     C                     MOVEL'OK'      P@HNTE
     C                     ELSE
     C                     MOVEL'NG'      P@HNTE
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
