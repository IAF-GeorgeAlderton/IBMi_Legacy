     H            Y.
     F** AB#RBM *************************************************************
     F*  GENERATE AB#EP40 FROM ABAEP20                                      *
     F*  JW   2025.07.24                                                    *
     F***********************************************************************
     FABAEP20 IF  E           K        DISK
     FAB#EP40 O   E                    DISK
      *----------------------------------------------------------------
     E                    MSG     1   5 60
     I            DS
     I                                        1  140STIME
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
      *  MAIN
      *---------------------------------------------------------
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLABAEP20
     C                     DO   *HIVAL
     C                     READ ABAEP20                  98
     C   98                LEAVE
      * ITER
     C           AEUPID    IFNE ' '
     C           AEEQTY    OREQ 0
     C                     ITER
     C                     ENDIF
      * 5917
     C           AENONY    IFEQ '5917'                     FNG VENTRA KITCHENER
     C           AEDAT1    ANDLT@DAT16
     C                     EXSR #P5917
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------------
      *  PROCESS FOR 5917
      *---------------------------------------------------------
     C           #P5917    BEGSR
      *
     C                     CLEARAB#EP401
     C                     MOVELAEPRTR    EPRTNR
     C                     MOVELAETOKU    ETOKU
     C                     MOVELAENONY    ENONY
     C                     MOVEL'0'       ENKOJ
     C                     MOVEL'00  '    ENUKE
     C                     MOVELAEMHIN    EMHIN
     C                     MOVELAEDAT1    ENDATE
     C                     Z-ADDAEEQTY    ESRYO
     C                     Z-ADDAECQTY    EUSYS
     C                     MOVEL'11655'   EODRN
     C                     MOVEL'2025203A'EINVN
     C                     MOVELMSG,1     EN1ST
     C                     MOVELMSG,2     EN1SU
     C                     MOVEL'EA'      EFLR1
     C                     MOVEL'5917'    EALFL
     C                     MOVELMSG,3     ESUNM
     C                     MOVEL'C'       EEKBN
     C                     MOVELTODAY     ERVSN
      *
     C           EMHIN     IFEQ 'C12003'
     C                     MOVELMSG,4     EPANM
     C                     ENDIF
      *
     C                     Z-ADDAERCVT    EPODT
     C                     Z-ADDNOW       EPOTM
      *
     C                     WRITEAB#EP401
     C                     ADD  1         @CNT
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  INITIAL SETTINGS
      *---------------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     TIME           STIME
     C                     Z-ADD0         @CNT    40
      * GET TARGET DATE
      * (TODAY + 16 DAYS)
     C                     MOVELTODAY     $DT8
     C                     MOVE '+'       $SIGN
     C                     MOVE '0016'    $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10A'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
      *
     C           $RTN      IFEQ ' '
     C                     MOVEL$TGT8     @DAT16  80
     C                     ELSE
     C                     Z-ADD0         @DAT16
     C                     ENDIF
      *
     C                     ENDSR
** MSG (60A) ......2.........3.........4.........5.........6
256714759                                                    01
INDIANA AUTOMOTIVE FASTENERS                                 02
946955648                                                    03
NUT   SQUARE     X  .  X   .                                 04
