     H            Y
     F**ALDRT7 ********************************************************
     F* GET SB LOADING  ALMPP01                                       *
     F*  SAKAKI.          2019.09.18                                  *
     F**************************************************ALMR0Z*********
     FALMPL01 IF  E           K        DISK                           UC
      *===============================================================
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     **かんばん発行日
     I            DS
     I                                        1   80W$HTHZ
     I                                        1   40W$HTYY
     I                                        5   60W$HTMM
     I                                        7   80W$HTDD
     **投入日
     I            DS
     I                                        1   80A1SCHZ
     I                                        1   40A1SCYY
     I                                        5   60A1SCMM
     I                                        7   80A1SCDD
     **投入時刻
     I            DS
     I                                        1   60A1SCTM
     I            DS
     I                                        1  15 A1KAN
     I                                        2   5 A1ZETI
     I                                        6   8 A1TEHI
     I                                        9  10 A1PAGE
     **
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *===============================================================
     C           *ENTRY    PLIST
     C*                                IN ------
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THAI  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           P@HTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEALMPL01
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN ALMPL01
     C                     ENDIF
     C*------------------------*
     C*   KLIST の作成       *
     C*------------------------*
     C           #KEY1     KLIST
     C                     KFLD           P@HIN1  5        PART NUMBER 1
     C                     KFLD           P@HIN2  5        PART NUMBER 2
     C                     KFLD           P@HIN3  2        PART NUMBER 3
     C* * *                KFLD           P@THAI  3        PRODUCTION ORDER
     C                     KFLD           W$HTYY  40       KANBAN PUBLICATION Y
     C                     KFLD           W$HTMM  20       KANBAN PUBLICATION M
     C                     KFLD           W$HTDD  20       KANBAN PUBLICATION D
     C           #KEY11    KLIST
     C                     KFLD           P@HIN1  5        PART NUMBER 1
     C                     KFLD           P@HIN2  5        PART NUMBER 2
     C                     KFLD           P@HIN3  2        PART NUMBER 3
     C* * *                KFLD           P@THAI  3        PRODUCTION ORDER
      *===============================================================
     C                     Z-ADDP@HTHZ    W$HTHZ           KANBAN PUBLICATION
     C                     Z-ADD0         P@WIHZ  80       WORK ADMITTABLE DATE
     C                     Z-ADD0         P@WITM  60       WORK ADMITTABLE TIME
     C           #KEY1     SETLLALMPL01
     C*
     C                     DO   *HIVAL
     C*
     C           #KEY11    READEALMPL01                  90
     C*
     C   90                LEAVE
     C*
     C           A1SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C*
     C           A1TEHI    IFNE P@THAI
     C                     ITER
     C                     END
     C           A1PAGE    IFNE P@PAGE
     C                     ITER
     C                     END
     C*
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA1SCHZ    P@WIHZ  80       WORK ADMITTABLE DATE
     C                     Z-ADDA1SCTM    P@WITM  60       WORK ADMITTABLE TIME
     C                     ENDIF
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
