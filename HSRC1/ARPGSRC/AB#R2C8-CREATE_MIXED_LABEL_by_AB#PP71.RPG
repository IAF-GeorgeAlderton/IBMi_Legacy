     H            Y.
      ** AB#R2C8 *******************************************
      *  CREATE MIXED LABEL BY AB#PP71                     *
      *                                                    *
      *  JW   2019.11.19                                   *
      ******************************************************
     FAB#PL71AIF  E           K        DISK
     FAB#NP30 UF  E           K        DISK                      A
     FAB#WP2O O   E                    DISK
JW   FAB#XP01AO   E                    DISK
      *-----------------------------------------------------
     E                    MSG     1   5 50
     I            DS
     I                                        1  23 @@PART
     I                                        1   5 @@MHN1
     I                                        6   6 @@HP1
     I                                        7  11 @@MHN2
     I                                       12  12 @@HP2
     I                                       13  17 @@MHN3
     I                                       18  18 @@HP3
     I                                       19  23 @@MHN4
     I            DS
     I                                        1  20 MPMHIN
     I                                        1   5 MPMHN1
     I                                        6  10 MPMHN2
     I                                       11  15 MPMHN3
     I                                       16  20 MPMHN4
     I            DS
     I                                        1  12 MPSHIN
     I                                        1   5 MPSHN1
     I                                        6  10 MPSHN2
     I                                       11  12 MPSHN3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------
      * MAIN ROUTINE
      *-----------------------------------------------------
     C                     EXSR #INIT
      *
     C           $SERL#    SETLLAB#PL71A
     C                     DO   *HIVAL
     C           $SERL#    READEAB#PL71A                 98
     C   98                LEAVE
      *
     C                     CLEARAB#WP2O1
      * GET SERIAL NO.
     C                     EXSR @NMBR
      * USER PART
     C                     MOVELMPMHIN    $IPART
     C                     MOVELMPNONY    $NONY
     C                     CALL 'UTLR75B'
     C                     PARM           $IPART 20
     C                     PARM           $NONY   4
     C                     PARM           $UPART 20
     C                     PARM           $RTN    1
      *
     C           MPMHIN    IFEQ $UPART
     C                     EXSR #PART
     C                     MOVEL@@PART    O2PART
     C                     ELSE
     C                     MOVEL$UPART    O2PART
     C                     ENDIF
      *
     C                     MOVELMPSBAN    O2SBAN
     C                     MOVELMPSRYO    O2QTY
     C                     MOVELMPNUKE    O2DOCK
     C                     MOVE *BLANK    O2ADDR
     C                     MOVELMPNONY    O2SIRE
      * PART NAME
     C           MPNONY    IFEQ 0465
     C           MPNONY    OREQ 0467
     C                     MOVELMSG,1     O2PNAM
     C                     ELSE
     C                     MOVE *BLANK    O2PNAM
     C                     ENDIF
      *
     C                     MOVELMPSHIN    O2IPAR
     C                     MOVELMPNOHZ    O2SHDT
     C                     MOVE *BLANK    O2SEQ#
     C                     MOVELMPODRN    O2ORDR
      * DUMMY FIELD
     C           MPNONY    IFEQ 0465
     C           MPNONY    OREQ 0467
     C                     MOVE N3NMBR    O2DUMY
     C                     ELSE
     C                     MOVE *BLANK    O2DUMY
     C                     ENDIF
      *
     C                     MOVELMPLOC1    O2LOC1
     C                     MOVELMPLOC2    O2LOC2
     C                     MOVELMPLOC3    O2LOC3
     C                     MOVELMPLOC4    O2LOC4
     C                     MOVELMPNONY    O2DELY
     C                     MOVELMPNKOJ    O2FACT
     C                     MOVE *BLANK    O2ZETI
     C                     MOVELMPSYOS    O2UNIT
      * CUSTOMER NAME
     C                     MOVELMPNONY    PMNONY
     C                     MOVE 'D'       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           PMRTN   1
     C                     MOVELPMNAME    O2CNAM
      * WEIGHT
     C                     MOVEL'0'       O2WEIT
      * SERIAL #
     C                     MOVELN3NMBR    O2SERL
     C                     MOVELMPNONY    O2SERL
      * USER SPACE
     C           MPNONY    IFEQ 0465
     C           MPNONY    OREQ 0467
     C                     EXSR #U0465
     C                     MOVEL@@FILR    O2FILR
     C                     ELSE
     C                     MOVE *BLANK    O2FILR
     C                     ENDIF
      *
     C                     MOVELMPNONY    PNONY
     C                     CALL 'AB#R2C2'
     C                     PARM           PNONY   4
     C                     PARM *BLANK    P@ADR1 50
     C                     PARM *BLANK    P@ADR2 50
     C                     PARM *BLANK    P@ADR3 50
     C                     PARM *BLANK    P@ADR4 50
     C                     PARM *BLANK    P@ADR5 50
     C                     PARM *BLANK    P@ADR6 50
     C                     PARM *BLANK    P@SKJY  1
      *
     C                     MOVELP@ADR1    O2FLDB
     C                     MOVELP@ADR2    O2FLDC
     C                     MOVELP@ADR3    O2FLDD
      *
     C                     WRITEAB#WP2O1
      *
 |   C                     CLEARAB#XP1A1
 |   C                     MOVEL'AB#WP2O 'IXWRKF    P
 |   C                     EXSR #XP01                      =>AB#XP01
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * EDIT PART (5-5-5-5)
      *-----------------------------------------------------
     C           #PART     BEGSR
      *
     C                     MOVELMPMHN1    @@MHN1
     C                     MOVELMPMHN2    @@MHN2
     C                     MOVELMPMHN3    @@MHN3
     C                     MOVELMPMHN4    @@MHN4
      *
     C           @@MHN2    IFEQ *BLANK
     C                     MOVE *BLANK    @@HP1
     C                     ENDIF
     C           @@MHN3    IFEQ *BLANK
     C                     MOVE *BLANK    @@HP2
     C                     ENDIF
     C           @@MHN4    IFEQ *BLANK
     C                     MOVE *BLANK    @@HP3
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
      * EDIT USER SPACE FOR ADVICS (0465)
      *-----------------------------------------------------
     C           #U0465    BEGSR
      *
     C                     MOVE *BLANK    @@FILR 20
     C                     MOVEL'#  '     LTR3A   3
     C                     MOVE MPNOBN    LTR3A
     C                     MOVEL'XXXX BIN'LTR11  11
     C                     MOVELMPNONY    LTR11
     C                     MOVE LTR3A     LTR11            '0465 BIN#01' 11A
     C                     MOVELMPPAL#    LTR3B   3
     C                     MOVEL'SKID#   'LTR8    8
     C                     MOVE LTR3B     LTR8             'SKID#001' 8A
     C                     MOVELLTR11     @@FILR                     A
     C                     MOVE LTR8      @@FILR           11A + b + 8A
      *
     C                     ENDSR
      *-----------------------------------------------------
      * SET SERIAL #
      *-----------------------------------------------------
     C           @NMBR     BEGSR
      *
     C                     MOVE *ALL'9'   @@14   140
     C           MPNONY    CHAINAB#NP30              97
     C                     Z-ADDTODAY     N3UDAT
     C                     Z-ADDNOW       N3UTIM
     C                     MOVEL#PGM      N3UPGM
     C                     MOVEL#USER     N3UUSR
     C                     MOVEL#WSID     N3UWIS
     C                     Z-ADDMPNONY    N3NONY
     C           *IN97     IFEQ *ON
     C                     Z-ADD1         N3NMBR
     C                     WRITEAB#NP301
     C                     ELSE
     C                     ADD  1         N3NMBR
     C           N3NMBR    IFEQ @@14
     C                     Z-ADD1         N3NMBR
     C                     ENDIF
     C                     UPDATAB#NP301
     C                     ENDIF
      *
     C                     ENDSR
      *================================================================
      *  ..LABEL DATA ISSUE LOG                            *
      *================================================================
     C           #XP01     BEGSR
      *
     C                     Z-ADDTODAY     IXKOHZ           TODAY
     C                     Z-ADDNOW       IXKOTM           NOW
      **                   MOVEL          IXTOKU           CUSTOMER
     C                     MOVELO2DELY    IXNONY           DELIVERY
     C                     MOVELO2FACT    IXNKOJ           FACTORY
     C                     MOVELO2DOCK    IXNUKE           DOCK
     C                     MOVELO2ORDR    IXODRN           ORDER #
     C                     MOVELO2SERL    IXSERL           SERIAL NUMBER
     C                     MOVELO2SHDT    IXDEDT           INVOICE DATE
      **                   MOVE           IXNOBN           INVOICE BIN
      *
     C                     MOVELMPSERL    IXPL#
     C                     MOVEL#USER     IXKOUS
     C                     MOVEL#WSID     IXKOWS
     C                     MOVEL#PGM      IXKOPG
      *
      **                   MOVEL MHIN     IXMHIN
      **                   MOVEL ASHIN    IXSHIN
     C                     MOVELO2PNAM    IXINVN
      **                   MOVEL AHPOS    IXHPOS
      **                   MOVEL AROUT    IXROUT
      **                   Z-ADD ASRYO    IXSRYO
      **                   Z-ADD ASYOS    IXSYOS
      **                   Z-ADD AUSYS    IXUSYS
      **                   MOVEL KDSP     IXFIL1
      *
     C                     WRITEAB#XP1A1
      *
     C                     ENDSR
      *-----------------------------------------------------
      * INITIAL SETTING
      *-----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SERL#  9
      *
     C                     TIME           SDATE
      *
     C                     ENDSR
** MSG ..1.........2.........3.........4..........5
MASTER LABEL                                         01
                                                     02
                                                     03
                                                     04
                                                     05
