E001 C                     END
     C*
B001 C           GASM      IFNE 0
     C                     MOVEL'M3/H'    BB04
E001 C                     END
     C*
     C                     EXCPTDET
     C*
     C           @END      TAG
     C*
     CL1                   MOVE *BLANK    CC01    5
     CL1                   MOVE *BLANK    CC02    4
B001 CL1         DAIS      IFNE 0
     CL1                   MOVEL'BOARD'   CC01
E001 CL1                   END
     C*
B001 CL1         GGASM     IFNE 0
     CL1                   MOVEL'M3/H'    CC02
E001 CL1                   END
     C*
     CL1         *INOF     IFEQ '1'
     CL1                   EXSR #OF
     CL1                   END
     C*
     CL1                   EXCPTKEI
     C*
     CL1                   MOVEL'1'       *INOF
     C******************************************************
     C           #OF       BEGSR                           *
     C******************************************************
     C                     MOVE *BLANK    KJNM   16
     C           @KOJO     CHAINFGBPL011             10
     C           *IN,10    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,10
     C                     END
     C*
     C  N10                MOVELB2SMEI    KJNM
     C*
     C                     MOVE *BLANK    SNM     8
B002 C           PKBN      IFEQ '1'
     C                     MOVEL'LUMP-SUM'SNM
X002 C                     ELSE
B003 C           PKBN      IFEQ '2'
     C                     MOVEL'ALLOCATE'SNM
E003 C                     END
E002 C                     END
     C*
     C                     TIME           TIME    60
     C                     Z-ADDUDATE     DAY     60
     C                     ADD  1         CNT
     C                     EXCPTHED
     C                     MOVEL'0'       *INOF
     C*
     C                     ENDSR
     C*
