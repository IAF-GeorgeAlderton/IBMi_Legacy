     C           *ENTRY    PLIST
     C                     PARM           PKJ     4
     C                     PARM           PKBN    1
     C                     PARM           PLST    1
     C******               MOVELPKJ       KOJO    40
     C*
     C  N01                GOTO @END
     C*
B001 C           *IN90     IFEQ '0'
     C                     MOVEL'1'       *INOF
     C                     MOVEA'1'       *IN,90
     C                     Z-ADD0         CNT     40
     C                     Z-ADD0         DAIS    30
     C                     Z-ADD0         GYOKW   72
     C                     Z-ADD0         GYOLL   71
     C                     Z-ADD0         GGASM   52
     C           PLST      IFEQ '1'
     C                     MOVE LT,1      LMEI   16
     C                     ELSE
     C           PLST      IFEQ '2'
     C                     MOVE LT,2      LMEI
     C                     ELSE
     C           PLST      IFEQ '3'
     C                     MOVE LT,3      LMEI
     C                     ELSE
     C           PLST      IFEQ '4'
     C                     MOVE LT,4      LMEI
     C                     ELSE
     C           PLST      IFEQ '5'
     C                     MOVE LT,5      LMEI
     C                     ELSE
     C                     MOVE *BLANK    LMEI
E006 C                     END
E005 C                     END
E004 C                     END
E003 C                     END
E002 C                     END
E001 C                     END
     C******************************************************
     C*  LET'S  PRINT-OUT                                  *
     C******************************************************
B001 C           *INOF     IFEQ '1'
     C                     EXSR #OF
E001 C                     END
     C*
     C                     ADD  1         DAIS
     C                     ADD  YOKW      GYOKW
     C                     ADD  YOLL      GYOLL
     C                     ADD  GASM      GGASM
     C*
     C                     MOVE *BLANK    AA01    1
     C                     MOVE *BLANK    AA02    1
     C                     MOVE *BLANK    AA03    1
     C                     MOVE *BLANK    AA04    1
     C                     MOVE *BLANK    AA06    1
     C                     MOVE *BLANK    AA07    1
     C                     MOVE *BLANK    AA08    1
     C                     MOVE *BLANK    AA09    1
     C                     MOVE *BLANK    AA10    1
B001 C           KAKA      IFNE *BLANK
     C                     MOVEL'-'       AA01
E001 C                     END
     C*
B001 C           KBN2      IFNE *BLANK
     C                     MOVEL'-'       AA02
E001 C                     END
     C*
B001 C           OKB2      IFNE *BLANK
     C                     MOVEL'-'       AA03
E001 C                     END
     C*
B001 C           SYS2      IFNE *BLANK
