E001 C                     END
     C*
     C*
B001 C           QCS3      IFNE *BLANK
     C                     MOVEL'-'       AA10
E001 C                     END
     C*
     C                     MOVE *BLANK    JTNM    8
     C           JTKB      LOKUPTAB1      TAB2           70
     C   70                MOVELTAB2      JTNM
     C*
     C                     MOVE *BLANK    QKJM    4
     C           QKJY      IFNE 0
     C                     MOVE QKJY      QKJM
     C                     END
     C*
     C                     MOVE *BLANK    BB01    3
     C                     MOVE *BLANK    BB02    2
     C                     MOVE *BLANK    BB03    1
     C                     MOVE *BLANK    BB04    4
B001 C           RPMH      IFNE 0
     C                     MOVEL'RPH'     BB01
E001 C                     END
     C*
B001 C           YOKW      IFNE 0
     C                     MOVEL'KW'      BB02
E001 C                     END
     C*
B001 C           YOLL      IFNE 0
