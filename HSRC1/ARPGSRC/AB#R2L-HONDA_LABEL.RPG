 .   C           @SYOS     IFNE 0
 .   C           *IN61     ANDEQ*OFF
 .   C           @RQTY     DIV  @SYOS     QUO     60       QUOTIENT
 .   C                     MVR            REM     30       REMAINDER
 .   C           REM       IFNE 0
