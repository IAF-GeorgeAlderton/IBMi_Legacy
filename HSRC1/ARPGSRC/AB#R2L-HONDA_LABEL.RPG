     C***********************************************************
     C* @CHK1:CHECK ITEMS ON 1ST. SCREEN
     C***********************************************************
     C           @CHK1     BEGSR
     C*
     C* DELIVERY CODE BLANK ?
     C           PNONY     IFEQ *BLANK
     C                     SETON                     3031
     C                     MOVELER,1      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* FACTORY CODE BLANK ?
     C           PNKOJ     IFEQ *BLANK
     C                     SETON                     3032
     C                     MOVELER,2      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* DOCK CODE BLANK ?
     C           PNUKE     IFEQ *BLANK
     C           *INKG     ANDEQ*ON
     C                     SETON                     3033
     C                     MOVELER,3      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* SHIPPING DATE
     C           PNOHZ     IFEQ 0
     C                     SETON                     3034
     C                     MOVELER,4      MSG
     C                     GOTO #CHK1
     C                     END
      *
     C           PNOMM     IFLT 1
     C           PNOMM     ORGT 12
     C                     SETON                     3034
     C                     MOVELER,5      MSG
     C                     GOTO #CHK1
     C                     END
      *
     C           PNODD     IFLT 1
     C           PNODD     ORGT 31
     C                     SETON                     3034
     C                     MOVELER,5      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* BIN       *
     C           BIN       IFEQ 0
     C                     SETON                     3035
     C                     MOVELER,6      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* SERIAL# (1)
     C*          SER1F     IFNE *ZERO
     C*          SER1T     ANDEQ*ZERO
     C*                    SETON                     3037
     C*                    MOVELER,7      MSG
     C*                    GOTO #CHK1
     C*                    END
     C*
     C*          SER1F     IFEQ *ZERO
     C*          SER1T     ANDNE*ZERO
     C*                    SETON                     3037
     C*                    MOVELER,7      MSG
     C*                    GOTO #CHK1
     C*                    END
     C*
     C* SERIAL# (2)
     C*          SER2F     IFNE *BLANK
     C*          SER2T     ANDEQ*BLANK
     C*                    SETON                     3038
     C*                    MOVELER,7      MSG
     C*                    GOTO #CHK1
     C*                    END
     C*
     C*          SER2F     IFEQ *BLANK
     C*          SER2T     ANDNE*BLANK
     C*                    SETON                     3038
     C*                    MOVELER,7      MSG
     C*                    GOTO #CHK1
     C*                    END
     C*
     C* SERIAL# (3)
     C*          SER3F     IFNE *ZERO
     C*          SER3T     ANDEQ*ZERO
     C*                    SETON                     3039
     C*                    MOVELER,7      MSG
     C*                    GOTO #CHK1
     C*                    END
     C*
     C*          SER3F     IFEQ *ZERO
     C*          SER3T     ANDNE*ZERO
     C*                    SETON                     3039
     C*                    MOVELER,7      MSG
     C*                    GOTO #CHK1
     C*                    END
     C*
     C* INPOSSIBLE F7 AND SERIAL NUMER
     C*          *INKG     IFEQ '1'
     C*          SER1F     IFNE *BLANK
     C*          SER1T     ORNE *BLANK
     C*          SER2F     ORNE *BLANK
     C*          SER2T     ORNE *BLANK
     C*          SER3F     ORNE *ZERO
     C*          SER3T     ORNE *ZERO
     C*                    SETON                     30
     C*                    MOVELER,13     MSG
     C*                    GOTO #CHK1
     C*                    END
     C*                    END
      *
     C                     MOVE PNONY     WNONY   40
     C                     EXSR #SYSCH
JW3  C* IF NO ERROR, RESET PALLET#
 |   C           *IN30     IFEQ *OFF
 |   C                     Z-ADD0         CNT2U
 |   C                     Z-ADD0         CNT2V
 |   C                     Z-ADD0         CNT2X
 |   C                     Z-ADD1         PLT2U
 |   C                     Z-ADD1         PLT2V
 |   C                     Z-ADD1         PLT2X
JW3  C                     ENDIF
