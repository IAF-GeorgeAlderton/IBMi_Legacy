     C***********************************************************
     C* @SFL:CREATE SUB FILE
     C***********************************************************
     C           @SFL      BEGSR
     C*
     C                     Z-ADD*ZERO     RRN
     C                     MOVE PNONY     WNONY
     C                     MOVE *OFF      *IN31
     C*
     C           KEY1      SETLLAB#PL131
     C           KEY1      READEAB#PL131                 93
     C           *IN93     DOWEQ'0'
     C                     MOVE *OFF      *IN61
     C*
     C* DELETED  ?
     C           BASKJY    IFNE ' '
     C                     GOTO #READ
     C                     END
     C*
     C* SAME BIN ?
     C           BIN       IFNE 0
     C           BIN       ANDNEBANOBN
     C                     GOTO #READ
     C                     END
      *
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     GOTO #READ
     C                     ENDIF
     C*
     C* IF SELECTED ORDER#, SAME ORDER# ?
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     GOTO #READ
     C                     END
     C*
     C* SET DATA TO SUB FILE
     C                     ADD  1         RRN
     C           RRN       CHAINSFL01                94
     C                     MOVE *BLANK    @FLAG
     C                     Z-ADD*ZERO     @#LAB
     C*
     C*
     C           BAMHN4    IFEQ *BLANK
     C                     MOVE *BLANK    @P3
     C                     ELSE
     C                     MOVE BAMHN4    WAMHN4
     C                     MOVE '-'       @P3
     C                     END
     C*
     C           BAMHN3    IFEQ *BLANK
     C                     MOVE *BLANK    @P2
     C                     ELSE
     C                     MOVE BAMHN3    WAMHN3
     C                     MOVE '-'       @P2
     C                     END
     C*
     C           BAMHN2    IFEQ *BLANK
     C                     MOVE *BLANK    @P1
     C                     ELSE
     C                     MOVE BAMHN2    WAMHN2
     C                     MOVE '-'       @P1
     C                     END
     C*
     C                     MOVE BAMHN1    WAMHN1
     C*
     C                     MOVE BASBAN    @SBAN
     C                     MOVE BAODRN    @ODER
     C                     Z-ADDBASRYO    @RQTY
     C                     Z-ADDBASYOS    @SYOS
     C                     Z-ADDBAUSYS    @USYS
      *
     C           BASYOS    IFNE BAUSYS
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN31
     C                     MOVELER,16     MSG
     C                     ENDIF
JW6   * CHECK FULL BOX QTY
 .   C           @SYOS     IFNE 0
 .   C           *IN61     ANDEQ*OFF
 .   C           @RQTY     DIV  @SYOS     QUO     60       QUOTIENT
 .   C                     MVR            REM     30       REMAINDER
 .   C           REM       IFNE 0
 .   C                     MOVE *ON       *IN61
 .   C                     MOVE *ON       *IN31
 .   C                     MOVELER,18     MSG
 .   C                     ENDIF
JW6  C                     ENDIF
      *
     C   94                WRITESFL01
     C  N94                UPDATSFL01
     C*
     C           #READ     TAG
     C           KEY1      READEAB#PL131                 93
     C                     END
     C*
     C           RRN       IFEQ *ZERO
     C                     SETON                     30
     C                     MOVELER,12     MSG
     C*
     C                     ELSE
     C                     MOVE '2'       WKDSP
     C                     Z-ADDRRN       W1RRN
     C                     Z-ADD1         RRN
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* @WRT2:WRITE LABEL DATA(SELECTED PART NUMBER)
     C***********************************************************
     C           @WRT2     BEGSR
     C*
     C                     SETOF                     55
     C                     SETON                     8887
     C* GET THE NUMBER OF LABEL
     C           PNONY     CHAINAB#PL90              96
     C           *IN96     IFEQ '0'
     C                     Z-ADDYA#LAB    W#LAB
     C                     ELSE
     C                     Z-ADD1         W#LAB
     C                     END
     C*
     C                     Z-ADD1         RRN
     C                     DO   W1RRN
     C           RRN       CHAINSFL01                94
     C           *IN94     IFEQ '0'
     C           @FLAG     IFNE *BLANK
     C           @#LAB     ORNE 0
     C*
     C                     MOVE PNONY     WNONY   40
     C                     MOVEL@ODER     WORDN  10
     C*
     C                     EXSR @HONDA
     C                     END
     C                     END
     C*
     C           #WRT2     TAG
     C                     ADD  1         RRN
     C                     END
     C*
     C                     SETOF                     88
     C*
     C                     ENDSR
