JW5  C           A2GSHZ    ANDLETODAY
TCHK C                     MOVEL*ON       *IN91
TCHK C                     END
TCHK C*
TCHK C           *IN91     IFEQ *ON
TCHK C                     ADD  1         RRN2
TCHK C                     MOVE BASHN1    S@PRT1
TCHK C                     MOVE BASHN2    S@PRT2
TCHK C                     MOVE BASHN3    S@PRT3
TCHK C                     Z-ADDBAUSYS    S@BOX1
TCHK C                     Z-ADDBASYOS    S@BOX2
JW6  C                     Z-ADDBASRYO    S@SRYO
TCHK C                     MOVELEMSG,1    S@EMSG
TCHK C                     WRITESFL02
TCHK C                     ENDIF
      * CHECK QPC
JW6  C           *IN91     IFEQ *OFF
     C           BAUSYS    ANDNEBASYOS
     C           BAUSYS    ANDNE0
     C           BASYOS    ANDNE0
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
JW6  C                     Z-ADDBASRYO    S@SRYO
TCHK C                     MOVELEMSG,2    S@EMSG
     C                     WRITESFL02
     C                     ENDIF
      * CHECK FULL BOX QTY
JW6  C           *IN91     IFEQ *OFF
     C           BASYOS    ANDNE0
     C           BASRYO    DIV  BASYOS    QUO
 .   C                     MVR            REM
 .   C           REM       IFNE 0
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
JW6  C                     Z-ADDBASRYO    S@SRYO
TCHK C                     MOVELEMSG,3    S@EMSG
     C                     WRITESFL02
     C                     ENDIF
      *
TCHK C                     ENDIF
TCHK  *
     C                     ENDIF
     C                     ENDDO
