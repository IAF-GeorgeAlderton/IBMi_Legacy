     H            Y/
     F***************************************************
     F*   ASJ MATERIAL QUICK SCHEDULE                   *
     F*          10/24/02   TCH                         *
     F*                                                 *
     F*   MODIFICAITON:                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGDLPW70 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FIZAPL01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGDLPL34 IF  E           K        DISK
     FGDLPP70 UF  E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    CMD     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@HMS
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@MM
     I                                       13  140W@DD
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#IZA     KLIST
     C                     KFLD           D@ZAIS
     C                     KFLD           D@ZAIK
     C           K#ADGP    KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GDL     KLIST
     C                     KFLD           D@ZAIS
     C                     KFLD           D@ZAIK
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#G70     KLIST
     C                     KFLD           D@ZAIS
     C                     KFLD           D@ZAIK
     C                     KFLD           K@YMD
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET1
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           K#IZA     SETLLIZAPL01
     C           *IN90     DOUEQ*ON
     C           K#IZA     READEIZAPL01                  90
     C           *IN90     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSTYY    ANDEQ9999
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN51
     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
     C                     MOVE *OFF      *IN80
      *  HEADER INFORMATION
     C                     MOVELZCADR1    D@LOC1
     C                     MOVELZCADR2    D@LOC2
     C                     MOVELZCADR3    D@LOC3
     C                     MOVELZCADR4    D@LOC4
     C           ZCMSJR    DIV  20        @@PDY   70H
     C           @@PDY     DIV  ZCTKJR    D@BXDY    H
      *
     C                     Z-ADDD@STCK    @@STCK  70
     C                     Z-ADD*DATE     K@YMD
     C           K#ADGP    SETGTAGDPL12
     C                     EXSR #SET2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     Z-ADD@@RRN     RRN1
     C                     CLEARSFL01
      *
     C                     Z-ADD*ZERO     X       30
     C                     DO   *HIVAL
     C                     READ AGDPL12                  80
     C           *IN80     IFEQ *ON
     C                     LEAVE
     C                     ELSE
      *
     C                     CLEARSFL01
      *
     C           F8KAMM    MULT 100       S@DATE
     C                     ADD  F8KADD    S@DATE
     C                     MOVELF8HIRU    S@HLDY
      * INVOICE INF.
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
      *
     C                     Z-ADDK@YMD     H@DATE
      *
     C           K#GDL     SETLLGDLPL34
     C           *IN91     DOUEQ*ON
     C           K#GDL     READEGDLPL34                  91
      *
     C           *IN91     IFEQ *OFF
     C           LESKJY    ANDEQ*BLANK
      *
     C                     MOVELLEINV1    S@IVNO
     C                     MOVE LEINV2    S@IVNO
     C                     MOVE S@IVNO    H@IVNO
     C           LEHANY    IFEQ 'S'
     C                     ADD  1         S@SEA
     C                     ELSE
     C                     ADD  1         S@AIR
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
      *** FROM SAVED FILE
     C           K#G70     CHAINGDLPP70             N91
     C           *IN91     IFEQ *OFF
     C           G7SKJY    ANDEQ*BLANK
     C                     MOVELG7IVNO    H@IVNO
     C                     MOVELG7IVNO    S@IVNO
     C                     Z-ADDG7#SCL    S@SEA
     C                     Z-ADDG7#ACL    S@AIR
     C                     ENDIF
      *
     C           S@HLDY    IFEQ *BLANK
     C                     Z-ADDD@BXDY    S@USE
     C                     ENDIF
      *
     C           @@STCK    ADD  S@AIR     S@STK2
     C                     ADD  S@SEA     S@STK2
     C                     SUB  S@USE     S@STK2
     C                     Z-ADDS@STK2    @@STCK
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ADD  1         X
     C           X         IFEQ 15
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN1      #RCNO1
     C                     Z-ADDRRN1      @@RRN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN52
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD@@REC     #RCNO1
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      * F5
     C           *INKE     WHEQ *ON
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     EXSR #UPD
     C                     ENDIF
     C                     MOVEL'01'      W@ID
      * F11
     C           *INKK     WHEQ *ON
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     EXSR #PRT
     C                     ENDIF
     C                     MOVEL'01'      W@ID
      * ROLL UP
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #CHK2
     C                     EXSR #SET2
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     Z-ADD*ZERO     WRRN    40
     C                     Z-ADDD@STCK    WWSTK   70
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVEA'00000000'*IN,60
      *
     C           S@AIR     IFNE *ZERO
     C           S@SEA     ORNE *ZERO
     C           S@IVNO    IFEQ *BLANK
     C                     MOVE *ON       *IN62
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
     C           S@IVNO    IFNE *BLANK
     C           S@AIR     ANDEQ*ZERO
     C           S@SEA     ANDEQ*ZERO
     C                     MOVE *ON       *IN63
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           WWSTK     ADD  S@AIR     S@STK2
     C                     ADD  S@SEA     S@STK2
     C                     SUB  S@USE     S@STK2
     C                     Z-ADDS@STK2    WWSTK
     C                     UPDATSFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDWWSTK     @@STCK
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
      *
     C                     Z-ADDH@DATE    K@YMD
     C           H@IVNO    IFNE *BLANK
     C           S@IVNO    ORNE *BLANK
     C           K#G70     CHAINGDLPP70              91
     C           *IN91     IFEQ *ON
     C                     CLEARGDLPP701
     C                     ENDIF
      * UPDATE/WRITE
     C                     MOVE S@IVNO    G7IVNO
     C                     MOVE D@ZAIS    G7ZAIS
     C                     Z-ADDD@ZAIK    G7ZAIK
     C                     Z-ADDH@DATE    G7RCDT
      *
     C           S@AIR     IFNE *ZERO
     C                     Z-ADDS@AIR     G7#ACL
     C                     ENDIF
     C           S@SEA     IFNE *ZERO
     C                     Z-ADDS@SEA     G7#SCL
     C                     ENDIF
      *
     C                     Z-ADD*DATE     G7KODT
     C                     TIME           G7KOTM
     C                     MOVEL#USER     G7KOME
     C  N91                UPDATGDLPP701
     C   91                WRITEGDLPP701
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  OUTPUT
      *------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     MOVE *ALL'-'   @@LINE 66
     C                     Z-ADD*ZERO     WRRN    40
     C                     EXCPT@HED
      *
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C                     EXCPT@DTL
      *
     C           H@IVNO    IFNE *BLANK
     C           S@IVNO    ORNE *BLANK
     C                     Z-ADDH@DATE    K@YMD
     C           K#G70     CHAINGDLPP70              91
     C           *IN91     IFEQ *ON
     C                     CLEARGDLPP701
     C                     ENDIF
      * UPDATE/WRITE
     C                     MOVE S@IVNO    G7IVNO
     C                     MOVE D@ZAIS    G7ZAIS
     C                     Z-ADDD@ZAIK    G7ZAIK
     C                     Z-ADDH@DATE    G7RCDT
      *
     C           S@AIR     IFNE *ZERO
     C                     Z-ADDS@AIR     G7#ACL
     C                     ENDIF
     C           S@SEA     IFNE *ZERO
     C                     Z-ADDS@SEA     G7#SCL
     C                     ENDIF
      *
     C                     Z-ADD*DATE     G7KODT
     C                     TIME           G7KOTM
     C                     MOVEL#USER     G7KOME
     C  N91                UPDATGDLPP701
     C   91                WRITEGDLPP701
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         @@MDY Y   59
     O                                   62 'P.'
     O                         PAGE  Z   66
     O        E   02           @HED
     O                                   40 'ASJ MATERIAL SCHEDULE'
     O                         W@HMS     59 '  :  :  '
     O        E   04           @HED
     O                                    9 'MATERIAL:'
     O                         D@ZAIS    27
     O                         D@ZAIK4   33
     O                                   55 'LOCATION:'
     O                         D@LOC1    57
     O                         D@LOC2    60
     O                         D@LOC3    63
     O                         D@LOC4    65
     O        E   05           @HED
     O                                   10 'COILS/DAY:'
     O                         D@BXDY1   19
     O        E   07           @HED
     O                                    4 'DATE'
     O                                   16 'INVOICE#'
     O                                   34 'AIR'
     O                                   41 'SEA'
     O                                   50 'USE'
     O                                   64 'BALANCE'
     O        E   08           @HED
     O                         @@LINE    66
     O        E 1              @DTL
     O                         S@DATEY    5
     O                         S@HLDY     7
     O                         S@IVNO    15
     O                         S@AIR 2   34
     O                         S@SEA 2   41
     O                         S@USE 2   50
     O                         S@STK2J   65
**  CMD
F3: EXIT
F3: EXIT    F5: SAVE INVOICE INF     F11: PRINT    F12: PREV
