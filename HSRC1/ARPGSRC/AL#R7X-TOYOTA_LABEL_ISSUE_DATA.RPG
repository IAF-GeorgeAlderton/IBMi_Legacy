     H            Y.
     F** AL#R7X  *******************************************
     F*  TOYOTA LABEL ISSUE DATA                           *
     F*      ITS.        2015.06.02                        *
     F******************************************************
     FAL#WP73 IF  F     256            DISK
     FAL#PP21 IF  E           K        DISK
     FAL#PPX1 O   E                    DISK                      A
      *
     IAL#WP73 AA  01
     I                                        1 256 IALL
     I                                        1   1 IKBN
     I                                        9  11 IPAGE
     I                                       12  14 ITPAG
     I                                       37  37 INKOJ
     I                                       38  39 INUKE
     I                                       56  59 INONY
     I                                      141 152 IORD#
     I                                      161 165 INAMC
     I                                      219 221 IIAFP
     I                                      222 227 ILOCA
     I                                      228 228 IPPUL
     I                                      231 231 IZONE
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
     C           *ENTRY    PLIST
     C                     PARM           P7FIXD  80
     C                     PARM           P7FIXT  60
     C                     PARM           P7TIMS  20
     C                     PARM           P7TRKB  2
     C                     PARM           P7IAFB  3
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
     C                     READ AL#WP73                  90
     C           *IN90     DOWEQ'0'
     C                     SELEC
     C           IKBN      WHEQ '3'
     C                     EXSR #SB500
     C           IKBN      WHEQ '2'
     C                     EXSR #SB501
     C                     ENDSL
     C                     READ AL#WP73                  90
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  '3'
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#PPX11
      *
     C                     MOVE IPAGE     CRPAGE
     C                     MOVE ITPAG     CRTPAG
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  '2'
      *-----------------------------------------------------
     CSR         #SB501    BEGSR
      *
     C           INAMC     CHAINAL#PP21              21
     C           *IN21     IFEQ *OFF
     C                     MOVE C2NONY    CRNONY
     C                     ENDIF
      *
     C                     Z-ADDSDATE     CRKOHZ
     C                     Z-ADDSTIME     CRKOTI
     C                     MOVELIZONE     CRZONE
     C                     MOVELIIAFP     CRIAFP
     C                     MOVELILOCA     CRLOCA
     C                     MOVELIPPUL     CRPPUL
     C                     MOVELINKOJ     CRNKOJ
     C                     MOVELINUKE     CRNUKE
     C                     MOVELIORD#     CRORD#
      *
     C                     Z-ADDP7FIXD    CRFIXD
     C                     Z-ADDP7FIXT    CRFIXT
     C                     Z-ADDP7TIMS    CRTIMS
     C                     MOVELP7TRKB    CRTRKB
     C                     MOVELP7IAFB    CRIAFB
      *
     C                     WRITEAL#PPX11
      *
     CSR         ESB501    ENDSR
