     CLR                   EXSR SUB
      *
     C           SUB       BEGSR
      *
      *新日鉄・住金用*
      * KG --> T *
     C           IJRY      DIV  1000000   @IJRY   60
     C           TJRY      DIV  1000000   @TJRY   60
      *
      *合計*
     C                     Z-ADD0         GOKI    60
     C           @IJRY     ADD  @TJRY     GOKI
      *
      *比率*
     C           GOKI      IFNE *ZERO
     C           @IJRY     DIV  GOKI      IPA     54
     C           IPA       MULT 100       @IPA    52
     C                     ELSE
     C                     Z-ADD*ZERO     @IPA
     C                     ENDIF
      *
     C                     Z-ADD0         GOP     52
     C                     Z-ADD@IPA      GOP
     C           100.00    SUB  GOP       @TPA    52
      *
     C                     MOVEL*ALL'-'   BAR1   38
     C                     MOVEL*ALL'-'   BAR2   20
      *
      *トヨタ集鋼材用*
      * KG --> T *
     C           IJRY2     DIV  1000000   @IJRY2  60
     C           TJRY2     DIV  1000000   @TJRY2  60
      *
      *合計*
     C                     Z-ADD0         GOKI2   60
     C           @IJRY2    ADD  @TJRY2    GOKI2
      *
      *比率*
     C           @IJRY2    DIV  GOKI2     IPA2    54
     C           IPA2      MULT 100       @IPA2   52
     C                     Z-ADD0         GOP2    52
     C                     Z-ADD@IPA2     GOP2
     C           100.00    SUB  GOP2      @TPA2   52
      *
     C                     MOVEL*ALL'-'   BAR3   38
     C                     MOVEL*ALL'-'   BAR4   20
     C                     EXCPTME
     C                     ENDSR
      *---------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     MOVE GGOKE2    @2      20
     C           GGOKE2    DIV  1000      W@TON   71
     C           @2        IFGT *ZERO
     C                     ADD  0.1       W@TON
     C                     ENDIF
      *
     C                     EXCPT@WRT
      *
     C                     ENDSR
