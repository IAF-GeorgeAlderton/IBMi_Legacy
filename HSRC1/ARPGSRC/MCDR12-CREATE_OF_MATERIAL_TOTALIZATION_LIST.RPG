     C******************************************************
     C* M-NO CD.1.1        ﾌﾟ[x-j- cinﾒ                    *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
     C                     SETOF                     201213
     C                     SETOF                     1402
      *
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     MOVE PHIZK     UHIZK
     C                     MOVE UYY       NEN     40
     C                     MOVE UMM       TUK     20
     C                     Z-ADD0         IJRY   150       ＩＡＦ重量
     C                     Z-ADD0         TJRY   150       その他重量量
     C                     Z-ADD0         IJRY2  150       ＩＡＦ重量
     C                     Z-ADD0         TJRY2  150       その他重量量
     C           UMONTH    SUB  1         WMONTH  20
     C           WMONTH    COMP 1                    131213
     C   12      *YEAR     SUB  1         WYEAR   40
     C   12                Z-ADD12        WMONTH
     C   13                MOVE *YEAR     WYEAR
     C                     Z-ADD0         I       30
     C                     MOVE ' '       WMS     2
     C                     END
      *
     C******************************************************
     C* 材料使用重量比較表　＜集計処理＞                 *
     C******************************************************
      * KEY *
     C           KEY       KLIST
     C                     KFLD           WHBN1
     C                     KFLD           WHBN2
     C                     KFLD           WHBN3
      *
     C           K#ZC      KLIST
     C                     KFLD           ZMEIH
     C                     KFLD           BZAIH
      * SUPPLIER
     C                     MOVE *BLANK    @@SUPL 10
     C           K#ZC      SETLLIZAPL01
     C           *IN90     DOUEQ*ON
     C           K#ZC      READEIZAPL01                  90
     C           *IN90     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSDAT    ANDEQ*ALL'9'
     C           ZCKAKE    SETLLFGBPL01
     C           *IN91     DOUEQ*ON
     C           ZCKAKE    READEFGBPL01                  91
     C           *IN91     IFEQ *OFF
     C           B2SKJY    ANDEQ*BLANK
     C                     MOVELB2SMEI    @@SUPL
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDZCMKJR    @MKJR   80
     C                     Z-ADDZCKMMX    @MAX    30
     C                     MOVE ZCADR1    @ADR1   1
     C                     MOVE ZCADR2    @ADR2   2
     C                     MOVE ZCADR3    @ADR3   2
     C                     MOVE ZCADR4    @ADR4   1
     C                     LEAVE
      *
     C                     ENDIF
     C                     ENDDO
      *
      *部品情報マスター*
     C                     SETOF                     30
     C           KEY       CHAINFCEPL011             30
     C           *IN30     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C           A2TEHI    ANDNE'G'
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
      *
      *設定数*
     C           A2GEKN    MULT A2SOZI    XXX    150
      *
      *手配*
     C           SKYUH     IFEQ '01'
     C           SKYUH     OREQ '02'
      *
      *集計*
     C           ZUKE      IFEQ 0111
     C                     ADD  XXX       IJRY
     C                     ELSE
     C                     ADD  XXX       TJRY
     C                     END
     C                     END
      *
     C           SKYUH     IFEQ '01'
     C           SKYUH     OREQ '02'
     C           SKYUH     OREQ '03'
      *
      *集計*
     C           ZUKE      IFEQ 0111
     C                     ADD  XXX       IJRY2
     C                     ELSE
     C                     ADD  XXX       TJRY2
     C                     END
     C                     END
      *
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         WKISU1  90
     C                     Z-ADD0         WKISU2  90
     C                     Z-ADD0         WKISU3  90
     C                     END
      *
     C                     SETOF                     30
     C                     MOVE *BLANK    WKIRI   1
     C           KEY       CHAINAFBPP201             30
     C           *IN30     IFEQ '0'
     C           CGSKJY    ANDEQ'D'
     C           CGSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVE CGKIRI    WKIRI
     C                     END
      *
     C           WKIRI     IFEQ '1'
     C                     ADD  JRYOH     WKISU1
     C                     END
     C           WKIRI     IFEQ '2'
     C                     ADD  JRYOH     WKISU2
     C                     END
     C           WKIRI     IFEQ '3'
     C                     ADD  JRYOH     WKISU3
     C                     END
      *
     C           SZAIH     MULT IGEKN     @@15   154H
     C           @@15      DIV  1000      @@7    070H
     C*******              ADD  @@7       @@WG   100
      *
     C******************************************************
     C* M-NO CD.1.2        xbﾅbOUT ﾆﾞ]ﾍﾞ                   *
     C******************************************************
     C           SKYUH     COMP '-'                      20
     C           MSYOH     IFNE WMS
     C                     MOVE MSYOH     WMS
     C                     END
     C   L2
     COR OF                MOVELZMEIH     WZMEI  15
     C   L2
     COR OF                MOVELZMEIH     #ZMEI  15
     C   L1
     COR OF                SETON                     02
     C   L1
     COR OF                Z-ADDBZAIH     WBZAI   52
     C   L1
     COR OF                Z-ADDBZAIH     #BZAI   52
      *
     C******************************************************
     C* M-NO CD.1.2.       TOTAL iﾇﾅ]                      *
     C******************************************************
     C           SRYOH     ADD  SGOKE2    SGOKE2  90
     C           JRYOH     ADD  GGOKE2    GGOKE2  70
     C           IGEKN     ADD  SGEKE2    SGEKE2  90
     C********   GRYOH     ADD  GGEKE2    GGEKE2  70
     C           @@7       ADD  GGEKE2    GGEKE2  70
     C           END       TAG
      *
     C******************************************************
     C* M-NO CD.1.3.       tﾞﾅﾞbib TOTAL ﾎﾟﾒ]n             *
     C******************************************************
     CL1         SGOKE2    ADD  SGOKE4    SGOKE4  90
     CL1         GGOKE2    ADD  GGOKE4    GGOKE4  70
     CL1         SGEKE2    ADD  SGEKE4    SGEKE4  90
     CL1         GGEKE2    ADD  GGEKE4    GGEKE4  70
