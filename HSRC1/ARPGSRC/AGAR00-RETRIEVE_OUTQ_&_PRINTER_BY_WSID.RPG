     H            Y.
     F** AGAR00 ******************************************************
     F*  RETRIEVE OUTQ & PRINTER BY WSID                             *
     F*  TYPE K=KANA G=KANJI  PRTG KANJI OUTQ                        *
      *-------------------------------------------------             *
     F*  CALLING SEQ.                                                *
     F*                    CALL 'AGAR00'                             *
     F*                    PARM           WSID   10                  *
     F*                    PARM           PRT     7                  *
     F*                    PARM           TYPE    1                  *
     F*                    PARM           PRTG   10                  *
     F*   IN  WSID   10A WSID                                        *
     F*   OUT PRT     7A SPOOL FILE                                  *
     F*       TYPE    1A WSID  TYPE (K=KANA G=KANJI)                 *
     F*       PRTG   10A OUTQ                                        *
      *-------------------------------------------------             *
     F*         I-HASADA    1991.05.23                               *
     F*         T-SAKAKI    2015.09.03 ADD USER                      *
JW1  F*         J.WATANABE  2021.08.09 STOP DEFAULT OUTQ LANPRT50    *
     F****************************************************************
     FAJEPL01 IF  E           K        DISK
     I            DS
     I                                        1  10 UWS
     I                                        1   2 UKEY
     I                                        1   1 UKY1
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C           *ENTRY    PLIST
     C                     PARM           WSID   10
     C                     PARM           PRT     7
     C                     PARM           TYPE    1
     C                     PARM           PRTG   10
     C                     MOVE WSID      UWS
      *
     C           KPARM     PLIST
     C                     PARM           PKINO   1
      *
     C           KEY1      KLIST
     C                     KFLD           PKINO
     C                     KFLD           UKEY
      *
     C                     CALL 'AJEC06'  KPARM
      *
     C                     SETOF                     01
     C           KEY1      CHAINAJEPL011             01
     C           *IN01     IFEQ '0'
     C                     MOVE H4SPLF    PRT
     C                     MOVE H4WSTY    TYPE
     C                     MOVELH4SPIG    PRTG
     C                     ELSE
      *
     C           PKINO     IFEQ '1'
     C                     MOVE 'QPRINT ' PRT
     C                     MOVE 'G'       TYPE
     C                     MOVEL'QPRINT ' PRTG
     C                     END
     C                     END
      *
     C           #USER     IFEQ 'QPGMR  '
     C           #USER     OREQ 'TEST   '
     C                     MOVE 'QPRINTP' PRT
     C                     MOVE 'G'       TYPE
     C                     MOVEL'QPRINTP' PRTG
     C                     ELSE
     C**JW1      PRTG      IFEQ 'QPRINT '
     C**                   MOVEL'LANPRT50'PRTG
     C**                   ENDIF
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
