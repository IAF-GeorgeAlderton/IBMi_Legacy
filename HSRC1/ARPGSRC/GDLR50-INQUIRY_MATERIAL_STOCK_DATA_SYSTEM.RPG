      *--------------------*
      * WIRE KANBAN MASTER *
      *--------------------*
     C           KEY1      SETGTIZAPL03
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      REDPEIZAPL031                 10
      *
     C           *IN10     IFEQ '0'
     C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ELSE
     C           ZCUKHZ    IFLE *DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     Z-ADDZCKMMX    ISMAI
     C                     MOVELZCTKRO    ITKRO
     C                     GOTO JUMP
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
