     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY2      READEGDLPL12                  20
     C           *IN20     IFEQ '0'
     C           LBSKJY    IFEQ 'D'
     C           LBSKHZ    ANDLE*DATE
     C                     ELSE
     C           A         IFLE 3
     C           A         ANDGT0
     C                     MOVELLBPTCD    PCD,A
     C                     MOVELLBODER    ODR,A
     C                     MOVELLBITEM    ITM,A
     C                     Z-ADDLBMAIS    COL,A
     C                     Z-ADD0         MINO    30
     C                     EXSR SUB1
     C           LBMAIS    SUB  REMA      MINO
     C                     Z-ADDMINO      MNO,A
     C                     Z-ADDLBSPHZ    SHZ,A
     C                     Z-ADDLBREHZ    AHZ,A
     C           LBREHZ    IFNE 0
     C           LBKAHZ    IFEQ 0
     C           LBREHZ    IFLE *DATE
     C                     MOVEL'1'       *IN,H
     C                     END
     C                     END
     C                     END
     C           A         IFEQ 3
     C                     MOVELLBODR1    ZODR1
     C                     MOVELLBODR2    ZODR2
     C                     MOVELLBODR3    ZODR3
     C                     MOVELLBITEM    ZITEM
     C                     END
     C                     END
     C                     ADD  1         A
     C                     ADD  1         H
     C                     END
     C                     END
     C  N20                ENDDO
