     C                     SETOF                     15
     C           KEY3      CHAINGDLPL251             15
      *
     C           *IN15     IFEQ '0'
     C           LDSKJY    IFEQ 'D'
     C           LDSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDLDSTCK    ISIKA
     C                     END
     C                     END
      *
     C           IJITU     IFGE 0
     C           IJITU     ADD  ISIKA     IRMAI
     C                     ELSE
     C                     Z-ADDISIKA     IRMAI
     C                     END
     C           IRMAI     SUB  ISMAI     IRESU
      *
     C           IRESU     IFLT 0
     C                     MOVEL'LESS'    IJUDG
     C                     END
      *
     C           IRESU     IFGT 0
     C                     MOVEL'MORE'    IJUDG
     C                     END
