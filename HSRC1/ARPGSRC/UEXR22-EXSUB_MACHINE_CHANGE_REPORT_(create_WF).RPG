      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * READ ABHPP01
     C                     EXSR #ABH
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * ABHPP01
      *======================================================
     C           #ABH      BEGSR
     C                     MOVEL'ABHPP01 'XFILE   8
     C                     Z-ADD111       K#ABH   40
     C                     MOVE 'Y'       FIRST   1
      *
     C           K#ABH     SETLLABHPL02
      *
     C                     DO   *HIVAL
     C           K#ABH     READEABHPL02                  98
     C   98                LEAVE
      *
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELM6SHIN    SVSHIN
     C                     MOVELM6LOC     SVLOC
     C                     MOVELM6KBN     SVKBN
     C                     ENDIF
      * BRAEK?
     C           M6SHIN    IFNE SVSHIN
     C           M6LOC     ORNE SVLOC
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     ADD  1         SEQ#    40
     C           SEQ#      IFGE 2
     C           M6KBN     ANDNESVKBN
     C           M6UKHZ    ANDGE20181100
      * BEFORE
     C                     MOVEL'C'       U2SKJY
     C                     MOVELXFILE     U2FILE
     C                     Z-ADDM6UKHZ    U2EFHZ
     C                     MOVELM6SHIN    U2SHIN
     C                     MOVELM6LOC     U2LOC
     C                     MOVELSVKBN     U2MCN
     C                     WRITEUEXWP221
      * AFTER
     C                     MOVEL'N'       U2SKJY
     C                     MOVELXFILE     U2FILE
     C                     Z-ADDM6UKHZ    U2EFHZ
     C                     MOVELM6SHIN    U2SHIN
     C                     MOVELM6LOC     U2LOC
     C                     MOVELM6KBN     U2MCN
     C                     WRITEUEXWP221
     C                     ENDIF
     C                     MOVELM6KBN     SVKBN
      *
     C                     ENDDO
      *
     C                     MOVELM6KBN     U2MCN
     C                     ENDSR
      *======================================================
      * BREAK
      *======================================================
     C           #BRK1     BEGSR
      *
     C                     MOVELM6SHIN    SVSHIN
     C                     MOVELM6LOC     SVLOC
     C                     MOVELM6KBN     SVKBN
     C                     Z-ADD0         SEQ#
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C                     MOVE *BLANK    SVSHIN 12
     C                     MOVE *BLANK    SVLOC   6
     C                     MOVE *BLANK    SVKBN  15
     C                     Z-ADD0         SEQ#
      *
     C                     ENDSR
