      *
     C                     Z-ADD1         X
     C           BADAT     LOKUPDAT,X                    10
     C                     Z-ADD*ZERO     WWQTY   70
     C                     MOVE BANONY    @@NONY
     C                     MOVE BANOBN    K@NOBN
     C                     MOVELBAODRN    @@ODRN    P
     C           K#AP70    SETLLAB#PL70
B2   C           *IN82     DOUEQ*ON
     C           K#AP70    READEAB#PL70                  82
B3   C           *IN82     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKHENK    ANDEQ*BLANK
     C                     ADD  EKSRYO    WWQTY
      *
E3   C                     ENDIF
E2   C                     ENDDO
      *
B2   C           WWQTY     IFEQ *ZERO
     C                     MOVELBAINVN    @@ODRN    P
     C           K#AP70    SETLLAB#PL70
B3   C           *IN82     DOUEQ*ON
     C           K#AP70    READEAB#PL70                  82
B4   C           *IN82     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKHENK    ANDEQ*BLANK
     C                     ADD  EKSRYO    WWQTY
E4   C                     ENDIF
E3   C                     ENDDO
E2   C                     ENDIF
      *
TCHX C                     MOVE BANONY    DEL,X
TCHX C                     ADD  BASRYO    QT1,X
B2   C           WWQTY     IFLT BASRYO
     C           BASRYO    SUB  WWQTY     @@BAL   90
TCHX C                     ADD  @@BAL     QT2,X
E2   C                     ENDIF
E1   C                     ENDIF
E0   C                     ENDDO
      *
      * LOAD
     C                     Z-ADD1         T       10
     C           1         DO   8         S       10
     C           T         IFGT 4
     C                     LEAVE
     C                     ENDIF
TCHX C           QT2,S     IFNE 0
     C                     Z-ADDDT6,S     @SHP,T
     C                     MOVE DEL,S     @DEL,T
     C           T         IFEQ 1
     C           @DEL,T    ANDNE'0000'
     C                     MOVE '1'       *IN71
     C                     ENDIF
     C           T         IFEQ 2
     C           @DEL,T    ANDNE'0000'
     C                     MOVE '1'       *IN72
     C                     ENDIF
     C           T         IFEQ 3
     C           @DEL,T    ANDNE'0000'
     C                     MOVE '1'       *IN73
     C                     ENDIF
     C           T         IFEQ 4
     C           @DEL,T    ANDNE'0000'
     C                     MOVE '1'       *IN74
     C                     ENDIF
     C           1         ADD  T         T
TCHX C                     ENDIF
     C                     ENDDO
      *SAVE BACK
TCH51C                     ENDSR
