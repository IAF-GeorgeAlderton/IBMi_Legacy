     C                     MOVE 'A'       MFSIDE
     C                     MOVELMAN       R1MFBC
     C                     EXSR #MANI
     C                     WRITEAM#PP011
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB710    BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           KKSHID  8
     C                     KFLD           KKSHIT  6
     C                     KFLD           KKSURT  9
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKORD# 12
     C                     KFLD           KKPALT  2
      *2Dかんばんよりセット
     C                     MOVELSHDT      KKSHID  8
     C                     MOVELSHTM      KKSHIT  6
     C                     MOVELSUBR      KKSURT  9
     C                     Z-ADD0         KKNONY  40
     C                     MOVEL*BLANK    KKNKOJ  1
     C                     MOVEL*BLANK    KKNUKE  4
     C           DEST      CHAINAL#PP211             26
     C           *IN26     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
     C           *IN26     IFEQ '0'
     C                     MOVELC2NONY    KKNONY
     C                     MOVELC2NKOJ    KKNKOJ
     C                     MOVELC2TOKU    K@TOKU  40
     C                     ENDIF
     C                     MOVELDCCOD     KKNUKE
     C                     MOVELORNO      KKORD# 12
     C                     MOVELPALT      KKPALT  2
      * GET : 0 NO DATA
      *     : 1 GET DATA
      *     : 2 ALREADY SCANNING
      *     : 3 PALLET# ERR
     C                     MOVEL*BLANK    WKIAFB  3
     C                     MOVEL*BLANK    WKIAFP  3
     C                     MOVEL*BLANK    WKSHME 20
     C                     MOVEL'0'       GET     1
     C                     TIME           WTIME
     C           KEY01     SETLLAL#PL031
     C           KEY01     READEAL#PL031            N    80
     C           *IN80     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAMHN     IFEQ PART
     C           CABOX#    ANDEQBXNBR
     C                     MOVELCAIAFB    WKIAFB
     C                     MOVELCAIAFP    WKIAFP
     C                     MOVELCASHME    WKSHME
      *品番、ボックス＃が同じときＩＡＦ便＃とパレット＃
     C           CAIAFB    IFEQ TIIAFB
     C           CAIAFP    ANDEQTIIAFP
     C           CAPLDT    IFEQ 0
     C                     MOVEL'1'       GET
     C****                 Z-ADDSDATE     CAPLDT
     C****                 Z-ADDSTIME     CAPLTI
     C****                 UPDATAL#PL031
     C                     ELSE
     C                     MOVEL'2'       GET
     C                     ENDIF
     C                     ELSE
     C                     MOVEL'3'       GET
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C           KEY01     READEAL#PL031            N    80
     C                     ENDDO
      *
     C                     SELEC
     C           GET       WHEQ '1'
     C           GET       WHEQ '0'
     C                     SETON                     3199
     C                     MOVELER,4      MSG
     C           GET       WHEQ '2'
     C****                 MOVEL'NG'      WKHNTE  2
     C                     SETON                     3199
     C                     MOVELER,5      MSG
     C           GET       WHEQ '3'
     C                     MOVEL'NG'      WKHNTE  2
     C                     SETON                     3199
     C                     MOVELER,6      MSG
     C                     ENDSL
      *
     C           *IN99     IFEQ '0'
     C                     EXSR #SB720
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB720    BEGSR
      *
     C           K#65      KLIST
     C                     KFLD           K@DEST  5
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@ORNO 12
     C                     KFLD           K@KANO  4
     C                     KFLD           K@BOXN  4
