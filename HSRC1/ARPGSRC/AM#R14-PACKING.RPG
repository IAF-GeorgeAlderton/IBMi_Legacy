     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    PCMD    2
     C                     MOVELWORKER    USRCD   6
     C                     CLEARB2D
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     IFEQ '02'
     C                     EXSR #SB215
     C                     ENDIF
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *パレットチケット                                  *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      PCMD    2
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN09     IFEQ *ON
     C                     CALL 'AM#R16'
     C                     PARM           WORKER
     C                     PARM           WUSRID
      *
     C                     CLEARB2D
     C                     Z-ADD*ZERO     D1SUMI
     C                     Z-ADD*ZERO     D1TOTL
     C                     Z-ADD*ZERO     D2SUMI
     C                     Z-ADD*ZERO     D2TOTL
     C                     MOVE *BLANKS   D2IAFB
     C                     MOVE *BLANKS   D2IAFP
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           B2D       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     GOTO ESB210
     C                     ENDIF
      *
      *総箱数と読取済み箱数
     C                     MOVELB2D       TICKET
     C                     EXSR #SB920
     C                     MOVE 'BIN'     D1BIN
     C                     MOVELTIIAFB    D1IAFB
     C                     MOVEL'PALLET#' D1PLT#
     C                     MOVELTIIAFP    D1IAFP
     C                     Z-ADDP2SUMI    D1SUMI
     C                     MOVEL'/'       D1SRSH
     C                     Z-ADDP2TOTL    D1TOTL
     C           P2TOTL    IFEQ 0
     C                     SETON                     3199
     C                     MOVELER,7      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARB2D
     C                     GOTO ESB210
     C                     ENDIF
     C           P2TOTL    IFEQ P2SUMI
     C                     SETON                     3199
     C                     MOVELER,3      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARB2D
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVELTIIAFB    D2IAFB
     C                     MOVELTIIAFP    D2IAFP
     C                     Z-ADDP2SUMI    D2SUMI
     C                     Z-ADDP2TOTL    D2TOTL
     C                     MOVEL'02'      DSPSW   2
     C                     CLEARD2R
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *窞�黬�砑ⓓ�樴灎獐�橑柷　　　　　　　　　　　　�
      *----------------------------------------------------*
     CSR         #SB215    BEGSR
      *
     C                     CLEARMAN
     C                     MOVE 'N'       DONE    1
     C           DONE      DOWEQ'N'
      *
     C                     EXFMTDSP04
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     99
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'01'      DSPSW
     C                     Z-ADD*ZERO     D1SUMI
     C                     Z-ADD*ZERO     D1TOTL
     C                     Z-ADD*ZERO     D2SUMI
     C                     Z-ADD*ZERO     D2TOTL
     C                     MOVE *BLANKS   D2IAFB
     C                     MOVE *BLANKS   D2IAFP
     C                     CLEARB2D
     C                     CLEARMAN
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELMAN       MF
      *
     C           MAN       IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,9      MSG
     C                     EXSR #SB999
     C                     SETOF                     99
     C                     MOVE *BLANKS   MSG
     C                     CLEARMAN
     C                     ITER
     C                     ENDIF
      *
     C           MFSKID    IFEQ *BLANKS
     C                     SETON                     99
     C                     MOVELER,14     MSG
     C                     EXSR #SB999
     C                     SETOF                     99
     C                     MOVE *BLANKS   MSG
     C                     CLEARMAN
     C                     ITER
     C                     ENDIF
      *
      * use Destination code to get delivery code from M/F.
     C                     Z-ADD*ZERO     C2NONY
     C           MFNAMC    CHAINAL#PP211             51
     C           *IN51     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     Z-ADD*ZERO     C2NONY
     C                     ENDIF
      *
     C                     MOVELC2NONY    MFNONY  4
      *
      * if Manifest info doesn't match Pallet Ticket info, display error.
     C           MFDOCK    IFNE TIDOCK
     C           MFORD#    ORNE TIORD#
     C           MFPALT    ORNE TIPALT
     C           MFNONY    ORNE TINONY
     C                     SETON                     99
     C                     MOVELER,10     MSG
     C                     EXSR #SB999
     C                     SETOF                     99
     C                     MOVE *BLANKS   MSG
     C                     CLEARMAN
     C                     ITER
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE 'Y'       DONE
     C                     ENDIF
      *
     C                     ENDDO
      *
     CSR         ESB215    ENDSR
      *----------------------------------------------------*
      *ユーザーかんばん                                  *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTDSP02
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     CLEARB2D
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD*ZERO     D1SUMI
     C                     Z-ADD*ZERO     D1TOTL
     C                     Z-ADD*ZERO     D2SUMI
     C                     Z-ADD*ZERO     D2TOTL
     C                     MOVE *BLANKS   D2IAFB
     C                     MOVE *BLANKS   D2IAFP
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D2R       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKHNTE  2
     C                     MOVELD2R       W2D
      *
      * check container namc code (dest) to make sure it matches...
     C           DEST      IFNE MFNAMC
     C                     SETON                     3199
     C                     MOVELER,12     MSG
     C                     ENDIF
      *
      * check container ship date (shdt) to make sure it matches...
     C           SHDT      IFNE TISHID
     C                     SETON                     3199
     C                     MOVELER,13     MSG
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     EXSR #SB710
     C                     ENDIF
      *
     C           *IN99     IFEQ '1'
     C                     EXSR #SB229
     C                     ELSE
     C                     MOVEL'OK'      WKHNTE  2
     C                     TIME           WTIME
     C                     MOVEL*BLANK    MSG
     C                     EXSR #SB500
     C                     EXSR #SB750
     C                     CLEARD2R
     C                     EXSR #SB920
     C                     Z-ADDP2SUMI    D1SUMI
     C                     Z-ADDP2TOTL    D1TOTL
     C                     Z-ADDP2SUMI    D2SUMI
     C                     Z-ADDP2TOTL    D2TOTL
      *
      * if all containers have been scanned to this pallet
      *    display OK, blank out totals, go back to display 1 - pallet ticket
     C           D2SUMI    IFEQ D2TOTL
     C                     SETON                     3199
     C                     MOVELER,3      MSG
      *
     C                     CALL 'AM#R413'
     C                     PARM           R1MFBC
     C                     PARM           USRCD
      *
     C                     EXFMTDSP03
     C                     SETOF                     3199
     C                     MOVE *BLANKS   MSG
     C                     Z-ADD*ZERO     D1SUMI
     C                     Z-ADD*ZERO     D1TOTL
     C                     Z-ADD*ZERO     D2SUMI
     C                     Z-ADD*ZERO     D2TOTL
     C                     MOVE *BLANKS   D2IAFB
     C                     MOVE *BLANKS   D2IAFP
     C                     MOVEL'01'      DSPSW   2
     C                     CLEARB2D
     C                     CLEARMAN
     C                     ENDIF
      *
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * ERR                                                *
      *----------------------------------------------------*
     CSR         #SB229    BEGSR
      *
     C           WKHNTE    IFEQ 'NG'
     C                     TIME           WTIME
     C                     EXSR #SB500
     C                     Z-ADD3         P1PGM
     C                     MOVELMSG       P1ERR
     C                     MOVELW#PGM     P1PID
     C                     MOVELWORKER    P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'                   LOCK
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
     C                     ELSE
     C                     EXSR #SB999
     C                     ENDIF
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     CLEARD2R
      *
     CSR         ESB229    ENDSR
