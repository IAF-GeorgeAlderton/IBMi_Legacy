      *
     CSR         ESB999    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * AM#PP01                                            *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAM#PP011
     C                     Z-ADDSDATE     R1KOHZ
     C                     Z-ADDSTIME     R1KOTI
     C                     MOVELWORKER    R1KOME
     C                     MOVELW#PGM     R1KPGM
     C                     Z-ADDSDATE     R1SSHZ
     C                     Z-ADDSTIME     R1SSTI
     C                     MOVELWORKER    R1USCD
     C                     MOVEL*BLANK    R1USNM
     C                     MOVELWKHNTE    R1HNTE
     C                     MOVELMSG       R1ERR
     C                     MOVELTICKET    R1TICK
     C                     MOVELTISURT    R1SURT
     C                     MOVELTISHID    R1SHID
     C                     MOVELTISHIT    R1SHIT
     C                     MOVELTISMEI    R1SMEI
     C                     MOVELTIDOCK    R1DOCK
