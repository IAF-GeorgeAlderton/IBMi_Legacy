     C                     SETON                     3199
     C                     MOVELER,8      MSG
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     EXSR #SB725
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     EXSR #SB728
     C                     ENDIF
      *
     CSR         ESB720    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB750    BEGSR
      *2Dかんばんよりセット
     C                     MOVELSHDT      KKSHID  8
     C                     MOVELSHTM      KKSHIT  6
     C                     MOVELSUBR      KKSURT  9
     C                     Z-ADD0         KKNONY  40
     C                     MOVEL*BLANK    KKNKOJ  1
     C                     MOVEL*BLANK    KKNUKE  4
     C           DEST      CHAINAL#PP211             26
     C           *IN26     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
     C           *IN26     IFEQ '0'
     C                     MOVELC2NONY    KKNONY
     C                     MOVELC2NKOJ    KKNKOJ
     C                     ENDIF
     C                     MOVELDCCOD     KKNUKE
     C                     MOVELORNO      KKORD# 12
     C                     MOVELPALT      KKPALT  2
      * GET : 0 NO DATA
      *     : 1 GET DATA
      *     : 2 ALREADY SCANNING
      *     : 3 PALLET# ERR
     C                     MOVEL'0'       GET     1
     C           KEY01     SETLLAL#PL031
     C           KEY01     READEAL#PL031                 80
     C           *IN80     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAMHN     IFEQ PART
     C           CABOX#    ANDEQBXNBR
      *品番、ボックス＃が同じときＩＡＦ便＃とパレット＃
     C           CAIAFB    IFEQ TIIAFB
