     C                     MOVELCALIAD    W7LIAD
     C                     MOVELCASTAD    W7STAD
     C                     MOVELCAQTBO    W7QTBO
     C                     MOVELCASUPN    W7SUPN
     C                     MOVELCAMART    W7MART
     C                     MOVELCASURT    W7SURT
     C                     MOVELCAULDA    W7ULDA
     C                     MOVELCASHID    W7SHID
     C                     MOVELCASHIT    W7SHIT
     C                     MOVELCAORD#    W7ORD#
     C                     MOVELCABOX#    W7BOX#
     C                     MOVELCABOXT    W7BOXT
     C                     MOVELCANAMC    W7NAMC
     C                     MOVELCAINKK    W7INKK
     C                     MOVELCALPOS    W7LPOS
     C                     MOVELCANAM2    W7NAM2
     C                     MOVELCANAM3    W7NAM3
     C                     MOVELCAPALT    W7PALT
     C                     MOVELCANAD5    W7NAD5
     C                     MOVELCANAD6    W7NAD6
     C                     MOVELCAFILL    W7FILL
     C                     MOVELCATERM    W7TERM
     C                     MOVELW1SHN1    W7SHN1
     C                     MOVELW1SHN2    W7SHN2
     C                     MOVELW1SHN3    W7SHN3
     C                     MOVELW1TKR1    W7TKR1
     C                     MOVELW1TKR2    W7TKR2
     C                     MOVELW1TKR3    W7TKR3
     C                     MOVELW1TKR4    W7TKR4
     C                     WRITEAL#WP771
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  AL#WP71
      *-----------------------------------------------------
     CSR         #SB700    BEGSR
      *社内品番
     C                     MOVELCATOKU    PTOKU
     C                     MOVELCANONY    PNONY
     C                     MOVELCANKOJ    PNKOJ
     C                     MOVELCANUKE    PNUKE
     C                     MOVEL*BLANK    @MHIN
     C                     MOVELCAMHN     @MHIN
     C                     MOVEL*BLANK    @SHIN
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
     C           KEYFCE    KLIST
     C                     KFLD           KKSHN1  5
     C                     KFLD           KKSHN2  5
     C                     KFLD           KKSHN3  2
     C                     MOVEL@SHN1     W1SHN1
     C                     MOVEL@SHN2     W1SHN2
     C                     MOVEL@SHN3     W1SHN3
     C                     MOVEL@SHN1     KKSHN1
     C                     MOVEL@SHN2     KKSHN2
     C                     MOVEL@SHN3     KKSHN3
     C           KEYFCE    CHAINFCEPL011             46
     C           *IN46     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLESDATE
     C                     ELSE
     C           A2SY      IFLE SDATE
     C                     MOVELA2SSYT    W1SYOT
     C                     ELSE
     C                     MOVELA2KSYT    W1SYOT
     C                     ENDIF
     C           A2TR      IFLE SDATE
     C                     MOVELA2STRK    W1TKR1
     C                     MOVELA2STRT    W1TKR2
     C                     MOVELA2STRR    W1TKR3
     C                     MOVELA2STRD    W1TKR4
     C                     ELSE
     C                     MOVELA2KTRK    W1TKR1
     C                     MOVELA2KTRT    W1TKR2
     C                     MOVELA2KTRR    W1TKR3
     C                     MOVELA2KTRD    W1TKR4
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB700    ENDSR
