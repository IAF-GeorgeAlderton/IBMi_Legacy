     C                     MOVELCANAM2    W1NAM2
     C                     MOVELCANAM3    W1NAM3
     C                     MOVELCAPALT    W1PALT
     C                     MOVELCANAD5    W1NAD5
     C                     MOVELCANAD6    W1NAD6
      *
     C                     Z-ADD0         W1SEQ#
     C                     MOVELCAIAFB    W1IAFB
     C                     MOVELCAIAFP    W1IAFP
     C           CAKADT    IFEQ 0
     C                     EXSR #SB700
     C                     ELSE
     C                     MOVELCASHN1    W1SHN1
     C                     MOVELCASHN2    W1SHN2
     C                     MOVELCASHN3    W1SHN3
     C                     MOVELCASYOT    W1SYOT
     C                     MOVELCATKR1    W1TKR1
     C                     MOVELCATKR2    W1TKR2
     C                     MOVELCATKR3    W1TKR3
     C                     MOVELCATKR4    W1TKR4
     C                     ENDIF
     C                     Z-ADDCATOKU    W1TOKU
     C                     Z-ADDCANONY    W1NONY
     C                     MOVELCANKOJ    W1NKOJ
     C                     MOVELCANUKE    W1NUKE
     C                     Z-ADDCAFIXD    W1FIXD
     C                     Z-ADDCAFIXT    W1FIXT
     C                     Z-ADDCATIMS    W1TIMS
     C                     Z-ADDCAEXTR    W1EXTR
     C                     MOVELCAPPUL    W1PPUL
     C           CAEXTR    IFEQ 0
     C                     MOVEL*BLANK    W1EXT
     C                     ELSE
     C                     MOVEL'1'       W1EXT
     C                     ENDIF
     C                     MOVELCASAT     W1SAT
      * PALLET PULLING品番
     C                     EXSR #SB390
      * SORT KEY
     C                     MOVEL*BLANK    W1#K01
     C                     MOVEL*BLANK    W1#K02
     C                     MOVEL*BLANK    W1#K03
     C                     MOVEL*BLANK    W1#K04
     C                     MOVEL*BLANK    W1#K05
     C                     MOVEL*BLANK    W1#K06
      * PALLET PULLING
     C                     MOVEL'2'       W1#K01
     C                     MOVEL*BLANK    W1#K02
     C           CAPPUL    IFEQ '1'
     C                     MOVEL'1'       W1#K01
     C                     MOVELCAIAFP    W1#K02
     C                     ENDIF
      *通路優先順
     C                     MOVELW1TKR2    P1BLK
     C                     Z-ADD0         P9SORT
     C                     MOVEL*BLANK    P9SITE
     C                     MOVEL*BLANK    P9SECT
     C                     CALL 'AL#R69'
     C                     PARM           P1BLK   2
     C                     PARM           P9SORT  50
     C                     PARM           P9SITE  1
     C                     PARM           P9SECT  2
     C                     MOVELP9SORT    W1#K03
     C                     MOVELP9SECT    W1SECT
     C           CAPPUL    IFEQ *BLANK
     C                     MOVEL*BLANK    W1#K02
     C                     MOVEL*BLANK    W1#K03
     C                     MOVEL*BLANK    W1#K04
     C*******              MOVELW1NAMC    W1#K02
     C                     MOVELP9SECT    W1#K03
     C                     MOVELP9SORT    W1#K04
     C                     ENDIF
      *列　昇順降順
     C                     MOVE W1TKR3    A       20
     C                     SELEC
     C           P9SITE    WHEQ '1'
     C                     MOVELW1TKR3    W1#K05           昇順
     C                     MOVELW1TKR2    W1#K06
     C           P9SITE    WHEQ '2'
     C           100       SUB  A         A                降順
     C                     MOVELA         W1#K05
     C                     MOVELW1TKR2    W1#K06
     C                     OTHER                           マスターなし
     C           WKPPUL    IFEQ '0'
     C                     MOVEL'0'       W1#K01
     C                     ENDIF
     C                     MOVELW1TKR2    W1#K04           通路昇順
     C                     MOVELW1TKR3    W1#K05           列昇順
     C                     ENDSL
      *
     C                     MOVEL'0'       W1FLG
      *
     C           KEYW46    KLIST
