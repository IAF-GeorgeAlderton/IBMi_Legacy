     C                     KFLD           W1SHID
     C                     KFLD           W1SHIT
     C                     KFLD           W1IAFB
     C                     KFLD           W1IAFP
     C           KEYW46    CHAINAL#WP46              96
     C           *IN96     IFEQ '0'
     C                     MOVELW6ZONE    W1ZONE
     C                     ELSE
     C                     ENDIF
      *
     C                     WRITEAL#WP711
      *ＷＥＢの番地とＡＳの番地チェック
     C****       CALOC1    IFEQ W1TKR1
     C           CALOC2    IFEQ W1TKR2
     C           CALOC3    ANDEQW1TKR3
     C****       CALOC4    ANDEQW1TKR4
