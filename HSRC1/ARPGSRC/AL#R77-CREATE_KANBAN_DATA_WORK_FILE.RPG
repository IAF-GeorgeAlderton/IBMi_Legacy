      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P7FIXD  80
     C                     PARM           P7FIXT  60
     C                     PARM           P7TRKB  2
     C                     PARM           P7IAFB  3
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     EXSR #SB400
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PP01
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           P7FIXD
     C                     KFLD           P7FIXT
     C                     KFLD           P7TRKB
     C                     KFLD           P7IAFB
      *
     C           KEYC1     SETLLAL#PL051
     C           KEYC1     READEAL#PL051                 81
     C           *IN81     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB500
     C           CAKADT    IFEQ 0
     C                     Z-ADDSDATE     CAKOHZ
     C                     Z-ADDSTIME     CAKOTI
     C                     MOVELW#USER    CAKOME
     C                     Z-ADDSDATE     CAKADT
     C                     Z-ADDSTIME     CAKATI
     C                     MOVELW1SHN1    CASHN1
     C                     MOVELW1SHN2    CASHN2
     C                     MOVELW1SHN3    CASHN3
     C                     MOVELW1SYOT    CASYOT
     C                     MOVELW1TKR1    CATKR1
     C                     MOVELW1TKR2    CATKR2
     C                     MOVELW1TKR3    CATKR3
     C                     MOVELW1TKR4    CATKR4
     C                     EXSR #SB401
     C                     ENDIF
     C                     UPDATAL#PL051
     C                     ENDIF
     C           KEYC1     READEAL#PL051                 81
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *仕切りのバーコード（未納票）
      *-----------------------------------------------------
     CSR         #SB401    BEGSR
      *
     C                     MOVE CAFIXD    BAFIXD
     C                     MOVE CATIMS    BATIMS
     C                     MOVE CAIAFB    BAIAFB
     C           CAEXTR    IFEQ 0
     C                     MOVE 'A'       BAEXT
     C                     ELSE
     C                     MOVE '1'       BAEXT
     C                     ENDIF
     C                     MOVE CAEXTR    BAPP
     C                     MOVEL*BLANK    WKCD
     C                     MOVELWKCONT    PMAREA
     C                     MOVEL'016'     PMBYTE
     C                     MOVEL*BLANK    PMCHK
     C                     MOVEL*BLANK    PMRTCD
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        *フィールド
     C                     PARM           PMBYTE  3        *有効桁数
     C                     PARM           PMCHK   1        * kｩｮhmﾞﾆﾞｮn
     C                     PARM           PMRTCD  1        * ﾒjｰ]ﾃｰnﾞ
     C                     MOVELPMCHK     WKCD
     C                     MOVELWKBAR     CASHME
      *
     CSR         ESB401    ENDSR
      *-----------------------------------------------------
      *  AL#WP71
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#WP711
     C                     MOVELCACADT    W1CADT
     C                     MOVELCASUPI    W1SUPI
     C                     MOVELCASUPC    W1SUPC
     C                     MOVELCADOCK    W1DOCK
     C                     MOVELCAKNB#    W1KNB#
     C                     MOVELCAMHN     W1MHN
     C                     MOVELCALIAD    W1LIAD
     C                     MOVELCASTAD    W1STAD
     C                     MOVELCAQTBO    W1QTBO
     C                     MOVELCASUPN    W1SUPN
     C                     MOVELCAMART    W1MART
     C                     MOVELCASURT    W1SURT
     C                     MOVELCAULDA    W1ULDA
     C                     MOVELCASHID    W1SHID
     C                     MOVELCASHIT    W1SHIT
     C                     MOVELCAORD#    W1ORD#
     C                     MOVELCABOX#    W1BOX#
     C                     MOVELCABOXT    W1BOXT
     C                     MOVELCANAMC    W1NAMC
     C                     MOVELCAINKK    W1INKK
