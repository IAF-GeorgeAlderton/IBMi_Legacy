      *
     C           WKYM      IFEQ WUKYM
     C           A         IFLE WSSDDD
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     MOVE @HOL,A    WHOL
     C           WHH1      IFEQ '*'
     C                     MOVE '1'       *IN,N
     C                     END
     C           WHH23     IFEQ *BLANK
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C           WKYM      IFLT WUKYM
     C           @KOKU     OREQ '3'
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     ENDSR
     C*-----------------------------------*
     C*   KANBAN OF MINUS ADJUSTMENT      *
     C*-----------------------------------*
     C           #SB001    BEGSR
      *
     C                     Z-ADD0         @MAIS   30
     C                     SETOF                     75
     C           KEY1      CHAINGTCPP411             75
     C           *IN75     IFEQ '0'
     C           G4SKJY    IFEQ 'D'
     C           G4SKHZ    ANDLEWSSDAT
     C                     ELSE
     C                     Z-ADDG4MAIS    @MAIS
     C                     END
     C                     END
      *
     C           ESB001    ENDSR
