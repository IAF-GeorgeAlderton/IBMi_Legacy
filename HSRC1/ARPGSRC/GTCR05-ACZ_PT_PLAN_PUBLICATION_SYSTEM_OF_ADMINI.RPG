      *
     C           *IN03     IFEQ '0'
      *収容数
     C           M1SYHZ    IFGT WSSDAT
     C                     Z-ADDM1KSYS    WSYOS
     C                     ELSE
     C                     Z-ADDM1SSYS    WSYOS
     C                     END
     C                     ELSE
