      *平準化ファイルにあればエラー *
      *-------------------------------*
TCHK1C*          KEY1      CHAINAGAPL311             90
TCHK1C*          *IN90     IFEQ '0'
TCHK1C*          CBSKJY    ANDEQ'D'
TCHK1C*                    SETON                     90
TCHK1C*                    END
TCHK1C*          *IN90     IFEQ '0'
TCHK1C*                    SETON                     0399
TCHK1C*                    MOVELER,10     MSG
TCHK1C*                    GOTO STP2
TCHK1C*                    END
