      *部品マスター／品番チェック*
      *----------------------------*
     C                     Z-ADD0         WSYOS   60
      *
     C                     SETOF                     03
     C           KEY1      CHAINFCEPL011             03
     C           *IN03     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLEWSSDAT
