     C                     SETOF                     010203
     C                     SETOF                     04
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *---------------------*
      *  CHECK OF PARTS NO  *
      *---------------------*
     C           HIN       IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     ENDIF
      *-----------------*
      *  CHECK OF DATE  *
      *-----------------*
     C           BEHZ      IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           YY        IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           MM        IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           MM        IFGT 12
     C                     SETON                     0399
     C                     MOVE ER,10     MSG
     C                     GOTO STP1
     C                     ENDIF
     C           DD        IFEQ 0
     C                     SETON                     0499
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           DD        IFGT 31
     C                     SETON                     0499
     C                     MOVE ER,11     MSG
     C                     GOTO STP1
     C                     ENDIF
