     H            Y.
      ** AB#R1A *******************************************
      * MONTHLY SHIP QTY                                  *
      *                                                   *
      ******************************************* AB#R1A **
     FAB#PL12 IF  E           K        DISK
     FQPRINT  O   F     156            PRINTER
      *----------------------------------------------------------
      *-----------------------------------------------------
      *    MAIN
      *-----------------------------------------------------
     C                     EXSR #WRT
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C           K#KEY     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C           K#GAD     KLIST
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
      *
     C           K#AGX     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
      *
     C                     Z-ADD2002      K@YY
     C                     Z-ADD10        K@MM
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     @TOTQ   90
     C                     Z-ADD*ZERO     @3411   90
     C                     Z-ADD*ZERO     @0541   90
     C                     Z-ADD*ZERO     @3503   90
     C                     Z-ADD*ZERO     @3504   90
     C                     Z-ADD*ZERO     @3804   90
     C                     Z-ADD*ZERO     @3805   90
     C                     Z-ADD*ZERO     @3347   90
     C                     Z-ADD*ZERO     @3348   90
     C                     Z-ADD*ZERO     @3765   90
     C                     Z-ADD*ZERO     @3931   90
     C                     Z-ADD*ZERO     @3932   90
     C                     Z-ADD*ZERO     @3560   90
     C                     Z-ADD*ZERO     @3554   90
     C                     Z-ADD*ZERO     @3555   90
     C                     Z-ADD*ZERO     @3557   90
     C                     Z-ADD*ZERO     @3561   90
     C                     Z-ADD*ZERO     @0323   90
     C           K#KEY     SETLLAB#PL12
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAB#PL12                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C           BAUSYS    IFNE *ZERO
     C           BASYOS    ANDNE*ZERO
     C           BAUSYS    ANDNEBASYOS
     C                     ITER
     C                     ENDIF
      *
     C           BASYOS    IFEQ *ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDBANODD    @D      20
     C                     Z-ADD*ZERO     @@QTY   70
     C           BAUSYS    IFNE *ZERO
     C           BASRYO    DIV  BAUSYS    @@QTY   70
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@QTY   70
     C                     ENDIF
     C                     ENDIF
     C                     ADD  @@QTY     @TOTQ
      *
     C           BATOKU    IFEQ 3411
     C                     ADD  @@QTY     @3411
     C                     ENDIF
     C           BATOKU    IFEQ 0541
     C                     ADD  @@QTY     @0541
     C                     ENDIF
      *
     C           BANONY    IFEQ 3503
     C                     ADD  @@QTY     @3503
     C                     ENDIF
     C           BANONY    IFEQ 3504
     C                     ADD  @@QTY     @3503
     C                     ENDIF
     C           BANONY    IFEQ 3804
     C                     ADD  @@QTY     @3804
     C                     ENDIF
     C           BANONY    IFEQ 3805
     C                     ADD  @@QTY     @3804
     C                     ENDIF
     C           BANONY    IFEQ 3347
     C                     ADD  @@QTY     @3347
     C                     ENDIF
     C           BANONY    IFEQ 3348
     C                     ADD  @@QTY     @3347
     C                     ENDIF
     C           BANONY    IFEQ 3765
     C                     ADD  @@QTY     @3765
     C                     ENDIF
     C           BANONY    IFEQ 3931
     C                     ADD  @@QTY     @3931
     C                     ENDIF
     C           BANONY    IFEQ 3932
     C                     ADD  @@QTY     @3931
     C                     ENDIF
     C           BANONY    IFEQ 3560
     C                     ADD  @@QTY     @3560
     C                     ENDIF
     C           BANONY    IFEQ 3554
     C                     ADD  @@QTY     @3554
     C                     ENDIF
     C           BANONY    IFEQ 3555
     C                     ADD  @@QTY     @3555
     C                     ENDIF
     C           BANONY    IFEQ 3557
     C                     ADD  @@QTY     @3557
     C                     ENDIF
     C           BANONY    IFEQ 3561
     C                     ADD  @@QTY     @3561
     C                     ENDIF
     C           BANONY    IFEQ 0323
     C                     ADD  @@QTY     @0323
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #OUT      BEGSR
      *-----------------------------------------------------
     C           @3411     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3411P  52
     C           @0541     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @0541P  52
     C           @3411     ADD  @0541     @@TOY   90
     C           @@TOY     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @TOYOP  52
     C           @3503     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3503P  52
     C           @3504     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3504P  52
     C           @3804     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3804P  52
     C           @3805     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3805P  52
     C           @3347     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3347P  52
     C           @3348     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3348P  52
     C           @3765     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3765P  52
     C           @3931     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3931P  52
     C           @3932     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3932P  52
     C           @3560     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3560P  52
     C           @3554     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3554P  52
     C           @3555     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3555P  52
     C           @3557     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3557P  52
     C           @3561     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @3561P  52
     C           @0323     DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @0323P  52
      *
     C           @0323     ADD  @3560     @OTHER  90
     C                     ADD  @3554     @OTHER
     C                     ADD  @3555     @OTHER
     C                     ADD  @3557     @OTHER
     C                     ADD  @3561     @OTHER
     C           @OTHER    DIV  @TOTQ     @@PCT   54H
     C           @@PCT     MULT 100       @OTHRP  52
      *
     C                     EXCPT@OUT
      *
     C                     ENDSR
      *-------------------------------------------------------
     OQPRINT  E   02           @OUT
     O                                   50 '<< SHIPMENT IN OCT >>'
     O        E   04           @OUT
     O                                   11 'TOTAL'
     O                                   29 'TOYOTA+NUMI'
     O                                   44 'TOYOTA'
     O                                   62 'NUMI'
     O                                   80 'TMMC'
     O                                   98 'TMMI'
     O                                  116 'TMMK'
     O                                  134 'TMMWV'
     O                                  152 'OTHER'
     O        E   06           @OUT
     O                         @TOTQ 1   11
     O                         @@TOY 1   22
     O                         @TOYOP1   29
     O                         @3411 1   40
     O                         @3411P1   47
     O                         @0541 1   58
     O                         @0541P1   65
     O                         @3503 1   76
     O                         @3503P1   83
     O                         @3804 1   94
     O                         @3804P1  101
     O                         @3347 1  112
     O                         @3347P1  119
     O                         @3931 1  130
     O                         @3931P1  137
     O                         @OTHER1  148
     O                         @OTHRP1  155
