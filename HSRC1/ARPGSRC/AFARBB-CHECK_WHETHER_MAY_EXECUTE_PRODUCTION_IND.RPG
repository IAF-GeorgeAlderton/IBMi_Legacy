     H            Y.
     F** AFARBB ************************************************
     F* CHECK WHETHER MAY EXECUTE PRODUCTION INDICATION PROGRAM || *.
     F* I-HASADA                                89.02.10       *
     F************************************************ AFARBB **
     FAGDPL12 IF  E           K        DISK
     I            DS
     I                                        1   80UYMD
     I                                        1   40UYY
     I                                        5   60UMM
     I                                        7   80UDD
     C           *ENTRY    PLIST
     C                     PARM           PKB     1
     C                     PARM           PCHK    1
      *
     C           KEY       KLIST
     C                     KFLD           UYY
     C                     KFLD           UMM
     C                     KFLD           UDD
     C                     Z-ADD*DATE     UYMD
     C                     MOVE '0'       PCHK
      *
     C           PKB       IFEQ 'A'
     C                     SETOF                     01
     C           KEY       CHAINAGDPL121             01
     C           *IN01     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C                     MOVE '1'       PCHK
     C                     END
     C                     END
     C                     ELSE
      *
     C           KEY       SETLLAGDPL121
     C                     SETOF                     01
     C                     READPAGDPL121                 01
     C           *IN01     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '1'       PCHK
     C                     END
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
