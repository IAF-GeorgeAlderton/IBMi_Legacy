     F** ADKR4S **************************************
     F*ADKPP4Aに値をセットする                   *
     F*  2024.10.02  T.ASAI                          *
     F************************************************
     FADKPP4A UF  E           K        DISK
      *
     C           OWKKEY    KLIST
     C                     KFLD           KSUKEY 10
      *
     C           *ENTRY    PLIST
     C                     PARM           OWKDAT  80
     C                     PARM           OWKTIM  60
     C                     PARM           OWKUSE 10
     C                     PARM           PPRTKS  52
     C                     PARM           PPRCKS  52
     C                     PARM           PTTLKS  52
      *
     C                     MOVEL'PART#'   KSUKEY    P
     C           OWKKEY    CHAINADKPP4A              60
     C           *IN60     IFEQ '0'
     C                     MOVELOWKDAT    D@KOHZ
     C                     MOVELOWKTIM    D@KOTI
     C                     MOVELOWKUSE    D@KOME
     C                     MOVELPPRTKS    D@KSU
     C                     UPDATADKPP4A1
     C                     ENDIF
      *
     C                     MOVEL'PROCESS' KSUKEY    P
     C           OWKKEY    CHAINADKPP4A              61
     C           *IN61     IFEQ '0'
     C                     MOVELOWKDAT    D@KOHZ
     C                     MOVELOWKTIM    D@KOTI
     C                     MOVELOWKUSE    D@KOME
     C                     MOVELPPRCKS    D@KSU
     C                     UPDATADKPP4A1
     C                     ENDIF
      *
     C                     MOVEL'TOTAL'   KSUKEY    P
     C           OWKKEY    CHAINADKPP4A              62
     C           *IN62     IFEQ '0'
     C                     MOVELOWKDAT    D@KOHZ
     C                     MOVELOWKTIM    D@KOTI
     C                     MOVELOWKUSE    D@KOME
     C                     MOVELPTTLKS    D@KSU
     C                     ENDIF
      *
     C                     UPDATADKPP4A1
      *
     C                     SETON                     LR
     C                     RETRN
      *
