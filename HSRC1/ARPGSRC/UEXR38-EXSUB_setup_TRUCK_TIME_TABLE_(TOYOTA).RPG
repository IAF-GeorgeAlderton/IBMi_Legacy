     H            Y.
      ** UEXR38 **********************************************
      *  TOYOTA - SETIP TRUCK TIME TABLE                     *
      *                                                      *
      *  J.WATANABE  2020.11.23                              *
      *------------------------------------------------------*
      *  CALLING SEQ.
      *                    CALL 'UEXR38'
      *                    PARM           $TGDT   8
      *                    PARM           $RTN    1
      *   IN  $TGDT   8A TARGET DATE
      *   OUT $TRN :  1A RETURN (BLANK:OK, *:NG)
      ********************************************************
     FAB#PP82 IF  E           K        DISK
     FAL#PLC2 IF  E           K        DISK
     FUEXWP38 UF  E           K        DISK                      A
      *
     E                    RT         30 10
     I            DS
     I                                        1 300 RT
     I                                        1 010 A8RT01
     I                                       11 020 A8RT02
     I                                       21 030 A8RT03
     I                                       31 040 A8RT04
     I                                       41 050 A8RT05
     I                                       51 060 A8RT06
     I                                       61 070 A8RT07
     I                                       71 080 A8RT08
     I                                       81 090 A8RT09
     I                                       91 100 A8RT10
     I                                      101 110 A8RT11
     I                                      111 120 A8RT12
     I                                      121 130 A8RT13
     I                                      131 140 A8RT14
     I                                      141 150 A8RT15
     I                                      151 160 A8RT16
     I                                      161 170 A8RT17
     I                                      171 180 A8RT18
     I                                      181 190 A8RT19
     I                                      191 200 A8RT20
     I                                      201 210 A8RT21
     I                                      211 220 A8RT22
     I                                      221 230 A8RT23
     I                                      231 240 A8RT24
     I                                      241 250 A8RT25
     I                                      251 260 A8RT26
     I                                      261 270 A8RT27
     I                                      271 280 A8RT28
     I                                      281 290 A8RT29
     I                                      291 300 A8RT30
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
      * READ AB#PP82 (TRUCK BIN)
     C           @TGDT     SETGTAB#PP82
     C                     READPAB#PP82                  98
      *
     C           *IN98     IFEQ *OFF
     C                     EXSR #SET1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * SET1: SET TRUCK BIN
      *************************************************************
     C           #SET1     BEGSR
      * BY AB#PP82
     C           1         DO   30        IX      20
     C           RT,IX     IFNE *BLANK
     C                     CLEARUEXWP381
     C                     Z-ADDIX        U3BIN
     C                     MOVELRT,IX     U3ROUT
     C                     MOVEL@TGDT     U3TGDT
     C                     MOVELA8FRDT    U3EFDT
     C                     Z-ADDTODAY     U3CRDT
     C                     Z-ADDNOW       U3CRTM
     C                     MOVEL#USER     U3CRUS
     C                     MOVEL#WSID     U3CRWS
     C                     WRITEUEXWP381
     C                     ENDIF
     C                     ENDDO
      * GET EFFECTIVE DATE
     C           @TGDT     SETGTAL#PLC2
     C                     READPAL#PLC2                  97
     C                     Z-ADDC5KIHZ    @EFDT   80
      *
      * SET TIME
     C           *LOVAL    SETLLUEXWP38
     C                     DO   *HIVAL
     C                     READ UEXWP38                  52
     C   52                LEAVE
      *
     C           U3TGDT    IFNE @TGDT
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELU3ROUT    K#SURT
     C                     Z-ADD@EFDT     K#KIHZ
     C           K#PLC2    CHAINAL#PLC2              99
     C   99                ITER
      *
     C                     Z-ADDC5STTN    U3STIM
     C                     Z-ADDC5EDTN    U3ETIM
     C                     UPDATUEXWP381
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TGDT   8
     C                     PARM           $RTN    1
      *
     C           K#PLC2    KLIST
     C                     KFLD           K#KIHZ  80
     C                     KFLD           K#SURT  9
      *
     C                     MOVEL$TGDT     @TGDT   80
     C                     MOVE ' '       $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         RCNT    20
      *
     C                     ENDSR
