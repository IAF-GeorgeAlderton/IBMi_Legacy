     C*----------------------------*
     C*     ..サブルーチン..     *
     C*  ..箱数＝Ｃ箱比率計算..  *
     C*----------------------------*
     C           SUBRC     BEGSR
      *
     C*----------------------------------*
     C*  ..社内かんばん切替マスター..  *
     C*----------------------------------*
     C                     SETOF                     13
     C                     MOVE *BLANK    WTKRO
     C                     MOVE *BLANK    WKDAI   1
     C           KEY5      CHAINAAMPL111             13
     C           *IN13     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     13
     C                     END
     C           *IN13     IFEQ '0'
      *
     C                     Z-ADD16        A       20
     C                     Z-ADD1         B       20
     C           1         DO   15        B
     C                     SETOF                     11
     C           A         SUB  B         Z       20
     C                     MOVELCKHZ,Z    CYMD    80
     C           CYMD      IFGT *DATE
     C           CKQR,Z    IFEQ 'C'
     C           CKQR,Z    OREQ 'D'
     C           CKQR,Z    OREQ 'E'
     C                     SETON                     11
     C                     MOVE CKQR,Z    WKDAI
     C                     MOVE CKQT,Z    WTKRO
     C                     END
     C                     ELSE
      *
     C           CKKR,Z    IFEQ 'C'
     C           CKKR,Z    OREQ 'D'
     C           CKKR,Z    OREQ 'E'
     C                     SETON                     11
     C                     MOVE CKKR,Z    WKDAI
     C                     MOVE CKNB,Z    WTKRO
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C                     Z-ADD0         WCBKO   20       Cﾌﾞﾃﾍﾒl
      *
     C*--------------------------------*
     C*  ..メッキかんばんマスター..  *
     C*--------------------------------*
