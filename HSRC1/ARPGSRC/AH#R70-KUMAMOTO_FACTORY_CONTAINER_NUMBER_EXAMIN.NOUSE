     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         YOHZ
     C                     ELSE
     C                     ADD  0.5       YOHZ
     C                     END
      *
     C           EX4       TAG
     C  N61                END
      *
      *翌々月
     C                     ADD  1         UAMM
     C           UAMM      IFGT 12
     C*****      UAYY      IFEQ 99
     C*****                Z-ADD0         UAYY
     C*****                ELSE
     C                     ADD  1         UAYY
     C*****                END
     C                     Z-ADD01        UAMM
     C                     END
     C                     MOVE UAYM      YYYM    60
      *
     C           KEY3      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     62
     C           KEY3      READEAGDPL121                 62
     C           *IN62     IFEQ '1'
     C                     GOTO EX5
     C                     END
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO EX5
     C                     END
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         YYHZ
     C                     ELSE
     C                     ADD  0.5       YYHZ
     C                     END
      *
     C           EX5       TAG
     C  N62                END
     C                     ENDSR
      *
      *
     C*<<<<<<<<<<<<<<<
     C*日当箱数計算
     C*>>>>>>>>>>>>>>>
     C           HAKOSU    BEGSR
      *
     C                     SETOF                     70
     C           CFHBAN    LOKUPWHIN                     70
     C           *IN70     IFEQ '1'
     C                     GOTO EX6
     C                     END
      *
     C                     MOVE CFHBAN    WHIN,Q
     C                     ADD  1         Q
      *
     C*---------------
     C* FCEPL01
     C*---------------
      *
     C                     SETOF                     71
     C           KEY4      CHAINFCEPL011             71
     C           *IN71     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     71
     C                     END
      *
     C           *IN71     IFEQ '1'
     C                     GOTO EX6
     C                     END
      *
     C           A2SYHZ    IFLT *DATE
     C                     Z-ADDA2SSYS    SYUY
     C                     ELSE
     C                     Z-ADDA2KSYS    SYUY
     C                     END
     C                     Z-ADDA2GEKN    GEKN
      *
     C           GEKN      DIV  TOHZ      @WK1    80H
     C           @WK1      DIV  SYUY      TOHK      H
     C                     ADD  TOHK      @TOHK
      *
     C*---------------
     C* ABBPL21
     C*---------------
     C                     SETOF                     72
     C           KEY4      CHAINABBPL211             72
     C           *IN72     IFEQ '1'
     C                     GOTO EX6
     C                     END
      *
     C                     Z-ADD0         WN1NM   90
     C                     Z-ADD0         WN2NM   90
     C           U1NGKB    IFEQ 'N'
     C                     Z-ADDU1N1NM    WN1NM
     C                     Z-ADDU1N2NM    WN2NM
     C                     ELSE
     C                     Z-ADDU1S1NM    WN1NM
     C                     Z-ADDU1S2NM    WN2NM
     C                     END
      *
     C           WN1NM     DIV  YOHZ      @WK2    80H
     C           WN2NM     DIV  YYHZ      @WK3    80H
     C           @WK2      DIV  SYUY      YOHK      H
     C           @WK3      DIV  SYUY      YYHK      H
     C                     ADD  YOHK      @YOHK
     C                     ADD  YYHK      @YYHK
      *
     C*-----
     C* EX6
     C*-----
     C           EX6       TAG
     C                     ENDSR
      *
      *
     C*<<<<<<<<<<<<<<<
     C*合計計算
     C*>>>>>>>>>>>>>>>
     C           GOUKEI    BEGSR
     C           1         DO   8         X       10
     C                     ADD  WKN1,X    KGK,X
     C                     ADD  WKN2,X    KGK,X
     C                     ADD  WKN3,X    KGK,X
     C                     ADD  WKN4,X    KGK,X
     C                     ADD  WCHT,X    KGK,X
     C                     ADD  WMA1,X    MGK,X
     C                     ADD  WMA2,X    MGK,X
     C                     ADD  WMA3,X    MGK,X
     C                     ADD  WMA4,X    MGK,X
     C                     ADD  WCHM,X    MGK,X
     C                     END
     C                     ENDSR
