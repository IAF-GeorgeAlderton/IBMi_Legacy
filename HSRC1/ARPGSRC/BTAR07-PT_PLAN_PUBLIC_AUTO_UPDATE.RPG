     C*
     C           *LOVAL    SETLLGDGPL10
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GDGPL10                  99
     C   99                LEAVE
     C*
     C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C*
     C                     MOVE *BLANK    @LOC1   1
     C                     MOVE *BLANK    @LOC2   2
     C                     MOVE *BLANK    @LOC3   2
     C                     MOVE *BLANK    @LOC4   1
     C                     Z-ADD*ZERO     W@LOT#  30
     C                     Z-ADD*ZERO     @DBOX   50
     C                     Z-ADD*ZERO     @DBOX@  50
     C                     Z-ADD*ZERO     @DBOX# 147
     C*
     C                     SELEC
     C*
     C           IBSEIH    WHEQ '0'
     C           K#KEY     SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAAPTL01                  90
     C           *IN90     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
TCHK6C*          L5STHZ    ANDEQ*ALL'9'
TCHK6C           L5UKHZ    IFGT WSSDAT
TCHK6C                     ITER
TCHK6C                     END
TCHK6C           L5STHZ    IFLE WSSDAT
TCHK6C                     ITER
TCHK6C                     END
     C                     MOVE L5TKR1    @LOC1   1
     C                     MOVE L5TKR2    @LOC2   2
     C                     MOVE L5TKR3    @LOC3   2
     C                     MOVE L5TKR4    @LOC4   1
     C                     EXSR #SETT
     C           W@SYS     IFNE *ZERO
     C           W@W#01    DIV  W@SYS     @DBOX@  50H
TCHK6C*          W@W#01    DIV  W@SYS     @DBOX   50
TCHK6C*                    MVR            W@MVR   92
TCHK6C*          W@MVR     IFNE *ZERO
TCHK6C*                    ADD  1         @DBOX
TCHK6C*                    END
TCHK6C           W@W#01    DIV  W@SYS     @DBOX# 147
     C                     ELSE
     C           L5SYOS    IFNE *ZERO
     C           L5KSSU    DIV  L5SYOS    @DBOX@  50H
TCHK6C*          L5KSSU    DIV  L5SYOS    @DBOX   50
TCHK6C*                    MVR            W@MVR   92
TCHK6C*          W@MVR     IFNE *ZERO
TCHK6C*                    ADD  1         @DBOX
TCHK6C*                    END
TCHK6C           L5KSSU    DIV  L5SYOS    @DBOX# 147
     C                     END
     C                     END
     C                     Z-ADDL5HKSU    W@LOT#  30
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C           IBSEIH    WHEQ '3'
     C           K#KEY     SETLLAKBPL04
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAKBPL04                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
TCHK6C*          L1STHZ    ANDEQ*ALL'9'
TCHK6C           L1UKHZ    IFGT WSSDAT
TCHK6C                     ITER
TCHK6C                     END
TCHK6C           L1STHZ    IFLE WSSDAT
TCHK6C                     ITER
TCHK6C                     END
     C                     MOVE L1TKR1    @LOC1   1
     C                     MOVE L1TKR2    @LOC2   2
     C                     MOVE L1TKR3    @LOC3   2
     C                     MOVE L1TKR4    @LOC4   1
     C           L1SYOS    IFNE *ZERO
TCHK8C*          L1KSSU    DIV  L1SYOS    @DBOX@  50H
TCHK8C           L1KTSU    DIV  L1SYOS    @DBOX@  50H
TCHK6C*          L1KSSU    DIV  L1SYOS    @DBOX   50
TCHK6C*                    MVR            W@MVR   92
TCHK6C*          W@MVR     IFNE *ZERO
TCHK6C*                    ADD  1         @DBOX
TCHK6C*                    END
TCHK8C*TCHK6     L1KSSU    DIV  L1SYOS    @DBOX# 147
TCHK8C           L1KTSU    DIV  L1SYOS    @DBOX# 147
     C                     ENDIF
     C                     Z-ADD1         W@LOT#  30
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           IBSEIH    WHEQ '6'
     C           K#KEY     SETLLAANPL06
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAANPL06                  90
     C           *IN90     IFEQ *OFF
     C           L7SKJY    ANDEQ*BLANK
TCHK6C*          L7STHZ    ANDEQ*ALL'9'
TCHK6C           L7UKHZ    IFGT WSSDAT
TCHK6C                     ITER
TCHK6C                     END
TCHK6C           L7STHZ    IFLE WSSDAT
TCHK6C                     ITER
TCHK6C                     END
     C                     MOVE L7TKR1    @LOC1   1
     C                     MOVE L7TKR2    @LOC2   2
     C                     MOVE L7TKR3    @LOC3   2
     C                     MOVE L7TKR4    @LOC4   1
     C                     EXSR #SETT
     C           W@SYS     IFNE *ZERO
     C           W@W#01    DIV  W@SYS     @DBOX@  50H
TCHK6C*          W@W#01    DIV  W@SYS     @DBOX   50
TCHK6C*                    MVR            W@MVR   92
TCHK6C*          W@MVR     IFNE *ZERO
TCHK6C*                    ADD  1         @DBOX
TCHK6C*                    END
TCHK6C           W@W#01    DIV  W@SYS     @DBOX# 147
     C                     ELSE
     C           L7SYOS    IFNE *ZERO
     C           L7KSSU    DIV  L7SYOS    @DBOX@  50H
TCHK6C*          L7KSSU    DIV  L7SYOS    @DBOX   50
TCHK6C*                    MVR            W@MVR   92
TCHK6C*          W@MVR     IFNE *ZERO
TCHK6C*                    ADD  1         @DBOX
TCHK6C*                    END
TCHK6C           L7KSSU    DIV  L7SYOS    @DBOX# 147
     C                     END
     C                     END
TCHK7C*                    Z-ADDL7HKSU    W@LOT#  30
TCHK7C                     Z-ADD1         W@LOT#  30
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
