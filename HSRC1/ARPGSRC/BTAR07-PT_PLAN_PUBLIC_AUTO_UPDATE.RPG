     C                     ENDSL
      *
TCHK6C*          @DBOX     MULT W@RATE    W@MS#
TCHK6C           @DBOX#    MULT W@RATE    W@MS#
TCHK6C                     Z-ADD@DBOX#    @DBOX
     C           W@MS#6    IFNE *ZERO
     C           W@MS#     ADD  1         W@MS@D  50
     C                     ELSE
     C                     Z-ADDW@MS#     W@MS@D
     C                     END
     C*
     C                     Z-ADDIBMAIS    W@BFMS  50
     C*
     C           W@LOT#    IFEQ *ZERO
     C                     Z-ADD1         W@LOT#
     C                     END
     C           W@LOT#    IFGT 1
     C           W@MS@D    DIV  W@LOT#    W@N001  50
     C                     MVR            W@N002  50
     C           W@N002    IFNE *ZERO
     C                     ADD  1         W@N001
     C                     END
     C           W@LOT#    MULT W@N001    W@MS@D
     C                     END
     C*
     C           IBMAIS    IFGT W@MS@D
     C           IBMAIS    SUB  W@MS@D    W@NXMS  50
     C                     Z-ADDW@MS@D    IBMAIS
     C                     ELSE
     C                     Z-ADD*ZERO     W@NXMS
     C                     END
     C*
     C           IBMAIS    MULT IBSYOS    IBSURY
     C*
     C                     UPDATGDGPL101
     C*
     C           W@NXMS    IFNE *ZERO
     C                     EXSR #PUBL
     C                     END
     C*
     C                     Z-ADD*ZERO     W@PUMS  50
     C                     EXSR #PULS
     C*
     C                     Z-ADD*ZERO     W@NTMS  50
     C                     EXSR #PUBN
     C*
     C           @DBOX@    IFEQ *ZERO
     C           IBMAIS    DIV  1         PERCEN    H
     C                     ELSE
     C           IBMAIS    DIV  @DBOX@    PERCEN    H
     C                     END
     C*
     C                     WRITEGDGWP071
     C*
     C                     ENDDO
     C*
     C* ----------------------------------------------------
     C*
     C                     Z-ADD*ZERO     ORGALL  70
     C                     Z-ADD*ZERO     ORDALL  70
     C                     Z-ADD*ZERO     PUBALL  70
     C                     Z-ADD*ZERO     PULALL  70
     C                     Z-ADD*ZERO     NTTALL  70
     C           *HIVAL    SETLLGDGWP07
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GDGWP07                  98
     C   98                LEAVE
     C*
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           @@TIME
     C                     TIME           WSDT
     C                     EXCPTHY
     C                     END
     C*
     C           *INOV     IFEQ '1'
     C                     EXCPTHY
     C                     SETOF                     OV
     C                     END
     C                     EXCPTMY
     C                     ADD  W@BFMS    ORGALL
     C                     ADD  IBMAIS    ORDALL
     C                     ADD  W@NXMS    PUBALL
     C                     ADD  W@PUMS    PULALL
     C                     ADD  W@NTMS    NTTALL
     C*
     C                     ENDDO
     C*
     C                     EXCPTTY
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *  GET SETTING
      *-----------------------------------------------------------
     C           #SETT     BEGSR
     C*
     C                     Z-ADD*ZERO     W@SYS   50
     C                     Z-ADD*ZERO     W@W#01 112
     C                     Z-ADD*ZERO     W@GEKN  90
     C*
     C                     DO
     C*
     C           K#FCEP    KLIST
     C                     KFLD           IBHIN1
     C                     KFLD           IBHIN2
     C                     KFLD           IBHIN3
     C           K#FCEP    CHAINFCEPL01              91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    W@SYS   50
     C                     ELSE
     C                     Z-ADDA2SSYS    W@SYS
     C                     END
     C*
     C                     Z-ADDA2GEKN    W@GEKN  90
     C           K#FCEP    CHAINFCEPL11              94
TCHK2C*          *IN94     IFEQ *OFF
TCHK2C*          FCCD01    ANDNE*ZERO
TCHK2C*          FCGK01    DIV  FCCD01    @@QTY   90
TCHK2C*          @@QTY     MULT 20        W@GEKN
TCHK2C*                    END
TCHK2C           *IN94     IFEQ *OFF
TCHK2C           FCSKJY    ANDEQ*BLANK
TCHK2C                     Z-ADD*ZERO     Z       20
TCHK2C                     DO   *HIVAL
TCHK2C                     ADD  1         Z
TCHK2C           Z         IFGT 10
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           WSSDAT    IFGE CGH,Z
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     ENDDO
TCHK2C           Z         IFLE 10
TCHK2C           CCD,Z     IFNE *ZERO
TCHK2C           CGK,Z     DIV  CCD,Z     @@QTY   90
TCHK2C           @@QTY     MULT 20        W@GEKN
TCHK2C                     END
TCHK2C                     END
TCHK2C                     END
     C*
     C           W@GEKN    DIV  20        W@W#01 112
     C*
     C                     ENDDO
     C*
     C                     ENDSR
