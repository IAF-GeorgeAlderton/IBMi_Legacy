     H            Y,
      *** EDIR35 ***********************************
      * ACCOUNTING CUSTOMER# MAINTENANCE           *
      *                                            *
      * CODING : A.MAMIYA             2000.09.21   *
      * ADD FRS# FLAG CHECK           2001.01.25   *
      *          K.KASHIWAGI                       *
      * ADD TRIAL FLAG = '2'          2001.02.14   *
      * INITIALIZED FRSFG IS DISPLAYED2001.02.15   *
      ************************************* EDIR35 *
     FEDIPW35 CF  E                    WORKSTN
     FEDIPL35 UF  E           K        DISK                      A
     FFGBPL01 IF  E           K        DISK
     E                    ER      1  20 60               ERROR MESSAGE
     E                    TB1     1   3  1   TB2     6
      *
     I            DS
     I                                        1   80E2SKHZ
     I                                        1   40E2SKYY
     I                                        5   60E2SKMM
     I                                        7   80E2SKDD
     I            DS
     I                                        1   80E2KOHZ
     I                                        1   40E2KOYY
     I                                        5   60E2KOMM
     I                                        7   80E2KODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20E2KOHH
     I                                        3   40E2KOSS
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      **********************
      *  DISPLAY 1 SCREEN  *
      **********************
     C           STEP0     TAG
     C                     MOVE *BLANK    NO
     C                     MOVE *BLANK    TOKU
     C                     MOVE *BLANK    NONY
     C                     MOVE *BLANK    NKOJ
     C                     MOVE *BLANK    NUKE
      *
     C           STEP1     TAG
     C                     EXFMTEDIPW351
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     077799
      * F1: EXIT
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      * F10: INQ
     C           *INKJ     IFEQ '1'
     C                     CALL 'EDIR36'
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           NO        IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           NO        IFNE '0'
     C           NO        ANDNE'1'
     C           NO        ANDNE'2'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           TOKU      IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     END
      *
     C                     Z-ADD0         WTOKU   40
     C                     MOVE TOKU      WTOKU
     C                     SETOF                     60
     C           WTOKU     CHAINFGBPL01              60
     C           *IN60     IFEQ '1'
     C                     SETON                     0299
     C                     MOVE ER,13     MSG
     C                     GOTO STEP1
     C                     END
     C           *IN60     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     0299
     C                     MOVE ER,13     MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C           NONY      IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,4      MSG
     C                     GOTO STEP1
     C                     END
      *
     C                     Z-ADD0         WNONY   40
     C                     MOVE NONY      WNONY
     C                     SETOF                     60
     C           WNONY     CHAINFGBPL01              60
     C           *IN60     IFEQ '1'
     C                     SETON                     0399
     C                     MOVE ER,13     MSG
     C                     GOTO STEP1
     C                     END
     C           *IN60     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     0399
     C                     MOVE ER,13     MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C           NKOJ      IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,5      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           NUKE      IFEQ *BLANK
     C                     SETON                     0599
     C                     MOVE ER,6      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           KEY2      KLIST
     C                     KFLD           TOKU
     C                     KFLD           NONY
     C                     KFLD           NKOJ
     C                     KFLD           NUKE
      *
     C                     MOVE *BLANK    GPS
     C                     MOVE *BLANK    EDI
JW   C                     MOVE '1'       FRSFG
     C                     SETOF                     50
     C           KEY2      CHAINEDIPL351             50
      *
     C           NO        IFEQ '0'
     C           NO        OREQ '1'
     C           *IN50     IFEQ '1'
     C                     SETON                     020304
     C                     SETON                     0599
     C                     MOVE ER,8      MSG
     C                     GOTO STEP1
     C                     END
     C           *IN50     IFEQ '0'
     C           E2SKJY    IFEQ 'D'
     C           E2SKHZ    ANDLE*DATE
     C                     SETON                     020304
     C                     SETON                     0599
     C                     MOVE ER,8      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C                     MOVE E2CUST    GPS
     C                     MOVE E2EDIC    EDI
      * ADD FRSFG
     C                     MOVE E2OFLG    FRSFG
     C                     END
      *
     C           NO        IFEQ '0'
     C                     SETON                     77
     C                     END
      *
     C           NO        IFEQ '2'
     C           *IN50     IFEQ '0'
     C           E2SKJY    IFEQ 'D'
     C           E2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     020304
     C                     SETON                     0599
     C                     MOVE ER,9      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C                     END
      **********************
      *  DISPLAY 2 SCREEN  *
      **********************
     C                     Z-ADD1         X       10
     C                     SETOF                     70
     C           NO        LOKUPTB1,X                    70
     C           *IN70     IFEQ '1'
     C                     MOVE TB2,X     KUBN
     C                     END
      *
     C           STEP2     TAG
     C                     EXFMTEDIPW352
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070899
      *
     C           *INKC     IFEQ '1'
     C                     GOTO STEP0
     C                     ENDIF
      *
     C           GPS       IFEQ *BLANK
     C                     SETON                     0699
     C                     MOVE ER,10     MSG
     C                     GOTO STEP2
     C                     END
      *
     C           EDI       IFEQ *BLANK
     C                     SETON                     0799
     C                     MOVE ER,11     MSG
     C                     GOTO STEP2
     C                     END
      *
      * NON-INVOICE '0'  INVOICE '1'  TRIAL '2'
      *
     C           EDI       IFEQ '0'
     C           EDI       OREQ '1'
     C           EDI       OREQ '2'
     C                     ELSE
     C                     SETON                     0799
     C                     MOVE ER,12     MSG
     C                     GOTO STEP2
     C                     END
      *
      *
     C           FRSFG     IFNE '1'
     C           FRSFG     ANDNE'2'
     C                     SETON                     0899
     C                     MOVE ER,14     MSG
     C                     GOTO STEP2
     C                     END
      *
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STEP2
     C                     END
      *
     C           NO        IFEQ '0'
     C                     MOVE 'D'       E2SKJY
     C                     Z-ADD*DATE     E2SKHZ
     C                     ELSE
     C                     MOVE ' '       E2SKJY
     C                     Z-ADD0         E2SKHZ
     C                     MOVELTOKU      E2TOKU
     C                     MOVELNONY      E2NONY
     C                     MOVELNKOJ      E2NKOJ
     C                     MOVELNUKE      E2UKEI
     C                     MOVELGPS       E2CUST
     C                     MOVELGPS       E2CUST
     C                     MOVELEDI       E2EDIC
     C                     MOVELFRSFG     E2OFLG
     C                     END
      *
      *
     C                     Z-ADD*DATE     E2KOHZ
     C                     TIME           WTIME
     C                     MOVELUSER      E2KOME
      *
     C           *IN50     IFEQ '0'
     C                     UPDATEDIPL351
     C                     ELSE
     C                     WRITEEDIPL351
     C                     END
      *
     C                     GOTO STEP0
** ER
E-01 ENTER UPDATE CODE
E-02 UPDATE CODE SHOULD BE 0, 1 OR 2!
E-03 ENTER CUSTOMER CODE!
E-04 ENTER DELIVERY CODE!
E-05 ENTER FACTORY CODE!
E-06 ENTER DOCK CODE!
E-07 SHIPPING M/F NOT FOUND!
E-08 DATA DOES NOT EXIST!
E-09 DATA HAS ALREADY BEEN REGISTERED!
E-10 ENTER GPS-CUSTOMER
E-11 ENTER INVOICE FLAG!
E-12 INVOICE FLAG SHOULD BE 0,1 OR 2!
E-13 CUSTOMER M/F NOT FOUND!
E-14 ORDER# FLAG SHOULD BE 1 OR 2!
**  TB1(NO)TB2(KUBN)
0CANCEL
1CHANGE
2ADD
