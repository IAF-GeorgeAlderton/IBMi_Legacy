     H            Y.
     F** MRAR93 *********************************************
     F* UNTRANSMIT LIST                                     *
     F*      TRANCOM-ITS.        2012.09.18                 *
     F*******************************************************
     FMRAWP91 IF  E           K        DISK
     FMRAPR93 O   E             55     PRINTER
      *
     I            DS
     I                                        1  14 P2SHN
     I                                        1   5 P2SHN1
     I                                        6   6 P2SF1
     I                                        7  11 P2SHN2
     I                                       12  12 P2SF2
     I                                       13  14 P2SHN3
      *
     I            DS
     I                                        1  23 P2MHN
     I                                        1   5 P2MHN1
     I                                        6   6 P2MF1
     I                                        7  11 P2MHN2
     I                                       12  12 P2MF2
     I                                       13  17 P2MHN3
     I                                       18  18 P2MF3
     I                                       19  23 P2MHN4
      *
     I            DS
     I                                        1   80W1STHZ
     I                                        1   40W1STYY
     I                                        5   60W1STMM
     I                                        7   80W1STDD
      *
     I            DS
     I                                        1   80W1PTA
     I                                        1   40W1PTAY
     I                                        5   60W1PTAM
     I                                        7   80W1PTAD
      *
     I              'PART'                C         SEKB1
     I              'COMPONENT'           C         SEKB2
      *
     I              'LOCAL PROD'          C         PRKB1
     I              'PATH-THRU '          C         PRKB2
     I              'BLANK PT  '          C         PRKB3
     I              'LOCAL PARC'          C         PRKB4
      *
     C                     EXSR #SB100
      *
     C                     READ MRAWP911                 80
     C           *IN80     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     EXSR #SB100
     C                     ENDIF
     C                     EXSR #SB400
     C                     READ MRAWP911                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     Z-ADD*DATE     P1DATE
     C                     WRITEMRAPR931
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVELW1SHN1    P2SHN1
     C                     MOVELW1SHN2    P2SHN2
     C                     MOVELW1SHN3    P2SHN3
     C                     MOVEL'-'       P2SF1
     C                     MOVEL'-'       P2SF2
     C           P2SHN3    IFEQ *BLANK
     C                     MOVEL*BLANK    P2SF2
     C                     ENDIF
     C           P2SHN2    IFEQ *BLANK
     C                     MOVEL*BLANK    P2SF1
     C                     ENDIF
      *
     C                     MOVELW1MHN1    P2MHN1
     C                     MOVELW1MHN2    P2MHN2
     C                     MOVELW1MHN3    P2MHN3
     C                     MOVELW1MHN4    P2MHN4
     C                     MOVEL'-'       P2MF1
     C                     MOVEL'-'       P2MF2
     C                     MOVEL'-'       P2MF3
     C           P2MHN4    IFEQ *BLANK
     C                     MOVEL*BLANK    P2MF3
     C                     ENDIF
     C           P2MHN3    IFEQ *BLANK
     C                     MOVEL*BLANK    P2MF2
     C                     ENDIF
     C           P2MHN2    IFEQ *BLANK
     C                     MOVEL*BLANK    P2MF1
     C                     ENDIF
      *
     C                     MOVELW1TMEI    P2TMEI
      *
     C                     MOVEL*BLANK    P2SEKB
     C                     SELEC
     C           W1SEKB    WHEQ '1'
     C                     MOVELSEKB1     P2SEKB
     C           W1SEKB    WHEQ '2'
     C                     MOVELSEKB2     P2SEKB
     C                     ENDSL
      *
     C                     MOVEL*BLANK    P2PRKB
     C                     SELEC
     C           W1PRKB    WHEQ '1'
     C                     MOVELPRKB1     P2PRKB
     C           W1PRKB    WHEQ '2'
     C                     MOVELPRKB2     P2PRKB
     C           W1PRKB    WHEQ '3'
     C                     MOVELPRKB3     P2PRKB
     C           W1PRKB    WHEQ '4'
     C                     MOVELPRKB4     P2PRKB
     C                     ENDSL
      *
     C                     Z-ADDW1STHZ    P2STHZ
     C                     Z-ADDW1SRYO    P2SRYO
     C                     MOVELW1SYKI    P2SYKI
     C                     MOVELW1SENO    P2SENO
     C                     MOVELW1KANA    P2KANA
     C                     Z-ADDW1PTA     P2PTA
     C                     MOVELW1CRAT    P2CRAT
     C                     MOVELW1BIKO    P2BIKO
     C                     WRITEMRAPR932
