     H            Y.                                    1
     H** UTLR14A ***************************************************************
     H*  GET A-PICS PRC/MCN/DPT/LOC # BY PART #
     H*  FROM AAMPP11
     H*  T.SAKAKI         10.09.2019
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR14A'
     F*                    PARM           PMHIN1  5
     F*                    PARM           PMHIN2  5
     F*                    PARM           PMHIN3  2
     F*                    PARM           PMDATE  80
     F*                    PARM           PMBIN   20
     F*                    PARM           PMLOCA  6
     F*                    PARM           PMKIND  1
     F*                    PARM           PMPRCN  3
     F*                    PARM           PMPRCR  3
     F*                    PARM           PMMCNN  3
     F*                    PARM           PMMCNR  3
     F*                    PARM           PMDPTN  40
     F*                    PARM           PMDPTR  40
     F*                    PARM           PMPLOC  6
     F*                    PARM           PMPKIN  1
     F*                    PARM           PMPPRC  3
     F*                    PARM           PMPMCN  3
     F*                    PARM           PMPDPT  40
     F*                    PARM           PMRTN   1
     F*   IN  PMHIN1:  5 A  IAF PART1
     F*       PMHIN2:  5 A  IAF PART2
     F*       PMHIN3:  2 A  IAF PART3
     F*       PMDATE:  80S  BASE DATE
     F*       PMBIN :  20S  BASE TIME
     F*   OUT PMLOCA:  3 A  A-PICS LOCATION
     F*       PMKIND:  3 A  A-PICS KANBAN KIND
     F*       PMPRCN:  3 A  A-PICS FINAL PROCESS
     F*       PMPRCR:  3 A  A-PICS FIRST PROCESS
     F*       PMMCNN:  3 A  A-PICS FINAL MACHINE
     F*       PMMCNR:  3 A  A-PICS FIRST MACHINE
     F*       PMDPTN:  40S  A-PICS FINAL DEPARTMENT
     F*       PMDPTR:  40S  A-PICS FIRST DEPARTMENT
     F*       PMPLOC:  6 A  PRECEDING LOCATION
     F*       PMPKIN:  1 A  PRECEDING KANBAN KIND
     F*       PMPPRC:  3 A  PRECEDING PROCESS
     F*       PMPMCN:  3 A  PRECEDING MACHINE #
     F*       PMPDPT:  40S  PRECEDING DEPARTMENT
     F*       PMRTN :  1 A  RETURN FLAG (BLANK=OK, *=ERROR)
     F*             :       RETURN FLAG (T=TS-LINE PARTS)
     H**************************************************************************
      * TABLE
     E                    PRC        15  3                PROCESS
     E                    MCN        15  3                MACHINE #
     E                    DPT        15  4                DEPARTMENT
     E                    LOC        15  6                LOCATION
     E                    KNB        15  1                KANBAN KIND
     E*
     I            DS
     I                                        1  100WKDTBN
     I                                        1   80WKDATE
     I                                        9  100WKBIN
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C***************************************************
     C*  ENTRY LIST
     C***************************************************
     C           *ENTRY    PLIST
     C                     PARM           PMHIN1  5
     C                     PARM           PMHIN2  5
     C                     PARM           PMHIN3  2
     C                     PARM           PMDATE  80
     C                     PARM           PMBIN   20
     C                     PARM           PMLOCA  6
     C                     PARM           PMKIND  1
     C                     PARM           PMPRCN  3
     C                     PARM           PMPRCR  3
     C                     PARM           PMMCNN  3
     C                     PARM           PMMCNR  3
     C                     PARM           PMDPTN  40
     C                     PARM           PMDPTR  40
     C                     PARM           PMPLOC  6
     C                     PARM           PMPKIN  1
     C                     PARM           PMPPRC  3
     C                     PARM           PMPMCN  3
     C                     PARM           PMPDPT  40
     C                     PARM           PMRTN   1
     C***************************************************
     C*  MAIN
     C***************************************************
     C                     Z-ADDPMDATE    WKDATE  80
     C                     Z-ADDPMBIN     WKBIN   20
     C*
     C                     MOVE *BLANK    PMLOCA
     C                     MOVE *BLANK    PMKIND
     C                     MOVE *BLANK    PMPRCN
     C                     MOVE *BLANK    PMPRCR
     C                     MOVE *BLANK    PMMCNN
     C                     MOVE *BLANK    PMMCNR
     C                     Z-ADD0         PMDPTN
     C                     Z-ADD0         PMDPTR
     C                     MOVE *BLANK    PMPLOC
     C                     MOVE *BLANK    PMPKIN
     C                     MOVE *BLANK    PMPPRC
     C                     MOVE *BLANK    PMPMCN
     C                     Z-ADD0         PMPDPT
     C                     MOVE *BLANK    PMRTN
      *
     C                     MOVEL'1'       OPNCLS
      *
     C                     EXSR #SB390
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C***************************************************
      * SUB ROUTINE 1                     *
     C***************************************************
     CSR         #SB390    BEGSR
      *
     C                     CLEARPRC
     C                     CLEARMCN
     C                     CLEARDPT
     C                     CLEARLOC
     C                     CLEARKNB
     C                     MOVELPMHIN1    CBSHN1  5
     C                     MOVELPMHIN2    CBSHN2  5
     C                     MOVELPMHIN3    CBSHN3  2
     C                     MOVE WKDTBN    INYMDB
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C           STATUS    IFEQ '9'
     C                     GOTO ESB390
     C                     ENDIF
      *
     C                     MOVEAPKOT      PRC
     C                     MOVEAPKBN      MCN
     C                     MOVEAPBMN      DPT
     C                     MOVEAPTKR      LOC
     C                     MOVEAPSHR      KNB
      *
      * SET A-PICS FINAL PROCESS
     C                     Z-ADD15        IX      20
     C           1         DO   15
1    C           LOC,IX    IFNE *BLANK
|    C                     MOVELPRC,IX    PMPRCN
|    C                     MOVELMCN,IX    PMMCNN
|    C                     MOVE DPT,IX    PMDPTN
|    C                     MOVELPRC,IX    PMPRCR
|    C                     MOVELMCN,IX    PMMCNR
|    C                     MOVE DPT,IX    PMDPTR
|    C                     MOVELLOC,IX    PMLOCA
|    C                     MOVELKNB,IX    PMKIND
|    C                     LEAVE
1    C                     ENDIF
     C                     SUB  1         IX
     C                     ENDDO
      *
      * SET A-PICS FIRST PROCESS
     C                     Z-ADDIX        IY      20
     C           1         DO   15
     C                     SUB  1         IY      20
1    C           IY        IFLE 0
|    C                     LEAVE
1    C                     ENDIF
1    C           LOC,IY    IFEQ '------'
|    C                     MOVELPRC,IY    PMPRCR
|    C                     MOVELMCN,IY    PMMCNR
|    C                     MOVE DPT,IX    PMDPTR
|     * SET PRECEDING PROCESS
X    C                     ELSE
|    C                     MOVELLOC,IY    PMPLOC
|    C                     MOVELKNB,IY    PMPKIN
|    C                     MOVELPRC,IY    PMPPRC
|    C                     MOVELMCN,IY    PMPMCN
|    C                     MOVE DPT,IX    PMPDPT
|    C                     LEAVE
1    C                     ENDIF
      *
     C                     ENDDO
      *
      * SET TS-LINE OR NOT
     C                     Z-ADD1         IX
     C           'OQ1'     LOKUPMCN,IX                   90
     C           *IN90     IFEQ *ON
     C                     MOVEL'T'       PMRTN
     C                     ENDIF
      *
     CSR         ESB390    ENDSR
