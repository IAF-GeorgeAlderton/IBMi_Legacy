     H            Y.
     F*******************************************************
     F*   CONVERT MATERIAL ORDER DATA                       *
     F*   MSK   2005.03.01                                  *
     F*******************************************************
     FGDLPP01 UP  E                    DISK
     FGDLPP90 IF  E           K        DISK
     FGDLPP91 O   E           K        DISK                      A
      *
     I            DS
     I                                        1   80LASKHZ
     I                                        1   40LASKYY
     I                                        5   60LASKMM
     I                                        7   80LASKDD
      *
     C           KEY1      KLIST
     C                     KFLD           #KZAIS 15
     C                     KFLD           #KZAIK  52
      *
     C                     Z-ADD0         HASU    31
     C                     MOVELLAZAIS    #KZAIS
     C                     Z-ADDLAZAIK    #KZAIK
     C           KEY1      CHAINGDLPP901             21
     C           *IN21     IFEQ '1'
     C                     GOTO @LAST
     C                     ENDIF
      *
     C                     DIV  2         LAMAIS
     C                     MVR            HASU    31
     C           HASU      IFNE 0
     C                     MOVELLAZAIS    LYZAIS
     C                     Z-ADDLAZAIK    LYZAIK
     C                     WRITEGDLPP911
     C                     ENDIF
      *
     C           LAMAIS    IFEQ 0
     C                     MOVEL'D'       LASKJY
     C                     Z-ADD*DATE     LASKHZ
     C                     ENDIF
     C                     MOVEL*BLANK    LAKOME
     C                     MOVEL'CONVERT' LAKOME
     C                     UPDATGDLPP011
      *
     C           @LAST     TAG
      *
