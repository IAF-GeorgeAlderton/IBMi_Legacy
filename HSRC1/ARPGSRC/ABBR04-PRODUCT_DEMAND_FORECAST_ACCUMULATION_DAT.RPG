     C           KEY1      KLIST
     C                     KFLD           WHYY
     C                     KFLD           WHMM
     C                     KFLD           WHDD
      *
     C           KEY2      KLIST
     C                     KFLD           WH1YY
     C                     KFLD           WH1MM
     C                     KFLD           WH1DD
      *
     C           *IN01     IFEQ '0'
     C                     SETON                     01
      *
     C           *ENTRY    PLIST
     C                     PARM           PKBN    1
     C                     PARM           PHIZ1   8
     C                     PARM           PHIZ2   8
     C                     PARM           PCD     3
      *
     C           PKBN      IFEQ 'A'
      *
     C*-----------------------------------------------------*
     C*      ...内示累積データ抜出の期間と稼動日数...     *
     C*-----------------------------------------------------*
     C                     Z-ADD*DATE     WHIZ
     C           KEY1      SETLLAGDPL121
     C                     Z-ADD1         A
     C           1         DO   2         A
     C                     SETOF                     02
     C                     READPAGDPL121                 02
     C           *IN02     IFEQ '1'
     C                     SETON                     U1LR
     C                     RETRN
     C                     END
     C                     END
      *
     C                     MOVE F8KAHZ    WHIZ2
     C           WH2MM     IFEQ 01
     C           WH2YY     SUB  1         WH1YY
     C                     Z-ADD12        WH1MM
     C                     ELSE
      *
     C                     Z-ADDWH2YY     WH1YY
     C           WH2MM     SUB  1         WH1MM
     C                     END
     C           WH2DD     ADD  1         WH1DD
      *
     C           WHYM      IFEQ WH2YM
     C                     Z-ADD01        WH1DD
     C                     Z-ADDWH1YM     WH2YM
     C                     Z-ADD31        WH2DD
     C                     END
      *
     C           KEY2      SETLLAGDPL121
     C                     SETOF                     02
     C                     READ AGDPL121                 02
     C           *IN02     IFEQ '0'
     C           WH1MM     IFNE F8KAMM
     C                     Z-ADDF8KAYY    WH1YY
     C                     Z-ADDF8KAMM    WH1MM
     C                     Z-ADD01        WH1DD
     C                     END
     C                     END
      *
     C           KEY2      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ AGDPL121                 02
     C           *IN02     IFEQ '1'
     C                     SETON                     U1LR
     C                     RETRN
     C                     END
      *
     C*---------------------------------*
     C*      ...期間の稼動日数...     *
     C*---------------------------------*
     C           F8KAHZ    IFGE WHIZ1
     C           F8KAHZ    IFLE WHIZ2
     C                     GOTO STP1
     C                     END
     C                     END
     C                     GOTO STP2
     C           STP1      TAG
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         WCD     31
     C                     ELSE
     C                     ADD  0.5       WCD
     C                     END
      *
     C                     END
     C                     END
     C           STP2      TAG
      *
     C                     MOVE WHIZ1     PHIZ1
     C                     MOVE WHIZ2     PHIZ2
     C                     MOVE PHIZ1     YMD1
     C                     MOVE PHIZ2     YMD2
      * IF WORKING DAY IS 0
     C           WCD       IFEQ 0
     C                     Z-ADD1         WCD
     C                     ENDIF
      *
     C                     MOVE WCD       PCD
      *
     C                     END
     C                     END
      *
     C*-------------------------------------*
     C*      ...内示区分のチェック...     *
     C*-------------------------------------*
     C           PKBN      IFEQ 'A'
     C           Q52NNK    IFNE 'N'
     C           Q51NNK    IFNE 'N'
     C           Q5NNNK    IFNE 'N'
     C                     GOTO END
     C                     END
     C                     END
     C                     END
     C                     ELSE
      *
     C           Q5CHK1    IFEQ *BLANK
     C           Q5CHS1    ANDEQ0
     C           Q5N2GM    ANDEQ0
     C           Q5N2ND    ANDEQ0
     C           Q5NNNK    ANDEQ*BLANK
     C           Q5NNNM    ANDEQ0
     C           WNN       ANDEQ*ZERO
     C           Q51NNK    ANDEQ*BLANK
     C           Q51NNM    ANDEQ0
     C           Q52NNK    ANDEQ*BLANK
     C           Q52NNM    ANDEQ0
     C                     GOTO END
     C                     END
     C                     END
      *
     C*--------------------------------------------------*
     C*      ...パラメーター                           *
     C*      ...期間開始日－－期間終了日の期間合計     *
     C*      ...をチェック用月間内示数に出力           *
     C*--------------------------------------------------*
     C                     Z-ADD0         WCHNM
     C           PKBN      IFEQ 'A'
     C           WH1YM     IFLT WH2YM
     C                     Z-ADD1         A       20
     C           DD1       DO   31        A
     C                     ADD  N2,A      WCHNM   90
     C                     END
     C                     END
     C                     Z-ADD1         A
     C           1         DO   DD2       A
     C                     ADD  N1,A      WCHNM
     C                     END
      *
     C*-------------------------------------*
     C*      ...内示区分のチェック...     *
     C*-------------------------------------*
     C                     MOVE Q5N2NK    WCHNK   1
     C           WCHNK     IFNE 'N'
     C                     MOVE Q5N1NK    WCHNK
     C                     END
     C                     END
      *
     C           PKBN      IFEQ 'C'
     C                     MOVE Q5CHK1    WCHNK
     C                     Z-ADDQ5CHS1    WCHNM
     C                     Z-ADDQ5N2GM    Q5N1GM
     C                     Z-ADDQ5N2ND    Q5N1ND
     C                     Z-ADDQ5N3GM    Q5N2GM
     C                     Z-ADDQ5N3ND    Q5N2ND
     C                     Z-ADDQ5N4GM    Q5N3GM
     C                     Z-ADDQ5N4ND    Q5N3ND
     C                     END
      *
     C                     SETOF                     10
     C           Q5NONY    LOKUPTB1                      10
     C           *IN10     IFEQ '1'
     C                     MOVE *BLANK    Q52NNK
     C                     Z-ADD0         Q52NNM
     C                     END
      *
     C                     Z-ADDQ5NONY    WNONY   40
     C                     MOVE Q5NKOJ    WNKOJ   1
     C                     MOVE Q5NUKE    WNUKE   4
      *
     C           Q5TOKU    IFEQ 5149
     C**         Q5TOKU    OREQ 0873
     C                     MOVE *BLANK    WNUKE
     C                     END
      *
     C                     EXCPTDT
      *
     C           END       TAG
      *
     OABBWP02 E                DT
     O                         Q5TOKU     4
     O                         WNONY      8
     O                         WNKOJ      9
     O                         WNUKE     13
     O                         Q5SEBN    17
     O                         Q5MHN1    22
     O                         Q5MHN2    27
     O                         Q5MHN3    32
     O                         Q5MHN4    37
     O                         Q5SHN1    42
     O                         Q5SHN2    47
     O                         Q5SHN3    49
     O                         WCHNK  B  50
     O                         WCHNM  B  55P
     O                         Q5NNNK    56
     O                         Q5NNNM    61P
     O                         NN       185P
     O                         Q51NNK   186
     O                         Q51NNM   191P
     O                         Q52NNK   192
     O                         Q52NNM   197P
     O                         Q5N3GM   202P
     O                         Q5N3ND   206P
