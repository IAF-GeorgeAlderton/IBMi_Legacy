     H            Y.                                    1
     F**ALDRT1 ********************************************************
     F* GET OUTSOURCE PROCESSING  AFAPP80                             *
     F*  2019.09.17      SAKAKI                                       *
     F*****************************************************************
     FAFAPL82 IF  E           K        DISK                           UC
     FAFDPL11 IF  E           K        DISK                           UC
     FAFDPL24 IF  E           K        DISK                           UC
      *
     I            DS
     I                                        1   80A8SUHZ
     I                                        1   40A8SUYY
     I                                        5   60A8SUMM
     I                                        7   80A8SUDD
     I            DS
     I                                        1   80A8NYHZ
     I                                        1   40A8NYYY
     I                                        5   60A8NYMM
     I                                        7   80A8NYDD
     I            DS
     I                                        1   80A8NOHZ
     I                                        1   40A8NOYY
     I                                        5   60A8NOMM
     I                                        7   80A8NODD
     I            DS
     I                                        1   80AFNYHZ
     I                                        1   40AFNYYY
     I                                        5   60AFNYMM
     I                                        7   80AFNYDD
     I            DS
     I                                        1   80AFNOHZ
     I                                        1   40AFNOYY
     I                                        5   60AFNOMM
     I                                        7   80AFNODD
      *
     I            DS
     I                                        1   80ADODHZ
     I                                        1   40ADODYY
     I                                        5   60ADODMM
     I                                        7   80ADODDD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  80
     C                     PARM           P@ORDD  80
     C                     PARM           P@PNDD  80
     C                     PARM           P@RCDD  80
     C                     PARM           P@MAIS  4
     C                     PARM           P#OPN   1
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEAFAPL82
     C                     CLOSEAFDPL11
     C                     CLOSEAFDPL24
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN AFAPL82
     C                     OPEN AFDPL11
     C                     OPEN AFDPL24
     C                     ENDIF
      *
     C                     MOVE P@CHYU    K@CHYU  1
     C                     MOVE P@ZENO    K@ZENO  4
     C                     MOVE P@THNO    K@THNO  3
     C                     MOVE P@HTHZ    K@HTHZ  80
      *
     C                     Z-ADD0         P@ORDD
     C                     Z-ADD0         P@RCDD
     C                     Z-ADD0         P@PNDD
     C                     MOVE *BLANK    P@MAIS
     C                     Z-ADD0         @CNT
      *
     C           AFAKEY    KLIST
     C                     KFLD           P@CHYU
     C                     KFLD           P@ZENO
     C                     KFLD           P@THNO
     C                     KFLD           P@PAGE
      *
     C           AFAKEY    SETLLAFAPL82
     C                     DO   *HIVAL
     C           AFAKEY    READEAFAPL82                  88
     C   88                LEAVE
     C           A8SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           A8SUHZ    IFLT K@HTHZ
     C                     ITER
     C                     END
     C           P@ORDD    IFEQ 0
     C                     Z-ADDA8DATE    P@ORDD
     C                     END
     C           P@PNDD    IFEQ 0
     C                     Z-ADDA8NYHZ    P@PNDD
     C                     END
     C           P@RCDD    IFEQ 0
     C                     Z-ADDA8NOHZ    P@RCDD
     C                     END
     C                     ADD  1         @CNT    40
     C                     END
      *
     C                     MOVE @CNT      P@MAIS
      *
     C           @CNT      IFEQ 0
     C                     EXSR #AFD
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
     C           #AFD      BEGSR
      *
     C           AFAKEY    SETLLAFDPL11
     C                     DO   *HIVAL
     C           AFAKEY    READEAFDPL11                  88
     C   88                LEAVE
     C           ADSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           ADODHZ    IFLT K@HTHZ
     C                     ITER
     C                     END
     C           P@ORDD    IFEQ 0
     C                     Z-ADDADODHZ    P@ORDD
     C                     END
     C                     SETON                     77
     C                     ADD  1         @CNT    40
     C                     END
      *
     C  N77                GOTO EAFD
      *
     C           AFDKEY    KLIST
     C                     KFLD           ADSUPP
     C                     KFLD           ADPAR1
     C                     KFLD           ADPAR2
     C                     KFLD           ADPAR3
     C                     KFLD           ADODYY
     C                     KFLD           ADODMM
     C                     KFLD           ADODDD
     C                     KFLD           ADBINN
      *
     C           AFDKEY    CHAINAFDPL24              44
     C           *IN44     IFEQ '0'
     C           P@PNDD    IFEQ 0
     C                     Z-ADDAFNYHZ    P@PNDD
     C                     END
     C           P@RCDD    IFEQ 0
     C                     Z-ADDAFNOHZ    P@RCDD
     C                     END
     C                     END
      *
     C           EAFD      ENDSR
