      **************************************************************************
     FALCPW01 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     FAKBPL01 IF  E           K        DISK
      *
     FALFPP01 IF  E           K        DISK                      A
      **************************************************************************
     E                    ERR     1  20 17
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
      * LOCATION
     I            DS
     I                                        1  10 WALOC
     I                                        1   4 WAZETI
     I                                        5  10 WALOC#
     I                                        5   5 WALC#1
     I                                        6   7 WALC#2
     I                                        8   9 WALC#3
     I                                       10  10 WALC#4
      *
      * ASJ KANBAN:KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
     I            DS
     I                                        1  17 WBKNBN
     I                                        1   1 WBKANS
     I                                        2   5 WBZETI
     I                                        6  11 WBORDR
     I                                       12  12 WBSEIH
     I                                       13  16 WBITEM
     I                                       17  17 WBCHKD
      *
      * FREEWAY KANBAN:KUBUN,ABSOLUTE#,SUPPLIER,ETC
     I            DS
     I                                        1  13 WCKNBN
     I                                        1   1 WCKANS
     I                                        2   5 WCZETI
     I                                        6   9 WCSUPP
     I                                       10  13 WCETC
      *
      * FREEWAY TAG:KUBUN,P#1,'-',P#2,'-',P#3
     I            DS
     I                                        1  15 WDKNBN
     I                                        1   1 WDKANS
     I                                        2   6 WDSHN1
     I                                        7   7 WDDASA
     I                                        8  12 WDSHN2
     I                                       13  13 WDDASB
     I                                       14  15 WDSHN3
      *
      * RETRIEVAL KANBAN:P#1,'-',P#2,'-',P#3
     I            DS
     I                                        1  15 WEKNBN
     I                                        1   5 WESHN1
     I                                        6   6 WEDASA
     I                                        7  11 WESHN2
     I                                       12  12 WEDASB
     I                                       13  14 WESHN3
     I            DS
     I                                        1  12 W1SHIN
     I                                        1   5 W1SHN1
     I                                        6  10 W1SHN2
     I                                       11  12 W1SHN3
     I            DS
     I                                        1  12 W2SHIN
     I                                        1   5 W2SHN1
     I                                        6  10 W2SHN2
     I                                       11  12 W2SHN3
     I            DS
     I                                        1  12 W3SHIN
     I                                        1   5 W3SHN1
     I                                        6  10 W3SHN2
     I                                       11  12 W3SHN3
     I            DS
     I                                        1  12 W4SHIN
     I                                        1   5 W4SHN1
     I                                        6  10 W4SHN2
     I                                       11  12 W4SHN3
     I            DS
     I                                        1  12 W5SHIN
     I                                        1   5 W5SHN1
     I                                        6  10 W5SHN2
     I                                       11  12 W5SHN3
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'00'      #FMT00
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #FMT30
     C           @@ID      CASEQ'40'      #FMT40
     C           @@ID      CASEQ'50'      #FMT50
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    W@DATE  80
     C                     Z-ADDWSSTM6    @@TIM   60
      *
     C                     CLEARFMT000
     C                     EXSR #CLRS
     C                     MOVEL*BLANK    W@ERR   1
      *
     C                     MOVEL'10'      @@ID    2
      * DUMMY READ
     C                     READ ALFPP01                  98
      *
     C                     ENDSR
      *************************************************************************
      *     TM-CODE ENTRY SCREEN
      **************************************************************************
     C           #FMT00    BEGSR
      *
     C                     EXFMTFMT000
     C                     MOVEL*BLANK    F0ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK00
     C           *IN99     IFEQ *OFF
     C                     MOVE '10'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     TM-CODE ENTRY SCREEN CHECK
      **************************************************************************
     C           #CHK00    BEGSR
      *
     C                     SETOF                     6199
      * TM-CODE CHECK
     C           F0USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     6199
     C           F0ERR     IFEQ *BLANK
     C                     MOVELERR,1     F0ERR
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     LOCATION SCREEN
      **************************************************************************
     C           #FMT20    BEGSR
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2ERR
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
      *
     C                     OTHER
     C                     Z-ADD*ZERO     W1BMON  40
     C                     EXSR #CHK20
      *
     C           *IN99     IFEQ *OFF
      *
     C           W1BMON    IFEQ 8990
     C                     MOVEL'20'      @@ID
     C                     ELSE
     C                     MOVE '30'      @@ID
     C                     ENDIF
      *
     C                     ELSE
     C           F2LOC     IFNE *BLANK
     C                     EXSR #WRTER
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     LOCATION SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     MOVEL*BLANK    W1SHIN
     C                     MOVELF1LOC     WALOC
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           WALOC     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
      *
     C           K#AKB     KLIST
     C                     KFLD           WALC#1
     C                     KFLD           WALC#2
     C                     KFLD           WALC#3
     C                     KFLD           WALC#4
      *
      *
     C           K#AKB     SETGTAKBPL01
      *
     C                     DO   *HIVAL
      *
     C           K#AKB     REDPEAKBPL01                  90
     C   90                LEAVE
      *
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           L1STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C           L1ZETI    IFNE WAZETI
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,5     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELL1SHN1    W1SHN1
     C                     MOVELL1SHN2    W1SHN2
     C                     MOVELL1SHN3    W1SHN3
     C                     Z-ADDL1BMON    W1BMON
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------------------*********
      *     FIELD CLEAR SUB
      *----------------------------------------------------------------*********
     C           #CLRS     BEGSR
      *
     C                     CLEARFMT100
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     CLEARFMT500
