      *     RETRIEVAL KANBAN SCREEN CHECK
      **************************************************************************
     C           #CHK50    BEGSR
      *
     C                     MOVEL*BLANK    W5SHIN
     C                     MOVELF5BARC    WEKNBN
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           WEKNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,6     F5ERR
     C                     MOVELERR,6     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELWESHN1    W5SHN1
     C                     MOVELWESHN2    W5SHN2
     C                     MOVELWESHN3    W5SHN3
      *
     C           W1SHIN    IFNE W5SHIN
