      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     FREEWAY/RK-METAL TAG SCREEN
      **************************************************************************
     C           #FMT40    BEGSR
      *
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK40
      *
     C           *IN99     IFEQ *OFF
      *
     C           WALC#2    IFEQ 'R1'
     C           WALC#2    OREQ 'R2'
     C           WALC#2    OREQ 'RK'
     C           WALC#2    OREQ 'RH'
     C           WALC#2    OREQ 'RJ'
     C           WALC#2    OREQ 'RL'
     C           WALC#2    OREQ 'RM'
     C           WALC#2    OREQ 'RN'
     C                     MOVE '50'      @@ID
     C                     ELSE
     C                     EXSR #WRTOK
     C                     EXSR #CLRS
     C                     MOVEL'10'      @@ID
     C                     EXFMTFMT900
     C                     ENDIF
      *
     C                     ELSE
     C                     EXSR #WRTER
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     FREEWAY/RK-METAL TAG SCREEN CHECK
      **************************************************************************
     C           #CHK40    BEGSR
      *
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVELF4BARC    WDKNBN
