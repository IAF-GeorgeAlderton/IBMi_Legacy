      *
     C                     DO
      *
     C           WDKNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,6     F4ERR
     C                     MOVELERR,6     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELWDSHN1    W4SHN1
     C                     MOVELWDSHN2    W4SHN2
     C                     MOVELWDSHN3    W4SHN3
      *
     C           W1SHIN    IFNE W4SHIN
     C                     SETON                     9961
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,10    F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
