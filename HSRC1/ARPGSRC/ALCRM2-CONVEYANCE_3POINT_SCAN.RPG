      **************************************************************************
     C           #FMT50    BEGSR
      *
     C                     EXFMTFMT500
     C                     MOVEL*BLANK    F5ERR
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
      *
     C                     OTHER
