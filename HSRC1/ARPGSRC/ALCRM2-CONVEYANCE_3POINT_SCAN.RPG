      **************************************************************************
      *       WRITE A OK RECORD
      **************************************************************************
     C           #WRTOK    BEGSR
      *
     C                     CLEARALFPP011
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A8DATE
     C                     Z-ADDWSSTM6    A8TIME
     C                     MOVEL#USER     A8USER
     C                     MOVEL#WSID     A8WSID
     C                     MOVEL#PGM      A8PGID
      *
     C                     MOVELF0USRC    A8TMCD
      *
     C                     MOVELW@ERR     A8ERR
     C           W1BMON    IFEQ 8990
     C                     MOVEL'A'       A8DKND
     C                     ENDIF
     C           W1BMON    IFEQ 2323
     C                     MOVEL'F'       A8DKND
     C                     ENDIF
     C           W1BMON    IFEQ 2525
     C                     MOVEL'R'       A8DKND
     C                     ENDIF
      *
     C                     MOVELW1SHN1    A8PRT1
     C                     MOVELW1SHN2    A8PRT2
     C                     MOVELW1SHN3    A8PRT3
      *
     C                     MOVELWALOC     A8BRC1
     C                     MOVELWAZETI    A8B1LZ
     C                     MOVELWALC#1    A8B1L1
     C                     MOVELWALC#2    A8B1L2
     C                     MOVELWALC#3    A8B1L3
     C                     MOVELWALC#4    A8B1L4
      *
     C           F2BARC    IFNE *BLANK
     C                     MOVELWBKNBN    A8BRC2
     C                     MOVELWBZETI    A8ZTI2
     C                     MOVELWBORDR    A8ODR2
     C                     MOVELWBITEM    A8ITM2
     C                     ENDIF
      *
     C           F3BARC    IFNE *BLANK
     C                     MOVELWCKNBN    A8BRC3
     C                     MOVELWCZETI    A8ZTI3
     C                     ENDIF
      *
     C           F4BARC    IFNE *BLANK
     C                     MOVELWDKNBN    A8BRC4
     C                     ENDIF
      *
     C           F5BARC    IFNE *BLANK
     C                     MOVELWEKNBN    A8BRC5
     C                     ENDIF
      *
     C           W@ERR     IFNE *BLANK
     C                     MOVELF99ER1    A8EM01
     C                     MOVELF99ER2    A8EM02
     C                     ENDIF
      *
     C                     WRITEALFPP011
      *
     C                     ENDSR
      **************************************************************************
      *       WRITE A ERROR RECORD
      **************************************************************************
     C           #WRTER    BEGSR
      *
     C                     MOVEL'E'       W@ERR
      *
     C                     EXSR #WRTOK
      *
     C                     MOVEL*BLANK    W@ERR
      *
     C                     ENDSR
      **************************************************************************
