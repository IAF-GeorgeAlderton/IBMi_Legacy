      *************************************************************************
      *     FREEWAY/RK-METAL KANBAN SCREEN
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     EXFMTFMT300
     C                     MOVEL*BLANK    F3ERR
      *
     C                     SELEC
      *
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK30
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE '40'      @@ID
     C                     ELSE
     C                     EXSR #WRTER
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     FREEWAY/RK-METAL KANBAN SCREEN CHECK
      **************************************************************************
     C           #CHK30    BEGSR
      *
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVELF3BARC    WCKNBN
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           WCKNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,6     F3ERR
     C                     MOVELERR,6     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C           WCSUPP    IFNE '2323'
     C           WCSUPP    ANDNE'2525'
     C                     SETON                     9961
     C                     MOVELERR,6     F3ERR
     C                     MOVELERR,6     F99ER1
     C                     MOVELERR,11    F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C           WCZETI    IFNE WAZETI
     C                     SETON                     9961
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,10    F99ER2
