     H            Y.
     F** ABMR4F *********************************************
     F*構成品から親品番検索→調整取得
     F*   SAKAKI.       2019.09.23                          *
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.09|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F*2021.03.23|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F*****************************************************************
     FMCENP13 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
     FAAHTL06 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20WTITH
     I                                        3   40WTITM
     I                                        5   60WTITS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I            DS
     I                                        1   60@@YM
     I                                        1   40@YY
     I                                        5   60@MM
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PKMHN1  5
     C                     PARM           PKMHN2  5
     C                     PARM           PKMHN3  2
     C                     PARM           PKHAKO  90
      *
     C                     MOVELPKMHN1    #KMHN1
     C                     MOVELPKMHN2    #KMHN2
     C                     MOVELPKMHN3    #KMHN3
     C                     Z-ADD0         PKHAKO
     C                     EXSR #SB400
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      * MCENP13より親品番       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYMD1    KLIST
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C           KEYMD1    SETLLMCENP131
     C           KEYMD1    READEMCENP131                 83
     C           *IN83     DOWEQ'0'
     C                     EXSR #SB700
     C           KEYMD1    READEMCENP131                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *---------------------------*
      * AAFPP01,AAHPP01から調整枚数
      *---------------------------*
     CSR         #SB700    BEGSR
      *
     C           KEYA31    KLIST
     C                     KFLD           MCSHN1  5
     C                     KFLD           MCSHN2  5
     C                     KFLD           MCSHN3  2
     C           KEYA31    SETGTAAFTL061
     C           KEYA31    REDPEAAFTL061                 82
     C           *IN82     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3STHZ    IFEQ 99999999
     C***        A3KMAX    IFEQ 999
     C           A3KMAX    IFEQ 99999
     C                     ELSE
     C                     ADD  A3DUPH    PKHAKO
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAAFTL061                 82
     C                     ENDDO
      *
     C           KEYA31    SETGTAAHTL061
     C           KEYA31    REDPEAAHTL061                 82
     C           *IN82     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6STHZ    IFEQ 99999999
     C***        L6KMAX    IFEQ 999
     C           L6KMAX    IFEQ 99999
     C                     ELSE
     C                     ENDIF
     C                     ADD  L6DUPH    PKHAKO
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAAHTL061                 82
     C                     ENDDO
      *
     CSR         ESB700    ENDSR
