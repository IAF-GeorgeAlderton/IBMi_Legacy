     H            Y.
      ** AFFR74 ******************************************************
      *  PROGRAM    : DELETE ABBPP60                                 *
      *  WRITTEN    : JW (SRA) 2024.06.11                            *
      ****************************************************************
     FAFFWP71 IF  E           K        DISK
     FABBPL61 UF  E           K        DISK
      *----------------------------------------------------*
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1  20 ABMHIN
     I                                        1   5 ABMHN1
     I                                        6  10 ABMHN2
     I                                       11  15 ABMHN3
     I                                       16  20 ABMHN4
      *
     I            DS
     I                                        1   80ABSKHZ
     I                                        1   40ABSKYY
     I                                        5   60ABSKMM
     I                                        7   80ABSKDD
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
     C                     TIME           WSDT
     C                     MOVE 'Y'       FIRST   1
      * READ AFFWP71
     C                     DO   *HIVAL
     C                     READ AFFWP71                  98
     C   98                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDAFNONY    SVNONY  40
     C                     MOVELAFNUKE    SVNUKE  4
     C                     MOVELAFMHIN    SVMHIN 20
     C                     ENDIF
      * BREAK?
     C           AFNONY    IFNE SVNONY
     C           AFNUKE    ORNE SVNUKE
     C           AFMHIN    ORNE SVMHIN
     C                     EXSR #BRK1
     C                     ENDIF
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DELETE PP60
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C           SVNONY    SETLLABBPL61
     C                     DO   *HIVAL
     C           SVNONY    READEABBPL61                  98
     C   98                LEAVE
      *
     C           ABSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           ABNUKE    IFEQ SVNUKE
     C           ABMHIN    ANDEQSVMHIN
     C                     MOVE 'D'       ABSKJY
     C                     Z-ADDTODAY     ABSKHZ
     C                     MOVEL#PGM      ABKOME
     C                     UPDATABBPL611
     C                     ENDIF
     C                     ENDDO
      * RESET
     C                     Z-ADDAFNONY    SVNONY
     C                     MOVELAFNUKE    SVNUKE
     C                     MOVELAFMHIN    SVMHIN
      *
     C                     ENDSR
