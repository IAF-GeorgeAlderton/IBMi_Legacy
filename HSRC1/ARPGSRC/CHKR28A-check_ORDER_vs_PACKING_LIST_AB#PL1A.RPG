     H            Y.
     F***CHKR28A****************************************************************
     F*  PROGRAM    : CHECK ORDER VS PACKING LIST                              *
     F*             : READ AB#PP10 AND DETECT SERL=BLANK                       *
     F*  WRITTEN    : JW   2024.03.13                                          *
     F**************************************************************************
     FAB#PL1A IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------
     E                    NY       1000  4 0
     I            DS
     I                                        1  140@DATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C                     EXSR @INIT
      *
     C           TODAY     SETLLAB#PL1A
     C                     DO   *HIVAL
     C                     READ AB#PL1A                  98
     C   98                LEAVE
      *
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDBANONY    SVNONY  40
     C                     MOVELBANKOJ    SVNKOJ  1
     C                     MOVELBANUKE    SVNUKE  4
     C                     Z-ADDBANOHZ    SVNOHZ  80
     C                     Z-ADDBANOBN    SVNOBN  20
     C                     Z-ADD0         ODCNT   30
     C                     Z-ADD0         PLCNT   30
     C                     ENDIF
      * BREAK?
     C           BANONY    IFNE SVNONY
     C           BANKOJ    ORNE SVNKOJ
     C           BANUKE    ORNE SVNUKE
     C           BANOHZ    ORNE SVNOHZ
     C           BANOBN    ORNE SVNOBN
     C                     EXSR #BRK
     C                     ENDIF
      * PROCESS
     C                     ADD  1         ODCNT
     C           BASERL    IFNE *BLANK
     C                     ADD  1         PLCNT
     C                     ENDIF
     C                     ENDDO
      * LAST PROCESS
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK      BEGSR
      *
     C           ODCNT     IFNE PLCNT
     C                     EXSR #PRINT
     C                     ENDIF
      * RESET
     C                     Z-ADDBANONY    SVNONY
     C                     MOVELBANKOJ    SVNKOJ
     C                     MOVELBANUKE    SVNUKE
     C                     Z-ADDBANOHZ    SVNOHZ
     C                     Z-ADDBANOBN    SVNOBN
     C                     Z-ADD0         ODCNT
     C                     Z-ADD0         PLCNT
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           @RTN    1
      *
     C                     MOVE *BLANK    @RTN
     C                     TIME           @DATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         CNT     40
      *
     C                     ENDSR
      ************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** OLD AND NEW ORDE '
     O                                   60 'R MIX LIST **       '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'DEL#'
     O                                   21 'SHP_DATE'
     O                                   27 'BIN'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         BANONY  +001
     O                         BANOHZ  +003
     O                         BANOBN  +003
