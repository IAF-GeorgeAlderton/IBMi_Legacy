     H            Y.
     F** ABMR1B *********************************************
     F* PASS THROUGH / OUTSOURCE CHECK
     F*    HOTTA.               2018.08.06                  *
     F*******************************************************
     FAAPTL01 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAKBPL07 IF  E           K        DISK
     E                    OBM        15  4               部門
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   60W@DTYM
     I                                        1   40W@DTYY
     I                                        5   60W@DTMM
     I                                        7   80W@DTDD
      *
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
      *
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
     C                     PARM           P@PAS   1
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C           KEYSHN    KLIST
     C                     KFLD           P@SHN1
     C                     KFLD           P@SHN2
     C                     KFLD           P@SHN3
     C                     MOVEL'0'       P@PAS
      *
     C           KEYSHN    SETGTAAPTL011
     C           KEYSHN    REDPEAAPTL011                 82
     C           *IN82     DOWEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ELSE
     C           L5STHZ    IFEQ 99999999
     C           L5BMON    ANDEQ8990
     C                     MOVEL'1'       P@PAS
     C                     ENDIF
     C                     ENDIF
     C           KEYSHN    REDPEAAPTL011                 82
     C                     ENDDO
      *
     C           KEYSHN    SETGTAANPL061
     C           KEYSHN    REDPEAANPL061                 82
     C           *IN82     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7STHZ    IFEQ 99999999
     C           L7BMON    ANDEQ8990
     C                     MOVEL'1'       P@PAS
     C                     ENDIF
     C                     ENDIF
     C           KEYSHN    REDPEAANPL061                 82
     C                     ENDDO
      *
     C           KEYSHN    SETGTAKBPL071
     C           KEYSHN    REDPEAKBPL071                 82
     C           *IN82     DOWEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
     C           L1STHZ    IFEQ 99999999
     C           L1BMON    ANDEQ8990
     C                     MOVEL'1'       P@PAS
     C                     ENDIF
     C                     ENDIF
     C           KEYSHN    REDPEAKBPL071                 82
     C                     ENDDO
      *
     C                     CALL 'ABMR42'
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
     C                     PARM           P9BMON  40
     C                     PARM           P9PROC  3
     C                     PARM           P9PASS  1
     C           P9PASS    IFEQ '2'
     C                     MOVELP9PASS    P@PAS
     C                     ENDIF
      *
     C           P@PAS     IFEQ '0'
     C                     MOVEL'1'       OPNCLS
     C                     EXSR #SB390
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *工程情報                         *
      *-----------------------------------*
     CSR         #SB390    BEGSR
      *
     C                     CLEAROBM
     C                     MOVELP@SHN1    CBSHN1  5
     C                     MOVELP@SHN2    CBSHN2  5
     C                     MOVELP@SHN3    CBSHN3  2
     C                     MOVEL*DATE     INYMDB
     C                     MOVE '01'      INYMDB
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C           STATUS    IFEQ '9'
     C                     GOTO ESB390
     C                     ENDIF
      *
     C                     MOVEAPBMN      OBM
     C                     Z-ADD1         A       30
     C           A         DOWLE15
     C           OBM,A     IFNE '0111'
     C           OBM,A     ANDNE'8990'
     C                     MOVEL'3'       P@PAS
     C                     LEAVE
     C                     ENDIF
     C                     ADD  1         A
     C                     ENDDO
      *
     CSR         ESB390    ENDSR
