     C           *ENTRY    PLIST
     C                     PARM           P@SIRE  4          VENDOR
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
      * WIRE
     C                     EXSR #OUT1
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#GL1     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#GL2     KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           K#MC      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C           K#AB      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C                     KFLD           K@YY10
     C                     KFLD           K@MM10
     C                     KFLD           K@DD10
     C           K#ABX     KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           I#AGD     KLIST
     C                     KFLD           I@YY
     C                     KFLD           I@MM
     C                     KFLD           I@DD
     C           KEY2      KLIST
     C                     KFLD           W#HIN1
     C                     KFLD           W#HIN2
     C                     KFLD           W#HIN3
      *
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     MOVE *BLANK    A2KEY
     C                     MOVE *ALL'-'   @@LIN1132
     C                     MOVE *ALL'-'   @@LIN2 66
     C           *LIKE     DEFN MCSHN1    K@SHN1
     C           *LIKE     DEFN MCSHN2    K@SHN2
     C           *LIKE     DEFN MCSHN3    K@SHN3
      * IAF CALENDER
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL121
     C                     Z-ADD*ZERO     M       30
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL121                 90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         M
     C                     SELEC
     C           M         WHEQ 1
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C           M         WHEQ 5
     C                     Z-ADDF8KAYY    K@YY5
     C                     Z-ADDF8KAMM    K@MM5
     C                     Z-ADDF8KADD    K@DD5
     C           M         WHEQ 10
     C                     Z-ADDF8KAYY    K@YY10
     C                     Z-ADDF8KAMM    K@MM10
     C                     Z-ADDF8KADD    K@DD10
     C           M         WHEQ 20
     C                     Z-ADDF8KAYY    K@YY20
     C                     Z-ADDF8KAMM    K@MM20
     C                     Z-ADDF8KADD    K@DD20
     C                     LEAVE
     C                     ENDSL
     C                     ENDIF
     C                     ENDDO
      * ASJ CALENDER
     C                     Z-ADD*DATE     I@YMD
     C           I#AGD     SETLLA#DPL12
     C                     Z-ADD*ZERO     M       30
     C           *IN90     DOUEQ*ON
     C                     READPA#DPL12                  90
     C           *IN90     IFEQ *OFF
     C           I8HIRU    ANDEQ*BLANK
     C                     ADD  1         M
     C                     SELEC
     C           M         WHEQ 1
     C                     Z-ADDI8KAYY    I@YY
     C                     Z-ADDI8KAMM    I@MM
     C                     Z-ADDI8KADD    I@DD
     C           M         WHEQ 5
     C                     Z-ADDI8KAYY    I@YY5
     C                     Z-ADDI8KAMM    I@MM5
     C                     Z-ADDI8KADD    I@DD5
     C           M         WHEQ 10
     C                     Z-ADDI8KAYY    I@YY10
     C                     Z-ADDI8KAMM    I@MM10
     C                     Z-ADDI8KADD    I@DD10
     C           M         WHEQ 20
     C                     Z-ADDI8KAYY    I@YY20
     C                     Z-ADDI8KAMM    I@MM20
     C                     Z-ADDI8KADD    I@DD20
     C                     LEAVE
     C                     ENDSL
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PART
      *------------------------------------------------------
     C           #OUT1     BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     MOVELTTL,1     HEDR   30
     C                     MOVELP@FACT    HEDR
     C                     MOVE *ON       *IN50
      *
     C           *IN80     DOUEQ*ON
     C                     READ FCEPL01                  80
     C           *IN80     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
      * IMPORT?
      * SUPPLIER IS '8990'?
     C                     MOVEL*BLANK    @GET    1
     C           A2KEY     SETGTGDKPL04
     C                     DO   *HIVAL
     C           A2KEY     REDPEGDKPL04                  91
     C   91                LEAVE
     C*
     C           ISSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           ISENHZ    IFGT *DATE
     C                     MOVEL'1'       @GET
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C           @GET      IFEQ *BLANK
     C                     ITER
     C                     ENDIF
     C**
      **
     C                     MOVE A2BHB1    P$HIN1  5        PART NO1
     C                     MOVE A2BHB2    P$HIN2  5        PART NO2
     C                     MOVE A2BHB3    P$HIN3  2        PART NO3
      ** BTAPL05  PT PLAN PUBLICATION CALC
     C                     MOVE A2BHB1    W#HIN1  5        PART NO1
     C                     MOVE A2BHB2    W#HIN2  5        PART NO2
     C                     MOVE A2BHB3    W#HIN3  2        PART NO3
     C                     EXSR #PLAN                      工場CHECK
      **
     C                     Z-ADD0         @AJST   30
     C           K#GL1     CHAINBTAPP411             70
     C           *IN70     IFEQ '0'
     C           B4SKJY    IFEQ 'D'
     C           B4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-SUBB4MAIS    @AJST
     C                     ENDIF
     C                     ENDIF
      *
      * SUM LAST 5/10/20 DAYS ORDER
     C                     Z-ADD*ZERO     @COUNT  30
     C                     Z-ADD*ZERO     @SUM5   50
     C                     Z-ADD*ZERO     @SUM10  50
     C                     Z-ADD*ZERO     @SUM20  50
     C           K#GL1     SETGTGDGPL19
     C                     DO   *HIVAL
     C           K#GL1     REDPEGDGPL19                  91
     C   91                LEAVE
     C*
     C           ICSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C*
     C           ICODHZ    IFLT I@DT20
     C                     LEAVE
     C                     ENDIF
     C*
     C                     SELEC
     C           ICODHZ    WHGE I@DT5
     C                     ADD  ICMAIS    @SUM5
     C                     ADD  ICMAIS    @SUM10
     C                     ADD  ICMAIS    @SUM20
     C                     ADD  1         @COUNT
     C           ICODHZ    WHGE I@DT10
     C                     ADD  ICMAIS    @SUM10
     C                     ADD  ICMAIS    @SUM20
     C                     ADD  1         @COUNT
     C           ICODHZ    WHGE I@DT20
     C                     ADD  ICMAIS    @SUM20
     C                     ADD  1         @COUNT
     C                     OTHER
     C                     LEAVE
     C                     ENDSL
     C*
     C                     ENDDO
      * THEN OUTPUT
     C                     Z-ADD*ZERO     @MAIS
     C                     Z-ADD*ZERO     @ORDR   60
     C           K#GL1     SETGTGDGPL19
     C           *IN91     DOUEQ*ON
     C           K#GL1     REDPEGDGPL19                  91
     C           *IN91     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C                     Z-ADDICMAIS    @MAIS   50
     C                     Z-ADDICODER    @ORDR
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     EXSR #PRT1
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT THE LIST
      *------------------------------------------------------
     C           #PRT1     BEGSR
      *
     C  N98
     COR OF                EXCPT@HED1
     C  N98                MOVE *ON       *IN98
      *
     C           A2BHB2    COMP *BLANK               0101
     C           A2BHB3    COMP *BLANK               0202
      *
      * DAILY USAGE X 5 = WEEKLY USAGE
     C           K#GL1     CHAINFCEPL11              90
     C           *IN90     IFEQ *OFF
     C           FCCD01    ANDNE*ZERO
     C           FCGK01    DIV  FCCD01    @@WQY   70
     C           @@WQY     DIV  A2SSYS    @@BOX   72
      *
     C                     MOVE A2BHB1    K@SHN1
     C                     MOVE A2BHB2    K@SHN2
     C                     MOVE A2BHB3    K@SHN3
     C                     Z-ADD*ZERO     @SHQY
     C                     EXSR #ACT
     C           A2SSYS    IFNE *ZERO
     C           @SHQY     DIV  A2SSYS    @BOX10  72
     C           @BOX10    DIV  10        @@ABOX  72
     C                     ENDIF
      *
      * CALC SET# ORDER % (LAST 5DAYS)
     C           @@ABOX    MULT 5         @I      72
     C           @I        IFEQ 0
     C                     Z-ADD1         @I
     C                     ENDIF
     C           @SUM5     DIV  @I        @I2     72
     C           @I2       MULT 100       @AVE5   40
      * CALC SET# ORDER % (LAST 10DAYS)
     C           @@ABOX    MULT 10        @I10    72
     C           @I10      IFEQ 0
     C                     Z-ADD1         @I10
     C                     ENDIF
     C           @SUM10    DIV  @I10      @I11    72
     C           @I11      MULT 100       @AVE10  40
      * CALC SET# ORDER % (LAST 20DAYS)
     C           @@ABOX    MULT 20        @I20    72
     C           @I20      IFEQ 0
     C                     Z-ADD1         @I20
     C                     ENDIF
     C           @SUM20    DIV  @I20      @I21    72
     C           @I21      MULT 100       @AVE20  40
      *
     C           @AVE5     IFLT 90
     C           @AVE10    ANDLT90
     C           @AVE20    ANDLT90
     C           @@BOX     ANDNE0
     C           @@ABOX    ANDNE0
      *
     C                     EXCPT@DTL1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WASHER
      *------------------------------------------------------
     C           #OUT2     BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     MOVELTTL,2     HEDR   30
     C                     MOVELP@FACT    HEDR
     C                     MOVE *OFF      *IN50
      *
     C           *IN80     DOUEQ*ON
     C                     READ AKBPL04                  80
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STYY    ANDEQ9999
     C**
     C           P@FACT    IFEQ 'ATC'                      工場
     C           L1BMON    IFNE 0002
     C           L1BMON    ANDNE0094
     C                     ITER
     C                     ENDIF
     C                     ELSE
     C           L1BMON    IFNE 8990
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      ** BTAPL05  PT PLAN PUBLICATION CALC
     C                     MOVE L1SHN1    W#HIN1  5        PART NO1
     C                     MOVE L1SHN2    W#HIN2  5        PART NO2
     C                     MOVE L1SHN3    W#HIN3  2        PART NO3
     C                     EXSR #PLAN                      工場CHECK
     C**
     C                     Z-ADD0         @AJST   30
     C           K#GL2     CHAINBTAPP411             70
     C           *IN70     IFEQ '0'
     C           B4SKJY    IFEQ 'D'
     C           B4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-SUBB4MAIS    @AJST   30
     C                     ENDIF
     C                     ENDIF
      *
      * SUM LAST 5/10/20 DAYS ORDER
     C                     Z-ADD*ZERO     @COUNT  30
     C                     Z-ADD*ZERO     @SUM5   50
     C                     Z-ADD*ZERO     @SUM10  50
     C                     Z-ADD*ZERO     @SUM20  50
     C           K#GL2     SETGTGDGPL19
     C                     DO   *HIVAL
     C           K#GL2     REDPEGDGPL19                  91
     C   91                LEAVE
     C*
     C           ICSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C*
     C           ICODHZ    IFLT I@DT20
     C                     LEAVE
     C                     ENDIF
     C*
     C                     SELEC
     C           ICODHZ    WHGE I@DT5
     C                     ADD  ICMAIS    @SUM5
     C                     ADD  ICMAIS    @SUM10
     C                     ADD  ICMAIS    @SUM20
     C                     ADD  1         @COUNT
     C           ICODHZ    WHGE I@DT10
     C                     ADD  ICMAIS    @SUM10
     C                     ADD  ICMAIS    @SUM20
     C                     ADD  1         @COUNT
     C           ICODHZ    WHGE I@DT20
     C                     ADD  ICMAIS    @SUM20
     C                     ADD  1         @COUNT
     C                     OTHER
     C                     LEAVE
     C                     ENDSL
     C*
     C                     ENDDO
      * THEN OUTPUT
      * THEN OUTPUT
     C                     Z-ADD*ZERO     @MAIS
     C                     Z-ADD*ZERO     @ORDR
     C           K#GL2     SETGTGDGPL19
     C           *IN91     DOUEQ*ON
     C           K#GL2     REDPEGDGPL19                  91
     C           *IN91     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C                     Z-ADDICMAIS    @MAIS   50
     C                     Z-ADDICODER    @ORDR
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     EXSR #PRT2
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT THE LIST
      *------------------------------------------------------
     C           #PRT2     BEGSR
      *
     C  N98
     COR OF                EXCPT@HED1
     C  N98                MOVE *ON       *IN98
      *
     C           L1SHN2    COMP *BLANK               0101
     C           L1SHN3    COMP *BLANK               0202
      *
      * DAILY USAGE X 5 = WEEKLY USAGE
     C                     Z-ADD*ZERO     W@QTY   90
     C                     Z-ADD*ZERO     @SHQY   90
     C           K#GL2     SETLLMCENP13
     C           *IN98     DOUEQ*ON
     C           K#GL2     READEMCENP13                  98
B01  C           *IN98     IFEQ *OFF
     C                     MOVE MCSHN1    K@SHN1
     C                     MOVE MCSHN2    K@SHN2
     C                     MOVE MCSHN3    K@SHN3
     C                     EXSR #USG
     C                     EXSR #ACT
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDW@QTY     @@WQY   70
     C*******    W@QTY     MULT 5         @@WQY   70
     C           @@WQY     DIV  L1SYOS    @@BOX   72
     C           L1SYOS    IFNE *ZERO
     C           @SHQY     DIV  L1SYOS    @BOX10  72
     C           @BOX10    DIV  10        @@ABOX  72
     C                     ENDIF
      * CALC SET# ORDER % (LAST 5DAYS)
     C           @@ABOX    MULT 5         @I      72
     C           @I        IFEQ 0
     C                     Z-ADD1         @I
     C                     ENDIF
     C           @SUM5     DIV  @I        @I2     72
     C           @I2       MULT 100       @AVE5   40
      *
      * CALC SET# ORDER % (LAST 10DAYS)
     C           @@ABOX    MULT 10        @I10    72
     C           @I10      IFEQ 0
     C                     Z-ADD1         @I10
     C                     ENDIF
     C           @SUM10    DIV  @I10      @I11    72
     C           @I11      MULT 100       @AVE10  40
      * CALC SET# ORDER % (LAST 20DAYS)
     C           @@ABOX    MULT 20        @I20    72
     C           @I20      IFEQ 0
     C                     Z-ADD1         @I20
     C                     ENDIF
     C           @SUM20    DIV  @I20      @I21    72
     C           @I21      MULT 100       @AVE20  40
      *
     C           @AVE5     IFLT 90
     C           @AVE10    ANDLT90
     C           @AVE20    ANDLT90
     C           @@BOX     ANDNE0
     C           @@ABOX    ANDNE0
     C                     EXCPT@DTL2
     C                     ENDIF
      *
     C                     ENDSR
