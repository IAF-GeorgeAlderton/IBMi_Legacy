      *   DAILY USAGE
      *------------------------------------------------------
     C           #USG      BEGSR
      *
     C           K#MC      CHAINFCEPL11              90
     C           *IN90     IFEQ *OFF
     C           FCCD01    ANDNE*ZERO
     C           FCGK01    DIV  FCCD01    @@QTY   70
     C                     ADD  @@QTY     W@QTY
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  ACTUAL
      *-----------------------------------------------------------
     C           #ACT      BEGSR
      *
     C           K#AB      SETLLAB#PL18
     C           *IN91     DOUEQ*ON
     C           K#ABX     READEAB#PL18                  91
     C           *IN91     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           ABYMD     IFGE *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  BASRYO    @SHQY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================
      *   GET PT PLAN PUBLICATION CALCURATION
      *================================================================
     C           #PLAN     BEGSR
     C*
     C                     Z-ADD0         @TOTL   40
     C           KEY2      SETLLBTAPL051
     C                     DO   *HIVAL
     C           KEY2      READEBTAPL051                 91
     C   91                LEAVE
     C*
     C           BTSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADD1         A       20
     C           1         DO   31        A
     C*
     C           #PH,A     IFNE *ZERO
     C           #MH,A     ORNE *ZERO
     C           #ZM,A     IFEQ *BLANK
     C*                    Z-ADDA         LDDDD
     C                     Z-SUB#MH,A     LMINU   30
     C                     Z-ADD#PH,A     LPLUS   30
     C           LMINU     ADD  LPLUS     LTOTL   30
     C                     ADD  LTOTL     @TOTL
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *================================================================
