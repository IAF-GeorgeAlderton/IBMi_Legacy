     H            Y.
     F** AL#RCA **************************************
     F*トラック便変更時に関連データ更新            *
     F*        ITS.         2015.05.26               *
     F************************************************
     FAL#PL41 UF  E           K        DISK
     FAL#PL05 UF  E           K        DISK
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C           KEYC7     KLIST
     C                     KFLD           KKNKHZ  80
     C                     KFLD           KKNKTI  60
      *発行前
     C                     Z-ADD0         KKNKHZ
     C                     Z-ADD0         KKNKTI
     C           KEYC7     SETLLAL#PL411
     C           KEYC7     READEAL#PL411                 81
     C           *IN81     DOWEQ'0'
     C           C4SKJY    IFEQ 'D'
     C           C4SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB390
     C                     ENDIF
     C           KEYC7     READEAL#PL411                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *トラック便が変更された
      *-----------------------------------------------------
     CSR         #SB390    BEGSR
      *
     C                     MOVEL*BLANK    P9TRKB
     C                     CALL 'AL#RC9'
     C                     PARM           C4SURT
     C                     PARM           P9TRKB  2
     C           C4TRKB    IFNE P9TRKB
     C                     EXSR #SB400
     C                     Z-ADDSDATE     C4KOHZ
     C                     Z-ADDSTIME     C4KOTI
     C                     MOVELW#USER    C4KOME
     C                     MOVELP9TRKB    C4TRKB
     C                     UPDATAL#PL411
     C                     ENDIF
      *
     CSR         ESB390    ENDSR
      *-----------------------------------------------------
      *  AL#PP01
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           C4FIXD
     C                     KFLD           C4FIXT
     C                     KFLD           C4TRKB
     C                     KFLD           C4IAFB
      *
     C           KEYC1     SETLLAL#PL051
     C           KEYC1     READEAL#PL051                 81
     C           *IN81     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C                     Z-ADDSDATE     CAKOHZ
     C                     Z-ADDSTIME     CAKOTI
     C                     MOVELW#USER    CAKOME
     C                     MOVELP9TRKB    CATRKB
     C                     UPDATAL#PL051
     C                     ENDIF
     C           KEYC1     READEAL#PL051                 81
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
