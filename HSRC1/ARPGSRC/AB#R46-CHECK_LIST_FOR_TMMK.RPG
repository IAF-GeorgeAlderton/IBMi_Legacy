     H            Y.
     F** AB#R46 ********************************************
     F*  CONTAINER CHECK LIST                              *
     F*-----------------------------------                 *
JW1  F*  JW       2023.04.05 ADD PARAMETER                 *
     F******************************************************
     FABWPL33 IP  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *--------------------------------------------------------
     E                    SB        260  4
     E                    KB        260  5 0
     E                    SA        260  4
     E                    KA        260  5 0
     E                    SBN         5  4
     E                    BOX         5  5 0
      *--------------------------------------------------------
     IAB#PP311    01
     I                                              INUKE L3
     I                                              IINV# L3
     I                                              ISBAN L1
     I                                              IMHN  L1
     I            DS
     I                                        1   80INOHZ
     I                                        1   40YYYY
     I                                        5   60MM
     I                                        7   80DD
     I            DS
     I                                        1   4 ISBAN
     I                                        2   2 SS
     I            DS
     I                                        1  10 WNOHZ
     I                                        1   2 WNOMM
     I                                        3   3 WNO1
     I                                        4   5 WNODD
     I                                        6   6 WNO2
     I                                        7  10 WNOYY
     I            DS
     I                                        1   60WTIME
     I                                        1   20THH
     I                                        3   40TMM
     I                                        5   60TSS
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===========================================================
JW1  C           *ENTRY    PLIST
 .   C                     PARM           PNONY   4
 .    *
JW1  C                     MOVELINONY     PNONY
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE *ALL'-'   @LINE  79
     C                     MOVE *ON       *IN99
     C                     MOVE *BLANK    SB
     C                     Z-ADD*ZERO     KB
     C                     Z-ADD*ZERO     X       30
     C                     Z-ADD200       Z       30
     C                     ENDIF
      *
     C           *INL3     IFEQ *ON
     C           *INOF     OREQ *ON
     C                     MOVELIINV#     WIVNO  16
     C                     EXSR #HED
     C                     ENDIF
      *
     C           SS        IFGE '0'
     C           SS        ANDLE'9'
     C                     ADD  1         X
     C                     MOVELISBAN     SB,X
     C                     ADD  FC#BOX    KB,X
     C                     ELSE
     C                     ADD  1         Z
     C                     MOVELISBAN     SB,Z
     C                     ADD  FC#BOX    KB,Z
     C                     ENDIF
      *
     CL3                   EXSR #DTL
      *--------------------------------------------------
     C           #HED      BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE YYYY      WNOYY
     C                     MOVE MM        WNOMM
     C                     MOVE DD        WNODD
     C                     MOVE '/'       WNO1
     C                     MOVE '/'       WNO2
      *
     C                     EXCPT@HED
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #DTL      BEGSR
      *
     C                     MOVE *BLANK    SA
     C                     Z-ADD*ZERO     KA
     C                     Z-ADD*ZERO     Z
     C           1         DO   260       X
     C           SB,X      IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVE SB,X      SA,Z
     C                     Z-ADDKB,X      KA,Z
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     Y1      30
     C                     Z-ADD52        Y2      30
     C                     Z-ADD104       Y3      30
     C                     Z-ADD156       Y4      30
     C                     Z-ADD208       Y5      30
     C                     DO   52
     C                     MOVE *BLANK    SBN
     C                     Z-ADD*ZERO     BOX
     C                     ADD  1         Y1
     C                     ADD  1         Y2
     C                     ADD  1         Y3
     C                     ADD  1         Y4
     C                     ADD  1         Y5
     C           SA,Y1     IFEQ *BLANK
     C           SA,Y2     ANDEQ*BLANK
     C           SA,Y3     ANDEQ*BLANK
     C           SA,Y4     ANDEQ*BLANK
     C           SA,Y5     ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE SA,Y1     SBN,1
     C                     MOVE SA,Y2     SBN,2
     C                     MOVE SA,Y3     SBN,3
     C                     MOVE SA,Y4     SBN,4
     C                     MOVE SA,Y5     SBN,5
     C                     Z-ADDKA,Y1     BOX,1
     C                     Z-ADDKA,Y2     BOX,2
     C                     Z-ADDKA,Y3     BOX,3
     C                     Z-ADDKA,Y4     BOX,4
     C                     Z-ADDKA,Y5     BOX,5
     C                     EXCPT@DTL
     C                     ENDDO
      *
     C                     Z-ADD200       Z       30
     C                     Z-ADD*ZERO     X
     C                     MOVE *BLANK    SB
     C                     Z-ADD*ZERO     KB
      *
     C                     ENDSR
      *
     OQPRINT  E   02           @HED
     O                         #PGM      10
     O                                   60 'CONTAINER CHECK LIST'
     O                                   75 'P.'
     O                         PAGE  Z   79
     O        E   03           @HED
     O                         UDATE Y   70
     O                         WTIME     79 '  :  :  '
     O        E   04           @HED
     O                                   10 'SHIP TO:'
     O                         INONY     15
     O                         INKOJ     17
     O                         INUKE     22
     O                                   35 'SHIP DATE:'
     O                         WNOHZ     46
     O                         INOTM     49
     O        E   05           @HED
     O                                   12 'DELIVERY#:'
     O                         WIVNO     29
     O        E   06           @HED
     O                                    7 'KBAN'
     O                                   13 'BOXES'
     O                                   23 'KBAN'
     O                                   29 'BOXES'
     O                                   39 'KBAN'
     O                                   45 'BOXES'
     O                                   55 'KBAN'
     O                                   61 'BOXES'
     O                                   71 'KBAN'
     O                                   77 'BOXES'
     O        E   07           @HED
     O                         @LINE     80
     O        E 1              @DTL
     O                         SBN,1      7
     O                         BOX,1 4   13
     O                         SBN,2     23
     O                         BOX,2 4   29
     O                         SBN,3     39
     O                         BOX,3 4   45
     O                         SBN,4     55
     O                         BOX,4 4   61
     O                         SBN,5     71
     O                         BOX,5 4   77
