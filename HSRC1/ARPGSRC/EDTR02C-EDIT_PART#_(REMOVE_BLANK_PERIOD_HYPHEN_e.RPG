     H            Y.
     F** EDTR02C ***************************************
     F*  EDIT PART# (REMOVE BLANK PERIOD HYPHEN ETC.)  *
     F*  J.WATANABE    2023.09.27                      *
     F*------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDTR02C'
     F*                    PARM           $FLD1  25
     F*                    PARM           $FLD2  25
     F*  IN  $FLD1 : 25A CONTAINS "-"
     F*  OUT $FLD2 : 25A NOT CONTAIN "-"
     F**************************************************
     E                    VAL     1   2  1
     E                    FD1        25  1
     E                    FD2        25  1
      *
     C           *ENTRY    PLIST
     C                     PARM           $FLD1  25
     C                     PARM           $FLD2  25
      *
     C                     MOVEA*BLANK    FD1
     C                     MOVEA*BLANK    FD2
      *
     C                     MOVEA$FLD1     FD1
     C                     Z-ADD0         IY      20
      *
     C           1         DO   25        IX      20
     C           FD1,IX    IFEQ *BLANK
     C           FD1,IX    OREQ '-'
     C           FD1,IX    OREQ '.'
     C           FD1,IX    OREQ ','
     C           FD1,IX    OREQ '#'
     C           FD1,IX    OREQ '@'
     C           FD1,IX    OREQ VAL,1
     C           FD1,IX    OREQ VAL,2
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         IY
     C                     MOVE FD1,IX    FD2,IY
     C                     ENDDO
      *
     C                     MOVEAFD2       $FLD2
      *
     C                     SETON                     LR
     C                     RETRN
** VAL
'
"
