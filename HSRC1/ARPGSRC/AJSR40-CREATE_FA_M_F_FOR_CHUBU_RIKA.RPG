     H            Y.                                                      DAD000
     F** AJSR40 **********************************
     F* CREATE FA M/F FOR CHUBU RIKA
     F* PLATING KANBAN M/F                     *
     F* C:N.HAYAKAWA           1990.03.05        *
     F*
     F* TCHK1 02/25/09 ADD AAFTL06 SELECT CONDITION
     F* SAKAKI 2020.09.16 ADD CADTL04
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.10|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F*****************************************************************
     FAAFTL06 IF  E           K        DISK
     FCADTL04 IF  E           K        DISK
     FAJSPL01 IF  E           K        DISK
     FAJSWP40 O   F     229            DISK                      A
     FAJSWP41 O   F     256            DISK                      A
     I           SDS
     I                                     *PROGRAM S@PGM
     I                                      244 253 S@WSID
     I                                      254 263 S@USER
     I                                      264 269 S@JBNO
      *
     C*****************************************************
     C* KEY LIST
     C*****************************************************
     C           KEY1      KLIST
     C                     KFLD           #KHB1
     C                     KFLD           #KHB2
     C                     KFLD           #KHB3
     C*
     C*****************************************************
     C* READ AAFTL06
     C*****************************************************
     C           *LOVAL    SETLLAAFTL061
     C                     SETOF                     10
     C                     DO   *HIVAL
     C                     READ AAFTL061                 10
     C   10                LEAVE
     C*
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C*有効日・失効日のチェック*
     C           A3UKHZ    IFLE *DATE
     C           A3STHZ    ANDGT*DATE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C           A3KCD1    IFEQ 'C'
     C           A3KCD2    ANDEQ'A'
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C*  CHECK FA MASTER
     C                     MOVELA31HB5    #KHB1   5
     C                     MOVELA32HB5    #KHB2   5
     C                     MOVELA33HB2    #KHB3   2
     C                     MOVELA3KCD1    #KKBN   1
     C                     EXSR $SB900
     C*  WRITE
     C                     Z-ADDA3KALL    @3KALL  30
     C                     Z-ADDA3KAIS    @3KAIS  30
     C                     Z-ADDA3KMIN    @3KMIN  30
     C                     Z-ADDA3KMAX    @3KMAX  30
     C                     Z-ADDA3SRMS    @3SRMS  30
     C                     Z-ADDA3ALHK    @3ALHK  30
     C                     Z-ADDA3MXHK    @3MXHK  30
     C                     Z-ADDA3JDMS    @3JDMS  30
     C                     EXCPTDTA0
     C*
     C                     ENDDO
     C*
     C*****************************************************
     C* READ CADTL04
     C*****************************************************
     C           *LOVAL    SETLLCADTL041
     C                     SETOF                     10
     C                     DO   *HIVAL
     C                     READ CADTL041                 10
     C   10                LEAVE
     C*
     C           C2SKJY    IFEQ 'D'
     C           C2SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*有効日・失効日のチェック*
     C           C2UKHZ    IFLE *DATE
     C           C2STHZ    ANDGT*DATE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C* ST PROC EXIST?
     C           C2MEKI    IFEQ *BLANK
     C           C2MEKI    OREQ '.......'
     C           C2BARA    OREQ 0
     C                     ITER
     C                     ENDIF
     C*
     C* IAF ST LINE ?           '0' IS VENDOR
     C           C2MEKI    IFEQ 'O'
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADD0111      W2BMON  40
     C*
     C*  CHECK FA MASTER
     C                     MOVELC2SHN1    #KHB1   5
     C                     MOVELC2SHN2    #KHB2   5
     C                     MOVELC2SHN3    #KHB3   2
     C                     MOVELC2KCD1    #KKBN   1
     C                     EXSR $SB900
     C*  WRITE
     C                     EXCPTDTA1
     C*
     C                     ENDDO
     C*
     C**************************
     C*         終了         *
     C**************************
     C           SKIP      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************
     C* CHAIN FA MASTER
     C****************************************************
     C           $SB900    BEGSR
     C*
     C                     SETOF                     99
     C           KEY1      SETLLAJSPL011
     C                     SETOF                     20
     C           LOOP1     TAG
     C           KEY1      READEAJSPL011                 20
     C           *IN20     IFEQ '0'
     C*引ける*
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    ANDLE*DATE
     C                     GOTO LOOP1
     C                     ENDIF
     C* CHECK KANBAN KIND
     C           J1KDAI    IFNE #KKBN
     C                     GOTO LOOP1
     C                     ENDIF
     C*引けない*
     C                     ELSE
     C                     SETON                     99
     C                     END
     C**********************************
     C*         更新区分入力         *
     C**********************************
     C           *IN99     IFEQ '1'
     C                     MOVE '0'       UPKBN   1
     C                     MOVE ' '       SYKBN   1
     C                     Z-ADD0         JISEN   31
     C                     ELSE
     C                     MOVE '1'       UPKBN
     C                     MOVE J1MKSK    SYKBN
     C                     Z-ADDJ1MKJI    JISEN
     C                     END
     C*
     C           ESB900    ENDSR
     C****************************************************
     OAJSWP40 EADD             DTA0
