     H            Y/
     F***************************************************
     F*   PART#/PROC/MACHINE# COST INQUIRY              *
     F*       SEP/11/2002                               *
     F*                                                 *
     F*   MODIFICAITON:                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FFCEPW57 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FFCEPL50 IF  E           K        DISK
     FMFAPL25 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    MSG     1   1 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  12 D@PRT
     I                                        1   5 D@PRT1
     I                                        6  10 D@PRT2
     I                                       11  12 D@PRT3
     I            DS
     I                                        1   6 @@CNTR
     I                                        1   2 M@COS1
     I                                        3   4 M@COS2
     I                                        5   6 M@COS3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'00'      #SCRN0
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#KEYX    KLIST
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
     C           K#FCE     KLIST
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
     C                     KFLD           S@PROC
     C                     KFLD           S@MCHN
     C           K#MFA     KLIST
     C                     KFLD           K@FACT  40
     C                     KFLD           S@MCHN
     C                     KFLD           S@PROC
      *
     C                     Z-ADD0111      K@FACT
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'00'      W@ID    2
     C                     Z-ADD*DATE     D@DATE
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN0    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK0
     C           *IN99     IFEQ *OFF
     C                     MOVE *BLANK    D@PRT1
     C                     MOVE *BLANK    D@PRT2
     C                     MOVE *BLANK    D@PRT3
     C                     EXSR #SET
     C           RRN1      IFNE *ZERO
     C                     MOVE '01'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK0     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@DATE    IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     EXSR #CLR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C           K#KEY     SETLLFCEPL50
     C           *IN80     DOUEQ*ON
     C                     READ FCEPL50                  80
     C           *IN80     IFEQ *OFF
     C           F5SKJY    ANDEQ*BLANK
      *
     C                     CLEARSFL01
     C                     MOVE F5PRT1    S@PRT1
     C                     MOVE F5PRT2    S@PRT2
     C                     MOVE F5PRT3    S@PRT3
     C                     EXSR #SET1
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C           K#KEYX    SETGTFCEPL50
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO
     C                     MOVE D@PRT     W@PRT  12
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C           K#KEYX    SETLLFCEPL50
     C           *IN95     DOUEQ*ON
     C           K#KEYX    READEFCEPL50                  95
     C           *IN95     IFEQ *OFF
     C           F5SKJY    ANDEQ*BLANK
      *
     C                     MOVE F5PROC    S@PROC
     C                     MOVE F5MCHN    S@MCHN
     C           K#FCE     SETGTFCEPL50
     C           *IN96     DOUEQ*ON
     C           K#FCE     REDPEFCEPL50                  96
     C           *IN96     IFEQ *OFF
     C           F5SKJY    ANDEQ*BLANK
     C           F5VLDT    ANDLED@DATE
     C                     ADD  F5COST    S@COST
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           K#FCE     SETGTFCEPL50
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '00'      W@ID
     C           D@PRT     WHNE W@PRT
     C                     EXSR #SET
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN2      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     MOVE '01'      W@ID
      *
     C                     Z-ADD*ZERO     @@RRN
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     MOVE S@PRT1    D@PPR1
     C                     MOVE S@PRT2    D@PPR2
     C                     MOVE S@PRT3    D@PPR3
     C                     Z-ADDS@COST    D@COST
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     EXSR #SET2
     C                     MOVE '02'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2
      *
     C           K#KEYX    SETLLFCEPL50
     C           *IN81     DOUEQ*ON
     C           K#KEYX    READEFCEPL50                  81
     C           *IN81     IFEQ *OFF
     C           F5SKJY    ANDEQ*BLANK
      *
     C                     CLEARSFL02
     C                     MOVE F5PROC    S@PROC
     C                     MOVE F5MCHN    S@MCHN
     C           K#FCE     SETGTFCEPL50
     C           *IN96     DOUEQ*ON
     C           K#FCE     REDPEFCEPL50                  96
     C           *IN96     IFEQ *OFF
     C           F5SKJY    ANDEQ*BLANK
     C           F5VLDT    ANDLED@DATE
     C                     Z-ADDF5COST    S@PCST
     C           K#MFA     CHAINMFAPL25              91
     C  N91                MOVEL@@CNTR    S@WCNT
     C           F5DEPT    IFNE *ZERO
     C           F5DEPT    CHAINFGBPL01              98
     C  N98                MOVELB2SMEI    S@SUPL
     C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           K#FCE     SETGTFCEPL50
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
      *
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1:END
F1:END      F12:GO BACK
**  MSG
  NO DATA
