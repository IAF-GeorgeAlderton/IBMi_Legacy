      ****************************************************************
      * MONTHLY TOTALIZATION HANDLING / PRINT OF ORDER RESULT TABLE
      *      G.B.C                         97/03/06
      ****************************************************************
     H            Y/                                    1
     FGDGPL20 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     F*
     FQPRINT  O   F     132     OF     PRINTER
     I****************************************************************
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
     I* DELETE DUE DATE
     I            DS
     I                                        1   80IDSKHZ
     I                                        1   40IDSKYY
     I                                        5   60IDSKMM
     I                                        7   80IDSKDD
     I            DS
     I                                        1   80W1DATE
     I                                        1   40W1YEAR
     I                                        5   60W1MONT
     I                                        7   80W1DAY
     I*発注実績
     I            DS
     I                                        1   40WKJSYY
     I                                        5   60WKJSMM
     I                                        1   6 WKDATE
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C                     PARM           PPDATE  6
     C****************************************************************
     C           KEY       KLIST
     C                     KFLD           WKJSYY
     C                     KFLD           WKJSMM
     C           KEYFC     KLIST
     C                     KFLD           IDHIN1
     C                     KFLD           IDHIN2
     C                     KFLD           IDHIN3
     C****************************************************************
     C                     MOVE PPDATE    WKDATE
     C                     SETON                     OF
     C                     Z-ADD*DATE     W1DATE
     C*
     C           KEY       SETLLGDGPL20
     C*--------------------
B1   C                     DO   *HIVAL
     C           KEY       READEGDGPL20                  90
     C   90                LEAVE
     C*
 B2  C           IDSKJY    IFEQ 'D'                        DELETE CODE
     C           IDSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C*----------
     C                     MOVE *BLANK    WKNAME 30
     C           KEYFC     SETLLFCEPL01
     C                     DO   *HIVAL
     C           KEYFC     READEFCEPL01                  91
     C   91                LEAVE
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*----------
     C**N91                MOVELA2SMEI    D2NAME
     C  N91                MOVELA2MMEI    WKNAME
     C*
     C   OF                EXCPT#HED
     C   OF                SETOF                     OF
     C           IDHIN3    COMP *BLANK                   21
     C                     EXCPT#DTL
E1   C                     ENDDO
     C*--------------------
     C* <終　了>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     O*****************************************************************
     OQPRINT  E   01           #HED
     O                                    7 'GDGR51'
     O                                   60 'ODER RESULT LIST'
     O                                  107 'DATE:'
     O                         W1MONT  +  0
     O                                 +  0 '/'
     O                         W1DAY   +  0
     O                                 +  0 '/'
     O                         W1YEAR  +  0
     O                                  127 'PAGE:'
     O                         PAGE  Z +  0
     O        E   03           #HED
     O                                   10 'PART NO.'
     O                                   29 'S-CLASS NAME'
     O                                   63 'ORDER QTY'
     O        E   04           #HED
     O                                   16 '--------------'
     O                                   37 '--------------------'
     O                                 +  0 '---------------'
     O                                   63 '---------'
     O        E 1              #DTL
     O                         IDHIN1     7
     O                                    8 '-'
     O                         IDHIN2    13
     O                      N21          14 '-'
     O                         IDHIN3    16
     O                         WKNAME    47
     O                         IDSURY1   63
