     H            Y.
     F*** OAAR25 ***************************************
     F*    UPDATE OF PERSON IN CHARGE M/F              *
     F*      <OUT GOING ORDER BUSINESS>                *
     F*         H.ITO            90.10.05              *
     F*************************************** OAAR25 ***
     FOAAPW25 CF  E                    WORKSTN
     FOAAPL25 UF  E           K        DISK                      A
     E                    KOCD    1   3  1   KONM    8   UPDATE INSTRUCT
     E                    ER      1  14 60               ERROR MESSAGE
     I            DS
     I                                        1   80R6SKHZ
     I                                        1   40R6SKYY
     I                                        5   60R6SKMM
     I                                        7   80R6SKDD
     I            DS
     I                                        1   80R6KOHZ
     I                                        1   40R6KOYY
     I                                        5   60R6KOMM
     I                                        7   80R6KODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20R6KOHH
     I                                        3   40R6KOSS
     C           *ENTRY    PLIST
     C                     PARM           PARM1  10        USER NAME
     C                     Z-ADD0         R6SKHZ
     C*
     C* fﾞx]-1
     C*
     C           @SCR1     TAG
     C                     EXFMTOAAPW251
     C                     SETOF                     020399
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C* ﾃcﾆ]hﾎﾞ]
     C*
     C                     MOVE *BLANK    @KONM   8
     C                     SETOF                     20
     C                     Z-ADD1         A       10
     C           @KOSN     LOKUPKOCD,A                   20
     C           *IN20     IFEQ '0'
     C                     SETON                     0299
     C                     MOVELER,01     MSG
     C                     GOTO @SCR1
     C                     END
     C                     MOVELKONM,A    @KONM
     C*
     C* j]ncﾆｫﾃｰnﾞ
     C*
     C           @TANT     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVELER,02     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C* lbf
     C*
     C                     SETOF                     30
     C           @TANT     CHAINOAAPL251             30
     C           @KOSN     IFEQ '2'
     C           *IN30     IFEQ '0'
     C           R6SKJY    IFEQ 'D'
     C           R6SKHZ    ANDLE*DATE
     C                     GOTO @001
     C                     END
     C                     SETON                     020399
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* s]ﾃc
     C*
     C           @KOSN     IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     SETON                     020399
     C                     MOVELER,04     MSG
     C                     GOTO @SCR1
     C                     END
     C           R6SKJY    IFEQ 'D'
     C           R6SKHZ    ANDLE*DATE
     C                     SETON                     020399
     C                     MOVELER,05     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* nﾒiﾆ
     C*
     C           @KOSN     IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     SETON                     020399
     C                     MOVELER,06     MSG
     C                     GOTO @SCR1
     C                     END
     C           R6SKJY    IFEQ 'D'
     C           R6SKHZ    ANDLE*DATE
     C                     SETON                     020399
     C                     MOVELER,07     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C           @001      TAG
     C*
     C                     MOVE R6NAME    @NAME
     C           @KOSN     IFEQ '2'
     C                     MOVE *BLANK    @NAME
     C                     END
     C*
     C                     SETON                     70
     C*
     C* fﾞx]-2
     C*
     C           @SCR2     TAG
     C                     EXFMTOAAPW251
     C                     SETOF                     020399
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @TANT
     C                     MOVE *BLANK    @NAME
     C                     SETOF                     70
     C                     GOTO @SCR1
     C                     END
     C*
     C* j]ncﾆｫxb
     C*
     C           @NAME     IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,08     MSG
     C                     GOTO @SCR2
     C                     END
     C*
     C  NKE                GOTO @SCR2
     C*
     C                     MOVE @TANT     R6TANT
     C                     MOVE @NAME     R6NAME
     C*
     C                     MOVE @KONM     MKOSN
     C                     MOVE @TANT     MTANT
     C                     MOVE @NAME     MNAME
     C*
     C           @KOSN     IFEQ '0'
     C                     MOVEL'D'       R6SKJY
     C                     Z-ADD*DATE     R6SKHZ
     C                     ELSE
     C                     MOVE *BLANK    R6SKJY
     C                     Z-ADD0         R6SKHZ
     C                     END
     C                     Z-ADD*DATE     R6KOHZ
     C                     TIME           WTIME
     C                     MOVELPARM1     R6KOME
     C           *IN30     IFEQ '0'
     C                     UPDATOAAPL251
     C                     ELSE
     C                     WRITEOAAPL251
     C                     END
     C*
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @TANT
     C                     MOVE *BLANK    @NAME
     C                     SETOF                     70
     C                     GOTO @SCR1
     C*
**  (KOCD/KONM)
00-CANCEL
11-CHANGE
22-ADD
**  ER
E-01  UPDATE INSTRUCTION IS 0.1.2
E-02  PERSON IN CHARGE CODE ISN'T INPUT
E-03  ADD WAS APPOINTED, BUT M/F EXISTS
E-04  A CHANGE WAS APPOINTED, BUT M/F DOESN'T EXIST
E-05  A CHANGE WAS APPOINTED, BUT M/F IS CANCELLED ALREADY
E-06  A CANCELLATION WAS APPOINTED, BUT M/F DOESN'T EXIST
E-07  A CANCELLATION WAS APPOINTED, BUT M/F IS CANCELLED
E-08  PERSON IN CHARGE NAME ISN'T INPUT
