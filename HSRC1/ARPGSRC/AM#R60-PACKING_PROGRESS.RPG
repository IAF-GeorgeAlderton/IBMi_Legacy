     H            Y.
     F** AM#R60 *********************************************
     F* PACKING PROGRESS
     F*             ITS.           2015.06.22               *
     F*******************************************************
     FAM#PW60 CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
     E                    ER      1  20 60
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I            DS
     I                                        1   80F8KA
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     I            DS
     I                                        1   80WKDATE
     I                                        1   40WKDAYY
     I                                        5   60WKDAMM
     I                                        7   80WKDADD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHID  8
     C                     PARM           P9CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    P1SHID
     C                     MOVEL*BLANK    P9CMD
     C                     Z-ADD0         D1SHID
      *前の金曜日（非稼動の場合は稼動まで）
     C           KEYAGD    KLIST
     C                     KFLD           WKDAYY
     C                     KFLD           WKDAMM
     C                     KFLD           WKDADD
     C                     Z-ADDWDATE     WKDATE
     C                     MOVEL'0'       WKFRI   1
     C           KEYAGD    SETLLAGDPL121
     C                     READPAGDPL121                 80
     C           *IN80     DOWEQ'0'
     C           D1SHID    ANDEQ0
     C           F8YOBI    IFEQ 5
     C                     MOVEL'1'       WKFRI   1
     C                     ENDIF
     C           WKFRI     IFEQ '1'
     C           F8HIRU    IFEQ *BLANK
     C                     Z-ADDF8KA      D1SHID
     C                     ENDIF
     C                     ENDIF
     C                     READPAGDPL121                 80
     C                     ENDDO
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAM#PW601
     C                     SETOF                     303132
     C                     SETOF                     333435
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      *
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1SHID    IFEQ 0
     C                     MOVELER,1      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVEL'99'      DSPSW
     C                     MOVELD1SHID    P1SHID
     C                     MOVEL'05'      P9CMD
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
** ER
