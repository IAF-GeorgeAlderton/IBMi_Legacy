     H            Y.
     FAB#PL18 IF  E           K        DISK                           UC
     FAB#PL70 IF  E           K        DISK                           UC
     FAB#WPS3 O   E                    DISK                           UC
     E                    TB1      9999 12  A
     I            DS
     I                                        1   80K@NODT
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I            DS
     I                                        1   80BANODT
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  120W#DTTM
     I                                        1   80W#SDAT
     I                                        9  120W#TIME
     I            DS
     I                                        1  120QQDTTM
     I                                        1   80QQSDAT
     I                                        9  120QQTIME
     I            DS
     I                                        1  12 TBKEY
     I                                        1   80TBDATE
     I                                        9  120TBNONY
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@FROM  8
     C                     PARM           P@TO    8
      *
     C                     PARM           @@NSCN  90
      *
     C                     PARM           P@SDAT  80
     C                     PARM           P@STIM  40
      *
     C                     PARM           P@DAT1  80
     C                     PARM           P@NON1  40
     C                     PARM           P@DAT2  80
     C                     PARM           P@NON2  40
     C                     PARM           P@DAT3  80
     C                     PARM           P@NON3  40
     C                     PARM           P@DAT4  80
     C                     PARM           P@NON4  40
      *
     C                     PARM           P@CRTD  1
     C                     PARM           P#OPN   1
      *
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEAB#PL18
     C                     CLOSEAB#PL70
     C                     CLOSEAB#WPS3
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN AB#PL18
     C                     OPEN AB#PL70
     C                     OPEN AB#WPS3
     C                     ENDIF
      *
     C                     MOVE P@HIN1    K@HIN1  5
     C                     MOVE P@HIN2    K@HIN2  5
     C                     MOVE P@HIN3    K@HIN3  2
     C                     MOVE P@FROM    K@NODT
     C                     MOVE P@TO      K@ENDD  80
      *
     C           AB#KEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C                     KFLD           K@NODD  20
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C                     Z-ADD0         QQDTTM
      *
     C                     Z-ADD0         @@NSCN
     C                     Z-ADD0         P@SDAT
     C                     Z-ADD0         P@STIM
     C                     Z-ADD0         @Z      50
     C                     MOVEA*ALL'9'   TB1
      *
     C                     Z-ADD0         P@DAT1  80
     C                     Z-ADD0         P@NON1  40
     C                     Z-ADD0         P@DAT2  80
     C                     Z-ADD0         P@NON2  40
     C                     Z-ADD0         P@DAT3  80
     C                     Z-ADD0         P@NON3  40
     C                     Z-ADD0         P@DAT4  80
     C                     Z-ADD0         P@NON4  40
      *
     C           AB#KEY    SETLLAB#PL18
     C                     DO   *HIVAL
     C           HINKEY    READEAB#PL18                  88
     C   88                LEAVE
     C           BANODT    IFGT K@ENDD
     C                     LEAVE
     C                     END
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C                     MOVE BANONY    @@NONY
     C                     MOVE BANOBN    K@NOBN
     C                     MOVELBAODRN    @@ODRN    P
     C                     Z-ADD*ZERO     WWQTY   70
     C                     EXSR #AB#70
      *
     C           WWQTY     IFEQ 0
     C                     MOVELBAINVN    @@ODRN    P
     C                     EXSR #AB#70
     C                     END
      *
     C           WWQTY     IFLT BASRYO
     C           BASRYO    SUB  WWQTY     @@BAL   90
      *
     C                     EXSR #TBL
      *
     C                     EXSR #MAST
      *
     C                     ADD  @@BAL     @@NSCN
      *
     C           P@CRTD    IFEQ '1'
     C                     EXSR #WPF
     C                     END
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SORTATB1
     C           1         DO   4         @P      20
     C                     MOVE TB1,@P    TBKEY
     C           TBNONY    IFNE 9999
     C           @P        IFEQ 1
     C                     Z-ADDTBDATE    P@DAT1
     C                     Z-ADDTBNONY    P@NON1
     C                     END
     C           @P        IFEQ 2
     C                     Z-ADDTBDATE    P@DAT2
     C                     Z-ADDTBNONY    P@NON2
     C                     END
     C           @P        IFEQ 3
     C                     Z-ADDTBDATE    P@DAT3
     C                     Z-ADDTBNONY    P@NON3
     C                     END
     C           @P        IFEQ 4
     C                     Z-ADDTBDATE    P@DAT4
     C                     Z-ADDTBNONY    P@NON4
     C                     END
     C                     END
     C                     ENDDO
      *
     C***********          SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------------------
     C           #AB#70    BEGSR
      *
     C           K#AP70    KLIST
     C                     KFLD           BATOKU
     C                     KFLD           @@NONY  4
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           @@ODRN 10
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           K@NOBN  2
     C                     KFLD           BADEYY
     C                     KFLD           BADEMM
     C                     KFLD           BADEDD
      *
     C           K#AP70    SETLLAB#PL70
     C                     DO   *HIVAL
     C           K#AP70    READEAB#PL70                  77
     C   77                LEAVE
     C           EKSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           EKHENK    IFNE *BLANK
     C                     ITER
     C                     END
     C                     ADD  EKSRYO    WWQTY
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #MAST     BEGSR
      *
     C                     MOVE BANONY    P#NONY  4
     C                     MOVE BANOBN    P#BIN   2
     C                     Z-ADDBANODT    P#SDAT  80
     C                     Z-ADD0         P#TIME  40
     C                     CALL 'AB#RM5'
     C                     PARM           P#NONY  4
     C                     PARM           P#BIN   2
     C                     PARM           P#SDAT  80
     C                     PARM           P#TIME  40
      *
     C* * *      P#TIME    IFEQ 9999
     C* * *                GOTO EMAST
     C* * *                END
      *
     C                     Z-ADDP#SDAT    W#SDAT
     C                     Z-ADDP#TIME    W#TIME
     C           QQDTTM    IFEQ 0
     C                     Z-ADDW#DTTM    QQDTTM
     C                     Z-ADDQQSDAT    P@SDAT
     C                     Z-ADDQQTIME    P@STIM
     C                     END
     C           W#DTTM    IFLT QQDTTM
     C                     Z-ADDW#DTTM    QQDTTM
     C                     Z-ADDQQSDAT    P@SDAT
     C                     Z-ADDQQTIME    P@STIM
     C                     END
      *
     C           EMAST     ENDSR
      *-----------------------------------------------------
     C           #TBL      BEGSR
      *
     C                     Z-ADDBANONY    TBNONY
     C                     Z-ADDBANODT    TBDATE
     C                     Z-ADD1         @X      50
     C           TBKEY     LOKUPTB1,@X                   66
     C           *IN66     IFEQ '0'
     C                     ADD  1         @Z
     C                     MOVE TBKEY     TB1,@Z
     C                     END
      *
     C           ETBL      ENDSR
      *-----------------------------------------------------
     C           #WPF      BEGSR
     C                     MOVE BASHN1    J#HIN1
     C                     MOVE BASHN2    J#HIN2
     C                     MOVE BASHN3    J#HIN3
     C                     Z-ADDBANOYY    J#NOYY
     C                     Z-ADDBANOMM    J#NOMM
     C                     Z-ADDBANODD    J#NODD
     C                     Z-ADDP#TIME    J#NOTM
     C                     Z-ADDBANOBN    J#NOBI
     C                     Z-ADDBANONY    J#NONY
     C                     Z-ADD@@BAL     J#SRYO
     C                     WRITEAB#WPS31
     C           EWPF      ENDSR
