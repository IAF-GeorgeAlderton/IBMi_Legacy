     H            Y.
     F** GDKR60 ********************************
     F*  DAILY ACCOUNT PAYABLE PROCESS         *
     F*      A.MAMIYA        2000.11.07        *
     F******************************** GDKR60 **
     FGDKPL0B IF  E           K        DISK
     FGDKWP60 O   E                    DISK
     I            DS
     I                                        1   80ITSKHZ
     I                                        1   40ITSKYY
     I                                        5   60ITSKMM
     I                                        7   80ITSKDD
     I            DS
     I                                        1   80ITKOHZ
     I                                        1   40ITKOYY
     I                                        5   60ITKOMM
     I                                        7   80ITKODD
     I            DS
     I                                        1   60ITKOTI
     I                                        1   20ITKOHH
     I                                        3   40ITKOSS
     I            DS
     I                                        1   80ITMMHZ
     I                                        1   40ITMMYY
     I                                        5   60ITMMMM
     I                                        7   80ITMMDD
     I            DS
     I                                        1   80ITHTHZ
     I                                        1   40ITHTYY
     I                                        5   60ITHTMM
     I                                        7   80ITHTDD
     I            DS
     I                                        1   80ITUKHZ
     I                                        1   40ITUKYY
     I                                        5   60ITUKMM
     I                                        7   80ITUKDD
     I            DS
     I                                        1   80ITSAHZ
     I                                        1   40ITSAYY
     I                                        5   60ITSAMM
     I                                        7   80ITSADD
     I            DS
     I                                        1   80ITSIHZ
     I                                        1   40ITSIYY
     I                                        5   60ITSIMM
     I                                        7   80ITSIDD
     I            DS
     I                                        1   80WREHZ
     I                                        1   40WREYY
     I                                        5   60WREMM
     I                                        7   80WREDD
     C           #CHG      PLIST
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C*
     C           *ENTRY    PLIST
     C                     PARM           PVEND   4
     C                     PARM           PREHZ   80
     C*
     C                     MOVELPVEND     WVEND   4
     C                     Z-ADDPREHZ     WREHZ   80
     C*
     C           KEY1      KLIST
     C                     KFLD           WREYY
     C                     KFLD           WREMM
     C                     KFLD           WREDD
     C                     KFLD           WVEND
     C*
     C                     SETOF                     90
     C           KEY1      SETLLGDKPL0B1
     C                     DO   *HIVAL
     C           KEY1      READEGDKPL0B1                 90
     C           *IN90     IFEQ '0'
     C           ITSKJY    IFEQ 'D'
     C           ITSKHZ    ANDLE*DATE
     C                     ELSE
     C*
     C                     Z-ADD5         PLEN
     C                     Z-ADDITTAN     PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      ITTAN1
     C*
     C                     Z-ADD5         PLEN
     C                     Z-ADDITRATE    PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      ITRAT1
     C*
     C*
     C                     Z-ADD5         PLEN
     C                     Z-ADDITDOLL    PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      ITDOL1
     C*
     C                     WRITEGDKWP601
     C                     END
     C                     END
     C  N90                ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
