      *自工程　工程コード*
     C                     MOVEL*BLANK    ATOK    3
     C                     MOVELJ6ATOK    ATOK
      *
     C                     MOVEL*BLANK    AKT
     C                     Z-ADD*ZERO     ABM
     C                     MOVEL*BLANK    AKB
     C                     MOVEL*BLANK    ATOK
     C                     MOVEL*BLANK    ALC
      *
     C                     SETOF                     30
     C           KEY1      CHAINAAMPL111             30
      *
     C           *IN30     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD1         X       20
     C                     Z-ADD0         L       20
     C           1         DO   15        X
     C                     MOVELNUKH,X    WUKH    80
     C           WUKH      IFGT J6UKHZ
     C                     ADD  1         L
     C                     MOVE OKOT,X    AKT,L
     C                     Z-ADDOBMN,X    ABM,L
     C                     MOVE OKBN,X    AKB,L
     C                     MOVELOLC,X     ALC,L
     C                     ELSE
     C                     ADD  1         L
     C                     MOVE NKOT,X    AKT,L
     C                     Z-ADDNBMN,X    ABM,L
     C                     MOVE NKBN,X    AKB,L
     C                     MOVELNLC,X     ALC,L
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *BLANK    W@MRK   5
      ** TMMKWV
     C                     MOVELJ6H       W@MRK     P
     C           K#MBD     CHAINMBDPL01              91
     C           *IN91     IFEQ *OFF
     C                     MOVEL'***** '  W@MRK     P
     C                     ELSE
     C           K#GHC     SETLLGHCPL22
     C           *IN92     DOUEQ*ON
     C           K#GHC     READEGHCPL22                  92
     C           *IN92     IFEQ *OFF
     C           K#MBDX    CHAINMBDPL01              91
     C           *IN91     IFEQ *OFF
     C                     MOVEL'*****'   W@MRK     P
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *----
     C                     SETOF                     30
