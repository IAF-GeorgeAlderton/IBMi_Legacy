%08   *  CKECK PROCESS CODE FOR PRINTING BARCODE
     C                     MOVEL*BLANK    C@OQ    1
     C                     MOVEL*BLANK    C@LOQ   1
      *
     C                     Z-ADD1         X       20
     C           J6ATK     LOKUPALC,X                    30
      *
     C           *IN30     IFEQ *ON
     C           'OQ'      IFEQ AKT,X
     C                     MOVEL'1'       C@OQ
     C                     ENDIF
     C           'LOQ'     IFEQ AKT,X
     C                     MOVEL'1'       C@LOQ
     C                     ENDIF
     C                     ENDIF
      * X-1
     C                     SUB  1         X
      *
     C           X         DOWGE1
      *
     C           ALC,X     IFEQ '------'
      *                                                 C
     C           'OQ'      IFEQ AKT,X
     C                     MOVEL'1'       C@OQ
     C                     ENDIF
     C           'LOQ'     IFEQ AKT,X
     C                     MOVEL'1'       C@LOQ
     C                     ENDIF
      *                                                 C
     C                     ELSE
      *                                                 C
     C           J6ATK     IFNE ALC,X
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     SUB  1         X
     C*
     C                     ENDDO
