%0001C                     MOVEL*BLANK    WKBN    1
     C                     Z-ADD3931      K@NONY  40
      *
     C           WNKOJ     IFNE 9999
     C           WNKOJ     IFNE J6NKOJ
     C                     GOTO END
     C                     END
     C                     END
      *
     C           J6SKJY    IFEQ 'D'
     C           J6SAKJ    ANDLE*DATE
     C                     GOTO END
     C                     END
      *
     C           PKBN      IFEQ 'Z'
     C                     MOVELJ6KOME    WKOME   6
     C           WKOME     CABNE'ZOUGEN'  END
     C                     END
      *
     C           PNO       IFEQ '1'
     C           J6KOUT    CABNE'Y'       END
     C           J6KMIN    CABEQJ6KMAX    END
     C                     END
      *
     C           PNO       IFEQ '3'
     C           PNO       OREQ '2'
     C           J6STHZ    IFNE 99999999
     C                     GOTO END
     C                     END
     C                     END
