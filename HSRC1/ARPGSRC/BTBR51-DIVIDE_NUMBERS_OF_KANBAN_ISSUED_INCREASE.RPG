     H            Y.
     F** BTBR51 ******************************************************
     F* DIVIDE NUMBERS OF KANBAN ISSUED INCREASE/DECREASE PORTION    *
     F*    N-HYOTO  2000.12.05                                       *
     F*                                                              *
     F*  *IN89=1 MAINU INCREASE/DECREASE QUANTITY                    *
     F*  *IN90=1 NOT EXIST AGDPL12(CALENDER MASTER)                  *
     F*************************************** BASED ON   AAPR02 ******
     FAGDPL12 IF  E           K        DISK
     FBTBPP51 O   E                    DISK                      A
     E                    TBL        20  3 0
     E                    FLG     1  20  2
     I* TIME
     I            DS
     I                                        1  120WTMDT
     I                                        1   20WHH
     I                                        3   40WSS
      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     PARM           PSIRE   40
     C                     PARM           PUKEI   40
     C                     PARM           PPTCD   1
     C                     PARM           PZAIS  15
     C                     PARM           PZAIK   52
     C                     PARM           PIDQTY  30
     C                     PARM           PSETI   30
      *
     C           KEY1      KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
     C                     KFLD           WDD
     C***********************************************************
     C*
     C                     EXSR @INZ
     C                     EXSR @TBL
     C                     EXSR @FILE
     C                     EXSR @END
     C***********************************************************
     C* INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     Z-ADD*ZERO     WIDQTY  30
     C                     Z-ADD*ZERO     I       20
     C******               Z-ADD*ZERO     M       20
     C                     Z-ADD1         M       20
     C                     Z-ADD*ZERO     R       20
     C                     Z-ADD*ZERO     TBL
     C*
     C                     Z-ADD*YEAR     WYY     40
     C                     Z-ADDUMONTH    WMM     20
     C                     Z-ADDUDAY      WDD     20
     C                     TIME           WTMDT
     C*
     C                     ENDSR
     C***********************************************************
     C* CREATE TABLE
     C***********************************************************
     C           @TBL      BEGSR
     C*
     C* MINUS QTY --> PLUS QTY
     C           PIDQTY    IFLT *ZERO
     C                     SETON                     89
     C           PIDQTY    MULT -1        WIDQTY
     C*
     C                     ELSE
     C                     Z-ADDPIDQTY    WIDQTY
     C                     END
     C*
     C           WIDQTY    DOWGEPSETI
     C*
     C* SET INDICATOR OF TBL
     C           I         ADD  1         I
     C           I         IFGT 20
     C                     Z-ADD1         I
     C                     END
     C                     MOVE FLG,I     M
     C*
     C                     ADD  PSETI     TBL,M
     C                     SUB  PSETI     WIDQTY
     C*
     C                     END
     C*
     C* PROCESS REST OF INCREASE/DECREASE QTY
     C           WIDQTY    IFNE *ZERO
     C                     ADD  WIDQTY    TBL,M
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* WRITE INCREASE/DECREASE FILE
     C***********************************************************
     C           @FILE     BEGSR
     C*
     C                     CLEARBTBPP511
     C                     Z-ADD*YEAR     B5KOYY
     C                     Z-ADDUMONTH    B5KOMM
     C                     Z-ADDUDAY      B5KODD
     C                     Z-ADDWHH       B5KOHH
     C                     Z-ADDWSS       B5KOSS
     C                     MOVELPUS       B5KOME
     C                     MOVEL'BTBR51'  B5KOPG
     C                     Z-ADDPSIRE     B5SIRE
     C                     Z-ADDPUKEI     B5UKEI
     C                     MOVE PPTCD     B5PTCD
     C                     MOVE PZAIS     B5ZAIS
     C                     MOVE PZAIK     B5ZAIK
     C*
     C           KEY1      SETGTAGDPL121
     C*
B01  C                     DO   20        R
     C*
     C           #READ     TAG
     C                     READ AGDPL121                 90
B02  C           *IN90     IFEQ '1'
     C                     GOTO #END
E02  C                     END
     C*
B02  C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO #READ
     C                     ELSE
     C*
B03  C           TBL,R     IFNE *ZERO
     C                     Z-ADDF8KAYY    B5NUYY
     C                     Z-ADDF8KAMM    B5NUMM
     C                     Z-ADDF8KADD    B5NUDD
     C   89      -1        MULT TBL,R     B5MAIS
     C  N89                Z-ADDTBL,R     B5MAIS
     C                     WRITEBTBPP511
      *
E03  C                     END
     C*
     C                     END
     C                     END
     C*
     C           #END      ENDSR
     C***********************************************************
     C* END
     C***********************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C***********************************************************
** INDICATOR
01
06
11
16
02
07
12
17
03
08
13
18
04
09
14
19
05
