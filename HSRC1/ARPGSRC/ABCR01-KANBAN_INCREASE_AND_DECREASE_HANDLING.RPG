     C                     END
      *
     C                     EXCPTUP
     C                     ELSE
      *
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     EXCPTWT
     C                     END
      *
     C                     Z-ADDARECD     CQJTNO
     C                     WRITEAU#PP511
      *
     C                     END
     C                     END
