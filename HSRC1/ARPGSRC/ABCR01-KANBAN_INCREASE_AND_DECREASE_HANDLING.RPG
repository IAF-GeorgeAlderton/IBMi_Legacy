     C*     ...樹脂かんばん...     *
     C*------------------------------*
     C           KTY,I     IFEQ 'G'
      *
     C                     MOVE TKR,I     WTKR
     C                     MOVE KOT,I     WKOTI
     C                     Z-ADDBUM,I     WBMON
     C                     MOVE KHN,I     WKHIN
      *
     C           KEYC      SETLLAECPL031
      *
     C           YP13      TAG
     C                     SETOF                     10
     C                     READ AECPL031                 10
     C           *IN10     IFEQ '0'
     C           AFSKJY    ANDEQ'D'
     C           AFSKHZ    CABLE*DATE     YP13
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     GOTO AP1
     C                     END
     C           AFATKR    IFNE TKR,I
     C                     GOTO AP1
     C                     END
      *
     C           AFSTHZ    CABLE*DATE     YP13
      *
     C           AFDTKO    IFEQ '2'
     C           AFDTKO    OREQ 'D'
     C                     Z-ADDWSURO     AFKTSU
     C                     GOTO YP131
     C                     END
     C           AFSYOS    IFEQ 0
     C                     Z-ADDWSURO     AFKTSU
     C                     GOTO YP131
     C                     END
     C           AFKTSU    IFEQ WSURO
     C                     GOTO YP131
     C                     END
      *
     C           AFKTSU    DIV  20        XKTSU     H
     C           WSURO     DIV  20        XSURO     H
      *
     C           XKTSU     DIV  AFSYOS    WMO       H
     C           XSURO     DIV  AFSYOS    WMN       H
     C                     Z-ADD0         WMON1
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON
     C           WMON1     MULT 100       $$WMON    H
      *
     C                     MOVE 'Z'       $ZOGN
     C                     MOVE '+'       $$ZOGN
     C           WMN       IFLT WMO
     C                     MOVE 'G'       $ZOGN
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           $$WMON    IFEQ 0
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           $ZOGN     ANDEQ'G'
     C                     GOTO YP131
     C                     END
      *
     C*--------------------------------------------*
     C*  ..増減比率　＋－２５％未満処理しない..  *
     C*--------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO YP131
     C                     END
      *
     C                     MOVE 'G'       $KCD1
     C                     MOVE AFATKR    $TKRO
     C                     MOVE AFSHIN    $SHIN
     C                     Z-ADD0         $NLOT
     C                     Z-ADDAFKMAX    $NMAS
     C                     Z-ADDAFKMAX    $OMAS
     C                     Z-ADDAFSYOS    $SYOS
     C                     MOVE *BLANK    $KOT1
     C                     MOVE *BLANK    $KOT2
     C                     MOVE *BLANK    $KOT3
     C                     MOVE *BLANK    $KOT4
     C                     Z-ADD0         $BMON
     C                     Z-ADD0111      $UKOJ
      *
     C                     Z-ADD0         $KSTS
     C                     Z-ADD0         $KHTS
     C                     Z-ADD0         $ZSTS
     C                     Z-ADD0         $ZHTS
     C                     Z-ADD0         $$N1SU
     C                     Z-ADD0         $N1HS
     C                     Z-ADD0         $$N2SU
     C                     Z-ADD0         $N2HS
     C                     Z-ADD0         $$ZGSU
     C                     Z-ADD0         $ZGHS
     C                     Z-ADD0         $TENS
      *
     C                     Z-ADDWSUROK    $$KSTS
     C                     Z-ADDWSURO     $KSTS
     C           WSURO     DIV  20        WKTE      H
     C           AFSYOS    IFNE 0
     C           WKTE      DIV  AFSYOS    $KHTS     H
     C                     END
      *
     C                     Z-ADDAFKTSU    $ZSTS
     C           AFKTSU    DIV  20        WKTE      H
     C           AFSYOS    IFNE 0
     C           WKTE      DIV  AFSYOS    $ZHTS     H
     C                     END
      *
     C                     Z-ADD0         W
     C                     MOVE *BLANK    #HIN
     C           KEY4      SETLLGHCPL221
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY4      READEGHCPL221                 02
     C           *IN02     IFEQ '0'
      *
     C                     SETOF                     04
     C                     Z-ADD1         A
     C           MMJHIN    LOKUP#HIN,A                   04
     C           *IN04     IFEQ '0'
     C                     ADD  1         W
     C                     MOVE MMJHIN    #HIN,W
      *
     C                     SETOF                     04
     C           KEY3      CHAINABBPL211             04
     C           *IN04     IFEQ '0'
     C           U1NGKB    IFEQ 'N'
     C                     ADD  U1N1NM    $$N1SU
     C                     ADD  U1N2NM    $$N2SU
     C                     ELSE
     C                     ADD  U1S1NM    $$N1SU
     C                     ADD  U1S2NM    $$N2SU
     C                     END
     C                     END
      *
     C                     SETOF                     04
     C           KEY5      CHAINMBEPL051             04
     C           *IN04     IFEQ '0'
     C                     Z-ADD#JMM      U
     C                     ADD  #SRY,U    $$ZGSU
     C                     ADD  1         $TENS
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
      *
     C           $$N1SU    DIV  @CD,1     WKTE      H
     C           WKTE      MULT 20        $N1SU
     C           AFSYOS    IFNE 0
     C           WKTE      DIV  AFSYOS    $N1HS     H
     C                     END
      *
     C           $$N2SU    DIV  @CD,2     WKTE      H
     C           WKTE      MULT 20        $N2SU
     C           AFSYOS    IFNE 0
     C           WKTE      DIV  AFSYOS    $N2HS     H
     C                     END
      *
     C           $$ZGSU    DIV  @CD,3     WKTE      H
     C           WKTE      MULT 20        $ZGSU
     C           AFSYOS    IFNE 0
     C           WKTE      DIV  AFSYOS    $ZGHS     H
     C                     END
      *
     C                     SETON                     U4
     C                     EXCPTGDT
      *
     C                     MOVE AFSHIN    $$SHIN
     C                     MOVE AFATKR    $$TKRO
     C                     MOVE 'G'       $$KCOD
     C                     Z-ADDAFATOB    $$BMON
     C                     EXCPTRDT1
      *
     C           YP131     TAG
     C                     Z-ADDWSURO     AFKSSU
     C                     UPDATAECPL031
     C                     GOTO YP13
      *
     C                     END
      *
     C           AP1       TAG
     C                     END
      *
     C                     END
      *
      *
     C*------------------------------------*
     C*  ..手書きかんばん　増減リスト..  *
     C*------------------------------------*
     C                     Z-ADD1         I
     C           1         DO   15        I
     C           KTY,I     IFNE *BLANK
      *
     C                     SETOF                     10
     C           KTY,I     LOKUPHTY                      10
     C           *IN10     IFEQ '1'
     C                     GOTO YPTE
     C                     END
      *
     C           YPTF      TAG
     C                     Z-ADD0         TSYOS   50
     C                     Z-ADD0         TTKSTS  90
     C                     Z-ADD0         TKHTS   62
     C                     Z-ADD0         TTZSTS  90
     C                     Z-ADD0         TZHTS   62
     C                     Z-ADD0         TTN1SU  90
     C                     Z-ADD0         TN1HS   62
     C                     Z-ADD0         TTN2SU  90
     C                     Z-ADD0         TN2HS   62
     C                     Z-ADD0         TTZGSU  90
     C                     Z-ADD0         TZGHS   62
     C                     Z-ADD0         TTENS   30
      *
     C                     MOVE TKR,I     WTKR
     C                     MOVE KOT,I     WKOTI
     C                     Z-ADDBUM,I     WBMON
     C                     MOVE KHN,I     WKHIN
      *
     C                     Z-ADD0         W
     C                     MOVE *BLANK    #HIN
     C           KEY4      SETLLGHCPL221
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY4      READEGHCPL221                 02
     C           *IN02     IFEQ '0'
      *
     C                     SETOF                     04
     C                     Z-ADD1         A
     C           MMJHIN    LOKUP#HIN,A                   04
     C           *IN04     IFEQ '0'
     C                     ADD  1         W
     C                     MOVE MMJHIN    #HIN,W
      *
     C                     SETOF                     04
     C           KEY7      CHAINAAUPL011             04
     C           *IN04     IFEQ '0'
     C           J1SKJY    ANDEQ'D'
     C           J1SKHZ    ANDLE*DATE
     C                     SETON                     04
     C                     END
     C           *IN04     IFEQ '0'
     C                     Z-ADDJ1NSYS    TSYOS
     C                     ADD  J1NGEK    TTKSTS
     C                     ADD  J1OGEK    TTZSTS
     C                     END
      *
     C                     SETOF                     04
     C           KEY3      CHAINABBPL211             04
     C           *IN04     IFEQ '0'
     C           U1NGKB    IFEQ 'N'
     C                     ADD  U1N1NM    TTN1SU
     C                     ADD  U1N2NM    TTN2SU
     C                     ELSE
     C                     ADD  U1S1NM    TTN1SU
     C                     ADD  U1S2NM    TTN2SU
     C                     END
     C                     END
      *
     C                     SETOF                     04
     C           KEY5      CHAINMBEPL051             04
     C           *IN04     IFEQ '0'
     C                     Z-ADD#JMM      U
     C                     ADD  #SRY,U    TTZGSU
     C                     ADD  1         TTENS
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
      *
     C           PKBN      IFEQ 'C'
     C           TTZSTS    DIV  @CD,4     XKTSU     H
     C                     ELSE
     C           TTZSTS    DIV  WCD       XKTSU     H
     C                     END
      *
     C           TTKSTS    DIV  WCD       XSURO     H
      *
     C           XKTSU     MULT 20        TZSTS   90
     C           XSURO     MULT 20        TKSTS   90
      *
     C           *IN99     IFEQ '1'
     C           TKSTS     ANDLTTZSTS
     C                     GOTO YPTE
     C                     END
      *
     C           XKTSU     DIV  TSYOS     WMO       H
     C           XSURO     DIV  TSYOS     WMN       H
     C                     Z-ADD0         WMON1
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON
     C           WMON1     MULT 100       $$WMON    H
      *
     C                     MOVE 'Z'       TZOGN   1
     C                     MOVE '+'       $$ZOGN
     C           WMN       IFLT WMO
     C                     MOVE 'G'       TZOGN
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           $$WMON    IFEQ 0
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           TZOGN     ANDEQ'G'
     C                     GOTO YPTE
     C                     END
      *
     C*-----------------------------------------------*
     C*     ...増減比率　＋－２５％未満処理しない   *
     C*-----------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO YPTE
     C                     END
      *
     C           TKSTS     DIV  20        WKTE      H
     C           TSYOS     IFNE 0
     C           WKTE      DIV  TSYOS     TKHTS     H
     C                     END
      *
     C           TZSTS     DIV  20        WKTE      H
     C           TSYOS     IFNE 0
     C           WKTE      DIV  TSYOS     TZHTS     H
     C                     END
      *
     C           TTN1SU    DIV  @CD,1     WKTE      H
     C           WKTE      MULT 20        TN1SU   90
     C           TSYOS     IFNE 0
     C           WKTE      DIV  TSYOS     TN1HS     H
     C                     END
      *
     C           TTN2SU    DIV  @CD,2     WKTE      H
     C           WKTE      MULT 20        TN2SU   90
     C           TSYOS     IFNE 0
     C           WKTE      DIV  TSYOS     TN2HS     H
     C                     END
      *
     C           TTZGSU    DIV  @CD,3     WKTE      H
     C           WKTE      MULT 20        TZGSU   90
     C           TSYOS     IFNE 0
     C           WKTE      DIV  TSYOS     TZGHS     H
     C                     END
      *
     C                     SETON                     U2
     C                     EXCPTF01
      *
     C                     MOVE WKHIN     $$SHIN
     C                     MOVE WTKR      $$TKRO
     C                     MOVE *BLANK    $$KCOD
     C                     Z-ADDWBMON     $$BMON
     C                     EXCPTRDT1
      *
     C           YPTE      TAG
     C                     END
     C                     END
      *
     C           END       TAG
