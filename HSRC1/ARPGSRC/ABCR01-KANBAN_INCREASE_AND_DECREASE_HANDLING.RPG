     C                     Z-ADDHOUR      CQURJI
     C                     Z-ADDMINUTE    CQURPN
     C                     MOVE 'B'       CQBNKA
     C                     MOVE WHIN3     CQHBSB
     C                     Z-ADDWMON      CQPAST
      *
     C                     Z-ADD@ZMIS     CQZMIS
     C                     Z-ADD@KMIS     CQKMIS
      *
     C                     SETOF                     10
     C                     Z-ADD1         X       20
     C                     Z-ADD0         CQMBMN
     C           @MBMN     LOKUPTB1,X                    10
     C           *IN10     IFEQ '1'
     C                     Z-ADDTB2,X     CQMBMN
     C                     ELSE
     C                     Z-ADD0111      CQMBMN
     C                     END
      *
     C                     MOVE '2'       CQDTSO
     C                     MOVE '15'      CQGYOM
     C           PKBN      IFEQ 'A'
     C                     MOVE '5'       CQDTSO
     C                     MOVE '14'      CQGYOM
     C                     END
     C           PKBN      IFEQ 'C'
     C                     MOVE '6'       CQDTSO
     C                     MOVE '14'      CQGYOM
     C                     END
      *
     C                     Z-ADDWSSYS     CQSYUY
     C                     MOVE WRTKR     CQTKR
      *
     C                     Z-ADDWJDMS     ZJDMS   30
     C           WJDMS     IFLT 0
     C           WJDMS     MULT -1        ZJDMS
     C                     END
      *
     C           WBARA     IFGE ZJDMS
      *
     C                     Z-ADDWYMD1     CQTHHZ
     C                     Z-ADDWYMD1     CQNOHZ
     C           WJDMS     MULT WSSYS     CQSRYO
     C           CQSRYO    DIV  WSSYS     CQHAKO
     C                     MVR            WS1     30
      *
     C           WS1       IFNE 0
     C           WS1       IFLT 0
     C                     SUB  1         CQHAKO
     C                     ELSE
     C                     ADD  1         CQHAKO
     C                     END
     C                     END
      *
     C                     SETOF                     10
     C           1         CHAINAU#NP11              10
     C           *IN10     IFEQ '0'
     C           AHZMM     IFNE UMONTH
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     ELSE
     C                     ADD  1         ARECD
     C                     END
      *
     C                     EXCPTUP
     C                     ELSE
      *
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     EXCPTWT
     C                     END
      *
     C                     Z-ADDARECD     CQJTNO
     C                     WRITEAU#PP511
     C                     ELSE
      *
     C           WJDMS     DIV  4         WA1     52
     C           WA1       MULT WSSYS     CQSRYO
     C           CQSRYO    DIV  WSSYS     CQHAKO
     C                     MVR            WS1
      *
     C           WS1       IFNE 0
     C           WS1       IFLT 0
     C                     SUB  1         CQHAKO
     C                     ELSE
     C                     ADD  1         CQHAKO
     C                     END
     C                     END
      *
     C                     Z-ADD1         A
     C           1         DO   4         A
     C                     Z-ADDHIZ,A     CQTHHZ
     C                     Z-ADDHIZ,A     CQNOHZ
      *
     C                     SETOF                     10
     C           1         CHAINAU#NP11              10
     C           *IN10     IFEQ '0'
     C           AHZMM     IFNE UMONTH
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     ELSE
