     C*------------------------------*
     C*     ...かんばん増減...     *
     C*------------------------------*
     C                     SETOF                     10
     C                     MOVE *BLANK    ASURI   2
     C           KEYB      CHAINAAMPL111             10
     C           *IN10     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C   10                GOTO END
      *
     C                     MOVE *BLANK    KOT
     C                     Z-ADD0         BUM
     C                     MOVE *BLANK    KTY
     C                     MOVE *BLANK    TKR
     C                     MOVE *BLANK    KHN
     C                     Z-ADD0         SUR
     C                     MOVE *BLANK    @TKR
      *
     C                     Z-ADD1         I
     C                     Z-ADD0         X       20
     C           1         DO   15        I
     C           CKKO,I    IFNE *BLANK
     C                     ADD  1         X
     C                     MOVE CKKO,I    KOT,X
     C                     Z-ADDCKBM,I    BUM,X
     C                     MOVE CKTY,I    KTY,X
     C                     MOVE CKNB,I    TKR,X
     C                     MOVE CKHB,I    KHN,X
     C                     Z-ADDCKSU,I    SUR,X
     C                     MOVE CKNB,I    @TKR
     C                     END
     C                     END
      *
     C                     Z-ADD1         E       20
     C                     Z-ADD16        I       20
     C           1         DO   15        E
     C                     SUB  1         I
     C           SUR,I     IFNE 0
      *
     C                     Z-ADDSUR,I     WSUROK  90
      *
     C           SUR,I     DIV  WCD       WRURO   90
     C                     MVR            WRURO1  90
     C           WRURO1    IFNE 0
     C                     ADD  1         WRURO
     C                     END
     C           WRURO     IFEQ 0
     C                     Z-ADD1         WRURO
     C                     END
      *
     C           WRURO     MULT 20        WSURO   90
     C           WSURO     IFEQ 0
     C                     Z-ADD1         WSURO
     C                     END
      *
      *
     C*--------------------------------*
     C*     ... ABHPL03                *
     C*     ...工程内かんばん...     *
     C*--------------------------------*
     C           KTY,I     IFEQ 'A'
      *
     C                     MOVE TKR,I     WTKR
     C                     MOVE KOT,I     WKOTI   3
     C                     Z-ADDBUM,I     WBMON   40
     C                     MOVE KHN,I     WKHIN
      *
     C           KEYC      SETLLABHPL031
      *
     C           YYP0      TAG
     C                     SETOF                     10
     C                     READ ABHPL031                 10
     C           *IN10     IFEQ '0'
     C           M6SKJY    ANDEQ'D'
     C           M6SKHZ    CABLE*DATE     YYP0
     C                     END
     C           *IN10     IFEQ '1'
     C                     GOTO AP1
     C                     END
      *
     C           M6JBAN    IFNE TKR,I
     C                     GOTO AP1
     C                     END
     C           M6STHZ    CABLE*DATE     YYP0
      *
     C           M6DTKO    IFEQ '2'
     C           M6DTKO    OREQ 'D'
     C                     Z-ADDWSURO     M6KTSU
     C                     GOTO YYP01
     C                     END
     C           M6SYUY    IFEQ 0
     C                     Z-ADDWSURO     M6KTSU
     C                     GOTO YYP01
     C                     END
      *
     C           M6KTSU    IFEQ WSURO
     C                     GOTO YYP01
     C                     END
      *
     C*------------------------------------------*
     C*  ..増減箱数・増減比率　の　チェック..  *
     C*------------------------------------------*
     C           M6KTSU    DIV  20        XKTSU   90H
     C           WSURO     DIV  20        XSURO   90H
      *
     C           XKTSU     DIV  M6SYUY    WMO    102H
     C           XSURO     DIV  M6SYUY    WMN    102H
     C                     Z-ADD0         WMON1   93
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON    51
     C           WMON1     MULT 100       $$WMON  40H
      *
     C                     MOVE 'Z'       #ZOGN   1
     C                     MOVE '+'       $$ZOGN  1
     C           WMN       IFLT WMO
     C                     MOVE 'G'       #ZOGN
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           $$WMON    IFEQ 0
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           #ZOGN     ANDEQ'G'
     C                     GOTO YYP01
     C                     END
      *
     C*-----------------------------------------------*
     C*     ...増減比率　＋－２５％未満処理しない   *
     C*-----------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO YYP01
     C                     END
      *
     C                     MOVE M6BMON    XBMN    4
     C                     MOVE WSURO     XKTS    9
     C                     MOVE M6SYUY    XSYU    7
     C                     MOVE M6LIGK    XGLT    4
     C                     MOVE M6ANZN    XANZ    3
     C                     MOVE M6BRAH    XBRA    3
     C                     MOVE M6SETO    XSET    3
     C                     MOVE M6ATLT    XALT    2
     C                     MOVE M6UKYY    XUYY    4
     C                     MOVE M6UKMM    XUMM    2
     C                     MOVE M6UKDD    XUDD    2
     C                     MOVE M6UBIN    XUBN    2
     C                     MOVE M6KJNK    PKJY    3
     C                     MOVE M6LOTK    PLOT    3
     C                     MOVE '000'     PMIS    3
     C                     MOVE *BLANK    ERR     1
