     C*     ... ABCR20                           *
     C*     ...工程内かんばん枚数　計算...     *
     C*------------------------------------------*
     C                     CALL 'ABCR20'
     C                     PARM           XBMN    4        部門
     C                     PARM           M6HIN1  5        品番・１
     C                     PARM           M6HIN2  5        　　・２
     C                     PARM           M6HIN3  2        　　・３
     C                     PARM           M6KSN1  1        計算区分１
     C                     PARM           M6KSN2  1        　　　　２
     C                     PARM           XKTS    9        確定設定数
     C                     PARM           XSYU    7        自工程収容数
     C                     PARM           XGLT    4        合計Ｌ・Ｔ
     C                     PARM           XANZ    3        安全率
     C                     PARM           XBRA    3        バラツキ箱数
     C                     PARM           XSET    3        セット数
     C                     PARM           XALT    2        後工程ロット
     C                     PARM           M6JBN1  1        所番地・１
     C                     PARM           M6JBN2  2        　　　・２
     C                     PARM           M6JBN3  2        　　　・３
     C                     PARM           M6JBN4  1        　　　・４
     C                     PARM           XUYY    4        有効日　年
     C                     PARM           XUMM    2        有効日　月
     C                     PARM           XUDD    2        有効日　日
     C                     PARM           XUBN    2        有効日　便
     C                     PARM           PKJY    3        基準値
     C                     PARM           PLOT    3        生産ロット
     C                     PARM           PMIS    3        かんばん枚数
     C                     PARM           ERR     1        エラー
      *
     C                     MOVE PKJY      WKJNK   30
     C                     MOVE PLOT      WLOTK   30
     C                     MOVE PMIS      WKMAX   30
      *
     C                     Z-ADD0         #KSTS   90
     C                     Z-ADD0         #KHTS   62
     C                     Z-ADD0         #ZSTS   90
     C                     Z-ADD0         #ZHTS   62
     C                     Z-ADD0         ##N1SU  90
     C                     Z-ADD0         #N1HS   62
     C                     Z-ADD0         ##N2SU  90
     C                     Z-ADD0         #N2HS   62
     C                     Z-ADD0         ##ZGSU  90
     C                     Z-ADD0         #ZGHS   62
     C                     Z-ADD0         #TENS   30
      *
     C                     Z-ADDWSUROK    ##KSTS  90
     C                     Z-ADDWSURO     #KSTS
     C           WSURO     DIV  20        WKTE    90H
     C           M6SYUY    IFNE 0
     C           WKTE      DIV  M6SYUY    #KHTS     H
     C                     END
      *
     C                     Z-ADDM6KTSU    #ZSTS
     C           M6KTSU    DIV  20        WKTE      H
     C           M6SYUY    IFNE 0
     C           WKTE      DIV  M6SYUY    #ZHTS     H
     C                     END
      *
     C                     Z-ADD0         W       40
     C                     MOVE *BLANK    #HIN
     C           KEY4      SETLLGHCPL221
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY4      READEGHCPL221                 02
     C           *IN02     IFEQ '0'
      *
     C                     SETOF                     04
     C                     Z-ADD1         A
     C           MMJHIN    LOKUP#HIN,A                   04
     C           *IN04     IFEQ '0'
     C                     ADD  1         W
     C                     MOVE MMJHIN    #HIN,W
      *
     C                     SETOF                     04
     C           KEY3      CHAINABBPL211             04
     C           *IN04     IFEQ '0'
     C           U1NGKB    IFEQ 'N'
     C                     ADD  U1N1NM    ##N1SU
     C                     ADD  U1N2NM    ##N2SU
     C                     ELSE
     C                     ADD  U1S1NM    ##N1SU
     C                     ADD  U1S2NM    ##N2SU
     C                     END
     C                     END
      *
     C                     SETOF                     04
     C           KEY5      CHAINMBEPL051             04
     C           *IN04     IFEQ '0'
     C                     Z-ADD#JMM      U       20
     C                     ADD  #SRY,U    ##ZGSU
     C                     ADD  1         #TENS
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
      *
     C           ##N1SU    DIV  @CD,1     WKTE      H
     C           WKTE      MULT 20        #N1SU   90
     C           M6SYUY    IFNE 0
     C           WKTE      DIV  M6SYUY    #N1HS     H
     C                     END
      *
     C           ##N2SU    DIV  @CD,2     WKTE      H
     C           WKTE      MULT 20        #N2SU   90
     C           M6SYUY    IFNE 0
     C           WKTE      DIV  M6SYUY    #N2HS     H
     C                     END
      *
     C           ##ZGSU    DIV  @CD,3     WKTE      H
     C           WKTE      MULT 20        #ZGSU   90
     C           M6SYUY    IFNE 0
     C           WKTE      DIV  M6SYUY    #ZGHS     H
     C                     END
      *
     C                     Z-ADD0         #KHPS   61
     C           #ZHTS     IFNE 0
     C           #KHTS     DIV  #ZHTS     #KHPS1  83H
     C           #KHPS1    MULT 100       #KHPS     H
     C                     END
      *
     C                     SETON                     U3
     C                     EXCPTKDT
      *
     C                     MOVE M6SHIN    $$SHIN 12
     C                     MOVE M6JBAN    $$TKRO  6
     C                     MOVE 'A'       $$KCOD  1
     C                     Z-ADDM6BMON    $$BMON  40
     C                     EXCPTRDT1
      *
     C           YYP01     TAG
     C                     Z-ADDWSURO     M6KSSU
     C                     UPDATABHPL031
     C                     GOTO YYP0
      *
     C                     END
      *
      *
     C*------------------------------*
     C*     ... ADHPL03              *
     C*     ...焼入かんばん...     *
     C*------------------------------*
     C           KTY,I     IFEQ 'B'
      *
     C                     MOVE TKR,I     WTKR
     C                     MOVE KOT,I     WKOTI
     C                     Z-ADDBUM,I     WBMON
     C                     MOVE KHN,I     WKHIN
      *
     C           KEYC      SETLLADHPL031
      *
     C           YYP1      TAG
     C                     SETOF                     10
     C                     READ ADHPL031                 10
     C           *IN10     IFEQ '0'
     C           J6SKJY    ANDEQ'D'
     C           J6SKHZ    CABLE*DATE     YYP1
     C                     END
     C           *IN10     IFEQ '1'
     C                     GOTO AP1
     C                     END
      *
     C           J6ATKR    IFNE TKR,I
     C                     GOTO AP1
     C                     END
      *
     C           J6STHZ    CABLE*DATE     YYP1
      *
     C           J6DTKO    IFEQ '2'
     C           J6DTKO    OREQ 'D'
     C                     Z-ADDWSURO     J6KTSU
     C                     GOTO YYP11
     C                     END
     C           J6SYOS    IFEQ 0
     C                     Z-ADDWSURO     J6KTSU
     C                     GOTO YYP11
     C                     END
      *
     C           J6KEI2    IFEQ 'E'
     C                     GOTO YYP11
     C                     END
      *
     C           J6KTSU    IFEQ WSURO
     C                     GOTO YYP11
     C                     END
      *
     C           J6KTSU    DIV  20        XKTSU     H
     C           WSURO     DIV  20        XSURO     H
      *
     C           XKTSU     DIV  J6SYOS    WMO       H
     C           XSURO     DIV  J6SYOS    WMN       H
     C                     Z-ADD0         WMON1
     C           WMO       IFNE 0
     C           WMN       DIV  WMO       WMON1     H
     C                     END
     C           WMON1     MULT 100       WMON
     C           WMON1     MULT 100       $$WMON    H
      *
     C                     MOVE 'Z'       @ZOGN   1
     C                     MOVE '+'       $$ZOGN
     C           WMN       IFLT WMO
     C                     MOVE 'G'       @ZOGN
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           $$WMON    IFEQ 0
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           @ZOGN     ANDEQ'G'
     C                     GOTO YYP11
     C                     END
      *
     C*-----------------------------------------------*
     C*     ...増減比率　＋－２５％未満処理しない   *
     C*-----------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO YYP11
     C                     END
      *
     C                     MOVE '000'     YWMISU  3
     C                     MOVELJ6KTSU    YWKTSU  9
     C                     MOVELJ6SYOS    YWSYOS  7
     C                     MOVELJ6KAKE    YWKAKE  2
     C                     MOVELJ6NKOJ    YWATOB  4
     C                     MOVELJ6HKLT    YWHKLT  2
     C                     MOVELJ6LOTO    YWLOTO  2
     C                     MOVELJ6TOLT    YWTOLT  3
     C                     MOVELJ6ANZR    YWANZR  3
     C                     MOVELJ6SETO    YWSETO  2
     C                     MOVELJ6BRAH    YWBRAH  2
     C                     MOVELJ6UKYY    YWUKYY  4
     C                     MOVELJ6UKMM    YWUKMM  2
     C                     MOVELJ6UKDD    YWUKDD  2
     C                     MOVELJ6UBIN    YWUBIN  2
     C                     MOVELJ6MAKB    YWMAKB  4
     C                     MOVEL*BLANK    YWERR   1
      *
     C*----------------------------------------*
     C*     ... ABCR21                         *
     C*     ...焼入かんばん枚数　計算...     *
     C*----------------------------------------*
     C                     CALL 'ABCR21'
     C                     PARM           J6KEI1
     C                     PARM           J6KEI2
     C                     PARM           YWKTSU
     C                     PARM           YWSYOS
     C                     PARM           YWKAKE
     C                     PARM           J6SHN1
     C                     PARM           J6SHN2
     C                     PARM           J6SHN3
     C                     PARM           YWATOB
     C                     PARM           J6ATOK
     C                     PARM           J6ATK1
     C                     PARM           J6ATK2
     C                     PARM           J6ATK3
     C                     PARM           J6ATK4
     C                     PARM           YWHKLT
     C                     PARM           YWLOTO
     C                     PARM           YWTOLT
     C                     PARM           YWANZR
     C                     PARM           YWSETO
     C                     PARM           YWBRAH
     C                     PARM           YWUKYY
     C                     PARM           YWUKMM
     C                     PARM           YWUKDD
     C                     PARM           YWUBIN
     C                     PARM           YWMAKB
     C                     PARM           J6MTYP
     C                     PARM           YWMISU
     C                     PARM           YWERR
      *
     C                     MOVELYWMISU    @NMAS   30
     C                     Z-ADDJ6KMAX    @OMAS   30
      *
     C                     Z-ADD0         @KSTS   90
     C                     Z-ADD0         @KHTS   62
     C                     Z-ADD0         @ZSTS   90
     C                     Z-ADD0         @ZHTS   62
     C                     Z-ADD0         @@N1SU  90
     C                     Z-ADD0         @N1HS   62
     C                     Z-ADD0         @@N2SU  90
     C                     Z-ADD0         @N2HS   62
     C                     Z-ADD0         @@ZGSU  90
     C                     Z-ADD0         @ZGHS   62
     C                     Z-ADD0         @TENS   30
      *
     C                     Z-ADDWSUROK    @@KSTS  90
     C                     Z-ADDWSURO     @KSTS
     C           WSURO     DIV  20        WKTE      H
     C           J6SYOS    IFNE 0
     C           WKTE      DIV  J6SYOS    @KHTS     H
     C                     END
      *
     C                     Z-ADDJ6KTSU    @ZSTS
     C           J6KTSU    DIV  20        WKTE      H
     C           J6SYOS    IFNE 0
     C           WKTE      DIV  J6SYOS    @ZHTS     H
     C                     END
      *
     C                     Z-ADD0         W
     C                     MOVE *BLANK    #HIN
     C           KEY4      SETLLGHCPL221
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY4      READEGHCPL221                 02
     C           *IN02     IFEQ '0'
      *
     C                     SETOF                     04
     C                     Z-ADD1         A
     C           MMJHIN    LOKUP#HIN,A                   04
     C           *IN04     IFEQ '0'
     C                     ADD  1         W
     C                     MOVE MMJHIN    #HIN,W
      *
     C                     SETOF                     04
     C           KEY3      CHAINABBPL211             04
     C           *IN04     IFEQ '0'
     C           U1NGKB    IFEQ 'N'
     C                     ADD  U1N1NM    @@N1SU
     C                     ADD  U1N2NM    @@N2SU
     C                     ELSE
     C                     ADD  U1S1NM    @@N1SU
     C                     ADD  U1S2NM    @@N2SU
     C                     END
     C                     END
      *
     C                     SETOF                     04
     C           KEY5      CHAINMBEPL051             04
     C           *IN04     IFEQ '0'
     C                     Z-ADD#JMM      U
     C                     ADD  #SRY,U    @@ZGSU
     C                     ADD  1         @TENS
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
      *
     C           @@N1SU    DIV  @CD,1     WKTE      H
     C           WKTE      MULT 20        @N1SU   90
     C           J6SYOS    IFNE 0
     C           WKTE      DIV  J6SYOS    @N1HS     H
     C                     END
      *
     C           @@N2SU    DIV  @CD,2     WKTE      H
     C           WKTE      MULT 20        @N2SU   90
     C           J6SYOS    IFNE 0
     C           WKTE      DIV  J6SYOS    @N2HS     H
     C                     END
      *
     C           @@ZGSU    DIV  @CD,3     WKTE      H
     C           WKTE      MULT 20        @ZGSU   90
     C           J6SYOS    IFNE 0
     C           WKTE      DIV  J6SYOS    @ZGHS     H
     C                     END
      *
     C                     SETON                     U5
     C                     EXCPTYDT
      *
     C                     MOVE J6SHIN    $$SHIN
     C                     MOVE J6ATKR    $$TKRO
     C                     MOVE 'B'       $$KCOD
     C                     Z-ADDJ6ATOB    $$BMON
     C                     EXCPTRDT1
      *
     C           YYP11     TAG
     C                     Z-ADDWSURO     J6KSSU
     C                     UPDATADHPL031
     C                     GOTO YYP1
      *
     C                     END
      *
      *
     C*--------------------------------*
     C*     ... AAFPL03                *
     C*     ...メッキかんばん...     *
     C*--------------------------------*
     C           KTY,I     IFEQ 'C'
      *
     C                     MOVE TKR,I     WTKR
     C                     MOVE *BLANK    WSY     1
     C                     Z-ADD0         WSTHZ   80
     C                     MOVE *BLANK    WKC     1
     C                     MOVE *BLANK    WKC1    1
      *
     C           KEYC      SETLLAAFPL031
      *
     C           YP2       TAG
     C                     SETOF                     10
     C                     READ AAFPL031                 10
     C           *IN10     IFEQ '0'
     C           A3SKJY    ANDEQ'D'
     C           A3SKHZ    CABLE*DATE     YP2
     C                     END
      *
     C           *IN10     IFEQ '1'
     C           WSY       IFEQ 'Y'
     C           WSTHZ     IFEQ 99999999
     C                     EXSR SUBRTN
     C                     END
     C                     END
     C                     GOTO AP1
     C                     END
      *
     C           A3ATKR    IFNE TKR,I
     C           WSY       IFEQ 'Y'
     C           WSTHZ     IFEQ 99999999
     C                     EXSR SUBRTN
     C                     END
     C                     END
     C                     GOTO AP1
     C                     END
      *
     C           A3STHZ    CABLE*DATE     YP2
      *
     C           A3DTKO    IFEQ '2'
     C           A3DTKO    OREQ 'D'
     C                     GOTO YP21
     C                     END
     C           A3SSYS    IFEQ 0
     C                     GOTO YP21
     C                     END
     C           A3KTSU    IFEQ WRURO
     C                     GOTO YP22
     C                     END
      *
     C*----------------------------------------------*
     C*  ..Ａ－ＰＩＣＳＩ平準化確定発注ファイル..  *
     C*----------------------------------------------*
     C           WKC1      IFEQ *BLANK
     C                     MOVE '*'       WKC1
      *
     C                     SETOF                     10
     C                     MOVE A31HB5    WDHN1   5
     C                     MOVE A32HB5    WDHN2   5
     C                     MOVE A33HB2    WDHN3   2
     C           KEY1      CHAINAGAPL311             10
     C           *IN10     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           CBKDAI    ANDEQ'C'
      *
     C                     SETOF                     10
     C                     Z-ADD1         F       20
     C           A3ATKR    LOKUPTKR,F                    10
     C           *IN10     IFEQ '1'
     C           'C'       ANDEQKTY,F
      *
     C                     ADD  1         F
     C           F         IFGT 15
     C                     MOVE '*'       WKC
     C                     ELSE
      *
     C                     SETOF                     10
     C                     Z-ADD1         G       20
     C           F         DO   15        G
     C           KOT,G     IFEQ *BLANK
     C                     SETON                     10
     C                     MOVE '*'       WKC
     C                     ELSE
     C           KTY,G     IFNE *BLANK
     C                     SETON                     10
     C                     END
     C                     END
     C  N10                END
      *
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*----------------------------*
     C*  ..Ａ－ＰＩＣＳでない..  *
     C*----------------------------*
     C           WKC       IFNE '*'
      *
     C           WRURO     DIV  A3KTSU    WMON1     H
     C           WMON1     MULT 100       WMON
     C           WMON1     MULT 100       $$WMON    H
      *
     C                     MOVE '+'       $$ZOGN
     C           WRURO     IFLT A3KTSU
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           $$WMON    IFEQ 0
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C*--------------------------------------------*
     C*  ..増減比率　＋－２５％未満処理しない..  *
     C*--------------------------------------------*
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     GOTO YP22
     C                     END
     C                     END
      *
     C                     Z-ADD0         WMAIS   40
      *
     C*------------------------------------------*
     C*     ... ABCR05                           *
     C*     ...メッキかんばん枚数　計算...     *
     C*------------------------------------------*
     C                     CALL 'ABCR05'
     C                     PARM           ASURI
     C                     PARM           WRURO
     C                     PARM           A3SSYS
     C                     PARM           A3KEIS
     C                     PARM           A3READ
     C                     PARM           A3BARA
     C                     PARM           A3CBKO
     C                     PARM           A3LOTO
     C                     PARM           A3MAXH
     C                     PARM           WMAIS
      *
     C                     Z-ADDA3KMAX    @ZMIS   30
     C                     Z-ADDWMAIS     @KMIS   30
      *
     C           WMAIS     IFEQ A3KMAX
     C                     Z-ADDWRURO     A3KTSU
     C                     GOTO YP22
     C                     END
      *
     C           *IN99     IFEQ '1'
     C           WMAIS     ANDLTA3KMAX
     C                     GOTO YP22
     C                     END
      *
     C           WMAIS     IFGT A3KMAX
     C                     MOVE '8'       A3DTKO
     C                     ELSE
     C                     MOVE '9'       A3DTKO
     C                     END
      *
     C           A3DTKO    IFEQ 'E'
     C           WMAIS     SUB  A3JDMS    SJDMS   30
     C                     MOVE '1'       A3DTKO
     C                     Z-ADD0         A3JDMS
     C                     ELSE
     C           WMAIS     SUB  A3KMAX    SJDMS
     C                     END
      *
     C           A3DOUT    IFNE *BLANK
     C           A3KALL    ANDLTA3KMAX
     C                     Z-ADDA3KMAX    A3KALL
     C                     END
      *
     C                     Z-ADDA3KMAX    A3KMIN
     C                     Z-ADDA3KMAX    A3KAIS
     C                     Z-ADDWMAIS     A3KMAX
      *
     C*----------------------*
     C*  ..Ａ－ＰＩＣＳ..  *
     C*----------------------*
     C           WKC       IFEQ '*'
     C                     Z-ADDCBMBMN    @MBMN   40
     C                     Z-ADDA3STHZ    WSTHZ
     C                     MOVE A31HB5    WRHN1   5
     C                     MOVE A32HB5    WRHN2   5
     C                     MOVE A33HB2    WRHN3   2
     C                     MOVE A3ATKR    WRTKR   6
     C                     Z-ADDA3BARA    WBARA   20
     C                     Z-ADDSJDMS     WJDMS   30
     C                     Z-ADDA3SSYS    WSSYS   50
     C                     MOVE A33HB2    WHIN3   2
     C                     MOVE *BLANK    A3KOUT
     C                     MOVE 'Y'       A3DOUT
     C                     MOVE 'Y'       WSY
      *
     C           A3STHZ    IFEQ 99999999
      *
     C           @KMIS     DIV  @ZMIS     WMON1     H
     C           WMON1     MULT 100       WMON
     C           WMON1     MULT 100       $$WMON    H
      *
     C           WMON      IFGE 75.0
     C           WMON      ANDLE125.0
     C                     ELSE
      *
     C                     MOVE '+'       $$ZOGN
     C           @KMIS     IFLT @ZMIS
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C           $$WMON    IFEQ 0
     C                     MOVE '-'       $$ZOGN
     C                     END
      *
     C                     MOVE A3SHIN    $$SHIN
     C                     MOVE A3ATKR    $$TKRO
     C                     MOVE 'C'       $$KCOD
     C                     Z-ADDA3ATOB    $$BMON
     C                     EXCPTRDT1
     C                     END
     C                     END
      *
     C                     GOTO YP21
     C                     END
      *
     C                     MOVE 'Y'       A3KOUT
     C                     MOVE *BLANK    A3DOUT
      *
     C                     MOVE A3SHIN    $$SHIN
     C                     MOVE A3ATKR    $$TKRO
     C                     MOVE 'C'       $$KCOD
     C                     Z-ADDA3ATOB    $$BMON
     C                     EXCPTRDT1
      *
     C           YP21      TAG
     C                     Z-ADDWRURO     A3KTSU
     C                     Z-ADD*YEAR     A3KOYY
     C                     Z-ADDUMONTH    A3KOMM
     C                     Z-ADDUDAY      A3KODD
     C                     TIME           HMS
     C                     Z-ADDHOUR      A3KOHH
     C                     Z-ADDMINUTE    A3KOSS
     C                     MOVE *BLANK    A3KOME
     C                     MOVEL'ZOUGEN'  A3KOME
      *
     C           YP22      TAG
     C                     Z-ADDWRURO     A3KSSU
     C                     UPDATAAFPL031
     C                     GOTO YP2
      *
     C                     END
      *
      *
     C*----------------------------------*
     C*     ... AAGPL03                  *
     C*     ...トンネルかんばん...     *
     C*----------------------------------*
     C           KTY,I     IFEQ 'D'
      *
     C                     MOVE TKR,I     WTKR
     C                     MOVE *BLANK    WSY
     C                     Z-ADD0         WSTHZ
     C                     MOVE *BLANK    WKD     1
     C                     MOVE *BLANK    WKD1    1
      *
     C           KEYC      SETLLAAGPL031
      *
     C           YP3       TAG
     C                     SETOF                     10
     C                     READ AAGPL031                 10
     C           *IN10     IFEQ '0'
     C           O4SKJY    ANDEQ'D'
     C           O4SKHZ    CABLE*DATE     YP3
     C                     END
      *
     C           *IN10     IFEQ '1'
     C           WSY       IFEQ 'Y'
     C           WSTHZ     IFEQ 99999999
     C                     EXSR SUBRTN
     C                     END
     C                     END
     C                     GOTO AP1
     C                     END
      *
     C           O4AKRO    IFNE TKR,I
     C           WSY       IFEQ 'Y'
     C           WSTHZ     IFEQ 99999999
     C                     EXSR SUBRTN
     C                     END
     C                     END
     C                     GOTO AP1
     C                     END
      *
     C           O4STHZ    CABLE*DATE     YP3
      *
     C           O4DTKO    IFEQ '2'
     C           O4DTKO    OREQ 'D'
     C                     GOTO YP31
     C                     END
     C           O4SYOS    IFEQ 0
     C                     GOTO YP31
     C                     END
     C           O4KTSU    IFEQ WRURO
