      *
     C                     MOVE PYM       #YM
     C                     MOVE PYM       ##YM
     C                     MOVE PJYM      #JYM
     C                     MOVE PCD       WCD     31
      *
     C           *IN01     IFEQ '0'
     C                     SETON                     01
      *
     C                     Z-ADD*DATE     WYMD
     C           PKBN      IFEQ 'B'
     C           PKBN      OREQ 'C'
     C           PKBN      OREQ 'D'
     C                     SETON                     99
     C                     END
      *
     C                     Z-ADD0         HIZ
     C           KEYA      SETGTAGDPL111
     C                     SETOF                     02
     C                     READ AGDPL111                 02
     C           *IN02     IFEQ '1'
     C                     SETON                       U1LR
     C                     RETRN
     C                     END
     C                     Z-ADDF8KAYM    WYMD1   80
      *
     C           KEYA      SETGTAGDPL111
     C                     Z-ADD1         A       40
     C                     Z-ADD0         B       10
      *
     C           1         DO   6         A
     C                     SETOF                     02
     C                     READ AGDPL111                 02
     C           *IN02     IFEQ '1'
     C                     SETON                       U1LR
     C                     RETRN
     C                     END
     C           A         IFGE 3
     C                     ADD  1         B
     C                     Z-ADDF8KAYM    HIZ,B
     C                     END
     C                     END
      *
     C                     Z-ADD1         A
     C                     Z-ADD0         @HZ
     C           1         DO   2         A
     C           #MM       IFEQ 12
     C                     ADD  1         #YY
     C                     Z-ADD01        #MM
     C                     ELSE
     C                     ADD  1         #MM
     C                     END
     C                     Z-ADD#YM       @HZ,A
     C                     END
      *
     C                     Z-ADD0         @CD
     C                     Z-ADD0         #CD     31
     C                     Z-ADD#JYM      #YM
      *
     C           KEY2      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY2      READEAGDPL121                 02
     C           *IN02     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         #CD
     C                     ELSE
     C                     ADD  0.5       #CD
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
     C                     Z-ADD#CD       @CD,3
      *
     C                     Z-ADD0         #CD
     C                     Z-ADDWYM       #YM
      *
     C           KEY2      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY2      READEAGDPL121                 02
     C           *IN02     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         #CD
     C                     ELSE
     C                     ADD  0.5       #CD
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
     C                     Z-ADD#CD       @CD,4
      *
     C                     Z-ADD1         A
     C           1         DO   2         A
     C                     Z-ADD0         #CD
     C                     Z-ADD@HZ,A     #YM
      *
     C           KEY2      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     02
     C           KEY2      READEAGDPL121                 02
     C           *IN02     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         #CD
     C                     ELSE
     C                     ADD  0.5       #CD
     C                     END
      *
     C                     END
     C                     END
     C  N02                END
     C                     Z-ADD#CD       @CD,A
     C                     END
