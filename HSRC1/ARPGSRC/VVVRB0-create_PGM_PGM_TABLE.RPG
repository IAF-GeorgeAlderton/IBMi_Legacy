     H            Y.
     F** VVVRB0 ****************************
     F* CREATE PGM-PGM TABLE               *
     F**************************************
     FVVVWPA0 IF  E                    DISK
     FVVVPPB0 O   E                    DISK                      A
      *
     I            DS
     I                                        1  11 WHFNAM
     I                                        4   5 PP
      *
     C                     READ VVVWPA0                  81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB001
     C                     READ VVVWPA0                  81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------*
      *                                         *
      *-----------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     MOVELWHPNAM    VWPNAM
     C                     MOVELWHTEXT    VWTEXT
     C                     MOVELWHFNAM    VWFNAM
     C           WHOTYP    IFEQ '*PGM'
     C           WHFNAM    IFNE *BLANK
     C                     WRITEVVVPPB01
     C                     ENDIF
     C                     ENDIF
     C           PP        IFEQ 'PW'
     C           PP        OREQ 'PR'
     C                     WRITEVVVPPB01
     C                     ENDIF
      *
     CSR         ESB001    ENDSR
