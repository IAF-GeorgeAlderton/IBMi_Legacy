     H            Y.
     F** AL#RT2  *******************************************
     F*  AL#WP10,11                                        *
     F*      ITS.        2015.05.19                        *
     F******************************************************
     FAL#PL11 UF  E           K        DISK
     FAL#WP10 UF  E           K        DISK                      A
     FAL#WP11 O   E                    DISK                      A
      *
     I            DS
     I                                        1   9 @9
     I                                        1   4 XCUST
     I                                        5   5 XFACT
     I                                        6   9 XSHTO
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHID  8
     C                     PARM           P1SHIT  6
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           KEYC1     KLIST
     C                     KFLD           KKSHID  8
     C*********            KFLD           KKSHIT  6
     C                     MOVELP1SHID    KKSHID
     C*********            MOVELP1SHIT    KKSHIT
     C           KEYC1     SETLLAL#PL111
     C           KEYC1     READEAL#PL111                 81
     C           *IN81     DOWEQ'0'
     C           C1SKJY    IFEQ 'D'
     C           C1SKHZ    ANDLESDATE
     C                     ELSE
     C           C1FIXD    IFEQ 0
     C                     EXSR #SB500
     C                     EXSR #SB501
     C*****                Z-ADDSDATE     C1FIXD
     C*****                Z-ADDSTIME     C1FIXT
     C                     UPDATAL#PL111
     C                     ENDIF
     C                     ENDIF
     C           KEYC1     READEAL#PL111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WP10
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           C1SHID
     C                     KFLD           K1TRKB  2
     C                     KFLD           C1SURT
      *
     C                     MOVEL'00'      K1TRKB
     C           KEYW0     CHAINAL#WP101             22
     C           *IN22     IFEQ '0'
     C                     ADD  1         W0KPLT
     C                     UPDATAL#WP101
     C                     ELSE
     C                     CLEARAL#WP101
     C                     MOVELC1SHID    W0SHID
     C**********           MOVELC1SHIT    W0SHIT
     C                     MOVEL*BLANK    W0SHIT
     C                     MOVELC1SURT    W0SURT
     C                     Z-ADDC1EXTR    W0EXTR
     C                     Z-ADD1         W0KPLT
     C                     MOVEL'00'      W0TRKB
     C                     WRITEAL#WP101
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  AL#WP11
      *-----------------------------------------------------
     CSR         #SB501    BEGSR
      *
     C                     CLEARAL#WP111
     C                     MOVELC1NONY    W1NONY
     C                     MOVELC1NKOJ    W1NKOJ
     C                     MOVELC1NUKE    W1NUKE
     C                     MOVELC1ORD#    W1ORD#
     C                     MOVELC1SHID    W1SHID
     C**********           MOVELC1SHIT    W1SHIT
     C                     MOVEL*BLANK    W1SHIT
     C                     MOVELC1SURT    W1SURT
     C                     Z-ADDC1EXTR    W1EXTR
     C                     MOVELC1PALT    W1PALT
     C                     Z-ADDC1BOX     W1BOX
     C                     MOVEL'00'      W1TRKB
     C                     WRITEAL#WP111
      *
     CSR         ESB501    ENDSR
