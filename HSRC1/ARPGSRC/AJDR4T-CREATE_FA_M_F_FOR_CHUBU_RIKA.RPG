     C                     MOVE C2SHN2    KOTK2   5
     C                     MOVE C2SHN3    KOTK3   2
     C                     SETOF                     99
     C                     EXSR KOTEI
     C           *IN99     IFEQ '1'
     C                     MOVELMSG,ER    PMSG
     C                     END
     C*************************
     C*メッキ係数の計算(SUB)*
     C*************************
     C                     SETOF                     96
     C                     EXSR MEKKI
     C*
     C           *IN96     IFEQ '1'
     C                     Z-ADD0         J1MKRI           理論値
     C                     ELSE
     C                     Z-ADDK         J1MKRI           理論値
     C                     END
      ****************************
      *メッキ係数使用区分の入力*
      * ０＝無　１＝理　２＝実 *
      ****************************
     C           J1MKRI    IFEQ 0
     C                     MOVE '0'       J1MKSK           使用区分
     C                     ELSE
     C           J1MKRI    IFNE ODMKRI
     C                     SETON                     55
     C                     MOVE '1'       J1MKSK
     C                     ENDIF
     C                     END
     C************************************
     C*その他の内容をＦＡマスターに入力*
     C************************************
     C                     Z-ADD0         J1KANS
     C                     Z-ADD0         J1HHAK
     C                     MOVE *BLANK    J1NOP
     C*
     C                     MOVE *BLANK    J1MSNS
     C                     MOVE *BLANK    J1MSZK
     C*更新日・者
     C                     MOVE *BLANK    J1SKJY
     C                     Z-ADD*ZERO     J1SKYY
     C                     Z-ADD*ZERO     J1SKMM
     C                     Z-ADD*ZERO     J1SKDD
     C                     Z-ADD*YEAR     J1KOYY
     C                     Z-ADDUMONTH    J1KOMM
     C                     Z-ADDUDAY      J1KODD
     C                     Z-ADDUJI       J1KOHH
     C                     Z-ADDUFUN      J1KOSS
     C                     MOVEL'AJDR4T'  J1KOME
     C******************************
     C*   ＦＡマスターに書出し   *
     C******************************
     C           C2RAIN    IFEQ 'A'
     C                     MOVE '01'      J1MKBN
     C                     ENDIF
     C           C2RAIN    IFEQ 'D'
     C                     MOVE '51'      J1MKBN
     C                     ENDIF
      *
     C           C2UPKB    IFEQ '0'
     C                     WRITEAJSPL011
     C           OUTKEN    ADD  1         OUTKEN  70
     C                     EXCPTCHG
     C*
     C                     ELSE
     C                     Z-ADDC2MKJI    J1MKJI
     C                     MOVE C2SYKB    J1MKSK
     C                     MOVE '1'       J1MENT
     C                     UPDATAJSPL011
     C           UPKEN     ADD  1         UPKEN   70
     C* ＦＡＭの変更有りかのチェック(MKSUB) *
     C                     EXSR MKSUB
     C                     ENDIF
      *
     C                     ENDDO
