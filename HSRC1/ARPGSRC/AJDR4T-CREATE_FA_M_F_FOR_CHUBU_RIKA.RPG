     C** BUHIN *********************************
     C*部品マスターにチェインするサブルーチン*
     C******************************************
     C           BUHIN     BEGSR
     C*
     C           KEY1      KLIST
     C                     KFLD           BUHK1
     C                     KFLD           BUHK2
     C                     KFLD           BUHK3
     C*
     C                     SETOF                     31
     C           KEY1      CHAINFCEPL011             31
     C           *IN31     IFEQ '0'
     C*引ける*
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    IFLE *DATE
     C                     Z-ADD2         ER
     C                     SETON                     99
     C                     GOTO SREX1
     C                     END
     C                     END
     C*首下が０*
     C           A2KUBI    IFEQ 0
     C                     SETON                     99
     C                     Z-ADD5         ER
     C                     END
     C*
     C                     ELSE
     C*引けない*
     C                     Z-ADD1         ER
     C                     SETON                     99
     C                     GOTO SREX1
     C                     END
     C*部品マスターの内容をＦＡマスターに入力*
     C                     MOVE A2ZETI    J1ZETI           絶対番号
TCHK1C*
TCHK2C                     Z-ADDA3SSYS    J1NSYU
TCHK2C                     MOVE A3SSYT    J1NHKS
     C                     Z-ADDA2KSYS    J1OSYU           旧収容数
     C                     MOVE A2KSYT    J1OHKS           旧箱種
     C                     Z-ADDA2SYYY    J1SKIY           収容切替年
     C                     Z-ADDA2SYMM    J1SKIM           収容切替月
     C                     Z-ADDA2SYDD    J1SKID           収容切替日
     C                     Z-ADDA2KUBI    J1MSKB           電・首下
     C                     Z-ADDA2TUSZ    J1MSKE           電・径
     C                     MOVE A2BHIN    J1MSKJ           電・形状
     C           A2SYK1    ADD  A2SYK2    WASYA   20
     C           WASYA     ADD  A2SYK3    WASYA
     C           WASYA     ADD  A2SYK4    J1MSWS           電・ワッシャ数
     C*メッキコードは各かんばんマスターより入力する
     C*空白の時のみ部品マスターより入力する
     C           J1MEK1    IFEQ *BLANK
     C           J1MEK2    ANDEQ*BLANK
     C           J1MEK3    ANDEQ*BLANK
     C                     MOVE A2MEK1    J1MEK1           メッキ処理１
     C                     MOVE A2MEK2    J1MEK2           メッキ処理２
     C                     MOVE A2MEK3    J1MEK3           メッキ処理３
     C*メッキ膜厚*
     C                     SETOF                     16
     C           MK1CHR    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C           *IN16     IFEQ '1'
     C                     MOVE MK1CHR    MK1SUU
     C                     ELSE
     C                     MOVE '0'       MK1SUU
     C                     END
     C                     SETOF                     16
     C           MK2CHR    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C           *IN16     IFEQ '1'
     C                     MOVE MK2CHR    MK2SUU
     C                     ELSE
     C                     MOVE '0'       MK2SUU
     C                     END
     C                     Z-ADDMAKU      J1MSMA           電・メッキ膜厚
     C*
     C           A2MIRO    IFEQ '.'
     C                     MOVE *BLANK    J1MSCK
     C                     ELSE
     C                     MOVE A2MIRO    J1MSCK           電・着色区分
     C                     END
     C*
     C                     MOVE *BLANK    J1MSAK           電・あき
     C                     END
     C*
     C           SREX1     TAG
     C                     ENDSR
      *
     C** TANJYU **************************************
     C*メッキ売掛金マスターで単重を入力サブルーチン*
     C************************************************
     C           TANJYU    BEGSR
     C           KEY2      KLIST
     C                     KFLD           TAHIN1
     C                     KFLD           TAHIN2
     C                     KFLD           TAHIN3
     C*メッキ売掛金マスターチェイン*
     C                     SETOF                     1097
     C           KEY2      CHAINAARTL13              10
     C*引けない*
     C           *IN10     IFEQ '1'
     C                     SETON                     97
     C                     ELSE
     C*引ける*
     C           CSSKJY    IFEQ 'D'
     C           CSSKHZ    IFLE *DATE
     C                     SETON                     97
     C                     END
     C                     END
     C                     END
     C*完成単重をＦＡマスターに入力*
     C           *IN97     IFEQ '0'
     C                     Z-ADDCSTANJ    J1TANJ
     C                     ELSE
     C                     Z-ADD0         J1TANJ
     C                     END
     C                     ENDSR
     C** KOTEI *********************************
