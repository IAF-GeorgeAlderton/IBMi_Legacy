     C                     MOVELC2SHN2    TAHIN2  5
     C                     MOVELC2SHN3    TAHIN3  2
     C                     EXSR TANJYU
     C           J1TANJ    IFEQ 0
     C                     MOVE MSG,6     PMSG
     C                     END
     C**************************************
     C*工程マスターで焼入れ有無入力(SUB) *
