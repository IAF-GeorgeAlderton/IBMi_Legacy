     C           KEY01     KLIST
     C                     KFLD           WWHIN1  5
     C                     KFLD           WWHIN2  5
     C                     KFLD           WWHIN3  2
      *----------------------------------------------------------------
      *メインルーチン
      *----------------------------------------------------------------
     C                     TIME           WTIME   60
      *メッキかんばん
     C                     EXSR $SBAAF
      *指示かんばん
     C                     EXSR $SBCAD
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------------------
      *メッキかんばんマスターの読込み*
      *----------------------------------------------------------------
     C           $SBAAF    BEGSR
      *
     C           1         SETLLAJSWP40
     C                     SETOF                     30
     C                     DO   *HIVAL
     C                     READ AJSWP40                  30
     C   30                LEAVE
     C*
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C*件数のカウント*
     C           ALLKEN    ADD  1         ALLKEN  70
     C*
     C*ＦＡマスターＵＰＤＡＴの為のみのＣＨＡＩＮ(SUB) *
     C                     SETOF                     95
     C           A3UPKB    IFEQ '1'
     C                     MOVE '*'       UP      1
     C                     MOVE A31HB5    WWHIN1  5        社内品番１
     C                     MOVE A32HB5    WWHIN2  5        社内品番２
     C                     MOVE A33HB2    WWHIN3  2        社内品番３
     C                     MOVE A31HB5    J1SHN1
     C                     MOVE A32HB5    J1SHN2
     C                     MOVE A33HB2    J1SHN3
     C* FA MASTER CHAIN SUB
     C                     EXSR CHSUB
     C*
     C           *IN95     IFEQ '1'
     C                     MOVELMSG,7     PMSG
     C                     ITER
     C                     ENDIF
     C*
     C                     ELSE
     C                     MOVE ' '       UP
     C                     ENDIF
     C*
     C*ＦＡＭフィールドクリアーと旧変数格納(SUB) *
     C                     EXSR CLRSUB
     C*メッキかんばんマスターの内容をＦＡマスターに入力*
     C                     MOVE A31HB5    J1SHN1           社内品番１
     C                     MOVE A32HB5    J1SHN2           社内品番２
     C                     MOVE A33HB2    J1SHN3           社内品番３
     C                     Z-ADDA3ATOB    J121CD           二次１加工先
     C                     MOVE A3JOK1    J121M1           二次１ＢＺ１１
     C                     MOVE A3JOK2    J121M2           二次１ＢＺ１２
     C                     MOVE A3JOK3    J1NS11           荷姿条件１１
     C                     MOVE A3JOK4    J1NS21           荷姿条件２１
     C                     MOVE A3JOK5    J1NS22           荷姿条件２２
     C                     MOVE A3JOK6    J1NS23           荷姿条件２３
     C                     MOVE A3KCD1    J1KDAI           かんばん大
     C                     MOVE A3KCD2    J1KSYO           かんばん小
     C                     Z-ADDA3BARA    J1BAB1           バレルＡ
     C                     Z-ADDA3BARB    J1BAB2           バレルＢ
     C                     MOVELA3RAIN    J1MKBN           メッキ機番
     C                     Z-ADDA3UKYY    J1BKIY           所番地切替日　年
     C                     Z-ADDA3UKMM    J1BKIM           所番地切替日　月
     C                     Z-ADDA3UKDD    J1BKID           所番地切替日　日
     C                     MOVE A3MTK1    J1NBN1           所番地新
     C                     MOVE A3MTK2    J1NBN2           所番地新
     C                     MOVE A3MTK3    J1NBN3           所番地新
     C                     MOVE A3MTK4    J1NBN4           所番地新
     C                     MOVE *BLANK    J1OBN1           所番地旧
     C                     MOVE *BLANK    J1OBN2           所番地旧
     C                     MOVE *BLANK    J1OBN3           所番地旧
     C                     MOVE *BLANK    J1OBN4           所番地旧
     C           J1MKBN    IFEQ *BLANK
     C                     MOVE '??'      J1MKBN
     C                     END
     C                     MOVELA3MEK1    J1MEK1           メッキ処理１
     C                     MOVELA3MEK2    J1MEK2           メッキ処理２
     C                     MOVELA3MEK3    J1MEK3           メッキ処理３
     C*メッキ膜厚*
     C                     SETOF                     16
     C           A3MK21    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C           *IN16     IFEQ '1'
     C                     MOVE A3MK21    MK1SUU
     C                     ELSE
     C                     MOVE '0'       MK1SUU
     C                     END
     C                     SETOF                     16
     C           A3MK22    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C           *IN16     IFEQ '1'
     C                     MOVE A3MK22    MK2SUU
     C                     ELSE
     C                     MOVE '0'       MK2SUU
     C                     END
     C                     Z-ADDMAKU      J1MSMA           電・メッキ膜厚
     C*
     C           A3MK14    IFEQ '.'
     C                     MOVE *BLANK    J1MSCK
     C                     ELSE
     C                     MOVE A3MK14    J1MSCK           電・着色区分
     C                     END
     C*
     C                     MOVE *BLANK    J1MSAK           電・あき
     C**********************************
     C*部品マスターのデータ入力(SUB) *
     C**********************************
     C                     MOVE A31HB5    BUHK1   5
     C                     MOVE A32HB5    BUHK2   5
     C                     MOVE A33HB2    BUHK3   2
     C                     SETOF                     99
     C                     Z-ADD0         ER      10
     C                     EXSR BUHIN
     C           *IN99     IFEQ '1'
     C                     MOVELMSG,ER    PMSG   42
     C           ER        IFEQ 1                          1=BUHIN NOT
     C           ER        OREQ 2                          2=BUHIN DEL
     C           ERRKEN    ADD  1         ERRKEN  70
     C                     ITER
     C                     ELSE
     C           ERRKEI    ADD  1         ERRKEI  70
     C                     END
     C                     END
     C****************************************
     C*メッキ売掛金マスターの単重入力(SUB) *
     C****************************************
     C                     MOVE A31HB5    TAHIN1  5
     C                     MOVE A32HB5    TAHIN2  5
     C                     MOVE A33HB2    TAHIN3  2
     C                     EXSR TANJYU
     C           J1TANJ    IFEQ 0
     C                     MOVE MSG,6     PMSG
     C                     END
     C**************************************
     C*工程マスターで焼入れ有無入力(SUB) *
     C**************************************
     C                     MOVE A31HB5    KOTK1   5
     C                     MOVE A32HB5    KOTK2   5
     C                     MOVE A33HB2    KOTK3   2
     C                     SETOF                     99
     C                     EXSR KOTEI
     C           *IN99     IFEQ '1'
     C                     MOVELMSG,ER    PMSG
     C                     END
     C*************************
     C*メッキ係数の計算(SUB)*
     C*************************
     C                     SETOF                     96
     C                     EXSR MEKKI
     C*
     C           *IN96     IFEQ '1'
     C                     Z-ADD0         J1MKRI           理論値
     C                     ELSE
     C                     Z-ADDK         J1MKRI           理論値
     C                     END
      *-----------------------------------------------------------*
      *  めっき係数理論値が変更された時使用区分を‘１’にする   *
      *                    UPDATE   :  SEP/25/1997.  S.OHTAKE     *
      *-----------------------------------------------------------*
      ****************************
      *メッキ係数使用区分の入力*
      * ０＝無　１＝理　２＝実 *
      ****************************
     C           J1MKRI    IFEQ 0
     C                     MOVE '0'       J1MKSK           使用区分
     C                     ELSE
     C           J1MKRI    IFNE ODMKRI
     C                     SETON                     55
     C                     MOVE '1'       J1MKSK
     C                     ENDIF
     C                     END
     C************************************
     C*その他の内容をＦＡマスターに入力*
     C************************************
     C                     Z-ADD0         J1KANS
     C                     Z-ADD0         J1HHAK
     C                     MOVE *BLANK    J1NOP
     C*
     C                     MOVE *BLANK    J1MSNS
     C                     MOVE *BLANK    J1MSZK
     C*更新日・者
     C                     MOVEL*BLANK    J1SKJY
     C                     Z-ADD*ZERO     J1SKYY
     C                     Z-ADD*ZERO     J1SKMM
     C                     Z-ADD*ZERO     J1SKDD
     C                     Z-ADD*YEAR     J1KOYY
     C                     Z-ADDUMONTH    J1KOMM
     C                     Z-ADDUDAY      J1KODD
     C                     Z-ADDUJI       J1KOHH
     C                     Z-ADDUFUN      J1KOSS
     C                     MOVEL'AJDR4T'  J1KOME
     C******************************
     C*   ＦＡマスターに書出し   *
     C******************************
      *------------------------*
      *引き取りかんばんを読む*
      *              S.OHTAKE. *
      *           1997.FEB.07. *
      *------------------------*
     C                     MOVE J1SHN1    HSHN1   5
     C                     MOVE J1SHN2    HSHN2   5
     C                     MOVE J1SHN3    HSHN3   2
     C           HKEY      KLIST
     C                     KFLD           HSHN1
     C                     KFLD           HSHN2
     C                     KFLD           HSHN3
      *
     C                     SETOF                     98
     C           HKEY      SETLLAAHTL011
     C                     DO   *HIVAL
     C           HKEY      READEAAHTL011                 98
     C           *IN98     IFEQ '1'
     C                     GOTO EXT
     C                     ENDIF
      *
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     GOTO EXT
     C                     ENDIF
      *
     C           L6UKHZ    IFGT *DATE
     C                     GOTO EXT
     C                     ENDIF
      *
     C           L6STHZ    IFLT *DATE
     C                     GOTO EXT
     C                     ENDIF
      *
%0002C                     MOVE 'C'       J1KDAI
%0002C                     MOVE 'A'       J1KSYO
     C                     SETON                     98
      *
     C           EXT       TAG
     C  N98                ENDDO
      *
     C           A3RAIN    IFEQ 'A'
     C                     MOVE '01'      J1MKBN
     C                     ENDIF
     C           A3RAIN    IFEQ 'D'
     C                     MOVE '51'      J1MKBN
     C                     ENDIF
      *
     C           A3UPKB    IFEQ '0'
     C                     WRITEAJSPL011
     C           OUTKEN    ADD  1         OUTKEN  70
     C                     EXCPTCHG
     C*
     C                     ELSE
     C                     Z-ADDA3MKJI    J1MKJI
     C                     MOVE A3SYKB    J1MKSK
     C                     MOVE '1'       J1MENT
     C                     UPDATAJSPL011
     C           UPKEN     ADD  1         UPKEN   70
     C* ＦＡＭの変更有りかのチェック(MKSUB) *
     C                     EXSR MKSUB
     C                     ENDIF
      *
     C                     ENDDO
     C*
     C           $SAAFE    ENDSR
     C**************************************************
      *指示かんばんマスターの読込み  *
     C**************************************************
     C           $SBCAD    BEGSR
      **
     C           1         SETLLAJSWP41
     C                     SETOF                     30
     C                     DO   *HIVAL
     C                     READ AJSWP41                  30
     C         30          LEAVE
      **削除
     C           C2SKJY    IFEQ 'D'
     C           C2SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      **
     C*件数のカウント*
     C           ALLKEN    ADD  1         ALLKEN  70
      *
     C*ＦＡマスターＵＰＤＡＴの為のみのＣＨＡＩＮ(SUB) *
     C                     SETOF                     95
     C           C2UPKB    IFEQ '1'
     C                     MOVE '*'       UP      1
     C                     MOVE C2SHN1    WWHIN1  5        社内品番１
     C                     MOVE C2SHN2    WWHIN2  5        社内品番２
     C                     MOVE C2SHN3    WWHIN3  2        社内品番３
     C                     MOVE C2SHN1    J1SHN1
     C                     MOVE C2SHN2    J1SHN2
     C                     MOVE C2SHN3    J1SHN3
     C* FA MASTER CHAIN SUB
     C                     EXSR CHSUB
     C*
     C           *IN95     IFEQ '1'
     C                     MOVELMSG,7     PMSG
     C                     ITER
     C                     ENDIF
     C*
     C                     ELSE
     C                     MOVE ' '       UP
     C                     ENDIF
     C*
     C*ＦＡＭフィールドクリアーと旧変数格納(SUB) *
     C                     EXSR CLRSUB
      **
     C*指示かんばんマスターの内容をＦＡマスターに入力*
     C                     MOVELC2SHN1    J1SHN1           社内品番１
     C                     MOVELC2SHN2    J1SHN2           社内品番２
     C                     MOVELC2SHN3    J1SHN3           社内品番３
     C                     Z-ADDC2BMON    J121CD           二次１加工先
     C                     MOVELC2SJK1    J121M1           二次１ＢＺ１１
     C                     MOVELC2SJK2    J121M2           二次１ＢＺ１２
     C                     MOVELC2NJK1    J1NS11           荷姿条件１１
     C                     MOVELC2NJK2    J1NS21           荷姿条件２１
