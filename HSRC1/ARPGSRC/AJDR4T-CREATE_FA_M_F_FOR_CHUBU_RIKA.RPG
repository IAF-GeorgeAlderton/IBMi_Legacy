     C**********************************
     C*部品マスターのデータ入力(SUB) *
     C**********************************
     C                     MOVE C2SHN1    BUHK1   5
     C                     MOVE C2SHN2    BUHK2   5
     C                     MOVE C2SHN3    BUHK3   2
     C                     SETOF                     99
     C                     Z-ADD0         ER      10
     C                     EXSR BUHIN
SAKA C                     Z-ADDC2SYOS    J1NSYU
SAKA C                     MOVE C2SYOT    J1NHKS
     C           *IN99     IFEQ '1'
     C                     MOVELMSG,ER    PMSG   42
     C           ER        IFEQ 1                          1=BUHIN NOT
     C           ER        OREQ 2                          2=BUHIN DEL
     C           ERRKEN    ADD  1         ERRKEN  70
     C                     ITER
     C                     ELSE
     C           ERRKEI    ADD  1         ERRKEI  70
     C                     END
     C                     END
     C****************************************
     C*メッキ売掛金マスターの単重入力(SUB) *
     C****************************************
