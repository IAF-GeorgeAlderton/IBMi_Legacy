     H            Y/                                    1
     H** FBCR48 *******************************************************
     H*  FORD PLANT INQ BY CODE                                       *
     H*  JW   2021.11.23                                              *
     H*****************************************************************
     FFBCPW48 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFL01
     FAB#PPYY IF  E           K        DISK
      *================================================================
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE *BLANK    SVPLNT  5
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           *LOVAL    SETLLAB#PPYY
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AB#PPYY                  90
     C   90                LEAVE
     C*
     C           FFSKJY    IFEQ 'D'                        DELETE CODE
     C                     ITER
     C                     ENDIF
     C* FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELFFCUST    SVPLNT
     C                     ENDIF
     C* OUT BLANK LINE
     C           FFCUST    IFNE SVPLNT
     C                     MOVE *BLANK    S1PLNT
     C                     MOVE *BLANK    S1CONT
     C                     MOVE *BLANK    S1KOHZ
     C                     MOVE *BLANK    S1KOTM
     C                     MOVE *BLANK    S1KOME
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     MOVELFFCUST    SVPLNT
     C                     ENDIF
     C*
     C                     MOVELFFCUST    S1PLNT
     C                     MOVELFFCONT    S1CONT
      *
     C           FFKODT    IFNE 0
     C                     MOVELFFKODT    $DATE1
     C                     MOVELFFKOTM    $TIME1
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    S1KOHZ
     C           FFKOTM    IFEQ 0
     C                     MOVE *BLANK    S1KOTM
     C                     ELSE
     C                     MOVEL$TIME2    S1KOTM
     C                     ENDIF
      *
     C                     ELSE
     C                     MOVE *BLANK    S1KOHZ
     C                     MOVE *BLANK    S1KOTM
     C                     ENDIF
      *
     C                     MOVELFFKOME    S1KOME
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      * DISPLAY 1ST SCREEN
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTCTL01
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < F3 > END
     C           *INKC     WHEQ *ON
     C           *INKA     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '#END    '@STEP
     C* < PAGE UP/DOWN >
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* <    >
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFL01                95
     C           *IN95     IFEQ *OFF
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C                     ENDSR
      *===============================================================
