      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           US     10
     C                     PARM           PSIRE   4
     C                     PARM           PODR1   2
     C                     PARM           PODR2   2
     C                     PARM           PODR3   2
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *-----*
      * KEY *
      *-----*
     C           KEY1      KLIST
     C                     KFLD           LAZAIS
     C                     KFLD           LAZAIK
     C                     KFLD           LASIRE
      *
     C           KEY2      KLIST
     C                     KFLD           LAZAIS
     C                     KFLD           LAZAIK
