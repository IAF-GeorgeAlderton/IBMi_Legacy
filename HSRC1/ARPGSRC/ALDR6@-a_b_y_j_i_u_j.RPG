     FALDPW6Z CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FALDWP6ZHIF  F     132            DISK
     FALDWP6ZDIF  F     132            DISK
     FALDWP6ZTIF  F     132            DISK
     IALDWP6ZHAA  01
     I                                        1 132 I@HEAD
     IALDWP6ZDAA  01
     I                                        1 132 I@DATA
     IALDWP6ZTAA  01
     I                                        1 132 I@TOL
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         @CNT    40
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C* * *      *LOVAL    SETLLGADPL11
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ ALDWP6ZH                 90
     C   90                LEAVE
     C*
     C                     ADD  1         @CNT
     C*
     C           @CNT      IFEQ 1
     C                     MOVELI@HEAD    S1HED1
     C                     END
     C           @CNT      IFEQ 2
     C                     MOVELI@HEAD    S1HED2
     C                     END
     C           @CNT      IFEQ 3
     C                     MOVELI@HEAD    S1HED3
     C                     END
     C           @CNT      IFEQ 4
     C* * *                MOVELI@HEAD    S1HED4
     C                     END
      *
     C* * *                WRITESFREC1
      *
     C           @CNT      IFGE 4
     C                     LEAVE
     C                     END
      *
E1   C                     ENDDO
     C*-------------------------
     C                     READ ALDWP6ZT                 90
     C                     MOVELI@TOL     S1TOL
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ ALDWP6ZD                 90
     C   90                LEAVE
     C*
     C                     MOVELI@DATA    S1DATA
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C           RRN       IFEQ 0
