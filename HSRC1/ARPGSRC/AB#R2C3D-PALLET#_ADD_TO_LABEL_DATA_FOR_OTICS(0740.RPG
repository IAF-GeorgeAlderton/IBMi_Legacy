     H            Y.
     F** AB#R2C3D ***********************************************************
     F*  PALLET# ADD TO LABEL DATA FOR OTICS(0740, 0741)                    *
     F*  JW      2023.01.12                                                 *
     F***********************************************************************
     FAB#WL2I UF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
     E*****************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************************
      * MAIN ROUTINE
      ***********************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#WL2I                  98
     C   98                LEAVE
      *
     C           I2DELY    IFNE '0740'
     C           I2DELY    ANDNE'0741'
     C                     ITER
     C                     ENDIF
      *
      * GET MAX BOX
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C           I2DELY    CHAINAB#PL90              97
     C   97                LEAVE
      *
     C           YAMXPL    IFEQ 0
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDYAMXPL    @MAX
     C                     ENDIF
      *
     C                     EXSR #UPD
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      ***********************************************************
      * UPDATE
      ***********************************************************
     C           #UPD      BEGSR
      *
     C                     ADD  1         TSEQ#
     C           TSEQ#     DIV  @MAX      @SHO    40
     C                     MVR            @RMT    40
     C           @RMT      IFNE 0
     C                     ADD  1         @SHO
     C                     ENDIF
     C                     MOVEL@SHO      I2DUMY
      *
     C                     UPDATAB#WP2I1
      *
     C                     ENDSR
      ***********************************************************
      * INITIAL SETTINGS
      ***********************************************************
     C           #INIT     BEGSR
      *
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         @MAX    40
     C                     Z-ADD0         TSEQ#   40
      *
     C                     ENDSR
