      **** GDGR50 ****************************************************
      *    MONTHLY TOTALIZATION HANDLING
      *      G.B.C                         97/03/06
      ****************************************************************
     H            Y/                                    1
     FGDGPL15 UF  E           K        DISK
     FGDGPP20 UF  E                    DISK                      A
     F*
     I****************************************************************
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
     I            DS
     I                                        1   5 ICHIN1
     I                                        6  10 ICHIN2
     I                                       11  12 ICHIN3
     I                                        1  12 ICHIN
     I            DS
     I                                        1   5 IDHIN1
     I                                        6  10 IDHIN2
     I                                       11  12 IDHIN3
     I                                        1  12 IDHIN
     I            DS
     I                                        1   80ICKOHZ
     I                                        1   40ICKOYY
     I                                        5   60ICKOMM
     I                                        7   80ICKODD
     I            DS
     I                                        1   40ICKOTM
     I                                        1   20ICKOHH
     I                                        3   40ICKOSS
     I* DELETE DUE DATE
     I            DS
     I                                        1   80IDSKHZ
     I                                        1   40IDSKYY
     I                                        5   60IDSKMM
     I                                        7   80IDSKDD
     I            DS
     I                                        1   80IDKOHZ
     I                                        1   40IDKOYY
     I                                        5   60IDKOMM
     I                                        7   80IDKODD
     I            DS
     I                                        1   40IDKOTM
     I                                        1   20IDKOHH
     I                                        3   40IDKOSS
     I*発注実績
     I            DS
     I                                        1   40IDJSYY
     I                                        5   60IDJSMM
     I                                        1   6 IDJSHZ
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C                     PARM           PPDATE  6
     C                     MOVE *BLANK    MMHIN  12
     C                     MOVE *BLANK    MMSEIH  1        製品区分
     C                     Z-ADD0         WKSURY  90       数量
     C*
     C* <更新処理>
     C*--------------------
B1   C                     DO   *HIVAL
     C                     READ GDGPL15                  90
     C   90                LEAVE
     C*
     C           ICMJHZ    IFNE 0                                      )
     C                     ITER
     C                     ENDIF
     C*
     C           ICIFMK    IFNE 'C'
     C           ICHIN     IFEQ MMHIN
     C                     ADD  ICSURY    WKSURY           数量
     C                     ELSE
     C           MMHIN     IFNE *BLANK
     C                     EXSR #WRITE
     C                     ENDIF
     C                     MOVE ICSEIH    MMSEIH           製品区分
     C                     MOVE ICHIN     MMHIN
     C                     Z-ADDICSURY    WKSURY           数量
     C                     ENDIF
     C                     ENDIF
     C*
     C                     TIME           @@TIME
     C                     Z-ADD*DATE     ICKOHZ
     C                     Z-ADD@TIME     ICKOTM
     C                     MOVELPPUSER    ICKOME
     C                     Z-ADD*DATE     ICMJHZ                       )
     C                     UPDATGDGPL151
E1   C                     ENDDO
     C*--------------------
     C           WKSURY    IFNE 0
     C                     EXSR #WRITE
     C                     ENDIF
     C* <終　了>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C* DUMMY READ
     C                     READ GDGPP20                  90
     C****************************************************************
     C*月次発注データ
     C****************************************************************
     C           #WRITE    BEGSR
     C                     TIME           @@TIME
     C                     MOVE *BLANK    IDSKJY
     C                     Z-ADD0         IDSKHZ
     C                     Z-ADD*DATE     IDKOHZ
     C                     Z-ADD@TIME     IDKOTM
     C                     MOVELPPUSER    IDKOME
     C                     MOVE PPDATE    IDJSHZ
     C                     MOVE MMSEIH    IDSEIH           製品区分
     C                     MOVE MMHIN     IDHIN            品番
     C                     Z-ADDWKSURY    IDSURY           発注数量
     C                     Z-ADD0         IDYJYY
     C                     Z-ADD0         IDYJMM
     C                     Z-ADD0         IDYJDD
     C                     WRITEGDGPP201
     C                     ENDSR
     C****************************************************************
