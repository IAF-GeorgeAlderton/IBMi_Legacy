     C****************************
     C*     PARAMATER CECTION    *
     C****************************
     C           *ENTRY    PLIST
     C                     PARM           BNCH1   1
     C                     PARM           BNCH2   2
     C                     PARM           BNCH3   2
     C                     PARM           BNCH4   1
     C                     PARM           YUKOY   4
     C                     PARM           YUKOM   2
     C                     PARM           YUKOD   2
     C                     PARM           YUKOB   2
     C                     MOVE BNCH1     BANCH1
     C                     MOVE BNCH2     BANCH2
     C                     MOVE BNCH3     BANCH3
     C                     MOVE BNCH4     BANCH4
     C                     MOVE YUKOY     YUKOYY
     C                     MOVE YUKOM     YUKOMM
     C                     MOVE YUKOD     YUKODD
     C                     MOVE YUKOB     YUKOBN
     C****************************
     C*  MOVE CHARACTER FOR DS   *
     C****************************
     C                     MOVE '-'       B01
     C                     MOVE '-'       B02
     C                     MOVE '-'       B03
     C                     MOVE '.'       T01
     C                     MOVE '.'       T02
     C****************************
     C*    JUMP TO GAMEN2 ?      *
     C****************************
     C           BANCH     IFNE *BLANK
     C                     SETON                     08
     C                     GOTO STEP1
     C                     END
     C****************************
     C*    GAMEN NO1 NO SYORI    *
     C****************************
     C           STP11     TAG
     C                     MOVE *BLANK    BANCH
     C                     Z-ADD0         YUKOHZ
     C           STP10     TAG
     C                     EXFMTAAJPW161
     C                     SETOF                     990102
     C           *INKA     CABEQ'1'       PGMEND
     C*
     C           BANCH     IFEQ *BLANK
     C                     SETON                     9901
     C                     MOVELMSG,1     ERRMSG
     C                     GOTO STP10
     C                     END
     C*
     C           YUKOHZ    IFNE 0
     C           YUKOMM    IFGT 12
     C           YUKOMM    ORLT 1
     C                     SETON                     9902
     C                     MOVE MSG,2     ERRMSG
     C                     GOTO STP10
     C                     END
     C           YUKODD    IFGT 31
     C           YUKODD    ORLT 1
     C                     SETON                     9902
     C                     MOVE MSG,2     ERRMSG
     C                     GOTO STP10
     C                     END
     C                     END
     C*
     C           YUKOHZ    IFEQ 0
     C                     Z-ADD*DATE     YUKDAY
     C                     Z-ADD01        YUKOBN
     C                     END
     C****************************
     C*        CLEAR FIELD       *
     C****************************
     C           STEP1     TAG
     C                     SETOF                     101112
     C                     MOVE *BLANK    HIN
     C                     MOVE *BLANK    KGN
     C                     MOVE *BLANK    KNN
     C                     Z-ADD0         SYO
     C                     Z-ADD0         LOT
     C                     Z-ADD0         BMN
     C********* POINTER SET ********
     C           KEY2      KLIST
     C                     KFLD           BANCH1
     C                     KFLD           BANCH2
     C                     KFLD           BANCH3
     C                     KFLD           BANCH4
     C                     KFLD           BLNK1
     C                     KFLD           BLNK2
     C                     KFLD           BLNK3
     C                     KFLD           ZERO1
     C                     KFLD           ZERO2
     C                     KFLD           ZERO3
     C                     KFLD           ZERO4
     C                     MOVE *BLANK    BLNK1   5
     C                     MOVE *BLANK    BLNK2   5
     C                     MOVE *BLANK    BLNK3   2
     C                     Z-ADD0         ZERO1   40
     C                     Z-ADD0         ZERO2   20
     C                     Z-ADD0         ZERO3   20
     C                     Z-ADD0         ZERO4   20
     C           KEY2      SETLLAAJTL141
     C***
     C           STEP6     TAG
     C                     Z-ADD0         I
     C***
     C           STEP5     TAG
     C                     READ AAJTL14                  10
     C           *IN10     CABEQ'1'       STEP2
     C*****  NOT SAME BANCHI  *****
     C                     SETOF                     06
     C           BANCH     IFNE MBANCH
     C                     SETON                     06    CHANGE BANCH
     C           I         SUB  1         I
     C                     READPAAJTL14                  05NOT USE
     C           I         IFEQ 0
     C                     SETON                     99
     C                     MOVELMSG,5     ERRMSG
     C                     END
     C                     GOTO STEP3
     C                     END
     C******   SAME HINBAN   ******
     C           CJAKHZ    IFNE 0
     C           CJAKHZ    CABLE*DATE     STEP5
     C                     END
     C           CJCHHZ    CABLT*DATE     STEP5
     C           I         ADD  1         I       20
     C***
     C           KEY1      KLIST
     C                     KFLD           CJKDAI
     C                     KFLD           CJKSYO
     C           KEY1      CHAINGCMPL311             11
     C           *IN11     IFEQ '0'
     C                     MOVELT3NAMN    KANJI2
     C           T3SKJY    IFEQ 'D'
     C                     MOVEL'NO CLR'  KNN,I
     C                     ELSE
     C                     MOVELKANNA     KNN,I
     C                     END
     C                     ELSE
     C                     MOVEL'NO CLR'  KNN,I
     C                     END
     C                     MOVELHINBAN    HIN,I
     C                     MOVELKIGEN     KGN,I
     C                     Z-ADDCJBMON    BMN,I
     C                     Z-ADDCJSYUY    SYO,I
     C                     Z-ADDCJSLOT    LOT,I
     C           I         CABGE17        STEP3
     C                     GOTO STEP5
     C********* (*IN10='1') ********
     C           STEP2     TAG
     C           *HIVAL    SETLLAAJTL141
     C                     SETON                     99
     C                     MOVELMSG,3     ERRMSG
     C********* OUT GAMEN ********
     C           STEP3     TAG
     C                     EXFMTAAJPW162
     C                     SETOF                     99
     C********* (CMD3='1') RETURN GAMEN1 **********
     C           *INKC     IFEQ '1'
     C           *IN08     IFEQ '1'
     C                     GOTO PGMEND
     C                     ELSE
     C                     GOTO STP11
     C                     END
     C                     END
     C********* (*IN03='1') R-UP **********
     C           *IN03     IFEQ '1'
     C           *IN06     CABEQ'1'       STEP3
     C           *IN10     CABEQ'1'       STEP2
     C                     GOTO STEP6
     C                     END
     C********* (*IN04='1') R-DWN **********
     C           *IN04     IFEQ '1'
     C           *IN06     CABEQ'1'       STEP3
     C           I         ADD  17        J       20
     C           STEP4     TAG
     C                     READPAAJTL14                  12
     C           *IN12     IFEQ '1'
     C           *LOVAL    SETGTAAJTL141
     C                     SETON                     99
     C                     MOVELMSG,4     ERRMSG
     C                     GOTO STEP3
     C                     END
     C           CJAKHZ    IFNE 0
     C           CJAKHZ    CABLE*DATE     STEP4
     C                     END
     C           CJCHHZ    CABLT*DATE     STEP4
     C           J         SUB  1         J
     C           J         CABGE1         STEP4
     C                     GOTO STEP6
     C                     END
     C********* ENTER **********
     C                     GOTO STEP3
     C**************************
     C*   PROGRAM       END    *
     C**************************
     C           PGMEND    TAG
     C                     SETON                     LR
     C                     RETRN
**  MSG (MESAAGE)
E-01 SETTING PART NO RETRIEVAL LOCATION CODE ISN'T INPUT
E-02 EFFECTIVE KANBAN DAY IS NOT RIGHT
M-03 THIS SCREEN IS THE LAST DATA OF A FILE
M-04 THIS SCREEN IS THE FIRST DATA OF A FILE
E-05 THIS SETTING P/N RETRIEVAL LOC.CD ISN'T APPLICABLE P/N
