     H            Y.
     F** ABNR13 *********************************************
     F*  LOCATION INFO                                      *
     F*  JW       2019.05.15                                *
     F*******************************************************
     FABNPP11 IF  E           K        DISK
     FABNPP11AO   E                    DISK                      A
      *
     E                    FLD     1  10 20
      *
     I            DS
     I                                        1   9 S7LOC
     I                                        1   1 S7TKR1
     I                                        2   2 HP1
     I                                        3   4 S7TKR2
     I                                        5   5 HP2
     I                                        6   7 S7TKR3
     I                                        8   8 HP3
     I                                        9   9 S7TKR4
      *
     I            DS
     I                                        1   9 $LOC
     I                                        1   1 $LOC1
     I                                        2   2 $P1
     I                                        3   4 $LOC2
     I                                        5   5 $P2
     I                                        6   7 $LOC3
     I                                        8   8 $P3
     I                                        9   9 $LOC4
      *
     I            DS
     I                                        1  14 S7SHIN
     I                                        1   5 S7SHN1
     I                                        6   6 HP4
     I                                        7  11 S7SHN2
     I                                       12  12 HP5
     I                                       13  14 S7SHN3
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C           *IN95     DOWEQ*OFF
     C                     READ ABNPP11                  95
     C   95                LEAVE
      *
     C                     EXSR #OUT
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *OUTPUT                   *
      *---------------------------*
     C           #OUT      BEGSR
      *
     C                     CLEARABNPP1A1
     C                     MOVELS7KCD1    SAKCD1    P
     C                     MOVELS7KCD2    SAKCD2    P
     C                     MOVELS7BMON    SABMON    P
     C                     MOVELS7LOC     SATKR     P
      * EDIT PART
     C           S7SHN2    IFEQ *BLANK
     C                     MOVE *BLANK    HP4
     C                     ELSE
     C                     MOVE '-'       HP4
     C                     ENDIF
     C           S7SHN3    IFEQ *BLANK
     C                     MOVE *BLANK    HP5
     C                     ELSE
     C                     MOVE '-'       HP5
     C                     ENDIF
     C                     MOVELS7SHIN    SASHIN    P
      *
     C                     MOVELS7KMAX    SAKMAX    P
     C                     MOVELS7SDAI    SASDAI    P
     C                     MOVELS7SSYO    SASSYO    P
     C                     MOVELS7HAKO    SAHAKO    P
     C                     MOVELS7BRYO    SABRYO    P
     C                     MOVELS7SHAK    SASHAK    P
     C                     MOVELS7NSIZ    SANSIZ    P
      * GET SERVICE PART LOCATION
     C                     MOVELS7SHN1    $SHN1
     C                     MOVELS7SHN2    $SHN2
     C                     MOVELS7SHN3    $SHN3
     C                     CALL 'UTLR26'
     C                     PARM           $SHN1   5
     C                     PARM           $SHN2   5
     C                     PARM           $SHN3   2
     C                     PARM           $LOC1   1
     C                     PARM           $LOC2   2
     C                     PARM           $LOC3   2
     C                     PARM           $LOC4   1
     C                     PARM           $RTN    1
     C                     MOVEL$LOC      SASLOC
      *
     C                     WRITEABNPP1A1
      *
     C                     ENDSR
      *---------------------------*
      * INITIAL SETTING
      *---------------------------*
     C           #INIT     BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '-'       HP1
     C                     MOVE '-'       HP2
     C                     MOVE '-'       HP3
     C                     MOVE '-'       HP4
     C                     MOVE '-'       HP5
     C                     MOVE '-'       $P1
     C                     MOVE '-'       $P2
     C                     MOVE '-'       $P3
      * HEADER
     C                     MOVELFLD,1     SAKCD1
     C                     MOVELFLD,2     SAKCD2
     C                     MOVEL'DEPT.   'SABMON    P
     C                     MOVEL'LOCATION'SATKR     P
     C                     MOVEL'PART_NO 'SASHIN    P
     C                     MOVEL'MAX     'SAKMAX    P
     C                     MOVELFLD,3     SASDAI
     C                     MOVELFLD,4     SASSYO
     C                     MOVEL'BOX TYPE'SAHAKO    P
     C                     MOVELFLD,5     SABRYO
     C                     MOVELFLD,6     SASHAK
     C                     MOVELFLD,7     SANSIZ
     C                     MOVELFLD,8     SASLOC
     C                     MOVEL'PGM: ABN'SAPGM
     C                     MOVE 'C11     'SAPGM
     C                     WRITEABNPP1A1
      *
     C                     ENDSR
** FLD ..+.........> (20)
K_KIND (L)            01
K_KIND (S)            02
DEPOT_KIND SIZE       03
DEPOT_KIND TYPE       04
LOC_CODE USE#         05
HARVEST_#_OF_BOX      06
NEED_SIZE             07
SERVICE LOCATION      08
                      09
                      10
