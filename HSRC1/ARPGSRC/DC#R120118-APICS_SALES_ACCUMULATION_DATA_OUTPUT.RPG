     H            Y.
      *********************************************************
      *   APICS SALES ACCUMULATION DATA OUTPUT                *
      *   1997.02.18                                          *
      *********************************************************
     F* ORDER RECEIPT ACCUMULATIO DATA WORK FILE
     FDC#WP10 IF  E           K        DISK
     C* LEVELLED PRODUCTION FIXED ORDERING FILE
     FAGAPL31 IF  E           K        DISK
     F* ORDER RECEIPT ACCUMULATION DATA
     FDA#PL12 UF  E           K        DISK
     F* SHIPMENT M/F
     FGADPL11 IF  E           K        DISK
     F* APICS SALES ACCUMULATION DATA
     FAU#PP11 O   E                    DISK                      A
     I*================================================================
     I            DS
     I                                        1  140WTIME
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@US   10        USER PROFILE
     C                     PARM           P@YMD   8        IS THIS DELIVER
     C*================================================================
     C* AGAPL31
     C           KEY1      KLIST
     C                     KFLD           B8TOKU
     C                     KFLD           B8NONY
     C                     KFLD           B8NKOJ
     C                     KFLD           B8NUKE
     C           KEYCB     KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C           KEYB8     KLIST
     C                     KFLD           B8SAMM
     C                     KFLD           B8RENO
     C*================================================================
     C                     TIME           WTIME
     C*--------------------
     C                     DO   *HIVAL
     C                     READ DC#WP101                 90
     C   90                LEAVE
      *
     C           B8STBN    IFNE 'G'
     C                     GOTO ESC
     C                     ENDIF
     C* AGAPL31
     C                     MOVE B8SHN1    CBSHN1
     C                     MOVE B8SHN2    CBSHN2
     C                     MOVE B8SHN3    CBSHN3
     C           KEYCB     CHAINAGAPL311             80
     C           *IN80     IFEQ *OFF
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     80
     C                     END
      *
     C           *IN80     IFEQ *OFF
     C                     EXSR CYCLE
     C                     EXSR AU#PP
     C                     EXSR DA#PP
     C                     ENDIF
     C**
     C           ESC       TAG
     C                     ENDDO
     C*--------------------
     C                     SETON                     LR
     C                     RETRN
      *
     C*================================================================
     C* APICS SALES ACCUMULATION DATA OUTPUT                          *
     C*================================================================
     C           AU#PP     BEGSR
     C                     MOVE *BLANK    CQSKJY           DELETE CD
     C                     Z-ADD0         CQSKYY           DELETE DATE YY
     C                     Z-ADD0         CQSKMM                       MM
     C                     Z-ADD0         CQSKDD                       DD
     C                     Z-ADDB8KOYY    CQKOYY           UPDATE DATE YY
     C                     Z-ADDB8KOMM    CQKOMM                       MM
     C                     Z-ADDB8KODD    CQKODD                       DD
     C                     Z-ADDB8KOJI    CQKOHH           UPDATE TIME JI
     C                     Z-ADDB8KOFN    CQKOSS                       FN
     C                     MOVE B8KONA    CQKOME           UPDATE WORKER
     C*
     C                     Z-ADDB8TOKU    CQTOKU           CUSTOMER CD
     C                     MOVE B8TKOJ    CQTKOJ                    F
     C                     MOVE B8TUKE    CQTUKE                    RCV
     C                     Z-ADDB8NONY    CQNONY           DELIVERY POINT
     C                     MOVE B8NKOJ    CQNKOJ                    F
     C                     MOVE B8NUKE    CQNUKE                    RCV
     C                     MOVE B8SHN1    CQSHN1           PARTS NO     1
     C                     MOVE B8SHN2    CQSHN2                        2
     C                     MOVE B8SHN3    CQSHN3                        3
     C                     MOVE B8MHN1    CQMHN1           USER PARTS NO1
     C                     MOVE B8MHN2    CQMHN2                        2
     C                     MOVE B8MHN3    CQMHN3                        3
     C                     MOVE B8KANR    CQKANR           MANAGEMENT NO
     C                     Z-ADDB8TANK    CQTANK           UNIT PRICE
     C                     MOVE B8TKBN    CQTKUB                     INST
     C                     MOVE B8TTAI    CQTKTI                     FORM
     C                     MOVE B8NBAN    CQNOCR           DELIVERY NO
     C                     Z-ADDB8SRYO    CQSRYO           DELIVERY QTY
     C                     MOVE B8TANI    CQTANI                    UNIT
     C                     MOVE B8NSYO    CQNSYK           DELIVERY INST
     C                     MOVE *BLANK    CQKOBI           PURCHASING TEAM
     C                     MOVE *BLANK    CQSEBN           INDENT NO
     C                     Z-ADDB8TEYY    CQTHYY           SHIP ORDER DATE YY
     C                     Z-ADDB8TEMM    CQTHMM                           MM
     C                     Z-ADDB8TEDD    CQTHDD                           DD
     C                     MOVE B8TKR1    CQSBKJ           LOCATION CD 1
     C                     MOVE B8TKR2    CQSBRO                       2
     C                     MOVE B8TKR3    CQSBRT                       3
     C                     MOVE B8TKR4    CQSBDN                       4
     C                     Z-ADDB8MEYY    CQNOYY           DELIVERY DATE YY
     C                     Z-ADDB8MEMM    CQNOMM                         MM
     C                     Z-ADDB8MEDD    CQNODD                         DD
     C                     Z-ADD0         CQNOBB           DELIVERY DATE BIN
     C                     MOVE *BLANK    CQKJYN           SHIPMENT STANDARD
     C                     MOVE B8STBN    CQTHAI           INTRAL COMPANY INST
     C                     MOVE *BLANK    CQSKKB           INDICATION KANBAN
      *
     C                     Z-ADD0         HAKO    30       BOX
     C                     Z-ADD0         HASU    30       FRACTION
     C           B8SYUY    IFEQ 0
     C                     Z-ADD0         CQHAKO
     C                     ELSE
     C           B8SRYO    DIV  B8SYUY    HAKO
     C                     MVR            HASU
     C           HASU      IFNE 0
     C           HAKO      ADD  1         HAKO
     C                     ENDIF
     C                     Z-ADDHAKO      CQHAKO
     C                     ENDIF
      *
     C                     Z-ADDB8SYUY    CQSYUY           ACCOMMODATED QTY
     C                     MOVE *BLANK    CQSTAN           BARCODE IN CHARGE
     C                     MOVE *BLANK    CQKIBN           BARCODE MACHINE NO
     C                     MOVE *BLANK    CQHBSB           PART NO CLASS
     C                     MOVE *BLANK    CQROTN           LOT NO
     C                     Z-ADD0         CQPAGN           PAGE NO
     C                     Z-ADD0         CQOCRD           OCR SLIP LINE
     C                     MOVE *BLANK    CQDTSY           DATA CLASSIFICATION
     C                     MOVE *BLANK    CQDTSO           DATA CLASSIFY CLASS
     C                     MOVE *BLANK    CQGYOM           BUSINESS CODE
     C                     Z-ADD0         CQURYY           SALES ADDING UP YY
     C                     Z-ADD0         CQURMM                           MM
     C                     Z-ADD0         CQURDD                           DD
     C                     Z-ADD0         CQJTNO           SALES RECEIPT NO
     C                     MOVE *BLANK    CQBNKA           DATA DIVISION INST
     C                     WRITEAU#PP111
     C                     ENDSR
     C*================================================================
     C* ORDER RECEIPT ACUMULATION DATA
     C*================================================================
     C           DA#PP     BEGSR
     C           KEYB8     CHAINDA#PL121             91
     C           *IN91     IFEQ *OFF
     C                     Z-ADDWYY       B8SAYY           CREATE YY
     C                     Z-ADDWMM       B8SAMM                  MM
     C                     Z-ADDWDD       B8SADD                  DD
     C                     UPDATDA#PL121
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C* USER SHIPMENT CYCLE
     C*================================================================
     C           CYCLE     BEGSR
     C                     SETOF                     50
     C           KEY1      CHAINGADPL111             50
     C           *IN50     IFEQ '1'
     C                     Z-ADD1         CQCIC1
     C                     Z-ADD1         CQCIC2
     C                     Z-ADD1         CQCIC3
     C                     Z-ADDWJI       CQTHJI
     C                     Z-ADDWFN       CQTHPN
     C                     Z-ADDWJI       CQURJI
     C                     Z-ADDWFN       CQURPN
     C                     ELSE
     C           B5SKJY    IFEQ 'D'
     C                     Z-ADD1         CQCIC1
     C                     Z-ADD1         CQCIC2
     C                     Z-ADD1         CQCIC3
     C                     Z-ADDWJI       CQTHJI
     C                     Z-ADDWFN       CQTHPN
     C                     Z-ADDWJI       CQURJI
     C                     Z-ADDWFN       CQURPN
     C                     ELSE
     C                     Z-ADDB5HIZK    CQCIC1
     C                     Z-ADDB5KAIS    CQCIC2
     C                     Z-ADDB5NBIN    CQCIC3
     C                     Z-ADDB51SJI    CQTHJI
     C                     Z-ADDB51SFN    CQTHPN
     C                     Z-ADDB51UJI    CQURJI
     C                     Z-ADDB51UFN    CQURPN
     C                     END
     C                     END
      *
     C           CQTHJI    IFEQ 0
     C                     Z-ADDWJI       CQTHJI
     C                     END
     C           CQTHPN    IFEQ 0
     C                     Z-ADDWFN       CQTHPN
     C                     END
     C           CQURJI    IFEQ 0
     C                     Z-ADDWJI       CQURJI
     C                     END
     C           CQURPN    IFEQ 0
     C                     Z-ADDWFN       CQURPN
     C                     END
      *
     C                     ENDSR
     C*================================================================
