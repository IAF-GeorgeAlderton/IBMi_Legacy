     C           *INKE     WHEQ *ON
     C           X         IFLT MHLOTS
     C                     MOVELERR,15    F88ER1
     C                     MOVELERR,16    F88ER2
TCHK4C                     MOVEL*BLANK    F88ER3
TCHK4C                     Z-ADD*ZERO     F8IDCD
TCHK4C           #LP888    TAG
      *
      * display TL password entry screen...
     C                     EXFMTFMT888
      *
     C           *INKF     IFEQ *ON
      * verify TL password entered is in password file and not deleted...
     C           F8IDCD    CHAINAM#PP31              31
     C           *IN31     IFEQ *OFF
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     SETON                     31
     C                     ENDIF
      *
      * R3PGM2 = conveyance...so if it's not CV, then it's not valid.
     C           *IN31     IFEQ *OFF
     C           R3PGM2    ANDNE'1'
     C                     SETON                     31
     C                     ENDIF
      *
     C           *IN31     IFEQ *OFF
      *
TCHK4 ********** F8IDCD    IFEQ 862239                     ANTHONY
TCHK4 ********** F8IDCD    OREQ 965306                     KEVIN
TCHK4 ********** F8IDCD    OREQ 967391                     TONY
TCHK4 ********** F8IDCD    OREQ 881778                     HOLLY
TCHK4 ********** F8IDCD    OREQ 884875                     KEI SATO
      ********** F8IDCD    OREQ 905383                     BRYAN MULLINS
      *
     C                     EXSR #WRTOK
     C                     EXSR #LASTP
     C                     EXSR #CLRS
     C                     MOVELF1SHIN    F1PPRT
