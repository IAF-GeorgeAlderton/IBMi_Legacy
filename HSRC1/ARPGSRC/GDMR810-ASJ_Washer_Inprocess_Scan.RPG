TCHK4C                     ELSE
TCHK4C                     MOVELERR,17    F88ER3
TCHK4C                     GOTO #LP888
TCHK4C                     END
     C                     END
     C                     ELSE
     C                     EXSR #WRTOK
     C                     EXSR #LASTP
     C                     EXSR #CLRS
     C                     MOVELF1SHIN    F1PPRT
     C                     MOVEL'10'      @@ID
     C                     END
     C           *INKG     WHEQ *ON
