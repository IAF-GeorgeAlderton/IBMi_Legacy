     C                     MOVELWASHN3    M9OPT3
     C                     MOVELWAKNBN    M9OBRC
     C                     MOVELWAKANS    M9OBR1
     C                     MOVELWAZETI    M9OBR2
     C                     MOVELWACDT6    M9OBR3
     C                     MOVELWASEIH    M9OBR4
     C                     MOVELWAITM1    M9OBR5
     C                     MOVELWAITM2    M9OBR6
     C                     MOVELWACHKD    M9OBR7
     C*
     C                     MOVELWBSHN1    M9CPT1
     C                     MOVELWBSHN2    M9CPT2
     C                     MOVELWBSHN3    M9CPT3
     C                     MOVELWBKNBN    M9CBRC
     C                     MOVELWBKANS    M9CBR1
     C                     MOVELWBZETI    M9CBR2
     C                     MOVELWBORDR    M9CBR3
     C                     MOVELWBSEIH    M9CBR4
     C                     MOVELWBITM1    M9CBR5
     C                     MOVELWBITM2    M9CBR6
     C                     MOVELWBCHKD    M9CBR7
     C*
     C                     ENDSR
      **************************************************************************
      *       CALL PROGRAM TO UPDATE WASHER INVENTORY FILE
      **************************************************************************
     C           #CALL     BEGSR
      *
     C                     MOVEL#PGM      ##PGMN 10
     C                     MOVELWAKNBN    ORDKAN 20
     C                     MOVELWBKNBN    CONKAN 20
      *
      * STEP 1 - ADD CONTAINER IF NOT IN INVENTORY FILE
     C                     CALL 'IWAR70U1'
     C                     PARM           CONKAN
     C                     PARM           L1TKRO
     C                     PARM           WORKER
     C                     PARM           ##PGMN
     C                     PARM '1'       #STEP   1
     C                     PARM           #RTNC   1
      *
      * STEP 2 - DUMP (CONSUME) CONTAINER INTO ORDER (CAN)
     C                     CALL 'IWAR70U2'
     C                     PARM           CONKAN
     C                     PARM           ORDKAN
     C                     PARM 'DUMP  '  LOC6    6
     C                     PARM           WORKER
     C                     PARM           ##PGMN
     C                     PARM '2'       #STEP
     C                     PARM           #RTNC
      *
     C                     ENDSR
     C**************************************************************************
     C*       EDIT LAST PART
     C**************************************************************************
     C           #LASTP    BEGSR
     C*
     C                     MOVEL*BLANK    F1SHIN
     C                     MOVELWASHN1    F1SHN1
     C           WASHN2    IFNE *BLANK
     C                     MOVEL'-'       F1SHNA
     C                     END
     C                     MOVELWASHN2    F1SHN2
     C           WASHN3    IFNE *BLANK
     C                     MOVEL'-'       F1SHNB
     C                     END
     C                     MOVELWASHN3    F1SHN3
     C*
     C                     ENDSR
     C**************************************************************************
     C*       EDIT ORDR PART
     C**************************************************************************
     C           #ORDRP    BEGSR
     C*
     C                     MOVEL*BLANK    F2SHIN
     C                     MOVELWASHN1    F2SHN1
     C           WASHN2    IFNE *BLANK
     C                     MOVEL'-'       F2SHNA
     C                     END
     C                     MOVELWASHN2    F2SHN2
     C           WASHN3    IFNE *BLANK
     C                     MOVEL'-'       F2SHNB
     C                     END
     C                     MOVELWASHN3    F2SHN3
     C*
     C                     ENDSR
     C**************************************************************************
** ERR
USER CODE ERROR                  #01 O
ORDER KANBAN ERROR               #02 O
BLANK                            #03 O
M/F NOT FOUND                    #04 O
CHECK DIGIT                      #05 O
ASJ KANBAN ERROR                 #06 O
ONLY ASJ KANBAN                  #07 O
UNMATCHED                        #08 O
PART NUMBER                      #09 O
ALREADY DELETED                  #10 O
ALREADY PROCESSED                #11 O
DUPLICATE                        #12 O
ALREADY SCANNED                  #13 O
TOO MUCH SCAN                    #14 O
SCAN NOT FIXED                   #15 O WARNING
IGNORE UPDATE?                   #16 O WARNING
ID ERROR                         #17 O
                                 #18
                                 #19
                                 #20
