     C                     MOVELWBKNBN    ASJB,X
     C                     MOVELWBSHIN    ASJP,X
     C                     TIME           WWTIME
     C                     Z-ADDWTIM4     SCNT,X
     C                     Z-ADD@@YMD     SCND,X
     C                     EXSR #CLRS2
     C                     ELSE
      ***   write error to output log...
     C                     EXSR #WRTER
      *
      ***   if error needs to lock screen...
