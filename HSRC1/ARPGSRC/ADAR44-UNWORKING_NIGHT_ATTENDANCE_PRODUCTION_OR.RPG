     H            Y.
     F** ADAR44 **************************************
     F*UNWORKING NIGHT ATTENDANCE PRODUCTION ORDER  LIST MAKING ADAR44 *
     F*                      FOR ERROR             *
     F************************************** ADAR44 **
     FADAWL44 IP  F     128            DISK
     FFCEPL01 IF  E           K        DISK
     FADAPR44 O   E             50     PRINTER
     E                    TBL     1   2 10
     IADAWL44 AA  01
     I                                        1   4 DAMEKA
     I                                        5   9 DAHIN1L1
     I                                       10  14 DAHIN2L1
     I                                       15  16 DAHIN3L1
     I                                       17  230DASURY
     I                                       24  280DASYUY
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I            DS
     I                                        1   6 A2KTKR
     I                                        1   1 A2KTRK
     I                                        2   3 A2KTRT
     I                                        4   5 A2KTRR
     I                                        6   6 A2KTRD
     I            DS
     I                                        1   6 A2STKR
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
     I            DS
     I                                        1  14 @HIN
     I                                        1   5 DAHIN1
     I                                        6   6 H1
     I                                        7  11 DAHIN2
     I                                       12  12 H2
     I                                       13  14 DAHIN3
     I            DS
     I                                        1   9 @TKR
     I                                        1   1 @TKR1
     I                                        2   2 @T1
     I                                        3   4 @TKR2
     I                                        5   5 @T2
     I                                        6   7 @TKR3
     I                                        8   8 @T3
     I                                        9   9 @TKR4
     I            DS
     I                                        1   6 WTKRO
     I                                        1   1 WTKR1
     I                                        2   3 WTKR2
     I                                        4   5 WTKR3
     I                                        6   6 WTKR4
     C           KEY       KLIST
     C                     KFLD           DAHIN1
     C                     KFLD           DAHIN2
     C                     KFLD           DAHIN3
     C/SPACE 1
     C           *IN02     IFEQ '0'
     C                     SETON                     02
     C/SPACE 1
     C           *ENTRY    PLIST
     C                     PARM           PARM1   1
     C                     PARM           PARM2   8
     C                     MOVE PARM2     @MID2
     C/SPACE 1
     C           PARM1     IFEQ 'R'
     C                     MOVELTBL,1     @MID1
     C                     END
     C           PARM1     IFEQ 'M'
     C                     MOVELTBL,2     @MID1
     C                     END
     C/SPACE 1
     C                     WRITEADAPR441
     C                     END
     C/SPACE 1
     C                     ADD  DASURY    WSURY   80
     C/SPACE 1
     CL1                   EXSR SUBRTN
     C/SPACE 1
     CLR         @GHAK     IFEQ *ZERO
     CLR                   SETON                     99
     CLR                   END
     CLRN99                WRITEADAPR443
     C/SPACE 1
     C           SUBRTN    BEGSR
     C                     SETOF                     03
     C                     Z-ADD0         @SYUY
     C                     MOVE *BLANK    WTR     6
     C/SPACE 1
     C           KEY       CHAINFCEPL011             03
     C           *IN03     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
     C/SPACE 1
     C           *IN03     IFEQ '0'
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    @SYUY
     C                     ELSE
     C                     Z-ADDA2SSYS    @SYUY
     C                     END
     C           A2TRHZ    IFGT *DATE
     C                     MOVE A2KTKR    WTR
     C                     ELSE
     C                     MOVE A2STKR    WTR
     C                     END
     C                     END
     C/SPACE 1
     C                     Z-ADD0         @HAK
     C           @SYUY     IFNE 0
     C           WSURY     DIV  @SYUY     @HAK      H
     C                     END
     C/SPACE 1
     C           @HAK      IFGE 3
     C                     ADD  @HAK      @GHAK
     C/SPACE 1
     C                     MOVE *BLANK    H1
     C                     MOVE *BLANK    H2
     C           DAHIN2    IFNE *BLANK
     C                     MOVE '-'       H1
     C                     END
     C           DAHIN3    IFNE *BLANK
     C                     MOVE '-'       H2
     C                     END
     C/SPACE 1
     C                     MOVE WTR       WTKRO
     C                     MOVE *BLANK    @TKR
     C                     MOVE WTKR1     @TKR1
     C                     MOVE WTKR2     @TKR2
     C                     MOVE WTKR3     @TKR3
     C                     MOVE WTKR4     @TKR4
     C/SPACE 1
     C*                    MOVEL@TKR2     WTKR    1
     C*          WTKR      IFEQ '0'
     C*                    MOVEL' '       @TKR2
     C*                    END
     C*                    MOVEL@TKR3     WTKR
     C*          WTKR      IFEQ '0'
     C*                    MOVEL' '       @TKR3
     C*                    END
     C*          @TKR4     IFEQ '0'
     C*                    MOVE '-'       @T3
     C*                    MOVE *BLANK    @TKR4
     C*                    END
     C/SPACE 1
     C           @TKR2     IFNE *BLANK
     C                     MOVE '-'       @T1
     C                     END
     C           @TKR3     IFNE *BLANK
     C                     MOVE '-'       @T2
     C                     END
     C           @TKR4     IFNE *BLANK
     C                     MOVE '-'       @T3
     C                     END
     C/SPACE 1
     C           *IN50     IFEQ '1'
     C                     WRITEADAPR441
     C                     SETOF                     50
     C                     END
     C/SPACE 1
     C                     WRITEADAPR442
     C                     END
     C/SPACE 1
     C                     Z-ADD0         WSURY
     C                     ENDSR
** TBL
UNWRK ATT
UNWRK NGT
