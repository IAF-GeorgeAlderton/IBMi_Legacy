     C                     MOVE #ZAI2     XXZAI2
     C                     MOVE #CTRK     XXCTRK
     C                     MOVE #CTRD     XXCTRD
     C                     MOVE #SPNK     XXSPNK
     C                     MOVE #SPND     XXSPND
      *  EXFMT fﾞx] 2
     C                     EXSR #SET2
     C                     MOVE *BLANK    OP
     C                     UPDATDSP2R
E003 C                     END
E002 C                     END
E001 C  N42                END
      *
     C                     Z-ADD*ZERO     RRN
