     C                     MOVELJ5PAG4    #PNO4
     C                     MOVELJ52JKA    #2JIK
     C                     MOVELJ5TASY    #TISG
     C                     MOVELJ5SYKO    #SYKB
     C                     MOVELJ5HKBR    #HAKO
     C                     Z-ADDJ5MKSU    #KEIS
     C                     MOVELJ5IROK    #IRO
     C                     Z-ADDJ5SYUY    #SYOS
     C                     MOVELJ5HKFA    #MHKO
     C                     Z-ADDJ5TANJ    #TANJ
     C                     Z-ADDJ5WKHZ    #THIZ
     C                     Z-ADDJ5WKTM    #TTIM
     C                     Z-ADDJ5WMJY    #TNMJ
     C                     MOVE J5MKKB    #KIBN
     C                     Z-ADDJ5KEHZ    #KHIZ
     C                     Z-ADDJ5KETM    #KTIM
     C                     Z-ADDJ5WAIT    #KEIJ
     C                     MOVE J5TOCD    #TOCD
