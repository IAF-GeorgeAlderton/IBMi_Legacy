     C                     Z-ADDJ5WKHZ    @THIZ
     C                     Z-ADDJ5WKTM    @TTIM
     C                     Z-ADDJ5KEHZ    @HHIZ
     C                     Z-ADDJ5KETM    @HTIM
     C                     MOVELJ5KANK    #KNKB
