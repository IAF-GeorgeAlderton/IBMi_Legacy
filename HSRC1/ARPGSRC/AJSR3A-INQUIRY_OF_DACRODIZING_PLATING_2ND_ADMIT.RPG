     C                     Z-ADDJ5TANJ    #TANJ
     C                     Z-ADDJ5WKHZ    #THIZ
     C                     Z-ADDJ5WKTM    #TTIM
     C                     Z-ADDJ5WMJY    #TNMJ
     C                     MOVE J5MKKB    #KIBN
     C                     Z-ADDJ5KEHZ    #KHIZ
     C                     Z-ADDJ5KETM    #KTIM
     C                     Z-ADDJ5WAIT    #KEIJ
     C                     MOVE J5TOCD    #TOCD
     C                     MOVE J5ZBR1    #ZAI1
     C                     MOVE J5ZBR2    #ZAI2
     C                     MOVE J5CTRK    #CTRK
     C                     MOVE J5CTRD    #CTRD
     C                     MOVE J5SPNK    #SPNK
     C                     MOVE J5SPND    #SPND
      *
     C                     MOVEA'0'       *IN,21
     C           J5SAIK    IFEQ '1'
