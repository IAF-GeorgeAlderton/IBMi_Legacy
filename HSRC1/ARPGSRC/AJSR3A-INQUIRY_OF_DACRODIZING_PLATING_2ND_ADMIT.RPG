     C                     MOVE *BLANK    #SPND
      *
B001 C                     DO   *HIVAL
     C           MORE1     TAG
     C           KEY2      READEAJSPL921                 40
     C   40                GOTO @@@
      *
     C           J5SKJY    IFEQ 'D'
     C           J5SKHZ    IFLE *DATE
     C                     GOTO MORE1
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C                     MOVEA'0'       *IN,21
     C           J5WKHZ    CABLTSHIZ      @END
     C           J5WKHZ    CABGTEHIZ      @@@
     C                     MOVE J5MKKB    @KIBN
     C                     MOVELJ5THAI    @TEHI
     C                     MOVELJ5PAG1    @PAG1
     C                     MOVELJ5PAG2    @PAG2
     C                     MOVELJ5PAG3    @PAG3
