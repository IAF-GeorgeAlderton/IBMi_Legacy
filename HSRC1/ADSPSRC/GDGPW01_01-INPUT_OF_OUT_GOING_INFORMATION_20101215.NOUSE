     A* CTL01
     A**************
     A          R CTL01                     SFLCTL(SFL01)
     A                                      CF01 CF03 CF05
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(9) SFLSIZ(10)
     A                                      ROLLUP(71)
     A                                      ROLLDOWN(72)
     A  81                                  SFLDSP
     A  82                                  SFLDSPCTL
     A  83                                  SFLCLR
     A            NBR            4  0H      SFLRCDNBR
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 23' INPUT OF DELIVERY INFORM-
     A                                      ATION '
     A                                      DSPATR(RI)
     A                                    +1'(PRODUCTS)'
     A                                  1 69'FMT GDGPW01'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  4  5' DATA CORRECTION SCRREN '
     A                                      DSPATR(RI)
     A                                  6  5'PART NO.'
     A            D3HIN1         5      7  5
     A                                   + 1'-'
     A            D3HIN2         5       + 1
     A                                   + 1'-'
     A            D3HIN3         2       + 1
     A                                  9  6'   MARK      PART NO.      -
     A                                      SHEETS   ID NO.  SEQ.  PROD.CODE -
     A                                       ORDER DATE '
     A*                                 9  8' MARK      PART NO.      -
     A*                                     SHEETS     ID NUMBER  PROD .CODE -
     A*                                      ORDER DATE '
     A                                      DSPATR(HI UL)
