     A**************
     A* DSP01 *
     A**************
     A          R DSP01                     CF01 CF07 CF12
     A                                      OVERLAY PROTECT
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 23' INPUT OF DELIVERY INFORM-
     A                                      ATION '
     A                                      DSPATR(RI)
     A                                    +1'(PRODUCTS)'
     A                                  1 69'FMT GDGPW01'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  5  5' INPUT OF BARCODES '
     A                                  9 11'GAVE A BARCODES BE READ -
     A                                      ----->'
     A            D1BAR         17   B  9 42CHECK(ER)
     A  99                                  DSPATR(RI PC)
     A**************
     A* DSP02  *
     A**************
     A          R DSP02                     OVERLAY
     A                                 13  7'                      -
     A                                      VERIFICATION SCREEN-
     A                                                               '
     A                                      DSPATR(RI)
     A                                 14  7' '   DSPATR(RI)
     A                                 15  7' '   DSPATR(RI)
     A                                 16  7' '   DSPATR(RI)
     A                                 17  7' '   DSPATR(RI)
     A                                 18  7' '   DSPATR(RI)
     A                                 14 72' '   DSPATR(RI)
     A                                 15 72' '   DSPATR(RI)
     A                                 16 72' '   DSPATR(RI)
     A                                 17 72' '   DSPATR(RI)
     A                                 18 72' '   DSPATR(RI)
     A                                 19  7'                      -
     A                                                         -
     A                                                               '
     A                                      DSPATR(RI)
     A                                 15 14'ORDER NO.'
     A                                 15 29'ID NUMBER'
     A                                 15 43'PROD.CODE'
     A                                 15 54'ISSUE NO.'
     A                                 15 65'C/D'
     A            D2ODER         6Y 0  16 15
     A            D2ZETI         4     16 31
     A            D2SEIH         1     16 47
     A            D2RENB         4Y 0  16 55
     A            D2CD           1     16 66
     A                                 18 24'"KANBAN" ABOVE HAS -
     A                                      BEEN INPUT'
     A**************
     A* MSG        *
     A**************
     A          R MSG01
     A                                 22 10' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 20
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24  1'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 17'PRESS'
     A                                   + 1' CMD-7 '
     A                                      DSPATR(RI)
     A                                   + 1'FOR MANUAL INPUT'
     A                                 24 48'PRESS'
     A                                   + 1' CMD-12'
     A                                      DSPATR(RI)
     A                                   + 1'HALF-FIN. INPUT'
     A**************
     A* DSP03  *
     A**************
     A          R DSP03                     OVERLAY PROTECT
     A                                      CF01 CF03 CF05 CF07
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 23' INPUT OF DELIVERY INFORM-
     A                                      ATION '
     A                                      DSPATR(RI)
     A                                    +1'(PRODUCTS)'
     A                                  1 69'FMT GDGPW01'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
