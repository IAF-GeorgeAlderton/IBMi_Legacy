     A                                   + 1'-'
     A            D4HIN2         5       + 1
     A                                   + 1'-'
     A            D4HIN3         2       + 1
     A            D4MAIS         3Y 0  16 35EDTCDE(4)
     A            D4ZETI         4     16 43
     A            D4SEIH         1     16 56
     A            D4HAHZ         8Y 0  16 65EDTCDE(4)
