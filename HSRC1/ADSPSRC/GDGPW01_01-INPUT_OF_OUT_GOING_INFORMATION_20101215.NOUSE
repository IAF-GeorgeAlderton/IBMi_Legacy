     A                                      DSPATR(RI)
     A                                  7 13'PART NO.'
     A                                  7 31'NUMBER OF SHEETS'
     A                                  7 51'PROD.CODE'
     A                                  7 64'ORDER DATE'
     A            D3HIN1         5   B  9 13
     A  21                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D3HIN2         5   B   + 1
     A  21                                  DSPATR(RI)
     A                                   + 1'-'
     A            D3HIN3         2   B   + 1
     A  21                                  DSPATR(RI)
     A            D3MAIS         3Y 0B  9 38EDTCDE(4) CHECK(RB)
     A  22                                  DSPATR(RI PC)
     A            D3SEIH         1   B  9 54
     A  23                                  DSPATR(RI PC)
     A            D3HAHZ         8Y 0B  9 65EDTCDE(4) CHECK(RB)
     A  24                                  DSPATR(RI PC)
