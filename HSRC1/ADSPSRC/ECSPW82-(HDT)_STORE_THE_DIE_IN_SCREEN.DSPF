     A**** ECSPW82 ****************************************
     A*  (HDT) STORE THE DIE IN SCREEN                    *
     A*          2019.05.24  MAEDA.                       *
     A************************************** ECSPW82 ******
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF01(01) CF02(02) CF03(03)
     A                                      CF04(04) CF05(05) CF06(06)
     A                                      CF07(07) CF08(08) CF09(09)
     A                                      CF10(10) CF11(11) CF12(12)
     A                                      CF13(13) CF14(14) CF15(15)
     A                                      CF16(16) CF17(17) CF18(18)
     A                                      CF19(19) CF20(20) CF21(21)
     A                                      CF22(22) CF23(23) CF24(24)
     A*
     A*===================================================*
     A*      1. READING PT KANBAN                         *
     A*===================================================*
     A          R ECSPW821
     A  99                                  ALARM
     A*
     A                                  1  2' STORE IN (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2  9TEXT(' WORKER ')
     A*
     A                                  4  2'KANBAN (PT OR LOCAL)'
     A            D#BAR1        18A  B  5  2TEXT(' PT KANBAN ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      2. READING STORE OUT LABEL                   *
     A*===================================================*
     A          R ECSPW822
     A  99                                  ALARM
     A*
     A                                  1  2' STORE IN (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2  9TEXT(' WORKER ')
     A*
     A                                  4  2'STORE OUT LABEL'
     A            D#BAR2        15A  B  5  2TEXT(' STORE OUT LABEL ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A**                                7  2'DIE PART NO.'
     A**          D#KAT@        11A  O  7 15TEXT(' DIE NUMBER ')
     A**                                    DSPATR(UL)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      3. READING DIE LOCATION LABEL                *
     A*===================================================*
     A          R ECSPW823
     A  99                                  ALARM
     A*
     A                                  1  2' STORE IN (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2  9TEXT(' WORKER ')
     A*
     A                                  4  2'LOCATION BARCODE'
     A            D#BAR3        16A  B  5  2TEXT(' DIE LOCATION LABEL ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A                                  7  2'DIE PART NO.'
     A            D#KAT@        11A  O  7 15TEXT(' DIE NUMBER ')
     A                                      DSPATR(UL)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      4. READING DIE KANBAN                        *
     A*===================================================*
     A          R ECSPW824
     A  99                                  ALARM
     A*
     A                                  1  2' STORE IN (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2  9TEXT(' WORKER ')
     A*
     A                                  4  2'DIE KANBAN'
     A            D#BAR4        13A  B  5  2TEXT(' DIE KANBAN ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A                                  7  2'DIE PART NO.'
     A            D#KAT@        11A  O  7 15TEXT(' DIE NUMBER ')
     A                                      DSPATR(UL)
     A*
     A                                  8  2'LOCATION'
     A            D#LOC@        11A  O  8 15TEXT(' LOCATION ')
     A                                      DSPATR(UL)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      9. DISPLAY ERROR MESSAGE                     *
     A*===================================================*
     A          R ECSPW829
     A  99                                  ALARM
     A*
     A                                  1  2' STORE IN (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2  9TEXT(' WORKER ')
     A*
     A                                  5  5'***          ***'
     A                                  6  5'  ***      ***  '
     A                                  7  5'    ***  ***    '
     A                                  8  5'      ****      '
     A                                  9  5'    ***  ***    '
     A                                 10  5'  ***      ***  '
     A                                 11  5'***          ***'
     A*
     A            D#EMSG        25A  O 15  1TEXT(' MESSAGE ')
     A                                      DSPATR(RI)
     A*
     A                                 16  2'F1 BACK'
     A*
