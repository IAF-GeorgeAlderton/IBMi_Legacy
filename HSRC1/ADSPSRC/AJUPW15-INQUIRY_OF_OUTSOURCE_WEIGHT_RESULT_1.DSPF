     A** AJUPW15 ******************************************************
     A* INQUIRY OF OUTSOURCE WEIGHT RESULT 1
     A* KIRI  15/12/07
     A*****************************************************************
     A                                      CHGINPDFT
     A                                      PRINT
      *-------------------------------------
     A          R DSP01
     A                                      CF01
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20' INQUIRY OF OUTSOURCE -
     A                                      WEIGHT RESULT 1 '
     A                                      DSPATR(RI UL)
     A                                  1 71'AJUPW15'
     A                                  2  2'DATE'
     A                                  2  7DATE  EDTWRD('0  .  .  ')
     A*
     A                                  6 24'MACHINE NO'
     A                                      DSPATR(UL)
     A            D1MKKB         2   B  8 28TEXT('MACHINE NO')
     A                                      DSPATR(CS)
     A  11                                  DSPATR(PC RI)
     A*
     A                                  8 35'01: MACHINE #1'
     A*
     A                                 10 20'WEIGHTING DATE TIME-
     A                                                      '
     A                                      DSPATR(UL)
     A            D1KED1         8  0B 12 20TEXT('WEIGHTING DATE')
     A                                      EDTWRD('    /  /  ')
     A                                      EDTMSK('    &  &  ')
     A                                      DSPATR(CS)
     A  12                                  DSPATR(PC RI)
     A            D1KET1         4  0B   + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('  :  ')
     A                                      EDTMSK('  &  ')
     A                                      DSPATR(CS)
     A  13                                  DSPATR(PC RI)
     A                                   + 1'-' DSPATR(HI)
     A            D1KED2         8  0B   + 1TEXT('WEIGHTING DATE')
     A                                      EDTWRD('    /  /  ')
     A                                      EDTMSK('    &  &  ')
     A                                      DSPATR(CS)
     A  14                                  DSPATR(PC RI)
     A            D1KET2         4  0B   + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('  :  ')
     A                                      EDTMSK('  &  ')
     A                                      DSPATR(CS)
     A  15                                  DSPATR(PC RI)
      **
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60   O 22 18
      **
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'END'
      * ------------------------------------
      * ------------------------------------
     A          R SFREC1                    SFL
     A            S1SLCT         1   B  7  2DSPATR(CS)
     A            S1KEID         6  0    + 1TEXT('WEIGHTING DATE')
     A                                      EDTWRD('  /  /  ')
     A            S1KEIT         4  0    + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('0 :  ')
     A            S1HIN         14       + 1TEXT('PART NUMBER')
      *
     A            S1THP1         6       + 1TEXT('ORDER+PAGE 1')
     A            S1THP2         6       + 1TEXT('ORDER+PAGE 2')
     A            S1THP3         6       + 1TEXT('ORDER+PAGE 3')
     A            S1THP4         6       + 1TEXT('ORDER+PAGE 4')
     A            S1ZBR1         8       + 1TEXT('MATERIAL BARCODE 1')
     A            S1ZBR2         8       + 1TEXT('MATERIAL BARCODE 2')
      *
     A            S1KANR         1   H      TEXT('MANAGEMENT INSTRUC')
     A            S1ZETI         4   H      TEXT('ID NUMBER')
     A            S12JKA         1   H      TEXT('SECONDARY PROCESSING')
     A            S1TASY         1   H      TEXT('OBJECT OUTSIDE')
     A            S1SYUK         1   H      TEXT('OUTGOING EFFECTIVE')
     A            S1HKBR         1   H      TEXT('CONTAINER TYPE(BCR)')
     A            S1HNTE         1   H      TEXT('PART NUMBER INPUT')
     A            S1SYTE         1   H      TEXT('ACCOMMODATED QUANT')
     A            S1SYUY         5  0H      TEXT('ACCOMMODATED QTY')
     A            S1HKFA         1   H      TEXT('CONTAINER TYPE(FAM)')
     A            S1TATE         1   H      TEXT('COMPLETION UNIT WEIGHT')
     A            S1TANJ         7  3H      TEXT('COMP UNIT WEIGHT')
     A            S1MTAN         7  3H      TEXT('COMP UNIT MASTER WEIGHT')
     A            S1WAIT         5  2H      TEXT('WEIGHTING WEIGHT')
     A            S1TMAI         2  0H      TEXT('NUMBER OF SURPLUS')
     A            S1GAFR         1   H      TEXT('APPEARANCE DEFECT')
     A            S1BINN         4   H      TEXT('BIN NO.')
     A            S1KECD         6   H      TEXT('MEASUREMENT WORKER')
      * ----------
     A          R SFCTL1                    SFLCTL(SFREC1)
     A                                      SFLSIZ(0016)
     A                                      SFLPAG(0015)
     A                                      OVERLAY
     A                                      CF01 CF03
     A  71                                  SFLDSP
     A  72                                  SFLDSPCTL
     A  73                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      ROLLUP(74)
     A            #RCNO1         4  0H      SFLRCDNBR
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 20' INQUIRY OF OUTSOURCE -
     A                                      WEIGHT RESULT 1 '
     A                                      DSPATR(RI UL)
     A                                  1 71'AJUPW15'
     A*
     A                                  3 18'MACHINE NO'
     A                                      DSPATR(UL)
     A                                  3 35'WEIGHTING DATE TIME-
     A                                                      '
     A                                      DSPATR(UL)
     A            D1MKKB         2      4 23TEXT('PLATING MACHINE NO')
     A*
     A            D1KED1         8  0    +10TEXT('WEIGHTING DATE')
     A                                      EDTWRD('    /  /  ')
     A            D1KET1         4  0    + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('  :  ')
     A                                   + 1'-' DSPATR(HI)
     A            D1KED2         8  0    + 1TEXT('WEIGHTING DATE')
     A                                      EDTWRD('    /  /  ')
     A            D1KET2         4  0    + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('  :  ')
     A*
     A                                  5  6'WEIGHTING'
     A                                      DSPATR(HI)
     A                                  5 66'MATERIAL' DSPATR(HI)
     A                                  5 34'ORDER ' DSPATR(HI)
     A                                  5 41'ORDER ' DSPATR(HI)
     A                                  5 48'ORDER ' DSPATR(HI)
     A                                  5 55'ORDER ' DSPATR(HI)
     A*
     A                                  6  2'X' DSPATR(HI)
     A                                  6  4'  DATE  '
     A                                      DSPATR(HI UL)
     A                                  6 13'TIME '
     A                                      DSPATR(HI UL)
     A                                  6 19'PART NUMBER   '
     A                                      DSPATR(HI UL)
     A                                  6 34'PAGE 1' DSPATR(HI UL)
     A                                  6 41'PAGE 2' DSPATR(HI UL)
     A                                  6 48'PAGE 3' DSPATR(HI UL)
     A                                  6 55'PAGE 4' DSPATR(HI UL)
     A                                  6 62'BARCODE1'
     A                                      DSPATR(HI UL)
     A                                  6 71'BARCODE2'
     A                                      DSPATR(HI UL)
      * ----------
     A          R DSP02
     A  99                             23 11'ERROR' DSPATR(RI BL)
     A  99        D2ERR         60   O 23 18
      **
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'END'
     A                                   + 4' F3 ' DSPATR(RI)
     A                                   + 1'GO BACK'
      * ------------------------------------
      * ------------------------------------
     A          R DSP03
     A                                      CF01 CF03
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 20' INQUIRY OF OUTSOURCE -
     A                                      WEIGHT RESULT 1 '
     A                                      DSPATR(RI UL)
     A                                  1 71'AJUPW15'
     A*
     A                                  3 18'MACHINE NO'
     A                                      DSPATR(UL)
     A                                  3 35'WEIGHTING DATE TIME-
     A                                                      '
     A                                      DSPATR(UL)
     A            D1MKKB         2      4 23TEXT('MACHINE NO')
     A*
     A            D1KED1         8  0    +10TEXT('WEIGHTING DATE')
     A                                      EDTWRD('    /  /  ')
     A            D1KET1         4  0    + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('  :  ')
     A                                   + 1'-' DSPATR(HI)
     A            D1KED2         8  0    + 1TEXT('WEIGHTING DATE')
     A                                      EDTWRD('    /  /  ')
     A            D1KET2         4  0    + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('  :  ')
     A*
     A                                  6  6'WEIGHTING'
     A                                      DSPATR(HI)
     A                                  6 34'ORDER ' DSPATR(HI)
     A                                  6 41'ORDER ' DSPATR(HI)
     A                                  6 48'ORDER ' DSPATR(HI)
     A                                  6 55'ORDER ' DSPATR(HI)
     A                                  6 66'MATERIAL' DSPATR(HI)
     A*
     A                                  7  4'  DATE  '
     A                                      DSPATR(HI UL)
     A                                  7 13'TIME '
     A                                      DSPATR(HI UL)
     A                                  7 19'PART NUMBER   '
     A                                      DSPATR(HI UL)
     A                                  7 34'PAGE 1' DSPATR(HI UL)
     A                                  7 41'PAGE 2' DSPATR(HI UL)
     A                                  7 48'PAGE 3' DSPATR(HI UL)
     A                                  7 55'PAGE 4' DSPATR(HI UL)
     A                                  7 62'BARCODE1'
     A                                      DSPATR(HI UL)
     A                                  7 71'BARCODE2'
     A                                      DSPATR(HI UL)
     A*
     A            S1KEID         6  0   8  4TEXT('WEIGHTING DATE')
     A                                      EDTWRD('  /  /  ')
     A            S1KEIT         4  0    + 1TEXT('WEIGHTING TIME')
     A                                      EDTWRD('0 :  ')
     A            S1HIN         14       + 1TEXT('PART NUMBER')
      *
     A            S1THP1         6       + 1TEXT('ORDER+PAGE 1')
     A            S1THP2         6       + 1TEXT('ORDER+PAGE 2')
     A            S1THP3         6       + 1TEXT('ORDER+PAGE 3')
     A            S1THP4         6       + 1TEXT('ORDER+PAGE 4')
     A            S1ZBR1         8       + 1TEXT('MATERIAL BARCODE 1')
     A            S1ZBR2         8       + 1TEXT('MATERIAL BARCODE 2')
      *         *
     A                                 10  4'ACCOMMODATED' DSPATR(HI)
     A                                 11  4'  QUANTITY  ' DSPATR(HI UL)
     A            S1SYUY         5  0  12  6EDTCDE(2)
     A            S1HKFA         1       + 1TEXT('CONTAINER TYPE(FAM)')
      *         *
     A                                 10 22'COMPLETION UNIT' DSPATR(HI)
     A                                 11 20'   WEIGHT  (MASTER)'
     A                                      DSPATR(HI UL)
     A            S1TANJ         7  3  12 20EDTCDE(2)
     A            S1MTAN         7  3    + 1EDTCDE(2)
      *         *
     A                                 10 43'WEIGHTING' DSPATR(HI)
     A                                 11 43'  WEIGHT ' DSPATR(HI UL)
     A            S1WAIT         5  2  12 45EDTCDE(2)
      *         *
     A                                 11 56'BIN NO.' DSPATR(HI UL)
     A            S1BINN         4     12 57TEXT('BIN NO.')
     A                                 10 67'MEASUREMENT' DSPATR(HI)
     A                                 11 67'   WORKER  ' DSPATR(HI UL)
     A            S1KECD         6     12 70TEXT('MEASUREMENT WORKER')
      *         *
     A                                 14  4'NUMBER OF SURPLUS'
     A                                      DSPATR(HI)
     A                                 15  4'  KANBAN ISSUED  '
