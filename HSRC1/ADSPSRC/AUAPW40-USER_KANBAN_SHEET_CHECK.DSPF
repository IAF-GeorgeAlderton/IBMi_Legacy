     A** AUAPW40 *******************************************
     A* USER KANBAN SHEET CHECK (PARM INPUT SCREEN)
     A*              M-OKUDA            86.11.15           *
     A******************************************************
     A                                      PRINT
     A                                      CHGINPDFT
     A          R AUAPW401                  TEXT('USER KANBAN CHECK')
     A                                      CA01(01)
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 24' INPUT OF USER KANBAN +
     A                                      CHECK SHEET '
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'AUAPW40'
     A                                  7 20'RECEIVING CO.'
     A                                      DSPATR(RI)
     A            UNONY          4A  B  7 39DSPATR(CS)
     A  02                                  DSPATR(RI PC)
     A                                  9 20'FACTORY'
     A                                      DSPATR(RI)
     A            UNKOJ          1A  B  9 39DSPATR(CS)
     A  03                                  DSPATR(RI PC)
     A                                 11 20'DATE OF DELIVERY'
     A                                      DSPATR(RI)
     A            UNOBI          6A  B 11 39DSPATR(CS)
     A  04                                  DSPATR(RI PC)
     A                                 13 20'BIN OF DELIVERY'
     A                                      DSPATR(RI)
     A            UBIN           1A  B 13 39DSPATR(CS)
     A  05                                  DSPATR(RI PC)
     A                                 15 20'ORDER NO.'
     A                                      DSPATR(RI)
     A            UCHNO         10A  B 15 39DSPATR(CS)
     A  06                                  DSPATR(RI PC)
     A  99                             22 11' ERR ' DSPATR(RI BL)
     A  99        UMSG          60   O 22 18DSPATR(HI)
     A                                 24 11'CANCEL'
     A                                 24 18' CMD-1 ' DSPATR(RI)
