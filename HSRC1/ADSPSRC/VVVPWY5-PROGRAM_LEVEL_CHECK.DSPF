     A** VVVPWY5 *************************************
     A* PROGRAM LEVEL CHECK                          *
     A*    KIRI                        2014.10.09    *
     A************************************* VVVPWY5 **
     A                                      PRINT
     A                                      CHGINPDFT
      *
     A          R DSP01
     A                                      CF01 CF05
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  /  /  ')
     A                                  1 17' **  PROGRAM SRC & OBJ LEVEL CHK+
     A                                      ** '
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT VVVPWY5'
      *
     A                                  5 19' PHYSICAL FILE '
     A            D1FILE        10   B   + 1DSPATR(CS)
     A  11                                  DSPATR(PC RI)
      *
     A  99                             22 11' ERR ' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
      *
     A                                 24  4' F1 '  DSPATR(RI)
     A                                    +1'END'
     A                                    +4' F5 '  DSPATR(RI)
     A                                    +1'CREAT CSV DATA'
