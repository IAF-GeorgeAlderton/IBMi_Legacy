     A                                      PRINT
     A*----------------------------------------------------------------
     A          R DSP01
     A*%%TS  SD  20190711  153204  I0777       REL-V7R3M0  5770-WDS
     A                                      CF01(01)
     A                                      CF05(05)
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20' ** print TOYOTA WEB LOCATION CHEC-
     A                                      K LIST ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AL#PWTB '
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  7 12'Enter Ship Date From :'
     A                                      COLOR(WHT)
     A*
     A            XFROM         10A  B  7 35TEXT('SHRTG DATE')
     A  41                                  DSPATR(PC)
     A  41                                  DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  7 45'YYYYMMDD'
     A                                      COLOR(YLW)
     A                                  7 47'YYYYMMDD'
     A                                      COLOR(YLW)
     A*
     A                                 13 12'Select Printer ..... :'
     A                                      COLOR(WHT)
     A            XSLCT          1A  B 13 35DSPATR(UL)
     A  42                                  DSPATR(PC)
     A  42                                  DSPATR(RI)
     A                                 13 40'1.LANPRT03 (OFFICE)'
     A                                      COLOR(YLW)
     A            XMSG          70A  O 22  5COLOR(WHT)
     A*
     A                                 24  5'F1:'
