     A** KCLPWA1 ***********************
     A* LIMITATION PART DELIVERY DATE ANSWER *
     A* KANI <F1 F2> SELECT SCREEN *
     A* A-IDOTA 88.10.14 *
     A*********************** KCLPWA1 **
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A************
     A* SCREEN 1*
     A************
     A          R KCLPWA11
     A                                      TEXT('LIMITATION PART')
     A                                      CF01(01)
     A  90                                  ALARM
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 19'* LIMITATION PART DELIVERY DATE AN-
     A                                      SWER *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 69'FMT KCLPWA1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  8 20'INPUT SECTION CODE'
     A            @CODE          4A  B  8 51DSPATR(CS)
     A  02                                  DSPATR(RI)
     A  02                                  DSPATR(PC)
     A                                 10 24'KANI THE FIRST FACTORY  --- 9032'
     A                                 11 24'KANI THE SECOND FACTORY --- 9040'
     A                                 12 24'KANI THE THIRD FACTORY  --- 9245'
     A                                 13 24'KANI THE FOURTH FACTORY --- 9253'
     A                                 22 11'ERROR'
     A N90                                  DSPATR(ND)
     A  90                                  DSPATR(RI)
     A  90                                  DSPATR(BL)
     A            MSG           60A  O 22 18
     A N90                                  DSPATR(ND)
     A                                 24  5'EXIT'
     A                                 24 15'CMD-1'
     A                                      DSPATR(RI)
     A                                 24 24'INPUT OK'
     A                                 24 35'ENTER'
     A                                      DSPATR(RI)
