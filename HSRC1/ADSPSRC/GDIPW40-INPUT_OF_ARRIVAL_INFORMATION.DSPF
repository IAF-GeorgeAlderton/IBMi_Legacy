      **** GDIPW40 ***************************************************
      *   INPUT OF ARRIVAL INFORMATION
      *     G.B.C                           97/02/24
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS)
     A**************
     A* ＤＳＰ１ *
     A**************
     A          R DSP01                     CF01 CF05
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 19' INPUT TREATMENT ON RECEI-
     A                                      VE INFORMATION '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW40'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  9 14'INPUT THE INVOICE NUMBER -
     A                                      RECEIVED. -----'
     A            D1INVO         6   B   + 1
     A  11                                  DSPATR(RI PC)
     A                                 13 29'RECEIVED DATE'
     A            D1DATE         8Y 0B 14 31EDTCDE(4) CHECK(RB)
     A  12                                  DSPATR(RI PC)
     A                                 14 41'(YYYYMMDD)'
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 23
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24 10'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 34'INPUT OK'
     A                                   + 1' CMD-5 '
     A                                      DSPATR(RI)
