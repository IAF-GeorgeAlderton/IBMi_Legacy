     A*%%TS  SD  20210618  092330  I0777       REL-V7R3M0  5770-WDS
     A** ABBPW7M ******************************************************
     A*  INQUIRY MACHINE# TO PART SIZE                                *
     A*  KIRI 2015.09.15                                              *
     A*****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R SFREC1
     A                                      SFL
     A            S1SEL          1   B  5  5DSPATR(ND)
     A            S1MANO         3       + 1TEXT('MACHINE#')
     A            S1LOCT         6      5 16TEXT('LOCATION')
     A            S1SIZE         3A     5 26TEXT('SIZE')
      *
     A          R SFCTL1                    SFLCTL(SFREC1)
     A*%%TS  SD  20210618  092330  I0777       REL-V7R3M0  5770-WDS
     A  *DS3                                SFLLIN(0013)
     A                                      SFLSIZ(0033)
     A                                      SFLPAG(0032)
     A                                      CF03(03)
     A                                      CF10(10)
     A                                      CF12(12)
     A                                      OVERLAY
     A                                      PROTECT
     A  70                                  SFLDSPCTL
     A  71                                  SFLDSP
     A  72                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      ROLLUP(73)
     A                                      ROLLDOWN(73)
     A                                      SFLCSRRRN(&$RRN)
     A            RRN1           4S 0H      SFLRCDNBR
     A            $RRN           5S 0H
     A                                  1  2'ABBR7M'
     A                                  1 16' MACHINE#/LOCATION/SIZE MASTER INQ-
     A                                      UIRY '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 62DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A*
     A                                  4  3'  MACHINE#  LOCATION  SIZE  '
     A                                      DSPATR(UL)
     A                                  4 40'  MACHINE#  LOCATION  SIZE  '
     A                                      DSPATR(UL)
     A*
     A          R DSP99
     A*%%TS  SD  20210618  092330  I0777       REL-V7R3M0  5770-WDS
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                 24  7'BACK'
     A                                 24 41' PAGE UP/DOWN '
     A                                      DSPATR(RI)
     A                                 24 17' F10 '
     A                                      DSPATR(RI)
     A                                 24 23'Download csv'
