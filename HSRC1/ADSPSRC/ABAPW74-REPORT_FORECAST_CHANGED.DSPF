     A  99                                  ALARM
     A                                      CF01(01 'END')
     A                                      CF05(05 'UP DATE')
     A                                  1  2'TIME'
     A                                  1  7TIME EDTWRD('0 :  :  ')
     A                                  1 21'  内示更新変動数チェックの更新+
     A                                        '
     A                                      DSPATR(RI UL)
