     A** AJEPW06 *******************************
     A* .. PASS THROUGH MENU ABNORMALITY SCREEN  *
     A* ..REVISING  AJAPW28                  *
     A* I-HASADA                 91.05.23      *
     A******************************* AJEPW06 **
     A*
     A          R AJEPW061
     A*%%TS  SD  19961021  152039  AO          REL-V3R0M5  5763-PW1
     A                                      TEXT('THE FIRST SCREEN')
     A                                      CF01(01)
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 28'** PASS THROUGH MENU **'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 68'FMT AJEPW06'
     A                                  2 63'SYSTEM :'
     A            PSYS           8A  O  2 72DSPATR(HI)
     A                                  8 18'PLEASE OPRATE(DATA HANDLING) AT AS-
     A                                      /400 (NO.1)'
     A                                 24  4'EXIT OR CANCEL'
     A                                 24 27'CMD-1'
     A                                      DSPATR(RI)
     A                                 24 38'CHANGE TO NO.1'
     A                                 24 53'ENTER'
     A                                      DSPATR(RI)
     A*
     A*
     A          R AJEPW062
     A*%%TS  SD  19961021  152039  AO          REL-V3R0M5  5763-PW1
     A                                      TEXT('THE SECOND SCREEN')
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 28'** PASS THROUGH MENU **'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 68'FMT AJEPW06'
     A                                  2 63'SYSTEM :'
     A            PSYS           8A  O  2 72DSPATR(HI)
     A                                  6 21'SYSTEM IS ALREADY CONNECTED -
     A                                      WITH TARGET AS/400'
     A                                  8 21'OR YOU CAN NOT PASS THROUGH FROM T-
     A                                      HIS TELEVISION.'
     A                                 10 21'OR PASS THROUGH LINE IS NOT ACTIVE-
     A                                      .'
     A                                 24  9'EXIT'
     A                                 24 15'ENTER'
     A                                      DSPATR(RI)
     A*
     A*
     A          R AJEPW063
     A*%%TS  SD  19961021  152039  AO          REL-V3R0M5  5763-PW1
     A                                      TEXT('THE THIRD SCREEN')
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 28'** PASS THROUGH MENU **'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 68'FMT AJEPW06'
     A                                  2 63'SYSTEM :'
     A            PSYS           8A  O  2 72DSPATR(HI)
     A                                  6 21'PASSWORD OF TARGET AS/400 IS -
     A                                      WRONG'
     A                                  9 21'OR NOT INPUT, CONFIRM IT'
     A                                 24  9'EXIT'
     A                                 24 15'ENTER'
     A                                      DSPATR(RI)
     A*
     A*
     A          R AJEPW064
     A*%%TS  SD  19961021  152039  AO          REL-V3R0M5  5763-PW1
     A                                      TEXT('THE FOURTH SCREEN')
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 28'** PASS THROUGH MENU **'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 68'FMT AJEPW06'
     A                                  2 63'SYSTEM :'
     A            PSYS           8A  O  2 72DSPATR(HI)
     A                                  6 21'A POWER OF TARGET AS/400 IS N-
     A                                      OT ON'
     A                                  8 21'OR APPNL2 IS NOT ACTIVE.'
     A                                 10 21'CONFIRM IT.'
     A                                 24  9'EXIT'
     A                                 24 15'ENTER'
     A                                      DSPATR(RI)
