      *
     A          R SFL1                      TEXT(' ﾅﾎﾞ､ﾎｦbﾓ')
     A                                      SFL
     A            @DINVO         7A    13  2
     A            @DPALN         4A    13 13
     A            @DSHPD         6Y 0  13 23EDTWRD('  /  /  ')
     A            @DSHPQ         7Y 0  13 32EDTWRD(' ,   ,   ')
     A            @DSYS          6Y 0  13 42EDTWRD('   ,   ')
     A            @DBOX          5Y 0  13 50EDTWRD('  ,   ')
     A            @DDATE         6Y 0  13 57EDTWRD('  /  /  ')
     A            @HANY          4     13 67
     A            @DRDAT         6Y 0  13 72EDTWRD('  /  /  ')
      *
     A            @DBOXN         4Y 0  14 13EDTWRD('    ')
      *
     A          R SREC1                     TEXT(' SFL-CTL')
     A                                      SFLCTL(SFL1)
     A  70                                  SFLDSP SFLDSPCTL
     A  71                                  SFLCLR
     A                                      CF03(03)
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(05) SFLSIZ(05)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
      *
     A                                  1  2'TIME'
     A                                    +1TIME
     A                                  1 22'** ORDER INFORMATION **'
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT'
     A                                    +1'GDGPW82'
     A                                  2  2'DATE'
     A                                    +1DATE EDTCDE(Y)
      *
     A            @TYPE         13      3 12DSPATR(UL)
     A                                  4  2'ORDER NO.'
     A            @ODER1         8      4 12DSPATR(UL)
     A                                  4 21'-'
     A            @ODER2         8      4 23DSPATR(UL)
      *
     A                                  6  2'ORDER NO.'
     A                                      DSPATR(UL)
     A                                  6 13'ITEM NO.'
     A                                      DSPATR(UL)
     A                                  6 22'PARTS NO.    '
     A                                      DSPATR(UL)
     A                                  6 38'    QTY '
     A                                      DSPATR(UL)
     A                                  6 49'UNIT QTY'
     A                                      DSPATR(UL)
     A                                  6 59'  BOX '
     A                                      DSPATR(UL)
     A                                  6 67'CRY'
     A                                      DSPATR(UL)
     A                                  6 71'DELIVERY  '
     A                                      DSPATR(UL)
      *                                      1
     A            @HODR          8      8  2
     A            @HITEM         5Y 0   8 13
     A            @HPART        15      8 22
     A            @HQTY          7Y 0   8 38EDTWRD(' ,   ,   ')
     A            @HSYS          7Y 0   8 48EDTWRD(' ,   ,   ')
     A            @HBOX          5Y 0   8 59EDTWRD('  ,   ')
     A            @HANYK         1      8 68
     A            @DLVR          8Y 0   8 71EDTWRD('  /  /    ')
      *
     A                                 10  2'INVOICE'
     A                                 10 11'PALLETE NO'
     A                                 10 22'DEPARTURE'
     A                                 10 34'SHIPPED'
     A                                 10 43'UNIT'
     A                                 10 51'BOX'
     A                                 10 56'IAF ARRIVAL CARRY RECEIPT'
     A                                 11  2'NO.'
     A                                 11 11'BOX NO'
     A                                 11 23'DATE'
     A                                 11 34'QTY'
     A                                 11 43'QTY'
     A                                 11 57'DATE'
     A                                 11 68'CODE  DATE'
