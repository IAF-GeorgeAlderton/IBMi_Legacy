      ** GDGPW28 *****************************************************
      *  (HANDY) READ CASE MARK                                      *
      *      SEEK                 2023.02.20                         *
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT
      ****************************************************************
      * 画面１                                                     *
      ****************************************************************
     A          R DSP1                      TEXT('画面１')
     A                                      CF03
     A  99                                  ALARM
     A*
     A                                  1  5' CASE MARK '
     A                                      DSPATR(RI)
     A*
     A            D1BAR         17   B  3  3TEXT(' BAR-CODE')
     A                                      DSPATR(CS)
     A                                      CHECK(ER)
     A  31                                  DSPATR(RI PC)
     A*
     A  40                              6  3'** REGISTERED **'
     A                                      COLOR(BLU)
     A  40                              7  5'C/NO='
     A                                      COLOR(WHT)
     A  40        D1CASN         4        +1TEXT(' CASE-NO')
     A                                      COLOR(WHT)
     A  40                              8  5'DATE='
     A                                      COLOR(WHT)
     A  40        D1DATE         8Y 0     +1TEXT(' ISSUE DATE')
     A                                      EDTCDE(W)
     A                                      COLOR(WHT)
     A*
     A                                 10  3'F3=END'
      ****************************************************************
      * エラー画面                                                 *
      ****************************************************************
     A          R DSP99                     TEXT('エラー画面')
     A*
     A                                  1  2'**********************'
     A                                  2  2'**********************'
     A                                  3  2'**********************'
     A                                  4  2'**********************'
     A                                  5  2'*                    *'
     A                                  6  2'*                    *'
     A                                  7  2'*'
     A            D9ERR         18      7  4TEXT('エラーＭＳＧ')
     A                                  7 23'*'
     A                                  8  2'*                    *'
     A                                  9  2'*                    *'
     A                                 10  2'**********************'
     A                                 11  2'**********************'
     A                                 12  2'**********************'
     A                                 13  2'**********************'
     A                                 15  2'ENTER:CONTINUE'
