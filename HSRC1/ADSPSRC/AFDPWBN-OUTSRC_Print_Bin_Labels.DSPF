     A** AFDPWBN *******************************************
     A*  PRINT OUTSOURCE BIN LABELS                        *
     A*                                                    *
     A* LEC   08/10/2021    CREATE                         *
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A          R DSP00
     A                                      OVERLAY
     A                                      CF03
     A                                  1 16' Outsource Bin Labels '
     A                                      DSPATR(RI)
     A                                      COLOR(WHT)
     A                                  4 12'1. Create/Assign New Bin Numbers'
     A                                  5 12'2. Reprint Bin Labels for Existing-
     A                                       Bin Numbers'
     A                                  6 12'3. Deactivate Bin Numbers'
     A                                  7 12'4. Download Bin Data to CSV file'
     A                                  8 12'5. Bin Inquiry'
     A                                 11 15'Selection:'
     A            D@SEL#         1Y 0B 11 27EDTCDE(Z)
     A  32                                  DSPATR(RI)
     A                                      COLOR(WHT)
     A            MSG           50A  O 14  4COLOR(RED)
     A                                 16 14'F3:End'
     A          R DSP01
     A                                      OVERLAY
     A                                      CF05
     A                                      CF12
     A                                  1 16' Print Labels for New Bins '
     A                                      DSPATR(RI)
     A                                      COLOR(WHT)
     A                                  4 12'Number of New Bins'
     A            D@#NEW         3Y 0B  4 31EDTCDE(Z)
     A  31                                  DSPATR(RI)
     A                                      COLOR(WHT)
     A                                  5  6'Number of Labels per Bin'
     A            D@#PER         1Y 0B  5 31EDTCDE(Z)
     A  32                                  DSPATR(RI)
     A                                      COLOR(WHT)
     A            MSG           50   O 10  4COLOR(RED)
     A                                 12 31'F12:Back'
     A                                 12 14'F5:Print'
      *
     A          R DSP02
     A                                      OVERLAY
     A                                      CF05
     A                                      CF12
     A                                  1 16' Reprint Bin Labels '
     A                                      DSPATR(RI)
     A                                      COLOR(WHT)
     A                                  4 16' Bin#'
     A            D@BIN          3A  B  4 23
