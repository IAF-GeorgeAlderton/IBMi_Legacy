      ** GDLPW40 ****************************
      *  MATERIAL ORDER VALIOUS LIST PRINT  *
      *              K.YASUDA   2000.11.20  *
      **************************** GDGPW40 **
     A                                      PRINT
     A                                      CHGINPDFT
      *----------*
      * SCREEN 1 *
      *----------*
     A          R GDLPW401                  CF01
     A                                      BLINK PUTOVR KEEP
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 21'** MATELIALE ORDER VAL -
     A                                      IOUS LIST PRINT **'
     A                                      DSPATR(RI)
     A                                  1 69'FMT GDLPW40'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
      *
     A                                  8 23'1.NON-DELIVERY LIST'
     A                                 10 23'2.ORDER HISTORY LIST'
     A            @NO            1A  B 14 23OVRATR
     A                                      OVRDTA
     A                                      DSPATR(CS)
     A  01                                  DSPATR(RI PC)
     A                                 14 26'<----INPUT MENU NO.'
     A                                 22  8' ERROR '
     A                                      OVRATR
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            MSG           59     22 20OVRATR OVRDTA
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
      *
     A                                 24  5'EXIT'
     A                                 24 13' CMD-1 '
     A                                      DSPATR(RI)
      *----------*
      * SCREEN 2 *
      *----------*
     A          R GDLPW402                  CF03 CF05
     A                                      BLINK PUTOVR KEEP
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 21'** MATELIALE ORDER VAL -
     A                                      IOUS LIST PRINT **'
     A                                      DSPATR(RI)
     A                                  1 69'FMT GDLPW40'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
      *
     A                                  6 22'LIST TYPE'
     A            ILIST         20A  O  6 35OVRATR
     A                                      DSPATR(HI)
      *
     A                                 10 23'SUPPLIER'
     A            ISIRE          4A  B 10 38OVRATR
     A                                      OVRDTA
     A                                      DSPATR(CS)
     A  01                                  DSPATR(RI PC)
      *
     A                                 12 23'WIRE'
     A            IZAIS         15A  B 12 38OVRATR
     A                                      OVRDTA
     A                                      DSPATR(CS)
     A  02                                  DSPATR(RI PC)
      *
     A                                 14 23'WIRE DIAMETER'
     A            IZAIK          5Y 2B 14 38OVRATR
     A                                      OVRDTA
     A                                      EDTWRD('   .  ')
     A                                      DSPATR(CS)
     A  03                                  DSPATR(RI PC)
      *
     A                                 16 23'ORDER NO.'
     A                                 16 38'IAF -'
     A            ISODR          6A  B 16 44OVRATR
     A                                      OVRDTA
     A                                      DSPATR(CS)
     A  04                                  DSPATR(RI PC)
     A                                 16 51'-'
     A                                 16 53'IAF -'
     A            IEODR          6A  B 16 59OVRATR
     A                                      OVRDTA
     A                                      DSPATR(CS)
     A  05                                  DSPATR(RI PC)
     A                                 18 18'ALL DATA IS PRINTED OUT'
     A                                 18 42'IF DATA IS NOT INPUT.'
     A                                 22  8' ERROR '
     A                                      OVRATR
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            MSG           59     22 20OVRATR OVRDTA
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
      *
     A                                 24  5'GO BACK'
     A                                 24 13' CMD-3 '
     A                                      DSPATR(RI)
      *
     A                                 24 25'PRINTING'
     A                                 24 34' CMD-5 '
     A                                      DSPATR(RI)
