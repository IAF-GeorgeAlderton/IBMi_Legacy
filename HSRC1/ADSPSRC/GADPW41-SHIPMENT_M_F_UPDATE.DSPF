     A** GADPW41 ******************************************************
     A* SHIPMENT M/F UPDATE
     A*  KIRI                                            2017.06.28
     A*****************************************************************
     A                                      CHGINPDFT
     A                                      PRINT
      *----------------------------------------------------------------
      * * SCREEN 1*
      *----------------------------------------------------------------
     A          R GADPW411
     A  99                                  ALARM
     A                                      CF01 CF24
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A                                  1 26' ** SHIPMENT M/F UPDATE ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT GADPW411'
     A*
     A                                  9 17'-> 0-CANCEL'
     A                                 10 17'   1-CHANGE'
     A                                 11 17'   2-ADD   '
     A*
     A*
     A                                  5 15'UPDATE'   DSPATR(RI)
     A                                  5 24'CUSTOMER' DSPATR(RI)
     A                                  5 35'DELIVERY' DSPATR(RI)
     A                                  5 46'FACTORY'  DSPATR(RI)
     A                                  5 56'DOCK'     DSPATR(RI)
     A*
     A            D1KKBN         1   B  7 17DSPATR(CS)
     A  21                                  DSPATR(PC RI)
     A            D1TOKU         4A  B  7 26DSPATR(CS)
     A  22                                  DSPATR(PC RI)
     A            D1NONY         4A  B  7 37DSPATR(CS)
     A  23                                  DSPATR(PC RI)
     A            D1NKOJ         1A  B  7 49DSPATR(CS)
     A  24                                  DSPATR(PC RI)
     A            D1NUKE         4A  B  7 56DSPATR(CS)
     A  25                                  DSPATR(PC RI)
     A*
     A                                 15 11'LAST TIME'
     A                                 16 15'UPDATE'   DSPATR(UL)
     A                                 16 24'CUSTOMER' DSPATR(UL)
     A                                 16 34'DELIVERY' DSPATR(UL)
     A                                 16 46'FACTORY'  DSPATR(UL)
     A                                 16 56'DOCK'     DSPATR(UL)
     A            D2KKBN         8     18 15
     A            D2TOKU         4A    18 26
     A            D2NONY         4A    18 36
     A            D2NKOJ         1A    18 49
     A            D2NUKE         4A    18 56
     A*
     A  99                             23 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 23 18
     A*
     A                                 24  5' F1=EXIT '
     A                                      DSPATR(RI)
     A                                 24 65' F24=DOWNLOAD '
     A                                      DSPATR(RI)
      *----------------------------------------------------------------
      * * SCREEN 2*
      *----------------------------------------------------------------
     A          R GADPW412
     A  99                                  ALARM
     A                                      CF03
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A                                  1 26' ** SHIPMENT M/F UPDATE ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT GADPW412'
      *
     A                                  4  6'UPDATE' DSPATR(RI)
     A            D2KKBN         8       + 1
     A                                   + 2'CUSTOMER' DSPATR(RI)
     A            D2TOKU         4A      + 1
     A                                   + 2'DELIVERY' DSPATR(RI)
     A            D2NONY         4A      + 1
     A                                   + 2'FACTORY'  DSPATR(RI)
     A            D2NKOJ         1A      + 1
     A                                   + 2'DOCK'     DSPATR(RI)
     A            D2NUKE         4A      + 1
      *
     A                                  6  8'FACTORY NAME        -
     A                                                '
     A                                      DSPATR(UL)
     A            D2KMEI        30   B  7  8TEXT('FACTORY NAME (KANA)')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  31                                  DSPATR(PC RI)
      *
     A                                  9  8'DELIVERY CYCLE '
     A                                      DSPATR(UL)
     A                                 10  8'(DAY)(BIN)(DLY)'
     A            D2HIZK         2  0B 11  9TEXT('CYCLE (DAY)')
     A                                      EDTCDE(4)
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  32                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D2KAIS         2  0B   + 1TEXT('TIME)')
     A                                      EDTCDE(4)
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  33                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D2NBIN         2  0B   + 1TEXT('BIN)')
     A                                      EDTCDE(4)
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  34                                  DSPATR(PC RI)
      *
     A                                  9 27'DATE OF DELIVERY       -
     A                                                       '
     A                                      DSPATR(UL)
     A                                 10 27'MON.  TUE.  WED.  THU. -
     A                                       FRI.  SAT.  SUN.'
     A            D2YOB1         1   B 11 28TEXT('MONDAY')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  35                                  DSPATR(PC RI)
     A            D2YOB2         1   B   + 5TEXT('TUESDAY  ')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  36                                  DSPATR(PC RI)
     A            D2YOB3         1   B   + 5TEXT('WEDNESDAY  ')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  37                                  DSPATR(PC RI)
     A            D2YOB4         1   B   + 5TEXT('THURSDAY  ')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  38                                  DSPATR(PC RI)
     A            D2YOB5         1   B   + 5TEXT('FRIDAY  ')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  39                                  DSPATR(PC RI)
     A            D2YOB6         1   B   + 5TEXT('SATURDAY  ')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  40                                  DSPATR(PC RI)
     A            D2YOB7         1   B   + 5TEXT('SUNDAY  ')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  41                                  DSPATR(PC RI)
      *
     A                                 13  8'SUPPLIER'
     A                                   + 4'SUPPLIER'
     A                                   + 4'PROVISION POINT'
     A                                   + 4'CARRIER SET UP CALLED'
     A                                      DSPATR(UL)
     A                                 14  8'  CODE  '
     A                                      DSPATR(UL)
     A                                 14 20'FACTORY '
     A                                      DSPATR(UL)
     A                                 14 32'     CODE     '
     A                                      DSPATR(UL)
     A*
     A            D2SIRE         4   B 15 10TEXT('SUPPLIER CODE')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  42                                  DSPATR(PC RI)
     A            D2SMEI         1   B 15 23TEXT('FACTORY CODE')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  43                                  DSPATR(PC RI)
     A            D2SKYU         4   B 15 37TEXT('PROVISION POINT COD  E')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  44                                  DSPATR(PC RI)
     A            D2CSUC         1   B 15 53TEXT('CARRIER SET UP')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  45                                  DSPATR(PC RI)
     A*
     A                                 15 56'0- DAY OF'
     A                                 16 56'1- 1 DAY BEFORE'
     A                                 17 56'2- 2 DAY BEFORE'
     A                                 18 56'3- OTHER(SPECIFY)'
     A                                 19 56'4- MILKRUN AUTOMATIC'
     A                                 20 56'5- IAF CALLS'
     A*
      *
      * ERROR
      *
     A  99                             23 11'ERROR' DSPATR(RI BL)
     A  99        D2ERR         60A  O 23 18
     A*
     A                                 24  5' F3=RETURN '
     A                                      DSPATR(RI)
     A                                 24 20' ENTER=CONTINUE '
     A                                      DSPATR(RI)
      *----------------------------------------------------------------
      * * SCREEN 3*  サブファイル
      *----------------------------------------------------------------
     A          R GADPW413
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A                                  1 26' ** SHIPMENT M/F UPDATE ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT GADPW413'
      *
     A                                  4  6'UPDATE' DSPATR(RI)
     A            D2KKBN         8       + 1
     A                                   + 2'CUSTOMER' DSPATR(RI)
     A            D2TOKU         4A      + 1
     A                                   + 2'DELIVERY' DSPATR(RI)
     A            D2NONY         4A      + 1
     A                                   + 2'FACTORY'  DSPATR(RI)
     A            D2NKOJ         1A      + 1
     A                                   + 2'DOCK'     DSPATR(RI)
     A            D2NUKE         4A      + 1
      *
     A                                  5 21'DELIVERY CYCLE ' DSPATR(RI)
     A            D3CYCL         8       + 1TEXT('CYCLE')
      *
     A          R SFREC1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ')
     A                                      SFL
      *
     A                                  6  4'-----'
     A            S1BIN          2  0    + 1TEXT('BIN')
     A                                      EDTCDE(4)
     A                                   + 1'BIN -----------------+
     A                                      ----------------------+
     A                                      --------------------'
     A                                  7 06'SHIPMENT ADJUST DAY'
     A                                   + 5'SHIPPING #'
     A                                   + 5'TRANSPORTATION CODE'
     A            S1NSPD         2  0B  8 14TEXT('N SHIPMENT ADJ. DAY')
     A                                      EDTCDE(4)
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  51                                  DSPATR(PC RI)
     A            S1NSHP         3   B  8 33TEXT('N SHIPPING #')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  52                                  DSPATR(PC RI)
     A            S1NCAR         2   B  8 46TEXT('N CARRIER')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  53                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            S1NRUT         4   B   + 1TEXT('N ROUTE')
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  54                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            S1NBIN         2  0B   + 1TEXT('N BIN #')
     A                                      EDTCDE(4)
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  55                                  DSPATR(PC RI)
     A*
     A                                  9  6'OLD--->'
     A            S1OSPD         2  0   9 14TEXT('O SHIPMENT ADJ. DAY')
     A                                      EDTCDE(4)
     A            S1OSHP         3      9 33TEXT('O SHIPPING #')
     A*
     A            S1OCAR         2      9 46TEXT('N CARRIER')
     A                                   + 1'-'
     A            S1ORUT         4       + 1TEXT('N ROUTE')
     A                                   + 1'-'
     A            S1OBIN         2  0    + 1TEXT('N BIN #')
     A                                      EDTCDE(4)
     A                                 10  2' '
      *
     A          R SFCTL1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ ﾃ]nﾜｰﾓ')
     A                                      SFLCTL(SFREC1)
     A                                      OVERLAY PROTECT
     A                                      CF03 CF05
     A  71                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  73                                  SFLCLR
     A                                      SFLPAG(3) SFLSIZ(4)
     A                                      ROLLUP(75)
     A                                      ROLLDOWN(76)
     A            DSPRRN         4  0H      SFLRCDNBR(CURSOR)
      **
     A                                 21  6'CHANGE OVER DATE-
     A                                      (SHIPMENT DAY)'
     A            D3CHDT         8  0B 22 11TEXT('CHANGE OVER DATE')
     A                                      EDTCDE(4)
     A N29                                  DSPATR(CS)
     A  29                                  DSPATR(PR)
     A  58                                  DSPATR(PC RI)
     A*
      * ERROR
      *
     A  99                             23 11'ERROR' DSPATR(RI BL)
     A  99        D3ERR         60A  O 23 18
     A*
     A                                 24  5' F3=RETURN '
     A                                      DSPATR(RI)
     A                                   + 5' F5=UPDATE '
     A                                      DSPATR(RI)
     A                                 24 65'PAGE DOWN/UP'
     A                                      DSPATR(RI)
