     A** IIKPW32 ***********************************
     A*受注と出荷照合                          *
     A*     KATOGI.        2016.03.18              *
     A**********************************************
      *
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R IIKPW321
     A                                      CF01(01)
     A                                      CF05(05)
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** ORDER DATA <--> SHIPPED +
     A                                       DATA ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT IIKPW32'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                 10 18'DELIVERY DATE'
     A                                      DSPATR(RI)
     A            D1NOH1         8Y 0B 10 36DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                   + 2'-'
     A            D1NOH2         8Y 0B   + 2DSPATR(CS)
     A  32                                  DSPATR(RI PC)
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'EXIT'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'CREATE'
