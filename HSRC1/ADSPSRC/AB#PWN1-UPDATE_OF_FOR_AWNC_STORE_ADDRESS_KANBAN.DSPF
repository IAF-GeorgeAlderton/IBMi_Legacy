     A** AB#PWN1 ******************************************************
     A* UPDATE OF FOR AWNC : STORE ADDRESS , KANBAN
     A*
     A*  KIRI 15.08.07
     A*****************************************************************
     A                                      CHGINPDFT
     A                                      PRINT
      *-------------------------------------
     A          R DSP01
     A                                      CF01 CF12
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20' ** FOR AWNC :-
     A                                       STORE ADDRESS , KANBAN ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT AB#PWN1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  5 22'UPDATE'   DSPATR(UL)
     A                                  5 32'   USER PARTS NO    '
     A                                      DSPATR(UL)
     A*
     A            D1KBN          1A  B  7 24DSPATR(CS)
     A  21                                  DSPATR(PC RI)
     A*
     A            D1MHN         20   B  7 32DSPATR(CS)
     A  22                                  DSPATR(PC RI)
     A*
     A                                 10 24'0- CANCEL '
     A                                 11 24'1- CHANGE '
     A                                 12 24'2- ADD    '
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
     A*
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
     A                                 24 66' F12 ' DSPATR(RI)
     A                                   + 1'INQUIRY'
      *-------------------------------------
      *-------------------------------------
     A          R DSP02
     A                                      CF03 CF05
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20' ** FOR AWNC :-
     A                                       STORE ADDRESS , KANBAN ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT AB#PWN1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  5 22'UPDATE'   DSPATR(UL)
     A                                  5 32'   USER PARTS NO    '
     A                                      DSPATR(UL)
     A*
     A            D2KBN          8      7 22
     A*
     A            D1MHN         20      7 32
     A*
     A*
     A                                 11 32' STORE ADDRESS '
     A                                      DSPATR(UL)
     A                                 11 52'KANBAN'
     A                                      DSPATR(UL)
     A            D2ADDR        15   B 13 32
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A  31                                  DSPATR(PC RI)
     A*
     A            D2SBAN         5   B 13 52
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A  32                                  DSPATR(PC RI)
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D2ERR         60A  O 22 18
     A*
     A                                 24  4' F3 ' DSPATR(RI)
     A                                   + 1'PREV. SCREEN'
     A                                   + 4' F5 ' DSPATR(RI)
     A                                   + 1'UPDATE OK'
     A*-------------------------------------
     A*-------------------------------------
