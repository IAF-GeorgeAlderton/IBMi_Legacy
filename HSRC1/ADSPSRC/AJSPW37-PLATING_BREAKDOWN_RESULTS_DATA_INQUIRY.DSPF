     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT(*LIBL/QPRINT)
     A          R AJSPW371
     A                                      TEXT('SCREEN 1')
     A                                      CF01
     A                                      BLINK
     A                                      PUTOVR
     A                                      KEEP
     A  99                                  ALARM
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 18'DACRODIZING PLATING BREAKDOWN -
     A                                      RESULT DATA INQUIRY'
     A                                      DSPATR(RI)
     A                                  1 68'FMT'
     A                                  1 72'AJSPW37'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  7 30'BREAKDOWN CODE.'
     A                                      DSPATR(UL)
     A            COD            4Y 0B  9 31DSPATR(CS) EDTCDE(Z)
     A                                      OVRDTA
     A                                      OVRATR
     A  01                                  DSPATR(PC)
     A  01                                  DSPATR(RI)
     A                                  9 38'<---9999:ALL DATA'
     A                                 12 30'BREAKDOWN DATE START'
     A                                      DSPATR(UL)
     A            SHIZ           8Y 0B 14 33DSPATR(CS)
     A                                      EDTCDE(4)
     A                                      OVRDTA
     A                                      OVRATR
     A  02                                  DSPATR(PC)
     A  02                                  DSPATR(RI)
     A                                 14 50' -'
     A                                 12 55'BREAKDOWN DATE EXIT'
     A                                      DSPATR(UL)
     A            EHIZ           8Y 0B 14 58DSPATR(CS)
     A                                      EDTCDE(4)
     A                                      OVRDTA
     A                                      OVRATR
     A  03                                  DSPATR(PC)
     A  03                                  DSPATR(RI)
     A                                 22 11'ERROR'
     A                                      OVRATR
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A            ERR           60A  O 22 18OVRATR
     A                                      OVRDTA
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A  99                                  DSPATR(BL)
     A                                 24  3'EXIT'
     A                                 24  9'CMD-1'
     A                                      DSPATR(RI)
     A*
     A*
     A          R DSP2R                     TEXT('SUBFILE')
     A                                      SFL
     A            @CODE          4Y 0   5  2
     A            @BTIM          4Y 0   5  7
     A            @BRHZ          8Y 0   5 17EDTWRD('    /  /  ')
     A            @BRTM          6Y 0   5 28EDTWRD('  :  :  ')
     A            @REHZ          8Y 0   5 39EDTWRD('    /  /  ')
     A            @RETM          6Y 0   5 51EDTWRD('  :  :  ')
     A            @BRNA         20      5 60
     A* <DISPLAY FIELD > THAT A FIELD NECESSARY FOR SCREEN 2 IS APPOINTED
     A            #CODE          4Y 0H
     A            #BTIM          4Y 0H
     A            #BRHZ          8Y 0H
     A            #BRTM          6Y 0H
     A            #REHZ          8Y 0H
     A            #RETM          6Y 0H
     A            #BRNA         20   H
     A*
     A*
     A          R DSP2C                     TEXT('SUBFILE CONTROL')
     A                                      SFLCTL(DSP2R)
     A                                      CF03 BLINK
     A                                      PUTOVR KEEP
     A  99                                  ALARM
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(15) SFLSIZ(16)
     A  91                                  SFLDSP SFLDSPCTL SFLEND
     A  92                                  SFLCLR
     A  93                                  SFLINZ
     A                                      ROLLUP(81)
     A  99                                  SFLMSG('NO MORE DATA' 99)
     A            RCDNBR         4  0H      SFLRCDNBR
     A                                  1  2'TIME'
     A                                    +1TIME
     A                                  1 18'DACRODIZING PLATING BREAKDOWN -
     A                                       RESULT DATA INQUIRY'
     A                                      DSPATR(RI)
     A                                  1 68'FMT'
     A                                    +1'AJSPW37'
     A                                  2  2'DATE'
     A                                    +1DATE EDTCDE(Y)
     A*
     A                                  2 18'BREAKDOWN CODE'
     A                                      DSPATR(UL)
     A            COD            4Y 0   2 33OVRDTA
     A                                  2 41'ADMIT DATE'
     A                                      DSPATR(UL)
GBCUPA            SHIZ           8Y 0   2 52EDTWRD('    /  /  ')
     A                                      OVRDTA
     A                                  2 63' -'
GBCUPA            EHIZ           8Y 0   2 68EDTWRD('    /  /  ')
     A*
     A                                  3  2'BREAKDOWN'
     A                                  3 16'BREAKDOWN GENERATION'
     A                                  3 44'RECOVERY'
     A                                  3 61'BREAKDOWN'
     A                                  4  2'CODE TIME        DATE      TIME -
     A                                              DATE       TIME-
     A                                           CONTENT            '
     A                                      DSPATR(UL)
     A*
     A          R DSP2X                     TEXT('COMMAND EXPLANATION')
     A                                      PUTOVR KEEP
     A*
