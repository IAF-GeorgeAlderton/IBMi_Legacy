     A** INVPW1B ***********************************
     A* UPDATE OF INVENTORY FILE                   *
     A*          KIRI             15.06.09         *
     A*********************************** INVPW1B **
     A                                      CHGINPDFT
     A                                      PRINT
      *-------------------------------------
     A          R DSP01
     A                                      CF01
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** UPDATE OF -
     A                                      PART SCAN FILE ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT INVPW1B'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  7 25'DATE'
     A            D1DATE         8   B   + 1TEXT('DATE')
     A                                      DSPATR(CS)
     A  11                                  DSPATR(PC RI)
     A*
     A                                 10 24'PART#'
     A            D1SHN1         5   B   + 1TEXT('PART#1')
     A                                      DSPATR(CS)
     A  12                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1SHN2         5   B   + 1TEXT('PART#2')
     A                                      DSPATR(CS)
     A  12                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1SHN3         2   B   + 1TEXT('PART#3')
     A                                      DSPATR(CS)
     A  12                                  DSPATR(PC RI)
     A*
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
     A*
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
      *-------------------------------------
      *---------------------------------------*
      *  サブファイル定義                   *
      *---------------------------------------*
     A          R SFREC1
     A                                      SFL
     A            S1SEL          1   B  5  4DSPATR(CS)
     A  21                                  DSPATR(PC RI)
     A            S1DATE         8  0    + 2TEXT('DATE')
     A                                      EDTWRD('    .  .  ')
     A            S1TIME         6  0    + 2TEXT('TIME')
     A                                      EDTWRD('  :  :  ')
     A            S1SHN1         5       + 2TEXT('PART#1')
     A                                   + 1'-'
     A            S1SHN2         5       + 1TEXT('2')
     A                                   + 1'-'
     A            S1SHN3         2       + 1TEXT('3')
     A            S1KANS         3  0    + 6TEXT('# OF KANBAN')
      *---------------------------------------*
      *  サブファイル制御　                 *
      *---------------------------------------*
     A          R SFCTL1
     A                                      CF03(03)
     A                                      SFLCTL(SFREC1)
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(16)
     A                                      SFLSIZ(17)
     A                                      ROLLUP(75)
     A                                      ROLLDOWN(75)
     A  70                                  SFLDSPCTL
     A  71                                  SFLDSP
     A  72                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A            RRN1           4  0H      SFLRCDNBR
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** UPDATE OF -
     A                                      INVENTORY FILE ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT INVPW1B'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  4  7'   DATE   '
     A                                      DSPATR(UL)
     A                                   + 2'  TIME  ' DSPATR(UL)
     A                                   + 2'     PART#        '
     A                                      DSPATR(UL)
     A                                   + 2'# OF KANBAN'
     A                                      DSPATR(UL)
      *
     A          R DSP02
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
     A                                 24  4' F3 '  DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 7' PAGE UP/DOWN '
     A                                      DSPATR(RI)
      *-------------------------------------
     A          R DSP03
     A                                      CF03 CF05
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** UPDATE OF -
     A                                      INVENTORY FILE ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT INVPW1B'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
      *
     A                                  7 25'DATE'
     A            D2DATE         8  0    + 2TEXT('DATE')
     A                                      EDTWRD('    .  .  ')
     A                                  9 25'TIME'
     A            D2TIME         6  0    + 2TEXT('TIME')
     A                                      EDTWRD('  :  :  ')
      *
     A                                 11 24'PART#'
     A            D2SHN1         5       + 2TEXT('PART#1')
     A                                   + 1'-'
     A            D2SHN2         5       + 1TEXT('PART#2')
     A                                   + 1'-'
     A            D2SHN3         2       + 1TEXT('PART#3')
      *
     A                                 13 18'# OF KANBAN'
     A            D2KANS         3  0B   + 2TEXT('# OF KANBAN')
     A                                      DSPATR(CS) EDTCDE(4)
     A  31                                  DSPATR(PC RI)
      *
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
      *
     A                                 24  4' F3 ' DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 4' F5 ' DSPATR(RI)
     A                                   + 1'UPDATE OK'
      *-------------------------------------
      *-------------------------------------
     A*-------------------------------------
