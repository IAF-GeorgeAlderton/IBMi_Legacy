     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  24                                  DSPATR(PC RI)
     A            D2NUK5         2   B   + 2
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  25                                  DSPATR(PC RI)
     A            D2NUK6         2   B   + 2
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  26                                  DSPATR(PC RI)
     A            D2NUK7         2   B   + 2
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  27                                  DSPATR(PC RI)
     A            D2NUK8         2   B   + 2
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  28                                  DSPATR(PC RI)
     A            D2NUK9         2   B   + 2
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  29                                  DSPATR(PC RI)
     A            D2KIHZ         8  0B 13 67TEXT('CHANGE DATE')
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A                                      EDTCDE(4)
     A  30                                  DSPATR(PC RI)
