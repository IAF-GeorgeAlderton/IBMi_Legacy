     A** AL#PWG0 ***********************
     A* UPDATE CUSTOMER PER TRUCK M/F  *
     A*  KIRI            2016.08.12    *
     A*********************** AL#PWG0 **
     A                                      PRINT
     A                                      CHGINPDFT
      *-------------------------------------
     A          R DSP01
     A                                      CF01 CF12
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A*
     A                                  1 24'** UPDATE OF -
     A                                      CUSTOMER PER TRUCK M/F **'
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'AL#PWG0'
      *
     A                                  5 16'UPDATE'    DSPATR(UL)
     A                                   + 4' TRUCK # ' DSPATR(UL)
     A                                   + 2'CUST.' DSPATR(UL)
     A                                   + 2'DELIV.' DSPATR(UL)
     A***                                + 2'FACT' DSPATR(UL)
      *
     A            D1KKBN         1   B  7 18DSPATR(CS)
     A  11                                  DSPATR(PC RI)
     A            D1SURT         9   B  7 26TEXT('SUB ROUTE')
     A                                      DSPATR(CS)
     A  12                                  DSPATR(PC RI)
     A            D1TOKU         4  0O   + 2TEXT('COSTOMER CODE')
     A                                      EDTCDE(4)
     A  13                                  DSPATR(PC RI)
     A            D1NONY         4  0B   + 4TEXT('DELIVERY CODE')
     A                                      DSPATR(CS) EDTCDE(4)
     A  14                                  DSPATR(PC RI)
     A            D1NKOJ         1   O   + 4TEXT('DELIVERY FACTORY')
     A  15                                  DSPATR(PC RI)
      *
     A                                 10 18'0- CANCEL '
     A                                 11 18'1- CHANGE '
     A                                 12 18'2- ADD    '
      *
     A  99                             23  2' ERR ' DSPATR(RI)
     A  99        D1ERR         60A  O 23  8DSPATR(HI)
      *
     A                                 24  2' F1 ' DSPATR(RI)
     A                                   + 1'END'
     A                                   + 2' F12 ' DSPATR(RI)
     A                                   + 1'TRUCK# INQ.'
      *-------------------------------------
      *-------------------------------------
     A          R DSP02
     A                                      CF03 CF05
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A*
     A                                  1 24'** UPDATE OF -
     A                                      CUSTOMER PER TRUCK M/F **'
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'AL#PWG0'
      *
     A                                  5 13' UPDATE  '  DSPATR(UL)
     A                                   + 4' TRUCK # ' DSPATR(UL)
     A                                   + 2'CUST.' DSPATR(UL)
     A                                   + 2'DELIV.' DSPATR(UL)
     A                                   + 2'FACT' DSPATR(UL)
      *
     A            D1KKBN         1      6 14
     A            D2KKBN         6       + 1
     A            D1SURT         9      6 26TEXT('SUB ROUTE')
     A            D1TOKU         4  0    + 2TEXT('COSTOMER CODE')
     A            D1NONY         4  0    + 4TEXT('DELIVERY CODE')
     A            D1NKOJ         1   O   + 4TEXT('DELIVERY FACTORY')
      *
     A                                 11 12'DOCK    '    DSPATR(UL)
     A                                 11 66'CHANGE DATE' DSPATR(UL)
     A*
     A            D2NUK1         2   B 13 14
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
     A  21                                  DSPATR(PC RI)
     A            D2NUK2         2   B   + 2
     A N18                                  DSPATR(CS)
     A  18                                  DSPATR(PR)
