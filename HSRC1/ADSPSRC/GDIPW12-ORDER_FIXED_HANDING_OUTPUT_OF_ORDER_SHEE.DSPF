      *** GDIPW12 ****************************************************
      *    ORDER FIXED HANDING / OUTPUT OF ORDER SHEET
      *     G.B.C                                97/04/10
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS)
     A**************
     A* ＤＳＰ１ *
     A**************
     A          R DSP01                     CF01 CF05
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 26' ISSUING OF ORDER SHEET '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW12'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  7  8'ISSUING THE ORDER SHEET.'
     A                                 11  8' ORDER NO. '
     A                                      DSPATR(RI)
     A                                   + 1'----> IAF -'
     A            D1ODR1         2Y 0B   + 1EDTCDE(4)
     A  11                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1ODR2         2Y 0B   + 1EDTCDE(4)
     A  12                                  DSPATR(RI)
     A                                   + 1'-'
     A            D1ODR3         2Y 0B   + 1EDTCDE(4)
     A  13                                  DSPATR(RI)
     A*
     A                                 22 10' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 19
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24  9'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 35'INPUT OK'
     A                                   + 1' CMD-5 '
     A                                      DSPATR(RI)
