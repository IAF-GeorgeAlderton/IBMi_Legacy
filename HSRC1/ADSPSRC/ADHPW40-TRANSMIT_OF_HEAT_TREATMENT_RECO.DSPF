     A********************************************* ADHPW40 ***
     A                                      PRINT
     A                                      CHGINPDFT
     A*
     A          R ADHPW401                  CF01(01) CF05(05)
     A  99                                  ALARM
     A                                      BLINK
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 19'TRANSMIT OF HEAT TREATMENT CHARG+
     A                                      ING RECORD'
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'ADHPW40'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  /  /  ')
     A*
     A                                 10 14'HEAT TREATMENT CHARGING RECORD WIL+
     A                                      L TRANSMIT TO AS/400'
     A                                      DSPATR(UL)
     A                                 22 11' ERR '
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            ERR           60O    22 17
     A N99                                  DSPATR(ND)
     A                                 24  2' E N D '
     A                                 24 12' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 22'TRANSMIT'
     A                                 24 34' CMD-5 '
     A                                      DSPATR(RI)
