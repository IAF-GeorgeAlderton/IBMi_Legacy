     A*%%TS  SD  20030512  140936  TEST        REL-V4R4M0  5769-PW1
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF05
     A                                      CF01
     A          R DSP01
     A*%%TS  SD  20030512  140936  TEST        REL-V4R4M0  5769-PW1
     A            #PGM           8A  O  1  2
     A                                  1 23'** SUMMARIZE INPUT ORDER DATA **'
     A                                      DSPATR(RI)
     A                                  2 31'<< MATERIAL >>'
     A                                      DSPATR(RI)
     A                                  1 63DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A                                  9 35'Last summarized date:'
     A            D@DATE         8Y 0O  9 57EDTWRD('    /  /  ')
     A            D@TIME         6Y 0O 10 57EDTWRD('  :  :  ')
     A                                  6 21'SUPPLIER CODE:'
     A            D@SUPL         4A  B  6 36DSPATR(CS)
     A  61                                  DSPATR(RI)
     A  61                                  DSPATR(PC)
     A                                  6 42'0002=AMC'
     A                                 23  3'F1:END       F5:SUMMARIZE'
     A            D@MSG         78   O 24  2DSPATR(HI)
     A          R DSPWN
     A*%%TS  SD  20020516  142523  TEST        REL-V4R4M0  5769-PW1
     A                                      WINDOW(5 10 10 50)
     A                                      WDWBORDER((*COLOR BLU) (*DSPATR RI)-
     A                                       (*CHAR '...:::.:'))
     A                                  2  9'** MATERIAL ORDER PROCESSING  **'
     A                                      DSPATR(RI)
     A                                  5  5'Somebody is using the same file.'
     A                                      DSPATR(HI)
     A                                      DSPATR(RI)
     A                                  6  5'Please ask him to close the progra-
     A                                      m.'
     A                                      DSPATR(HI)
     A                                      DSPATR(RI)
     A                                  7  5'Then hit Enter key.'
     A                                      DSPATR(HI)
     A                                      DSPATR(RI)
     A                                  9 17'ENTER:Continue'
