      ******************** MYCPW00 **
     A                                      PRINT
     A                                      CHGINPDFT
      *
      **********
      * 画面 *
      **********
     A          R MYCPW001                  TEXT('SCREEN')
     A                                      KEEP
      *
     A                                      CF01
      *
     A                                  1 23'   THE EQUIPMENT LOAD -
     A                                      CHART MENU   '
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT MYCPW00'
      *
      *
     A                                  3  3' DATA MAKING '
     A                                      COLOR(PNK) DSPATR(RI)
      *
     A                                  5  3' 10 '
     A                                      DSPATR(RI)
     A                                    +2'EQUIPMENT LOAD CHART <NO.3>'
     A                                  7  3' 20 '
     A                                      DSPATR(RI)
     A                                    +2'EQUIPMENT LOAD CHART <NEW>'
     A                                  9  3' 30 '
     A                                      DSPATR(RI)
     A                                    +2'HEAT-TREATMENT EQUIPMENT'
     A                                 10 10'LOAD CHART <NEW>'
      *
      *
     A                                  3 43' MASTER RENEWAL '
     A                                      COLOR(BLU) DSPATR(RI)
      *
     A                                  5 43' 51 '
     A                                      DSPATR(RI)
     A                                    +2'MORE THAN ONE PLANE TURN'
     A                                  6 50'RATIO MASTER'
     A                                  8 43' 52 '
     A                                      DSPATR(RI)
     A                                    +2'THE STOCK NUMBER ANOTHER'
     A                                  9 50'NUMBER OF RORATIONS MASTER'
      *
      *
     A            IMENO          2Y 0B 20  4DSPATR(CS) EDTCDE(Z)
     A  51                                  DSPATR(RI PC)
     A                                    +2'--> PLEASE INPUT THE MENU NO.'
      *
      *
     A  99                             22  2' ERROR '
     A                                      DSPATR(RI BL)
     A  99        MSG           70A  O    +1
      *
     A                                 24  4'EXIT'
     A                                    +2' F1 ' DSPATR(RI)
