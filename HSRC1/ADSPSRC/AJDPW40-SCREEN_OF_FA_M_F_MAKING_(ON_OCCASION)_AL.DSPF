     A                                      PRINT
     A          R AJDPW401
     A*%%TS  SD  19961016  154313  NIWA        REL-V3R0M5  5763-PW1
     A                                      CF01(01) CF05(05)
     A                                      OVERLAY
     A                                      BLINK
     A                                      PUTOVR
     A                                      KEEP
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25'* FA M/F MAKING (ON OCCASION) +
     A                                        ALL DATA'
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                  1 73'AJSPW40'
