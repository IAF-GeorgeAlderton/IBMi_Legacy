     A** AGFPW10 ******************************************************
     A* ORDER ACCUMULATION DATA INQURIRY
     A* KIRI  15/07/09
     A*****************************************************************
     A                                      CHGINPDFT
     A                                      PRINT
     A*
     A          R DSP01
     A                                      CF01
     A                                      CF05
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20' ORDER ACCUMULATION DATA -
     A                                      INQUIRY (PRODUCT)'
     A                                      DSPATR(RI UL)
     A                                  1 71'AGFPW10'
     A                                  2  2'DATE'
     A                                  2  7DATE  EDTWRD('0  .  .  ')
     A*
     A                                  6 20'INPUT SELECT ORDER DATE -
     A                                      FOR CREATE DOWNLOAD DATA'
     A            D1KARA         8Y 0B  8 25EDTCDE(4)
     A                                      DSPATR(CS)
     A  11                                  DSPATR(PC RI)
     A                                   + 1'-'
     A                                      DSPATR(HI)
     A            D1MADE         8Y 0B   + 1EDTCDE(4)
     A                                      DSPATR(CS)
     A  12                                  DSPATR(PC RI)
     A                                   + 4'(YYYYMMDD)'
      **
     A                                 10 20'INPUT PARTS NO.'
     A            D1HIN1         5A  B 12 25DSPATR(CS)
     A  13                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1HIN2         5A  B   + 1DSPATR(CS)
     A  13                                  DSPATR(RI)
     A                                   + 1'-'
     A            D1HIN3         2A  B   + 1DSPATR(CS)
     A  13                                  DSPATR(RI)
      **
     A                                 14 20'INPUT SUPPLIER CODE'
     A            D1SUPP         4A  B 16 25DSPATR(CS)
     A  14                                  DSPATR(PC RI)
      **
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
      **
     A                                 24  4'F1:END'
     A                                   + 8'F5:CREATE'
     A*--------------------------------------
