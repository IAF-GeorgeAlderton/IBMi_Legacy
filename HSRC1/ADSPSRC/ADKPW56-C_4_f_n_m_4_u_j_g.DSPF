     A          R ADKPW560
     A                                      CF01(01)
     A                                      CF12(12)
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** OVER LIMIT PROCESS MASTER ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT ADKPW56'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A            D0UPD          1A  B  4 17DSPATR(CS)
     A  29                                  DSPATR(RI PC)
     A                                  4 20'0 : DELETE  1 : CHANGE'
     A                                   + 2'2 : ADDNEW'
      *
     A            D0CODE         1A  B  6 17DSPATR(CS)
     A  30                                  DSPATR(RI PC)
     A                                  6 20'CODE'
     A                                  7 20'1 : PROCESS(BY MACHINE.NO)'
     A                                  8 20'2 : PROCESS + MACHINE.NO'
      *
     A            D0GROP         2A  B 10 17DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                 10 20'GROUP CODE'
      *
     A  99                             22 11' ERR '
     A                                      DSPATR(RI)
     A                                      DSPATR(BL)
     A            D0ERR         60O       +2
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A                                 24  7'EXIT'
     A                                   + 1' F1 '
     A                                      DSPATR(RI)
     A                                   + 2'NEXT'
     A                                   + 1' ENTER '
     A                                      DSPATR(RI)
     A                                 24 68'INQ'
     A                                   + 1' F12 '
     A                                      DSPATR(RI)
     A          R ADKPW561
     A                                      CF03(03)
     A                                      CF05(05)
