      *
     A                                  6 10'1 : PROCESS(BY MACHINE.NO)'
     A                                  7 12'GROUP CODE' DSPATR(RI)
     A            D0GROP         2A     7 24
     A                                  9 12'PROCESS' DSPATR(RI)
     A            D1PRC1         3A  B  9 24DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A                                 11 12'GROUP NAME' DSPATR(RI)
     A            D0NAME        20A  B 11 24DSPATR(CS)
