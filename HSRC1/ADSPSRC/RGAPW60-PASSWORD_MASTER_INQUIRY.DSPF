      ****************************************************** RGAPW60 **
     A                                      PRINT
     A                                      CHGINPDFT
      *
     A          R DSP01
     A                                      CF01
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 23' PASSWORD MASTER INQUIRY '
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT RGAPW60'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  6 19'検索文字'
     A                                      DSPATR(RI)
     A            D1KENS        36O  B  6 31DSPATR(CS)
     A  31                                  DSPATR(RI PC)
      *
      *
     A  99                             23 11' d[ｰ ' DSPATR(RI BL)
     A  99        D1ERR         60   O 23 18
      *
     A                                 24  2' F1 ' DSPATR(RI)
     A                                   + 1'終了'
      *-------------------------------------
      *-------------------------------------
      *-------------------------------------
     A          R SFREC1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ')
     A                                      SFL
     A            S1SEL          1   B  6 02TEXT('選択№')
     A                                      DSPATR(ND)
     A            S1PROF        10       + 1TEXT('ﾎﾟﾜﾎb-ﾓ')
     A            S1NAME        15       + 1TEXT('ﾏ-ﾅﾞ- xb')
     A            S1SHNO        10A      + 1TEXT('社員№')
     A            S1NAM1        36       + 1TEXT('人事Ｆ名称')
     A            S1NAM2        36   H      TEXT('人事Ｆ名称２')
      *-------------------------------------
     A          R SFCTL1
     A  99                                  ALARM
     A                                      SFLCTL(SFREC1)
     A                                      CF01 CF03
     A                                      BLINK
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(15) SFLSIZ(16)
     A                                      ROLLUP(75)
     A                                      ROLLDOWN(75)
     A  71                                  SFLDSP SFLDSPCTL
     A  72                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      SFLCSRRRN(&RRNCSR)
     A            RRN1           4  0H      SFLRCDNBR
     A            RRNCSR         5S 0H
      *
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 23'＊　パスワードマスター-
     A                                      　検索照会　＊'
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT RGAPW60'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
      *
     A                                  3 22'検索文字'
     A            D1KENS        36O      + 1DSPATR(UL)
      *
      *
     A                                  5  2'  ﾎﾟﾜﾎｧｰﾓ  -
     A                                        ﾏ-ﾅﾞ- xb    -
     A                                         社員№   -
     A                                       人事Ｆ名称 -
     A                                                              '
     A                                      DSPATR(UL)
      *-------------------------------------
     A          R DSP02
      *
     A  99                             23 11' d[ｰ ' DSPATR(RI BL)
     A  99        D2ERR         60   O 23 18
      *
     A                                 24  2'終了'
     A                                   + 1' F1 ' DSPATR(RI)
     A                                   + 4'戻る'
     A                                   + 1' F3 ' DSPATR(RI)
