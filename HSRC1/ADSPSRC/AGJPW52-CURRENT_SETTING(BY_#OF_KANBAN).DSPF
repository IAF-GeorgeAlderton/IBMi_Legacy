     A** AGJPW52 ***********************************
     A* CURRENT SETTING(BY #OF KANBAN)
     A*    SAKAKI.        2020.01.07               *
     A**********************************************
     A                                      PRINT
     A                                      CHGINPDFT
      *------------------------*
      *                        *
      *------------------------*
     A          R SFL                       SFL
     A            S1NAME        10A     6  2
     A            S1TOTL         5Y 0   6 15EDTWRD('   0 ')
     A            S1GRP1         5Y 0   6 21EDTWRD('   0 ')
     A            S1GRP2         5Y 0   6 27EDTWRD('   0 ')
     A            S1GRP3         5Y 0   6 33EDTWRD('   0 ')
     A            S1GRP4         5Y 0   6 39EDTWRD('   0 ')
     A            S1GRP5         5Y 0   6 45EDTWRD('   0 ')
     A            S1GRP6         5Y 0   6 51EDTWRD('   0 ')
     A            S1GRP7         5Y 0   6 57EDTWRD('   0 ')
     A            S1GRP8         5Y 0   6 63EDTWRD('   0 ')
     A            S1GRP9         5Y 0   6 69EDTWRD('   0 ')
     A            S1GRPA         5Y 0   6 75EDTWRD('   0 ')
      *非表示項目
     A            @RRN           4Y 0H
      *
      *---------------------------------------*
      *  サブファイル制御　                 *
      *---------------------------------------*
     A          R SFLCTL
     A                                      SFLCTL(SFL)
     A  72                                  SFLDSPCTL
     A  72                                  ERASE(SFL)
     A  73                                  SFLDSP
     A  71                                  SFLCLR
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(10)
     A                                      SFLSIZ(10)
     A                                      CF03(03)
     A                                      CF12(12)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3  0H
     A            S@SCLM         3  0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22' ** CURRENT SETTING(BY #OF +
     A                                       KANBAN) ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AGJPW52'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4 21'GROUP GROUP GROUP GROUP +
     A                                       GROUP GROUP GROUP GROUP +
     A                                       GROUP GROUP'
     A                                  5 14' TOTAL     1     2     3     +
     A                                       4     5     6     7     8     +
     A                                       9 OTHER'
     A                                      DSPATR(UL)
     A          R AGJPW529
     A                                      OVERLAY PROTECT
     A N81                             16 72'MORE...'
     A  81                             16 72'LAST...'
      *
     A                                 17  7'*** CONDITION ***'
     A                                 18 10' UNIT : # OF BOX / DAY'
     A                                 19 10' FORMULA : CALC SETTING #'
     A                                   + 1' / QPC. / 20'
     A                                 21 10'PRODUCTION : OWN LOCATION'
     A                                   + 1'IS "G" "K" "Z" "X" ONLY.'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D9ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2'F12'
     A                                      DSPATR(RI)
     A                                   + 1'GROUP M/F INQ'
     A                                   +10'PAGE UP'
     A                                   + 1'PRV'
     A                                      DSPATR(RI)
     A                                   + 2'PAGE DOWN '
     A                                   + 1'NEXT'
     A                                      DSPATR(RI)
