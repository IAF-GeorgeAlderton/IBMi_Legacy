     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 21' RESTRICTION QUANTITY -
     A                                      ON TAKING OUT DIE '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT ECSPW902'
     A*
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A*
     A                                  5 24' UPDATE '
     A                                      DSPATR(RI UL)
     A*
     A            D#UPKB         1A  O  7 27TEXT(' UPDATE ')
     A                                      DSPATR(UL HI)
     A            D#UPNM         6A  O  7 30TEXT(' UPDATE NAME ')
     A                                      DSPATR(HI)
     A*
     A                                 10 24' DIE NUMBER '
     A                                      DSPATR(RI UL)
     A*
     A            D#KAT1         2A  O 12 27TEXT(' DIE NUMBER 1 ')
     A                                      DSPATR(UL HI)
     A                                 12 30'-'
     A            D#KAT2         4A  O 12 32TEXT(' DIE NUMBER 2 ')
     A                                      DSPATR(UL HI)
     A                                 12 37'-'
     A            D#KAT3         1A  O 12 39TEXT(' DIE NUMBER 3 ')
     A                                      DSPATR(UL HI)
     A                                 12 41'-'
     A            D#KAT4         1A  O 12 43TEXT(' DIE NUMBER 4 ')
     A                                      DSPATR(UL HI)
     A*
     A                                 14 24' RESTRICTION QUANTITY '
     A                                      DSPATR(RI UL)
     A*
     A            D#REQT         3Y 0B 16 27TEXT(' RESTRICTION QTY ')
     A                                      CHECK(RB)
     A                                      EDTWRD(' 0 ')
     A  51                                  DSPATR(PR UL HI)
     A N51                                  DSPATR(CS)
     A  36                                  DSPATR(PC RI)
     A*
     A*
     A  99                             23 10' ERROR '
     A                                      DSPATR(RI BL)
