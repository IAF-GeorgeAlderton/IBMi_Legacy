     A****************************************** ECSPW90 **
     A                                      PRINT
     A                                      CHGINPDFT
     A*===================================================*
     A*         SCREEN-1                                  *
     A*===================================================*
     A          R ECSPW901
     A                                      CF01(01)
     A                                      CF12(12)
     A                                      BLINK
     A                                      KEEP
     A  99                                  ALARM
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 21' RESTRICTION QUANTITY -
     A                                      ON TAKING OUT DIE '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT ECSPW901'
     A*
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A*
     A                                  5 24' UPDATE '
     A                                      DSPATR(RI UL)
     A*
     A            D#UPKB         1A  B  7 27TEXT(' UPDATE ')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                  7 29'<--- 0:CANCEL 1:CHANGE 2:ADD'
     A*
     A                                 10 24' DIE NUMBER '
     A                                      DSPATR(RI UL)
     A*
     A            D#KAT1         2A  B 12 27TEXT(' DIE NUMBER 1 ')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(PC RI)
     A                                 12 30'-'
     A            D#KAT2         4A  B 12 32TEXT(' DIE NUMBER 2 ')
     A                                      DSPATR(CS)
     A  33                                  DSPATR(PC RI)
     A                                 12 37'-'
     A            D#KAT3         1A  B 12 39TEXT(' DIE NUMBER 3 ')
     A                                      DSPATR(CS)
     A  34                                  DSPATR(PC RI)
     A                                 12 41'-'
     A            D#KAT4         1A  B 12 43TEXT(' DIE NUMBER 4 ')
     A                                      DSPATR(CS)
     A  35                                  DSPATR(PC RI)
     A*
     A*
     A  99                             23 10' ERROR '
     A                                      DSPATR(RI BL)
     A  99        D#EMSG        60O  O 23 19
     A*
     A                                 24  4'EXIT'
     A                                 24 10' F1 '
     A                                      DSPATR(RI)
     A                                 24 65'INQUIRY'
     A                                 24 74' F12 '
     A                                      DSPATR(RI)
     A*
