     A*%%TS  SD  20190619  143509  I0777       REL-V7R3M0  5770-WDS
     A** FBCPW47 ******************************************************
     A*  TOYOTA NAME CODE INQUIRY                                     *
     A*****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*---------------------------------------*
     A          R SFL01                     SFL
     A*%%TS  SD  20190619  140904  I0777       REL-V7R3M0  5770-WDS
     A            S1SEL          1A  B  5  3DSPATR(ND)
     A            S1SHP1         5A  O  5  5TEXT('NAME CODE')
     A                                      COLOR(WHT)
     A            S1SHP2         1A  O  5 20TEXT('SEQ#')
     A            S1TOKU         4A  O  5 24TEXT('CUST#')
     A            S1NONY         4A  O  5 30TEXT('DELIV#')
     A                                      COLOR(YLW)
     A            S1KMEI        25A  O  5 36TEXT('CUSTOMER NAME')
     A                                      COLOR(WHT)
     A*---------------------------------------*
     A          R CTL01                     SFLCTL(SFL01)
     A*%%TS  SD  20190619  143509  I0777       REL-V7R3M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      CF03(03)
     A                                      OVERLAY
     A                                      PROTECT
     A  70                                  SFLDSPCTL
     A  71                                  SFLDSP
     A  72                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      ROLLUP(73)
     A                                      ROLLDOWN(73)
     A                                      SFLCSRRRN(&$RRN)
     A            RRN1           4S 0H      SFLRCDNBR
     A            $RRN           5S 0H
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20'** TOYOTA NAME CODE INQUIRY **'
     A                                      DSPATR(RI)
     A                                  1 68'FMT FBCPW47'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  4  3'TOYOTA NAME CD'
     A                                      DSPATR(UL)
     A                                  4 19'SEQ'
     A                                      DSPATR(UL)
     A                                  4 24'CUST#'
     A                                      DSPATR(UL)
     A                                  4 30'IAF DELIVERY CODE & NAME       '
     A                                      DSPATR(UL)
      *
     A          R DSP01
     A                                 24  2' F3 '  DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 7' PAGE UP/DOWN '
     A                                      DSPATR(RI)
