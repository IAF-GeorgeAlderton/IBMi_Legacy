     A* AJAPWF1 **********************************
     A* めっき投入実績EXCEL転送              *
     A*                          94.02.22        *
     A********************************************
     A                                      CHGINPDFT
     A                                      PRINT
      *
     A          R DSP01
     A  99                                  ALARM
     A                                      CF01
     A                                      CF05
     A                                  1  2'DATE'
     A                                  1  9DATE
     A                                      EDTCDE(Y)
     A                                  1 20'めっき投入実績-
     A                                      EXCEL転送'
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT AJSPWF1'
     A                                  2  2'TIME'
     A                                  2  9TIME
     A                                      EDTCDE(Y)
      *
     A                                 10 17'YEAR MONTH'
     A            @STYY          4  0B   + 1DSPATR(CS) EDTCDE(4)
     A  11                                  DSPATR(RI)
     A            @STMM          2  0B   + 1DSPATR(CS) EDTCDE(4)
     A  12                                  DSPATR(RI)
     A                                   + 1' - '
     A            @EDYY          4  0B   + 1DSPATR(CS) EDTCDE(4)
     A  13                                  DSPATR(RI)
     A            @EDMM          2  0B   + 1DSPATR(CS) EDTCDE(4)
     A  14                                  DSPATR(RI)
      *
     A  99                             22 11'ERROR' DSPATR(BL RI)
     A  99        @ERR          60A  O 22 18
     A*
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
     A                                   + 4' F5 ' DSPATR(RI)
     A                                   + 1'START'
