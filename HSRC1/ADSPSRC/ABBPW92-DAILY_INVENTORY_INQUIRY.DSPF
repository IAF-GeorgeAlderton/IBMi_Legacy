     A** ABBPW92 ***********************************
     A* DAILY INVENTORY INQUIRY
     A*     SAKAKI.         2019.10.14             *
     A**********************************************
      *
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R ABBPW921
     A                                      CF01(01)
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 24' ** DAILY INVENTORY +
     A                                       INQUIRY ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT ABBPW92'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                 10 28'DATE'
     A                                      DSPATR(RI)
     A            D1CR1          8Y 0B 10 36DSPATR(CS) EDTCDE(Z)
     A  31                                  DSPATR(RI PC)
     A                                   + 2'-'
     A            D1CR2          8Y 0B   + 2DSPATR(CS) EDTCDE(Z)
     A  32                                  DSPATR(RI PC)
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'EXIT'
