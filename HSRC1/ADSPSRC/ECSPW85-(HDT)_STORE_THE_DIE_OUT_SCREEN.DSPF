     A**** ECSPW85 ****************************************
     A*  (HDT) STORE THE DIE OUT SCREEN                   *
     A*          2017.06.05  ITS.  T.MITSUI               *
     A************************************** ECSPW85 ******
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF01(01) CF02(02) CF03(03)
     A                                      CF04(04) CF05(05) CF06(06)
     A                                      CF07(07) CF08(08) CF09(09)
     A                                      CF10(10) CF11(11) CF12(12)
     A                                      CF13(13) CF14(14) CF15(15)
     A                                      CF16(16) CF17(17) CF18(18)
     A                                      CF19(19) CF20(20) CF21(21)
     A                                      CF22(22) CF23(23) CF24(24)
     A*
     A*===================================================*
     A*      1. READING REQUESTER                         *
     A*===================================================*
     A          R ECSPW851
     A  99                                  ALARM
     A*
     A                                  1  2' STORE OUT (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' WS/ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2 12TEXT(' WORKER ')
     A*
     A                                  4  2'OPERATOR'
     A            D#1BAR        10A  B  5  2TEXT(' OPERATOR  ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      2. READING MACHINE                           *
     A*===================================================*
     A          R ECSPW852
     A  99                                  ALARM
     A*
     A                                  1  2' STORE OUT (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2 12TEXT(' WORKER ')
     A*
     A                                  4  2'MACHINE BARCODE'
     A            D#2BAR         4A  B  5  2TEXT(' MACHINE ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A                                  7  2'OPERATOR'
     A            D#RQNM        10A  O  7 12TEXT(' OPERATOR  ')
     A                                      DSPATR(UL)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      3. READING REASON                            *
     A*===================================================*
     A          R ECSPW853
     A  99                                  ALARM
     A*
     A                                  1  2' STORE OUT (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2 12TEXT(' WORKER ')
     A*
     A                                  4  2'REASON FOR GOODS ISSUE'
     A            D#3BAR         2A  B  5  2TEXT(' REASON ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A                                  7  2'REQUESTER'
     A            D#RQNM        10A  O  7 12TEXT(' REQUESTER ')
     A                                      DSPATR(UL)
     A*
     A                                  8  2'MACHINE NO.'
     A            D#KIBN         3A  O  8 14TEXT(' MACHINE ')
     A                                      DSPATR(UL)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      4. READING DIE LOCATION                      *
     A*===================================================*
     A          R ECSPW854
     A  99                                  ALARM
     A*
     A                                  1  2' STORE OUT (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2 12TEXT(' WORKER ')
     A*
     A                                  4  2'LOCATION BARCODE'
     A            D#4BAR        16A  B  5  2TEXT(' DIE LOCATION ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A                                  7  2'REQUESTER'
     A            D#RQNM        10A  O  7 12TEXT(' REQUESTER ')
     A                                      DSPATR(UL)
     A*
     A                                  8  2'MACHINE NO.'
     A            D#KIBN         3A  O  8 14TEXT(' MACHINE ')
     A                                      DSPATR(UL)
     A*
     A                                  9  2'REASON'
     A            D#RINM        17A  O  9  9TEXT(' REASON ')
     A                                      DSPATR(UL)
     A*
     A*
     A                                 16  2'F1 BACK'
     A*
     A*===================================================*
     A*      5. READING DIE STORE LABEL                   *
     A*===================================================*
     A          R ECSPW855
     A  99                                  ALARM
     A*
     A                                  1  2' STORE OUT (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2 12TEXT(' WORKER ')
     A*
     A                                  4  2'STORE OUT LABEL'
     A            D#5BAR        15A  B  5  2TEXT(' DIE STORE LABEL ')
     A                                      AUTO(RA)
     A                                      DSPATR(CS)
     A*
     A                                  7  2'OPERATOR'
     A            D#RQNM        10A  O  7 12TEXT(' OPERATOR  ')
     A                                      DSPATR(UL)
     A*
     A                                  8  2'MACHINE NO.'
     A            D#KIBN         3A  O  8 14TEXT(' MACHINE ')
     A                                      DSPATR(UL)
     A*
     A                                  9  2'REASON'
     A            D#RINM        17A  O  9  9TEXT(' REASON ')
     A                                      DSPATR(UL)
     A*
     A                                 10  2'DIE PART NO.'
     A            D#KAT@        11A  O 10 15TEXT(' DIE NUMBER ')
     A                                      DSPATR(UL)
     A*
     A                                 11  2'LOCATION'
     A            D#LOC@        11A  O 11 15TEXT(' DIE LOCATION ')
     A                                      DSPATR(UL)
     A*
     A                                 13  2'READ COUNT'
     A            D#MAI          4  0O   + 1EDTCDE(3)
     A                                   + 1'SHEETS'
     A*
     A                                 15  2'F1 OPERATOR'
     A                                   + 1'F2 MACHIN NO'
     A                                 16  2'F3 REASON  '
     A                                   + 1'F4 LOCATION'
     A*
     A*===================================================*
     A*      6. WARNING                                   *
     A*===================================================*
     A          R ECSPW856
     A  99                                  ALARM
     A*
     A                                  1  2' STORE OUT (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2 12TEXT(' WORKER ')
     A*
     A            D#TXT1        20A  O  4  2DSPATR(UL)
     A            D#TXT2        20A  O  6  2DSPATR(UL)
     A            D#TXT3        20A  O  8  2DSPATR(UL)
     A            D#TXT4        20A  O 10  2DSPATR(UL)
     A*
     A                                 15  2'F1 BACK'
     A                                   + 1'F7 CONTINUE'
     A*
     A*===================================================*
     A*      9. DISPLAY ERROR MESSAGE                     *
     A*===================================================*
     A          R ECSPW859
     A  99                                  ALARM
     A*
     A                                  1  2' STORE IN (DIE) '
     A                                      DSPATR(RI UL)
     A            D#WSID         5A  O  1 20TEXT(' W/S ID ')
     A*
     A                                  2  2'WORKER'
     A            D#TANM        10A  O  2  9TEXT(' WORKER ')
     A*
     A                                  5  5'***          ***'
     A                                  6  5'  ***      ***  '
     A                                  7  5'    ***  ***    '
     A                                  8  5'      ****      '
     A                                  9  5'    ***  ***    '
     A                                 10  5'  ***      ***  '
     A                                 11  5'***          ***'
     A*
     A            D#EMSG        25A  O 15  1TEXT(' MESSAGE ')
     A                                      DSPATR(RI)
     A*
     A                                 16  2'F1 BACK'
     A  81                             16 12'F7 CONTINUE'
     A*
