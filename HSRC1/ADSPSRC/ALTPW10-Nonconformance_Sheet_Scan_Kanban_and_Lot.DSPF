     A  99        MSG           60A  O 11  3
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A                                 13  4'F3:Back'
     A                                      DSPATR(RI)
     A                                  3  2'<< Scan Kanban QR Code >>'
     A            F1BARC       400A  B  5  1COLOR(WHT)
     A*
     A          R FMT200
     A                                      OVERLAY
     A                                  1  4' NON-CONFORMANCE SHEET '
     A                                      DSPATR(RI)
     A            @@PROC         8A  O  2  9DSPATR(RI)
