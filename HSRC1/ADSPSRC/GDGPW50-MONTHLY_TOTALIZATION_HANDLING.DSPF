      *** GDGPW50 <DSPF> ***************************************
      *    MONTHLY TOTALIZATION HANDLING
      *      G.B.C                         97/03/06
      **********************************************************
     A                                      PRINT
     A**************
     A* DSP01
     A**************
     A          R DSP01                     CF01(01) CF05(05)
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 20' MONTHLY AGGREGATION -
     A                                      TREATMENT '
     A                                      DSPATR(RI)
     A                                    +1'(PRODUCTS)'
     A                                  1 69'FMT GDGPW50'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A*
     A                                  7 17'EXECUTING MONTHLY AGGREG-
     A                                      ATION TREATMENT.'
     A                                      DSPATR(HI)
     A                                  9 31'DATE'
     A            D1YYMM         6Y 0B 10 30CHECK(RB) EDTCDE(4)
     A  11                                  DSPATR(PC RI)
     A                                 10 38'(YYYYMM)'
     A*
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 20
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24 11'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 34'INPUT OK'
     A                                   + 1' CMD-5 '
     A                                      DSPATR(RI)
