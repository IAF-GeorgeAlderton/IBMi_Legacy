      **** GTBPW13 <DSPF> ********************************************
      * ACZ CHANGE CARRY CODE SHIP > AIR
      *       G.B.C                         2003.11.28
      *
      * TCHK  10/08/12 CREATE(COPY FROM GDGPW13)
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS)
     A**************
     A* SFL01
     A**************
     A          R SFREC1                    SFL
     A            S1CHG          1   B  6  3TEXT('CHG')
     A  11                                  DSPATR(RI PC)
     A            S1HIN         14      6  6TEXT('PART NO.')
     A            S1SURY         9  0   6 22TEXT('QTY')
     A                                      EDTCDE(2)
     A            S1SYOS         7  0   6 35TEXT('QTY/BOX')
     A                                      EDTCDE(2)
     A            S1MAIS         5  0   6 46TEXT('BOX')
     A                                      EDTCDE(2)
     A            S1SHIP         5  0   6 54TEXT('SHIP/BOX')
     A                                      EDTCDE(2)
     A            S1AIR          5  0   6 62TEXT('AIR/BOX')
     A                                      EDTCDE(2)
     A            S1DLVR         8  0   6 70TEXT('DELIVERY')
     A                                      EDTWRD('  .  .    ')
     A            S1ZETI         4   H      TEXT('IAF PART ID NO')
     A            S1SEIH         1   H      TEXT('PART CODE')
     A**************
     A* CTL01
     A**************
     A          R SFCTL                     SFLCTL(SFREC1)
     A                                      CF01
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(13) SFLSIZ(14)
     A  81                                  SFLDSP
     A  82                                  SFLDSPCTL
     A  83                                  SFLCLR
     A            RRN            4  0H      SFLRCDNBR
     A*
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 25' ACZ CHANGE CARRY CODE-
     A                                       SHIP / AIR '
     A                                      DSPATR(RI)
     A                                  1 69'FMT GTBPW13'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A*
     A                                  3 25' ORDER NO. '
     A                                      DSPATR(RI)
     A            D1ODR0         3       + 1
     A                                   + 1'-'
     A            D1ODR1         2  0    + 1EDTCDE(4)
     A                                   + 1'-'
     A            D1ODR2         2  0    + 1EDTCDE(4)
     A                                   + 1'-'
     A            D1ODR3         2       + 1
     A*
     A                                  5  2'CHG  PARTS NO.        -
     A                                            QTY    QTY/BOX -
     A                                      ALL BOX    SHIP     AIR-
     A                                          DELIVERY'
     A                                      DSPATR(HI UL)
     A*         1         2         3         4         5         6
     A*123456789012345678901234567890123456789012345678901234567890
     A* CHG  PARTS NO.              QTY    QTY/BOX     BOX
     A*  X  XXXXX-XXXXX-XX  999,999,999  9,999,999  99,999
     A*         5         6         7         8
     A*1234567890123456789012345678901234567890
     A*        BOX    SHIP     AIR    DELIVERY
     A*     99,999  99,999  99,999  99.99.9999
     A*
     A**************
     A* DSP01
     A**************
     A          R DSP01
     A                                 19  3'|'
     A                                 20  3'+------> INPUT "1" TO-
     A                                       CHANGE.'
     A  99                             22 10' ERROR ' DSPATR(RI BL)
     A  99        D#MSG         60     22 19DSPATR(BL)
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'EXIT'
     A                                 24 60' PAGE U/D '
     A                                      DSPATR(RI)
     A                                   + 1'ROLL U/D'
     A*
     A**************
     A* DSP02
     A**************
     A          R DSP02
     A                                      CF03 CF05
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 25' ACZ CHANGE CARRY CODE-
     A                                       SHIP / AIR '
     A                                      DSPATR(RI)
     A                                  1 69'FMT GDGPW13'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A*
     A                                  3 25' ORDER NO. '
     A                                      DSPATR(RI)
     A            D1ODR0         3       + 1
     A                                   + 1'-'
     A            D1ODR1         2  0    + 1EDTCDE(4)
     A                                   + 1'-'
     A            D1ODR2         2  0    + 1EDTCDE(4)
     A                                   + 1'-'
     A            D1ODR3         2       + 1
     A*
     A                                  6 14'    PART NO.    '
     A                                      DSPATR(HI UL)
     A                                  6 32'   ALL QTY   '
     A                                      DSPATR(HI UL)
     A                                  6 47' ALL BOX'
     A                                      DSPATR(HI UL)
     A                                  6 57'  QTY/BOX  '
     A                                      DSPATR(HI UL)
     A*
     A            D2HIN         14      8 15TEXT('PART NO.')
     A            D2SURY         9  0   8 33TEXT('QTY')
     A                                      EDTCDE(2)
     A            D2MAIS         5  0   8 48TEXT('BOX')
     A                                      EDTCDE(2)
     A            D2SYOS         7  0   8 58TEXT('QTY/BOX')
     A                                      EDTCDE(2)
     A*
     A                                 11 30'     SHIP/BOX'
     A                                      DSPATR(HI)
     A                                 13 30'      AIR/BOX'
     A                                      DSPATR(HI)
     A                                 15 30'DELIVERY DATE'
     A                                      DSPATR(HI)
     A*
     A            D2SHIP         5  0  11 46TEXT('SHIP/BOX')
     A                                      EDTCDE(2)
     A**21                                  DSPATR(RI PC)
     A            D2AIR          5  0B 13 46TEXT('AIR/BOX')
     A                                      EDTCDE(2)
     A  22                                  DSPATR(RI PC)
     A            D2DLMM         2  0B 15 46TEXT('DELIVERY')
     A                                      EDTCDE(4)
     A  23                                  DSPATR(RI PC)
     A                                 15 49'.'
     A            D2DLDD         2  0B 15 51TEXT('DELIVERY')
     A                                      EDTCDE(4)
     A  23                                  DSPATR(RI PC)
     A                                 15 54'.'
     A            D2DLYY         4  0B 15 56TEXT('DELIVERY')
     A                                      EDTCDE(4)
     A  23                                  DSPATR(RI PC)
     A                                 16 46'MM   DD   YYYY'
     A*
     A*
     A  99                             22 10' ERROR ' DSPATR(RI BL)
     A  99        D#MSG         60     22 19DSPATR(BL)
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 4' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'INPUT'
     A*
      ***********************************************
      * POP WINDOW                                  *
      ***********************************************
     A          R W1
     A                                      OVERLAY
      * A:START LINE  B:START COLUMN
      * C:LINE WITHIN WINDOW  D:COLUMN WITHIN WINDOW
      *                                            A  B  C   D
     A                                      WINDOW(6 21  10  35)
     A                                      WDWBORDER((*DSPATR RI HI) (*CHAR ' -
     A                                             '))
     A                                      RMVWDW
     A                                      USRRSTDSP
     A                                      WDWTITLE((*TEXT '          '))
      *
     A          R DSP09
     A                                      OVERLAY PROTECT
     A                                      WINDOW(W1)
     A                                      CF03(03)
     A                                      CF05(05)
      *
     A                                  4  2'PLEASE CONFIRM AIR FRIGHT'
     A                                  9  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'OK'
