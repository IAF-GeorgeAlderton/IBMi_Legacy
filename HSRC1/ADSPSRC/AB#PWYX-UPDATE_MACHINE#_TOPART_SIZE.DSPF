     A** AB#PWYX ***********************************
     A*     Y.SAMEJIMA 2015.06.08                  *
     A**********************************************
     A                                      PRINT
     A                                      CHGINPDFT
      *
     A          R AB#PWYX1
     A                                      CF01(01)
     A                                      CF12(12)
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' UPDATE MACHINE# TO+
     A                                       PART SIZE       '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AB#PWYX'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  7  3'CODE'
     A                                      DSPATR(RI)
     A                                  7 19'NACHINE#'
      *
     A            @KOSN          1A  B  9  7DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A            @MCN#          3A  B  9 19DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A                                 11  7'0 :DELETE'
     A                                 12  7'1 :CHANGE'
     A                                 13  7'2 :ADD   '
      *
     A                                 23  2'ERR'
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            @ERR          60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'END   '
     A                                 24 67' F12 '
     A                                      DSPATR(RI)
     A                                   + 1'SHOW  '
      *
     A          R AB#PWYX2
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** UPDATE MACHINE# TO+
     A                                        PART SIZE#    ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AB#PWYX'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4  3'MACHINE#'
     A                                      DSPATR(RI)
     A            @MCN#          3A     4 14
     A                                  8 30'PART SIZE'
     A            @SIZE          1A  B 10 30DSPATR(CS)
     A  33                                  DSPATR(RI)
     A                                 10 35'1:M6' DSPATR(HI)
     A                                 11 35'2:M8' DSPATR(HI)
     A                                 12 35'3:M10' DSPATR(HI)
     A                                 13 35'4:NUT' DSPATR(HI)
     A                                 14 35'5:TS ' DSPATR(HI)
      *
     A                                 23  2'ERR'
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            @ERR          60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'UPDATE'
