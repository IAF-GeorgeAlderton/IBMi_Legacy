     A*** AM#PW08 ******************************************
     A* PASSWORD CHECK FOR ACTIVE CHECK                    *
     A*     T.SAKAKI      2015.10.15                       *
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R DSP01
     A                                  1 10' ***WARNING!*** '
     A                                      DSPATR(RI)
     A                                  3  3'THIS TERMINAL WAS'
     A                                  4  3'ABNORMAL END AT THE LAST TIME.'
     A                                  5  3'THE INFO. IS AS BELOW.'
     A*
     A                                  7  3'<DATE>'
     A            D1ONDT        10A  O    +2
     A                                  8  3'<TIME>'
     A            D1ONHH         2A  O  8 11
     A                                  8 14':'
     A            D1ONMM         2A     8 16
     A                                  8 19':'
     A            D1ONSS         2A     8 21
     A*
     A                                  9  3'<PROCESS>'
     A            D1PGNM        20A  O 10  5
     A                                 11  3'<WORKER>'
     A            D1WKNM        20A  O 12  5
     A*
     A                                 14  3'PASSWORD'
     A                                      DSPATR(HI)
     A            D1WKCD         6Y 0B    +2DSPATR(ND) CHECK(ER)
