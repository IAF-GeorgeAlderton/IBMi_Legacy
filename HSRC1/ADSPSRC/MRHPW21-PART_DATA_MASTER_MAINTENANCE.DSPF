     A                                      PRINT(*LIBL/QPRINT)
     **==============================================================**
     **  画面１（ＤＳＰ０１）
     **==============================================================**
     A          R MRHPW211
     A*<<キーワード定義>>
     A                                      CF01(01 '終了')
     A                                      OVERLAY
     A*<<カーソル制御用>>
     A                                      RTNCSRLOC(&D1RCD  &D1FLD)
     A                                      CSRLOC(D1LIN D1COL)
     A            D1LIN          3S 0H      TEXT('fｰﾓ制御（行）')
     A            D1COL          3S 0H      TEXT('fｰﾓ制御（桁）')
     A            D1RCD         10A  H      TEXT('ﾛﾃｰnﾞ')
     A            D1FLD         10A  H      TEXT('ﾎｧｰﾓnﾞID')
     A*<<フィールド定義>>
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 21'***  PART.PROCESS MASTER +
     A                                       MAINTENANCE  ***'
     A                                      DSPATR(HI RI)
     A                                  1 69'FMT MRHPW21'
      *
     A                                  2  2'DATE'
     A            D1SYMD         8Y 0O  2  7EDTWRD('0 /  /    ')
     A*<<入出力項目>>
     A                                  4 28'PART MASTER MAINTENANCE'
     A                                  6 12'-------------------------------+
     A                                       -------------------------'
      *
     A                                  8 30'INHOUSE PART NUMBER'
     A            D1SELC         1A  B 10 20TEXT('更新区分')
     A                                      DSPATR(CS)
     A  41                                  DSPATR(RI PC)
     A            D1SHN1         5A  B 10 30TEXT('社内品番１')
     A                                      DSPATR(CS)
     A  42                                  DSPATR(RI)
     A  43                                  DSPATR(PC)
     A                                 10 37'-'
     A            D1SHN2         5A  B 10 39TEXT('社内品番２')
     A                                      DSPATR(CS)
     A  44                                  DSPATR(RI PC)
     A                                 10 46'-'
     A            D1SHN3         2A  B 10 48TEXT('社内品番３')
     A                                      DSPATR(CS)
     A  45                                  DSPATR(RI PC)
      *
     A                                 12 20'0:DELETE'
     A                                 13 20'1:CHANGE'
     A                                 14 20'2:ADD'
     A*<<メッセージ>>
     A                                 22 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1EMSG        53O    22 18TEXT('d[ｰxｮﾈｰﾆﾞ')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*<<ファンクション>>
     A                                 24  9'EXIT'
     A                                 24 15'CMD-1'
     A                                      DSPATR(RI)
     A                                 24 32'NEXT SCREEN'
     A                                 24 45'ENTER'
     A                                      DSPATR(RI)
