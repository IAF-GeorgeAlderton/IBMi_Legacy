     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A*
     A                                  1 24'** UPDATE OF -
     A                                      CUSTOMER PER TRUCK M/F **'
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'AL#PWG0'
      *
     A                                  5 16'UPDATE'    DSPATR(UL)
     A                                   + 2'STARTING DATE' DSPATR(UL)
     A                                   + 2' TRUCK # ' DSPATR(UL)
     A                                   + 2' CUST.' DSPATR(UL)
     A                                   + 2' DELIV.' DSPATR(UL)
