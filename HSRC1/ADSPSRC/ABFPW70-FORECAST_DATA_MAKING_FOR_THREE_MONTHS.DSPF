     A*** ABFPW70 **********************************************
     A*   FORECAST DATA MAKING FOR THREE MONTHS                *
     A*      MSK......             2005.08.10                  *
     A******************************************** ABFPW70 *****
     A                                      PRINT(QPRINT)
     A                                      CHGINPDFT
      *
     A          R ABFPW701
     A                                      CF01(01)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                   + 1TIME  EDTWRD('  :  :  ')
     A                                  1 22'  FORECAST DATA MAKING FOR THREE M-
     A                                      ONTHS  '
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                   + 1'ABFPW70'
     A                                  2  2'DATE'
     A            @DATE          6Y 0    + 1EDTWRD('0  .  .  ')
      *
     A                                  5 25'PLEASE INPUT THIS MONTH'
     A                                      DSPATR(UL)
     A            @HYM           6Y 0B  7 32EDTCDE(4) DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                  8 31'(YYYYMM)'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            @ERR          72     23  8
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A                                 24  2' F1=EXIT '
     A                                      DSPATR(RI)
      *
     A          R ABFPW702
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                   + 1TIME  EDTWRD('  :  :  ')
     A                                  1 22'  FORECAST DATA MAKING FOR THREE M-
     A                                      ONTHS  '
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                   + 1'ABFPW70'
     A                                  2  2'DATE'
      *
     A                                  7 15'MONTH'
     A                                      DSPATR(UL)
     A            @1N            2Y 0   7 32EDTCDE(Z)
     A            @2N            2Y 0   7 38EDTCDE(Z)
     A            @3N            2Y 0   7 44EDTCDE(Z)
      *
     A                                  9 15'WORKING DAYS'
     A                                      DSPATR(UL)
     A            @1NS           3Y 1B  9 30EDTWRD('0 . ')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A            @2NS           3Y 1B  9 36EDTWRD('0 . ')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            @3NS           3Y 1B  9 42EDTWRD('0 . ')
     A                                      DSPATR(CS)
     A  33                                  DSPATR(RI PC)
      *
     A            @1NSB          3Y 1  11 30EDTWRD('0 . ')
     A            @2NSB          3Y 1  11 36EDTWRD('0 . ')
     A            @3NSB          3Y 1  11 42EDTWRD('0 . ')
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            @ERR          72     23  8
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A                                 24  2' F3=BACK '
     A                                      DSPATR(RI)
     A                                 24 15' F5=OK '
     A                                      DSPATR(RI)
