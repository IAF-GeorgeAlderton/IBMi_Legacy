     A*%%TS  SD  20020130  121528  TEST        REL-V4R4M0  5769-PW1
     A** AB#PWFX *******************************************
     A* FORD ACCUMULATED QTY RESET                         *
     A*                2001.08.02                          *
     A******************************************* AB#PWFX **
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A*---------------------------------------------------------------
     A          R DSP01
     A*%%TS  SD  20011009  153536  TEST        REL-V3R7M0  5716-PW1
     A                                      CF01(01)
     A                                      CF05(05)
     A                                      OVERLAY
     A            #PGM           8A  O  1  2
     A                                  1 16'* RESET ACCUMULATED QTY OF FORD OR-
     A                                      DER DATA *'
     A                                      DSPATR(RI)
     A                                  1 63DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A**                                                               HE ACC-
     A            D@OPT          1A  B 10 14DSPATR(UL)
     A                                    +2'<--- SELECT OPTION'
     A                                      DSPATR(HI)
     A**                                                               HE ACC-
     A                                  5 13' 1 '
     A                                      DSPATR(RI)
     A                                    +2' JANUARY 1ST'
     A                                    +1' 12/31 OR 1/1 '
     A                                      DSPATR(HI)
     A                                  7 13' 2 '
     A                                      DSPATR(RI)
     A                                    +2' AUGUST 1ST'
     A                                  7 32' ONLY 8/1 '
     A                                      DSPATR(HI)
     A**                                                               HE ACC-
     A                                 15 10'THIS PROCESS IS TO RESET THE ACC-
     A                                      UMULATED QTY WITH ZERO'
     A                                      DSPATR(HI)
     A                                 17 10'PLEASE MAKE SURE THAT IT IS THE RI-
     A                                      GHT TIME FOR REPLACEMENT.'
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A                                 13 10'CURRENT DATE'
     A                                      DSPATR(HI)
     A                                    +3DATE
     A                                      EDTCDE(Y)
     A                                      DSPATR(HI)
     A  99        D@MSG         50   O 21 10
     A  99                                  COLOR(PNK)
     A                                 23  7' F1 '
     A                                      DSPATR(RI)
     A                                    +2'END'
     A                                 23 25' F5 '
     A                                      DSPATR(RI)
     A                                    +2'UPDATE'
