     A*****************************************************************
     A* INQUIRY                                                         *
     A*
     A*  KIRI 2019.08.06
     A*****************************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
      *---------------------------------------*
      *
      *---------------------------------------*
     A          R DSP01
     A                                      CF01
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20'* PRIORITY KANBAN INQ. (SEPARATE B-
     A                                      Y GROUP) *'
     A                                      DSPATR(RI)
     A                                  1 68'FMT ABBPW7N'
     A                                  2  2'DATE'
     A                                  2  7DATE
      *
     A                                  4 30'DATE:'
     A                                      DSPATR(HI)
     A            D@YMD          6Y 0B  4 36EDTCDE(4)
     A                                      DSPATR(CS)
     A  61                                  DSPATR(RI)
     A  61                                  DSPATR(PC)
     A                                  5 36'YYMMDD'
     A                                  7 30'SHIFT....:'
     A                                      DSPATR(HI)
     A            D@SHFT         1A  B  7 41DSPATR(CS)
     A  63                                  DSPATR(RI)
     A  63                                  DSPATR(PC)
     A*
     A            XMSG          60A  O 22  3COLOR(WHT)
     A                                 23  3'F1: END'
      *---------------------------------------*
      *  サブファイル定義                   *
      *---------------------------------------*
     A          R SFREC1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ')
     A                                      SFL
     A            S1DATA        78      5  2
     C  11                                  DSPATR(UL)
     A*---------------------------------------*
     A*  サブファイル制御　                 *
     A*---------------------------------------*
     A          R SFCTL1                    SFLCTL(SFREC1)
     A                                      SFLSIZ(0018)
     A                                      SFLPAG(0017)
     A                                      CF03
     A                                      OVERLAY
     A                                      PROTECT
     A  71                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  73                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      ROLLUP(74)
     A                                      ROLLDOWN(74)
     A                                      SFLCSRRRN(&$RRN)
     A            RRN1           4S 0H      SFLRCDNBR
     A            $RRN           5S 0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20'* PRIORITY KANBAN INQ. (SEPARATE B-
     A                                      Y GROUP) *'
     A                                      DSPATR(RI)
     A                                  1 68'FMT ABBPW7N'
     A                                  2  2'DATE'
     A                                  2  7DATE
      *
     A                                  3 20'DATE:'
     A                                      DSPATR(HI)
     A            D@YMD          6Y 0    + 1EDTCDE(4)
     A                                   + 5'SHIFT:'
     A                                      DSPATR(HI)
     A            D@SHFT         1A      + 1
     A*
     A                                  4  2'  GROUP            -
     A                                         |     HD      |  -
     A                                         RL      |   OTHER-
     A                                      S    |    TOTAL    '
     A                                      DSPATR(UL)
      *
     A          R DSP02
     A                                 24  2' F3 '  DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 7' PAGE UP/DOWN '
     A                                      DSPATR(RI)
