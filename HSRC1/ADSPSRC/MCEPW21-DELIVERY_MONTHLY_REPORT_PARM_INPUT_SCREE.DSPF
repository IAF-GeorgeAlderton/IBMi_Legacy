     A****************************************************************
     A* DELIVERY MONTHLY REPORT PARM INPUT SCREEN *
     A*                 M-OKUDA             1981.08.25               *
     A****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R MCEPW211
     A*%%TS  SD  19961118  100629  MIKA        REL-V3R0M5  5763-PW1
     A  99                                  ALARM
     A                                      CF01(01)
     A                                      CF05(05)
     A                                  1 68'FMT MCEPW211'
     A                                  3 23'DELIVERY RESULTS MONTHLY REPORT '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A            SIME           8A  B  6 11DSPATR(CS)
     A                                      DSPATR(HI)
     A  91                                  DSPATR(RI)
     A                                  6 21'INPUT CLOSE DATE(A DATE OF THE END-
     A                                       OF THE MONTH)OF DELIVERY'
     A                                      DSPATR(HI)
     A                                  7 11'( YMD )'
     A                                  7 21'MONTHLY REPORT'
     A                                      DSPATR(HI)
     A            RERUN          1A  B  9 11DSPATR(CS)
     A  92                                  DSPATR(RI)
     A  92                                  DSPATR(PC)
     A                                  9 21'IS IT RE-RUN? (ROUTINE = 0, RE-RUN-
     A                                       = 1)'
     A            PAT            1A  B 12 11DSPATR(CS)
     A  93                                  DSPATR(RI)
     A  93                                  DSPATR(PC)
     A                                 12 21'APPOINT NUMBER OF LIST COPIES (1 T-
     A                                      O 3)'
     A                                 13 21'PAPER TYPE = K6H1'
     A            JOBQ           1A  B 15 11DSPATR(CS)
     A  94                                  DSPATR(RI)
     A  94                                  DSPATR(PC)
     A                                 15 21'SELECT JOBQ ( JOBQ-NO = 0 , JOBQ1 -
     A                                      = 1 , JOBQ2 = 2 )'
     A            CMT           60     20 11DSPATR(HI)
     A  99                             22 11'ERROR'
     A                                      DSPATR(RI)
     A                                      DSPATR(BL)
     A  99        MSG           60A  O 22 17DSPATR(HI)
     A                                 24  9'CANCEL'
     A                                 24 17'CMD-1'
     A                                      DSPATR(RI)
     A                                 24 34'UPDATE OK'
     A                                 24 45'CMD-5'
     A                                      DSPATR(RI)
