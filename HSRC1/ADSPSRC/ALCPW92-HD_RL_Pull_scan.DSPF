     A** ALCPW92 ***************************************************************
     A*  COPIED FROM ALCPW12 -- ADDING SCREEN FOR 4 LOT IDS                    *
     A*
     A*  HEADING/ROLLING PULL SCAN                                             *
     A**************************************************************************
     A*
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF03
     A                                      CF05
     A                                      CF07
     A* ----------------------------------------------------
     A* ----------------------------------------------------
     A          R FMT100
     A                                  1  2'HD/RL PULL SCAN'
     A                                      DSPATR(RI)
     A                                  5  2'USER CODE:'
     A            F1USRC         6Y 0B  5 13DSPATR(UL)
     A  61                                  DSPATR(RI)
     A  61                                  DSPATR(PC)
     A                                 12  1'ENTER=NEXT'
     A                                 13  1'F3=END'
     A                                      DSPATR(RI)
     A            F1ERR         16A  O 14  1DSPATR(BL)
      * ----------------------------------------------------
      * ----------------------------------------------------
     A          R FMT200
     A                                  1  5'HD/RL PULL SCAN'
     A                                      DSPATR(RI)
     A                                  4  3'* READ 1ST        *'
     A                                  5  3'*  BARCODE / QR   *'
     A*
     A                                  8  2'KANBAN->'
      *****                             8  2'KANBAN-> 4 POINT SCAN'
      *****                             9  2'OTHERS-> 3 POINT SCAN'
      **
     A                                 12  1'F3=END'
     A                                      DSPATR(RI)
     A            F2ERR         16A  O 14  1DSPATR(BL)
     A*
     A            F2BAR        512A  B 16  1DSPATR(UL)
     A                                      CHECK(ER)
     A  61                                  DSPATR(RI)
     A* ----------------------------------------------------
     A* ----------------------------------------------------
     A          R FMT300
     A                                  1  3'HD/RL PULL SCAN'
     A                                      DSPATR(RI)
     A            F3MID         12A  O  2  4DSPATR(RI)
     A*
     A                                  4  2'<<< LOCATION >>>'
     A            F3LOC         10A  B  6  5CHECK(ER)
     A  61                                  DSPATR(RI)
     A*
     A                                 11  1'F3=BACK'
     A                                      DSPATR(RI)
     A*
     A            F3ERR         16A  O 14  1DSPATR(BL)
     A* ----------------------------------------------------
     A* ----------------------------------------------------
     A          R FMT400
     A                                  1  3'HD/RL PULL SCAN'
     A                                      DSPATR(RI)
     A            F3MID         12A  O  2  4DSPATR(RI)
     A            F4MID1        18A  O  4  3
     A            F4MID2        18A  O  5  3
     A                                  6  3'*  BARCODE / QR  *'
     A**
     A N68                              8  2'LOC :'
     A                                      COLOR(WHT)
     A N68        F4LOC         20A  O  8  8COLOR(WHT)
     A**
     A                                 12  2'F3=BACK'
     A                                      DSPATR(RI)
     A  68                             13  2'F7=1ST SCREEN'
     A  68                                  DSPATR(RI)
     A            F4ERR         16A  O 14  1DSPATR(BL)
     A*
     A            F4BAR        512A  B 16  1DSPATR(UL)
     A                                      CHECK(ER)
     A  61                                  DSPATR(RI)
     A* ----------------------------------------------------
     A* ----------------------------------------------------
     A          R FMT500
     A                                  1  3'HD/RL PULL SCAN'
     A                                      DSPATR(RI)
     A            F3MID         12A  O  2  4DSPATR(RI)
     A*
     A                                  4  2'<<<LOT ID TAG>>>'
     A            F5LOT#        25A  B  6  6CHECK(ER)
     A  61                                  DSPATR(RI)
     A  66                              8  3'*F5=SKIP LOT ID*'
     A  66                                  DSPATR(RI)
     A                                 11  1'F3=BACK'
     A                                      DSPATR(RI)
     A                                 12  2'F7=1ST SCREEN'
     A                                      DSPATR(RI)
     A            F5ERR         16A  O 14  1DSPATR(BL)
     A* ----------------------------------------------------
     A* ----------------------------------------------------
     A          R FMT550
     A                                  1  4'HD/RL PULL SCAN'
     A                                      DSPATR(RI)
     A            F3MID         12A  O  2  5DSPATR(RI)
     A*
     A                                  4  4'***  LOT ID  ***'
     A            F5LTID         8A  B  5  8DSPATR(UL)
     A  61                                  DSPATR(RI)
     A*
     A            F5LOT1         8A  O  6  8COLOR(PNK)
     A            F5LOT2         8A  O  7  8COLOR(PNK)
     A            F5LOT3         8A  O  8  8COLOR(PNK)
     A            F5LOT4         8A  O  9  8COLOR(PNK)
     A*
     A            F5ERR         16A  O 11  4DSPATR(BL)
     A                                 13  2'F3: BACK'
     A                                 13 15'F5: DONE'
     A*
      * ----------------------------------------------------
      * ----------------------------------------------------
     A          R FMT900
     A                                  1  2' OOOOOO            '
