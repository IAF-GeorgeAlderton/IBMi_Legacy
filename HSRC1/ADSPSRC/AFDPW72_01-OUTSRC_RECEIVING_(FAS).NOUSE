     A** AFDPW72 *******************************************
     A*  OUT SOURCE ORDER RECIEVING FOR FAS                *
     A*                                                    *
     A* TCHK  10/11/12 CREATE                              *
%1   A* KIRI  2017/02/22 INTRA KANBAN                      *
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF03
     A*
     A          R DSP01
     A                                      OVERLAY
     A            TITL          15A  O  1  2DSPATR(RI)
     A                                      DSPATR(UL)
%1   A                                  3  2'APICS/      '
     A                                      DSPATR(HI)
     A                                      DSPATR(RI)
%1   A                                  4  2'INTRA KANBAN'
%1   A                                      DSPATR(RI HI)
     A            BARCD1        15A  B  5  2CHECK(ER)
     A  61                                  DSPATR(RI)
     A                                 10  2'F3:END'
     A*
     A          R DSP02
     A                                      OVERLAY
     A            TITL          15A  O  1  2DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  3  2'PART# barcode'
     A                                      DSPATR(HI)
     A                                      DSPATR(RI)
     A            BARCD2        14A  B  5  2CHECK(ER)
     A  64                                  DSPATR(RI)
     A                                 10  2'F3:END'
     A*
     A          R DSP03
     A                                      OVERLAY
     A            TITL          15A  O  1  2DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  3  2'SERIAL# barcode'
     A                                      DSPATR(HI)
     A                                      DSPATR(RI)
     A            BARCD3        11A  B  5  2CHECK(ER)
     A  65                                  DSPATR(RI)
     A                                 10  2'F3:END'
     A*
     A          R ERR99
     A                                      OVERLAY
     A                                      TEXT('DUMMY')
     A                                      KEEP
     A                                  1  2'*******************'
     A                                      DSPATR(BL)
     A                                  2  2'*                 *'
     A                                      DSPATR(BL)
     A                                  3  2'*                 *'
     A                                      DSPATR(BL)
     A                                  4  2'*                 *'
     A                                      DSPATR(BL)
     A                                  5  2'*'
     A                                      DSPATR(BL)
     A            MSG           15   O  5  4
     A                                      DSPATR(BL)
     A                                  5 20'*'
     A                                      DSPATR(BL)
     A                                  6  2'*'
     A                                      DSPATR(BL)
     A            MSG2          15   O  6  4
     A                                      DSPATR(BL)
     A                                  6 20'*'
     A                                      DSPATR(BL)
     A                                  7  2'*                 *'
     A                                      DSPATR(BL)
     A                                  8  2'*                 *'
     A                                      DSPATR(BL)
     A                                  9  2'*                 *'
     A                                      DSPATR(BL)
     A                                 10  2'*******************'
     A                                      DSPATR(BL)
