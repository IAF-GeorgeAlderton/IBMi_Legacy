     A*** ALOPW01 ******************************************
     A* READING BARCODE OF KANBAN(# OF SHORTAGE)           *
     A*
     A* TCHK  09/30/2014 CREATE
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF03
     A* ----------------------------------------------------
     A          R FMT100
     A                                  1  5'#OF SHORTAGE'
     A                                      DSPATR(RI)
     A                                  5  2'DATE  :'
     A            F1DATE         8Y 0O  5 10DSPATR(UL)
     A                                  7  2'SHIFT :'
     A            F1SHFT         1A  B  7 10
     A  62                                  DSPATR(RI)
     A  62                                  DSPATR(PC)
     A                                  9  2'USER CODE:'
     A            F1USRC         6Y 0B  9 13DSPATR(UL)
     A  61                                  DSPATR(RI)
     A  61                                  DSPATR(PC)
     A                                 12  1'ENTER=NEXT'
     A                                 13  1'F3=END'
     A                                      DSPATR(RI)
     A            F1ERR         16A  O 14  1
     A                                      DSPATR(BL)
     A* ----------------------------------------------------
     A          R FMT200
     A                                  1  5'#OF SHORTAGE'
     A                                      DSPATR(RI)
     A                                  2  2'AIAG LABEL BARCODE(2D/1D)'
     A            BAR01         25A  B  3  2
     A            BAR02         25A  B  4  2
     A            BAR03         25A  B  5  2
     A            BAR04         25A  B  6  2
     A            BAR05         25A  B  7  2
     A            BAR06         25A  B  8  2
     A            BAR07         25A  B  9  2
     A            BAR08         25A  B 10  2
     A            BAR09         25A  B 11  2
     A            BAR10         25A  B 12  2CHECK(ER)
     A                                 13  2'F3:END'
     A                                      DSPATR(RI)
     A            F2ERR         16A  O 14  1
     A                                      DSPATR(BL)
     A* ----------------------------------------------------
     A          R FMT300
     A                                  1  5'#OF SHORTAGE'
     A                                  5  2'# OF SHORT'
     A                                      DSPATR(RI)
     A            F3NBRS         3Y 0B  7  9EDTCDE(4)
     A  63                                  DSPATR(RI)
     A  63                                  DSPATR(PC)
     A                                 13  2'F3=END'
     A                                      DSPATR(RI)
     A            F3ERR         16A  O 14  1
     A                                      DSPATR(BL)
