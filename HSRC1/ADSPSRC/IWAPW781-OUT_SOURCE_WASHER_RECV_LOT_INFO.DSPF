     A** IWAPW781 ******************************************
     A*  OUT SOURCE WASHER                                 *
     A*                                                    *
     A******************************************* IWAPW781 *
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A**********************************************************
     A          R IWAPW7811
     A                                      CF01(01)
     A*
     A                                  1  4'* Add Lot Id to Inventory *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  6  6'* Scan Part No. *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A*
     A            D@SHN         20A  B  7  6CHECK(ER)
     A*
     A                                 13  2'F1:Exit'
     A                                      DSPATR(RI)
     A                                  3  5'Lot Id -'
     A            D@LOT#        20   O  3 14COLOR(PNK)
     A          R IWAPW7812
     A                                      CF01(01)
     A                                      CF04(04)
     A*
     A                                  1  4'* Add Lot Id to Inventory *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  6  6'* Scan Quantity *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A*
     A            D@QTY         10A  B  7  8CHECK(ER)
     A*
     A                                 13  2'F1:Exit'
     A                                      DSPATR(RI)
     A                                  3  5'Lot Id -'
     A            D@LOT#        20   O  3 14COLOR(PNK)
     A                                  4  5'Part No. -'
     A            D@SHN         20   O  4 16COLOR(PNK)
     A*
     A                                 14  2'F4:Previous'
     A                                      DSPATR(RI)
     A**********************************************************
     A          R IWAPW098
     A                                      OVERLAY
     A  90
     AO 99                                  ALARM
     A*
     A          R IWAPW099
     A                                      OVERLAY
     A                                  1  3' ** O/S WASHER ERROR ** '
     A                                      DSPATR(RI)
     A                                  4  6'***          ***'
     A                                      COLOR(RED)
     A                                  5  6'  ***      ***  '
     A                                      COLOR(RED)
     A                                  6  6'    ***  ***    '
     A                                      COLOR(RED)
     A                                  7  6'      ****      '
     A                                      COLOR(RED)
     A                                  8  6'    ***  ***    '
     A                                      COLOR(RED)
     A                                  9  6'  ***      ***  '
     A                                      COLOR(RED)
     A                                 10  6'***          ***'
     A                                      COLOR(RED)
     A            D9ERR         25A  O 12  2DSPATR(RI)
     A                                 14  2'ENTER:CONTINUE'
     A                                      COLOR(WHT)
