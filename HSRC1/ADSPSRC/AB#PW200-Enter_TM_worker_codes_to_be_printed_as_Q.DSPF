     A** AB#PW200 **************************************************************
     A*
     A*  PRINT WORKER CODE AS QR                                               *
     A**************************************************************************
     A*
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A* ----------------------------------------------------
     A* ----------------------------------------------------
     A          R FMT100
     A                                      CF03
     A                                      CF09
     A                                  1  4' Print Worker Code as QR '
     A                                      DSPATR(RI)
     A*
     A                                  4  4'Worker Code...'
     A            F1WKCD         6Y 0B  4 19DSPATR(UL)
     A                                      CHECK(RZ)
     A                                      CHECK(ER)
     A  61                                  DSPATR(RI)
     A*
     A            F1ERR         30A  O 10  3DSPATR(BL)
     A                                 12  5'F3: End'
     A                                 12 22'F9: Search'
     A                                  6 10'Count:'
     A            F1CNT          4Y 0O  6 17COLOR(PNK)
     A                                      EDTCDE(Z)
     A*****************************************************************
     A*
     A          R FMT200
     A                                      CF12
     A                                  1  4' Print Worker Code as QR '
     A                                      DSPATR(RI)
     A*
     A            F2WKCD         6S 0O  4  2COLOR(PNK)
     A            F2WKNM        20A  O  4 11COLOR(PNK)
     A*
     A                                 10 23'F12: Cancel'
     A*
     A                                 10  2'Enter: Confirm'
