     A** AB#PWH9 ***********************************
     A*  HONDA FTP INFORMATION MASTER              *
     A*     T.SAKAKI   2015.09.16                  *
     A**********************************************
     A                                      PRINT
     A                                      CHGINPDFT
      *
     A          R AB#PWH91
     A                                      CF01(01)
     A                                      CF05(05)
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' HONDA FTP INFORMATION +
     A                                       MASTER '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AB#PWH9'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  7 16' USER ID '
     A                                      DSPATR(RI)
     A                                  9 16' PASSWORD '
     A                                      DSPATR(RI)
     A                                 11 16' SERVER PORT '
     A                                      DSPATR(RI)
      *
     A            @USER         20O  B  7 34DSPATR(CS)   CHECK(LC)
     A  31                                  DSPATR(RI PC)
     A            @PASS         20O  B  9 34DSPATR(CS)   CHECK(LC)
     A  32                                  DSPATR(RI PC)
     A            @PORT          7Y 0B 11 34DSPATR(CS)
     A  33                                  DSPATR(RI PC)
      *
     A                                 23  2'ERR'
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            @ERR          60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  5' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'END   '
     A                                 24 24' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'UPDATE'
      *
