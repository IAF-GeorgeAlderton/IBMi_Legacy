     A** AGJPW30 ***********************************
     A* INQ #OF A-PICS KANBAN (GROUPING)         *
     A*     IWATA.         2018.04.25              *
     A**********************************************
      *
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R AGJPW301
     A                                      CF01(01)
     A                                      BLINK
     A                                      KEEP
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** INQ #OF A-PICS KANBAN ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT AGJPW30'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  7 21'SELECT DATA'
     A                                      DSPATR(RI)
     A            D1DATA         1A  B  7 36DSPATR(CS)
     A  35                                  DSPATR(RI PC)
     A                                  7 39'1 : EACH DAY(BY GROUP)'
     A                                  8 39'2 : EACH DAY-BIN(BY GROUP)'
     A                                 10 39'3 : EACH DAY(BY NEXT PROCESS)'
     A                                 11 39'4 : EACH DAY-BIN(BY NEXT PROCESS)'
     A                                 13 39'5 : EACH DAY(BY PRV PROCESS)'
     A                                 14 39'6 : EACH DAY-BIN(BY PRV PROCESS)'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'EXIT'
     A          R AGJPW302
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      BLINK
     A                                      KEEP
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** INQ #OF A-PICS KANBAN ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT AGJPW30'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  7 21'SELECT DATA'
     A                                      DSPATR(RI)
     A                                  7 36'EACH DAY'
     A            D2CMT         20A     7 45
      *
     A                                 10 22'APICS DATE'
     A                                      DSPATR(RI)
     A            D1CR1          8Y 0B 10 36DSPATR(CS) EDTCDE(Z)
     A  31                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1CR2          8Y 0B   + 2DSPATR(CS) EDTCDE(Z)
     A  32                                  DSPATR(RI PC)
      *
     A  88                             13 26'FILTER'
     A  88                                  DSPATR(RI)
     A  88        D1FILT         1A  B 13 36DSPATR(CS)
     A  88 36                               DSPATR(RI PC)
     A  88                             13 39'0: ALL'
     A  88                             14 39'1: TS-LINE PARTS (OQ1 ONLY)'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D2ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'RUN'
     A          R AGJPW303
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      BLINK
     A                                      KEEP
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** INQ #OF A-PICS KANBAN ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT AGJPW30'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  7 21'SELECT DATA'
     A                                      DSPATR(RI)
     A                                  7 36'EACH DAY-BIN'
     A            D3CMT         20A     7 49
      *
     A                                 10 22'APICS DATE'
     A                                      DSPATR(RI)
     A            D1CR1          8Y 0B 10 36DSPATR(CS) EDTCDE(Z)
     A  31                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1CB1          2Y 0B   + 1DSPATR(CS) EDTCDE(Z)
     A  33                                  DSPATR(RI PC)
     A                                   + 2'-'
     A            D1CR2          8Y 0B   + 2DSPATR(CS) EDTCDE(Z)
     A  32                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1CB2          2Y 0B   + 1DSPATR(CS) EDTCDE(Z)
     A  34                                  DSPATR(RI PC)
      *
     A  88                             13 26'FILTER'
     A  88                                  DSPATR(RI)
     A  88        D1FILT         1A  B 13 36DSPATR(CS)
     A  88 36                               DSPATR(RI PC)
     A  88                             13 39'0: ALL'
     A  88                             14 39'1: TS-LINE PARTS (OQ1 ONLY)'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D3ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'RUN'
