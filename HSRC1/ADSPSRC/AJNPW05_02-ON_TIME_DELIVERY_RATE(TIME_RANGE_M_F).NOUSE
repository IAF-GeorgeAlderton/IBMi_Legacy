     A** AJNPW05 *******************************************
     A* ON-TIME DELIVERY RATE(TIME RANGE M/F)
     A*       SAKAKI.          2019.10.04                  *
     A******************************************************
     A                                      CHGINPDFT
     A                                      PRINT
     A          R AJNPW051
     A  99                                  ALARM
     A                                      KEEP
     A                                      CF01(01)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                   + 1TIME  EDTWRD('0  :  :  ')
     A                                  1 20' ** ON-TIME DELIVERY RATE(TIME-
     A                                       RANGE M/F)** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                   + 1'AJNPW05'
     A                                  2  2'DATE'
     A                                   + 1DATE EDTWRD('0  .  .  ')
      *
     A                                  5  8'UPDATE' DSPATR(HI)
     A                                  5 26'TABLE#' DSPATR(HI)
     A            D1UPD          1A  B  6 10DSPATR(CS)
     A  30                                  DSPATR(RI PC)
     A                                  6 13'0:DELETE'
     A                                  7 13'1:CHANGE'
     A                                  8 13'2:ADD NEW'
     A            D1TYPE         1A  B  6 28DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                  6 32'1. CV(LOCATION -> PRELOAD)'
     A                                  7 32'2. BZ(PRELOAD  -> LOADING)'
     A                                  8 32'3. DS(PRELOAD  -> LOADING)'
     A                                  9 32'4. JC(PRELOAD  -> LOADING)'
     A                                 10 32'5. INSPECTION(PRELOAD  -> +
     A                                       LOCATION)'
     A                                 11 32'6. BZ/DS/JC(UNLOADING  -> +
     A                                       INSPECTION)'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  7'EXIT'
     A                                   + 1' F1 '
     A                                      DSPATR(RI)
      *
     A          R AJNPW052
     A  99                                  ALARM
     A                                      KEEP
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                   + 1TIME  EDTWRD('0  :  :  ')
     A                                  1 20' ** ON-TIME DELIVERY RATE(TIME-
     A                                       RANGE M/F)** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                   + 1'AJNPW05'
     A                                  2  2'DATE'
     A                                   + 1DATE EDTWRD('0  .  .  ')
      *
     A                                  5  8'UPDATE' DSPATR(HI)
     A                                  5 26'TABLE#' DSPATR(HI)
     A            D1UPD          1A     6 10
     A                                  6 13'0:DELETE'
     A                                  7 13'1:CHANGE'
     A                                  8 13'2:ADD NEW'
     A            D1TYPE         1A     6 28
     A                                  6 32'1. CV(LOCATION -> PRELOAD)'
     A                                  7 32'2. BZ(PRELOAD  -> LOADING)'
     A                                  8 32'3. DS(PRELOAD  -> LOADING)'
     A                                  9 32'4. JC(PRELOAD  -> LOADING)'
     A                                 10 32'5. INSPECTION(PRELOAD  -> +
     A                                       LOCATION)'
     A                                 11 32'6. BZ/DS/JC(UNLOADING  -> +
     A                                       INSPECTION)'
      *
     A                                 14  8' TIME RANGE(LESS THAN) '
     A                                      DSPATR(RI)
      *
     A            D2HH01         4Y 0B 15 14DSPATR(CS) EDTCDE(Z)
     A  31                                  DSPATR(RI PC)
     A  19                                  DSPATR(PR)
     A                                 15 23'MINUTES'
      *
     A            D2HH02         4Y 0B 16 14DSPATR(CS) EDTCDE(Z)
     A  32                                  DSPATR(RI PC)
     A  19                                  DSPATR(PR)
     A                                 16 23'MINUTES'
      *
     A            D2HH03         4Y 0B 17 14DSPATR(CS) EDTCDE(Z)
     A  33                                  DSPATR(RI PC)
     A  19                                  DSPATR(PR)
     A                                 17 23'MINUTES'
      *
     A            D2HH04         4Y 0B 18 14DSPATR(CS) EDTCDE(Z)
     A  34                                  DSPATR(RI PC)
     A  19                                  DSPATR(PR)
     A                                 18 23'MINUTES'
      *
     A            D2HH05         4Y 0B 19 14DSPATR(CS) EDTCDE(Z)
     A  35                                  DSPATR(RI PC)
     A  19                                  DSPATR(PR)
     A                                 19 23'MINUTES'
      *
     A            D2HH06         4Y 0H
     A**          D2HH06         4Y 0B 20 14DSPATR(CS) EDTCDE(Z)
     A**36                                  DSPATR(RI PC)
     A**19                                  DSPATR(PR)
     A**                               20 23'MINUTES'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  7'BACK'
     A                                   + 1' F3 '
     A                                      DSPATR(RI)
     A                                   + 2'UPDATE'
     A                                   + 1' F5 '
     A                                      DSPATR(RI)
