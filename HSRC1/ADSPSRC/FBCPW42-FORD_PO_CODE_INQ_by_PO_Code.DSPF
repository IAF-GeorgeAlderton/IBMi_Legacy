     A*****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*---------------------------------------*
     A          R SFREC1                    SFL
     A*%%TS  SD  20240523  142613  I0777       REL-V7R4M0  5770-WDS
     A            S1SHP1         2A  O  5  3TEXT('PLANT ID')
     A  41                                  COLOR(RED)
     A            S1SHP2         1A  O  5  9TEXT('SEQ#')
     A  41                                  COLOR(RED)
     A            S1TOKU         4A  O  5 14TEXT('CUST#')
     A  41                                  COLOR(RED)
     A            S1NONY         4A  O  5 20TEXT('DELV#')
     A  41                                  COLOR(RED)
     A            S1KMEI        15A  O  5 26TEXT('FACTORY NAME')
     A  41                                  COLOR(RED)
     A            S1CRHZ         8Y 0O  5 44EDTWRD('    /  /  ')
     A  41                                  COLOR(RED)
     A            S1KOHZ         8Y 0O  5 56EDTWRD('    /  /  ')
     A  41                                  COLOR(RED)
     A            S1KSHZ         8Y 0O  5 68EDTWRD('    /  /  ')
     A  41                                  COLOR(RED)
     A*---------------------------------------*
     A          R SFCTL1                    SFLCTL(SFREC1)
     A*%%TS  SD  20240523  142613  I0777       REL-V7R4M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      CF01(01)
     A                                      CF03(03)
     A                                      CF10(10)
     A                                      CF12(12)
     A                                      OVERLAY
     A                                      PROTECT
     A  70                                  SFLDSPCTL
     A  71                                  SFLDSP
     A  72                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      ROLLUP(73)
     A                                      ROLLDOWN(73)
     A                                      SFLCSRRRN(&$RRN)
     A            RRN1           4S 0H      SFLRCDNBR
     A            $RRN           5S 0H
     A                                  1  2'FBCR42'
     A                                  1 20' ** FORD PO CODE INQ ** '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 62DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A                                  2  2'PO POSITION:'
     A            XPO            2A  B  2 15DSPATR(UL)
     A                                  2 25'(BY PO CODE)'
     A*
     A                                  4  1'  PO   SQ# '
     A                                      DSPATR(UL)
     A                                  4 14'CUST# DELV# NAME           '
     A                                      DSPATR(UL)
     A                                  4 44' CREATED  '
     A                                      DSPATR(UL)
     A                                  4 56' UPDATED  '
     A                                      DSPATR(UL)
     A                                  4 68' DELETED  '
     A                                      DSPATR(UL)
     A*
     A          R DSP01
     A*%%TS  SD  20240523  143533  I0777       REL-V7R4M0  5770-WDS
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                 24  7'BACK'
     A                                 24 18' PAGE UP/DOWN '
     A                                      DSPATR(RI)
     A                                 24 41' F10 '
     A                                      DSPATR(RI)
     A                                 24 47'INQ BY DELIVERY CODE'
