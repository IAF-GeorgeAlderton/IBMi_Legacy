     A** ABHPWS1 *******************************
     A*INTRA-PROCESS KANBAN M/F --> CSV DATA   *
     A* KIRI                    2014.08.28     *
     A******************************* ABHPWS1 **
     A                                      CHGINPDFT
     A                                      PRINT
     A************
     A* * SCREEN 1*
     A************
     A          R DSP01
     A                                      BLINK
     A                                      CF01 CF05
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                      EDTWRD('  :  :  ')
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('  .  .  ')
     A                                  1 20'* INTRA-PROCESS KANBAN M/F -
                                            --> CSV DATA *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 67'FMT ABHPWS1'
      *
     A            D1KBN          1   B  6 20DSPATR(CS)
     A  11                                  DSPATR(RI PC)
     A                                  6 22' ..." ": CURRENTLY'
     A                                  8 22'    "1": FUTURE'
     A            D1YYM          6  0B 10 31DSPATR(CS) EDTCDE(4)
     A  12                                  DSPATR(RI PC)
     A            D1RITU         3  0B 10 40DSPATR(CS) EDTCDE(4)
     A  13                                  DSPATR(RI PC)
     A                                   + 1'%'
     A                                 11 31'YYYYMM'
      *
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
      *
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
     A                                   + 4' F5 ' DSPATR(RI)
     A                                   + 1'CREATE OK'
