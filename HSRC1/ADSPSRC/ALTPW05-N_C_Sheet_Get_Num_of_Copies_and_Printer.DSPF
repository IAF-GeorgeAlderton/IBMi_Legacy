     A** ALTPW05 ********************************************
     A*  N/C SHEET PRINT - # OF COPIES AND PRINTER TO PRINT *
     A*                                                     *
     A* LEC   : 10/18/2022  CREATE                          *
     A*******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A                                      CF03
     A* ----------------------------------------------------
     A          R FMT100
     A                                      OVERLAY
     A                                  1  3' NON-CONFORMANCE SHEET '
     A                                      DSPATR(RI)
     A            @@PROC         8A  O  2  9DSPATR(RI)
     A            #PGM          10A  O  1 70
     A  99        MSG           60A  O 12  3
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A                                 14  3' F3:Back '
     A                                      DSPATR(RI)
     A                                  3  4'<< Print/Email >>'
     A                                  5  4'Print to'
     A                                  6  4'Email to'
     A                                 10  4'Num of Copies->'
     A****        F1SEL          1Y 0B  8 19COLOR(WHT)
     A****                                  EDTCDE(Z)
     A            F1#CPY         1Y 0B 10 20COLOR(WHT)
     A                                      CHECK(ER)
     A                                      EDTCDE(Z)
     A                                 10 24'1 - 4'
     A****                              8  4'Selection--->'
     A****                              8 24'1 or 2'
     A            F1PRTR        10A  O  5 13
     A            F1EMAL        35A  O  6 13
     A                                 14 16' Enter:Continue '
     A                                      DSPATR(RI)
