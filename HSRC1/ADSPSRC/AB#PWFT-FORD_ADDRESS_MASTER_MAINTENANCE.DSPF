     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  2 68'ADD'
     A                                  5  2'DELIVERY CODE  :'
     A            NONY2          4S 0O  5 19
     A                                  7  2'FORD PLANT CODE:'
     A            DOCK2          5A  B  7 19DSPATR(CS)
     A  31                                  DSPATR(RI)
     A  31                                  DSPATR(PC)
     A                                  7 41'EX. AP06A'
     A                                  9  2'SHIP TO NAME   :'
     A            SHIP2          5A  B  9 19DSPATR(CS)
     A  32                                  DSPATR(RI)
     A  32                                  DSPATR(PC)
     A                                  9 41'EX. KCYA FOR LABEL'
     A                                 11  2'PLANT ID       :'
     A            PLID2          2A  B 11 19DSPATR(CS)
     A  33                                  DSPATR(RI)
     A  33                                  DSPATR(PC)
     A                                 11 41'EX. 06   FOR LABEL'
     A                                 13  2'ADDRESS 1      :'
     A                                 13 41'FOR LABEL'
     A            ADD12         20A  B 13 19DSPATR(CS)
     A  34                                  DSPATR(RI)
     A  34                                  DSPATR(PC)
     A                                 15  2'ADDRESS 2:     :'
     A            ADD22         20A  B 15 19DSPATR(CS)
     A  35                                  DSPATR(RI)
     A  35                                  DSPATR(PC)
     A                                 15 41'FOR LABEL'
     A                                 17  2'CUM. FLAG      :'
     A            FLAG2          1A  B 17 19DSPATR(CS)
     A  36                                  DSPATR(RI)
     A  36                                  DSPATR(PC)
     A                                 17 41'BLANK = CURRENT CUM.'
     A                                 18 41'    1 = PRIOR   CUM.'
     A                                 22 11'ERROR'
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A            @MSG2         60A  O 22 18
     A N99N97                               DSPATR(ND)
