     A** AB#PWFT *******************************************
     A* FORD ADDRESS MASTER MAINTENANCE                    *
     A* K.KASHIWAGI    2001.03.05                          *
     A******************************************* AB#PWFT **
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A*---------------------------------------------------------------
     A          R AB#PWFT1
     A                                      TEXT('THE 1ST SCREEN')
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      CF07(07)
     A                                      CF09(09)
     A                                      BLINK
     A  99                                  ALARM
     A                                      KEEP
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25'FORD ADDRESS MASTER MAINTENANCE'
     A                                      DSPATR(RI)
     A                                  1 68'FMT AB#PWFT1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  8 14'DELIVERY CODE:'
     A            NONY1          4Y 0B  8 30DSPATR(CS)
     A  30                                  DSPATR(RI)
     A  30                                  DSPATR(PC)
     A                                 22 11'ERROR'
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A            @MSG1         60A  O 22 18
     A N99N98                               DSPATR(ND)
     A                                 24  2'F3=EXIT'
     A                                      DSPATR(RI)
     A                                 24 14'F5=ADD'
     A                                      DSPATR(RI)
     A                                 24 39'F9=DELETE'
     A                                      DSPATR(RI)
     A                                 24 25'F7=CHANGE'
     A                                      DSPATR(RI)
     A*---------------------------------------------------------------
     A          R AB#PWFT2
