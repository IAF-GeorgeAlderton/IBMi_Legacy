     A** AGIPW01 ***********************************
     A* A-PICS SORT M/F                            *
     A*     ITS.    2013.11.25                     *
     A**********************************************
     A                                      PRINT
     A                                      CHGINPDFT
      *------------------------*
     A          R SFL                       SFL
     A            S1SORT         5Y 0   5  5EDTCDE(Z)
     A            S1K001         3A  B  5 15DSPATR(CS)
     A            S1K002         3A  B  5 26DSPATR(CS)
     A            S1K003         3A  B  5 37DSPATR(CS)
     A            S1K004         3A  B  5 48DSPATR(CS)
     A            S1K005         3A  B  5 59DSPATR(CS)
     A            S1K006         3A  B  5 70DSPATR(CS)
      *非表示項目
     A            @RRN           4Y 0H
     A            S1K007         3A  H
     A            S1K008         3A  H
     A            S1K009         3A  H
     A            S1K010         3A  H
      *---------------------------------------*
      * CONTROL                               *
      *---------------------------------------*
     A          R SFLCTL
     A                                      SFLCTL(SFL)
     A  72                                  SFLDSPCTL
     A  72                                  ERASE(SFL)
     A  73                                  SFLDSP
     A  71                                  SFLCLR
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(15)
     A                                      SFLSIZ(15)
     A                                      CF01(01)
     A                                      CF05(05)
     A                                      CF10(10)
     A                                      CF12(12)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3  0H
     A            S@SCLM         3  0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** A-PICS ASSIGNMENT M/F ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT AGIPW01'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4  4'  SORT    PROCESS1   PROCESS2   +
     A                                       PROCESS3   PROCESS4   +
     A                                       PROCESS5   PROCESS6  '
     A                                      DSPATR(UL)
      *------------------------*
     A          R AGIPW019
     A                                      OVERLAY PROTECT
     A N81                             22 72'MORE...'
     A  81                             22 72'LAST...'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D9ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'EXIT'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'UPDATE'
     A                                   + 2' F10 '
     A                                      DSPATR(RI)
     A                                   + 1'INSERT'
     A                                   + 2' F12 '
     A                                      DSPATR(RI)
     A                                   + 1'DELETE'
     A                                   + 2' PAGE UP/DOWN'
     A                                      DSPATR(RI)
      ***********************************************
      * WINDOW                                      *
      ***********************************************
     A          R W1
     A                                      OVERLAY
      * A開始行B開始桁Cウインド内行数Dウインド内桁数
      *                                            A  B  C   D
     A                                      WINDOW(8 14 12  40)
     A                                      WDWBORDER((*DSPATR RI HI) (*CHAR ' -
     A                                             '))
     A                                      RMVWDW
     A                                      USRRSTDSP
     A                                      WDWTITLE((*TEXT 'INSERT'))
      *
     A          R AGIPW01A
     A                                      OVERLAY PROTECT
     A                                      WINDOW(W1)
     A                                      CF03(03)
     A                                      CF05(05)
      *
     A                                  2  3'SORT'
     A            DASORT         5Y 0B  3  2EDTCDE(4)
     A                                      DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                  5  3'PROC1'
     A                                  5  9'PROC2'
     A                                  5 15'PROC3'
     A                                  5 21'PROC4'
     A                                  5 27'PROC5'
     A                                  5 33'PROC6'
     A            DAK001         3A  B  6  4DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            DAK002         3A  B  6 10DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            DAK003         3A  B  6 16DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            DAK004         3A  B  6 22DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            DAK005         3A  B  6 28DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            DAK006         3A  B  6 34DSPATR(CS)
     A  32                                  DSPATR(RI PC)
      *
     A            DAERR         30      8  2
     A                                 10  4'BACK = F3 '
     A                                   + 2'INSERT = F5'
      ***********************************************
      * WINDOW                                      *
      ***********************************************
     A          R W2
     A                                      OVERLAY
      * A開始行B開始桁Cウインド内行数Dウインド内桁数
      *                                            A  B  C   D
     A                                      WINDOW(8 14  6  30)
     A                                      WDWBORDER((*DSPATR RI HI) (*CHAR ' -
     A                                             '))
     A                                      RMVWDW
     A                                      USRRSTDSP
     A                                      WDWTITLE((*TEXT 'DELETE'))
      *
     A          R AGIPW01B
     A                                      OVERLAY PROTECT
     A                                      WINDOW(W2)
     A                                      CF03(03)
     A                                      CF05(05)
      *
     A                                  2  3'SORT'
     A            DBSORT         5Y 0B  3  2EDTCDE(4)
     A                                      DSPATR(CS)
     A  31                                  DSPATR(RI PC)
      *
     A            DBERR         20      4  2
     A                                  5  4'BACK = F3 '
     A                                   + 2'DELETE = F5'
      *
