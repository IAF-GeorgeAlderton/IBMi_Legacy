     A                                      PRINT
     A                                      CHGINPDFT
      *------------------------*
     A          R SFL                       SFL
     A            S1SHN         14A     5  3
     A            S1AP          10Y 0   5 19EDTWRD('    /  /  -  ')
     A            S1MAIS         3Y 0   5 36EDTWRD(' 0 ')
     A            S1BARL         2Y 0   5 45EDTWRD('0 ')
     A            S1CHNG         3Y 0B  5 54EDTWRD(' 0 ')
     A  31                                  DSPATR(RI PC)
     A N39                                  DSPATR(CS)
     A  39                                  DSPATR(PR)
      *非表示項目
     A            @RRN           4Y 0H
     A            H1APHZ         8Y 0H
     A            H1APBN         2Y 0H
     A            H1SHN1         5A  H
     A            H1SHN2         5A  H
     A            H1SHN3         2A  H
     A            H1BARL         3Y 1H
     A            H1EFLG         1A  H
      *---------------------------------------*
      * CONTROL                               *
      *---------------------------------------*
     A          R SFLCTL
     A                                      SFLCTL(SFL)
     A  72                                  SFLDSPCTL
     A  72                                  ERASE(SFL)
     A  73                                  SFLDSP
     A  71                                  SFLCLR
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(17)
     A                                      SFLSIZ(17)
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3Y 0H
     A            S@SCLM         3Y 0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** SATURDAY KANBAN DATA +
     A                                       INQ/UPD ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT ADKPW38'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4  3'PART NO.        DATE-BIN        +
     A                                       BOXES   BARREL   CHANGE '
     A                                      DSPATR(UL)
      *------------------------*
     A          R ADKPW389
     A                                      OVERLAY PROTECT
     A N81                             22 72'MORE...'
     A  81                             22 72'LAST...'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D9ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'UPDATE'
     A                                   + 2' PAGE UP '
     A                                      DSPATR(RI)
     A                                   + 1'PRV'
     A                                   + 2' PAGE DOWN '
     A                                      DSPATR(RI)
     A                                   + 1'NEXT'
