     A*%%TS  SD  20170810  094215  IAF         REL-V7R1M0  5770-WDS
     A** GAHPW37 ******************************************************
     A*  UPDATE OF ROUTE M/F
     A*  KIRI                                            2017.06.29
     A*
     A*   CHGDSPF FILE(GAHPW37) DFRWRT(*NO) *DO AFTER COMPILE
     A*
     A*****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
      *----------------------------------------------------------------
      * * SCREEN 1*
      *----------------------------------------------------------------
     A          R GAHPW371
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 30' ** ROUTE MASTER ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT GAHPW371'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4 14'CODE'
     A                                  4 41'ROUTE NAME'
      *----------------------------------------------------------------
      *サブファイル
      *----------------------------------------------------------------
     A          R SFREC1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ')
     A                                      SFL
      *
     A            S1COM          6      5  6TEXT('UPDATE')
     A            S1RTCD         4       + 2TEXT('ROUTE CODE')
     A            S1RTNA        45       + 4TEXT('ROUTE NAME 1')
      *
     A          R SFCTL1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ ﾃ]nﾜｰﾓ')
     A                                      SFLCTL(SFREC1)
     A                                      OVERLAY PROTECT
     A                                      CF03 CF05
     A  71                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  73                                  SFLCLR
     A  96                                  SFLEND(*MORE)
     A                                      SFLPAG(10) SFLSIZ(10)
     A                                      ROLLUP(75)
     A                                      ROLLDOWN(76)
      * *
     A                                 16 65'PAGE DOWN/UP'
     A                                      DSPATR(RI)
     A                                 17 10'UPDATE              -
     A                                       ROUTE CODE        -
     A                                       ROUTE NAME     '
     A                                      DSPATR(UL)
     A            D1KKBN         1   B 18 12DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                 18 15'-> 0-CANCEL'
     A                                 19 15'   1-CHANGE'
     A                                 20 15'   2-ADD   '
     A            D1RTCD         4   B 18 34TEXT('ROUTE CODE')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A            D1RTN1        15   B 18 50TEXT('ROUTE NAME 1')
     A                                      DSPATR(CS)
     A  33                                  DSPATR(RI PC)
     A            D1RTN2        15   B 19 50TEXT('ROURE NAME 2')
     A                                      DSPATR(CS)
     A  33                                  DSPATR(RI)
     A            D1RTN3        15   B 20 50TEXT('ROUTE NAME 3')
     A                                      DSPATR(CS)
     A  33                                  DSPATR(RI)
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL UL)
     A  99        D1ERR         60A  O 22 18
     A*
     A                                 24  5' F3=RETURN '
     A                                      DSPATR(RI)
     A                                   + 5' F5=UPDATE '
     A                                      DSPATR(RI)
      *
      *----------------------------------------------------------------
      *画面罫線消去
      *----------------------------------------------------------------
     A          R GAHPW372                  GRDRCD
     A                                      GRDCLR
      *----------------------------------------------------------------
      *画面罫線
      *----------------------------------------------------------------
     A          R GAHPW373                  GRDRCD
     A                                      GRDATR((*COLOR HWHT))
     A                                      GRDLIN((*POS (04 04 11)) +
     A                                             (*TYPE  LEFT))
     A                                      GRDLIN((*POS (04 20 11)) +
     A                                             (*TYPE  LEFT))
     A                                      GRDLIN((*POS (04 77 11)) +
     A                                             (*TYPE  LEFT))
     A                                      GRDLIN((*POS (04 04 73)) +
     A                                             (*TYPE UPPER))
     A                                      GRDLIN((*POS (05 04 73)) +
     A                                             (*TYPE UPPER))
     A                                      GRDLIN((*POS (15 04 73)) +
     A                                             (*TYPE UPPER))
