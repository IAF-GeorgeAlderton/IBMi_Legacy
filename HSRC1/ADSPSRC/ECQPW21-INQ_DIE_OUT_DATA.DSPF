     A** ECQPW21 ***********************************
     A* INQ DIE OUT DATA                           *
     A*    MAEDA.           2017.10.11             *
     A**********************************************
     A                                      PRINT
     A                                      CHGINPDFT
      *------------------------*
     A          R SFL                       SFL
     A            S1YOHZ         8Y 0   7  3EDTWRD('    .  .  ')
     A            S1KAT          9A     7 15
     A            S1KOSU         3Y 0   7 26EDTWRD(' 0 ')
     A            S1KINO         5A     7 34
     A            S1RESN        22A     7 43
     A            S1KOME        14A     7 66
      *非表示項目
     A            @RRN           4Y 0H
      *---------------------------------------*
      * CONTROL                               *
      *---------------------------------------*
     A          R SFLCTL
     A                                      SFLCTL(SFL)
     A  72                                  SFLDSPCTL
     A  72                                  ERASE(SFL)
     A  73                                  SFLDSP
     A  71                                  SFLCLR
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(15)
     A                                      SFLSIZ(15)
     A                                      CF03(03)
     A                                      CF04(04)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3Y 0H
     A            S@SCLM         3Y 0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** DIE OUT DATA INQUIRY ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT ECQPW21'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  3  3'FACTORY'
     A            C1KOJO         4A     3 12
     A            C1KJNM        16A     3 18
     A                                  4  3'DIE NO.'
     A            C1KAT          9A     4 12
     A                                  4 23'OUT DATE'
     A            C1DAT1         8Y 0   4 33EDTWRD('    .  .  ')
     A                                  4 44'-'
     A            C1DAT2         8Y 0   4 46EDTWRD('    .  .  ')
     A                                  6  2' OUT DATE    DIE NO    USED  +
     A                                       MACHINE NO  OUT +
     A                                       REASON             WORKER        '
     A                                      DSPATR(UL)
      *------------------------*
     A          R ECQPW219
     A                                      OVERLAY PROTECT
     A N81                             22 72'MORE...'
     A  81                             22 72'LAST...'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D9ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2' F4 '
     A                                      DSPATR(RI)
     A                                   + 1'EACH MACHINE'
     A                                   + 2' PAGE UP '
     A                                      DSPATR(RI)
     A                                   + 1'PRV'
     A                                   + 2' PAGE DOWN '
     A                                      DSPATR(RI)
     A                                   + 1'NEXT'
