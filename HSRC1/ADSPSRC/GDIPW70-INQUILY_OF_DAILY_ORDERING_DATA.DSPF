      *** GDIPW70 ****************************************************
      *     INQUILY OF       DAILY ORDERING DATA
      *        G.B.C                            97/04/09
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS UL FE)
     A                                      CF01(01 '終了')
      *---------------------------------------------------------------
     A          R G1
     A                                      OVERLAY
     A                                      PROTECT
      *
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 18' REFERRING TO THE DAIL-
     A                                      Y ORDERING DATA '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW70'
      *
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
      *
     A                                  4  3'ORDER DATE'
     A            G1JSYM         6Y 0B  4 14EDTCDE(4) CHECK(RB)
     A  61                                  DSPATR(RI PC)
     A                                  4 22'(YYYYMM)'
      *
     A                                  5  3'DIE NO.'
     A            G1KAT1         2   B  5 14
     A                                  5 17'-'
     A            G1KAT2         4   B  5 19
     A                                  5 24'-'
     A            G1KAT3         1   B  5 26
     A                                  5 28'-'
     A            G1KAT4         1   B  5 30
      *---------------------------------------------------------------
     A          R S1                        SFL
      *
     A            S1KATA        11   O  9  2TEXT('型番')
     A            S1ODER         6   O  9 15TEXT('オーダー番号')
     A            S1ITEM         5   O  9 23TEXT('アイテム番号')
     A            S1ODMD         4Y 0O  9 30TEXT('オーダー日付')
     A                                      EDTWRD('  /  ')
     A            S1SURY         9Y 0O  9 36TEXT('オーダー数量')
     A                                      EDTCDE(2)
      *
     A            S1INVO         6   O  9 49TEXT('インボイス番号')
     A            S1NYMD         4Y 0O  9 56TEXT('入荷日付')
     A                                      EDTWRD('  /  ')
     A            S1SUR2         9Y 0O  9 62TEXT('入荷数量')
     A                                      EDTCDE(2)
     A            S1NYUK         1   O  9 76TEXT('入荷区分')
      *---------------------------------------------------------------
     A          R S1C                       SFLCTL(S1)
      *
     A                                      CF03(03 '前画面')
     A                                      OVERLAY
     A                                      PROTECT
     A                                      SFLPAG(12) SFLSIZ(13)
     A                                      ROLLUP(25)
     A  31                                  SFLDSP
     A  31                                  SFLDSPCTL
     A  32                                  SFLCLR
     A            RRN            4  0H      SFLRCDNBR
      *
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 18' REFERRING TO THE DAIL-
     A                                      Y ORDERING DATA '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW70'
      *
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
      *
     A                                  4  3'ORDER DATE'
     A            G1JSYM         6Y 0O  4 14EDTCDE(4)
     A                                  4 22'(YYYYMM)'
      *
     A                                  5  3'DIE NO.'
     A            G1KAT1         2   O  5 14TEXT('型番１')
     A                                  5 17'-'
     A            G1KAT2         4   O  5 19TEXT('型番２')
     A                                  5 24'-'
     A            G1KAT3         1   O  5 26TEXT('型番３')
     A                                  5 28'-'
     A            G1KAT4         1   O  5 30TEXT('型番４')
      *
     A                                  7 29'ORDER'
     A                                      DSPATR(HI)
     A                                  7 53'RECEIVED    RECEIVED'
     A                                      DSPATR(HI)
      *
     A                                  8  2'DIE NO.    ORDER NO. ITE+
     A                                      M   DATE    ORDER QTY INVOICE  DAT+
     A                                      E         QTY RECEIVE'
     A                                      DSPATR(HI UL)
      *---------------------------------------------------------------
     A          R C1
      *
     A  99                             22 11' ERROR '
     A                                      DSPATR(RI BL)
     A  99        C1MSG         60   O 22 23
     A                                      DSPATR(BL)
      *
     A                                 24  9'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
      *---------------------------------------------------------------
     A          R C2
      *
     A                                 24  9'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 30'PRV SCREEN'
     A                                   + 1' CMD-3 '
     A                                      DSPATR(RI)
     A                                 24 56' ROLL-UP/DWN '
     A                                      DSPATR(RI)
