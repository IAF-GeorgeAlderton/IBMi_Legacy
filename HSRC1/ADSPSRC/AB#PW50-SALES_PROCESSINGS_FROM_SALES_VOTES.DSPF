     A** AB#PW50 *********************************
     A*  ..SALES PROCESSINGS FROM SALES VOTES..  *
     A*     S.OHTAKE                97.06.07     *
     A********************************* AB#PW50 **
     A                                      CHGINPDFT
     A                                      PRINT
      *
     A          R AB#PW501
     A                                      CF01
     A  99                                  ALARM
     A                                      BLINK PUTOVR KEEP
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
     A                                  1 20'*** SALES PROCESSINGS FROM SALES +
     A                                       VOTES ***'
     A                                      DSPATR(RI)
     A                                  1 69'FMT AB#PW50'
      *
     A                                  6 25' INPUT OF BARCODES '
     A                                      DSPATR(RI)
     A                                  9 11'GAVE A BARCODES BE READ  -+
     A                                      ---->'
     A            NBAR           8   B  9 44DSPATR(CS) OVRDTA
     A                                      CHECK(ER)
     A  01                                  DSPATR(RI PC)
     A                                 14 20'LAST BARCODES ------>'
     A            OBAR           8   O 14 44OVRDTA OVRATR
      *
     A                                 22 10'ERROR'
     A                                      OVRATR
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A            MSG           60   O 22 20OVRATR
     A                                      OVRDTA
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A  99                                  DSPATR(BL)
      *
     A                                 24  4' END '
     A                                 24 15' CMD-1 '
     A                                      DSPATR(RI)
