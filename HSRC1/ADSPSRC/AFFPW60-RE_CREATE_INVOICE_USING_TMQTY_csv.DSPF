     A            S1QTY1         5Y 0O  5 49EDTCDE(1)
     A                                      COLOR(WHT)
     A            S1QTY2         5Y 0O  5 56EDTCDE(1)
     A                                      COLOR(YLW)
     A            S1PRC          6Y 4O  5 63EDTWRD('0 .    ')
     A            S1AMT          7Y 2O  5 71EDTWRD('     .  ')
     A                                      COLOR(WHT)
