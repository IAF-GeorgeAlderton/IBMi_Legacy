     A*%%TS  SD  20240327  111937  I0777       REL-V7R4M0  5770-WDS
     A** AFFPW60 *****************************************************
     A*  UPLOAD TMQTY.CSV FROM DIRECTORY(K)
     A*  J.WATANABE  2024.03.27
     A****************************************************************
     A*
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*
     A          R DSP01
     A*%%TS  SD  20240327  111937  I0777       REL-V7R4M0  5770-WDS
     A                                      TEXT(' ')
     A                                      CF01(01)
     A                                      CF07(07)
     A                                  1  3'AFFR60'
     A                                  1 14'** RE-CREATE INVOICE USING TMQTY.C-
     A                                      SV **'
     A                                      DSPATR(RI)
     A                                  1 63DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A                                  3  6'Step1: Save INVOICE Data to:'
     A                                  3 35'(K:) /UPLOAD/TMQTY.CSV    '
     A                                      COLOR(WHT)
     A                                  5  6'Step2: Press ENTR to validate Sour-
     A                                      ce Data, then Press F5 to upload'
     A                                  7  4'** Format of TMQTY.CSV **'
     A                                      COLOR(YLW)
     A                                  8  7'< * = Must Enter >'
     A                                      COLOR(WHT)
     A                                  8 35'< * = Must Enter >'
     A                                      COLOR(WHT)
     A                                  9  9'*A: Line# (4 Digits)'
     A                                      COLOR(WHT)
     A                                  9 37'*I: Manifest#'
     A                                      COLOR(WHT)
     A                                 10  9' B: Purchasing#'
     A                                 10 37'*J: Part#'
     A                                      COLOR(WHT)
     A                                 11  9' C: Item#'
     A                                 11 37'*K: Invoice Date'
     A                                      COLOR(WHT)
     A                                 12  9' D: Plant'
     A                                 12 37' L: Order Qty'
     A                                 13  9'*E: Name'
     A                                      COLOR(WHT)
     A                                 13 37'*M: Received Qty'
     A                                      COLOR(WHT)
     A                                 14  9' F: Supp#'
     A                                 14 37'*N: Invoice Qty'
     A                                      COLOR(WHT)
     A                                 15  9' G: Manifest Status'
     A                                 15 37'*O: Price'
     A                                      COLOR(WHT)
     A                                 16  9' H: Tran Status'
     A                                 16 37'*P: Invoice Amount'
     A                                      COLOR(WHT)
     A                                 17  6'| A   |  B  |  C  |  D  | E:Name |-
     A                                        F  |  G  |  H  I I:Manifest# |'
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                 18  3'ex.| 001 | ---.| --- | --- | TMMAL-
     A                                        | --- | --- | --- | 82220653    |'
     A                                      COLOR(YLW)
     A                                 20  6'| J:Part#     | K:Inv Date |  L  |-
     A                                       M:Rcv Q | N:Inv Q | O:U/P  | P:Amt-
     A                                        |'
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                 21  3'ex.| 90105A02050 |  2/6/2024  | ---
     A                                      - |  900    |  1050   | 0.1367 | 14-
     A                                      3.54 |'
     A                                      COLOR(YLW)
     A            XMSG          70A  O 23  6COLOR(WHT)
     A                                 24  6'F1'
     A                                      DSPATR(RI)
     A                                 24  9'EXIT'
     A                                 24 21'ENTR'
     A                                      DSPATR(RI)
     A                                 24 26'Get and Check TMQTY.CSV    '
     A                                 24 59'F7'
     A                                      DSPATR(RI)
     A                                 24 62'create Invoice'
     A*
