     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  4 34'PART#         '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  4 49'RCV_QT'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  4 56'SHP_QT'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
