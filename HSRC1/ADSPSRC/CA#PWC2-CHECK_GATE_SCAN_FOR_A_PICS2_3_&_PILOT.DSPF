     A** CA#PWC2 *******************************************
     A*  CHECK GATE SCAN FOR A-PICS2/3 & PILOT             *
     A*              T.SAKASHITA 2020.10.19                *
     A*---------------------------------------------------------------*
     A*2021.07.07|TEC. |T.MITSUI  | A-PICS2 (19362)                   *
     A****************************************************** CA#PWC2 **
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A* ----------------------------------------------------
     A*   INPUT OPERATOR CODE
     A* ----------------------------------------------------
     A          R FMT100
     A                                      CF01(01 'END')
     A                                  1  2'T-'
     A                                  1  5TIME
     A                                  1 14'D-'
     A                                  1 17DATE EDTWRD('0  .  .  ')
     A                                  1 26'***  OPERATOR CODE INPUT-
     A                                        ***'
     A                                      DSPATR(RI)
     A                                  1 68'FMT CA#PWC21'
     A*
     A                                  4 10'OPERATOR CODE'
     A            F1OPCD         6A  B  4 27TEXT('OPERATOR')
     A                                      DSPATR(CS)
     A  40                                  DSPATR(RI PC)
     A*
     A                                 22 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            F1EMSG        60O    22 18TEXT('ERROR')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*
     A                                 24  9'EXIT'
     A                                 24 15'CMD-1'  DSPATR(RI)
     A                                 24 32'NEXT SCREEN'
     A                                 24 45'ENTER'  DSPATR(RI)
     A*
     A* ----------------------------------------------------
     A*   SCAN CHECK GATE BARCODE
     A* ----------------------------------------------------
     A          R FMT200
     A                                      CF03(03 'BACK')
     A                                  1  2'T-'
     A                                  1  5TIME
     A                                  1 14'D-'
     A                                  1 17DATE EDTWRD('0  .  .  ')
     A                                  1 30'*** CHECK GATE SCAN ***'
     A                                      DSPATR(RI)
     A                                  1 68'FMT CA#PWC22'
     A*
     A                                  2  3'OPERATOR CODE'
     A            F1OPCD         6A  O  2 20
     A            F2OPNM        20A  O  2 28TEXT('OPERATOR NAME')
     A*
     A                                  3  3'CHECK GATE BARCODE'
     A            F2BARC        20A  B  3 25DSPATR(CS)
     A  41                                  DSPATR(RI PC)
     A*
     A                                 22 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            F2EMSG        60O    22 18TEXT('ERROR')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*
     A                                 24  9'BACK'
     A                                 24 15'CMD-3'  DSPATR(RI)
     A                                 24 32'NEXT SCREEN'
     A                                 24 45'ENTER'  DSPATR(RI)
     A*
     A* ----------------------------------------------------
     A*   INPUT PROCESS #
     A* ----------------------------------------------------
     A*-------< SFL RECORD >-------*
     A          R FMT300S                   SFL
     A*
     A            @NO            2Y 0O  7  4TEXT('PROCESS NO')
     A                                      EDTCDE(Z)
     A  51                                  DSPATR(RI)
     A            AKOT           4A  O  7  8TEXT('PROCESS CODE')
     A  51                                  DSPATR(RI)
     A            AKOJ          10A  O  7 14TEXT('DEPARTMENT NAME')
     A  51                                  DSPATR(RI)
     A            AKBN           3A  O  7 28TEXT('MACHINE #')
     A  51                                  DSPATR(RI)
     A            ANOK           8Y 0O  7 35TEXT('PLAN DATE')
     A                                      EDTWRD('    /  /  ')
     A  51                                  DSPATR(RI)
     A            ANOB           8Y 0O  7 47TEXT('COMP.DATE')
     A                                      EDTWRD('    /  /  ')
     A            ATIM           4Y 0O  7 58TEXT('COMP.TIME')
     A                                      EDTWRD('0 :  ')
     A  52                                  DSPATR(ND)
     A            ATMN          10A  O  7 66TEXT('TM CODE')
     A*
     A            DHIN51         1A  H      TEXT('標識51 ')
     A            DHIN52         1A  H      TEXT('標識52 ')
     A            DHANOB         8Y 0H      TEXT('COMP.DATE')
     A            DHATIM         6Y 0H      TEXT('COMP.TIME')
     A*
     A*-------< SFL CONTROL >-------*
     A          R FMT300C
     A                                      SFLCTL(FMT300S)
     A  70                                  SFLCLR
     A N70                                  SFLDSPCTL
     A  71                                  SFLDSP
     A  71                                  SFLEND(*MORE)
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(15)
     A                                      SFLSIZ(16)
     A                                      CF03(03)
     A  61                                  CF05(05)
     A            #RRN1          4  0H      SFLRCDNBR
     A*
     A                                  1  2'T-'
     A                                  1  5TIME
     A                                  1 14'D-'
     A                                  1 17DATE EDTWRD('0  .  .  ')
     A                                  1 30'*** CHECK GATE SCAN ***'
     A                                      DSPATR(RI)
     A                                  1 68'FMT CA#PWC23'
     A*
     A                                  2  3'OPERATOR CODE'
     A            F1OPCD         6A  O  2 20TEXT('OPERATOR')
     A            F2OPNM        20A  O  2 28TEXT('OPERATOR NAME')
     A                                  2 51'PART NO. ->'
     A            F3PART        14A  O  2 63
     A*
     A                                  3  3'CHECK GATE BARCODE'
     A            F2BARC        20A  O  3 25
     A                                  3 51' LOT NO. ->'
     A            F3ZETI         4A  O  3 63
     A                                  3 68'-'
     A            F3TEHI         3Y 0O  3 70
     A                                      EDTWRD('0   ')
     A*
     A                                  5  4'INPUT YOUR PROCESS NO.'
     A            Q#PCNO         2Y 0B  5 29DSPATR(UL CS)
     A                                      EDTCDE(Z)
     A  42                                  DSPATR(RI PC)
     A  61                                  DSPATR(PR)
     A*
     A                                  6  4'NO. PROC. FACTORY     -
     A                                      MACHINE  PLAN DATE   -
     A                                      COMP.DATE-TIME     -
     A                                      TM NAME     '
     A                                      DSPATR(UL)
     A*
     A*-------< FOOTTER >-------*
     A          R FMT300
     A                                 23 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            F3EMSG        60O    23 18TEXT('ERROR')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*
     A                                 24  9'BACK'
     A                                 24 15'CMD-3'  DSPATR(RI)
     A*
     A N61                             24 32'NEXT SCREEN'
     A N61                             24 45'ENTER'  DSPATR(RI)
     A  61                             24 32'UPDATE'
     A  61                             24 40'CMD-5'  DSPATR(RI HI)
     A*
