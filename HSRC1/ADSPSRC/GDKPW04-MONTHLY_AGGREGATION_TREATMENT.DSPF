     A*** GDKPW04 <DSPF> *********************************************
     A*   MONTHLY AGGREGATION TREATMENT                              *
     A*   G.B.C                       97/07/25                       *
     A****************************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT(CS UL)
     A                                      PRINT
     A**************
     A* DSP1       *
     A**************
     A          R DSP01
     A                                      CF01
     A                                      CF05
     A                                      OVERLAY
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 26' MONTHLY AGGREGATION +
     A                                      TREATMENT '
     A                                      DSPATR(RI)
     A                                  1 69'FMT GDKPW04'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('  .  .  ')
     A                                  2 33'<< INPORT >>'
     A                                  9 23'EXCUTING MONTHLY +
     A                                      AGGREGATION TREATMENT '
     A                                      DSPATR(HI)
     A                                 12 29'MONTH'
     A            D1MMYY         6Y 0B 12 39EDTWRD('  /    ')
     A                                      CHECK(RB)
     A  11                                  DSPATR(RI)
     A  11                                  DSPATR(PC)
     A                                 12 48'(MM/YYYY)'
     A                                 14 29'RERUN'
     A            D1RUN          1A  B 14 39VALUES('Y' ' ')
     A  12                                  DSPATR(RI)
     A  12                                  DSPATR(PC)
     A                                 14 41'("Y" OR " ")'
     A**************
     A* DSP2       *
     A**************
     A          R DSP02
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A            D#MSG         60A  O 22 20
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24  9'END JOB'
     A                                 24 17' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 29'UPDATE'
     A                                 24 36' CMD-5 '
     A                                      DSPATR(RI)
