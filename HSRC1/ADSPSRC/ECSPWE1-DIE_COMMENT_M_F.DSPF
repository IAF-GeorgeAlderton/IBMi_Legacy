     A** ECSPWE1 *******************************************
     A* DIE COMMENT M/F
     A*       MAEDA.           2019.03.19                  *
     A******************************************************
     A                                      CHGINPDFT
     A                                      PRINT
     A          R ECSPWE11
     A  99                                  ALARM
     A                                      KEEP
     A                                      CF01(01)
     A                                      CF08(08)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                   + 1TIME  EDTWRD('0  :  :  ')
     A                                  1 28' ** DIE COMMENT M/F ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                   + 1'ECSPWE1'
     A                                  2  2'DATE'
     A                                   + 1DATE EDTWRD('0  .  .  ')
      *
     A                                  5  8'UPDATE' DSPATR(HI)
     A                                  5 27'DIE #' DSPATR(HI)
     A            D1UPD          1A  B  6 10DSPATR(CS)
     A  30                                  DSPATR(RI PC)
     A                                  6 13'0:DELETE'
     A                                  7 13'1:CHANGE'
     A                                  8 13'2:ADD NEW'
     A            D1KAT1         2A  B  6 27DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1KAT2         4A  B   + 1DSPATR(CS)
     A  31                                  DSPATR(RI PC)
      *
     A            Z1UPD          1A     9 10
     A            Z1KAT1         2A     9 27
     A                                   + 1'-'
     A            Z1KAT2         4A      + 1
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  7'EXIT'
     A                                   + 1' F1 '
     A                                      DSPATR(RI)
     A                                   + 2'INQ'
     A                                   + 1' F8 '
     A                                      DSPATR(RI)
      *
     A          R ECSPWE12
     A  99                                  ALARM
     A                                      KEEP
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                   + 1TIME  EDTWRD('0  :  :  ')
     A                                  1 28' ** DIE COMMENT M/F ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT'
     A                                   + 1'ECSPWE1'
     A                                  2  2'DATE'
     A                                   + 1DATE EDTWRD('0  .  .  ')
      *
     A                                  5  8'UPDATE' DSPATR(HI)
     A                                  5 27'DIE #' DSPATR(HI)
     A            D1UPD          1A     6 10
     A  30                                  DSPATR(RI PC)
     A                                  6 13'0:DELETE'
     A                                  7 13'1:CHANGE'
     A                                  8 13'2:ADD NEW'
     A            D1KAT1         2A     6 27
     A                                   + 1'-'
     A            D1KAT2         4A      + 1
      *
     A                                  9  8'MEMO' DSPATR(HI)
     A            D1TXT1        20A  B 10 10DSPATR(CS)
     A  29                                  DSPATR(PR)
     A            D1TXT2        20A  B 12 10DSPATR(CS)
     A  29                                  DSPATR(PR)
     A            D1TXT3        20A  B 14 10DSPATR(CS)
     A  29                                  DSPATR(PR)
     A            D1TXT4        20A  B 16 10DSPATR(CS)
     A  29                                  DSPATR(PR)
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  7'BACK'
     A                                   + 1' F3 '
     A                                      DSPATR(RI)
