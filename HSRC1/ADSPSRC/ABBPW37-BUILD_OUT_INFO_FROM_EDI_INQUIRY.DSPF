      ** ABBPW37 ******************************************************
      * BUILD OUT INFO. FROM EDI INQUIRY
      *  KIRI                                                2018.08.03
      *****************************************************************
     A                                      CHGINPDFT
     A                                      PRINT(*LIBL/QPRINT)
      *-------------------------------------
     A          R DSP01
     A                                      CF01
     A                                      BLINK
     A  99                                  ALARM
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22' ** BUILD OUT INFO. -
     A                                      FROM EDI INQUIRY ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT'
     A                                  1 72'ABBPW37'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
      ***
     A                                  4 08'RECEIVE DATE'
     A*                                     DSPATR(UL)
     A            D1DAT1         8  0B  4 25TEXT('ISSUE DATE')
     A                                      DSPATR(CS) EDTCDE(4)
     A  21                                  DSPATR(PC RI)
     A                                   + 2'TO'
     A            D1DAT2         8  0B   + 2TEXT('ISSUE DATE')
     A                                      DSPATR(CS) EDTCDE(4)
     A  22                                  DSPATR(PC RI)
     A*
     A                                  5 25'YYYYMMDD'
     A                                  5 39'YYYYMMDD'
      ***
     A                                  7 08'IAF PART #'
     A            D1SHN1         5   B  7 25TEXT('PART #1')
     A                                      DSPATR(CS)
     A  23                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1SHN2         5   B   + 1TEXT('PART #2')
     A                                      DSPATR(CS)
     A  23                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1SHN3         2   B   + 1TEXT('PART #3')
     A                                      DSPATR(CS)
     A  23                                  DSPATR(PC RI)
     A*
     A                                   + 2'( BLANK = ALL )'
      ***
     A                                  9 08'CUSTOMER PART #'
     A            D1MHN1         5   B  9 25TEXT('USER PART1')
     A                                      DSPATR(CS)
     A  24                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1MHN2         5   B   + 1TEXT('USER PART2')
     A                                      DSPATR(CS)
     A  24                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1MHN3         5   B   + 1TEXT('USER PART3')
     A                                      DSPATR(CS)
     A  24                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1MHN4         5   B   + 1TEXT('USER PART4')
     A                                      DSPATR(CS)
     A  24                                  DSPATR(PC RI)
     A                                   + 2'( BLANK = ALL )'
      ***
     A                                 11  8'CUSTOMER'
     A            D1TOKU         4   B 11 25TEXT('CUSTOMER')
     A                                      DSPATR(CS)
     A  25                                  DSPATR(PC RI)
     A                                   + 2'( BLANK = ALL )'
      ***
     A                                 12  8'DELIVERY'
     A            D1NONY         4   B 12 25TEXT('DELIVERY CODE')
     A                                      DSPATR(CS)
     A  26                                  DSPATR(PC RI)
     A                                   + 2'( BLANK = ALL )'
      ***
     A                                 13  8'FACTORY'
     A            D1NKOJ         1   B 13 25TEXT('FACTORY')
     A                                      DSPATR(CS)
     A  27                                  DSPATR(PC RI)
     A                                 13 31'( BLANK = ALL )'
      ***
     A                                 14  8'DOCK'
     A            D1NUKE         4   B 14 25TEXT('DOCK')
     A                                      DSPATR(CS)
     A  28                                  DSPATR(PC RI)
     A                                 14 31'( BLANK = ALL )'
      ***
      ***
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18        DSPATR(HI BL)
      *
      * *
     A                                 24  5' EXIT F1 '
     A                                      DSPATR(RI)
      *----------------------------------------------------------------
      *
      *----------------------------------------------------------------
      *         1         2         3         4         5         6
      *123456789012345678901234567890123456789012345678901234567890
      * RECEIVE DATE  YYYY.MM.DD  TO  YYYY.MM.DD
      * IAF PART #    12345-12345-XX        CUSTOMER PART #   12345-
      * CUST-DELV-FACT-DOCK   XXXX - XXXX - X - XXXX
      *
      *         1         2         3         4         5         6
      *123456789012345678901234567890123456789012345678901234567890
      *                        CUSTOMER PART #         FIRST RCV
      *   CUST DELV FACT DOCK  IAF PART #               LAST RCV
      * X 8888 8888  X   XXXX  XXXXX-XXXXX-XXXXX-XXXXX YYYY.MM.DD
      *                        XXXXX-XXXXX-XX
      *
      *         1         2         3         4         5         6
      *         5         6         7         8
      *123456789012345678901234567890123456789012345678901234567890
      *        FIRST RCV - SCHEDULE DATE
      *          LAST RCV - SCHEDULE DATE
      *        YYYY.MM.DD - YYYY.MM.DD
      *          YYYY.MM.DD - YYYY.MM.DD
      *
     A*
     A          R SFREC1                    TEXT('SUBFILE')
     A                                      SFL
     A            S1SEL          1   B  8  2TEXT('SELECT')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A            S1TOKU         4      8  4TEXT('CUSTOMER')
     A            S1NONY         4      8  9TEXT('DELIVERY CODE')
     A            S1NKOJ         1      8 15TEXT('FACTORY')
     A            S1NUKE         4      8 19TEXT('DOCK')
     A            S1MHN         23      8 25TEXT('USER PART1')
     A            S1RCDT         8  0   8 49TEXT('RCV DATE')
     A                                      EDTWRD('    .  .  ')
     A                                  8 60'-'
     A            S1SDAT         8  0   8 62TEXT('SCHEDULE DATE')
     A                                      EDTWRD('    .  .  ')
     A            S1SHN         14      9 25TEXT('IAF PART1')
     A            S2RCDT         8  0   9 51TEXT('RCV DATE')
     A                                      EDTWRD('    .  .  ')
     A                                  9 62'-'
     A            S2SDAT         8  0   9 64TEXT('SCHEDULE DATE')
     A                                      EDTWRD('    .  .  ')
     A            S1SEBN         4   H      TEXT('ID#')
     A*
     A*
     A          R SFCTL1                    TEXT('SUBFILE CONTROL')
     A                                      SFLCTL(SFREC1)
     A                                      OVERLAY PROTECT
     A                                      CF03 BLINK
     A  99                                  ALARM
      *
     A  71                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  73                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      SFLPAG(7) SFLSIZ(8)
     A                                      ROLLUP(75)
     A                                      ROLLDOWN(76)
     A            RRN            4  0H      SFLRCDNBR
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22' ** BUILD OUT INFO. -
     A                                      FROM EDI INQUIRY ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT'
     A                                  1 72'ABBPW37'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
      ***
      ***
     A                                  3  2'RECEIVE DATE'
     A                                      DSPATR(UL)
     A            D1DAT1         8  0   3 16TEXT('RECEIVE DATE')
     A                                      EDTWRD('    .  .  ')
     A                                   + 2'TO'
     A            D1DAT2         8  0    + 2TEXT('RECEIVE DATE')
     A                                      EDTWRD('    .  .  ')
      ***
     A                                  4  2'IAF PART #'
     A                                      DSPATR(UL)
     A            D2SHN         14      4 16TEXT('PART #')
     A                                  4 38'CUSTOMER PART #'
     A                                      DSPATR(UL)
     A            D2MHN         23      4 56TEXT('PART #')
      ***
     A                                  5  2'CUST-DELV-FACT-DOCK'
     A                                      DSPATR(UL)
     A            D1TOKU         4      5 24TEXT('CUSTOMER')
     A                                   + 1'-'
     A            D1NONY         4       + 1TEXT('DELIVERY CODE')
     A                                   + 1'-'
     A            D1NKOJ         1       + 1TEXT('FACTORY')
     A                                   + 1'-'
     A            D1NUKE         4       + 1TEXT('DOCK')
     A*
      ***
     A                                  6 25'CUSTOMER PART #'
     A                                  6 49'FIRST RCV -'
     A                                  6 61'SCHEDULE DATE'
      *
     A                                  7  2'  CUST DELV FACT DOCK -
     A                                       IAF PART #      -
     A                                                LAST RCV --
     A                                       SCHEDULE DATE'
     A                                      DSPATR(UL)
      *         1         2         3         4         5         6
      *123456789012345678901234567890123456789012345678901234567890
      *                       CUSTOMER PART #         FIRST RCV
      *   CUST DELV FACT DOCK IAF PART #               LAST RCV
      * X 8888 8888  X   XXXX XXXXX-XXXXX-XXXXX-XXXXX YYYY.MM.DD
      *                       XXXXX-XXXXX-XX
      *
      *         1         2         3         4         5         6
      *         5         6         7         8
      *123456789012345678901234567890123456789012345678901234567890
      *       FIRST RCV - SCHEDULE DATE
      *         LAST RCV - SCHEDULE DATE
      *----------------------------------------------------------------
      *
      *----------------------------------------------------------------
     A          R DSP02                     TEXT('COMMAND EXPLANATION')
     A N99                             23  2'+-> M-DETAIL'
     A  99                             23 11'ERROR' DSPATR(RI BL)
     A  99        D2ERR         60A  O 23 18        DSPATR(HI BL)
     A*
     A                                 24  5' BACK F3 '
     A                                      DSPATR(RI)
     A                                 24 65'PAGE-DOWN/UP'
     A                                      DSPATR(RI)
      *----------------------------------------------------------------
      *
      *----------------------------------------------------------------
