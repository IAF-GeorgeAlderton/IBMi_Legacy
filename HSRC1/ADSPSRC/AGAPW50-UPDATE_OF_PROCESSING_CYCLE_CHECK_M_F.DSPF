      ******  AGAPW50  **************************************
      *     UPDATE OF PROCESSING CYCLE CHECK M/F            *
      *                              WRITTEN ==> S.OOTAKE   *
      *                              UPDATE  ==> 93/07/06   *
      ***************************************  AGAPW50  *****
     A                                      PRINT(QPRINT)
     A                                      CHGINPDFT
      *
     A          R AGAPW501                  CF01
     A                                      HELP(45 'HELP KEY')
     A  99                                  ALARM
     A                                      BLINK PUTOVR KEEP
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
     A                                  1 19' ** UPDATE OF +
     A                                      PROCESSING CYCLE +
     A                                      CHECK M/F ** '
     A                                      DSPATR(RI)
     A                                  1 67'FMT AGAPW50'
      *************************************
      ***     UPDATE INSTRUCTION        ***
      *************************************
     A                                  5 17'UPDATE INSTRUCTION'
     A                                      DSPATR(RI)
     A            SKUBN          1   B  5 43DSPATR(CS) OVRDTA
     A                                      OVRATR
     A  01                                  DSPATR(RI PC)
     A                                  5 45'<-------'
     A                                  5 54'************'
     A                                  6 54'* 0=CANCEL *'
     A                                  7 54'* 1=CHANGE *'
     A                                  8 54'* 2=ADD    *'
     A                                  9 54'************'
      **************************************
      *** PRECEDING PROCESS SECTION CODE ***
      **************************************
     A                                  7  8' 1 +
     A                                      PRECEDING PROCESS SECTION CODE'
     A                                      DSPATR(RI)
     A            SMAECD         4   B  7 43DSPATR(CS) OVRDTA
     A                                      OVRATR
     A  02                                  DSPATR(PC RI)
      *************************************
      ***   PLATING SECTION CODE        ***
      *************************************
     A                                  9  8' 2 +
     A                                      PLATING SECTION CODE'
     A                                      DSPATR(RI)
     A            SMEKCD         4   B  9 43DSPATR(CS) OVRDTA
     A                                      OVRATR
     A  03                                  DSPATR(PC RI)
      **************************************
      *** SECOND PROCESSING SECTION CODE ***
      **************************************
     A                                 11  8' 3 +
     A                                      SECOND PROCESSING SECTION +
                                            CODE'
     A                                      DSPATR(RI)
     A            SKAKCD         4   B 11 43DSPATR(CS) OVRDTA
     A                                      OVRATR
     A  04                                  DSPATR(PC RI)
      *************************************
      ***    MESSAGE DISPLAY            ***
      *************************************
     A                                 22 11'ERROR'
     A                                      OVRATR
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            MSG           60   O 22 18
     A                                      OVRDTA OVRATR
     A N99                                  DSPATR(ND)
      *
     A                                 24  4'WORK EXIT'
     A                                 24 16' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 45'SECTION CODE INQUIRY'
     A                                 24 68' HELP '
     A                                      DSPATR(RI)
      *
      ********************************************
      *         THE NEXT SCREEN                  *
      ********************************************
     A          R AGAPW502                  CF03
     A                                      CF05
     A  99                                  ALARM
     A                                      BLINK PUTOVR KEEP
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
     A                                  1 19' ** UPDATE OF +
     A                                      PROCESSING CYCLE+
     A                                      CHECK M/F ** '
     A                                      DSPATR(RI)
     A                                  1 67'FMT AGAPW50'
      ********************************************
      *  DISPLAY OF PRECEDING PROCESS SECTION    *
      ********************************************
     A                                  5  4'PRECEDING PROCESS SECTION'
     A                                      DSPATR(RI)
     A            SMAECD         4   O  7  6OVRDTA
     A            DMAENM        15   O  7 11OVRDTA
     A            SMAEHI         2Y 0B  9  8EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N91                                  DSPATR(CS)
     A  91                                  DSPATR(PR)
     A  30                                  DSPATR(RI PC)
     A                                  9 11':'
     A                                      OVRATR
     A  94                                  DSPATR(ND)
     A            SMAEBN         2Y 0B  9 13EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N91                                  DSPATR(CS)
     A  91                                  DSPATR(PR)
     A  31                                  DSPATR(RI PC)
     A                                  9 16':'
     A                                      OVRATR
     A  94                                  DSPATR(ND)
     A            SMAECI         2Y 0B  9 18EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N91                                  DSPATR(CS)
     A  91                                  DSPATR(PR)
     A  32                                  DSPATR(RI PC)
      ********************************************
      *            PLATING SECTION               *
      ********************************************
     A                                  5 32'PLATING SECTION'
     A                                      DSPATR(RI)
     A            SMEKCD         4   O  7 30OVRDTA
     A            DMEKNM        15   O  7 35OVRDTA
     A            SMEKHI         2Y 0B  9 32EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N92                                  DSPATR(CS)
     A  92                                  DSPATR(PR)
     A  33                                  DSPATR(RI PC)
     A                                  9 35':'
     A                                      OVRATR
     A  95                                  DSPATR(ND)
     A            SMEKBN         2Y 0B  9 37EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N92                                  DSPATR(CS)
     A  92                                  DSPATR(PR)
     A  34                                  DSPATR(RI PC)
     A                                  9 40':'
     A                                      OVRATR
     A  95                                  DSPATR(ND)
     A            SMEKCI         2Y 0B  9 42EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N92                                  DSPATR(CS)
     A  92                                  DSPATR(PR)
     A  35                                  DSPATR(RI PC)
      ********************************************
      *       SECOND PROCESSING SECTION          *
      ********************************************
     A                                  5 52'SECOND PROCESSING SECTION'
     A                                      DSPATR(RI)
     A            SKAKCD         4   O  7 54OVRDTA
     A            DKAKNM        15   O  7 59OVRDTA
     A            SKAKHI         2Y 0B  9 56EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N93                                  DSPATR(CS)
     A  93                                  DSPATR(PR)
     A  36                                  DSPATR(RI PC)
     A                                  9 59':'
     A                                      OVRATR
     A  96                                  DSPATR(ND)
     A            SKAKBN         2Y 0B  9 61EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N93                                  DSPATR(CS)
     A  93                                  DSPATR(PR)
     A  37                                  DSPATR(RI PC)
     A                                  9 64':'
     A                                      OVRATR
     A  96                                  DSPATR(ND)
     A            SKAKCI         2Y 0B  9 66EDTCDE(Z)
     A                                      OVRDTA  OVRATR
     A N93                                  DSPATR(CS)
     A  93                                  DSPATR(PR)
     A  38                                  DSPATR(RI PC)
      *************************************
      ***      MESSAGE DISPLAY          ***
      *************************************
     A                                 22 11'ERROR'
     A                                      OVRATR
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            MSG           60   O 22 18
     A                                      OVRDTA OVRATR
     A N99                                  DSPATR(ND)
      *
     A                                 24 11'KEY INPUT'
     A                                 24 23' CMD-3 '
     A                                      DSPATR(RI)
     A                                 24 36'UPDATE OK'
     A                                 24 48' CMD-5 '
     A                                      DSPATR(RI)
