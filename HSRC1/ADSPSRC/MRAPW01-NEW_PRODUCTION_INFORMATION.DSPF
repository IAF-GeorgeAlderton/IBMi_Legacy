     A** MRAPW01 *******************************************
     A* NEW PRODUCTION INFORMATION                         *
     A*     TRANCOM ITS.                  2012.09.11       *
     A******************************************************
     A                                      PRINT(QPRINT)
     A                                      CHGINPDFT
     A          R MRAPW011
     A                                      CF01(01)
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** NEW PRODUCTION +
     A                                       INFORMATION ** '
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'MRAPW01'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
      *
     A                                  4 19'-->'
     A                                  4 23'INPUT INHOUSE PART NO.'
     A                                      DSPATR(RI)
     A            D1SHN1         5A  B  6 23DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1SHN2         5A  B   + 1DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1SHN3         2A  B   + 1DSPATR(CS)
     A  31                                  DSPATR(PC RI)
      *
     A                                  8 19'-->'
     A                                  8 23'PART OR COMPONENT?'
     A                                      DSPATR(RI)
     A            D1SEKB         1A  B 10 23DSPATR(CS)
     A  32                                  DSPATR(PC RI)
     A                                 10 27'1:PART'
     A                                 10 36'2:COMPONENT PART'
      *
     A                                 12 19'-->'
     A                                 12 23'PRODUCTION LOCATION'
     A                                      DSPATR(RI)
     A            D1PRKB         1A  B 14 23DSPATR(CS)
     A  33                                  DSPATR(PC RI)
     A                                 14 27'1:LOCAL PRODUCTION'
     A                                 14 52'2:PATH-THRU'
     A                                 15 27'3:BLANK PATH-THRU'
     A                                 15 52'4:LOCAL PURCHASE'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2'EXIT'
     A                                   + 1' F1 ' DSPATR(RI)
     A                                   + 2'NEXT SCREEN'
     A                                   + 1' ENTER ' DSPATR(RI)
