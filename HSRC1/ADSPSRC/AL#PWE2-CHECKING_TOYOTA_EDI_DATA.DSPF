     A** AL#PWE2 ***********************************
     A* CHECKING TOYOTA EDI DATA                   *
     A*     ITS.    2015.05.21                     *
     A**********************************************
     A                                      PRINT
     A                                      CHGINPDFT
      *------------------------*
      *                        *
      *------------------------*
     A          R SFL                       SFL
     A            S1NONY         4A     5  4
     A            S1NKOJ         1A     5 11
     A            S1NUKE         4A     5 16
     A            S1MHN         12A     5 22
     A            S1ORD#        12A     5 35
     A            S1BIN#         2A     5 49
     A            S1SRYO         8Y 0   5 53EDTWRD('      0 ')
     A            S1WEBS         8Y 0   5 63EDTWRD('      0 ')
      *非表示項目
     A            @RRN           4Y 0H
      *
      *---------------------------------------*
      *  サブファイル制御　                 *
      *---------------------------------------*
     A          R SFLCTL
     A                                      SFLCTL(SFL)
     A  72                                  SFLDSPCTL
     A  72                                  ERASE(SFL)
     A  73                                  SFLDSP
     A  71                                  SFLCLR
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(16)
     A                                      SFLSIZ(16)
     A                                      CF03(03)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3  0H
     A            S@SCLM         3  0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22' ** CHECKING TOYOTA EDI DATA +
     A                                        ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AL#PWE2'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  3  7'SHIP DATE' DSPATR(HI)
     A            D1SHID         8Y 0   3 21EDTWRD('    /  /  ')
     A                                  4  2'  DELI  FACT  DOCK  +
     A                                       USER PART#   +
     A                                       ORDER#       BIN#      +
     A                                       QTY   WEB QTY   '
     A                                      DSPATR(UL)
     A          R AL#PWE29
     A                                      OVERLAY PROTECT
     A N81                             22 72'MORE...'
     A  81                             22 72'LAST...'
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D9ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F3 '
     A                                      DSPATR(RI)
     A                                   + 1'BACK'
     A                                   + 2'PAGE UP'
     A                                   + 1'PRV'
     A                                      DSPATR(RI)
     A                                   + 2'PAGE DOWN '
     A                                   + 1'NEXT'
     A                                      DSPATR(RI)
