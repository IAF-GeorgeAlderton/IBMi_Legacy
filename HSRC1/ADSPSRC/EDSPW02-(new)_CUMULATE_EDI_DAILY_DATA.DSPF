     A                                      #EP40B)'
     A                                      COLOR(WHT)
     A                                 12 17'Press F5 to Run...'
     A                                      COLOR(YLW)
     A                                 22  9' '
     A                                 23 17'F1'
     A                                      DSPATR(RI)
     A                                 23 20'Exit,'
     A                                 23 28'F5'
