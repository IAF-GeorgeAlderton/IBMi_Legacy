     A** AB#PWM1 ***********************************
     A* UPDATE OF CUT OFF TIME MASTER              *
     A*          KIRI             14.08.08         *
     A*********************************** AB#PWM1 **
     A                                      CHGINPDFT
     A                                      PRINT
      *-------------------------------------
      *-------------------------------------
     A          R DSP01
     A                                      CF01 CF12
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** CUT OFF TIME MASTER ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT AB#PWM1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  5 22'UPDATE'   DSPATR(UL)
     A                                  5 32' DELV.'  DSPATR(UL)
     A                                  5 42' BIN ' DSPATR(UL)
     A*
     A            D1TYPE         1A  B  7 24DSPATR(CS)
     A  21                                  DSPATR(PC RI)
     A*
     A            D1NONY         4A  B  7 33TEXT('DELIVERY CODE')
     A                                      DSPATR(CS)
     A  22                                  DSPATR(PC RI)
     A            D1BIN          2A  B  7 43TEXT('BIN')
     A                                      DSPATR(CS)
     A  23                                  DSPATR(PC RI)
     A*
     A                                 10 24'0- CANCEL '
     A                                 11 24'1- CHANGE '
     A                                 12 24'2- ADD    '
     A                                 13 24'3- UPDATE '
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
     A*
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
     A                                 24 66' F12 ' DSPATR(RI)
     A                                   + 1'INQUIRY'
      *-------------------------------------
      *-------------------------------------
     A          R DSP02
     A                                      CF03 CF05
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** CUT OFF TIME MASTER ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT AB#PWM1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  5 20' UPDATE '   DSPATR(UL)
     A                                  5 32' DELV.'  DSPATR(UL)
     A                                  5 42' BIN ' DSPATR(UL)
     A*
     A            D2TYPE         8      6 20
     A            D1NONY         4      6 33TEXT('DELIVERY CODE')
     A            D1BIN          2      6 43TEXT('BIN')
     A            D2SMEI        15      8 33TEXT('DETAIL NAME KANA')
     A*
     A                                 11 32'OLD TIME'   DSPATR(UL)
     A                                 11 42'NEW TIME'   DSPATR(UL)
     A                                 11 52'CHAGE DATE' DSPATR(UL)
     A*
     A            D2OTJJ         2   B 13 32TEXT('OLD TIME')
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A  31                                  DSPATR(PC RI)
     A                                   + 1':'
     A            D2OTFF         2   B   + 1TEXT('OLD TIME')
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A  32                                  DSPATR(PC RI)
     A            D2NTJJ         2   B 13 42TEXT('NEW TIME')
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A N99 39
     AO 33                                  DSPATR(PC)
     A  33                                  DSPATR(RI)
     A                                   + 1':'
     A            D2NTFF         2   B   + 1TEXT('NEW TIME')
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A  34                                  DSPATR(PC RI)
     A            D2CHGD         8  0B 13 53TEXT('CHAGE DATE')
     A N30                                  DSPATR(CS)
     A  30                                  DSPATR(PR)
     A                                      EDTCDE(4)
     A  35                                  DSPATR(PC RI)
     A* **
     A  39                             16 30'CURRENT'
     A  39                             17 32'OLD TIME'   DSPATR(UL)
     A  39                             17 42'NEW TIME'   DSPATR(UL)
     A  39                             17 53'CHAGE DATE' DSPATR(UL)
     A  39        D$OTIM         4  0  18 34TEXT('OLD TIME')
     A                                      EDTWRD('0  :  ')
     A  39        D$NTIM         4  0  18 44TEXT('NEW TIME')
     A                                      EDTWRD('0  :  ')
     A  39        D$CHGD         8  0  18 53TEXT('CHAGE DATE')
     A                                      EDTWRD('    .  .  ')
     A* **
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D2ERR         60A  O 22 18
     A*
     A                                 24  4' F3 ' DSPATR(RI)
     A                                   + 1'PREV. SCREEN'
     A                                   + 4' F5 ' DSPATR(RI)
     A                                   + 1'UPDATE OK'
     A*-------------------------------------
