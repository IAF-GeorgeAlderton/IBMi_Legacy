      *
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R ANYPW2A1
     A                                      CF03(03)
      *
     A                                  1  2'DATE'
     A                                  1  7DATE
     A                                      EDTCDE(Y)
     A                                  1 22' ST ONEWAY KANBAN ABNORMAL -
     A                                      DETECTION INQUIRY '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                      COLOR(RED)
     A            #PGM           8A  O  1 72
     A                                  2  2'TIME'
     A                                  2  7TIME
      *
     A                                  7  9'PART NO.'
     A            D1SHN1         5A  B  7 19DSPATR(CS)
     A  30                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1SHN2         5A  B   + 1DSPATR(CS)
     A  30                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1SHN3         2A  B   + 1DSPATR(CS)
     A  30                                  DSPATR(RI PC)
      *
     A                                  9  9'LOCATION'
     A****        D1MTK1         1      9 19
     A**35                                  DSPATR(RI PC)
     A****                               + 1'-'
     A            D1MTK2         2A  B   + 2DSPATR(CS)
     A  35                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1MTK3         2A  B   + 1DSPATR(CS)
     A  35                                  DSPATR(RI PC)
     A****                               + 1'-'
     A****        D1MTK4         1       + 1
     A**35                                  DSPATR(RI PC)
      *
     A                                   + 3'TO'
     A****        D1TTK1         1       + 1
     A**36                                  DSPATR(RI PC)
     A*****                              + 1'-'
     A            D1TTK2         2A  B   + 3DSPATR(CS)
     A  36                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1TTK3         2A  B   + 1DSPATR(CS)
     A  36                                  DSPATR(RI PC)
     A*****                              + 1'-'
     A*****       D1TTK4         1       + 1
     A**36                                  DSPATR(RI PC)
      *
     A  99                             23 11' ERR '
     A                                      DSPATR(RI)
     A                                      DSPATR(BL)
     A            D1ERR         60O       +2
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A                                 24  7'END'
     A                                   + 1' F3 '
     A                                      DSPATR(RI)
      *----------------*
      *ウィンドウ枠  *
      *----------------*
     A          R WIND1
     A                                      OVERLAY
     A*                                     PROTECT
      *                                            A  B  C   D
     A                                      WINDOW(9 21  07  40)
     A                                      WDWBORDER((*DSPATR RI HI) (*CHAR ' -
     A                                             '))
     A                                      RMVWDW
     A                                      USRRSTDSP
     A                                      WDWTITLE((*TEXT ''))
      *
     A          R ANYPW2AZ
     A                                      OVERLAY PROTECT
     A                                      WINDOW(WIND1)
     A                                      CF03(03)
     A                                      CF05(05)
      *
     A                                  2  4'LOCATION OR PARTS NUMBAR IS BLANK'
     A                                  3  4'MAY I CONTINUE? '
     A                                  6  4'NO = F3 YES = F5'
