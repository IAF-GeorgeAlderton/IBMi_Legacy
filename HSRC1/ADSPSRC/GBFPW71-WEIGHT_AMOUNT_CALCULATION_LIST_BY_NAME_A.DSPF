     A                                      PRINT
     A                                      CHGINPDFT
     A          R GBFPW711
     A                                      CF01
     A*                                 1 3'DATE'
     A*                                 1 8DATE EDTCDE(Y)
     A                                  1 68'FMT GBFPW711'
     A                                  1 10'WEIGHT / AMOUNT TOTALIZATION LIST +
     A                                       CREATE BY NAME'
     A                                      DSPATR(RI UL)
     A                                  4 10'QUENCHING CONDITION'
     A                                      DSPATR(UL)
     A            YKBN           1A  B  4 36DSPATR(HI CS)
