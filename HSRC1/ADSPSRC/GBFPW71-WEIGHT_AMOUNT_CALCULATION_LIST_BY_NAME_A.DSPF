     A                                 16 36'B = THIS TERM RESULT B'
     A                                 17 36'C = NEXT TERM PLAN C'
     A  99                             22  8'ABNORMAL'
     A                                      DSPATR(RI BL)
     A  99        MSG           60A  O 22 17
     A                                      DSPATR(HI)
     A                                 24 11'CANCEL'
     A                                 24 18'CMD-1'
     A                                      DSPATR(RI)
     A          R GBFPW712
     A                                      OVERLAY
