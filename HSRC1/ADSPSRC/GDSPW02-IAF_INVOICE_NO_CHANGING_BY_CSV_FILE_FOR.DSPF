     A*** GDSPW02 ****************************************
     A* INVOICE NO. CHANGING BY CSV FILE FOR DIES        *
     A*     NAMSU.KIM               2022.02.17           *
     A**************************************** GDSPW02 ***
     A                                      PRINT
     A                                      CHGINPDFT
     A*
     A          R GDSPW021                  CF01(01) CF05(05)
     A  99                                  ALARM
     A                                      BLINK
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22'INVOICE NO. CHANGING BY CSV FILE +
                                            FOR DIES'
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'GDSPW02'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  /  /  ')
      *
     A                                  6 12'IAF CODE:'
     A            @SIRE          4   B   + 1DSPATR(CS) AUTO(RAZ)
     A  31                                  DSPATR(RI PC)
      *
     A                                 10 14'INVOICE NO. CHANGING +
     A                                       CSV FILE(FOR DIES) WILL BE  +
     A                                       UPLOADED TO AS400.'
     A                                      DSPATR(UL)
     A                                 16 22'PELASE BE CAREFULE BELOW.'
     A                                      DSPATR(HI BL)
     A                                 18 26'*FILE NAME :IAF INVOICE DATA +
     A                                       CHANGE DIES.CSV'
     A                                      DSPATR(HI BL)
     A                                 19 26'*LOCATION  : C:$AS400$DATA$'
     A                                      DSPATR(HI BL)
     A*エラー行
     A                                 22 11'ERROR'
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            @ERR          60O    22 17
     A N99                                  DSPATR(ND)
     A*コマンド行
     A                                 24  2'EXIT'
     A                                 24 13'CMD-1'
     A                                      DSPATR(RI)
     A                                 24 48'UPLOAD'
     A                                 24 59' CMD-5 '
     A                                      DSPATR(RI)
