     A** INVPW1D ***********************************
     A* PART OR WASHER SCAN DATA UPDATE            *
     A*          KIRI             14.08.05         *
     A*********************************** INVPWS1 **
     A                                      CHGINPDFT
     A                                      PRINT
      *-------------------------------------
     A          R INVPW1D1
     A                                      CF01(01)
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 19' ** PART OR WASHER SCAN DATA+
                                             UPDATE **'
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT INVPW1D1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  7 34'1: PART     '
     A                                 10 34'2: WASHER   '
     A                                 13 34'3: P/T PART '
     A*
     A            D1NO           1A  B  7 30DSPATR(CS)
     A  11                                  DSPATR(PC RI)
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        MSG           60A  O 22 18
     A*
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
