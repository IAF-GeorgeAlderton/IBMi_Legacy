      *** GDIPW11 ****************************************************
      *    ORDER FIXED HANDING / DAYLY ORDER FILE ADD&CHANGE
      *     G.B.C                        97/04/10
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS)
     A**************
     A* ＤＳＰ１ *
     A**************
     A          R DSP01                     CF01
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 19' DAILY CORRECTION & ADDIT-
     A                                      ION OF ORDERS '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW11'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  7 11'TREATMENT CLASSIFICATION'
     A                                  7 47'DIE NO.'
     A            D1OPT          1   B  9 17
     A  11                                  DSPATR(RI PC)
     A                                  9 19'--------- 0:DELETION'
     A                                 10 29'1:CORRECTION'
     A                                 11 29'2:ADDITION'
     A            D1KAT1         2   B  9 47
     A  12                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1KAT2         4   B   + 1AUTO(RAZ)
     A  12                                  DSPATR(RI)
     A                                   + 1'-'
     A            D1KAT3         1   B   + 1
     A  12                                  DSPATR(RI)
     A                                   + 1'-'
     A            D1KAT4         1   B   + 1
     A  12                                  DSPATR(RI)
     A*
     A                                 22 10' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 19
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24  9'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A**************
     A* ＤＳＰ２ *
     A**************
     A          R DSP02                     CF01 CF03 CF05
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 19' DAILY CORRECTION & ADDIT-
     A                                      ION OF ORDERS '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW11'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  6 15'DIE NO.'
     A            D2KATA        11      8 15
     A  80                              8 41' DELETION   '
     A                                      DSPATR(RI)
     A  81                              8 41' CORRECTION '
     A                                      DSPATR(RI)
     A  82                              8 41' ADDITION   '
     A                                      DSPATR(RI)
     A                                 12 21'BOX'
     A            D2MAIS         5Y 0B 12 40EDTCDE(4)  CHECK(RB)
     A  21                                  DSPATR(RI PC)
     A  29                                  DSPATR(PR)
     A                                 14 21'CONTAINRTS'
     A            D2SYOS         7Y 0O 14 36EDTCDE(1)
     A                                 16 21'ORDER QTY'
     A            D2SURY         7Y 0O 16 36EDTCDE(1)
     A*                                18 21'ORDER DATE'
     A*           D2DATE         8Y 0O 18 36EDTCDE(1)
     A* 22                                  DSPATR(RI PC)
     A*
     A                                 22 10' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 19
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24  9'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 30'PRV SCREEN'
     A                                   + 1' CMD-3 '
     A                                      DSPATR(RI)
     A                                 24 54'INPUT OK'
     A                                   + 1' CMD-5 '
     A                                      DSPATR(RI)
