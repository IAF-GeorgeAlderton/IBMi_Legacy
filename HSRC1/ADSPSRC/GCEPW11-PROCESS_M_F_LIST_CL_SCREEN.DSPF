     A** GCEPW11 ***************************************
     A* PROCESS M/F LIST CL SCREEN *
     A*            I-HASADA         86.10.29           *
     A*************************************** GCEPW11 **
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT(*LIBL/QPRINT)
     A*
     A          R GCEPW111
     A                                      CHGINPDFT
     A                                      TEXT('PROCESS M/F LIST')
     A                                      CF01(01)
     A                                  1  3TIME
     A                                  1 17'* PROCESS M/F LIST THAT P-
     A                                      ARM APPOINTED MAKING *'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 72DATE
     A                                      EDTCDE(Y)
     A                                  3  6'WHICH ORDER DO YOU MAKE LIST ?'
     A                                  5  6'1.'
     A                                      DSPATR(UL)
     A                                  5  9'ALL PART NUMBER'
     A                                  5 44'2.'
     A                                      DSPATR(UL)
     A                                  5 47'PER DAY NECESSARY BOXES'
     A                                  6  6'3.'
     A                                      DSPATR(UL)
     A                                  6  9'PER DAY RESULTS BOXES'
     A                                  6 44'4.'
     A                                      DSPATR(UL)
     A                                  6 47'COMPLETION LOCATION CODE'
     A                                  7  6'5.'
     A                                      DSPATR(UL)
     A                                  7  9'INTRA-PROCESS LOCATION CODE'
     A            FNO            1A  B  9 22DSPATR(CS)
     A  02                                  DSPATR(RI)
     A  02                                  DSPATR(PC)
     A                                  9 24'-->INPUT SELECT NO..'
     A            FMT            1A  B 11 22DSPATR(CS)
     A  03                                  DSPATR(RI)
     A  03                                  DSPATR(PC)
     A                                 11 24'-->INPUT INSTRUCTION.'
     A                                 11 49'M-DETAILS LINE'
     A                                 12 49'T-TOTAL LINE'
     A            FYO            1A  B 14 22DSPATR(CS)
     A  04                                  DSPATR(RI)
     A  04                                  DSPATR(PC)
     A                                 14 24'-->INPUT PAPER INSTRUCTION.'
     A                                 14 53'< 6-K6H1 / 8-K8H1 >'
     A            FPR            1A  B 16 22DSPATR(CS)
     A  05                                  DSPATR(RI)
     A  05                                  DSPATR(PC)
     A                                 16 24'-->INPUT PRINTER INSTRUCTION.'
     A                                 16 56'1- EDP SECTION'
     A                                 17 56'2- APPOINTMENT'
     A            FKB            1A  B 19 22DSPATR(CS)
     A  06                                  DSPATR(RI)
     A  06                                  DSPATR(PC)
     A                                 19 24'-->LIST ONLY INTRAL COMPANY PART N-
     A                                      O? < Y-YES / N-NO >'
     A            FMEIK          1A  B 21 22DSPATR(CS)
     A  07                                  DSPATR(RI)
     A  07                                  DSPATR(PC)
     A                                 21 24'-->SUPPLIER MAKER (SECTION.ONLY-
     A                                       9999) Y-YES / N-NO'
     A  99                             22  8'ERROR'
     A                                      DSPATR(RI)
     A                                      DSPATR(BL)
     A  99        MSG           65A  O 22 16
     A                                 24 30'CANCEL'
     A                                 24 45'CMD-1'
     A                                      DSPATR(RI)
