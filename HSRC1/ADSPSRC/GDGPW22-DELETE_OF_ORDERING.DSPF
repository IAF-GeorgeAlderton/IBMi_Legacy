      **** GDGPW22 <DSPF> ********************************************
      *      DELETE OF ORDERING
      *    G.B.C                           97/02/20
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS)
     A**************
     A* DSP01
     A**************
     A          R DSP01                     CF01
     A                                      OVERLAY PROTECT
     A*
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 25' REMOVE OF ORDER '
     A                                      DSPATR(RI)
     A                                    +1'(PRODUCTS)'
     A                                  1 69'FMT GDGPW22'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A*
     A                                  7  9'INPUT THE ITEM NUMBER OF-
     A                                       REMOVE. -----'
     A*
     A            D1ITEM         5Y 0B  7 48TEXT('ITEM NO.')
     A                                      EDTCDE(4) CHECK(RB)
     A  11                                  DSPATR(RI PC)
     A**************
     A* DSP02
     A**************
     A          R DSP02                     CF01 CF03 CF05
     A                                      OVERLAY PROTECT
     A*
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 25' REMOVE OF ORDER '
     A                                      DSPATR(RI)
     A                                    +1'(PRODUCTS)'
     A                                  1 69'FMT GDGPW22'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A*
     A                                  7  9'INPUT THE ITEM NUMBER OF-
     A                                       REMOVE. -----'
     A*
     A            D1ITEM         5Y 0   7 48TEXT('ITEM NO.')
     A*
     A                                 10 12' VERIFICATION '
     A                                      DSPATR(RI)
     A                                 12 17'PART NO.'
     A                                 14 17'NAME'
     A                                 16 17'ORDER QTY'
     A                                 18 17'RECEIVED QRY'
     A                                 20 17'RECEIVE MARK'
     A*
     A            D2HIN         14     12 35TEXT('PART NO')
     A            D2NAME        30     14 35TEXT('PART NAME')
     A            D2SURY         7Y 0  16 35TEXT('QTY')
     A                                      EDTCDE(1)
     A            D2SURT         7Y 0  18 35TEXT('QTY TOTAL')
     A                                      EDTCDE(1)
     A            D2IFMK         1     20 43TEXT('ARRIVAL COMPLETION MARK')
     A**************
     A* DSPM       *
     A**************
     A          R DSPM1
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A            D#MSG         60     22 23
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24  9'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A  20                             24 30'PRV SCREEN'
     A  20                               + 1' CMD-3 '
     A  20                                  DSPATR(RI)
     A  20                             24 54'INPUT OK'
     A  20                               + 1' CMD-5 '
     A  20                                  DSPATR(RI)
