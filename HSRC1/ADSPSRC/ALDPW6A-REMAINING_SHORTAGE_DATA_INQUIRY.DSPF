     A** ALDPW6A ******************************************************
     A* REMAINING SHORTAGE DATA INQ/UPD
     A*  KIRI                                            2018.10.30
     A*****************************************************************
     A                                      CHGINPDFT
     A                                      PRINT
      *----------------------------------------------------------------
      *サブファイル
      *----------------------------------------------------------------
     A          R SFREC1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ')
     A                                      SFL
     A            S1SEL          1   B  6  2TEXT('SEL')
     A                                      DSPATR(CS)
     A            S1NONY         4  0   6  4TEXT('DELIVERY CODE')
     A            S1NKOJ         1      6  9TEXT('FACTORY')
     A            S1NUKE         4      6 11TEXT('DOCK')
     A            S1MHN         23      6 17TEXT('CUST PART#')
     A            S1NODB         8  0   6 42TEXT('INVOICE DATE BIN')
     A                                      EDTWRD('  .  .  -  ')
     A            S1ODRN        10      6 56TEXT('ORDER NO')
      *
     A            S1SHN         14      7 17TEXT('CUST PART#')
     A            S1USYS         6  0   7 34TEXT('USER CAPACITY')
     A                                      EDTCDE(4)
     A            S1ODTM        12  0   7 43TEXT('SHORTG DATE')
     A                                      EDTWRD('  .  .  -  :  :  ')
     A            S1MINS         7  0   7 65TEXT('DELIVERY QUANTITY')
     A                                      EDTCDE(4)
      *         1         2         3         4         5         6
      *123456789012345678901234567890123456789012345678901234567890123
      *   DELV F DK    USER PART #              INVOICE DATE ORDER #
      *                IAF  PART #       QPC.    SHORTAGE DATE
      * X 1234 1 1234  12345-12345-12345-12345  YY.MM.DD-XX  1234567890
      *                12345-12345-12   888888   YY.MM.DD-88:88:88
      *
     A            S1TOKU         4S 0H      TEXT('CUSTOMER')
     A            S1NOYY         4S 0H      TEXT('INVOICE DATE  YY')
     A            S1NOMM         2S 0H      TEXT('INVOICE DATE  MM')
     A            S1NODD         2S 0H      TEXT('INVOICE DATE  DD')
     A            S1NOBN         2S 0H      TEXT('INVOICE BIN')
     A            S1NOTM         4S 0H      TEXT('INVOICE TIME')
     A            S1ODAT         8  0H      TEXT('SHRTG DATE')
     A            S1OTIM         6  0H      TEXT('SHRTG TIME')
      *
      *----------------------------------------------------------------
     A          R SFCTL1                    TEXT(' ﾅﾎﾞ､ﾎｦbﾓ ﾃ]nﾜｰﾓ')
     A                                      SFLCTL(SFREC1)
     A                                      OVERLAY PROTECT
     A                                      CF01 CF05
     A  71                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  73                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      SFLPAG(07) SFLSIZ(08)
     A                                      ROLLUP(75)
     A                                      ROLLDOWN(76)
     A            RRN1           4  0H      SFLRCDNBR
      * *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A*
     A                                  1 20' ** REMAINING SHORTAGE -
     A                                      DATA INQ/UPD ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT ALDPW6A1'
      *
     A                                  4  4'DELV F DK'
     A                                  4 17'USER PART #'
     A                                  4 42'INVOICE DATE  ORDER #'
      *
     A                                  5  2'               -
     A                                      IAF PART #        -
     A                                      QPC.    -
     A                                      SHORTAGE DATE   -
     A                                         SHORTAGE QTY.   '
     A                                      DSPATR(UL)
      *----------------------------------------------------------------
      * << 2 >>
      *----------------------------------------------------------------
     A          R DSP01
     A                                 22  2'+-> 1-UPDATE-
     A                                      (DECREASE PRODUCTION-
     A                                       ORDER)  0-DELETE'
     A*N90                             22 73'MORE...' COLOR(WHT)
     A* 90                             22 73' BOTTOM' COLOR(WHT)
     A*
     A  99                             23 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60   O 23 18
     A*
     A                                 24  5' END F1 '
     A                                      DSPATR(RI)
     A                                   + 5' UPDATE F5 '
     A                                      DSPATR(RI)
     A                                 24 65'PAGE UP/DOWN'
     A                                      DSPATR(RI)
      *----------------------------------------------------------------
