     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A          R MBDPW131
     A*%%TS  SD  19961118  094832  MIKA        REL-V3R0M5  5763-PW1
     A                                      CF01
     A                                  1 10'DELIVERY STATISTICAL LIST MAKING B-
     A                                      Y RECEIVING CO.'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 68'FMT MBDPW131'
     A                                  3 16'+----------------------------------
     A                                      ---------------+'
     A                                  4 16'|'
     A                                  4 22'1. PRINT ALL DATA'
     A                                  4 65'|'
     A                                  5 16'|'
     A                                  5 22'2. PRINT ONLY OSAKA BUSINESS OFFIC-
     A                                      E        |'
     A                                  6 16'|'
     A                                  6 22'3. PRINT ONLY ABOUT AOSHO         -
     A                                               |'
     A                                  7 16'|'
     A                                  7 22'4. PRINT RECEIVING CO.THAT''S ONLY-
     A                                       INPUT    |'
     A                                  8 16'+----------------------------------
     A                                      ---------------+'
     A                                 10 11'SELECT NO......'
     A                                      DSPATR(UL)
     A            ERABU          1Y 0B 10 27EDTCDE(Z)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A                                 10 35'RECEIVING CO. CODE'
     A                                      DSPATR(UL)
     A            NONY           4Y 0B 10 57EDTCDE(Z)
     A                                      CHECK(MF)
     A                                      CHECK(M11)
     A                                      DSPATR(CS)
     A                                 12 35'THIS MONTH-JANUARY'
     A                                      DSPATR(UL)
     A            T1             2Y 0B 12 57EDTCDE(Z)
     A                                      CHECK(RB)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A                                 13 35'THIS MONTH-FEBRUARY'
     A                                      DSPATR(UL)
     A            T2             2Y 0B 13 57EDTCDE(Z)
     A                                      CHECK(RB)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A                                 14 35'THIS MONTH-MARCH'
     A                                      DSPATR(UL)
     A            T3             2Y 0B 14 57EDTCDE(Z)
     A                                      CHECK(RB)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A                                 15 35'THIS MONTH-APRIL'
     A                                      DSPATR(UL)
     A            T4             2Y 0B 15 57EDTCDE(Z)
     A                                      CHECK(RB)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A                                 16 35'THIS MONTH-MAY'
     A                                      DSPATR(UL)
     A            T5             2Y 0B 16 57EDTCDE(Z)
     A                                      CHECK(RB)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A                                 17 35'THIS MONTH-JUNE'
     A                                      DSPATR(UL)
     A            T6             2Y 0B 17 57EDTCDE(Z)
     A                                      CHECK(RB)
     A                                      CHECK(ME)
     A                                      DSPATR(CS)
     A  99                             22 10'ERROR'
     A                                      DSPATR(RI)
