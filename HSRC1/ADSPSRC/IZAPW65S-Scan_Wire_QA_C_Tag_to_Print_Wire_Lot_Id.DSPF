     A**** IZAPW65S ****************************************
     A* SCAN WIRE QA C-TAG TO PRINT WIRE LOT ID TAGS
     A*   LEC....................    2025.10.06
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A*
     A          R IZAPW001
     A                                      CF01(01)
     A  99                                  ALARM
     A                                      OVERLAY
     A                                  1  3' ** Print Wire Lot Id Tags ** '
     A                                      DSPATR(RI)
     A                                  3  8'Scan QA C-Tag QR code'
     A            D1BAR1        75A  B  5  3DSPATR(UL)
     A                                 14  5'F1: End'
     A*
     A          R IZAPW002
     A                                      CF01(01)
     A  99                                  ALARM
     A                                      OVERLAY
     A                                 14 23'F1: Cancel'
     A                                  1  3' ** Print Wire Lot Id Tags ** '
     A                                      DSPATR(RI)
     A                                 14  4'Enter: Print'
     A            F2SUPP        15A  O  3  6COLOR(WHT)
     A            F2MATN        15A  O  4  6COLOR(PNK)
     A            F2DIAM         5Y 2O  5  6EDTWRD('   .  ')
     A                                      COLOR(PNK)
     A            F2HEAT        10A  O  8 15
     A            F2MFG#        10A  O  9 15
     A            F2COIL         3A  O 10 15
     A                                  9  6'Mfg#   -'
     A                                  8  6'Heat#  -'
     A                                 10  6'Coil#  -'
     A                                  7  6'Weight -'
     A            F2WGT          5Y 1O  7 15COLOR(BLU)
     A                                      EDTWRD('    . ')
     A                                  7 23'# Tags -'
     A            F2#TAG         2  0O  7 32COLOR(BLU)
      *
     A          R IZAPW095
     A                                  1  2' OOOOOO            '
     A                                  2  2'OO    OO           '
     A                                  3  2'OO    OO           '
     A                                  4  2'OO    OO           '
     A                                  5  2'OO    OO  KK    KKK'
     A                                  6  2'OO    OO  KK   KK  '
     A                                  7  2' OOOOOO   KK  KK   '
     A                                  8  2'          KKKKK    '
     A                                  9  2'          KK  KK   '
     A                                 10  2'          KK   KK  '
     A                                 11  2'          KK    KKK'
     A                                 14  2'ENTER:CONTINUE'
     A          R IZAPW098
     A                                      OVERLAY
     A  90
     AO 99                                  ALARM
     A*
     A          R IZAPW099
     A                                      OVERLAY
     A                                  1  4' **   Print ERROR    ** '
     A                                      DSPATR(RI)
     A                                  4  8'***          ***'
     A                                      COLOR(RED)
     A                                  5  8'  ***      ***  '
     A                                      COLOR(RED)
     A                                  6  8'    ***  ***    '
     A                                      COLOR(RED)
     A                                  7  8'      ****      '
     A                                      COLOR(RED)
     A                                  8  8'    ***  ***    '
     A                                      COLOR(RED)
     A                                  9  8'  ***      ***  '
     A                                      COLOR(RED)
     A                                 10  8'***          ***'
     A                                      COLOR(RED)
     A            D9ERR         25A  O 12  4DSPATR(RI)
     A                                 14  4'Enter: Continue'
     A                                      COLOR(WHT)
