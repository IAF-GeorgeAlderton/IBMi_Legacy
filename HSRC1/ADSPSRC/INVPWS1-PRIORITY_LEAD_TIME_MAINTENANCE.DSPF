     A** INVPWS1 ***********************************
     A* UPDATE OF PRIORITY LT MASTER               *
     A*          KIRI             14.08.05         *
     A*********************************** INVPWS1 **
     A                                      CHGINPDFT
     A                                      PRINT
      *-------------------------------------
     A          R DSP01
     A                                      CF01
     A                                      BLINK
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** PRIORITY LT MASTER ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT INVPWS1'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('0  .  .  ')
     A*
     A                                  7 34'1: IN HOUSE'
     A                                 10 34'2: OUTSOURCE'
     A*
     A            D1NO           1A  B  7 30DSPATR(CS)
     A  11                                  DSPATR(PC RI)
     A*
     A  99                             22 11'ERROR' DSPATR(RI BL)
     A  99        D1ERR         60A  O 22 18
     A*
     A                                 24  4' F1 ' DSPATR(RI)
     A                                   + 1'EXIT'
