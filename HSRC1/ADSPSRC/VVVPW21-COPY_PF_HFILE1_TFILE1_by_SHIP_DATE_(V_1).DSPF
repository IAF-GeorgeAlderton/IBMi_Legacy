     A*%%TS  SD  20240219  152344  I0777       REL-V7R4M0  5770-WDS
     A** VVVPW21 ******************************************************
     A*  COPY PF FROM HFILE1 TO TFILE1 BY SHIP DATE                   *
     A*  JW      2024.02.19                                           *
     A*****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A                                      CF01(01)
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      CF12(12)
     A          R DSP01
     A*%%TS  SD  20240219  152344  I0777       REL-V7R4M0  5770-WDS
     A                                      INVITE
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 19'** COPY PF from HFILE1 to TFILE1 b-
     A                                      y SHIP DATE **'
     A                                      DSPATR(RI)
     A            #PGM           8A  O  1 73
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  6 14'Enter Ship Date:'
     A                                      COLOR(WHT)
     A            XDATE          8A  B  6 31DSPATR(CS)
     A  63                                  DSPATR(RI)
     A  63                                  DSPATR(PC)
     A                                  6 40'YYYYMMDD'
     A                                      COLOR(YLW)
     A                                  9 14'** Files To Be Copied from HFILE1 -
     A                                      to TFILE1.'
     A                                      COLOR(WHT)
     A            X01            1A  O 10 15
     A                                 10 17'AB#PP10'
     A                                      COLOR(YLW)
     A            C01            6Y 0O 10 26EDTCDE(1)
     A            X02            1A  O 11 15
     A                                 11 17'AB#PP2A'
     A                                      COLOR(YLW)
     A            C02            6Y 0O 11 26EDTCDE(1)
     A            X03            1A  O 12 15
     A                                 12 17'AB#PP70'
     A                                      COLOR(YLW)
     A            C03            6Y 0O 12 26EDTCDE(1)
     A            X04            1A  O 13 15
     A                                 13 17'AB#PP75'
     A                                      COLOR(YLW)
     A            C04            6Y 0O 13 26EDTCDE(1)
     A            X05            1A  O 14 15
     A                                 14 17'AB#PP78'
     A                                      COLOR(YLW)
     A            C05            6Y 0O 14 26EDTCDE(1)
     A            X06            1A  O 15 15
     A                                 15 17'AB#PP2B'
     A                                      COLOR(YLW)
     A            C06            6Y 0O 15 26EDTCDE(1)
     A            X07            1A  O 16 15
     A                                 16 17'AB#PP2F'
     A                                      COLOR(YLW)
     A            C07            6Y 0O 16 26EDTCDE(1)
     A            X08            1A  O 17 15
     A                                 17 17'AB#PPA1'
     A                                      COLOR(YLW)
     A            C08            6Y 0O 17 26EDTCDE(1)
     A            X09            1A  O 18 15
     A                                 18 17'AB#PP01'
     A                                      COLOR(YLW)
     A            C09            6Y 0O 18 26EDTCDE(1)
     A  99                             22 11'ERROR'
     A                                      DSPATR(RI)
     A                                      DSPATR(BL)
     A            MSG           60A  O 22 17COLOR(WHT)
     A                                 24 11'F1:'
     A                                      DSPATR(RI)
     A                                 24 15'EXIT'
     A                                 24 24'F5:'
     A                                      DSPATR(RI)
     A                                 24 28'START COPY'
