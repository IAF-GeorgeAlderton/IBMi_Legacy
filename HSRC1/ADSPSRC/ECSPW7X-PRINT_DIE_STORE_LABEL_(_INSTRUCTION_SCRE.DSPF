     A** ECSPW7X ******************************************
     A*  PRINT DIE STORE LABEL ( FROM DIE INVENTOTU FILE )*
     A*          2018.04.04  KIRI                         *
     A****************************************** ECSPW7X **
     A                                      PRINT
     A                                      CHGINPDFT
     A*===================================================*
     A*         INSTRUCTION SCREEN                        *
     A*===================================================*
     A          R DSP01
     A                                      CF01
     A                                      CF05
     A                                      BLINK
     A  99                                  ALARM
     A*
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 26'**  ISSUE STORE OUT +
     A                                      LABEL  **'
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT ECSPW7X'
     A*
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A*
     A*
     A                                  6 20' LOCATION '
     A                                      DSPATR(RI)
     A                                   + 1'FROM'
     A            D1LOC1         1   B   + 1TEXT('LOCATION 1')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1LOC2         2   B   + 1TEXT('2')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1LOC3         2   B   + 1TEXT('3')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D1LOC4         1   B   + 1TEXT('4')
     A                                      DSPATR(CS)
     A  31                                  DSPATR(PC RI)
     A                                  8 33'TO'
     A            D2LOC1         1   B   + 1TEXT('LOCATION 1')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D2LOC2         2   B   + 1TEXT('2')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D2LOC3         2   B   + 1TEXT('3')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(PC RI)
     A                                   + 1'-'
     A            D2LOC4         1   B   + 1TEXT('4')
     A                                      DSPATR(CS)
     A  32                                  DSPATR(PC RI)
     A*
     A*
     A  99                             23 10' ERROR ' DSPATR(RI BL)
     A  99        D1ERR         60O  O 23 19
     A*
     A                                 24  5'END'
     A                                 24 10' F1 ' DSPATR(RI)
     A                                 24 18'PRINT'
     A                                 24 25' F5 ' DSPATR(RI)
     A*
