     A            S2KOTE         3   B  9 24DSPATR(CS)
     A  11                                  DSPATR(RI PC)
     A            S2MAIS         4Y 0B  9 35EDTCDE(4) CHECK(RB)
     A                                      DSPATR(CS)
     A  13                                  DSPATR(RI PC)
     A            S2SYUY         7Y 0B  9 45EDTCDE(2) CHECK(RB)
     A                                      DSPATR(CS)
     A  14                                  DSPATR(RI PC)
     A            S2SRY          9Y 0O  9 57EDTCDE(2)
     A            S2KKBN         1   H
     A            S2LOTO         3Y 0H
     A**************
     A* CTL2       *
     A**************
     A          R CTL02                     SFLCTL(SFL02)
     A                                      SFLSIZ(0013)
     A                                      SFLPAG(0012)
     A                                      CF01
     A                                      CF03
     A                                      CF05
     A                                      OVERLAY
     A                                      PROTECT
     A  81                                  SFLDSP
     A  82                                  SFLDSPCTL
     A  83                                  SFLCLR
     A            RECNO2         4S 0H      SFLRCDNBR
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 20'  INVENTORY DATA ADD/CORRECION  '
     A                                      DSPATR(RI)
     A                                  1 69'FMT GDJPW16'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTWRD('  .  .  ')
     A                                  4  2' CORRECTION/DELETION ' DSPATR(RI)
     A                                  4 29'DEPARTMENT'
     A            D1DEP          4Y 0O    +1
     A                                  5 29'PARTS NO. '
     A            D1HIN1         5   O    +1
     A                                    +1'-'
     A            D1HIN2         5   O    +1
     A                                    +1'-'
     A            D1HIN3         2   O    +1
     A                                  7 21'PROCESS'  DSPATR(HI)
     A                                  7 45'QUANTITY' DSPATR(HI)
     A                                  8  7' DELETE(0)      CODE        -
     A                                      BOXES        IN BOX      QUANTITY '
     A                                      DSPATR(HI UL)
     A**************
     A* DSP2       *
     A**************
     A          R DSP02
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
