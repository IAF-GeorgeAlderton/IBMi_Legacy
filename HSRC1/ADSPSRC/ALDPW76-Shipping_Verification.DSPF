     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A                                  5  2' PICK UP LIST '
     A                                      DSPATR(HI)
     A                                      DSPATR(UL)
     A            BRCD20         9A  B  7  4DSPATR(UL)
     A  62                                  DSPATR(RI)
     A  62                                  DSPATR(PC)
     A            F2EMSG        16A  O  9  2DSPATR(HI)
     A                                 11  2'F3=END'
     A                                 13  2'F6=RE-SCAN'
