     A*** ALDPW76 ******************************************
     A*  SHIPPING VERIFICATION                             *
     A*                                                    *
     A* TCHK1 01/26/10 CREATE(COPY FROM ALDPW70)           *
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A* ----------------------------------------------------
     A          R FMT010
     A                                      CF03
     A                                  1  4' SHIPPING '
     A                                      DSPATR(RI)
     A                                  2  2' VERIFICATION '
     A                                      DSPATR(RI)
     A                                  5  2'TM CODE :'
     A                                      DSPATR(HI)
     A            D@TMCD         6A  B  7  4
     A  61                                  DSPATR(RI)
     A  61                                  DSPATR(PC)
     A            F1EMSG        16A  O  9  2DSPATR(HI)
     A                                 11  2'F3:END'
