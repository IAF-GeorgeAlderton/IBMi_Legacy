      **********************************************************
      *  PRINT  OF DIE LOCATION M/F
      *  G.B.C                            97/03/21
      **********************************************************
     A                                      PRINT
     A**************
     A* ＤＳＰ１ *
     A**************
     A          R DSP01                     CF01(01) CF05(05)
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 20' ISSUING THE LOCATION -
     A                                      CODE MASTER LIST '
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW81'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A*
     A                                  6  9'LOCATION CODE MASTER -
     A                                      LIST'
     A                                      DSPATR(HI)
     A                                  9 19' 1 ' DSPATR(RI)
     A                                    +3'LIST IN ORDER THE DIE NO.'
     A                                 11 19' 2 ' DSPATR(RI)
     A                                    +3'LIST IN ORDER THE LOCATION -
     A                                      CODE.'
     A            D1NO           1Y 0B 15 20CHECK(RB) EDTCDE(4)
     A  11                                  DSPATR(PC RI)
     A                                 15 22'---> INPUT THE NUMBER.'
     A*
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 20
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24 11'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 34'CREATING A LIST'
     A                                   + 1' CMD-5 '
     A                                      DSPATR(RI)
