     A  90                                  DSPATR(RI)
     A  90                                  DSPATR(PC)
     A                                  5  7'(YYMMDD)'
     A                                 14  2'F5=MAIN MENU'
     A          R ALDPW011
     A*%%TS  SD  20010828  134357  TEST        REL-V3R7M0  5716-PW1
