     A                                      DSPATR(UL)
     A  33                                  DSPATR(RI)
     A  33                                  DSPATR(PC)
     A                                      CHECK(ER)
     A                                 13  2'F5=MAIN MENU'
     A                                 15  2'F7=SWITCH TO OTHERS'
     A            MSG           15A  O 16  2
     A N30                                  DSPATR(ND)
     A                                 14  2'F6=TMMK'
