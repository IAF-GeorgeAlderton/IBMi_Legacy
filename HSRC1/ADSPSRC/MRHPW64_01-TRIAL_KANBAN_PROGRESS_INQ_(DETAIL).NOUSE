     A**                                    DSPSIZ(24 80 *DS3)
     A                                      PRINT(*LIBL/QPRINT)
     **==============================================================**
     **  画面１（ＤＳＰ０１）
     **==============================================================**
     A          R MRHPW641
     A*<<キーワード定義>>
     A                                      CF03(03 '前画面')
     A                                      OVERLAY
     A                                      PROTECT
     A*<<カーソル制御用>>
     A***                                   RTNCSRLOC(&D1RCD  &D1FLD)
     A***                                   CSRLOC(D1LIN D1COL)
     A***         D1LIN          3S 0H      TEXT('fｰﾓ制御（行）')
     A***         D1COL          3S 0H      TEXT('fｰﾓ制御（桁）')
     A***         D1RCD         10A  H      TEXT('ﾛﾃｰnﾞ')
     A***         D1FLD         10A  H      TEXT('ﾎｧｰﾓnﾞID')
     A*<<フィールド定義>>
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22'***  TRIAL KANBAN PROGRESS +
     A                                       CHECK  ***'
     A                                      DSPATR(HI RI)
     A                                  1 69'FMT MRHPW64'
     A*
     A                                  2  2'DATE'
     A            D1SYMD         8Y 0O  2  7EDTWRD('0 /  /    ')
     A*<<入出力項目>>
     A                                  3  2'DIVISION :'
     A            D1DVKB         1A  O  3 13TEXT('発行部署')
     A            D1DVNM         9A  O  3 15TEXT('発行部署名')
     A            D1DPNM        10A  O  3 26TEXT('発行依頼者')
     A                                  3 43'LOT #:'
     A            D1THI          8A  O  3 50TEXT('手配番号')
     A                                  3 61'LOCATION:'
     A            D1BAN          9A  O  3 71TEXT('番地')
     A  56                                  DSPATR(BL)
     A*
     A                                  4  2'INHOUSE PART #:'
     A            D1SHN         14A  O  4 18TEXT('社内品番')
     A                                  4 33'CUSTOMER PART #:'
     A            D1MHN         23A  O  4 50TEXT('ユーザー品番')
     A*
     A                                  5  2'CUSTOMER:'
     A            D1TOKU         4S 0O  5 12TEXT('ユーザーコード')
     A            D1TKNM        15A  O  5 17TEXT('ユーザー名称')
     A                                  5 33'BLANK PART #   :'
     A            D1BHN         14A  O  5 50TEXT('ブランク品番')
     A*
     A                                  6  2'PRODUCTION QTY:'
     A            D1SISU         8Y 0O  6 18TEXT('総生産数量')
     A                                      EDTCDE(1)
     A                                  6 29'DERIVARY QTY:'
     A            D1THSU         7Y 0O  6 43TEXT('手配数量')
     A                                      EDTCDE(1)
     A                                  6 53'DELIVERY DATE :'
     A            D1NOHZ         8Y 0O  6 69TEXT('納期')
     A                                      EDTWRD('0    /  /  ')
     A*
     A                                  7  2'PURPOSE:'
     A            D1THMK        50A  O  7 11TEXT('手配目的')
     A*
     A                                  8 30'PLAN'
     A                                  8 37'CHECK'
     A                                  8 43'GATE'
     A*
     A                                  9  5'PROCESS'
     A                                  9 22'MACHINE'
     A                                  9 30'DATE'
     A                                  9 37'IN'
     A                                  9 44'OUT'
     A                                  9 52'DESCRIPTION'
     A*
     **==============================================================**
     **  画面２（ＳＦＬ０２）
     **==============================================================**
     A          R SFLREC02                  SFL
     A*
     A            S2SEQ          2S 0O 10  2TEXT('行№')
     A            S2KTEI         4A  O 10  5TEXT('工程')
     A  55                                  DSPATR(RI BL)
     A            S2KBMN         4S 0O 10 10TEXT('加工工場コード')
     A  55                                  DSPATR(RI BL)
     A            S2KBNM         8A  O 10 15TEXT('加工工場名')
     A  55                                  DSPATR(RI BL)
     A            S2MSNO         3A  O 10 24TEXT('機番')
     A  55                                  DSPATR(RI BL)
     A            S2KNHZ         4Y 0O 10 30TEXT('納期')
     A  55                                  DSPATR(RI BL)
     A                                      EDTWRD('0  /  ')
     A            S2CIHZ         4Y 0O 10 37TEXT('チェックゲート入り日')
     A  55                                  DSPATR(RI BL)
     A                                      EDTWRD('0  /  ')
     A            S2COHZ         4Y 0O 10 44TEXT('チェックゲート出た日')
     A  55                                  DSPATR(RI BL)
     A                                      EDTWRD('0  /  ')
     A            S2KVIK        27A  O 10 52TEXT('備考')
     A  55                                  DSPATR(RI BL)
     A*
     A*==============================================================**
     A*  画面２（ＣＴＬ０２）
     A*==============================================================**
     A*<<キーワード定義>>
     A          R SFLCTL02                  SFLCTL(SFLREC02)
     A                                      SFLSIZ(0020)
     A                                      SFLPAG(0010)
     A                                      CF03(03 '前画面')
     A  51                                  CF08(08 'チェックゲート')
     A***                                   PAGEDOWN(39)
     A                                      OVERLAY
     A                                      PROTECT
     A  31                                  SFLDSP
     A  32                                  SFLDSPCTL
     A**32                                  SFLEND(*PLUS)
     A**32                                  SFLEND(*MORE)
     A  33                                  SFLCLR
     A***                                   RTNCSRLOC(&D2RCD  &D2FLD)
     A***                                   CSRLOC(D2LIN D2COL)
     A*<<カーソル制御用フィールド>>
     A            D2RRN          4S 0H      TEXT('ﾅﾎﾞﾎｦbﾓﾛﾃｰnﾞ制御')
     A                                      SFLRCDNBR(CURSOR)
     A***         D2LIN          3S 0H      TEXT('fｰﾓ制御（行）')
     A***         D2COL          3S 0H      TEXT('fｰﾓ制御（桁）')
     A***         D2RCD         10A  H      TEXT('ﾛﾃｰnﾞ')
     A***         D2FLD         10A  H      TEXT('ﾎｧｰﾓnﾞID')
     A*<<入出力項目>>
     A                                 20  2'WASHER'
     A*
     A            D2KH1         24A  O 21  2TEXT('構成情報１')
     A            D2WHZ1         4Y 0O 21 27TEXT('構成品納期１')
     A                                      EDTWRD('0  /  ')
     A            D2KH2         24A  O 21 34TEXT('構成情報２')
     A            D2WHZ2         4Y 0O 21 59TEXT('構成品納期２')
     A                                      EDTWRD('0  /  ')
     A            D2KTHZ        15A  O 21 65TEXT('型納期')
     A*
     A            D2KH3         24A  O 22  2TEXT('構成情報３')
     A            D2WHZ3         4Y 0O 22 27TEXT('構成品納期３')
     A                                      EDTWRD('0  /  ')
     A            D2KH4         24A  O 22 34TEXT('構成情報４')
     A            D2WHZ4         4Y 0O 22 59TEXT('構成品納期４')
     A                                      EDTWRD('0  /  ')
     A            D2ZRHZ        15A  O 22 65TEXT('材料納期')
     A*<<メッセージ>>
     A                                 23 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D2EMSG        53O  O 23 18TEXT('d[ｰxｮﾈｰﾆﾞ')
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A*<<ファンクション>>
     A                                 24  9'PREV'
     A                                 24 15'CMD-3'
     A                                      DSPATR(RI)
     A  51                             24 23'CHECK GATE:'
     A  51                             24 35'CMD-8'
     A                                      DSPATR(RI)
     A                                 24 62'ROLL UP/DOWN'
     A                                      DSPATR(RI)
