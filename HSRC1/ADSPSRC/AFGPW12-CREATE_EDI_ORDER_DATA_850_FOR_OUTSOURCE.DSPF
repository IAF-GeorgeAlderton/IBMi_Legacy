     A** AFGPW12 ********************************************
     A* CREATE EDI ORDER DATA 850 FOR OUTSOURCE             *
     A*       T.SAKAKI                     2016.11.21       *
     A******************************************** AFGPW12 **
     A**                                    DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*------------------------*
     A          R SFL                       SFL
      *
     A            S1SEL          1A  B  8  2DSPATR(CS)
     A  31                                  DSPATR(RI PC)
     A            S1GPPO        17A     8  4
     A*** REVISED
     A  77                                  DSPATR(RI)
     A*** CANCELED
     A  78                                  COLOR(RED)
     A*** RESENT
     A  79                                  DSPATR(HI)
     A            S1PART        14A     8 22
     A  78                                  COLOR(RED)
     A            S1TQTY         8Y 0   8 37EDTCDE(1)
     A  78                                  COLOR(RED)
     A            S1TWGT         7Y 2   8 49EDTWRD('     .  ')
     A  78                                  COLOR(RED)
     A            S1B           12Y 0   8 61EDTWRD('    /  /  -  :  ')
     A  78                                  COLOR(RED)
     A* HIDDEN ITEM
     A            @RRN           4Y 0H
      *---------------------------------------*
      *  SUB FILE CONTROL                   *
      *---------------------------------------*
     A          R SFLCTL
     A                                      SFLCTL(SFL)
     A  72                                  SFLDSPCTL
     A  72                                  ERASE(SFL)
     A  73                                  SFLDSP
     A  71                                  SFLCLR
     A                                      OVERLAY PROTECT
     A                                      SFLPAG(13)
     A                                      SFLSIZ(13)
     A                                      CF03(03)
     A***                                   CF05(05)
     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3  0H
     A            S@SCLM         3  0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A*
     A                                  1 17' ** INQUIRY & RE-PROCESS EDI +
     A                                      ORDER ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT AFGPW12'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4  2'SUPPLIER ' DSPATR(UL)
     A            D1SUPP         4A  O   + 2
     A            D1SUPN        15O  O   + 2
      * DATE
     A                                  4 39'SENT DATA' DSPATR(UL)
     A            D1SDAT         8Y 0O   + 2EDTWRD('    /  /  ')
     A                                   + 1'-'
     A            D1EDAT         8Y 0O   + 1EDTWRD('    /  /  ')
      * P.O.#
     A                                  5  2'P.O.#    ' DSPATR(UL)
     A            D1GPPO        17A  O   + 2
      *
     A                                  7  2'S'
     A                                      DSPATR(UL)
      *
     A                                  7  4'ORDER #           IAF PART #     +
     A                                       TOTAL QTY.  +
     A                                       WEIGHT(LB)  LAST SENT DATE  '
     A                                      DSPATR(UL)
     A          R AFGPW129
     A                                      OVERLAY PROTECT
     A                                 21  2'|'
     A                                   + 5'POXXX' DSPATR(HI)
     A                                   + 1'RE-SENT'
     A                                   + 3'POXXX' DSPATR(RI)
     A                                   + 1'REVISED'
     A                                   + 3'POXXX' COLOR(RED)
     A                                   + 1'CANCELLED'
     A*
     A                                 22  2'+---> 1 : <INQUIRY> OR <RESEND>'
     A                                   + 2'|'
     A                                   + 1'R : <REVISE> '
     A                                   + 2'|'
     A                                   + 1'C : <CANCEL> '
      *
     A N81                             22 72' NEXT ...'
     A  81                             22 72' LAST ...'
      *
     A                                 23  2'ERROR'
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D9ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  5' F3 '
     A                                      DSPATR(RI)
     A                                   + 1' BACK '
     A                                 24 60'PAGE UP/DOWN'
     A                                      DSPATR(RI)
