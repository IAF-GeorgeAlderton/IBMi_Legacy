     A******************************* APLPW90 **
     A                                      PRINT
     A                                      CHGINPDFT
      *
     A          R APLPW9C1
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  /  /  ')
     A                                  1 38'MASSAGE'
     A                                  1 69'FMT APLPW9C'
      *
     A                                  5  4'PROGRAM ID:' DSPATR(UL)
     A            @PGID          6A  O  5 16DSPATR(HI) DSPATR(UL)
     A*
     A            @PMSG        256A  O  9  4DSPATR(UL)
