     A                                      DSPATR(HI)
     A                                  3  9'Last'
     A                                      DSPATR(HI)
     A                                  4 10'Nbr'
     A                                      DSPATR(HI)
     A                                  4 15'Location'
     A                                      DSPATR(HI)
     A                                  4 26'Part number'
     A                                      DSPATR(HI)
     A                                  3 46'Qty/'
     A                                      DSPATR(HI)
     A                                  4 46'Cont.'
     A                                      DSPATR(HI)
