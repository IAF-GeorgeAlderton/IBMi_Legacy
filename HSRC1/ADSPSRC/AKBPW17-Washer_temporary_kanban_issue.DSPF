     A            S@PRT2         5A  O  5 32
     A            S@PRT3         2A  O  5 38
     A            S@SYOS         7Y 0O  5 42EDTCDE(1)
     A            S@SETQ         5Y 0O  5 57EDTCDE(1)
     A            S@MAX          5Y 0O  5 66EDTCDE(1)
     A            S@PLNT         4  0O  5 75
     A          R CTL01                     SFLCTL(SFL01)
     A                                      SFLSIZ(0018)
     A                                      SFLPAG(0017)
     A  51                                  SFLDSP
     A  51                                  SFLDSPCTL
     A  52                                  SFLCLR
     A                                      OVERLAY
     A            #RCNO          4S 0H      SFLRCDNBR
     A            #PGM           8A  O  1  2
     A                                  1 26'** WASHER TEMPORARY KANBAN **'
     A                                      DSPATR(RI)
     A                                  1 63DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A                                  3  3'# of'
     A                                      DSPATR(HI)
