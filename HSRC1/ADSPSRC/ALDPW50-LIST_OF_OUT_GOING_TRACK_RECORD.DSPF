     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
      *----------*
      * SCREEN 1 *
      *----------*
     A          R ALDPW501
     A                                      CF01 CF05
     A  99                                  ALARM
     A                                      BLINK PUTOVR KEEP
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 69'FMT ALDPW50'
     A                                  2  2'DATE'
     A                                  2  7DATE
     A                                      EDTCDE(Y)
     A                                  1 22'*** LIST OF OUT-GOING TRACK +
     A                                       RECORD ***'
     A                                      DSPATR(RI)
      *
     A                                  6  3'RCV CO.'
     A                                      DSPATR(UL)
     A            NONY           4Y 0B  8  4DSPATR(CS) EDTCDE(Z)
     A                                      OVRDTA
     A                                      OVRATR
     A  01                                  DSPATR(RI)
     A  01                                  DSPATR(PC)
      *
     A                                  6 12'FACTORY'
     A                                      DSPATR(UL)
     A            KOJO           1A  B  8 15DSPATR(CS)
     A                                      OVRDTA
     A                                      OVRATR
     A  02                                  DSPATR(RI)
     A  02                                  DSPATR(PC)
      *
     A                                  6 22'RECEIVING'
     A                                      DSPATR(UL)
     A            NUKE           4A  B  8 24DSPATR(CS)
     A                                      OVRDTA
     A                                      OVRATR
     A  03                                  DSPATR(RI)
     A  03                                  DSPATR(PC)
      *
     A                                  6 34'IN-HOUSE PARTS NO'
     A                                      DSPATR(UL)
     A            SHN1           5   B  8 33DSPATR(CS) OVRDTA
     A  04                                  DSPATR(RI PC)
     A                                  8 39'-'
     A            SHN2           5   B  8 41DSPATR(CS) OVRDTA
     A  04                                  DSPATR(RI)
     A                                  8 47'-'
     A            SHN3           2   B  8 49DSPATR(CS) OVRDTA
     A  04                                  DSPATR(RI)
      *
     A                                  6 56'OUT-GOING DATE'
     A                                      DSPATR(UL)
     A            SHIZK          8Y 0B  8 55DSPATR(CS) EDTCDE(Z)
     A                                      OVRDTA
     A  05                                  DSPATR(RI PC)
     A                                  8 65'-'
     A            EHIZK          8Y 0B  8 68DSPATR(CS) EDTCDE(Z)
     A                                      OVRDTA
     A  06                                  DSPATR(RI PC)
      *
     A                                 12 30'IN-HOUSE PARTS NO = +
     A                                      999999999999 ---->> ALL DATA'
     A                                      COLOR(WHT) DSPATR(HI)
      *
     A                                 22 10'ERROR'
     A                                      OVRATR
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(RI)
     A  99                                  DSPATR(BL)
     A            MSG           60   O 22 20OVRATR
     A                                      OVRDTA
     A N99                                  DSPATR(ND)
     A  99                                  DSPATR(HI)
     A  99                                  DSPATR(BL)
     A                                 24  4' END '
     A                                 24 15' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 24'ISSUE OK'
     A                                 24 35' CMD-5 '
     A                                      DSPATR(RI)
