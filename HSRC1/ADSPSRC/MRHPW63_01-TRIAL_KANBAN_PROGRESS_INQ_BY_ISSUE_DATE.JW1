     A                                      EDTWRD('0    /  /  ')
     A                                      CHECK(RB)
     A                                      DSPATR(CS)
     A  43                                  DSPATR(RI PC)
     A                                  9 47'-'
     A            D1NOHT         8Y 0B  9 49TEXT('納入日TO')
     A                                      EDTWRD('0    /  /  ')
     A                                      CHECK(RB)
     A                                      DSPATR(CS)
     A  44                                  DSPATR(RI PC)
      *
     A                                 11 15'CUSTOMER          :'
     A            D1TOKU         4Y 0B 11 36TEXT('ユーザーコード')
     A                                      CHECK(RB)
     A                                      EDTCDE(4)
     A                                      DSPATR(CS)
     A  45                                  DSPATR(RI PC)
      *
     A                                 13 15'DEPARTMENT        :'
     A            D1DVKB         1A  B 13 36TEXT('発行部署')
     A                                      DSPATR(CS)
     A  46                                  DSPATR(RI PC)
     A                                 13 41'1:SALES  2:PC  3:QD  4:OTHER'
      *
     A*<<メッセージ>>
     A                                 22 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1EMSG        53O    22 18TEXT('d[ｰxｮﾈｰﾆﾞ')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*<<ファンクション>>
