     A                                      DSPATR(HI RI)
     A                                  1 69'FMT MRHPW63'
      *
     A                                  2  2'DATE'
     A            D1SYMD         8Y 0O  2  7EDTWRD('0 /  /    ')
     A*<<入出力項目>>
     A                                  7 15'KANBAN ISSUE DATE :'
     A            D1HKHF         8Y 0B  7 36TEXT('かんばん発行日FROM')
     A                                      EDTWRD('0    /  /  ')
     A                                      CHECK(RB)
     A                                      DSPATR(CS)
     A  41                                  DSPATR(RI PC)
     A                                  7 47'-'
     A            D1HKHT         8Y 0B  7 49TEXT('かんばん発行日TO')
     A                                      EDTWRD('0    /  /  ')
     A                                      CHECK(RB)
     A                                      DSPATR(CS)
     A  42                                  DSPATR(RI PC)
      *
     A                                  9 15'DELIVERY DATE     :'
