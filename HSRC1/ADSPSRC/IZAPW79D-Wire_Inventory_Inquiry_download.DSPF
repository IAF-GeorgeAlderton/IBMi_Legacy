     A** IZAPW79D *******************************************
     A*  WIRE INVENTORY LOG DOWNLOAD                        *
     A*  LEC    2025.06.30  ADD HEAD/ROLL AND REFORMAT SCRNS*
     A*******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT(UL)
     A                                      PRINT
     A          R DSP01
     A                                      OVERLAY
     A                                      CF01
     A                                  2  3'Time'
     A                                  2  8TIME
     A                                  1 25' ** Wire Inventory Log Download **-
     A                                       '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A            #PGM           8A  O  1 72
     A                                  1  3'Date'
     A                                  1  8DATE
     A                                      EDTCDE(Y)
     A                                  4 21'Scan Date From:'
     A            XFYY           4Y 0B  4 37EDTCDE(Z)
     A                                      COLOR(WHT)
     A                                      DSPATR(UL)
     A  31                                  DSPATR(RI)
     A  31                                  DSPATR(PC)
     A            XFMM           2Y 0B  4 42EDTCDE(Z)
     A                                      COLOR(WHT)
     A                                      DSPATR(UL)
     A  31                                  DSPATR(RI)
     A  31                                  DSPATR(PC)
     A            XFDD           2Y 0B  4 45EDTCDE(Z)
     A                                      COLOR(WHT)
     A                                      DSPATR(UL)
     A  31                                  DSPATR(RI)
     A  31                                  DSPATR(PC)
     A                                  4 48'To:'
     A            XTYY           4Y 0B  4 52EDTCDE(Z)
     A                                      COLOR(WHT)
     A                                      DSPATR(UL)
     A  32                                  DSPATR(RI)
     A  32                                  DSPATR(PC)
     A            XTMM           2Y 0B  4 57EDTCDE(Z)
     A                                      COLOR(WHT)
     A                                      DSPATR(UL)
     A  32                                  DSPATR(RI)
     A  32                                  DSPATR(PC)
     A            XTDD           2Y 0B  4 60EDTCDE(Z)
     A                                      COLOR(WHT)
     A                                      DSPATR(UL)
     A  32                                  DSPATR(RI)
     A  32                                  DSPATR(PC)
     A  85                             23  4'Error'
     A  85                                  DSPATR(RI)
     A  85                                  DSPATR(BL)
     A  85        XMSG          60A  O 23 10
     A  85                                  DSPATR(RI)
     A  85                                  DSPATR(BL)
     A                                 24 12'F1:End'
     A                                      DSPATR(RI)
     A                                 24 39'Enter: Continue'
     A                                      DSPATR(RI)
