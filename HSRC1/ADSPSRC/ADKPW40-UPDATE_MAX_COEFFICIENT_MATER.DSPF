     A** ADKPW40 ***********************************
     A*上限係数マスター更新
     A*     KATOGI.       2016.02.12               *
     A***********************************************************
     A* 改善シート24132:OWKのための上限カット係数変更       *
     A*  OWK用の係数を追加& APICSとOWK両方変更できるように*
     A* 2024.10.01 T.ASAI                                       *
     A***********************************************************
     A                                      PRINT
     A                                      CHGINPDFT
     A          R ADKPW401
     A                                      CF01(01)
     A                                      CF05(05)
     A                                      BLINK
     A  99                                  ALARM
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 28' ** OVER LIMIT RATE ** '
     A                                      DSPATR(RI)
     A                                  1 68'FMT ADKPW40'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  4  5' A-PICS '
     A                                      DSPATR(RI)
     A                                  5  9' OVER LIMIT RATE '
     A                                      DSPATR(RI)
     A                                  5 32' #OF BOX(ALL PARTS)'
     A                                      DSPATR(RI)
     A            D1TOTL        12Y 2   6 32EDTWRD(' ,   ,   , 0 .  ')
     A                                   + 1'BOXES PER DAY'
     A                                  8  9'PART#'
     A            D1KSUD         5Y 2B  8 18DSPATR(CS) EDTWRD(' 0 .  ')
     A  31                                  DSPATR(RI PC)
     A                                 10  7'PROCESS'
     A            D1KSUP         5Y 2B 10 18DSPATR(CS) EDTWRD(' 0 .  ')
     A  33                                  DSPATR(RI PC)
     A                                 12  9'TOTAL'
     A            D1KSUB         5Y 2B 12 18DSPATR(CS) EDTWRD(' 0 .  ')
     A  32                                  DSPATR(RI PC)
      *
     A            D1LIMD        12Y 2   8 32EDTWRD(' ,   ,   , 0 .  ')
     A                                      DSPATR(HI UL)
     A                                   + 1'BOXES PER DAY AFTER CALC'
     A                                      DSPATR(HI)
     A            D1LIMT        12Y 2  12 32EDTWRD(' ,   ,   , 0 .  ')
     A                                      DSPATR(HI UL)
     A                                   + 1'BOXES PER BIN AFTER CALC'
     A                                      DSPATR(HI)
      *
     A                                 14  5' OWK '
     A                                      DSPATR(RI)
     A                                 15  9' OVER LIMIT RATE '
     A                                      DSPATR(RI)
     A                                 15 32' #OF BOX(ALL PARTS)'
     A                                      DSPATR(RI)
     A            D1OWKA        12Y 2  16 32EDTWRD(' ,   ,   , 0 .  ')
     A                                   + 1'BOXES PER DAY'
     A                                 18  9'PART#'
     A            D1OWKP         5Y 2B 18 18DSPATR(CS) EDTWRD(' 0 .  ')
     A                                 20  7'PROCESS'
     A            D1OWKL         5Y 2B 20 18DSPATR(CS) EDTWRD(' 0 .  ')
     A                                 22  9'TOTAL'
     A            D1OWKT         5Y 2B 22 18DSPATR(CS) EDTWRD(' 0 .  ')
      *
     A            D1OWKB        12Y 2  18 32EDTWRD(' ,   ,   , 0 .  ')
     A                                      DSPATR(HI UL)
     A                                   + 1'BOXES PER DAY AFTER CALC'
     A                                      DSPATR(HI)
     A            D1OWKC        12Y 2  22 32EDTWRD(' ,   ,   , 0 .  ')
     A                                      DSPATR(HI UL)
     A                                   + 1'BOXES PER BIN AFTER CALC'
     A                                      DSPATR(HI)
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2' F1 '
     A                                      DSPATR(RI)
     A                                   + 1'EXIT'
     A                                   + 2' F5 '
     A                                      DSPATR(RI)
     A                                   + 1'UPDATE'
