     A*** ALEPW01 ******************************************
     A*  BPT SCAN                                          *
     A*                                                    *
     A* TCHK1 02/05/10 CREATE                              *
     A******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      PRINT
     A* ----------------------------------------------------
     A          R FMT010
     A                                      CF03
     A                                  1  4' BPT SCAN '
     A                                      DSPATR(RI)
     A                                  3  2'TM CODE :'
     A                                      DSPATR(HI)
     A            D@TMCD         6A  B  5  4
     A  61                                  DSPATR(RI)
     A  61                                  DSPATR(PC)
     A            F1EMSG        17A  O  7  2DSPATR(BL)
     A                                  9  2'F3:END'
     A* ----------------------------------------------------
     A          R FMT020
     A                                      CF03
     A                                  1  5' BPT SCAN '
     A                                      DSPATR(RI)
     A                                  2  2'MATERIAL HANDLING'
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A                                  3  6' KANBAN '
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A            BRCD20       400A  B  5  1DSPATR(UL)
     A                                      CHECK(ER)
     A  62                                  DSPATR(RI)
     A  62                                  DSPATR(PC)
     A            F2EMSG        17A  O 11  4DSPATR(BL)
     A                                 13  2'F3=END'
     A* ----------------------------------------------------
     A          R FMT030
     A                                      CF03
     A                                      CF05
     A                                  1  4' BPT SCAN '
     A                                      DSPATR(RI)
     A                                  6  3' LOT ID TAG '
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A            BRCD30         8A  B  9  5DSPATR(UL)
     A                                      CHECK(ER)
     A  63                                  DSPATR(RI)
     A  63                                  DSPATR(PC)
     A            F3EMSG        17A  O 11  2DSPATR(BL)
     A                                 13  2'F3 = End'
     A                                  7  5'of'
     A            TLOTS          1S 0O  7  3COLOR(PNK)
     A            #LOTS          1S 0O  7  8COLOR(PNK)
     A                                  7 10'scanned'
     A                                  3  2'IAF Part#'
     A                                  4  2'ASJ Part#'
     A            WHSHI1         5   O  3 12COLOR(PNK)
     A            WHSHI2         5   O  3 18COLOR(PNK)
     A            WHSHI3         2   O  3 24COLOR(PNK)
     A            WHPAR1         5   O  4 12COLOR(PNK)
     A            WHPAR2         5   O  4 18COLOR(PNK)
     A            WHPAR3         2   O  4 24COLOR(PNK)
     A* ----------------------------------------------------
     A          R FMT040
     A                                      CF03
     A                                      CF05
     A                                  1  5' BPT SCAN '
     A                                      DSPATR(RI)
     A                                  6  3' ASJ BPT KANBAN '
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A            BRCD40        17A  B  9  2DSPATR(UL)
     A                                      CHECK(ER)
     A  64                                  DSPATR(RI)
     A  64                                  DSPATR(PC)
     A            F4EMSG        17A  O 11  2DSPATR(BL)
     A                                 13  2'F3=End'
     A            TKANB          2Y 0O  7  3COLOR(PNK)
     A                                      EDTWRD('0 ')
     A                                  7  6'of'
     A            #KANBS         2S 0O  7  9COLOR(PNK)
     A                                  7 12'scanned'
     A                                  3  2'IAF Part#'
     A                                  4  2'ASJ Part#'
     A            WHSHI1         5A  O  3 12COLOR(PNK)
     A            WHSHI2         5A  O  3 18COLOR(PNK)
     A            WHSHI3         2A  O  3 24COLOR(PNK)
     A            WHPAR1         5A  O  4 12COLOR(PNK)
     A            WHPAR2         5A  O  4 18COLOR(PNK)
     A            WHPAR3         2A  O  4 24COLOR(PNK)
     A                                 13 14'F5=Done'
     A* ----------------------------------------------------
     A          R FMT999
     A                                  1  2'*******************'
     A                                      DSPATR(BL)
     A                                  2  2'*******************'
     A                                      DSPATR(BL)
     A                                  3  2'*******************'
     A                                      DSPATR(BL)
     A                                  4  2'*                 *'
     A                                      DSPATR(BL)
     A                                  5  2'*                 *'
     A                                      DSPATR(BL)
     A                                  6  2'*'
     A                                      DSPATR(BL)
     A            F99ER1        15A  O  6  4
     A                                      DSPATR(BL)
     A                                  6 20'*'
     A                                      DSPATR(BL)
     A                                  7  2'*'
     A                                      DSPATR(BL)
     A            F99ER2        15A  O  7  4
     A                                      DSPATR(BL)
     A                                  7 20'*'
     A                                      DSPATR(BL)
     A                                  8  2'*                 *'
     A                                      DSPATR(BL)
     A                                  9  2'*                 *'
     A                                      DSPATR(BL)
     A                                 10  2'*******************'
     A                                      DSPATR(BL)
     A                                 11  2'*******************'
     A                                      DSPATR(BL)
     A                                 12  2'*******************'
     A                                      DSPATR(BL)
     A                                 14  2'ENTER:CONTINUE'
     A                                      DSPATR(HI)
