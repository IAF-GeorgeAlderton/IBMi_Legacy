     A*%%TS  SD  20231213  090118  I0777       REL-V7R3M0  5770-WDS
     A** AB#PWHG ******************************************************
     A*  INQUIRY HONDA PLANT/SHIP TABLE BY DELIVERY CODE              *
     A*  JW    2023.03.03
     A*****************************************************************
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*---------------------------------------*
     A          R SFREC1                    SFL
     A*%%TS  SD  20231213  090118  I0777       REL-V7R3M0  5770-WDS
     A            S1SEL          1A  B  5  2DSPATR(ND)
     A            S1NONY         4A  O  5  5TEXT('DELIVERY CODE')
     A                                      COLOR(WHT)
     A            S1KMEI        17A  O  5 10TEXT('FACTORY NAME (KANA)')
     A            S1TOKU         4A  O  5 29TEXT('CUSTMER CODE')
     A                                      COLOR(WHT)
     A            S1SMEI         5A  O  5 34TEXT('DETAIL NAME KANA')
     A            S1PLNT         3A  O  5 41TEXT('PLANT ID')
     A                                      COLOR(YLW)
     A            S1SHCD        10A  O  5 46TEXT('SHIP TO CODE')
     A                                      COLOR(YLW)
     A            S1SHIP         1A  O  5 59
     A*---------------------------------------*
     A          R SFCTL1                    SFLCTL(SFREC1)
     A*%%TS  SD  20231213  090118  I0777       REL-V7R3M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      CF03(03)
     A                                      OVERLAY
     A                                      PROTECT
     A  70                                  SFLDSPCTL
     A  71                                  SFLDSP
     A  72                                  SFLCLR
     A  90                                  SFLEND(*MORE)
     A                                      ROLLUP(73)
     A                                      ROLLDOWN(73)
     A                                      SFLCSRRRN(&$RRN)
     A            RRN1           4S 0H      SFLRCDNBR
     A            $RRN           5S 0H
     A                                  1  3'AB#RHG'
     A                                  1 18'** HONDA PLANT AND SHIPTO CODE INQ-
     A                                       **'
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A                                  1 60DATE
     A                                      EDTCDE(Y)
     A                                  1 70TIME
     A                                  2  3'DELV#:'
     A            XNONY          4Y 0B  2 10EDTCDE(4)
     A                                      DSPATR(UL)
     A                                  2 22'(SORT BY DELIV# AND CUST#)'
     A                                  2 70USER
     A                                  3 58'SHIP'
     A                                      DSPATR(UL)
     A*
     A                                  4  4'DELV#'
     A                                      DSPATR(UL)
     A                                      COLOR(WHT)
     A                                  4 10'DELIVERY NAME    '
     A                                      DSPATR(UL)
     A                                  4 28'CUST#'
     A                                      DSPATR(UL)
     A                                      COLOR(WHT)
     A                                  4 34'NAME '
     A                                      DSPATR(UL)
     A                                  4 40'PLANT'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  4 46'SHIP CODE '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  4 57'MASTER'
     A                                      DSPATR(UL)
     A*
     A          R DSP01
     A*%%TS  SD  20230303  090620  I0777       REL-V7R3M0  5770-WDS
     A                                 24  4' F3 '
     A                                      DSPATR(RI)
     A                                 24  9'BACK'
     A                                 24 52' POSITION CURSOR TO SELECT '
     A                                      DSPATR(RI)
