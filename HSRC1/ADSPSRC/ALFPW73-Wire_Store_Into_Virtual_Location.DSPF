      **** ALFPW77 *****************************************
      * WIRE STORE INTO VIRTUAL LOCATION                   *
      *   LEC....................    2025.06.24            *
      ******************************************************
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
      *
     A          R ALFPW771
     A                                      CF01(01)
     A  99                                  ALARM
     A                                      OVERLAY
     A                                  1  2' ** WIRE STORE INTO LOC **'
     A                                      DSPATR(RI)
     A                                  3  3' LOCATION KANBAN '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A            D1QR          10A  B  4  3DSPATR(UL)
     A                                 14  2'F1: End'
     A          R ALFPW772
     A  99                                  ALARM
     A                                      OVERLAY
     A                                      CF01(01)
     A                                  1  2' ** WIRE STORE INTO LOC **'
     A                                      DSPATR(RI)
     A                                  3  7' WIRE KANBAN '
     A                                      DSPATR(RI)
     A                                      DSPATR(UL)
     A            D2QR          20A  B  4  7DSPATR(UL)
     A                                 14  2'F1: Back'
     A*
     A          R ALFPW095
     A                                  1  2' OOOOOO            '
     A                                  2  2'OO    OO           '
     A                                  3  2'OO    OO           '
     A                                  4  2'OO    OO           '
     A                                  5  2'OO    OO  KK    KKK'
     A                                  6  2'OO    OO  KK   KK  '
     A                                  7  2' OOOOOO   KK  KK   '
     A                                  8  2'          KKKKK    '
     A                                  9  2'          KK  KK   '
     A                                 10  2'          KK   KK  '
     A                                 11  2'          KK    KKK'
     A                                 14  2'ENTER:CONTINUE'
     A          R ALFPW098
     A                                      OVERLAY
     A  90
     AO 99                                  ALARM
      *
     A          R ALFPW099
     A                                      OVERLAY
     A                                  1  2' ** WIRE STORE ERROR ** '
     A                                      DSPATR(RI)
     A                                  4  6'***          ***'    COLOR(RED)
     A                                  5  6'  ***      ***  '    COLOR(RED)
     A                                  6  6'    ***  ***    '    COLOR(RED)
     A                                  7  6'      ****      '    COLOR(RED)
     A                                  8  6'    ***  ***    '    COLOR(RED)
     A                                  9  6'  ***      ***  '    COLOR(RED)
     A                                 10  6'***          ***'    COLOR(RED)
     A            D9ERR         25A  O 12  2DSPATR(RI)
     A                                 14  2'ENTER:CONTINUE'      COLOR(WHT)
