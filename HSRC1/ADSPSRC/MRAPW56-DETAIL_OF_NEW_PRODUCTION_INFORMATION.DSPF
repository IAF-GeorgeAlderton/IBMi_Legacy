     A** MRAPW56 *******************************************
     A* DETAIL OF NEW PRODUCTION INFORMATION               *
     A*     TRANCOM ITS.                  2012.10.25       *
     A******************************************************
     A                                      PRINT(QPRINT)
     A                                      CHGINPDFT
     A          R MRAPW561
     A                                      CF03(03)
     A                                      CF05(05)
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 22' ** DETAIL OF NEW +
     A                                       PRODUCTION INFO ** '
     A                                      DSPATR(RI UL)
     A                                  1 69'FMT'
     A                                  1 73'MRAPW56'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTCDE(Y)
      *
     A                                  4  4'INHOUSE PART NO  '
     A                                      DSPATR(UL)
     A                                  4 26'PART OR COMPO'
     A                                      DSPATR(UL)
     A                                  4 42'LOCATION  '
     A                                      DSPATR(UL)
     A                                  4 57'CREATER   '
     A                                      DSPATR(UL)
     A                                  4 69'KEY NO    '
     A                                      DSPATR(UL)
     A            D1SHN1         5A     5  4
     A                                   + 1'-'
     A            D1SHN2         5A      + 1
     A                                   + 1'-'
     A            D1SHN3         2A      + 1
      *
     A            D1SEKB         9A     5 26
     A            D1PRKB        10A     5 42
     A            D1CRAT        10A     5 57
     A            D1KEYN        10A     5 69
      *
     A                                  7  4'CUSTOMER PART NUMBER          '
     A                                      DSPATR(UL)
     A                                  7 40'CUSTOMER'
     A                                      DSPATR(UL)
     A                                  7 51'CAR CODE'
     A                                      DSPATR(UL)
     A                                  7 61'E.C NO.     '
     A                                      DSPATR(UL)
      *
     A            D1MHN1         5A     8  5
     A                                   + 1'-'
     A            D1MHN2         5A      + 1
     A                                   + 1'-'
     A            D1MHN3         5A      + 1
     A                                   + 1'-'
     A            D1MHN4         5A      + 1
      *
     A            D1TMEI         8A     8 40
      *
     A            D1SYKI         4A     8 52
      *
     A            D1SENO        12A     8 61
      *
     A                                 10  4'MASS PRODUCTION DATE'
     A                                      DSPATR(UL)
     A                                 10 29' QUANTITY '
     A                                      DSPATR(UL)
     A                                 10 40'NEED TOOLINGS?'
     A                                      DSPATR(UL)
     A                                 10 61'TOOL ORDER DATE'
     A                                      DSPATR(UL)
      *
     A            D1STYY         4Y 0  11  5EDTCDE(Z)
     A                                   + 1'/'
     A            D1STMM         2Y 0    + 1EDTCDE(Z)
     A                                   + 1'/'
     A            D1STDD         2Y 0    + 1EDTCDE(Z)
      *
     A            D1SRYO         8Y 0  11 28EDTWRD('  ,   , 0 ')
      *
     A            D1KANA         1A    11 42
     A                                   + 1'Y:YES N:NO'
      *
     A            D1PTAY         4Y 0  11 61EDTCDE(Z)
     A                                   + 1'/'
     A            D1PTAM         2Y 0    + 1EDTCDE(Z)
     A                                   + 1'/'
     A            D1PTAD         2Y 0    + 1EDTCDE(Z)
      *
     A                                 12 61'TOOL ARRIVAL DATE'
     A                                      DSPATR(UL)
     A            D1TLYY         4Y 0  13 61EDTCDE(Z)
     A                                   + 1'/'
     A            D1TLMM         2Y 0    + 1EDTCDE(Z)
     A                                   + 1'/'
     A            D1TLDD         2Y 0    + 1EDTCDE(Z)
      *
     A                                 13  4'ORDER START DATE'
     A                                      DSPATR(UL)
     A                                 13 29'COMPLETE PART NUMBER'
     A                                      DSPATR(UL)
     A                                 15 61'BLANK PART NUMBER'
     A                                      DSPATR(UL)
     A                                 16 61'MASS PRODUCTION DATE'
     A                                      DSPATR(UL)
      * ORDER START DATE
     A            D1OSYY         4Y 0  14  5EDTCDE(Z)
     A                                   + 1'/'
     A            D1OSMM         2Y 0    + 1EDTCDE(Z)
     A                                   + 1'/'
     A            D1OSDD         2Y 0    + 1EDTCDE(Z)
      * COMPLETE PART NO
     A            D1CHN1         5A    14 30
     A                                   + 1'-'
     A            D1CHN2         5A      + 1
     A                                   + 1'-'
     A            D1CHN3         2A      + 1
      * BLANK PART NO
     A            D1BHN1         5A    17 61
     A                                   + 1'-'
     A            D1BHN2         5A      + 1
     A                                   + 1'-'
     A            D1BHN3         2A      + 1
     A            D1BTYY         4Y 0  18 61EDTCDE(Z)
     A                                   + 1'/'
     A            D1BTMM         2Y 0    + 1EDTCDE(Z)
     A                                   + 1'/'
     A            D1BTDD         2Y 0    + 1EDTCDE(Z)
     A                                 16  4'PILOT INFORMATION           '
     A                                      DSPATR(UL)
     A            D1PIYY         4Y 0  17  4EDTCDE(Z)
     A                                   + 1'/'
     A            D1PIMM         2Y 0    + 1EDTCDE(Z)
     A                                   + 1'/'
     A            D1PIDD         2Y 0    + 1EDTCDE(Z)
     A            D1PISR         6Y 0    + 2EDTWRD('   ,   -PCS')
      *
     A                                 20  4' REMARKS '
     A                                      DSPATR(UL)
      *
      *
     A            D1BIKO        72A    21  4
      *
     A                                 23  2' ERR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1ERR         60A  O 23  8
     A  99                                  DSPATR(HI)
     A N99                                  DSPATR(ND)
      *
     A                                 24  2'BACK'
     A                                   + 1' F3 ' DSPATR(RI)
     A                                   + 2'ACCEPT'
     A                                   + 1' F5 ' DSPATR(RI)
     A                                   + 2'NEXT'
     A                                   + 1' ENTER ' DSPATR(RI)
