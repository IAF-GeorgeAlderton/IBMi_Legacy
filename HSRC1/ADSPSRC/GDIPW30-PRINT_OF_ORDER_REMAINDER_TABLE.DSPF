      **** GDIPW30 ***************************************************
      *     PRINT OF ORDER REMAINDER TABLE
      *     G.B.C                         97/02/24
      ****************************************************************
     A                                      PRINT
     A                                      CHGINPDFT(CS)
     A**************
     A* ＤＳＰ１ *
     A**************
     A          R DSP01                     CF01 CF05
     A                                  1  2'TIME'
     A                                  1  7 TIME
     A                                  1 17'ISSUING OF DATA STATEMEN-
     A                                      T FOR THE YET-ORDERED'
     A                                      DSPATR(RI)
     A                                    +1'(DIE)'
     A                                  1 69'FMT GDIPW30'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('  .  .  ')
     A                                  6 19'ISSUING DATA STATEMENT -
     A                                      FOR THE YET-ORDERED.'
     A                                 10 23'DIE NO.'
     A            D1KAT1         2   B 10 34
     A  11                                  DSPATR(RI PC)
     A                                   + 1'-'
     A            D1KAT2         4   B   + 1AUTO(RAZ)
     A  11                                  DSPATR(RI)
     A                                   + 1'-'
     A            D1KAT3         1   B   + 1
     A  11                                  DSPATR(RI)
     A                                   + 1'-'
     A            D1KAT4         1   B   + 1
     A  11                                  DSPATR(RI)
     A                                 12 15'(ALL DIE NUMBERS BE OUTP-
     A                                      UT IF THERE IS NO INPUT.)'
     A                                 22 11' ERROR '
     A  99                                  DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D#MSG         59     22 23
     A  99                                  DSPATR(BL)
     A N99                                  DSPATR(ND)
     A                                 24 10'END JOB'
     A                                   + 1' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 34'INPUT OK'
     A                                   + 1' CMD-5 '
     A                                      DSPATR(RI)
