     A            S1SHN         14A     5  4
     A            S1AP           8Y 0   5 19EDTWRD('  /  /  -  ')
     A            S1TIMS         3Y 0   5 32EDTWRD(' 0 ')
     A            S1HKSA         3Y 0   5 38EDTWRD(' 0 ')
     A            S1SYUY         5Y 0   5 43EDTWRD('  , 0 ')
     A            S1MAX          3Y 0   5 51EDTWRD(' 0 ')
     A            S1CUTH         5Y 2   5 56EDTWRD(' 0 .  ')
     A  39                                  DSPATR(BL)
     A            S1BOXD         6Y 2   5 63EDTWRD('  0 .  ')
     A            S1DOH          6Y 2   5 72EDTWRD('  0 .  ')
      *非表示項目
     A            @RRN           4Y 0H
     A            H1APHZ         8Y 0H
     A            H1APBN         2Y 0H
     A            H1SHN1         5A  H
     A            H1SHN2         5A  H
     A            H1SHN3         2A  H
     A            H1HND          3Y 0H
     A            H1RNJ          3Y 0H
     A            H1IN39         1A  H
