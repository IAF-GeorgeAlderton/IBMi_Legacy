     A                                      ROLLUP(51)
     A                                      ROLLDOWN(52)
     A N99                                  CSRLOC(S@SLIN S@SCLM)
      *
     A            @SFRC1         4  0H      SFLRCDNBR(CURSOR)
     A            S@SLIN         3Y 0H
     A            S@SCLM         3Y 0H
      *
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 25' ** HIGH LIMIT DATA INQUIRY ** '
     A                                      DSPATR(RI)
     A                                  1 69'FMT ADKPWA5'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
      *
     A                                  3 46'BOX'
     A                                  3 58'OVER'
     A                                  3 72'DAYS OF'
