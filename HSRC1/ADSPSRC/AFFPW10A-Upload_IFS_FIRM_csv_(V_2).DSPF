     A*%%TS  SD  20240514  104644  I0777       REL-V7R4M0  5770-WDS
     A** AFFPW10 *****************************************************
     A*  UPLOAD FIRM ORDER.CSV FROM IFS DATA
     A*  J.WATANABE  2018.04.24
     A****************************************************************
     A*
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*
     A          R DSP01
     A*%%TS  SD  20240514  104644  I0777       REL-V7R4M0  5770-WDS
     A                                      TEXT(' ')
     A                                      CF01(01)
     A                                  1  3'AFFR10A'
     A                                  1 21'** UPLOAD FIRM ORDER from CSV FILE-
     A                                       **'
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A                                  1 63DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A                                  4  6'Step1: Save ORDER Data To:'
     A                                  5 13'(J:) /PC/UPLOAD/IFS.FIRM.csv'
     A                                  7  6'Step2: Press ENTR to validate Sour-
     A                                      ce Data, then Press F5 to upload'
     A                                  9  8'** Format of IFS.FIRM.csv **'
     A                                      COLOR(YLW)
     A                                 10 10'<** Must Enter **>'
     A                                      COLOR(WHT)
     A                                 10 38'<** Option **>'
     A                                 11 10'A: IAF Delivery Code'
     A                                      COLOR(WHT)
     A                                 11 38'G: Factory'
     A                                 12 10'B: Ship Date (YYYY/MM/DD)'
     A                                      COLOR(WHT)
     A                                 12 38'H: Dock'
     A                                 13 10'C: Bin#'
     A                                      COLOR(WHT)
     A                                 13 38'I: Invoice#'
     A                                 14 10'D: User Part'
     A                                      COLOR(WHT)
     A                                 15 10'E: Order Quantity'
     A                                      COLOR(WHT)
     A                                 16 10'F: Order#'
     A                                      COLOR(WHT)
     A                                 18  6'| A   |      B    | C |      D    -
     A                                       |  E  |   F   | G | H  |   I   |'
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                 19  3'ex.|0567 |2018.06.30 |02 |90801-00-
     A                                      801 |3000 |869101 | 0 | 00 |123456 -
     A                                      |'
     A                                      COLOR(YLW)
     A            XMSG          70A  O 22  6COLOR(WHT)
     A                                 24  6'F1'
     A                                      DSPATR(RI)
     A                                 24  9'EXIT'
     A                                 24 21'ENTR'
     A                                      DSPATR(RI)
     A                                 24 26'Get and Check Order Data (IFS.FIRM-
     A                                      .csv)'
     A*------------------------*
     A          R SFL01                     SFL
     A*%%TS  SD  20180618  133014  I0777       REL-V7R3M0  5770-WDS
     A*------------------------*
     A**          RRN1           4Y 0H
     A            S1TOKU         4Y 0H
     A            S1NONY         4Y 0H
     A            S1PART        20A  H
     A            S1UHIN        20A  H
     A            S1SHIN        12A  H
      *
     A            S1LIN#         3Y 0O  6  2COLOR(TRQ)
     A            S1SHDT         8Y 0O  6  6EDTWRD('    /  /  ')
     A                                      COLOR(WHT)
     A            S1BN#          2S 0O  6 17COLOR(WHT)
     A            S1PRT2        14A  O  6 20COLOR(WHT)
     A            S1QTY          7Y 0O  6 35EDTCDE(1)
     A                                      COLOR(WHT)
     A            S1PO#         10A  O  6 45COLOR(WHT)
     A            S1NKOJ         1A  O  6 56
     A            S1NUKE         4A  O  6 58
     A            S1INVN        10A  O  6 63
     A**          S1SBAN         6A  O  6 74
     A*---------------------------------------*
     A*  SUB FILE CONTROL                   *
     A*---------------------------------------*
     A          R CTL01                     SFLCTL(SFL01)
     A*%%TS  SD  20240129  132423  I0777       REL-V7R4M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      OVERLAY
     A                                      CF03(03)
     A                                      CF05(05)
     A                                      CF12(12)
     A  72                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  71                                  SFLCLR
     A N73                                  SFLEND(*MORE)
     A                                      PROTECT
     A*
     A                                  1  3'AFFPW10A'
     A                                  1 18'** UPLOAD FIRM ORDER from CSV FILE-
     A                                       **'
     A                                      DSPATR(RI)
     A                                  1 63DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  1 72TIME
     A            XALT          50A  O  2 16COLOR(WHT)
     A*
     A                                  4  3'DELIVERY CODE:'
     A                                      DSPATR(RI)
     A            XSUPP          4A  O  4 18COLOR(YLW)
     A            XSUPN         20A  O  4 23COLOR(YLW)
     A*
     A                                  5  2'Ln#'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5  6'SHIP DATE'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 16'BIN'
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  5 20'USER PART#    '
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  5 35'ORDER QTY'
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  5 45'ORDER#    '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 56'F'
     A                                      DSPATR(UL)
     A                                      COLOR(TRQ)
     A                                  5 58'DOCK'
     A                                      DSPATR(UL)
     A                                      COLOR(TRQ)
     A                                  5 63'INVOICE#  '
     A                                      DSPATR(UL)
     A                                      COLOR(TRQ)
     A*------------------------*
     A          R DSP91
     A*%%TS  SD  20180620  092708  I0777       REL-V7R3M0  5770-WDS
     A                                      OVERLAY
     A                                      PROTECT
     A            D9ERR         70A  O 23  2COLOR(YLW)
     A                                 24  2'F3'
     A                                      DSPATR(RI)
     A                                 24  5'BACK'
     A                                 24 17'F5'
     A                                      DSPATR(RI)
     A                                 24 20'UPLOAD'
     A                                 24 35'PAGE UP/DOWN'
     A                                      DSPATR(RI)
     A*------------------------*
     A*------------------------*
     A**          RRN2           4Y 0H
     A          R SFL02                     SFL
     A*%%TS  SD  20240124  150354  I0777       REL-V7R4M0  5770-WDS
     A*------------------------*
     A**          RRN2           4Y 0H
     A            S2LIN#         3Y 0O  6  3COLOR(TRQ)
     A            S2ERR         14A  O  6  8COLOR(WHT)
     A            S2NKOJ         1A  O  6 23
     A            S2NUKE         4A  O  6 25
     A            S2MSG         50A  O  6 30
     A*---------------------------------------*
     A*  SUB FILE CONTROL                   *
     A*---------------------------------------*
     A          R CTL02                     SFLCTL(SFL02)
     A*%%TS  SD  20240129  132423  I0777       REL-V7R4M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      CF03(03)
     A                                      CF12(12)
     A  72                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  71                                  SFLCLR
     A N73                                  SFLEND(*MORE)
     A                                      OVERLAY
     A                                      PROTECT
     A                                  1  2'AFFPW10A'
     A                                  1 26'** CSV FILE ERROR **'
     A                                      DSPATR(RI)
     A                                      COLOR(RED)
     A                                      DSPATR(BL)
     A                                  1 63DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  1 72TIME
     A            XALT          50A  O  2 16COLOR(WHT)
     A*
     A                                  4  2'DELIVERY CODE:'
     A                                      DSPATR(RI)
     A            XSUPP          4A  O  4 17COLOR(YLW)
     A            XSUPN         20O  O  4 22COLOR(YLW)
     A*
     A                                  5  2'Line#'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5  8'Error Field   '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 23'F'
     A                                      DSPATR(UL)
     A                                  5 25'Dock'
     A                                      DSPATR(UL)
     A                                  5 30'Error Message                     -
     A                                                      '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A*------------------------*
     A          R DSP92
     A*%%TS  SD  20180608  164548  I0777       REL-V7R3M0  5770-WDS
     A                                      OVERLAY
     A                                      PROTECT
     A            D9ERR         70A  O 23  2COLOR(YLW)
     A                                 24  2'F3'
     A                                      DSPATR(RI)
     A                                 24  5'BACK'
     A                                 24 21'PAGE UP/DOWN'
     A                                      DSPATR(RI)
