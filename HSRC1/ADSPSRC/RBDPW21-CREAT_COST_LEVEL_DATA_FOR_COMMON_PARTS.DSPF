     A** RBDPW21 *************************************
     A*  .. CREAT COST LEVEL DATA FOR COMMON PARTS ..*
     A*      C:Y.AOYAMA            1992.05.25        *
     A*        GBC                 2000.07.14        *
     A*********************************** RBDPW21 ****
     A                                      PRINT
     A                                      CHGINPDFT
     A*---------------
     A* RBDPW211
     A*---------------
     A          R RBDPW211                  KEEP
     A  99                                  ALARM
     A                                      CF01 CF05
     A                                  1  2'TIME'
     A                                  1  7TIME EDTWRD('0 :  :  ')
     A                                  1 20' **  CREAT COST LEVEL DATA +
     A                                        FOR COMMON PARTS  ** '
     A                                      DSPATR(RI UL)
     A                                  1 68'FMT RBDPW211'
     A                                  2  2'DATE'
     A                                  2  7DATE EDTWRD('0  .  .  ')
     A                                  5 14' TERM     '
     A            SHIZK          4Y 0B  5 30DSPATR(CS)
     A  91                                  DSPATR(RI PC)
     A                                  5 35' - '
     A            EHIZK          4Y 0B  5 40DSPATR(CS)
     A  92                                  DSPATR(RI PC)
     A                                  7 14' USER   '
     A            DTOKU          4Y 0B  7 30DSPATR(CS)
     A                                      EDTCDE(Z)
     A  93                                  DSPATR(RI PC)
     A                                  7 35' <-- MAKERS WITH VARIOUS UNIT +
     A                                       PRICE DEPENDING'
     A                                  8 40'OR PLANT & RECEIVE CANNOT BE +
     A                                       APPOINTED.'
     A*
     A                                 10 14' PLANT'
     A            DTKOJ          1A  B 10 30DSPATR(CS)
     A                                 10 35' <-- INPUT PLANT CODE (OPTION).'
     A                                 12  4'USER FOR COST REFERENCE'
     A            STOKU          4Y 0B 12 30DSPATR(CS)
     A                                      EDTCDE(Z)
     A  94                                  DSPATR(RI PC)
     A                                 12 35' <-- SAME AS COMMEN FOR USER.'
     A            @YN            1A  B 14 19DSPATR(CS)
     A  30                                  DSPATR(RI PC)
     A                                 14 21' <-- DOES QUOTATION INCLUDE +
     A                                       SALES QUANTITY (Y/N).'
     A            #TOKU          4Y 0B 16 16DSPATR(CS)
     A                                      EDTCDE(Z)
     A  31                                  DSPATR(RI PC)
     A                                 16 21' <-- INPUT USER CODE TO +
     A                                       INPUT SALES QUANTITY.'
     A            #TKOJ          1A  B 18 19DSPATR(CS)
     A  32                                  DSPATR(RI PC)
     A                                 18 21' <-- INPUT PLANT CODE TO +
     A                                       INPUT SALES QUANTITY.'
     A  99                             22 11'ERROR'
     A                                      DSPATR(RI BL)
     A  99        MSG           60A  O 22 18DSPATR(HI)
     A                                 24  8'CANCEL'
     A                                 24 15' CMD-1 '
     A                                      DSPATR(RI)
     A                                 24 25'LIST CREATE'
     A                                 24 38' CMD-5 '
     A                                      DSPATR(RI)
