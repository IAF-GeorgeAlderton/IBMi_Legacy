     A                                      PRINT(*LIBL/QPRINT)
     **==============================================================**
     **  画面１（ＤＳＰ０１）
     **==============================================================**
     A          R MRHPW111
     A*<<キーワード定義>>
     A                                      CF01(01 '終了')
     A                                      CF12(12)
     A                                      OVERLAY
     A*<<カーソル制御用>>
     A                                      RTNCSRLOC(&D1RCD  &D1FLD)
     A                                      CSRLOC(D1LIN D1COL)
     A            D1LIN          3S 0H      TEXT('fｰﾓ制御（行）')
     A            D1COL          3S 0H      TEXT('fｰﾓ制御（桁）')
     A            D1RCD         10A  H      TEXT('ﾛﾃｰnﾞ')
     A            D1FLD         10A  H      TEXT('ﾎｧｰﾓnﾞID')
     A*<<フィールド定義>>
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 26'***  LOCATION MAINTENANCE  ***'
     A                                      DSPATR(HI RI)
     A                                  1 69'FMT MRHPW11'
      *
     A                                  2  2'DATE'
     A            D1SYMD         8Y 0O  2  7EDTWRD('0 /  /    ')
     A*<<入出力項目>>
     A            D1SELC         1A  B  7 22TEXT('更新区分')
     A                                      DSPATR(CS)
     A  41                                  DSPATR(RI PC)
     A            D1BAN1         1A  B  7 29TEXT('番地１')
     A                                      DSPATR(CS)
     A  42                                  DSPATR(RI PC)
     A                                  7 31'-'
     A            D1BAN2         2A  B  7 33TEXT('番地２')
     A                                      DSPATR(CS)
     A  43                                  DSPATR(RI PC)
     A                                  7 36'-'
     A            D1BAN3         2A  B  7 38TEXT('番地３')
     A                                      DSPATR(CS)
     A  44                                  DSPATR(RI PC)
     A                                  7 41'-'
     A            D1BAN4         1A  B  7 43TEXT('番地４')
     A                                      DSPATR(CS)
     A  45                                  DSPATR(RI PC)
      *
     A                                 10 22'0:DELETE'
     A                                 11 22'1:CHANGE'
     A                                 12 22'2:ADD'
     A*<<メッセージ>>
     A                                 22 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D1EMSG        53O    22 18TEXT('d[ｰxｮﾈｰﾆﾞ')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*<<ファンクション>>
     A                                 24  9'EXIT'
     A                                 24 15'CMD-1'
     A                                      DSPATR(RI)
     A                                 24 32'NEXT SCREEN'
     A                                 24 45'ENTER'
     A                                      DSPATR(RI)
     A                                 24 55'INQ'
     A                                   + 1'CMD-12'
     A                                      DSPATR(RI)
     **==============================================================**
     **  画面２（ＤＳＰ０２）
     **==============================================================**
     A          R MRHPW112
     A*<<キーワード定義>>
     A                                      CF03(03 '前画面')
     A                                      CF05(05 '更新')
     A  91                                  CF06(06 'スクラップ')
     A                                      OVERLAY
     A*<<カーソル制御用>>
     A                                      RTNCSRLOC(&D2RCD  &D2FLD)
     A                                      CSRLOC(D2LIN D2COL)
     A            D2LIN          3S 0H      TEXT('fｰﾓ制御（行）')
     A            D2COL          3S 0H      TEXT('fｰﾓ制御（桁）')
     A            D2RCD         10A  H      TEXT('ﾛﾃｰnﾞ')
     A            D2FLD         10A  H      TEXT('ﾎｧｰﾓnﾞID')
     A*<<フィールド定義>>
     A                                  1  2'TIME'
     A                                  1  7TIME
     A                                  1 21'***  LOCATION MAINTENANCE        -
     A                                          ***'
     A                                      DSPATR(HI RI)
     A                                  1 69'FMT'
      *
     A                                  2  2'DATE'
     A            D1SYMD         8Y 0O  2  7EDTWRD('0 /  /    ')
     A*<<入出力項目>>
     A                                  4  8'UPDATE'
     A                                  4 20'LOCATION CODE'
     A            D2SEL          8A  O  6  8TEXT('更新区分／名称')
     A            D1BAN1         1A  O  6 20TEXT('番地１')
     A                                  6 22'-'
     A            D1BAN2         2A  O  6 24TEXT('番地２')
     A                                  6 27'-'
     A            D1BAN3         2A  O  6 29TEXT('番地３')
     A                                  6 32'-'
     A            D1BAN4         1A  O  6 34TEXT('番地４')
     A                                  8  8'----------------------------------
     A                                      -----------------------------------
     A                                      ----'
      *
     A                                 10  8'LOCATION SIZE'
     A            D2HAKO         3Y 0B 12 10TEXT('番地サイズ')
     A                                      CHECK(RB)
     A                                      EDTCDE(4)
     A N90                                  DSPATR(CS)
     A  90                                  DSPATR(PR)
     A  46                                  DSPATR(RI PC)
     A N92                             10 25'PART NUMBER'
     A N92        D2HIN1         5A  B 12 25TEXT('品番１')
     A N92N90N91                            DSPATR(CS)
     A N92                                  DSPATR(PR)
     A*N92 90                               DSPATR(PR)
     A  47N92                               DSPATR(RI PC)
     A N92                             12 31'-'
     A N92        D2HIN2         5A  B 12 33TEXT('品番２')
     A N92N90N91                            DSPATR(CS)
     A N92                                  DSPATR(PR)
     A*N92 90                               DSPATR(PR)
     A  48N92                               DSPATR(RI PC)
     A N92                             12 39'-'
     A N92        D2HIN3         2A  B 12 41TEXT('品番３')
     A N92N90N91                            DSPATR(CS)
     A N92                                  DSPATR(PR)
     A*N92 90                               DSPATR(PR)
     A  49N92                               DSPATR(RI PC)
     A N92                             10 54'LOT NUMBER'
     A N92        D2LNO1         4A  B 12 54TEXT('手配番号１')
     A N92N90N91                            DSPATR(CS)
     A N92                                  DSPATR(PR)
     A*N92 90                               DSPATR(PR)
     A  50N92                               DSPATR(RI PC)
     A N92                             12 59'-'
     A N92        D2LNO2         3A  B 12 61TEXT('手配番号２')
     A N92N90N91                            DSPATR(CS)
     A N92                                  DSPATR(PR)
     A*N92 90                               DSPATR(PR)
     A  51N92                               DSPATR(RI PC)
     A*<<メッセージ>>
     A                                 22 11'ERROR'
     A                                      DSPATR(RI)
     A N99                                  DSPATR(ND)
     A            D2EMSG        53O    22 18TEXT('d[ｰxｮﾈｰﾆﾞ')
     A  99                                  DSPATR(RI BL)
     A N99                                  DSPATR(ND)
     A*<<ファンクション>>
     A                                 24  9'PREV'
     A                                 24 15'CMD-3'
     A                                      DSPATR(RI)
     A                                 24 32'UPDATE OK'
     A                                 24 43'CMD-5'
     A                                      DSPATR(RI)
     A  91                             24 54'SCRAP'
     A  91                             24 61'CMD-6'
     A                                      DSPATR(RI)
     **==============================================================**
     **  画面３（ＷＩＮＤＯＷ）
     **==============================================================**
     A          R MRHPW113
     A*<<キーワード定義>>
     A                                      WINDOW(15 19 3 41)
     A                                      WDWBORDER((*DSPATR RI) (*CHAR '    -
     A                                          '))
     A                                      CF03(03 'キャンセル')
     A                                      CF05(05 '実行')
     A                                      RMVWDW
     A                                      OVERLAY
     A*<<フィールド定義>>
     A                                  1  5'SCRAP OK? => YES: CMD-5'
     A                                  2  5'             NO : CMD-3'
