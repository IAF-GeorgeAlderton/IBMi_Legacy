     A*%%TS  SD  20220601  143058  I0777       REL-V7R3M0  5770-WDS
     A** AFFPW30 *****************************************************
     A*  UPLOAD TMPRICE.CSV FROM DIRECTORY(K)
     A*  J.WATANABE  2022.06.01
     A****************************************************************
     A*
     A*%%EC
     A                                      DSPSIZ(24 80 *DS3)
     A                                      CHGINPDFT
     A                                      PRINT
     A*
     A          R DSP01
     A*%%TS  SD  20220527  130307  I0777       REL-V7R3M0  5770-WDS
     A                                      TEXT(' ')
     A                                      CF01(01)
     A                                  1  3'AFFR30'
     A                                  1 16'** UPLOAD INVOICE PRICE from CSV F-
     A                                      ILE **'
     A                                      DSPATR(UL)
     A                                      DSPATR(HI)
     A                                  1 63DATE
     A                                      EDTCDE(Y)
     A                                  1 72TIME
     A                                  4  6'Step1: Save PRICE Data To:'
     A                                  4 33'(K:) /UPLOAD/TMPRICE.csv'
     A                                      COLOR(WHT)
     A                                  6  6'Step2: Press ENTR to validate Sour-
     A                                      ce Data, then Press F5 to upload'
     A                                  8  4'** Format of TMPRICE.csv  **'
     A                                      COLOR(YLW)
     A                                  9  7'< * = Must Enter >'
     A                                      COLOR(WHT)
     A                                  9 35'< * = Must Enter >'
     A                                      COLOR(WHT)
     A                                 10  9' A: Acct#'
     A                                 10 37'*H: Part Number'
     A                                      COLOR(WHT)
     A                                 11  9'*B: "TMMC"'
     A                                      COLOR(WHT)
     A                                 11 37'*I: Correct Price'
     A                                      COLOR(WHT)
     A                                 12  9' C: Invoiced Date'
     A                                 12 37'*J: Old Price'
     A                                      COLOR(WHT)
     A                                 13  9'*D: Ship Date'
     A                                      COLOR(WHT)
     A                                 13 37' K: Order Qty'
     A                                 14  9' E: Manifest#'
     A                                 14 37'*L: Invoiced Qty'
     A                                      COLOR(WHT)
     A                                 15  9'*F: Order#'
     A                                      COLOR(WHT)
     A                                 15 37' M: Currecncy'
     A                                 16  9' G: Receive#'
     A                                 16 37'*N: Error Code (=IB)'
     A                                      COLOR(WHT)
     A                                 17  6'| A   |  B  |   C      |    D    |-
     A                                          E   |     F      |  G  |     '
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                 18  3'ex.|1731 |TMMC |2/15/2022 |2/1/202-
     A                                      2 |1731B...|B9BD2035D06 |F868 |    -
     A                                       '
     A                                      COLOR(YLW)
     A                                 20  6'|     H         |   I   |    J   |-
     A                                        K  |  L  | M  | N |            '
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                 21  3'ex.|90119-A0247-00 |0.0397 | 1.041-
     A                                      3 |1000 |1000 |USD |IB |           -
     A                                       '
     A                                      COLOR(YLW)
     A            XMSG          70A  O 23  6COLOR(WHT)
     A                                 24  6'F1'
     A                                      DSPATR(RI)
     A                                 24  9'EXIT'
     A                                 24 21'ENTR'
     A                                      DSPATR(RI)
     A                                 24 26'Get and Check Order Data (TMPRICE.-
     A                                      csv)'
     A*------------------------*
     A*------------------------*
     A**          RRN1           4Y 0H
     A*
     A*
     A*
     A          R SFL01                     SFL
     A*%%TS  SD  20220601  131229  I0777       REL-V7R3M0  5770-WDS
     A*
     A            S1LIN#         4A  O  6  2COLOR(TRQ)
     A            S1SHDT         8Y 0O  6  7EDTWRD('    /  /  ')
     A                                      COLOR(WHT)
     A            S1INV#        16A  O  6 18
     A            S1MHIN        14A  O  6 35COLOR(WHT)
     A            S1TMMP         6Y 4O  6 50EDTWRD('  .    ')
     A                                      COLOR(YLW)
     A            S1IAFP         6Y 4O  6 58EDTWRD('  .    ')
     A            S1QTY          7Y 0O  6 66EDTCDE(1)
     A            S1ERR          2A  O  6 76
     A**          S1SBAN         6A  O  6 74
     A*---------------------------------------*
     A*  SUB FILE CONTROL                   *
     A*---------------------------------------*
     A          R SFLCT1                    SFLCTL(SFL01)
     A*%%TS  SD  20220601  131229  I0777       REL-V7R3M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      OVERLAY
     A                                      CF03(03)
     A                                      CF05(05)
     A  72                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  71                                  SFLCLR
     A N73                                  SFLEND(*MORE)
     A                                      PROTECT
     A*
     A                                  1  2'FMT AFFPW30'
     A                                  1 18'** INVOICE PRICE CONFIRMATION **'
     A                                      DSPATR(RI)
     A                                  1 63DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  1 72TIME
     A*
     A                                  3  3'DELIVERY CODE:'
     A                                      DSPATR(RI)
     A            XSUPP          4A  O  3 18COLOR(YLW)
     A            XSUPN         20A  O  3 23COLOR(YLW)
     A                                  4 50'  TMMC '
     A                                      COLOR(YLW)
     A                                  4 58'  IAF  '
     A                                      COLOR(YLW)
     A                                  4 70'ORDER'
     A                                      COLOR(YLW)
     A*
     A                                  5  2'Lin#'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5  7'SHIP DATE'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 18'INVOICE#        '
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  5 35'PART#         '
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  5 50'  PRICE'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 58'  PRICE'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 66'      QTY'
     A                                      COLOR(YLW)
     A                                      DSPATR(UL)
     A                                  5 76'ER'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A*------------------------*
     A          R DSP91
     A*%%TS  SD  20180620  092708  I0777       REL-V7R3M0  5770-WDS
     A                                      OVERLAY
     A                                      PROTECT
     A            D9ERR         70A  O 23  2COLOR(YLW)
     A                                 24  2'F3'
     A                                      DSPATR(RI)
     A                                 24  5'BACK'
     A                                 24 17'F5'
     A                                      DSPATR(RI)
     A                                 24 20'UPLOAD'
     A                                 24 35'PAGE UP/DOWN'
     A                                      DSPATR(RI)
     A*------------------------*
     A*------------------------*
     A          R SFL02                     SFL
     A*%%TS  SD  20220601  142541  I0777       REL-V7R3M0  5770-WDS
     A*------------------------*
     A            S2LIN#         4A  O  6  2COLOR(TRQ)
     A            L2SHDT         8Y 0O  6  7EDTWRD('    /  /  ')
     A                                      COLOR(WHT)
     A            S2INV#        14A  O  6 18
     A            S2MSG         47A  O  6 33
     A*---------------------------------------*
     A*  SUB FILE CONTROL                   *
     A*---------------------------------------*
     A          R SFLCT2                    SFLCTL(SFL02)
     A*%%TS  SD  20220601  142541  I0777       REL-V7R3M0  5770-WDS
     A                                      SFLSIZ(0017)
     A                                      SFLPAG(0016)
     A                                      CF03(03)
     A  72                                  SFLDSPCTL
     A  72                                  SFLDSP
     A  71                                  SFLCLR
     A N73                                  SFLEND(*MORE)
     A                                      OVERLAY
     A                                      PROTECT
     A*
     A                                  1  2'FMT AFFPW30'
     A                                  1 18'** INVOICE PRICE FILE ERROR INQ **'
     A                                      DSPATR(RI)
     A                                      COLOR(RED)
     A                                      DSPATR(BL)
     A                                  1 63DATE
     A                                      EDTWRD('0  .  .  ')
     A                                  1 72TIME
     A*
     A                                  3  3'DELIVERY CODE:'
     A                                      DSPATR(RI)
     A            XSUPP          4A  O  3 18COLOR(YLW)
     A            XSUPN         20O  O  3 23COLOR(YLW)
     A*
     A                                  5  2'Lin#'
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5  7'SHIP DATE '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 18'INVOICE#      '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A                                  5 33'Error Message                     -
     A                                                   '
     A                                      DSPATR(UL)
     A                                      COLOR(YLW)
     A*------------------------*
     A          R DSP99
     A*%%TS  SD  20180608  164548  I0777       REL-V7R3M0  5770-WDS
     A                                      OVERLAY
     A                                      PROTECT
     A            D9ERR         70A  O 23  2COLOR(YLW)
     A                                 24  2'F3'
     A                                      DSPATR(RI)
     A                                 24  5'BACK'
     A                                 24 21'PAGE UP/DOWN'
     A                                      DSPATR(RI)
